\page

{\footnote # IDH_ASM80386_03}
{\footnote $ Assembleur 80386 - MODES D'ADRESSAGE}
{\footnote K Assembleur 80386 modes adressage;immediat;registre;direct;indirect registre;base index deplacement;SIB scale index base;PC relatif;segment override;mode 16 32 bits}
\b\fs24 MODES D'ADRESSAGE \b0\fs20\par
\par
\par
\b 3.1 Vue d'ensemble \b0\par
\par
{\f1   Le 80386 dispose d'un jeu de modes d'adressage riche et regulier.}\par
{\f1   Chaque operande d'une instruction peut etre :}\par
\par
{\f1     - Une valeur immediate (constante codee dans l'instruction)}\par
{\f1     - Un registre (general, segment ou de controle)}\par
{\f1     - Un emplacement memoire designe par une adresse effective}\par
\par
{\f1   L'adresse effective (Effective Address, EA) est calculee a partir}\par
{\f1   d'une combinaison de :}\par
\par
{\f1     Base          : Un registre general 32 bits (EAX..ESP, EBP..EDI)}\par
{\f1     Index         : Un registre general 32 bits sauf ESP}\par
{\f1     Echelle       : Un facteur multiplicatif (1, 2, 4 ou 8)}\par
{\f1     Deplacement   : Une constante signee de 0, 8 ou 32 bits}\par
\par
{\f1   La formule generale de l'adresse effective est :}\par
\par
{\f1     EA = Base + (Index * Echelle) + Deplacement}\par
\par
{\f1   Chaque composant est optionnel. Les differentes combinaisons}\par
{\f1   donnent les modes d'adressage decrits ci-dessous.}\par
\par
{\f1   En mode reel, le calcul d'adresse physique ajoute la base du}\par
{\f1   segment (segment << 4). En mode protege, la base du segment est}\par
{\f1   obtenue via le descripteur reference par le selecteur de segment.}\par
\par
\par
\b 3.2 Adressage immediat \b0\par
\par
{\f1   L'operande est une constante codee directement dans l'instruction.}\par
{\f1   Il ne peut etre utilise que comme operande source (jamais comme}\par
{\f1   destination).}\par
\par
{\f1   Syntaxe :}\par
{\f1     MOV  reg, imm          ; charger une constante dans un registre}\par
{\f1     ADD  reg, imm          ; additionner une constante}\par
{\f1     CMP  reg, imm          ; comparer avec une constante}\par
{\f1     PUSH imm               ; empiler une constante (nouveau 80386)}\par
\par
{\f1   Tailles possibles :}\par
{\f1     imm8   : Constante de 8 bits (-128 a +127 ou 0 a 255)}\par
{\f1     imm16  : Constante de 16 bits (-32768 a +32767 ou 0 a 65535)}\par
{\f1     imm32  : Constante de 32 bits (nouveau 80386)}\par
\par
{\f1   Exemples :}\par
{\f1     MOV  EAX, 42                   ; EAX = 42 (imm32)}\par
{\f1     MOV  AL, 0FFh                  ; AL = 255 (imm8)}\par
{\f1     ADD  ECX, 1000                 ; ECX += 1000}\par
{\f1     PUSH 12345678h                 ; empiler une constante 32 bits}\par
{\f1     CMP  BYTE PTR [ESI], 0        ; comparer un octet avec zero}\par
{\f1     AND  EAX, 0FF00FF00h          ; masquage de bits}\par
\par
{\f1   Remarques :}\par
{\f1     - Les constantes 8 bits sont souvent etendues avec signe a}\par
{\f1       32 bits, ce qui donne des instructions plus compactes}\par
{\f1     - PUSH imm est une nouveaute du 80186, etendue a 32 bits}\par
{\f1       sur le 80386}\par
{\f1     - Les formes avec AL/AX/EAX ont un codage special plus court}\par
\par
\par
\b 3.3 Adressage par registre \b0\par
\par
{\f1   L'operande est un registre du processeur. C'est le mode le plus}\par
{\f1   rapide car aucun acces memoire n'est necessaire.}\par
\par
{\f1   Syntaxe :}\par
{\f1     MOV  reg1, reg2        ; copier un registre dans un autre}\par
{\f1     ADD  reg1, reg2        ; additionner deux registres}\par
{\f1     XCHG reg1, reg2        ; echanger deux registres}\par
\par
{\f1   Registres utilisables :}\par
{\f1     32 bits : EAX, EBX, ECX, EDX, ESI, EDI, EBP, ESP}\par
{\f1     16 bits : AX, BX, CX, DX, SI, DI, BP, SP}\par
{\f1      8 bits : AL, AH, BL, BH, CL, CH, DL, DH}\par
{\f1     Segment : CS, DS, ES, FS, GS, SS}\par
\par
{\f1   Exemples :}\par
{\f1     MOV  EAX, EBX                  ; EAX = EBX}\par
{\f1     ADD  ECX, EDX                  ; ECX += EDX}\par
{\f1     XOR  EAX, EAX                 ; EAX = 0 (idiome classique)}\par
{\f1     MOV  DS, AX                   ; charger un selecteur de segment}\par
{\f1     MOVZX EAX, CL                 ; etendre CL (8 bits) vers EAX}\par
{\f1     PUSH EBP                      ; sauvegarder le pointeur de base}\par
\par
{\f1   Remarques :}\par
{\f1     - Les operations registre-registre s'executent en 1 cycle}\par
{\f1       (pas d'acces memoire)}\par
{\f1     - Les melanges de taille (ex: MOV EAX, BX) ne sont pas}\par
{\f1       autorises directement; utiliser MOVZX ou MOVSX}\par
{\f1     - ESP ne peut pas etre utilise comme registre d'index}\par
\par
\par
\b 3.4 Adressage direct (deplacement seul) \b0\par
\par
{\f1   L'adresse effective est une constante de 32 bits codee dans}\par
{\f1   l'instruction. Elle designe directement un emplacement memoire.}\par
\par
{\f1   Formule : EA = Deplacement32}\par
\par
{\f1   Syntaxe :}\par
{\f1     MOV  reg, [depl32]     ; charger depuis une adresse fixe}\par
{\f1     MOV  [depl32], reg     ; stocker a une adresse fixe}\par
\par
{\f1   Exemples :}\par
{\f1     MOV  EAX, [00401000h]          ; lire le DWORD a l'adresse 401000h}\par
{\f1     MOV  EAX, DWORD PTR [_var]     ; lire la variable globale _var}\par
{\f1     MOV  BYTE PTR [_flag], 1       ; mettre _flag a 1}\par
{\f1     INC  DWORD PTR [_compteur]     ; incrementer un compteur global}\par
{\f1     FLD  QWORD PTR [_pi]           ; charger un flottant 64 bits}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Acces aux variables globales}\par
{\f1     - Acces aux constantes en memoire}\par
{\f1     - Acces aux tables de donnees a adresse fixe}\par
\par
{\f1   Remarques :}\par
{\f1     - Sur le 80386, le deplacement est toujours 32 bits en mode}\par
{\f1       protege (contrairement au 16 bits du 8086)}\par
{\f1     - L'assembleur traduit automatiquement les noms de variables}\par
{\f1       en adresses (deplacements)}\par
\par
\par
\b 3.5 Adressage indirect par registre \b0\par
\par
{\f1   L'adresse effective est contenue dans un registre. Le registre}\par
{\f1   sert de pointeur vers l'emplacement memoire.}\par
\par
{\f1   Formule : EA = [Registre]}\par
\par
{\f1   Syntaxe :}\par
{\f1     MOV  reg, [base_reg]   ; charger depuis l'adresse dans base_reg}\par
{\f1     MOV  [base_reg], reg   ; stocker a l'adresse dans base_reg}\par
\par
{\f1   Registres de base utilisables :}\par
{\f1     EAX, EBX, ECX, EDX, ESI, EDI, EBP, ESP}\par
{\f1     (tous les registres generaux 32 bits)}\par
\par
{\f1   Segment implicite :}\par
{\f1     [EBP] et [ESP] utilisent SS par defaut}\par
{\f1     Tous les autres utilisent DS par defaut}\par
{\f1     Peut etre surcharge par un prefixe de segment (ex: ES:[EAX])}\par
\par
{\f1   Exemples :}\par
{\f1     MOV  EAX, [EBX]                ; lire le DWORD pointe par EBX}\par
{\f1     MOV  [ESI], ECX                ; stocker ECX a l'adresse dans ESI}\par
{\f1     MOV  AL, [EDI]                 ; lire un octet pointe par EDI}\par
{\f1     CALL [EAX]                     ; appel indirect via un pointeur}\par
{\f1     JMP  [EBX]                     ; saut indirect via un pointeur}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Dereferencement de pointeurs}\par
{\f1     - Parcours de listes chainees}\par
{\f1     - Appels de fonctions via des tables de pointeurs (vtable)}\par
\par
{\f1   Remarques :}\par
{\f1     - Sur le 8086, seuls BX, SI, DI et BP pouvaient etre utilises}\par
{\f1       comme registres de base. Le 80386 autorise tous les registres}\par
{\f1       generaux, ce qui simplifie grandement la programmation}\par
{\f1     - [ESP] utilise un octet SIB supplementaire dans l'encodage}\par
\par
\par
\b 3.6 Adressage base + deplacement \b0\par
\par
{\f1   L'adresse effective est la somme d'un registre de base et d'un}\par
{\f1   deplacement (constante). C'est le mode le plus utilise pour}\par
{\f1   acceder aux variables locales et aux parametres de fonctions.}\par
\par
{\f1   Formule : EA = Base + Deplacement}\par
\par
{\f1   Syntaxe :}\par
{\f1     MOV  reg, [base_reg + depl]}\par
{\f1     MOV  [base_reg + depl], reg}\par
\par
{\f1   Tailles de deplacement :}\par
{\f1     disp8  : Deplacement signe de 8 bits (-128 a +127)}\par
{\f1     disp32 : Deplacement signe de 32 bits}\par
\par
{\f1   L'assembleur choisit automatiquement la taille la plus compacte.}\par
\par
{\f1   Exemples :}\par
{\f1     MOV  EAX, [EBP+8]             ; 1er parametre (convention cdecl)}\par
{\f1     MOV  EAX, [EBP+12]            ; 2e parametre}\par
{\f1     MOV  EAX, [EBP-4]             ; 1ere variable locale}\par
{\f1     MOV  EAX, [EBP-8]             ; 2e variable locale}\par
{\f1     MOV  EAX, [EBX+16]            ; champ d'une structure}\par
{\f1     MOV  AL, [ESI+3]              ; 4e octet d'un buffer}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Acces aux parametres de fonctions via EBP}\par
{\f1       (convention : [EBP+8], [EBP+12], [EBP+16], ...)}\par
{\f1     - Acces aux variables locales via EBP}\par
{\f1       (convention : [EBP-4], [EBP-8], [EBP-12], ...)}\par
{\f1     - Acces aux champs d'une structure via un pointeur}\par
{\f1     - Acces aux elements d'un tableau via un pointeur de base}\par
\par
{\f1   Organisation typique du cadre de pile (stack frame) :}\par
\par
{\f1     [EBP+16]   3e parametre}\par
{\f1     [EBP+12]   2e parametre}\par
{\f1     [EBP+8]    1er parametre}\par
{\f1     [EBP+4]    Adresse de retour (empilee par CALL)}\par
{\f1     [EBP+0]    Ancien EBP (empile par PUSH EBP)}\par
{\f1     [EBP-4]    1ere variable locale}\par
{\f1     [EBP-8]    2e variable locale}\par
\par
\par
\b 3.7 Adressage indexe (base + index) \b0\par
\par
{\f1   L'adresse effective est la somme d'un registre de base et d'un}\par
{\f1   registre d'index. Ce mode est utile pour le parcours de tableaux}\par
{\f1   avec un pointeur de base fixe et un index variable.}\par
\par
{\f1   Formule : EA = Base + Index}\par
\par
{\f1   Syntaxe :}\par
{\f1     MOV  reg, [base_reg + index_reg]}\par
{\f1     MOV  [base_reg + index_reg], reg}\par
\par
{\f1   Le registre d'index peut etre n'importe quel registre general}\par
{\f1   32 bits sauf ESP.}\par
\par
{\f1   Exemples :}\par
{\f1     MOV  EAX, [EBX+ESI]           ; tableau pointe par EBX, index ESI}\par
{\f1     MOV  [EDI+ECX], AL            ; ecrire un octet dans un buffer}\par
{\f1     MOV  EAX, [EBP+ECX]           ; variable locale indexee}\par
{\f1     LEA  EAX, [EBX+EDX]           ; calculer une adresse sans lire}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Parcours de tableaux (base = debut du tableau, index = offset)}\par
{\f1     - Copie de blocs memoire element par element}\par
\par
\par
\b 3.8 Adressage indexe avec echelle (SIB) \b0\par
\par
{\f1   C'est le mode d'adressage le plus puissant du 80386, nouveau}\par
{\f1   par rapport au 8086/80286. L'adresse effective combine un registre}\par
{\f1   de base, un registre d'index multiplie par un facteur d'echelle,}\par
{\f1   et un deplacement optionnel.}\par
\par
{\f1   Formule : EA = Base + (Index * Echelle) + Deplacement}\par
\par
{\f1   Facteurs d'echelle possibles : 1, 2, 4 ou 8}\par
\par
{\f1   L'octet SIB (Scale-Index-Base) est un octet supplementaire dans}\par
{\f1   l'encodage de l'instruction qui specifie les trois composants :}\par
{\f1     - Bits 7-6 : Echelle (00=1, 01=2, 10=4, 11=8)}\par
{\f1     - Bits 5-3 : Registre d'index (sauf ESP = pas d'index)}\par
{\f1     - Bits 2-0 : Registre de base}\par
\par
{\f1   Syntaxe :}\par
{\f1     MOV  reg, [base + index * echelle]}\par
{\f1     MOV  reg, [base + index * echelle + depl]}\par
{\f1     MOV  reg, [index * echelle + depl]        ; sans base}\par
\par
{\f1   Exemples :}\par
\par
{\f1     Acces a un tableau de DWORD (4 octets par element) :}\par
{\f1       MOV  EAX, [EBX+ECX*4]       ; tab[i], EBX=tab, ECX=i}\par
{\f1       MOV  EAX, [_tab+ECX*4]      ; tab[i], adresse directe}\par
\par
{\f1     Acces a un tableau de WORD (2 octets par element) :}\par
{\f1       MOV  AX, [ESI+EDI*2]        ; tab[i], ESI=tab, EDI=i}\par
\par
{\f1     Acces a un tableau de QWORD (8 octets par element) :}\par
{\f1       FLD  QWORD PTR [EBX+ECX*8]  ; tab_double[i]}\par
\par
{\f1     Acces a un champ dans un tableau de structures :}\par
{\f1       MOV  EAX, [EBX+ECX*8+4]     ; tab[i].champ2}\par
{\f1                                    ; (structures de 8 octets,}\par
{\f1                                    ;  champ2 a l'offset 4)}\par
\par
{\f1     Table de sauts (jump table) :}\par
{\f1       JMP  [_jtable+EAX*4]        ; saut indirect indexe}\par
\par
{\f1     Calcul d'adresse avec LEA :}\par
{\f1       LEA  EAX, [EAX+EAX*4]       ; EAX = EAX * 5}\par
{\f1       LEA  EAX, [EBX+ECX*8+12]    ; calcul sans acces memoire}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Acces aux tableaux de types scalaires (WORD, DWORD, QWORD)}\par
{\f1       sans avoir a calculer l'offset manuellement}\par
{\f1     - Acces aux champs dans des tableaux de structures}\par
{\f1     - Tables de sauts pour les instructions switch/case}\par
{\f1     - Calculs arithmetiques rapides via LEA (multiplication}\par
{\f1       par 2, 3, 4, 5, 8, 9 sans utiliser MUL/IMUL)}\par
\par
{\f1   Correspondance echelle / type de donnees :}\par
{\f1     Echelle 1 : BYTE (octets, caracteres)}\par
{\f1     Echelle 2 : WORD (entiers 16 bits, Unicode)}\par
{\f1     Echelle 4 : DWORD (entiers 32 bits, pointeurs, float)}\par
{\f1     Echelle 8 : QWORD (entiers 64 bits, double)}\par
\par
\par
\b 3.9 Adressage relatif (branchements) \b0\par
\par
{\f1   Les instructions de branchement (JMP, Jcc, CALL, LOOP) utilisent}\par
{\f1   un deplacement relatif par rapport a l'adresse de l'instruction}\par
{\f1   suivante. Ce mode n'est pas utilise pour les operandes memoire}\par
{\f1   mais uniquement pour le calcul de la cible des sauts.}\par
\par
{\f1   Formule : Cible = EIP + Deplacement}\par
\par
{\f1   Tailles de deplacement :}\par
{\f1     rel8  : Deplacement signe de 8 bits (-128 a +127 octets)}\par
{\f1             Utilise pour les sauts courts (short jump)}\par
{\f1     rel32 : Deplacement signe de 32 bits (nouveau 80386)}\par
{\f1             Utilise pour les sauts proches (near jump)}\par
\par
{\f1   Exemples :}\par
{\f1     JMP  SHORT _boucle             ; saut court (rel8)}\par
{\f1     JMP  NEAR PTR _fonction        ; saut proche (rel32)}\par
{\f1     JE   _si_egal                  ; saut conditionnel (rel8 ou rel32)}\par
{\f1     CALL _ma_procedure             ; appel relatif (rel32)}\par
{\f1     LOOP _boucle                   ; boucle (rel8 uniquement)}\par
{\f1     JECXZ _vide                    ; saut si ECX=0 (rel8)}\par
\par
{\f1   Remarques :}\par
{\f1     - Les sauts conditionnels (Jcc) n'acceptaient que rel8 sur le}\par
{\f1       8086. Le 80386 ajoute les sauts conditionnels rel32}\par
{\f1       (prefixe 0Fh), ce qui elimine le besoin de sauts}\par
{\f1       intermediaires pour les branches distantes}\par
{\f1     - L'adressage relatif rend le code relogeable (position-}\par
{\f1       independent) car les adresses ne sont pas absolues}\par
{\f1     - LOOP et JECXZ n'existent qu'en version rel8}\par
\par
\par
\b 3.10 Prefixes de surcharge de segment \b0\par
\par
{\f1   Par defaut, chaque mode d'adressage utilise un registre de}\par
{\f1   segment implicite :}\par
\par
{\f1     DS : Pour la plupart des acces memoire (MOV, ADD, etc.)}\par
{\f1     SS : Pour les acces via EBP ou ESP ([EBP+x], [ESP+x])}\par
{\f1     CS : Pour le fetch des instructions (implicite)}\par
{\f1     ES : Pour la destination des instructions de chaines}\par
{\f1          (MOVS, STOS, SCAS, CMPS via ES:[EDI])}\par
\par
{\f1   Un prefixe de segment peut surcharger le segment par defaut :}\par
\par
{\f1     MOV  EAX, ES:[EBX]            ; utiliser ES au lieu de DS}\par
{\f1     MOV  EAX, FS:[0]              ; utiliser FS (ex: TEB Windows)}\par
{\f1     MOV  EAX, GS:[EDI+8]          ; utiliser GS}\par
{\f1     MOV  EAX, CS:[_table]         ; lire dans le segment de code}\par
{\f1     MOV  EAX, SS:[ECX+4]          ; forcer le segment de pile}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - FS : Acces au Thread Environment Block (TEB) sous Windows}\par
{\f1       (FS:[0] = chaine SEH, FS:[18h] = pointeur TEB)}\par
{\f1     - GS : Utilise par certains systemes d'exploitation}\par
{\f1     - ES : Destination implicite pour les instructions de chaines}\par
{\f1     - CS : Acces a des donnees dans le segment de code (tables}\par
{\f1       de constantes dans du code relogeable)}\par
\par
{\f1   En mode FLAT 32 bits (Windows, Linux), les segments CS, DS, ES}\par
{\f1   et SS pointent generalement sur le meme espace lineaire. Les}\par
{\f1   prefixes de segment sont alors rarement necessaires, sauf pour}\par
{\f1   FS et GS qui sont souvent configures differemment.}\par
\par
\par
\b 3.11 Resume et tableau comparatif \b0\par
\par
{\f1   Mode                     Syntaxe                  Formule EA}\par
{\f1   -----------------------  -----------------------  ---------------------}\par
{\f1   Immediat                 MOV EAX, 42              (pas d'EA, source)}\par
{\f1   Registre                 MOV EAX, EBX             (pas d'EA)}\par
{\f1   Direct                   MOV EAX, [_var]          EA = depl32}\par
{\f1   Indirect registre        MOV EAX, [EBX]           EA = base}\par
{\f1   Base + deplacement       MOV EAX, [EBP+8]         EA = base + depl}\par
{\f1   Base + index             MOV EAX, [EBX+ESI]       EA = base + index}\par
{\f1   Index * echelle + depl   MOV EAX, [ECX*4+_tab]    EA = idx*s + depl}\par
{\f1   Base + index * echelle   MOV EAX, [EBX+ECX*4]     EA = base + idx*s}\par
{\f1   Complet (SIB)            MOV EAX, [EBX+ECX*4+8]   EA = base+idx*s+depl}\par
{\f1   Relatif (sauts)          JMP _label               cible = EIP + rel}\par
\par
{\f1   Comparaison avec le 8086 :}\par
\par
{\f1   Caracteristique             8086              80386}\par
{\f1   --------------------------  ----------------  ----------------------}\par
{\f1   Registres de base           BX, BP            EAX..EDI (tous les 8)}\par
{\f1   Registres d'index           SI, DI            EAX..EDI sauf ESP}\par
{\f1   Facteur d'echelle           Non               1, 2, 4, 8}\par
{\f1   Taille deplacement          0, 8, 16 bits     0, 8, 32 bits}\par
{\f1   Taille adresse effective    16 bits            32 bits}\par
{\f1   Sauts conditionnels         rel8 uniquement    rel8 et rel32}\par
{\f1   Segments supplementaires    Non                FS, GS}\par
{\f1   Octet SIB                   Non               Oui}\par
\par
\par
