\page

{\footnote # IDH_ASM80386_09}
{\footnote $ Assembleur 80386 - OPTIMISATION POSSIBLE DU 80386}
{\footnote K Assembleur 80386 optimisation;pipeline;cache;pairing;alignement;LEA arithmetique;instructions specialisees}
\b\fs24 OPTIMISATION POSSIBLE DU 80386 \b0\fs20\par
\par
{\f1   Cette section decrit les differents niveaux d'optimisation applicables}\par
{\f1   lors de la generation de code assembleur ciblant le processeur 80386.}\par
{\f1   Les niveaux sont classes par ordre croissant de complexite et d'impact}\par
{\f1   sur les performances.}\par
\par
\par
\b 9.1 Niveau 0 - Aucune optimisation (code naif) \b0\par
\par
{\f1   Le code est genere de maniere directe, instruction par instruction,}\par
{\f1   sans aucune tentative d'amelioration. Chaque operation du langage}\par
{\f1   source est traduite independamment.}\par
\par
{\f1   Caracteristiques :}\par
{\f1     - Chaque variable est lue depuis la memoire avant utilisation}\par
{\f1     - Chaque resultat est ecrit en memoire immediatement}\par
{\f1     - Pas de reutilisation des registres entre instructions}\par
{\f1     - Les expressions sont evaluees via la pile (PUSH/POP)}\par
{\f1     - Les branchements sont generes sans analyse de flot}\par
\par
{\f1   Exemple (a = b + c) :}\par
{\f1       MOV  EAX, DWORD PTR [_b]      ; charger b}\par
{\f1       PUSH EAX                       ; sauvegarder sur la pile}\par
{\f1       MOV  EAX, DWORD PTR [_c]      ; charger c}\par
{\f1       POP  EBX                       ; recuperer b}\par
{\f1       ADD  EAX, EBX                  ; additionner}\par
{\f1       MOV  DWORD PTR [_a], EAX      ; stocker resultat}\par
\par
{\f1   Avantage  : Simplicite de generation, debogage facile}\par
{\f1   Inconvenient : Code volumineux et lent}\par
\par
\par
\b 9.2 Niveau 1 - Optimisations de base (peephole) \b0\par
\par
{\f1   Des motifs d'instructions redondants sont detectes et remplaces}\par
{\f1   par des sequences plus courtes apres generation. C'est une}\par
{\f1   optimisation locale, limitee a une fenetre de quelques instructions.}\par
\par
{\f1   Techniques appliquees :}\par
{\f1     - Suppression des PUSH/POP consecutifs sur le meme registre}\par
{\f1         PUSH EAX / POP EAX  ->  (supprime)}\par
{\f1     - Remplacement de MOV reg, 0 par XOR reg, reg}\par
{\f1         MOV EAX, 0  ->  XOR EAX, EAX}\par
{\f1     - Suppression des MOV reg, reg identiques}\par
{\f1         MOV EAX, EAX  ->  (supprime)}\par
{\f1     - Remplacement de multiplications par des puissances de 2}\par
{\f1         IMUL EAX, 4  ->  SHL EAX, 2}\par
{\f1     - Simplification des branchements sur le prochain label}\par
{\f1         JMP label_suivant / label_suivant:  ->  label_suivant:}\par
{\f1     - Remplacement de IMUL EAX, 1 par rien}\par
{\f1     - Remplacement de ADD EAX, 0 par rien}\par
{\f1     - Utilisation de LEA pour des calculs d'adresses combines}\par
{\f1         MOV EAX, [_b] / ADD EAX, [_c]  ->  LEA EAX, [EBX+ECX]}\par
\par
{\f1   Exemple ameliore (a = b + c) :}\par
{\f1       MOV  EAX, DWORD PTR [_b]}\par
{\f1       ADD  EAX, DWORD PTR [_c]}\par
{\f1       MOV  DWORD PTR [_a], EAX}\par
\par
{\f1   Avantage  : Gains significatifs pour un cout d'implementation faible}\par
{\f1   Inconvenient : Optimisation locale uniquement}\par
\par
\par
\b 9.3 Niveau 2 - Allocation de registres \b0\par
\par
{\f1   Les variables les plus utilisees sont conservees dans des registres}\par
{\f1   du processeur au lieu d'etre rechargees depuis la memoire a chaque}\par
{\f1   acces. Cela reduit considerablement les acces memoire.}\par
\par
{\f1   Techniques appliquees :}\par
{\f1     - Analyse de la duree de vie des variables (liveness analysis)}\par
{\f1     - Attribution de registres aux variables locales actives}\par
{\f1     - Registres disponibles pour l'allocation : EAX, EBX, ECX, EDX,}\par
{\f1       ESI, EDI (EBP et ESP reserves pour la pile)}\par
{\f1     - Spilling : si plus de variables actives que de registres, les}\par
{\f1       moins utilisees sont releguees en memoire (pile)}\par
{\f1     - Propagation des constantes dans les registres}\par
{\f1     - Elimination des rechargements inutiles (un registre contenant}\par
{\f1       deja la bonne valeur n'est pas recharge)}\par
\par
{\f1   Exemple avec allocation (boucle i = 0 a 99, somme += i) :}\par
{\f1       XOR  ECX, ECX                  ; i = 0, dans ECX}\par
{\f1       XOR  EAX, EAX                  ; somme = 0, dans EAX}\par
{\f1     _boucle:}\par
{\f1       ADD  EAX, ECX                  ; somme += i}\par
{\f1       INC  ECX                       ; i++}\par
{\f1       CMP  ECX, 100                  ; i < 100 ?}\par
{\f1       JL   _boucle}\par
{\f1       MOV  DWORD PTR [_somme], EAX   ; stocker resultat final}\par
\par
{\f1   Avantage  : Reduction massive des acces memoire}\par
{\f1   Inconvenient : Complexite d'implementation (analyse de graphe)}\par
\par
\par
\b 9.4 Niveau 3 - Optimisations de boucles \b0\par
\par
{\f1   Les boucles sont les zones les plus critiques pour les performances.}\par
{\f1   Ce niveau applique des transformations specifiques aux boucles.}\par
\par
{\f1   Techniques appliquees :}\par
{\f1     - Deplacement du code invariant hors de la boucle}\par
{\f1       (loop-invariant code motion) : les calculs dont le resultat}\par
{\f1       ne change pas a chaque iteration sont places avant la boucle}\par
{\f1     - Reduction de force (strength reduction) : remplacement des}\par
{\f1       multiplications par des additions incrementales}\par
{\f1         i * 4  ->  compteur incremente de 4 a chaque iteration}\par
{\f1     - Deroulement de boucles (loop unrolling) : le corps de la}\par
{\f1       boucle est duplique pour reduire le cout des branchements}\par
{\f1     - Inversion de boucle (loop inversion) : transformation d'une}\par
{\f1       boucle WHILE en DO-WHILE precedee d'un test, pour eliminer}\par
{\f1       un branchement par iteration}\par
{\f1     - Utilisation de LOOP/REP pour les boucles simples}\par
{\f1     - Fusion de boucles adjacentes ayant les memes bornes}\par
\par
{\f1   Exemple de deroulement (boucle de copie, 4 elements par iteration) :}\par
{\f1       MOV  ECX, _count}\par
{\f1       SHR  ECX, 2                    ; count / 4}\par
{\f1     _boucle:}\par
{\f1       MOV  EAX, [ESI]}\par
{\f1       MOV  [EDI], EAX}\par
{\f1       MOV  EAX, [ESI+4]}\par
{\f1       MOV  [EDI+4], EAX}\par
{\f1       MOV  EAX, [ESI+8]}\par
{\f1       MOV  [EDI+8], EAX}\par
{\f1       MOV  EAX, [ESI+12]}\par
{\f1       MOV  [EDI+12], EAX}\par
{\f1       ADD  ESI, 16}\par
{\f1       ADD  EDI, 16}\par
{\f1       DEC  ECX}\par
{\f1       JNZ  _boucle}\par
\par
{\f1   Avantage  : Amelioration majeure des boucles intensives}\par
{\f1   Inconvenient : Augmentation de la taille du code}\par
\par
\par
\b 9.5 Niveau 4 - Optimisations globales et specifiques au 80386 \b0\par
\par
{\f1   Ce niveau regroupe les optimisations avancees qui tirent parti}\par
{\f1   des specificites du pipeline et du cache du 80386, ainsi que des}\par
{\f1   analyses inter-procedurales.}\par
\par
{\f1   Techniques appliquees :}\par
\par
{\f1     Ordonnancement des instructions (instruction scheduling) :}\par
{\f1       - Eviter les blocages de pipeline en intercalant des}\par
{\f1         instructions independantes entre une lecture memoire et}\par
{\f1         son utilisation}\par
{\f1       - Le 80386 a un pipeline a 6 etapes (Bus Interface, Code}\par
{\f1         Prefetch, Instruction Decode, Execution, Segment, Page)}\par
{\f1       - Eviter les dependances de donnees consecutives}\par
\par
{\f1     Alignement des donnees et du code :}\par
{\f1       - Aligner les donnees 32 bits sur des adresses multiples de 4}\par
{\f1         (ALIGN 4) pour eviter les penalites d'acces non alignes}\par
{\f1       - Aligner les cibles de branchement sur des adresses paires}\par
{\f1         ou multiples de 4 pour optimiser le prefetch}\par
{\f1       - Aligner le debut des procedures sur des limites de 16 octets}\par
\par
{\f1     Utilisation optimale de LEA :}\par
{\f1       - LEA permet de calculer des expressions complexes en une}\par
{\f1         instruction sans affecter les drapeaux}\par
{\f1       - LEA EAX, [EBX+ECX*4+8] combine addition et multiplication}\par
\par
{\f1     Optimisations specifiques au 80386 :}\par
{\f1       - Preferer MOVZX/MOVSX aux sequences XOR+MOV pour les}\par
{\f1         extensions de taille (8 vers 32 bits, 16 vers 32 bits)}\par
{\f1       - Utiliser les modes d'adressage bases+index*echelle}\par
{\f1         (SIB byte) pour les acces aux tableaux}\par
{\f1       - Utiliser CDQ au lieu de XOR EDX,EDX / OR EAX,EAX / ...}\par
{\f1         avant IDIV pour l'extension de signe}\par
{\f1       - Preferer TEST reg, reg a CMP reg, 0 pour tester si nul}\par
{\f1       - Preferer INC/DEC a ADD/SUB 1 (plus compact, 1 octet)}\par
{\f1       - Eviter les prefixes de taille d'operande (melange 16/32}\par
{\f1         bits) qui causent des penalites de decodage}\par
\par
{\f1     Optimisations inter-procedurales :}\par
{\f1       - Inlining de petites fonctions (expansion en ligne)}\par
{\f1       - Propagation des constantes a travers les appels}\par
{\f1       - Elimination du code mort (dead code elimination)}\par
{\f1       - Optimisation des appels terminaux (tail call optimization)}\par
\par
{\f1   Avantage  : Performance maximale pour le 80386}\par
{\f1   Inconvenient : Complexite elevee, temps de compilation accru}\par
\par
\par
