{\footnote # IDH_ASM80386_06}
{\footnote $ Assembleur 80386 - MODE PROTEGE ET DESCRIPTEURS}
{\footnote K Assembleur 80386 mode protege descripteurs;GDT LDT IDT;segment selector;descripteur segment code donnee systeme;privilege level CPL DPL RPL;TSS task state segment;call gate trap gate interrupt gate task gate}
\b\fs24 MODE PROTEGE ET DESCRIPTEURS \b0\fs20\par
\par
\par
\b 6.1 Vue d'ensemble du mode protege \b0\par
\par
{\f1   Le 80386 peut fonctionner dans trois modes principaux :}\par
\par
{\f1   1. Mode reel (Real Mode)}\par
{\f1      - Compatible 8086. Segments de 64 Ko max.}\par
{\f1      - Adressage : segment << 4 + offset = adresse physique (20 bits).}\par
{\f1      - Pas de protection memoire ni de privileges.}\par
{\f1      - C'est le mode au demarrage (reset).}\par
\par
{\f1   2. Mode protege (Protected Mode)}\par
{\f1      - Adressage 32 bits (4 Go d'espace lineaire).}\par
{\f1      - Segments decrits par des descripteurs dans des tables.}\par
{\f1      - Protection memoire par niveaux de privilege (rings 0 a 3).}\par
{\f1      - Pagination optionnelle (adresses lineaires -> physiques).}\par
{\f1      - Support du multitache materiel (TSS).}\par
\par
{\f1   3. Mode virtuel 8086 (Virtual 8086 Mode, V86)}\par
{\f1      - Sous-mode du mode protege.}\par
{\f1      - Permet d'executer des programmes 8086 dans un environnement}\par
{\f1        protege, sous le controle d'un moniteur en ring 0.}\par
{\f1      - Active par le bit VM (bit 17) du registre EFLAGS.}\par
\par
{\f1   Le mode protege est le mode de fonctionnement principal du 80386}\par
{\f1   pour les systemes d'exploitation modernes. Il offre :}\par
{\f1     - Un espace d'adressage de 4 Go par processus}\par
{\f1     - L'isolation des processus par la segmentation et la pagination}\par
{\f1     - Quatre niveaux de privilege pour le controle d'acces}\par
{\f1     - Un mecanisme de commutation de taches (task switching)}\par
{\f1     - La gestion des interruptions et exceptions via l'IDT}\par
\par
\par
\b 6.2 Descripteurs de segments \b0\par
\par
{\f1   En mode protege, chaque segment de memoire est decrit par un}\par
{\f1   descripteur de 8 octets (64 bits). Les descripteurs contiennent}\par
{\f1   toutes les informations necessaires pour definir un segment :}\par
{\f1   son adresse de base, sa limite, son type et ses droits d'acces.}\par
\par
{\f1   6.2.1 Format general d'un descripteur de segment}\par
\par
{\f1   Un descripteur occupe 8 octets consecutifs en memoire.}\par
{\f1   La disposition est la suivante (les octets sont numerotes 0 a 7) :}\par
\par
{\f1   Octet 7     Octet 6     Octet 5     Octet 4}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
{\f1   |Base    |  |G|D|0|AVL|  |P|DPL|S|  |Base    |}\par
{\f1   |[31:24] |  |Lim[19:16]| |  Type |  |[23:16] |}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
\par
{\f1   Octet 3     Octet 2     Octet 1     Octet 0}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
{\f1   |  Base  |  |  Base  |  | Limite |  | Limite |}\par
{\f1   | [15:8] |  | [7:0]  |  | [15:8] |  | [7:0]  |}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
\par
{\f1   Champs du descripteur :}\par
\par
{\f1   Base (32 bits)   : Adresse lineaire de debut du segment.}\par
{\f1                      Repartie dans les octets 2-3 (bits 0-15),}\par
{\f1                      octet 4 (bits 16-23) et octet 7 (bits 24-31).}\par
\par
{\f1   Limite (20 bits) : Taille du segment - 1.}\par
{\f1                      Repartie dans les octets 0-1 (bits 0-15) et}\par
{\f1                      les bits 0-3 de l'octet 6 (bits 16-19).}\par
{\f1                      Avec G=0 : en octets (max 1 Mo).}\par
{\f1                      Avec G=1 : en pages de 4 Ko (max 4 Go).}\par
\par
{\f1   G (bit 7, octet 6) : Granularite}\par
{\f1     0 = Limite en octets (resolution a l'octet)}\par
{\f1     1 = Limite en pages de 4096 octets}\par
\par
{\f1   D/B (bit 6, octet 6) : Taille par defaut}\par
{\f1     Pour un segment de code :}\par
{\f1       0 = Operandes et adresses 16 bits par defaut}\par
{\f1       1 = Operandes et adresses 32 bits par defaut}\par
{\f1     Pour un segment de pile (SS) :}\par
{\f1       0 = SP 16 bits}\par
{\f1       1 = ESP 32 bits}\par
\par
{\f1   AVL (bit 4, octet 6) : Disponible pour le systeme d'exploitation.}\par
{\f1     Le processeur ne l'utilise pas.}\par
\par
{\f1   P (bit 7, octet 5) : Present}\par
{\f1     1 = Le segment est present en memoire}\par
{\f1     0 = Le segment n'est pas present (genere #NP si on y accede)}\par
\par
{\f1   DPL (bits 6-5, octet 5) : Descriptor Privilege Level}\par
{\f1     Niveau de privilege du segment (0 a 3).}\par
{\f1     0 = plus privilegie (noyau), 3 = moins privilegie (utilisateur).}\par
\par
{\f1   S (bit 4, octet 5) : Type de descripteur}\par
{\f1     1 = Descripteur de segment (code ou donnees)}\par
{\f1     0 = Descripteur systeme (TSS, LDT, porte)}\par
\par
{\f1   Type (bits 3-0, octet 5) : Sous-type du segment}\par
{\f1     Depend du bit S. Voir ci-dessous.}\par
\par
{\f1   6.2.2 Types de descripteurs de segments (S=1)}\par
\par
{\f1   Pour les segments de donnees (bit 3 = 0) :}\par
\par
{\f1   Type  E  W  A  Description}\par
{\f1   ----  -  -  -  ------------------------------------}\par
{\f1   0000  0  0  0  Donnees, lecture seule}\par
{\f1   0001  0  0  1  Donnees, lecture seule, accede}\par
{\f1   0010  0  1  0  Donnees, lecture/ecriture}\par
{\f1   0011  0  1  1  Donnees, lecture/ecriture, accede}\par
{\f1   0100  1  0  0  Donnees, expand-down, lecture seule}\par
{\f1   0101  1  0  1  Donnees, expand-down, lecture seule, accede}\par
{\f1   0110  1  1  0  Donnees, expand-down, lecture/ecriture}\par
{\f1   0111  1  1  1  Donnees, expand-down, lecture/ecriture, accede}\par
\par
{\f1   E (Expand-Down) : Utilise pour les segments de pile.}\par
{\f1     Le segment grandit vers les adresses basses.}\par
{\f1     La limite definit l'adresse la plus basse accessible.}\par
\par
{\f1   W (Writable) : Indique si le segment est inscriptible.}\par
{\f1     Un segment de donnees sans W ne peut etre que lu.}\par
\par
{\f1   A (Accessed) : Mis a 1 par le processeur a chaque acces.}\par
{\f1     Utile pour le systeme d'exploitation (LRU, swapping).}\par
\par
{\f1   Pour les segments de code (bit 3 = 1) :}\par
\par
{\f1   Type  C  R  A  Description}\par
{\f1   ----  -  -  -  ------------------------------------}\par
{\f1   1000  0  0  0  Code, execute seul}\par
{\f1   1001  0  0  1  Code, execute seul, accede}\par
{\f1   1010  0  1  0  Code, execute/lecture}\par
{\f1   1011  0  1  1  Code, execute/lecture, accede}\par
{\f1   1100  1  0  0  Code, conforming, execute seul}\par
{\f1   1101  1  0  1  Code, conforming, execute seul, accede}\par
{\f1   1110  1  1  0  Code, conforming, execute/lecture}\par
{\f1   1111  1  1  1  Code, conforming, execute/lecture, accede}\par
\par
{\f1   C (Conforming) : Le segment de code peut etre appele depuis un}\par
{\f1     niveau de privilege inferieur sans changement de CPL.}\par
{\f1     Utile pour les bibliotheques partagees du systeme.}\par
\par
{\f1   R (Readable) : Le segment de code peut etre lu (en plus d'etre}\par
{\f1     execute). Necessaire pour lire des constantes dans le code.}\par
\par
{\f1   6.2.3 Types de descripteurs systeme (S=0)}\par
\par
{\f1   Type   Description}\par
{\f1   ----   --------------------------------------------------}\par
{\f1   0000   Reserve}\par
{\f1   0001   TSS 16 bits (disponible)}\par
{\f1   0010   LDT (Local Descriptor Table)}\par
{\f1   0011   TSS 16 bits (occupe/busy)}\par
{\f1   0100   Porte d'appel 16 bits (Call Gate)}\par
{\f1   0101   Porte de tache (Task Gate)}\par
{\f1   0110   Porte d'interruption 16 bits (Interrupt Gate)}\par
{\f1   0111   Porte de trappe 16 bits (Trap Gate)}\par
{\f1   1000   Reserve}\par
{\f1   1001   TSS 32 bits (disponible)       (nouveau 80386)}\par
{\f1   1010   Reserve}\par
{\f1   1011   TSS 32 bits (occupe/busy)       (nouveau 80386)}\par
{\f1   1100   Porte d'appel 32 bits           (nouveau 80386)}\par
{\f1   1101   Reserve}\par
{\f1   1110   Porte d'interruption 32 bits    (nouveau 80386)}\par
{\f1   1111   Porte de trappe 32 bits         (nouveau 80386)}\par
\par
\par
\b 6.3 Tables de descripteurs \b0\par
\par
{\f1   Les descripteurs sont regroupes dans des tables en memoire.}\par
{\f1   Le 80386 utilise trois types de tables :}\par
\par
{\f1   6.3.1 GDT (Global Descriptor Table)}\par
\par
{\f1   Table de descripteurs globale, partagee par toutes les taches.}\par
{\f1   Elle contient les descripteurs accessibles a l'ensemble du systeme :}\par
{\f1     - Segments de code et de donnees du noyau}\par
{\f1     - Segments partages entre les taches}\par
{\f1     - Descripteurs de TSS pour chaque tache}\par
{\f1     - Descripteurs de LDT pour chaque tache}\par
\par
{\f1   La GDT est localisee par le registre GDTR :}\par
{\f1     - Base  : adresse lineaire 32 bits de la table}\par
{\f1     - Limite : taille de la table en octets - 1}\par
\par
{\f1   L'entree 0 de la GDT (descripteur nul) est reservee et ne peut}\par
{\f1   pas etre utilisee. Un selecteur qui pointe vers l'entree 0}\par
{\f1   est appele "selecteur nul" et genere #GP s'il est charge dans}\par
{\f1   CS ou SS.}\par
\par
{\f1   Instructions associees :}\par
{\f1     LGDT mem48  : Charge GDTR depuis la memoire (ring 0 seulement)}\par
{\f1     SGDT mem48  : Sauvegarde GDTR en memoire}\par
\par
{\f1   6.3.2 LDT (Local Descriptor Table)}\par
\par
{\f1   Table de descripteurs locale, propre a chaque tache.}\par
{\f1   Elle contient les descripteurs prives d'une tache :}\par
{\f1     - Segments de code et de donnees de l'application}\par
{\f1     - Segments de pile de l'application}\par
\par
{\f1   La LDT est elle-meme decrite par un descripteur dans la GDT.}\par
{\f1   Le registre LDTR contient le selecteur de ce descripteur.}\par
\par
{\f1   Chaque tache peut avoir sa propre LDT, ce qui permet l'isolation}\par
{\f1   des espaces d'adressage entre les taches.}\par
\par
{\f1   Instructions associees :}\par
{\f1     LLDT reg16  : Charge LDTR depuis un selecteur (ring 0)}\par
{\f1     SLDT reg16  : Sauvegarde le selecteur de LDTR}\par
\par
{\f1   6.3.3 IDT (Interrupt Descriptor Table)}\par
\par
{\f1   Table des descripteurs d'interruptions. Elle contient les}\par
{\f1   descripteurs de portes (interrupt gates, trap gates, task gates)}\par
{\f1   pour les 256 vecteurs d'interruption possibles.}\par
\par
{\f1   L'IDT est localisee par le registre IDTR :}\par
{\f1     - Base  : adresse lineaire 32 bits}\par
{\f1     - Limite : taille en octets - 1 (max 256 * 8 = 2048 octets)}\par
\par
{\f1   Instructions associees :}\par
{\f1     LIDT mem48  : Charge IDTR depuis la memoire (ring 0)}\par
{\f1     SIDT mem48  : Sauvegarde IDTR en memoire}\par
\par
\par
\b 6.4 Selecteurs de segments \b0\par
\par
{\f1   Un selecteur de segment est une valeur de 16 bits chargee dans un}\par
{\f1   registre de segment (CS, DS, ES, FS, GS, SS). Il identifie un}\par
{\f1   descripteur dans une table de descripteurs.}\par
\par
{\f1   Format d'un selecteur :}\par
\par
{\f1     15                  3  2  1  0}\par
{\f1   +---------------------+--+-----+}\par
{\f1   |       Index         |TI| RPL |}\par
{\f1   +---------------------+--+-----+}\par
{\f1          13 bits         1b   2b}\par
\par
{\f1   Index (bits 15-3) : Numero d'entree dans la table de descripteurs.}\par
{\f1     Permet d'adresser jusqu'a 8192 descripteurs (2^13).}\par
\par
{\f1   TI (bit 2) : Table Indicator}\par
{\f1     0 = Le descripteur est dans la GDT}\par
{\f1     1 = Le descripteur est dans la LDT}\par
\par
{\f1   RPL (bits 1-0) : Requested Privilege Level}\par
{\f1     Niveau de privilege demande (0 a 3).}\par
{\f1     Utilise dans les verifications de privilege.}\par
\par
{\f1   L'adresse du descripteur dans la table est :}\par
{\f1     Adresse = Base_de_la_table + Index * 8}\par
\par
{\f1   Chaque table peut contenir jusqu'a 8192 descripteurs.}\par
{\f1   Avec la GDT et une LDT par tache, on peut definir :}\par
{\f1     - 8192 segments globaux (GDT)}\par
{\f1     - 8192 segments locaux par tache (LDT)}\par
{\f1   soit 16384 segments accessibles par tache, totalisant un espace}\par
{\f1   d'adressage logique de 64 To (16384 segments * 4 Go chacun).}\par
\par
{\f1   Exemples de selecteurs :}\par
\par
{\f1     08h = Index 1, GDT, RPL 0   (premier segment utile de la GDT)}\par
{\f1     10h = Index 2, GDT, RPL 0}\par
{\f1     23h = Index 4, GDT, RPL 3   (segment utilisateur)}\par
{\f1     0Fh = Index 1, LDT, RPL 3}\par
\par
\par
\b 6.5 Traduction d'adresses en mode protege \b0\par
\par
{\f1   En mode protege, une adresse logique (selecteur:offset) est}\par
{\f1   traduite en adresse lineaire par l'unite de segmentation :}\par
\par
{\f1   1. Le selecteur est utilise pour trouver le descripteur dans}\par
{\f1      la GDT ou la LDT.}\par
{\f1   2. Le processeur verifie les droits d'acces (privilege, type,}\par
{\f1      presence, limites).}\par
{\f1   3. L'adresse de base du descripteur est ajoutee a l'offset}\par
{\f1      pour former l'adresse lineaire.}\par
\par
{\f1   Schema :}\par
\par
{\f1     Adresse logique     Unite de segmentation     Adresse lineaire}\par
{\f1     selecteur:offset -> descripteur -> base+offset -> 32 bits}\par
\par
{\f1   Si la pagination est activee (CR0.PG = 1), l'adresse lineaire}\par
{\f1   est ensuite traduite en adresse physique par l'unite de}\par
{\f1   pagination (voir section 7).}\par
\par
{\f1   Si la pagination est desactivee (CR0.PG = 0), l'adresse lineaire}\par
{\f1   est egale a l'adresse physique.}\par
\par
{\f1   Verifications effectuees lors de l'acces a un segment :}\par
\par
{\f1   a) Verification de la limite :}\par
{\f1      L'offset ne doit pas depasser la limite du segment.}\par
{\f1      Pour G=0 : offset <= limite (en octets)}\par
{\f1      Pour G=1 : offset <= limite * 4096 + 4095}\par
{\f1      Violation : exception #GP (General Protection Fault)}\par
\par
{\f1   b) Verification du type :}\par
{\f1      - On ne peut pas executer un segment de donnees}\par
{\f1      - On ne peut pas ecrire dans un segment de code}\par
{\f1      - On ne peut pas ecrire dans un segment de donnees sans W}\par
{\f1      Violation : exception #GP}\par
\par
{\f1   c) Verification de la presence :}\par
{\f1      Si P=0, le segment n'est pas en memoire.}\par
{\f1      Violation : exception #NP (Segment Not Present)}\par
\par
{\f1   d) Verification des privileges :}\par
{\f1      Voir section 6.6 ci-dessous.}\par
\par
\par
\b 6.6 Niveaux de privilege \b0\par
\par
{\f1   Le 80386 implemente un systeme de protection a 4 niveaux de}\par
{\f1   privilege, souvent appeles "anneaux" (rings) :}\par
\par
{\f1     Ring 0 : Noyau du systeme d'exploitation (plus privilegie)}\par
{\f1     Ring 1 : Services du systeme d'exploitation}\par
{\f1     Ring 2 : Extensions du systeme}\par
{\f1     Ring 3 : Applications utilisateur (moins privilegie)}\par
\par
{\f1   En pratique, la plupart des systemes d'exploitation n'utilisent}\par
{\f1   que les rings 0 (noyau) et 3 (utilisateur).}\par
\par
{\f1   6.6.1 Types de niveaux de privilege}\par
\par
{\f1   CPL (Current Privilege Level) :}\par
{\f1     Niveau de privilege courant du code en execution.}\par
{\f1     Stocke dans les bits RPL du selecteur de CS.}\par
{\f1     CPL = CS.RPL a tout moment.}\par
\par
{\f1   DPL (Descriptor Privilege Level) :}\par
{\f1     Niveau de privilege du segment ou de la porte.}\par
{\f1     Stocke dans le descripteur lui-meme.}\par
\par
{\f1   RPL (Requested Privilege Level) :}\par
{\f1     Niveau de privilege demande, stocke dans le selecteur.}\par
{\f1     Peut etre utilise pour restreindre les droits d'acces}\par
{\f1     (le niveau effectif est max(CPL, RPL)).}\par
\par
{\f1   6.6.2 Regles de verification des privileges}\par
\par
{\f1   Pour acceder a un segment de donnees :}\par
{\f1     max(CPL, RPL) <= DPL}\par
\par
{\f1   Un programme ne peut acceder qu'aux segments de donnees dont}\par
{\f1   le DPL est numeriquement superieur ou egal a son niveau effectif.}\par
\par
{\f1   Pour transferer le controle a un segment de code :}\par
\par
{\f1   a) Code non-conforming (C=0) :}\par
{\f1      CPL == DPL  (le niveau doit etre exactement le meme)}\par
{\f1      Exception : les portes d'appel permettent les transitions.}\par
\par
{\f1   b) Code conforming (C=1) :}\par
{\f1      CPL >= DPL  (le code appele peut etre plus privilegie)}\par
{\f1      Le CPL ne change pas apres le transfert.}\par
\par
{\f1   Pour utiliser une porte d'appel (Call Gate) :}\par
{\f1      max(CPL, RPL) <= DPL de la porte}\par
{\f1      CPL >= DPL du segment de code cible}\par
\par
{\f1   6.6.3 Schema des anneaux de privilege}\par
\par
{\f1               +-------------------+}\par
{\f1               |      Ring 0       |}\par
{\f1               |      Noyau        |}\par
{\f1               |  +-------------+  |}\par
{\f1               |  |   Ring 1    |  |}\par
{\f1               |  |  Services   |  |}\par
{\f1               |  | +---------+ |  |}\par
{\f1               |  | |  Ring 2 | |  |}\par
{\f1               |  | | Ext. OS | |  |}\par
{\f1               |  | | +-----+ | |  |}\par
{\f1               |  | | |Ring 3| | |  |}\par
{\f1               |  | | | Appli| | |  |}\par
{\f1               |  | | +-----+ | |  |}\par
{\f1               |  | +---------+ |  |}\par
{\f1               |  +-------------+  |}\par
{\f1               +-------------------+}\par
\par
{\f1   Les transitions entre anneaux se font par :}\par
{\f1     - Portes d'appel (CALL via call gate) : ring 3 -> ring 0}\par
{\f1     - Instructions INT/IRET : via l'IDT}\par
{\f1     - Commutation de taches : via TSS}\par
{\f1     - Instructions SYSENTER/SYSEXIT (a partir du Pentium II)}\par
\par
\par
\b 6.7 Portes (Gates) \b0\par
\par
{\f1   Les portes sont des descripteurs systeme (S=0) qui permettent}\par
{\f1   des transitions controlees entre niveaux de privilege.}\par
\par
{\f1   6.7.1 Porte d'appel (Call Gate)}\par
\par
{\f1   Format (8 octets) :}\par
\par
{\f1   Octet 7     Octet 6     Octet 5     Octet 4}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
{\f1   | Offset |  | Offset |  |P|DPL|0|  |000|Param|}\par
{\f1   | [31:24]|  | [23:16]|  |  1100 |  |  Count |}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
\par
{\f1   Octet 3     Octet 2     Octet 1     Octet 0}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
{\f1   |Selecteur  |Selecteur  | Offset |  | Offset |}\par
{\f1   |  [15:8]   |  [7:0]    | [15:8] |  | [7:0]  |}\par
{\f1   +--------+  +--------+  +--------+  +--------+}\par
\par
{\f1   Selecteur : Selecteur du segment de code cible}\par
{\f1   Offset    : Offset du point d'entree dans le segment cible}\par
{\f1   DPL       : Niveau de privilege requis pour utiliser la porte}\par
{\f1   Param Count : Nombre de parametres (DWords) a copier de la pile}\par
{\f1               de l'appelant vers la pile du noyau (0 a 31)}\par
{\f1   Type      : 1100 (Call Gate 32 bits)}\par
\par
{\f1   Fonctionnement d'un CALL via une porte d'appel :}\par
{\f1   1. Le processeur verifie : max(CPL, RPL) <= DPL de la porte}\par
{\f1   2. Il verifie : CPL >= DPL du segment de code cible}\par
{\f1   3. Si changement de privilege :}\par
{\f1      a. Il charge SS et ESP depuis le TSS pour le nouveau ring}\par
{\f1      b. Il empile sur la nouvelle pile : SS ancien, ESP ancien,}\par
{\f1         les parametres copies, CS ancien, EIP ancien}\par
{\f1   4. Il charge CS:EIP depuis la porte (selecteur + offset)}\par
{\f1   5. L'execution continue au point d'entree avec le nouveau CPL}\par
\par
{\f1   Le retour se fait par RET (ou RETF) qui restaure CS:EIP et}\par
{\f1   eventuellement SS:ESP si le privilege change.}\par
\par
{\f1   6.7.2 Porte d'interruption (Interrupt Gate)}\par
\par
{\f1   Format identique a la porte d'appel, mais avec Type = 1110.}\par
\par
{\f1   Difference avec la porte d'appel :}\par
{\f1     - Utilisee pour les interruptions (materielles et logicielles)}\par
{\f1     - Le drapeau IF est mis a 0 automatiquement (interruptions}\par
{\f1       desactivees pendant le handler)}\par
{\f1     - Pas de copie de parametres}\par
\par
{\f1   Le processeur empile automatiquement sur la pile du handler :}\par
{\f1     - EFLAGS, CS, EIP (toujours)}\par
{\f1     - SS, ESP (si changement de privilege)}\par
{\f1     - Code d'erreur (pour certaines exceptions)}\par
\par
{\f1   6.7.3 Porte de trappe (Trap Gate)}\par
\par
{\f1   Format identique a la porte d'interruption, mais avec Type = 1111.}\par
\par
{\f1   Difference avec la porte d'interruption :}\par
{\f1     - Le drapeau IF n'est PAS modifie (les interruptions restent}\par
{\f1       dans l'etat ou elles etaient)}\par
{\f1     - Utilisee typiquement pour les exceptions (debug, breakpoints)}\par
\par
{\f1   6.7.4 Porte de tache (Task Gate)}\par
\par
{\f1   Format (8 octets) :}\par
\par
{\f1   Octet 5 contient P|DPL|0|0101 (Type = 0101)}\par
{\f1   Octets 2-3 contiennent le selecteur du TSS de la tache cible.}\par
{\f1   Les autres champs sont reserves.}\par
\par
{\f1   Lorsqu'une porte de tache est activee (par CALL, JMP, INT ou}\par
{\f1   exception), le processeur effectue une commutation de tache}\par
{\f1   complete vers le TSS reference par le selecteur.}\par
\par
\par
\b 6.8 Segment d'etat de tache (TSS) \b0\par
\par
{\f1   Le TSS (Task State Segment) est une structure de donnees en}\par
{\f1   memoire qui stocke l'etat complet d'une tache. Le 80386 utilise}\par
{\f1   le TSS pour la commutation de taches materielle.}\par
\par
{\f1   6.8.1 Format du TSS 32 bits}\par
\par
{\f1   Le TSS 32 bits occupe au minimum 104 octets (68h) :}\par
\par
{\f1   Offset  Taille  Contenu}\par
{\f1   ------  ------  -------------------------------------------}\par
{\f1   00h     WORD    Lien arriere (selecteur du TSS precedent)}\par
{\f1   02h     WORD    Reserve}\par
{\f1   04h     DWORD   ESP0 (pile pour Ring 0)}\par
{\f1   08h     WORD    SS0  (segment de pile pour Ring 0)}\par
{\f1   0Ah     WORD    Reserve}\par
{\f1   0Ch     DWORD   ESP1 (pile pour Ring 1)}\par
{\f1   10h     WORD    SS1}\par
{\f1   12h     WORD    Reserve}\par
{\f1   14h     DWORD   ESP2 (pile pour Ring 2)}\par
{\f1   18h     WORD    SS2}\par
{\f1   1Ah     WORD    Reserve}\par
{\f1   1Ch     DWORD   CR3 (repertoire de pages)}\par
{\f1   20h     DWORD   EIP}\par
{\f1   24h     DWORD   EFLAGS}\par
{\f1   28h     DWORD   EAX}\par
{\f1   2Ch     DWORD   ECX}\par
{\f1   30h     DWORD   EDX}\par
{\f1   34h     DWORD   EBX}\par
{\f1   38h     DWORD   ESP}\par
{\f1   3Ch     DWORD   EBP}\par
{\f1   40h     DWORD   ESI}\par
{\f1   44h     DWORD   EDI}\par
{\f1   48h     WORD    ES}\par
{\f1   4Ah     WORD    Reserve}\par
{\f1   4Ch     WORD    CS}\par
{\f1   4Eh     WORD    Reserve}\par
{\f1   50h     WORD    SS}\par
{\f1   52h     WORD    Reserve}\par
{\f1   54h     WORD    DS}\par
{\f1   56h     WORD    Reserve}\par
{\f1   58h     WORD    FS}\par
{\f1   5Ah     WORD    Reserve}\par
{\f1   5Ch     WORD    GS}\par
{\f1   5Eh     WORD    Reserve}\par
{\f1   60h     WORD    Selecteur LDT}\par
{\f1   62h     WORD    Reserve}\par
{\f1   64h     WORD    Bit T (debug trap) | Reserve}\par
{\f1   66h     WORD    Offset de la carte d'E/S (I/O Map Base)}\par
\par
{\f1   Apres l'offset 68h, on peut placer la carte de permissions}\par
{\f1   d'E/S (I/O Permission Bitmap), terminee par un octet FFh.}\par
\par
{\f1   6.8.2 Piles par niveau de privilege}\par
\par
{\f1   Le TSS contient trois paires SS:ESP (pour les rings 0, 1 et 2).}\par
{\f1   Lorsqu'un appel passe a un niveau de privilege superieur,}\par
{\f1   le processeur charge automatiquement la pile correspondante}\par
{\f1   depuis le TSS de la tache courante.}\par
\par
{\f1   Cela garantit que chaque niveau de privilege dispose de sa}\par
{\f1   propre pile, evitant qu'un programme utilisateur puisse}\par
{\f1   corrompre la pile du noyau.}\par
\par
{\f1   6.8.3 Carte de permissions d'E/S (I/O Permission Bitmap)}\par
\par
{\f1   La carte d'E/S est un tableau de bits ou chaque bit correspond}\par
{\f1   a un port d'E/S. Elle permet de controler l'acces aux ports}\par
{\f1   pour les programmes en ring > IOPL.}\par
\par
{\f1     Bit = 0 : L'acces au port est autorise}\par
{\f1     Bit = 1 : L'acces au port genere une exception #GP}\par
\par
{\f1   L'offset de la carte dans le TSS est donne par le champ}\par
{\f1   "I/O Map Base" a l'offset 66h. La carte peut couvrir jusqu'a}\par
{\f1   65536 ports (8192 octets).}\par
\par
{\f1   Si IOPL >= CPL, tous les acces E/S sont autorises sans}\par
{\f1   consulter la carte.}\par
\par
{\f1   6.8.4 Commutation de taches}\par
\par
{\f1   Une commutation de taches peut etre declenchee par :}\par
{\f1     - JMP ou CALL vers un descripteur de TSS dans la GDT}\par
{\f1     - JMP ou CALL via une porte de tache (Task Gate)}\par
{\f1     - Une interruption ou exception via une porte de tache dans l'IDT}\par
{\f1     - IRET lorsque le flag NT (Nested Task) est a 1}\par
\par
{\f1   Lors d'une commutation de tache, le processeur :}\par
\par
{\f1   1. Sauvegarde l'etat complet de la tache courante dans son TSS}\par
{\f1      (EAX-EDI, EIP, EFLAGS, segments, CR3)}\par
{\f1   2. Marque le TSS courant comme "busy" (occupe)}\par
{\f1   3. Charge le registre TR avec le selecteur du nouveau TSS}\par
{\f1   4. Charge l'etat complet depuis le nouveau TSS}\par
{\f1   5. Si CALL ou INT : met le flag NT a 1 et sauvegarde le}\par
{\f1      selecteur de l'ancien TSS dans le champ "lien arriere"}\par
{\f1   6. Reprend l'execution au EIP du nouveau TSS}\par
\par
{\f1   Le registre TR (Task Register) contient le selecteur du TSS}\par
{\f1   de la tache courante :}\par
{\f1     LTR reg16  : Charge TR avec un selecteur (ring 0)}\par
{\f1     STR reg16  : Sauvegarde le selecteur de TR}\par
\par
\par
\b 6.9 Passage en mode protege \b0\par
\par
{\f1   La sequence typique pour passer du mode reel au mode protege :}\par
\par
{\f1   1. Desactiver les interruptions (CLI)}\par
\par
{\f1   2. Activer la ligne d'adresse A20}\par
{\f1      (necessaire pour adresser au-dela de 1 Mo)}\par
{\f1      Typiquement via le controleur de clavier 8042 :}\par
{\f1        MOV AL, 0D1h}\par
{\f1        OUT 64h, AL        ; commande d'ecriture au port de sortie}\par
{\f1        MOV AL, 0DFh}\par
{\f1        OUT 60h, AL        ; activer A20}\par
\par
{\f1   3. Preparer la GDT en memoire avec au minimum :}\par
{\f1      - Descripteur nul (entree 0, obligatoire)}\par
{\f1      - Descripteur de code (entree 1, ex: base=0, limite=FFFFFh, G=1)}\par
{\f1      - Descripteur de donnees (entree 2, ex: base=0, limite=FFFFFh, G=1)}\par
\par
{\f1   4. Charger GDTR :}\par
{\f1        LGDT [gdtr_value]}\par
{\f1      ou gdtr_value est une structure de 6 octets :}\par
{\f1        dw taille_gdt - 1   ; limite (16 bits)}\par
{\f1        dd adresse_gdt       ; base (32 bits)}\par
\par
{\f1   5. Activer le bit PE (Protection Enable) dans CR0 :}\par
{\f1        MOV EAX, CR0}\par
{\f1        OR  EAX, 1          ; bit 0 = PE}\par
{\f1        MOV CR0, EAX}\par
\par
{\f1   6. Effectuer un JMP FAR vers un selecteur de code protege}\par
{\f1      pour vider le pipeline et charger CS :}\par
{\f1        JMP 08h:debut_protege}\par
{\f1      (08h = selecteur du descripteur de code dans la GDT)}\par
\par
{\f1   7. Charger les registres de segment de donnees :}\par
{\f1        MOV AX, 10h         ; selecteur du descripteur de donnees}\par
{\f1        MOV DS, AX}\par
{\f1        MOV ES, AX}\par
{\f1        MOV FS, AX}\par
{\f1        MOV GS, AX}\par
{\f1        MOV SS, AX}\par
\par
{\f1   8. Charger la pile :}\par
{\f1        MOV ESP, adresse_sommet_pile}\par
\par
{\f1   9. Charger l'IDT si necessaire :}\par
{\f1        LIDT [idtr_value]}\par
\par
{\f1   10. Reactiver les interruptions (STI) si un PIC est configure}\par
\par
{\f1   Note : Le JMP FAR a l'etape 6 est crucial. Sans lui, CS contient}\par
{\f1   toujours un selecteur de mode reel et le processeur se comporte}\par
{\f1   de facon imprevisible.}\par
\par
\par
\b 6.10 Instructions specifiques au mode protege \b0\par
\par
{\f1   Le 80386 fournit des instructions dediees a la gestion du mode}\par
{\f1   protege. La plupart sont reservees au ring 0 (privilege maximum).}\par
\par
{\f1   6.10.1 Instructions pour les tables de descripteurs}\par
\par
{\f1   LGDT mem48   Charge GDTR (base + limite)               Ring 0}\par
{\f1   SGDT mem48   Sauvegarde GDTR                            Tous}\par
{\f1   LIDT mem48   Charge IDTR (base + limite)               Ring 0}\par
{\f1   SIDT mem48   Sauvegarde IDTR                            Tous}\par
{\f1   LLDT reg16   Charge LDTR depuis un selecteur            Ring 0}\par
{\f1   SLDT reg16   Sauvegarde le selecteur de LDTR            Tous}\par
{\f1   LTR  reg16   Charge le Task Register                    Ring 0}\par
{\f1   STR  reg16   Sauvegarde le Task Register                Tous}\par
\par
{\f1   6.10.2 Instructions de verification des privileges}\par
\par
{\f1   ARPL reg16, reg16   Ajuste le RPL d'un selecteur}\par
{\f1                        Met RPL(dest) = max(RPL(dest), RPL(src))}\par
{\f1                        Met ZF=1 si modifie}\par
\par
{\f1   LAR  reg, r/m16     Charge les droits d'acces d'un descripteur}\par
{\f1                        Retourne les octets 4-7 du descripteur}\par
{\f1                        Met ZF=1 si le descripteur est valide}\par
\par
{\f1   LSL  reg, r/m16     Charge la limite d'un segment}\par
{\f1                        Retourne la limite en octets ou en pages}\par
{\f1                        Met ZF=1 si le descripteur est valide}\par
\par
{\f1   VERR r/m16          Verifie si un segment est lisible}\par
{\f1                        Met ZF=1 si le segment peut etre lu}\par
{\f1                        au niveau de privilege courant}\par
\par
{\f1   VERW r/m16          Verifie si un segment est inscriptible}\par
{\f1                        Met ZF=1 si le segment peut etre ecrit}\par
{\f1                        au niveau de privilege courant}\par
\par
{\f1   6.10.3 Instructions pour les registres de controle}\par
\par
{\f1   MOV CRn, reg32      Ecriture dans un registre de controle    Ring 0}\par
{\f1   MOV reg32, CRn      Lecture d'un registre de controle         Ring 0}\par
\par
{\f1   Registres de controle du 80386 :}\par
\par
{\f1   CR0 : Controle du processeur}\par
{\f1     Bit 0  (PE) : Protection Enable (active le mode protege)}\par
{\f1     Bit 1  (MP) : Monitor Coprocessor}\par
{\f1     Bit 2  (EM) : Emulation (FPU absent, emuler par logiciel)}\par
{\f1     Bit 3  (TS) : Task Switched (mis a 1 lors d'un task switch)}\par
{\f1     Bit 4  (ET) : Extension Type (type de FPU : 80287 ou 80387)}\par
{\f1     Bit 16 (WP) : Write Protect (protege les pages en ring 0)}\par
{\f1     Bit 31 (PG) : Paging (active la pagination)}\par
\par
{\f1   CR2 : Adresse lineaire de la faute de page}\par
{\f1     Contient l'adresse qui a cause la derniere exception #PF.}\par
\par
{\f1   CR3 : Adresse physique du repertoire de pages (PDBR)}\par
{\f1     Bits 31-12 : Adresse physique du repertoire (alignee 4 Ko)}\par
{\f1     Bit 4 (PCD) : Page Cache Disable}\par
{\f1     Bit 3 (PWT) : Page Write-Through}\par
\par
{\f1   6.10.4 Instructions pour les registres de debug}\par
\par
{\f1   MOV DRn, reg32      Ecriture dans un registre de debug       Ring 0}\par
{\f1   MOV reg32, DRn      Lecture d'un registre de debug            Ring 0}\par
\par
{\f1   DR0-DR3 : Adresses lineaires des points d'arret materiels}\par
{\f1   DR6      : Etat du debug (indique quel breakpoint a ete touche)}\par
{\f1   DR7      : Controle du debug (active/configure les breakpoints)}\par
{\f1     Chaque breakpoint peut etre configure pour :}\par
{\f1     - Arret sur execution}\par
{\f1     - Arret sur ecriture memoire}\par
{\f1     - Arret sur lecture/ecriture memoire}\par
{\f1     - Arret sur acces E/S}\par
\par
{\f1   6.10.5 Exemple : configuration minimale du mode protege}\par
\par
{\f1   ; --- Descripteurs GDT ---}\par
{\f1   gdt_start:}\par
{\f1     dq 0                        ; Descripteur nul (obligatoire)}\par
\par
{\f1   gdt_code:                     ; Descripteur de code ring 0}\par
{\f1     dw 0FFFFh                   ; Limite [15:0]}\par
{\f1     dw 0                        ; Base [15:0]}\par
{\f1     db 0                        ; Base [23:16]}\par
{\f1     db 10011010b                ; P=1, DPL=0, S=1, Type=1010 (code R/X)}\par
{\f1     db 11001111b                ; G=1, D=1, Limit[19:16]=Fh}\par
{\f1     db 0                        ; Base [31:24]}\par
\par
{\f1   gdt_data:                     ; Descripteur de donnees ring 0}\par
{\f1     dw 0FFFFh                   ; Limite [15:0]}\par
{\f1     dw 0                        ; Base [15:0]}\par
{\f1     db 0                        ; Base [23:16]}\par
{\f1     db 10010010b                ; P=1, DPL=0, S=1, Type=0010 (data R/W)}\par
{\f1     db 11001111b                ; G=1, D=1, Limit[19:16]=Fh}\par
{\f1     db 0                        ; Base [31:24]}\par
{\f1   gdt_end:}\par
\par
{\f1   ; --- GDTR ---}\par
{\f1   gdtr_value:}\par
{\f1     dw gdt_end - gdt_start - 1 ; Limite}\par
{\f1     dd gdt_start                ; Base}\par
\par
{\f1   ; --- Passage en mode protege ---}\par
{\f1     CLI}\par
{\f1     LGDT [gdtr_value]}\par
{\f1     MOV EAX, CR0}\par
{\f1     OR  EAX, 1}\par
{\f1     MOV CR0, EAX}\par
{\f1     JMP 08h:protege_start       ; 08h = selecteur du code}\par
\par
{\f1   protege_start:}\par
{\f1     MOV AX, 10h                 ; 10h = selecteur des donnees}\par
{\f1     MOV DS, AX}\par
{\f1     MOV ES, AX}\par
{\f1     MOV SS, AX}\par
{\f1     MOV ESP, 90000h             ; Sommet de pile}\par
\par
{\f1   Cet exemple configure un modele "flat" (base=0, limite=4Go)}\par
{\f1   couramment utilise par les systemes d'exploitation modernes.}\par
{\f1   Tous les segments couvrent l'integralite de l'espace d'adressage,}\par
{\f1   et la protection est assuree principalement par la pagination}\par
{\f1   (voir section 7).}\par
\par
\par
