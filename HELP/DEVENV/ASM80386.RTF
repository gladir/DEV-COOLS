{\footnote # IDH_ASM80386_08}
{\footnote $ Assembleur 80386 - INTERRUPTIONS ET EXCEPTIONS}
{\footnote K Assembleur 80386 interruptions exceptions;IDT;faults traps aborts;divide error;page fault;general protection fault;double fault;INT 0-FF;NMI;IRQ;interrupt vector}
\b\fs24 INTERRUPTIONS ET EXCEPTIONS \b0\fs20\par
\par
\par
\b 8.1 Vue d'ensemble \b0\par
\par
{\f1   Les interruptions et exceptions sont des mecanismes qui}\par
{\f1   suspendent l'execution normale du processeur pour traiter}\par
{\f1   un evenement. Le 80386 supporte 256 vecteurs d'interruption}\par
{\f1   (numerotes de 0 a 255), chacun associe a un handler via la}\par
{\f1   table des descripteurs d'interruptions (IDT).}\par
\par
{\f1   Terminologie :}\par
\par
{\f1   - Interruption : evenement asynchrone externe au processeur}\par
{\f1     (materiel) ou declenche explicitement par logiciel (INT n).}\par
{\f1     L'execution peut reprendre normalement apres le traitement.}\par
\par
{\f1   - Exception : evenement synchrone genere par le processeur}\par
{\f1     lui-meme en reponse a une erreur ou condition speciale}\par
{\f1     detectee pendant l'execution d'une instruction.}\par
\par
{\f1   Les interruptions et exceptions provoquent :}\par
{\f1     1. Sauvegarde du contexte (EFLAGS, CS, EIP) sur la pile}\par
{\f1     2. Transfert du controle au handler via l'IDT}\par
{\f1     3. Retour par IRET apres le traitement}\par
\par
\par
\b 8.2 Classification \b0\par
\par
{\f1   8.2.1 Interruptions materielles (externes)}\par
\par
{\f1   Generees par des peripheriques via les lignes d'interruption}\par
{\f1   du processeur :}\par
\par
{\f1   - INTR (Interrupt Request) : interruptions masquables.}\par
{\f1     Peuvent etre desactivees par CLI (Clear Interrupt Flag)}\par
{\f1     et reactivees par STI (Set Interrupt Flag).}\par
{\f1     Le drapeau IF de EFLAGS controle leur acceptation.}\par
\par
{\f1   - NMI (Non-Maskable Interrupt) : interruption non masquable.}\par
{\f1     Toujours acceptee, vecteur 2. Utilisee pour les erreurs}\par
{\f1     critiques (erreur de parite memoire, watchdog, etc.).}\par
\par
{\f1   8.2.2 Interruptions logicielles}\par
\par
{\f1   Declenchees explicitement par l'instruction INT n :}\par
\par
{\f1     INT 21h     ; Appel systeme DOS (mode reel)}\par
{\f1     INT 80h     ; Appel systeme Linux (mode protege)}\par
{\f1     INT 3       ; Point d'arret (breakpoint, opcode CC)}\par
{\f1     INTO        ; INT 4 si OF=1 (Overflow)}\par
\par
{\f1   Les interruptions logicielles ne sont pas affectees par}\par
{\f1   le drapeau IF (elles ne sont pas masquables).}\par
\par
{\f1   8.2.3 Exceptions}\par
\par
{\f1   Generees par le processeur lors de la detection d'erreurs.}\par
{\f1   Trois categories :}\par
\par
{\f1   a) Faults (fautes) :}\par
{\f1      L'exception est signalee AVANT l'execution de l'instruction}\par
{\f1      fautive. CS:EIP pointe sur l'instruction qui a cause la}\par
{\f1      faute. Apres correction, l'instruction peut etre relancee.}\par
{\f1      Exemple : #PF (Page Fault) - la page est chargee puis}\par
{\f1      l'instruction est reexecutee.}\par
\par
{\f1   b) Traps (pieges) :}\par
{\f1      L'exception est signalee APRES l'execution de l'instruction.}\par
{\f1      CS:EIP pointe sur l'instruction suivante. L'execution}\par
{\f1      reprend normalement apres le traitement.}\par
{\f1      Exemple : #DB (Debug) apres une instruction en mode trace,}\par
{\f1      INT 3 (Breakpoint).}\par
\par
{\f1   c) Aborts (abandons) :}\par
{\f1      L'exception signale une erreur grave qui ne permet pas}\par
{\f1      de localiser precisement l'instruction fautive ni de}\par
{\f1      reprendre l'execution.}\par
{\f1      Exemple : #DF (Double Fault), erreur materielle.}\par
\par
\par
\b 8.3 Table des descripteurs d'interruptions (IDT) \b0\par
\par
{\f1   L'IDT est une table en memoire contenant jusqu'a 256}\par
{\f1   descripteurs de portes (gates). Chaque descripteur occupe}\par
{\f1   8 octets, soit une taille maximale de 2048 octets (256 * 8).}\par
\par
{\f1   Le registre IDTR (IDT Register) contient :}\par
{\f1     - L'adresse lineaire de base de l'IDT (32 bits)}\par
{\f1     - La limite de l'IDT en octets (16 bits)}\par
\par
{\f1   Format du registre IDTR :}\par
\par
{\f1     47                16 15        0}\par
{\f1   +--------------------+-----------+}\par
{\f1   | Base (32 bits)     | Limite    |}\par
{\f1   +--------------------+-----------+}\par
\par
{\f1   Instructions associees :}\par
\par
{\f1     LIDT mem48    ; Charger IDTR (instruction privilegiee)}\par
{\f1     SIDT mem48    ; Sauvegarder IDTR (accessible depuis tout CPL)}\par
\par
{\f1   Exemple de chargement de l'IDT :}\par
\par
{\f1     idt_descriptor:}\par
{\f1       DW  256*8 - 1       ; Limite = 2047}\par
{\f1       DD  idt_table        ; Adresse de base}\par
\par
{\f1     LIDT [idt_descriptor]}\par
\par
{\f1   L'IDT peut contenir trois types de descripteurs :}\par
{\f1     - Porte d'interruption (Interrupt Gate)}\par
{\f1     - Porte de piege (Trap Gate)}\par
{\f1     - Porte de tache (Task Gate)}\par
\par
{\f1   En mode reel, l'equivalent est l'IVT (Interrupt Vector Table)}\par
{\f1   situee a l'adresse 0000:0000, contenant 256 pointeurs far}\par
{\f1   (segment:offset) de 4 octets chacun (1024 octets total).}\par
\par
\par
\b 8.4 Format des portes d'interruption et trap \b0\par
\par
{\f1   8.4.1 Porte d'interruption (Interrupt Gate, type 0Eh pour 32 bits)}\par
\par
{\f1     63           48 47 46 45 44    40 39    37 36  35  32}\par
{\f1   +----------------+--+-----+--------+--------+--+------+}\par
{\f1   | Offset [31:16] | P| DPL | 0D110  |  000   |0 | res  |}\par
{\f1   +----------------+--+-----+--------+--------+--+------+}\par
{\f1     31           16 15                               0}\par
{\f1   +----------------+----------------------------------+}\par
{\f1   | Selecteur seg. |        Offset [15:0]             |}\par
{\f1   +----------------+----------------------------------+}\par
\par
{\f1   Champs :}\par
\par
{\f1   Offset [31:16] et [15:0] : Adresse du handler dans le segment}\par
{\f1     de code designe par le selecteur. Les deux parties forment}\par
{\f1     l'offset 32 bits complet.}\par
\par
{\f1   Selecteur de segment (16 bits) : Selecteur du segment de code}\par
{\f1     contenant le handler. Doit pointer vers un segment de code}\par
{\f1     dans la GDT ou la LDT.}\par
\par
{\f1   P (bit 47) : Present}\par
{\f1     1 = Le descripteur est valide}\par
{\f1     0 = Le descripteur n'est pas present (#NP si utilise)}\par
\par
{\f1   DPL (bits 46-45) : Descriptor Privilege Level}\par
{\f1     Niveau de privilege requis pour invoquer cette porte}\par
{\f1     via INT n. Le CPL doit etre <= DPL pour les interruptions}\par
{\f1     logicielles. Les exceptions et interruptions materielles}\par
{\f1     ignorent le DPL.}\par
\par
{\f1   Type (bits 44-40) : 0D110 pour une porte d'interruption 32 bits}\par
{\f1     D=1 pour 32 bits (type = 0Eh), D=0 pour 16 bits (type = 06h)}\par
\par
{\f1   Comportement specifique : quand le processeur passe par une}\par
{\f1   porte d'interruption, le drapeau IF est automatiquement}\par
{\f1   efface (IF=0), desactivant les interruptions masquables.}\par
{\f1   Cela empeche les interruptions imbriquees involontaires.}\par
\par
{\f1   8.4.2 Porte de piege (Trap Gate, type 0Fh pour 32 bits)}\par
\par
{\f1   Format identique a la porte d'interruption, sauf :}\par
\par
{\f1   Type (bits 44-40) : 0D111 pour une porte de piege 32 bits}\par
{\f1     D=1 pour 32 bits (type = 0Fh), D=0 pour 16 bits (type = 07h)}\par
\par
{\f1   Difference cle : le drapeau IF n'est PAS modifie lors du}\par
{\f1   passage par une porte de piege. Les interruptions masquables}\par
{\f1   restent activees si elles l'etaient avant.}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Portes d'interruption : pour les interruptions materielles}\par
{\f1       et les handlers qui ne doivent pas etre interrompus}\par
{\f1     - Portes de piege : pour les exceptions (#PF, #GP, etc.)}\par
{\f1       et les appels systeme (INT 80h sous Linux)}\par
\par
{\f1   8.4.3 Porte de tache (Task Gate, type 05h)}\par
\par
{\f1   Contient un selecteur de TSS au lieu d'un offset de handler.}\par
{\f1   Le processeur effectue un changement de tache complet pour}\par
{\f1   traiter l'interruption. Rarement utilise en pratique sauf}\par
{\f1   pour le Double Fault (#DF) ou certains debuggers.}\par
\par
{\f1     63           48 47 46 45 44    40 39              32}\par
{\f1   +----------------+--+-----+--------+-----------------+}\par
{\f1   |   Reserve      | P| DPL | 00101  |    Reserve      |}\par
{\f1   +----------------+--+-----+--------+-----------------+}\par
{\f1     31           16 15                               0}\par
{\f1   +----------------+----------------------------------+}\par
{\f1   | Selecteur TSS  |           Reserve                |}\par
{\f1   +----------------+----------------------------------+}\par
\par
\par
\b 8.5 Exceptions du 80386 \b0\par
\par
{\f1   Le 80386 definit 17 exceptions (vecteurs 0 a 16). Les}\par
{\f1   vecteurs 17-31 sont reserves par Intel pour les futurs}\par
{\f1   processeurs. Les vecteurs 32-255 sont disponibles pour}\par
{\f1   les interruptions materielles et logicielles.}\par
\par
{\f1   Table complete des exceptions :}\par
\par
{\f1   Vec  Mnemo  Type    Err  Description}\par
{\f1   ---  -----  ------  ---  ------------------------------------}\par
{\f1    0   #DE    Fault   Non  Division Error (DIV/IDIV par zero}\par
{\f1                            ou quotient trop grand)}\par
{\f1    1   #DB    Fault/  Non  Debug (point d'arret materiel,}\par
{\f1               Trap         mode trace T=1, registres DRx)}\par
{\f1    2   NMI    Int     Non  Non-Maskable Interrupt (erreur}\par
{\f1                            materielle critique)}\par
{\f1    3   #BP    Trap    Non  Breakpoint (instruction INT 3,}\par
{\f1                            opcode CC sur 1 octet)}\par
{\f1    4   #OF    Trap    Non  Overflow (instruction INTO}\par
{\f1                            quand OF=1 dans EFLAGS)}\par
{\f1    5   #BR    Fault   Non  BOUND Range Exceeded (instruction}\par
{\f1                            BOUND, index hors limites)}\par
{\f1    6   #UD    Fault   Non  Invalid Opcode (opcode inconnu}\par
{\f1                            ou instruction invalide)}\par
{\f1    7   #NM    Fault   Non  Device Not Available (instruction}\par
{\f1                            FPU avec CR0.EM=1 ou CR0.TS=1)}\par
{\f1    8   #DF    Abort   Oui  Double Fault (exception pendant}\par
{\f1                            le traitement d'une exception,}\par
{\f1                            code d'erreur toujours 0)}\par
{\f1    9   ---    Abort   Non  Coprocessor Segment Overrun}\par
{\f1                            (obsolete depuis le 80486)}\par
{\f1   10   #TS    Fault   Oui  Invalid TSS (selecteur TSS invalide}\par
{\f1                            lors d'une commutation de tache)}\par
{\f1   11   #NP    Fault   Oui  Segment Not Present (bit P=0 dans}\par
{\f1                            un descripteur de segment)}\par
{\f1   12   #SS    Fault   Oui  Stack-Segment Fault (depassement}\par
{\f1                            de pile ou segment SS invalide)}\par
{\f1   13   #GP    Fault   Oui  General Protection (violation de}\par
{\f1                            protection generique, la plus}\par
{\f1                            courante des exceptions)}\par
{\f1   14   #PF    Fault   Oui  Page Fault (page non presente ou}\par
{\f1                            violation de protection par page,}\par
{\f1                            voir section 7.9)}\par
{\f1   15   ---    ---     ---  Reserve par Intel}\par
{\f1   16   #MF    Fault   Non  x87 FPU Floating-Point Error}\par
{\f1                            (erreur FPU non masquee)}\par
\par
{\f1   Colonne "Err" : indique si le processeur empile un code}\par
{\f1   d'erreur de 32 bits en plus de EFLAGS/CS/EIP.}\par
\par
{\f1   8.5.1 Detail des exceptions les plus courantes}\par
\par
{\f1   #DE - Division Error (vecteur 0)}\par
{\f1     Declenchee par DIV ou IDIV quand le diviseur est 0 ou}\par
{\f1     quand le quotient ne tient pas dans le registre destination.}\par
{\f1     CS:EIP pointe sur l'instruction DIV/IDIV fautive.}\par
\par
{\f1   #DB - Debug (vecteur 1)}\par
{\f1     Declenchee dans plusieurs situations :}\par
{\f1     - Point d'arret materiel (registres DR0-DR3 + DR7)}\par
{\f1     - Mode trace pas-a-pas (TF=1 dans EFLAGS)}\par
{\f1     - Acces aux registres de debug (DR4-DR5 quand GD=1)}\par
{\f1     Le registre DR6 contient les informations sur la cause.}\par
\par
{\f1   #BP - Breakpoint (vecteur 3)}\par
{\f1     Declenchee par l'instruction INT 3 (opcode CC, 1 octet).}\par
{\f1     Utilisee par les debuggers pour poser des points d'arret}\par
{\f1     logiciels. L'opcode court (1 octet) permet de remplacer}\par
{\f1     n'importe quelle instruction en memoire.}\par
\par
{\f1   #UD - Invalid Opcode (vecteur 6)}\par
{\f1     Declenchee quand le processeur rencontre un opcode}\par
{\f1     invalide ou une combinaison d'operandes illegale.}\par
{\f1     Aussi declenchee si LOCK est utilise avec une instruction}\par
{\f1     qui ne le supporte pas.}\par
\par
{\f1   #NM - Device Not Available (vecteur 7)}\par
{\f1     Declenchee par une instruction FPU (WAIT/FWAIT ou ESC)}\par
{\f1     quand CR0.EM=1 (emulation) ou CR0.TS=1 (task switched).}\par
{\f1     Utilisee pour implementer le "lazy FPU context switching" :}\par
{\f1     le contexte FPU n'est sauvegarde/restaure que quand un}\par
{\f1     processus utilise effectivement le FPU.}\par
\par
{\f1   #DF - Double Fault (vecteur 8)}\par
{\f1     Declenchee quand une exception se produit pendant le}\par
{\f1     traitement d'une autre exception et que les deux ne}\par
{\f1     peuvent pas etre traitees en serie (voir section 8.11).}\par
{\f1     Le code d'erreur est toujours 0.}\par
\par
{\f1   #GP - General Protection (vecteur 13)}\par
{\f1     L'exception la plus generique, couvrant de nombreuses}\par
{\f1     violations :}\par
{\f1     - Acces memoire depassant la limite d'un segment}\par
{\f1     - Ecriture dans un segment en lecture seule}\par
{\f1     - Chargement d'un selecteur invalide dans un registre}\par
{\f1     - Execution d'une instruction privilegiee en ring 3}\par
{\f1     - Acces a une porte avec un DPL insuffisant}\par
{\f1     - Reference a un descripteur NULL (selecteur 0)}\par
{\f1     Le code d'erreur contient le selecteur fautif ou 0.}\par
\par
{\f1   #PF - Page Fault (vecteur 14)}\par
{\f1     Voir la section 7.9 pour le detail complet. Le registre}\par
{\f1     CR2 contient l'adresse lineaire fautive. Le code d'erreur}\par
{\f1     indique la cause (P/W-R/U-S).}\par
\par
{\f1   #MF - x87 FPU Error (vecteur 16)}\par
{\f1     Declenchee lors de l'execution de WAIT/FWAIT ou d'une}\par
{\f1     instruction FPU quand une exception FPU est en attente}\par
{\f1     (non masquee dans le registre de controle FPU).}\par
\par
\par
\b 8.6 Interruptions materielles et le PIC 8259A \b0\par
\par
{\f1   8.6.1 Le controleur d'interruptions programmable (PIC)}\par
\par
{\f1   Le 80386 ne gere pas directement les interruptions des}\par
{\f1   peripheriques. Un controleur externe, le PIC 8259A, sert}\par
{\f1   d'intermediaire. La configuration standard du PC utilise}\par
{\f1   deux PIC en cascade :}\par
\par
{\f1   PIC maitre (ports 20h/21h) :}\par
{\f1     IRQ 0 : Timer systeme (8253/8254)       -> Vecteur 08h (20h)}\par
{\f1     IRQ 1 : Clavier                         -> Vecteur 09h (21h)}\par
{\f1     IRQ 2 : Cascade vers PIC esclave        -> (pas de vecteur)}\par
{\f1     IRQ 3 : Port serie COM2/COM4            -> Vecteur 0Bh (23h)}\par
{\f1     IRQ 4 : Port serie COM1/COM3            -> Vecteur 0Ch (24h)}\par
{\f1     IRQ 5 : Port parallele LPT2 / Son      -> Vecteur 0Dh (25h)}\par
{\f1     IRQ 6 : Controleur de disquettes        -> Vecteur 0Eh (26h)}\par
{\f1     IRQ 7 : Port parallele LPT1            -> Vecteur 0Fh (27h)}\par
\par
{\f1   PIC esclave (ports A0h/A1h) :}\par
{\f1     IRQ 8  : Horloge temps reel (RTC)       -> Vecteur 70h (28h)}\par
{\f1     IRQ 9  : Redirection IRQ 2 / ACPI       -> Vecteur 71h (29h)}\par
{\f1     IRQ 10 : Disponible                     -> Vecteur 72h (2Ah)}\par
{\f1     IRQ 11 : Disponible                     -> Vecteur 73h (2Bh)}\par
{\f1     IRQ 12 : Souris PS/2                    -> Vecteur 74h (2Ch)}\par
{\f1     IRQ 13 : Coprocesseur FPU               -> Vecteur 75h (2Dh)}\par
{\f1     IRQ 14 : Controleur IDE primaire        -> Vecteur 76h (2Eh)}\par
{\f1     IRQ 15 : Controleur IDE secondaire      -> Vecteur 77h (2Fh)}\par
\par
{\f1   Les vecteurs entre parentheses indiquent le remappage}\par
{\f1   typique en mode protege (base 20h pour le maitre, 28h}\par
{\f1   pour l'esclave) pour eviter les conflits avec les vecteurs}\par
{\f1   d'exceptions Intel (0-1Fh).}\par
\par
{\f1   8.6.2 Remappage des IRQ en mode protege}\par
\par
{\f1   En mode reel, les IRQ 0-7 utilisent les vecteurs 08h-0Fh,}\par
{\f1   ce qui entre en conflit avec les vecteurs d'exceptions du}\par
{\f1   80386 (vecteurs 8-15). Il est essentiel de remapper les}\par
{\f1   PIC en mode protege.}\par
\par
{\f1   Sequence de remappage des PIC :}\par
\par
{\f1     ; Reinitialisation des PIC (ICW1)}\par
{\f1     MOV AL, 11h         ; ICW1: initialisation + ICW4 needed}\par
{\f1     OUT 20h, AL         ; PIC maitre}\par
{\f1     OUT A0h, AL         ; PIC esclave}\par
\par
{\f1     ; Vecteurs de base (ICW2)}\par
{\f1     MOV AL, 20h         ; IRQ 0-7 -> vecteurs 20h-27h}\par
{\f1     OUT 21h, AL         ; PIC maitre}\par
{\f1     MOV AL, 28h         ; IRQ 8-15 -> vecteurs 28h-2Fh}\par
{\f1     OUT A1h, AL         ; PIC esclave}\par
\par
{\f1     ; Cascade (ICW3)}\par
{\f1     MOV AL, 04h         ; IRQ2 = cascade}\par
{\f1     OUT 21h, AL         ; PIC maitre}\par
{\f1     MOV AL, 02h         ; Esclave connecte sur IRQ2}\par
{\f1     OUT A1h, AL         ; PIC esclave}\par
\par
{\f1     ; Mode 8086 (ICW4)}\par
{\f1     MOV AL, 01h         ; Mode 8086/88}\par
{\f1     OUT 21h, AL         ; PIC maitre}\par
{\f1     OUT A1h, AL         ; PIC esclave}\par
\par
{\f1     ; Masques d'interruption (OCW1)}\par
{\f1     MOV AL, 00h         ; Toutes les IRQ demasquees}\par
{\f1     OUT 21h, AL         ; PIC maitre (ou FFh pour tout masquer)}\par
{\f1     OUT A1h, AL         ; PIC esclave}\par
\par
{\f1   8.6.3 Acquittement d'interruption (EOI)}\par
\par
{\f1   Apres le traitement d'une IRQ, le handler doit envoyer}\par
{\f1   un signal End-Of-Interrupt (EOI) au PIC pour debloquer}\par
{\f1   les interruptions de meme priorite ou inferieure.}\par
\par
{\f1     ; EOI pour le PIC maitre (IRQ 0-7)}\par
{\f1     MOV AL, 20h         ; Commande EOI non specifique}\par
{\f1     OUT 20h, AL}\par
\par
{\f1     ; EOI pour le PIC esclave (IRQ 8-15)}\par
{\f1     ; Il faut envoyer l'EOI aux DEUX PIC}\par
{\f1     MOV AL, 20h}\par
{\f1     OUT A0h, AL          ; EOI au PIC esclave}\par
{\f1     MOV AL, 20h}\par
{\f1     OUT 20h, AL          ; EOI au PIC maitre (cascade)}\par
\par
{\f1   8.6.4 Masquage des interruptions}\par
\par
{\f1   Chaque PIC possede un registre de masque (IMR) accessible}\par
{\f1   via le port de donnees (21h pour le maitre, A1h pour l'esclave).}\par
{\f1   Un bit a 1 masque l'IRQ correspondante.}\par
\par
{\f1     ; Masquer IRQ 1 (clavier) uniquement}\par
{\f1     IN  AL, 21h          ; Lire le masque actuel}\par
{\f1     OR  AL, 02h          ; Mettre le bit 1 a 1}\par
{\f1     OUT 21h, AL          ; Ecrire le nouveau masque}\par
\par
{\f1     ; Demasquer IRQ 1 (clavier)}\par
{\f1     IN  AL, 21h}\par
{\f1     AND AL, NOT 02h      ; FDh = 11111101b}\par
{\f1     OUT 21h, AL}\par
\par
\par
\b 8.7 Interruptions logicielles (INT n) \b0\par
\par
{\f1   L'instruction INT n declenche l'interruption de vecteur n.}\par
{\f1   Elle est utilisee pour les appels systeme et les services}\par
{\f1   du BIOS/DOS.}\par
\par
{\f1   Encodage :}\par
\par
{\f1     INT 3       ; Opcode CC (1 octet, cas special breakpoint)}\par
{\f1     INT n       ; Opcode CD n (2 octets, n = 0-255)}\par
{\f1     INTO        ; Opcode CE (INT 4 si OF=1)}\par
\par
{\f1   Comportement de INT n :}\par
\par
{\f1   1. Le processeur verifie le DPL de la porte dans l'IDT :}\par
{\f1      CPL <= DPL pour les interruptions logicielles.}\par
{\f1      Si CPL > DPL : exception #GP (protection).}\par
\par
{\f1   2. Empile EFLAGS, CS et EIP sur la pile (du handler)}\par
\par
{\f1   3. Si porte d'interruption : efface IF et TF}\par
{\f1      Si porte de piege : efface seulement TF}\par
\par
{\f1   4. Charge CS:EIP depuis le descripteur de la porte}\par
\par
{\f1   5. Execute le handler}\par
\par
{\f1   Interruptions logicielles courantes (mode reel) :}\par
\par
{\f1     INT 10h     ; Services video BIOS}\par
{\f1     INT 13h     ; Services disque BIOS}\par
{\f1     INT 16h     ; Services clavier BIOS}\par
{\f1     INT 21h     ; Services DOS}\par
{\f1     INT 33h     ; Driver souris}\par
\par
{\f1   Interruptions logicielles courantes (mode protege) :}\par
\par
{\f1     INT 80h     ; Appels systeme Linux (convention i386)}\par
{\f1     INT 2Eh     ; Appels systeme Windows NT (ancienne methode)}\par
{\f1     INT 3       ; Breakpoint (debugger)}\par
\par
\par
\b 8.8 Mecanisme de dispatch des interruptions \b0\par
\par
{\f1   Quand une interruption ou exception est declenchee, le}\par
{\f1   processeur execute la sequence suivante :}\par
\par
{\f1   8.8.1 Sans changement de privilege (intra-privilege)}\par
\par
{\f1   Si le handler s'execute au meme niveau de privilege que}\par
{\f1   le code interrompu (meme CPL) :}\par
\par
{\f1   1. Empiler EFLAGS (32 bits)}\par
{\f1   2. Empiler CS (16 bits, etendu a 32 bits)}\par
{\f1   3. Empiler EIP (32 bits)}\par
{\f1   4. Si l'exception a un code d'erreur : empiler le code (32 bits)}\par
{\f1   5. Si porte d'interruption : IF = 0, TF = 0}\par
{\f1      Si porte de piege : TF = 0}\par
{\f1   6. Charger CS depuis le selecteur de la porte}\par
{\f1   7. Charger EIP depuis l'offset de la porte}\par
\par
{\f1   Etat de la pile apres l'interruption :}\par
\par
{\f1     ESP+12 : EFLAGS (ancien)}\par
{\f1     ESP+8  : CS     (ancien)}\par
{\f1     ESP+4  : EIP    (ancien)}\par
{\f1     ESP    : Code d'erreur (si applicable)}\par
\par
{\f1   8.8.2 Avec changement de privilege (inter-privilege)}\par
\par
{\f1   Si le handler s'execute a un niveau de privilege plus}\par
{\f1   eleve (CPL du handler < CPL du code interrompu), le}\par
{\f1   processeur effectue un changement de pile :}\par
\par
{\f1   1. Lire le SS:ESP de la nouvelle pile dans le TSS}\par
{\f1      (champ SS0:ESP0 pour passage au ring 0)}\par
{\f1   2. Empiler l'ancien SS (16 bits, etendu a 32 bits)}\par
{\f1   3. Empiler l'ancien ESP (32 bits)}\par
{\f1   4. Empiler EFLAGS (32 bits)}\par
{\f1   5. Empiler CS (16 bits, etendu a 32 bits)}\par
{\f1   6. Empiler EIP (32 bits)}\par
{\f1   7. Si code d'erreur : empiler le code (32 bits)}\par
{\f1   8. Charger SS:ESP depuis le TSS}\par
{\f1   9. Si porte d'interruption : IF = 0, TF = 0}\par
{\f1   10. Charger CS:EIP depuis la porte}\par
\par
{\f1   Etat de la pile (ring 0) apres l'interruption :}\par
\par
{\f1     ESP+20 : SS     (ancien, ring 3)}\par
{\f1     ESP+16 : ESP    (ancien, ring 3)}\par
{\f1     ESP+12 : EFLAGS (ancien)}\par
{\f1     ESP+8  : CS     (ancien)}\par
{\f1     ESP+4  : EIP    (ancien)}\par
{\f1     ESP    : Code d'erreur (si applicable)}\par
\par
{\f1   Ce mecanisme est essentiel pour la securite : le code}\par
{\f1   utilisateur (ring 3) ne peut pas corrompre la pile du}\par
{\f1   noyau (ring 0) car le processeur change automatiquement}\par
{\f1   de pile avant d'empiler quoi que ce soit.}\par
\par
{\f1   8.8.3 Schema du mecanisme de dispatch}\par
\par
{\f1     Interruption/Exception}\par
{\f1            |}\par
{\f1            v}\par
{\f1     Lire le descripteur dans l'IDT[vecteur]}\par
{\f1            |}\par
{\f1            v}\par
{\f1     Verifier P=1, DPL >= CPL (pour INT n logiciel)}\par
{\f1            |}\par
{\f1            +--- Changement de privilege necessaire ?}\par
{\f1            |            |                    |}\par
{\f1            |           Oui                  Non}\par
{\f1            |            |                    |}\par
{\f1            |    Lire SS:ESP du TSS   Utiliser la pile}\par
{\f1            |    Changer de pile       actuelle}\par
{\f1            |            |                    |}\par
{\f1            +------------+--------------------+}\par
{\f1            |}\par
{\f1            v}\par
{\f1     Empiler [SS, ESP], EFLAGS, CS, EIP [, Error Code]}\par
{\f1            |}\par
{\f1            v}\par
{\f1     IF = 0 (si Interrupt Gate), TF = 0}\par
{\f1            |}\par
{\f1            v}\par
{\f1     CS:EIP = Handler (depuis la porte IDT)}\par
{\f1            |}\par
{\f1            v}\par
{\f1     Execution du handler}\par
{\f1            |}\par
{\f1            v}\par
{\f1     IRET -> Restauration de CS:EIP, EFLAGS [, SS:ESP]}\par
\par
\par
\b 8.9 Instructions liees aux interruptions \b0\par
\par
{\f1   8.9.1 CLI - Clear Interrupt Flag}\par
\par
{\f1     CLI                 ; IF = 0 (desactive les interruptions masquables)}\par
\par
{\f1   Opcode : FA}\par
{\f1   Privilege : IOPL (en mode protege, CPL <= IOPL requis)}\par
{\f1   Si CPL > IOPL : exception #GP(0)}\par
{\f1   Utilisation : sections critiques, handlers d'interruptions}\par
\par
{\f1   8.9.2 STI - Set Interrupt Flag}\par
\par
{\f1     STI                 ; IF = 1 (active les interruptions masquables)}\par
\par
{\f1   Opcode : FB}\par
{\f1   Privilege : IOPL (en mode protege, CPL <= IOPL requis)}\par
{\f1   Note importante : les interruptions ne sont activees qu'apres}\par
{\f1   l'instruction SUIVANT STI, ce qui permet la sequence :}\par
{\f1     STI}\par
{\f1     HLT                 ; L'interruption reveille le processeur}\par
\par
{\f1   8.9.3 INT n - Software Interrupt}\par
\par
{\f1     INT imm8            ; Declenche l'interruption de vecteur n}\par
\par
{\f1   Opcode : CD n (2 octets), sauf INT 3 = CC (1 octet)}\par
{\f1   Empile EFLAGS, CS, EIP. Efface IF et TF (si Interrupt Gate).}\par
{\f1   Verifie DPL >= CPL pour les interruptions logicielles.}\par
\par
{\f1   8.9.4 INTO - Interrupt on Overflow}\par
\par
{\f1     INTO                ; Si OF=1 : INT 4, sinon NOP}\par
\par
{\f1   Opcode : CE}\par
{\f1   Utilisee apres des operations arithmetiques signees pour}\par
{\f1   detecter les debordements :}\par
{\f1     ADD EAX, EBX}\par
{\f1     INTO                ; Exception si debordement}\par
\par
{\f1   8.9.5 IRET / IRETD - Interrupt Return}\par
\par
{\f1     IRET                ; Retour d'interruption 16 bits}\par
{\f1     IRETD               ; Retour d'interruption 32 bits}\par
\par
{\f1   Opcode : CF}\par
{\f1   Depile EIP, CS, EFLAGS (et SS, ESP si changement de privilege).}\par
{\f1   Restaure le contexte precedent l'interruption.}\par
\par
{\f1   En mode protege 32 bits, IRETD est utilise :}\par
{\f1   - Depile EIP (32 bits)}\par
{\f1   - Depile CS  (32 bits, seuls les 16 bits bas sont utilises)}\par
{\f1   - Depile EFLAGS (32 bits)}\par
{\f1   - Si retour a un niveau de privilege inferieur :}\par
{\f1     depile aussi ESP et SS (retour ring 0 -> ring 3)}\par
\par
{\f1   Restrictions :}\par
{\f1   - Le drapeau IOPL ne peut etre modifie que si CPL = 0}\par
{\f1   - Le drapeau IF ne peut etre modifie que si CPL <= IOPL}\par
{\f1   - Le drapeau VM (Virtual 8086) ne peut etre active que depuis ring 0}\par
\par
{\f1   8.9.6 BOUND - Check Array Bounds}\par
\par
{\f1     BOUND reg16, mem32  ; Verifie reg16 dans [mem:mem+2]}\par
{\f1     BOUND reg32, mem64  ; Verifie reg32 dans [mem:mem+4]}\par
\par
{\f1   Opcode : 62 /r}\par
{\f1   Si l'index est hors des limites, declenche l'exception}\par
{\f1   #BR (vecteur 5). Utile pour la verification des bornes}\par
{\f1   de tableaux dans les langages de haut niveau.}\par
\par
{\f1     bounds  DD 0, 99          ; Limites : 0 a 99}\par
{\f1     BOUND EAX, [bounds]       ; #BR si EAX < 0 ou EAX > 99}\par
\par
{\f1   8.9.7 HLT - Halt}\par
\par
{\f1     HLT                 ; Arrete le processeur jusqu'a la}\par
{\f1                         ; prochaine interruption, NMI ou RESET}\par
\par
{\f1   Opcode : F4}\par
{\f1   Privilege : instruction privilegiee (CPL = 0 requis)}\par
{\f1   Utilisation typique dans les boucles d'attente du noyau :}\par
{\f1     .idle_loop:}\par
{\f1       STI               ; Activer les interruptions}\par
{\f1       HLT               ; Attendre une interruption}\par
{\f1       JMP .idle_loop    ; Reprendre apres l'interruption}\par
\par
\par
\b 8.10 Gestion des exceptions avec code d'erreur \b0\par
\par
{\f1   Certaines exceptions empilent un code d'erreur de 32 bits}\par
{\f1   apres EFLAGS/CS/EIP. Le handler doit depiler ce code}\par
{\f1   avant d'executer IRET.}\par
\par
{\f1   8.10.1 Format general du code d'erreur}\par
\par
{\f1     31                              3  2  1  0}\par
{\f1   +----------------------------------+--+--+--+}\par
{\f1   |        Index de selecteur        |TI|IDT|EXT|}\par
{\f1   +----------------------------------+--+--+--+}\par
\par
{\f1   EXT (bit 0) : External event}\par
{\f1     1 = L'exception a ete causee par un evenement externe}\par
{\f1         (interruption materielle)}\par
{\f1     0 = L'exception a ete causee par le code en cours}\par
\par
{\f1   IDT (bit 1) : IDT reference}\par
{\f1     1 = L'index fait reference a un descripteur dans l'IDT}\par
{\f1     0 = L'index fait reference a un descripteur dans la}\par
{\f1         GDT ou LDT (selon TI)}\par
\par
{\f1   TI (bit 2) : Table Indicator (quand IDT=0)}\par
{\f1     0 = L'index fait reference a la GDT}\par
{\f1     1 = L'index fait reference a la LDT}\par
\par
{\f1   Index (bits 15-3) : Index du descripteur dans la table}\par
{\f1     (divise par 8 pour obtenir le selecteur)}\par
\par
{\f1   8.10.2 Code d'erreur de #PF (Page Fault)}\par
\par
{\f1   Le code d'erreur de #PF a un format different}\par
{\f1   (voir section 7.9.1) :}\par
\par
{\f1     Bit 0 (P)   : 0 = page non presente, 1 = violation protection}\par
{\f1     Bit 1 (W/R) : 0 = lecture, 1 = ecriture}\par
{\f1     Bit 2 (U/S) : 0 = superviseur, 1 = utilisateur}\par
\par
{\f1   8.10.3 Depilage du code d'erreur dans le handler}\par
\par
{\f1   Le handler DOIT depiler le code d'erreur avant IRET,}\par
{\f1   car IRET ne le fait pas automatiquement :}\par
\par
{\f1     handler_gp:           ; Handler de #GP}\par
{\f1       POP EAX             ; Depiler le code d'erreur dans EAX}\par
{\f1       ; ... traitement de l'exception ...}\par
{\f1       ; Analyser le code d'erreur dans EAX}\par
{\f1       IRETD               ; Retour (depile EIP, CS, EFLAGS)}\par
\par
{\f1   Alternative sans utiliser de registre :}\par
\par
{\f1     handler_gp:}\par
{\f1       ADD ESP, 4          ; Ignorer le code d'erreur}\par
{\f1       ; ... traitement ...}\par
{\f1       IRETD}\par
\par
{\f1   8.10.4 Exceptions avec et sans code d'erreur}\par
\par
{\f1   Avec code d'erreur    : #DF(8), #TS(10), #NP(11), #SS(12),}\par
{\f1                           #GP(13), #PF(14)}\par
\par
{\f1   Sans code d'erreur    : #DE(0), #DB(1), NMI(2), #BP(3),}\par
{\f1                           #OF(4), #BR(5), #UD(6), #NM(7),}\par
{\f1                           Copro(9), #MF(16)}\par
\par
{\f1   Le handler doit connaitre le type d'exception pour savoir}\par
{\f1   s'il doit depiler un code d'erreur ou non.}\par
\par
\par
\b 8.11 Double faute et triple faute \b0\par
\par
{\f1   8.11.1 Double Fault (#DF, vecteur 8)}\par
\par
{\f1   Une double faute se produit quand une exception est}\par
{\f1   declenchee pendant le traitement d'une autre exception,}\par
{\f1   et que la combinaison des deux exceptions ne peut pas}\par
{\f1   etre geree en serie.}\par
\par
{\f1   Classification des exceptions pour le double fault :}\par
\par
{\f1   Classe 1 (Benigne) : #DE, #TS, #NP, #SS, #GP}\par
{\f1   Classe 2 (Contributive) : #PF}\par
{\f1   Classe 3 (Page Fault) : #PF}\par
\par
{\f1   Regles de combinaison :}\par
\par
{\f1   Premiere exception  Deuxieme exception  Resultat}\par
{\f1   ------------------  ------------------  --------}\par
{\f1   Benigne             Benigne             Traitement en serie}\par
{\f1   Benigne             #PF                 Traitement en serie}\par
{\f1   #PF                 Benigne             Traitement en serie}\par
{\f1   #PF                 #PF                 Double Fault (#DF)}\par
{\f1   Contributive        Contributive        Double Fault (#DF)}\par
\par
{\f1   En pratique, la double faute se produit le plus souvent}\par
{\f1   quand une faute de page se produit pendant le traitement}\par
{\f1   d'une autre faute de page (par exemple, si le handler de}\par
{\f1   #PF lui-meme provoque un #PF).}\par
\par
{\f1   Le handler de #DF devrait utiliser une porte de tache}\par
{\f1   (Task Gate) dans l'IDT, car cela garantit un changement}\par
{\f1   de pile propre via le TSS, meme si la pile courante est}\par
{\f1   corrompue.}\par
\par
{\f1   8.11.2 Triple Fault}\par
\par
{\f1   Si une exception se produit pendant le traitement d'une}\par
{\f1   double faute, le processeur ne peut plus recuperer.}\par
{\f1   Il effectue un RESET (triple fault) :}\par
{\f1     - Le processeur revient a l'etat initial (mode reel)}\par
{\f1     - Equivalent a un redemarrage materiel}\par
{\f1     - Aucune interruption n'est generee}\par
\par
{\f1   La triple faute est souvent causee par :}\par
{\f1     - Un handler de #DF invalide ou absent}\par
{\f1     - Une IDT corrompue ou inaccessible}\par
{\f1     - Un TSS invalide pour le handler de #DF}\par
\par
{\f1   Sequence de degradation :}\par
\par
{\f1     Exception initiale --> Exception pendant le traitement}\par
{\f1                            --> Double Fault (#DF)}\par
{\f1                                --> Exception pendant #DF}\par
{\f1                                    --> TRIPLE FAULT (RESET)}\par
\par
\par
\b 8.12 Exemple : mise en place d'un handler d'interruption \b0\par
\par
{\f1   Voici un exemple complet d'installation d'un handler}\par
{\f1   d'interruption pour le timer (IRQ 0) en mode protege.}\par
\par
{\f1   8.12.1 Definition du handler}\par
\par
{\f1     timer_count  DD 0              ; Compteur de ticks}\par
\par
{\f1     timer_handler:}\par
{\f1       PUSH EAX                    ; Sauvegarder les registres utilises}\par
{\f1       PUSH DS}\par
\par
{\f1       MOV AX, 10h                 ; Selecteur du segment de donnees}\par
{\f1       MOV DS, AX                  ; Charger DS pour acceder aux donnees}\par
\par
{\f1       INC DWORD PTR [timer_count] ; Incrementer le compteur}\par
\par
{\f1       ; Envoyer EOI au PIC maitre}\par
{\f1       MOV AL, 20h}\par
{\f1       OUT 20h, AL}\par
\par
{\f1       POP DS                      ; Restaurer les registres}\par
{\f1       POP EAX}\par
{\f1       IRETD                       ; Retour d'interruption}\par
\par
{\f1   8.12.2 Installation dans l'IDT}\par
\par
{\f1   Chaque entree de l'IDT fait 8 octets. Pour le vecteur 20h}\par
{\f1   (IRQ 0 remappee) :}\par
\par
{\f1     ; Construire le descripteur de porte d'interruption}\par
{\f1     ; Selecteur de code = 08h, DPL = 0, type = 0Eh (32-bit Int Gate)}\par
\par
{\f1     MOV EAX, timer_handler           ; Adresse du handler}\par
{\f1     MOV WORD PTR [idt_table + 20h*8 + 0], AX     ; Offset [15:0]}\par
{\f1     MOV WORD PTR [idt_table + 20h*8 + 2], 08h    ; Selecteur code}\par
{\f1     MOV BYTE PTR [idt_table + 20h*8 + 4], 00h    ; Reserve}\par
{\f1     MOV BYTE PTR [idt_table + 20h*8 + 5], 8Eh    ; P=1,DPL=0,type=0Eh}\par
{\f1     SHR EAX, 16}\par
{\f1     MOV WORD PTR [idt_table + 20h*8 + 6], AX     ; Offset [31:16]}\par
\par
{\f1   L'octet d'attribut 8Eh se decompose :}\par
{\f1     1 0 0 0 1 1 1 0}\par
{\f1     P DPL 0 D 1 1 0}\par
{\f1     P=1, DPL=00, type=0Eh (32-bit Interrupt Gate)}\par
\par
{\f1   8.12.3 Installation d'un handler d'exception (#GP)}\par
\par
{\f1     gp_handler:}\par
{\f1       POP EAX                     ; Depiler le code d'erreur}\par
{\f1       ; EAX contient le code d'erreur (selecteur fautif)}\par
\par
{\f1       ; ... afficher un message d'erreur ...}\par
{\f1       ; ... terminer le processus ou faire un HALT ...}\par
\par
{\f1       ; Si on veut reprendre (rarement possible pour #GP) :}\par
{\f1       ; IRETD}\par
\par
{\f1       ; En pratique, on arrete :}\par
{\f1       HLT}\par
\par
{\f1   Installation dans l'IDT pour le vecteur 13 (#GP) :}\par
\par
{\f1     MOV EAX, gp_handler}\par
{\f1     MOV WORD PTR [idt_table + 0Dh*8 + 0], AX}\par
{\f1     MOV WORD PTR [idt_table + 0Dh*8 + 2], 08h}\par
{\f1     MOV BYTE PTR [idt_table + 0Dh*8 + 4], 00h}\par
{\f1     MOV BYTE PTR [idt_table + 0Dh*8 + 5], 8Fh    ; Trap Gate, P=1}\par
{\f1     SHR EAX, 16}\par
{\f1     MOV WORD PTR [idt_table + 0Dh*8 + 6], AX}\par
\par
{\f1   Note : 8Fh = porte de piege (Trap Gate, type 0Fh) car on}\par
{\f1   veut que les interruptions materielles restent actives}\par
{\f1   pendant le traitement de #GP.}\par
\par
\par
\b 8.13 Resume des vecteurs d'interruption \b0\par
\par
{\f1   Vecteurs  Usage}\par
{\f1   --------  ---------------------------------------------------}\par
{\f1    0 - 16   Exceptions definies par Intel (reserves au processeur)}\par
{\f1   17 - 31   Reserves par Intel (futurs processeurs)}\par
{\f1   32 - 47   IRQ 0-15 (apres remappage typique 20h-2Fh)}\par
{\f1   48 - 255  Disponibles pour les interruptions logicielles}\par
{\f1             (appels systeme, services utilisateur, etc.)}\par
\par
{\f1   Registres de controle lies aux interruptions :}\par
\par
{\f1   EFLAGS.IF  : Autorise/bloque les interruptions masquables}\par
{\f1   EFLAGS.TF  : Active le mode trace (exception #DB apres}\par
{\f1                chaque instruction)}\par
{\f1   EFLAGS.IOPL: Niveau de privilege requis pour CLI/STI/IN/OUT}\par
{\f1   EFLAGS.NT  : Nested Task (pour IRET avec commutation de tache)}\par
{\f1   EFLAGS.VM  : Virtual 8086 Mode}\par
\par
{\f1   IDTR       : Adresse et limite de l'IDT}\par
{\f1   CR0.NE     : Numeric Error (FPU, exception #MF vs IRQ 13)}\par
\par
{\f1   En resume, le systeme d'interruptions du 80386 fournit un}\par
{\f1   mecanisme complet et securise pour gerer les evenements}\par
{\f1   asynchrones (interruptions materielles), les appels systeme}\par
{\f1   (interruptions logicielles) et les conditions d'erreur}\par
{\f1   (exceptions), avec des niveaux de protection, un changement}\par
{\f1   automatique de pile et une table de dispatch configurable (IDT).}\par
\par
\par
