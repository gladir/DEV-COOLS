{\footnote # IDH_ASM80386_10}
{\footnote $ Assembleur 80386 - DIRECTIVES ASSEMBLEUR (MASM/TASM)}
{\footnote K Assembleur 80386 directives MASM TASM;ASM86.PAS MASM.PAS;DB DW DD DQ DF DT;DUP;SEGMENT ENDS;ASSUME;PROC ENDP;.MODEL;.386 .486;.CODE .DATA .STACK;EQU =;MACRO ENDM;ORG END}
\b\fs24 DIRECTIVES ASSEMBLEUR (MASM/TASM) \b0\fs20\par
\par
{\f1   Les directives assembleur ne sont pas des instructions executees par}\par
{\f1   le processeur. Ce sont des commandes interpretees par l'assembleur}\par
{\f1   (MASM, TASM, WASM, etc.) pour controler l'assemblage : organisation}\par
{\f1   de la memoire, definition de donnees, macros, assemblage conditionnel,}\par
{\f1   etc. Cette section couvre les directives les plus courantes pour le}\par
{\f1   mode 32 bits (80386+).}\par
\par
\par
\b 10.1 Directives de processeur \b0\par
\par
{\f1   Ces directives indiquent a l'assembleur quel jeu d'instructions}\par
{\f1   est autorise. Elles doivent apparaitre en debut de fichier.}\par
\par
{\f1     .8086           ; Jeu d'instructions 8086 uniquement (defaut)}\par
{\f1     .186            ; Ajout des instructions du 80186}\par
{\f1     .286            ; Ajout des instructions du 80286}\par
{\f1     .286P           ; 80286, instructions privilegiees autorisees}\par
{\f1     .386            ; Ajout des instructions du 80386}\par
{\f1     .386P           ; 80386, instructions privilegiees autorisees}\par
{\f1     .486            ; Ajout des instructions du 80486}\par
{\f1     .486P           ; 80486, instructions privilegiees autorisees}\par
{\f1     .586            ; Ajout des instructions du Pentium}\par
{\f1     .586P           ; Pentium, instructions privilegiees autorisees}\par
{\f1     .686            ; Ajout des instructions du Pentium Pro}\par
{\f1     .686P           ; Pentium Pro, instructions privilegiees autorisees}\par
\par
{\f1   Directives de coprocesseur :}\par
\par
{\f1     .8087           ; Instructions du coprocesseur 8087}\par
{\f1     .287            ; Instructions du coprocesseur 80287}\par
{\f1     .387            ; Instructions du coprocesseur 80387}\par
{\f1     .NO87           ; Desactive les instructions de coprocesseur}\par
\par
{\f1   Note : .386 et superieur active automatiquement les registres 32 bits}\par
{\f1   (EAX, EBX, etc.) et les modes d'adressage etendus du 80386.}\par
\par
{\f1   Sans suffixe P, seules les instructions non privilegiees sont}\par
{\f1   autorisees. Avec le suffixe P, les instructions privilegiees}\par
{\f1   comme LGDT, LIDT, MOV CR0, etc. sont egalement acceptees.}\par
\par
\par
\b 10.2 Directives de modele memoire (.MODEL) \b0\par
\par
{\f1   La directive .MODEL definit le modele memoire utilise par le}\par
{\f1   programme. Elle controle la taille par defaut des pointeurs}\par
{\f1   (NEAR ou FAR) et la convention d'appel.}\par
\par
{\f1   Syntaxe :}\par
\par
{\f1     .MODEL modele [, convention] [, type_pile]}\par
\par
{\f1   Modeles memoire :}\par
\par
{\f1   Modele      Segments de  Segments de   Pointeurs}\par
{\f1               code         donnees       par defaut}\par
{\f1   ----------  -----------  -----------   --------------------}\par
{\f1   TINY        1            1 (=code)     NEAR (COM, < 64Ko)}\par
{\f1   SMALL       1            1             NEAR code, NEAR data}\par
{\f1   MEDIUM      Plusieurs    1             FAR code, NEAR data}\par
{\f1   COMPACT     1            Plusieurs     NEAR code, FAR data}\par
{\f1   LARGE       Plusieurs    Plusieurs     FAR code, FAR data}\par
{\f1   HUGE        Plusieurs    Plusieurs     FAR, tableaux > 64Ko}\par
{\f1   FLAT        1 (32 bits)  1 (32 bits)   NEAR 32 bits (0-4Go)}\par
\par
{\f1   Le modele FLAT est le plus utilise pour la programmation 32 bits}\par
{\f1   (Win32, Linux 32 bits). Il utilise un espace d'adressage plat}\par
{\f1   de 4 Go avec des pointeurs NEAR 32 bits.}\par
\par
{\f1   Conventions d'appel :}\par
\par
{\f1     C           Convention C : parametres empiles de droite a gauche,}\par
{\f1                 l'appelant nettoie la pile. Noms prefixes par _.}\par
{\f1     STDCALL     Convention Windows : parametres de droite a gauche,}\par
{\f1                 l'appele nettoie la pile (RET n). Noms decores @.}\par
{\f1     PASCAL      Convention Pascal : parametres de gauche a droite,}\par
{\f1                 l'appele nettoie la pile.}\par
{\f1     BASIC       Similaire a Pascal.}\par
{\f1     FORTRAN     Similaire a Pascal.}\par
{\f1     SYSCALL     Convention des appels systeme OS/2.}\par
\par
{\f1   Exemples :}\par
\par
{\f1     .MODEL SMALL, C              ; Mode 16 bits, convention C}\par
{\f1     .MODEL FLAT, STDCALL         ; Mode 32 bits Win32}\par
{\f1     .MODEL FLAT, C               ; Mode 32 bits, convention C}\par
\par
\par
\b 10.3 Directives de segment simplifiees \b0\par
\par
{\f1   Les directives simplifiees creent automatiquement les segments}\par
{\f1   standards. Elles necessitent une directive .MODEL prealable.}\par
\par
{\f1     .CODE [nom]     ; Ouvre le segment de code (ou un segment}\par
{\f1                     ; de code nomme en modele MEDIUM/LARGE)}\par
{\f1     .DATA           ; Ouvre le segment de donnees initialisees}\par
{\f1     .DATA?          ; Ouvre le segment de donnees non initialisees}\par
{\f1     .CONST          ; Ouvre le segment de constantes (lecture seule)}\par
{\f1     .STACK [taille] ; Definit le segment de pile}\par
{\f1                     ; (defaut : 1024 octets)}\par
\par
{\f1   Exemple typique (programme 32 bits Win32) :}\par
\par
{\f1     .386}\par
{\f1     .MODEL FLAT, STDCALL}\par
{\f1     OPTION CASEMAP:NONE}\par
\par
{\f1     .STACK 4096}\par
\par
{\f1     .DATA}\par
{\f1     message  DB 'Hello, World!', 0}\par
{\f1     nombre   DD 42}\par
\par
{\f1     .DATA?}\par
{\f1     buffer   DB 256 DUP(?)}\par
\par
{\f1     .CODE}\par
{\f1     main PROC}\par
{\f1       ; ... code du programme ...}\par
{\f1       RET}\par
{\f1     main ENDP}\par
{\f1     END main}\par
\par
\par
\b 10.4 Directives de segment completes \b0\par
\par
{\f1   Les directives completes offrent un controle total sur la}\par
{\f1   definition des segments.}\par
\par
{\f1   Syntaxe :}\par
\par
{\f1     nom SEGMENT [align] [combine] [use] ['class']}\par
{\f1       ; ... contenu du segment ...}\par
{\f1     nom ENDS}\par
\par
{\f1   Parametres :}\par
\par
{\f1   align (alignement) :}\par
{\f1     BYTE      ; Aucun alignement}\par
{\f1     WORD      ; Aligne sur 2 octets}\par
{\f1     DWORD     ; Aligne sur 4 octets}\par
{\f1     PARA      ; Aligne sur 16 octets (paragraphe, defaut)}\par
{\f1     PAGE      ; Aligne sur 256 octets}\par
\par
{\f1   combine (combinaison) :}\par
{\f1     PRIVATE   ; Le segment n'est pas combine (defaut)}\par
{\f1     PUBLIC    ; Les segments de meme nom sont concatenes}\par
{\f1     COMMON    ; Les segments de meme nom se superposent}\par
{\f1     STACK     ; Concatenation pour le segment de pile}\par
{\f1     AT adresse; Le segment est place a une adresse fixe}\par
\par
{\f1   use (mode) :}\par
{\f1     USE16     ; Segment 16 bits (defaut si .286 ou inferieur)}\par
{\f1     USE32     ; Segment 32 bits (defaut si .386 ou superieur)}\par
\par
{\f1   'class' : Chaine de classification pour le linker.}\par
{\f1     'CODE'    ; Segment de code}\par
{\f1     'DATA'    ; Segment de donnees}\par
{\f1     'STACK'   ; Segment de pile}\par
{\f1     'BSS'     ; Segment de donnees non initialisees}\par
\par
{\f1   Exemple (mode 16 bits) :}\par
\par
{\f1     _TEXT SEGMENT PARA PUBLIC USE16 'CODE'}\par
{\f1       ; ... code ...}\par
{\f1     _TEXT ENDS}\par
\par
{\f1     _DATA SEGMENT PARA PUBLIC USE16 'DATA'}\par
{\f1       ; ... donnees ...}\par
{\f1     _DATA ENDS}\par
\par
{\f1     STACK SEGMENT PARA STACK USE16 'STACK'}\par
{\f1       DB 256 DUP(?)}\par
{\f1     STACK ENDS}\par
\par
{\f1   Exemple (mode 32 bits) :}\par
\par
{\f1     _TEXT SEGMENT DWORD PUBLIC USE32 'CODE'}\par
{\f1       ; ... code 32 bits ...}\par
{\f1     _TEXT ENDS}\par
\par
{\f1     _DATA SEGMENT DWORD PUBLIC USE32 'DATA'}\par
{\f1       ; ... donnees 32 bits ...}\par
{\f1     _DATA ENDS}\par
\par
\par
\b 10.5 Directives ASSUME et GROUP \b0\par
\par
{\f1   ASSUME indique a l'assembleur quel registre de segment pointe}\par
{\f1   vers quel segment. Essentiel en mode 16 bits segmente, moins}\par
{\f1   utile en mode FLAT 32 bits.}\par
\par
{\f1     ASSUME CS:_TEXT, DS:_DATA, SS:STACK}\par
{\f1     ASSUME ES:NOTHING           ; Pas d'association pour ES}\par
{\f1     ASSUME NOTHING              ; Retire toutes les associations}\par
\par
{\f1   GROUP regroupe plusieurs segments sous un meme nom de groupe}\par
{\f1   pour qu'ils partagent un registre de segment :}\par
\par
{\f1     DGROUP GROUP _DATA, _BSS, STACK}\par
\par
{\f1   En mode FLAT (32 bits), ASSUME est rarement necessaire car}\par
{\f1   tous les segments partagent la meme base.}\par
\par
\par
\b 10.6 Directives de donnees \b0\par
\par
{\f1   10.6.1 Definition de variables}\par
\par
{\f1   Les directives de donnees reservent et initialisent de la memoire.}\par
\par
{\f1     DB   (Define Byte)       1 octet   (8 bits)}\par
{\f1     DW   (Define Word)       2 octets  (16 bits)}\par
{\f1     DD   (Define Doubleword) 4 octets  (32 bits)}\par
{\f1     DF   (Define Fword)      6 octets  (48 bits, pointeur far 32)}\par
{\f1     DQ   (Define Quadword)   8 octets  (64 bits)}\par
{\f1     DT   (Define Tenbyte)   10 octets  (80 bits, extended float)}\par
\par
{\f1   Syntaxe :}\par
\par
{\f1     [nom]  directive  valeur [, valeur, ...]}\par
\par
{\f1   Exemples :}\par
\par
{\f1     octet1    DB  42              ; Un octet = 42}\par
{\f1     mot1      DW  1234h           ; Un mot = 1234h}\par
{\f1     dword1    DD  12345678h       ; Un double mot}\par
{\f1     qword1    DQ  0               ; Un quadruple mot = 0}\par
{\f1     float1    DD  3.14            ; Flottant simple precision}\par
{\f1     double1   DQ  2.718281828     ; Flottant double precision}\par
{\f1     extend1   DT  1.0             ; Flottant etendu 80 bits}\par
\par
{\f1   Chaines de caracteres :}\par
\par
{\f1     msg1      DB  'Hello', 0      ; Chaine terminee par un zero}\par
{\f1     msg2      DB  'A', 'B', 'C'   ; Equivalent a DB 41h, 42h, 43h}\par
{\f1     msg3      DB  "Guillemets"    ; Guillemets doubles aussi acceptes}\par
{\f1     crlf      DB  0Dh, 0Ah       ; Retour chariot + saut de ligne}\par
\par
{\f1   Tableaux et repetitions (DUP) :}\par
\par
{\f1     tab1      DB  10 DUP(0)       ; 10 octets initialises a 0}\par
{\f1     tab2      DW  5  DUP(?)       ; 5 mots non initialises}\par
{\f1     tab3      DD  3  DUP(1)       ; 3 double mots = 1, 1, 1}\par
{\f1     matrice   DB  4  DUP(8 DUP(0)); Matrice 4x8 d'octets}\par
{\f1     buf256    DB  256 DUP(?)      ; Tampon de 256 octets}\par
\par
{\f1   Valeur speciale ? : donnee non initialisee. L'assembleur}\par
{\f1   reserve l'espace sans ecrire de valeur. Utilisee dans .DATA?}\par
{\f1   pour les variables BSS.}\par
\par
{\f1   10.6.2 Constantes symboliques}\par
\par
{\f1   EQU - Constante textuelle ou numerique (non modifiable) :}\par
\par
{\f1     MAX_SIZE    EQU  256          ; Constante numerique}\par
{\f1     CR          EQU  0Dh         ; Retour chariot}\par
{\f1     LF          EQU  0Ah         ; Saut de ligne}\par
{\f1     GREETING    EQU  <'Hello'>   ; Constante textuelle}\par
{\f1     PSIZE       EQU  <DWORD PTR> ; Alias de type}\par
\par
{\f1   = - Constante numerique (modifiable, MASM seulement) :}\par
\par
{\f1     compteur    =    0            ; Valeur initiale}\par
{\f1     compteur    =    compteur + 1 ; Reassignation autorisee}\par
\par
{\f1   Difference entre EQU et = :}\par
{\f1     - EQU ne peut pas etre redefini. = peut l'etre.}\par
{\f1     - EQU accepte du texte et des nombres. = uniquement des nombres.}\par
{\f1     - EQU est supporte par MASM et TASM. = est MASM seulement.}\par
\par
{\f1   10.6.3 Operateurs de type et de taille}\par
\par
{\f1     BYTE PTR [addr]   ; Force l'acces en 8 bits}\par
{\f1     WORD PTR [addr]   ; Force l'acces en 16 bits}\par
{\f1     DWORD PTR [addr]  ; Force l'acces en 32 bits}\par
{\f1     QWORD PTR [addr]  ; Force l'acces en 64 bits}\par
{\f1     FWORD PTR [addr]  ; Force l'acces en 48 bits}\par
{\f1     TBYTE PTR [addr]  ; Force l'acces en 80 bits}\par
\par
{\f1     TYPE variable     ; Retourne la taille en octets de la variable}\par
{\f1     LENGTHOF tableau  ; Nombre d'elements du tableau (MASM 6+)}\par
{\f1     SIZEOF tableau    ; Taille totale en octets (MASM 6+)}\par
{\f1     LENGTH tableau    ; Nombre d'elements (ancienne syntaxe)}\par
{\f1     SIZE tableau      ; Taille totale (ancienne syntaxe)}\par
\par
{\f1     OFFSET variable   ; Adresse (offset) de la variable}\par
{\f1     SEG variable      ; Segment de la variable (mode 16 bits)}\par
{\f1     ADDR variable     ; Adresse pour INVOKE (MASM)}\par
{\f1     THIS type         ; Cree un alias a la position courante}\par
\par
{\f1   Exemples :}\par
\par
{\f1     MOV AL, BYTE PTR [ESI]       ; Lire un octet}\par
{\f1     MOV EAX, DWORD PTR [ESI]    ; Lire un double mot}\par
{\f1     MOV ECX, LENGTHOF tableau   ; Nombre d'elements}\par
{\f1     LEA EAX, [variable]         ; Charger l'adresse effective}\par
{\f1     PUSH OFFSET message         ; Empiler l'adresse du message}\par
\par
\par
\b 10.7 Directives de procedures \b0\par
\par
{\f1   10.7.1 PROC et ENDP}\par
\par
{\f1   PROC definit une procedure avec gestion automatique du prologue,}\par
{\f1   de l'epilogue et des parametres (MASM 6+).}\par
\par
{\f1   Syntaxe simple :}\par
\par
{\f1     nom PROC [distance]}\par
{\f1       ; ... corps de la procedure ...}\par
{\f1       RET}\par
{\f1     nom ENDP}\par
\par
{\f1   Distance :}\par
{\f1     NEAR    ; Appel intra-segment (defaut en FLAT)}\par
{\f1     FAR     ; Appel inter-segment}\par
\par
{\f1   Syntaxe etendue (MASM 6+) avec parametres :}\par
\par
{\f1     nom PROC [distance] [convention] [USES regs] [, params]}\par
{\f1       ; ... corps ...}\par
{\f1       RET}\par
{\f1     nom ENDP}\par
\par
{\f1   USES : liste des registres a sauvegarder automatiquement}\par
{\f1   (PUSH au debut, POP a la fin).}\par
\par
{\f1   Parametres : nom:type declares apres le nom de la procedure.}\par
\par
{\f1   Exemple :}\par
\par
{\f1     Addition PROC STDCALL USES EBX ECX, a:DWORD, b:DWORD}\par
{\f1       MOV EAX, a          ; Acces au parametre a = [EBP+8]}\par
{\f1       ADD EAX, b          ; Acces au parametre b = [EBP+12]}\par
{\f1       RET                 ; Retour avec nettoyage de la pile}\par
{\f1     Addition ENDP}\par
\par
{\f1   L'assembleur genere automatiquement :}\par
{\f1     - PUSH EBP / MOV EBP, ESP (prologue)}\par
{\f1     - PUSH EBX / PUSH ECX (sauvegarde USES)}\par
{\f1     - POP ECX / POP EBX (restauration USES)}\par
{\f1     - MOV ESP, EBP / POP EBP (epilogue)}\par
{\f1     - RET 8 (nettoyage de 2 parametres DWORD en STDCALL)}\par
\par
{\f1   10.7.2 LOCAL}\par
\par
{\f1   LOCAL declare des variables locales sur la pile a l'interieur}\par
{\f1   d'une procedure PROC.}\par
\par
{\f1     nom PROC ...}\par
{\f1       LOCAL var1:DWORD           ; 1 variable locale de 4 octets}\par
{\f1       LOCAL buf[256]:BYTE        ; Tableau local de 256 octets}\par
{\f1       LOCAL x:DWORD, y:DWORD    ; Plusieurs variables locales}\par
{\f1       ; ...}\par
{\f1     nom ENDP}\par
\par
{\f1   L'assembleur genere SUB ESP, n dans le prologue pour reserver}\par
{\f1   l'espace des variables locales et les rend accessibles par}\par
{\f1   nom (traduites en [EBP-offset]).}\par
\par
{\f1   10.7.3 INVOKE (MASM seulement)}\par
\par
{\f1   INVOKE appelle une procedure avec verification automatique}\par
{\f1   du nombre et du type des parametres, et empile les arguments}\par
{\f1   dans l'ordre correct selon la convention d'appel.}\par
\par
{\f1   Syntaxe :}\par
\par
{\f1     INVOKE nom_procedure, arg1, arg2, ...}\par
\par
{\f1   Necessite une declaration PROTO :}\par
\par
{\f1     nom_procedure PROTO [convention] :type1, :type2, ...}\par
\par
{\f1   Exemple :}\par
\par
{\f1     ; Declaration du prototype}\par
{\f1     MessageBoxA PROTO STDCALL :DWORD, :DWORD, :DWORD, :DWORD}\par
\par
{\f1     ; Appel}\par
{\f1     INVOKE MessageBoxA, 0, ADDR message, ADDR titre, 0}\par
\par
{\f1   INVOKE genere automatiquement :}\par
{\f1     - PUSH des arguments dans l'ordre inverse (convention C/STDCALL)}\par
{\f1     - CALL nom_procedure}\par
{\f1     - ADD ESP, n si convention C (nettoyage par l'appelant)}\par
\par
{\f1   10.7.4 PROTO}\par
\par
{\f1   PROTO declare le prototype d'une procedure (MASM 6+).}\par
\par
{\f1     nom PROTO [convention] [:type1 [, :type2, ...]]}\par
\par
{\f1   Exemples :}\par
\par
{\f1     Addition PROTO STDCALL :DWORD, :DWORD}\par
{\f1     ExitProcess PROTO STDCALL :DWORD}\par
{\f1     printf PROTO C :DWORD, :VARARG     ; Nombre variable d'arguments}\par
\par
{\f1   PROTO permet a INVOKE de verifier les types des arguments}\par
{\f1   et a l'assembleur de generer le bon code d'appel.}\par
\par
\par
\b 10.8 Directives de declarations externes et publiques \b0\par
\par
{\f1   PUBLIC - Rend un symbole visible pour le linker :}\par
\par
{\f1     PUBLIC nom_symbole}\par
{\f1     PUBLIC _main, _data_table}\par
\par
{\f1   EXTRN / EXTERN - Declare un symbole defini dans un autre module :}\par
\par
{\f1     EXTRN symbole:type           ; Syntaxe ancienne (MASM 5)}\par
{\f1     EXTERN symbole:type          ; Syntaxe MASM 6+ (alias)}\par
{\f1     EXTERNDEF symbole:type       ; Definition+declaration (MASM 6+)}\par
\par
{\f1   Types pour EXTRN/EXTERN :}\par
{\f1     BYTE, WORD, DWORD, QWORD     ; Variables}\par
{\f1     NEAR, FAR                     ; Procedures}\par
{\f1     PROC                          ; Procedure (MASM 6+)}\par
{\f1     ABS                           ; Constante absolue}\par
\par
{\f1   Exemples :}\par
\par
{\f1     EXTRN _printf:NEAR            ; Fonction C externe}\par
{\f1     EXTRN ExitProcess@4:NEAR      ; Fonction Win32}\par
{\f1     EXTERN MessageBoxA@16:NEAR    ; Fonction Win32 decoree}\par
{\f1     PUBLIC _main                  ; Exporter le point d'entree}\par
\par
{\f1   EXTERNDEF (MASM 6+) : combine PUBLIC et EXTERN. Si le symbole}\par
{\f1   est defini dans le module courant, il est exporte. Sinon, il}\par
{\f1   est importe. Utile dans les fichiers d'en-tete .INC.}\par
\par
{\f1     EXTERNDEF compteur:DWORD     ; Export si defini, import sinon}\par
\par
\par
\b 10.9 Directives d'inclusion et de liaison \b0\par
\par
{\f1   INCLUDE - Inclut un fichier source dans le fichier courant :}\par
\par
{\f1     INCLUDE fichier.inc           ; Insere le contenu du fichier}\par
{\f1     INCLUDE windows.inc           ; En-tetes Win32 pour MASM}\par
{\f1     INCLUDE macros.inc            ; Fichier de macros personnalisees}\par
\par
{\f1   INCLUDELIB - Indique une bibliotheque a lier :}\par
\par
{\f1     INCLUDELIB kernel32.lib       ; Liaison avec kernel32.dll}\par
{\f1     INCLUDELIB user32.lib         ; Liaison avec user32.dll}\par
{\f1     INCLUDELIB msvcrt.lib         ; Liaison avec la CRT Microsoft}\par
\par
{\f1   INCLUDELIB ne lie pas directement la bibliotheque, mais insere}\par
{\f1   une directive dans le fichier objet pour que le linker la trouve.}\par
\par
{\f1   COMMENT - Commentaire multi-lignes :}\par
\par
{\f1     COMMENT * }\par
{\f1     Ceci est un commentaire}\par
{\f1     sur plusieurs lignes.}\par
{\f1     *}\par
\par
{\f1   Le delimiteur est le premier caractere non-blanc apres COMMENT.}\par
{\f1   Le commentaire se termine a la prochaine occurrence de ce caractere.}\par
\par
\par
\b 10.10 Directives d'assemblage conditionnel \b0\par
\par
{\f1   L'assemblage conditionnel permet d'inclure ou d'exclure du code}\par
{\f1   selon des conditions evaluees au moment de l'assemblage.}\par
\par
{\f1   10.10.1 Conditions sur des expressions}\par
\par
{\f1     IF expression               ; Si expression <> 0}\par
{\f1       ; ... code assemble ...}\par
{\f1     ELSEIF expression2          ; Sinon si expression2 <> 0}\par
{\f1       ; ... code alternatif ...}\par
{\f1     ELSE                        ; Sinon}\par
{\f1       ; ... code par defaut ...}\par
{\f1     ENDIF                       ; Fin de la condition}\par
\par
{\f1   Exemples :}\par
\par
{\f1     DEBUG = 1}\par
\par
{\f1     IF DEBUG}\par
{\f1       CALL AfficherRegistres    ; Code de debug}\par
{\f1     ENDIF}\par
\par
{\f1     IF ($ - debut) GT 100h}\par
{\f1       ; Le code depasse 256 octets}\par
{\f1     ENDIF}\par
\par
{\f1   10.10.2 Conditions sur des symboles}\par
\par
{\f1     IFDEF symbole               ; Si le symbole est defini}\par
{\f1     IFNDEF symbole              ; Si le symbole n'est pas defini}\par
{\f1     IFB <argument>              ; Si l'argument est vide (blank)}\par
{\f1     IFNB <argument>             ; Si l'argument n'est pas vide}\par
{\f1     IFIDN <s1>, <s2>           ; Si les chaines sont identiques}\par
{\f1     IFIDNI <s1>, <s2>          ; Idem, insensible a la casse}\par
{\f1     IFDIF <s1>, <s2>           ; Si les chaines sont differentes}\par
{\f1     IFDIFI <s1>, <s2>          ; Idem, insensible a la casse}\par
\par
{\f1   Exemples :}\par
\par
{\f1     IFDEF _WIN32}\par
{\f1       .MODEL FLAT, STDCALL}\par
{\f1     ELSE}\par
{\f1       .MODEL SMALL, C}\par
{\f1     ENDIF}\par
\par
{\f1     IFNDEF MAX_BUF}\par
{\f1       MAX_BUF EQU 256}\par
{\f1     ENDIF}\par
\par
{\f1   10.10.3 Conditions sur les types (MASM seulement)}\par
\par
{\f1     IF1                         ; Passe 1 de l'assemblage}\par
{\f1     IF2                         ; Passe 2 de l'assemblage}\par
{\f1     IFE expression              ; Si expression = 0}\par
\par
\par
\b 10.11 Directives de macro \b0\par
\par
{\f1   10.11.1 Definition et appel}\par
\par
{\f1   MACRO/ENDM definit une macro-instruction. A chaque appel,}\par
{\f1   le corps de la macro est expanse avec substitution des}\par
{\f1   parametres.}\par
\par
{\f1   Syntaxe :}\par
\par
{\f1     nom MACRO [param1 [, param2, ...]]}\par
{\f1       ; ... corps de la macro ...}\par
{\f1     ENDM}\par
\par
{\f1   Exemple :}\par
\par
{\f1     ; Definition de la macro}\par
{\f1     PushAll MACRO}\par
{\f1       PUSH EAX}\par
{\f1       PUSH EBX}\par
{\f1       PUSH ECX}\par
{\f1       PUSH EDX}\par
{\f1     ENDM}\par
\par
{\f1     ; Utilisation}\par
{\f1     PushAll                      ; Expanse les 4 PUSH}\par
\par
{\f1   Macro avec parametres :}\par
\par
{\f1     PrintStr MACRO addr}\par
{\f1       PUSH OFFSET addr}\par
{\f1       CALL _puts}\par
{\f1       ADD ESP, 4}\par
{\f1     ENDM}\par
\par
{\f1     ; Utilisation}\par
{\f1     PrintStr message             ; Affiche la chaine 'message'}\par
\par
{\f1   Macro avec parametres par defaut :}\par
\par
{\f1     AllocBuf MACRO taille:=<256>}\par
{\f1       SUB ESP, taille}\par
{\f1     ENDM}\par
\par
{\f1     AllocBuf                     ; SUB ESP, 256}\par
{\f1     AllocBuf 512                 ; SUB ESP, 512}\par
\par
{\f1   10.11.2 Operateurs de macro}\par
\par
{\f1     &           ; Operateur de substitution (colle le texte)}\par
{\f1     <>          ; Litteraux de texte}\par
{\f1     !           ; Caractere litteral (echappe les caracteres speciaux)}\par
{\f1     %          ; Expression evaluee comme texte}\par
{\f1     ;;          ; Commentaire de macro (non expanse)}\par
\par
{\f1   Exemple avec & :}\par
\par
{\f1     DeclareVar MACRO nom, taille}\par
{\f1       _&nom  DB taille DUP(0)   ;; Genere _buffer DB 64 DUP(0)}\par
{\f1     ENDM}\par
\par
{\f1     DeclareVar buffer, 64}\par
\par
{\f1   10.11.3 Directives dans les macros}\par
\par
{\f1     LOCAL label1, label2         ; Etiquettes locales a la macro}\par
{\f1                                  ; (renommees automatiquement a}\par
{\f1                                  ; chaque expansion pour eviter}\par
{\f1                                  ; les conflits)}\par
\par
{\f1     EXITM [valeur]               ; Sortie prematuree de la macro}\par
{\f1                                  ; (retourne une valeur optionnelle)}\par
\par
{\f1     .ERR [message]               ; Genere une erreur d'assemblage}\par
{\f1     .ERRNZ expression            ; Erreur si expression <> 0}\par
{\f1     .ERRE expression             ; Erreur si expression = 0}\par
{\f1     .ERRB <texte>                ; Erreur si texte est vide}\par
{\f1     .ERRNB <texte>               ; Erreur si texte n'est pas vide}\par
{\f1     .ERRIDN <s1>, <s2>          ; Erreur si chaines identiques}\par
{\f1     .ERRDIF <s1>, <s2>          ; Erreur si chaines differentes}\par
\par
{\f1   Exemple avec LOCAL :}\par
\par
{\f1     CompareAndJump MACRO val, dest}\par
{\f1       LOCAL skip}\par
{\f1       CMP EAX, val}\par
{\f1       JNE skip}\par
{\f1       JMP dest}\par
{\f1     skip:}\par
{\f1     ENDM}\par
\par
{\f1   10.11.4 Macros de repetition}\par
\par
{\f1     REPT n                       ; Repete le bloc n fois}\par
{\f1       ; ... corps ...}\par
{\f1     ENDM}\par
\par
{\f1     IRP param, <val1, val2, ...> ; Repete pour chaque valeur}\par
{\f1       ; ... corps avec param ...}\par
{\f1     ENDM}\par
\par
{\f1     IRPC param, chaine           ; Repete pour chaque caractere}\par
{\f1       ; ... corps avec param ...}\par
{\f1     ENDM}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; Generer 10 NOP}\par
{\f1     REPT 10}\par
{\f1       NOP}\par
{\f1     ENDM}\par
\par
{\f1     ; Empiler plusieurs registres}\par
{\f1     IRP reg, <EAX, EBX, ECX, EDX>}\par
{\f1       PUSH reg}\par
{\f1     ENDM}\par
\par
{\f1     ; Generer des DB pour chaque caractere}\par
{\f1     IRPC c, HELLO}\par
{\f1       DB '&c'}\par
{\f1     ENDM}\par
\par
{\f1   10.11.5 Macros fonctions (MASM seulement)}\par
\par
{\f1   Les macros fonctions retournent une valeur via EXITM :}\par
\par
{\f1     IsEven MACRO n}\par
{\f1       IF (n) MOD 2 EQ 0}\par
{\f1         EXITM <1>                ;; Retourne 1 (pair)}\par
{\f1       ELSE}\par
{\f1         EXITM <0>                ;; Retourne 0 (impair)}\par
{\f1       ENDIF}\par
{\f1     ENDM}\par
\par
{\f1     IF IsEven(42)}\par
{\f1       DB "Pair"}\par
{\f1     ENDIF}\par
\par
\par
\b 10.12 Directives d'alignement et d'organisation \b0\par
\par
{\f1   ALIGN n - Aligne la position courante sur une frontiere de}\par
{\f1   n octets (n doit etre une puissance de 2) :}\par
\par
{\f1     ALIGN 4                      ; Aligne sur 4 octets (DWORD)}\par
{\f1     ALIGN 16                     ; Aligne sur 16 octets (paragraphe)}\par
{\f1     ALIGN 256                    ; Aligne sur 256 octets (page)}\par
\par
{\f1   L'assembleur insere des octets de remplissage (NOP dans le code,}\par
{\f1   00h dans les donnees) pour atteindre l'alignement demande.}\par
\par
{\f1   EVEN - Aligne sur une frontiere de mot (2 octets) :}\par
\par
{\f1     EVEN                         ; Equivalent a ALIGN 2}\par
\par
{\f1   ORG expression - Fixe le compteur de position a l'adresse}\par
{\f1   specifiee :}\par
\par
{\f1     ORG 0100h                    ; Debut a l'offset 100h (fichiers COM)}\par
{\f1     ORG $ + 10                   ; Saute 10 octets}\par
\par
{\f1   $ - Symbole special representant la position courante du}\par
{\f1   compteur de localisation :}\par
\par
{\f1     msg      DB  'Hello', 0}\par
{\f1     msg_len  EQU $ - msg         ; Longueur de la chaine = 6}\par
\par
{\f1     tableau  DD  1, 2, 3, 4, 5}\par
{\f1     nb_elem  EQU ($ - tableau) / 4  ; Nombre d'elements = 5}\par
\par
{\f1   $$ - Adresse de debut du segment courant.}\par
\par
\par
\b 10.13 Directives OPTION (MASM seulement) \b0\par
\par
{\f1   OPTION configure divers comportements de l'assembleur.}\par
\par
{\f1     OPTION CASEMAP:NONE          ; Sensible a la casse (majuscules}\par
{\f1                                  ; et minuscules distinguees)}\par
{\f1     OPTION CASEMAP:ALL           ; Insensible a la casse}\par
{\f1     OPTION CASEMAP:NOTPUBLIC     ; Sensible sauf pour PUBLIC/EXTRN}\par
{\f1     OPTION DOTNAME               ; Autorise les points dans les noms}\par
{\f1     OPTION PROC:PRIVATE          ; Les procedures sont privees}\par
{\f1                                  ; par defaut}\par
{\f1     OPTION PROLOGUE:nom          ; Utilise un prologue personnalise}\par
{\f1     OPTION EPILOGUE:nom          ; Utilise un epilogue personnalise}\par
{\f1     OPTION LANGUAGE:convention   ; Convention d'appel par defaut}\par
{\f1     OPTION SCOPED                ; Etiquettes locales aux procedures}\par
{\f1     OPTION NOSCOPED              ; Etiquettes globales (defaut)}\par
{\f1     OPTION LJMP                  ; Active les sauts longs automatiques}\par
{\f1     OPTION NOLJMP                ; Desactive les sauts longs auto}\par
\par
{\f1   La combinaison la plus courante en Win32 :}\par
\par
{\f1     .386}\par
{\f1     .MODEL FLAT, STDCALL}\par
{\f1     OPTION CASEMAP:NONE}\par
\par
\par
\b 10.14 Directives de base de numeration \b0\par
\par
{\f1   .RADIX base - Change la base par defaut des nombres :}\par
\par
{\f1     .RADIX 16                    ; Base hexadecimale par defaut}\par
{\f1     .RADIX 10                    ; Base decimale (defaut)}\par
{\f1     .RADIX 8                     ; Base octale}\par
{\f1     .RADIX 2                     ; Base binaire}\par
\par
{\f1   Sans .RADIX, la base par defaut est decimale (10).}\par
\par
{\f1   Suffixes explicites (toujours valides quelle que soit la base) :}\par
\par
{\f1     42              ; Decimal (ou depend de .RADIX)}\par
{\f1     42d             ; Decimal explicite}\par
{\f1     2Ah             ; Hexadecimal (suffixe h)}\par
{\f1     0FFh            ; Hexadecimal (doit commencer par un chiffre)}\par
{\f1     52o             ; Octal (suffixe o ou q)}\par
{\f1     52q             ; Octal (suffixe q)}\par
{\f1     101010b         ; Binaire (suffixe b)}\par
\par
{\f1   Attention : avec .RADIX 16, les nombres comme 0FFh doivent}\par
{\f1   etre ecrits 0FFt ou avec le suffixe t pour eviter l'ambiguite}\par
{\f1   avec le suffixe h qui devient un chiffre hexadecimal.}\par
\par
\par
\b 10.15 Directive END \b0\par
\par
{\f1   END marque la fin du fichier source et specifie optionnellement}\par
{\f1   le point d'entree du programme.}\par
\par
{\f1     END [point_entree]}\par
\par
{\f1   Exemples :}\par
\par
{\f1     END                          ; Fin du module (pas de point d'entree)}\par
{\f1     END main                     ; Fin du programme, entree a 'main'}\par
{\f1     END _start                   ; Point d'entree _start}\par
\par
{\f1   Le point d'entree n'est specifie que dans le module principal.}\par
{\f1   Les modules secondaires utilisent END sans argument.}\par
\par
\par
\b 10.16 Directives de structures et unions \b0\par
\par
{\f1   STRUCT/STRUC et UNION permettent de definir des types composes.}\par
\par
{\f1   10.16.1 Structures}\par
\par
{\f1     nom STRUCT}\par
{\f1       champ1  type  valeur_initiale}\par
{\f1       champ2  type  valeur_initiale}\par
{\f1       ; ...}\par
{\f1     nom ENDS}\par
\par
{\f1   Exemple :}\par
\par
{\f1     POINT STRUCT}\par
{\f1       x  DD  0}\par
{\f1       y  DD  0}\par
{\f1     POINT ENDS}\par
\par
{\f1     RECT STRUCT}\par
{\f1       gauche  DD  0}\par
{\f1       haut    DD  0}\par
{\f1       droite  DD  0}\par
{\f1       bas     DD  0}\par
{\f1     RECT ENDS}\par
\par
{\f1   Utilisation :}\par
\par
{\f1     ; Declaration d'une variable de type POINT}\par
{\f1     MonPoint  POINT  <10, 20>         ; x=10, y=20}\par
{\f1     MonPoint2 POINT  <>               ; Valeurs par defaut (0, 0)}\par
{\f1     MonPoint3 POINT  <, 30>           ; x=defaut(0), y=30}\par
\par
{\f1     ; Acces aux champs}\par
{\f1     MOV EAX, MonPoint.x               ; Lire x}\par
{\f1     MOV MonPoint.y, 50                ; Ecrire y}\par
\par
{\f1     ; Acces via un registre pointeur}\par
{\f1     LEA ESI, MonPoint}\par
{\f1     MOV EAX, [ESI].POINT.x           ; Lire x via pointeur}\par
{\f1     MOV [ESI].POINT.y, 100           ; Ecrire y via pointeur}\par
\par
{\f1     ; Taille de la structure}\par
{\f1     MOV ECX, SIZEOF POINT             ; ECX = 8 (2 * 4 octets)}\par
\par
{\f1   10.16.2 Unions}\par
\par
{\f1     nom UNION}\par
{\f1       champ1  type  valeur_initiale}\par
{\f1       champ2  type  valeur_initiale}\par
{\f1     nom ENDS}\par
\par
{\f1   Tous les champs d'une union occupent la meme zone memoire.}\par
{\f1   La taille de l'union est la taille du plus grand champ.}\par
\par
{\f1   Exemple :}\par
\par
{\f1     VARIANT UNION}\par
{\f1       b  DB  ?}\par
{\f1       w  DW  ?}\par
{\f1       d  DD  ?}\par
{\f1     VARIANT ENDS}\par
{\f1     ; SIZEOF VARIANT = 4 (taille du plus grand champ DD)}\par
\par
{\f1   10.16.3 Structures imbriquees}\par
\par
{\f1     FENETRE STRUCT}\par
{\f1       pos     POINT   <>}\par
{\f1       taille  POINT   <>}\par
{\f1       titre   DD      0}\par
{\f1     FENETRE ENDS}\par
\par
{\f1     fen1  FENETRE  <<10,20>, <640,480>, OFFSET str_titre>}\par
\par
\par
\b 10.17 Directives de listing et de debug \b0\par
\par
{\f1   Ces directives controlent le fichier listing (.LST) genere}\par
{\f1   par l'assembleur.}\par
\par
{\f1     .LIST            ; Active la generation du listing}\par
{\f1     .NOLIST          ; Desactive la generation du listing}\par
{\f1     .XLIST           ; Desactive completement le listing}\par
{\f1     .LISTALL         ; Liste tout, y compris les macros}\par
{\f1     .LISTMACRO       ; Liste le corps des macros expandees}\par
{\f1     .LISTMACROALL    ; Liste toutes les expansions de macros}\par
\par
{\f1     TITLE texte      ; Titre en haut de chaque page du listing}\par
{\f1     SUBTITLE texte   ; Sous-titre}\par
{\f1     PAGE [lignes, colonnes] ; Dimensions de la page du listing}\par
{\f1     PAGE +           ; Nouvelle page dans le listing}\par
\par
{\f1     .CREF            ; Active la table des references croisees}\par
{\f1     .NOCREF          ; Desactive les references croisees}\par
\par
\par
\b 10.18 Differences entre MASM et TASM \b0\par
\par
{\f1   MASM (Microsoft Macro Assembler) et TASM (Turbo Assembler de}\par
{\f1   Borland) partagent la majorite de la syntaxe, mais presentent}\par
{\f1   quelques differences :}\par
\par
{\f1   10.18.1 Mode IDEAL (TASM seulement)}\par
\par
{\f1   TASM supporte un mode alternatif appele IDEAL qui clarifie}\par
{\f1   certaines ambiguites de la syntaxe MASM :}\par
\par
{\f1     IDEAL                         ; Active le mode IDEAL}\par
{\f1     MASM                          ; Retour au mode MASM (defaut)}\par
\par
{\f1   Differences en mode IDEAL :}\par
{\f1     - Les crochets [] sont obligatoires pour l'acces memoire}\par
{\f1     - Les crochets signifient toujours "contenu a l'adresse"}\par
{\f1     - Les types sont ecrits avant l'operande : [DWORD PTR var]}\par
{\f1       devient [DWORD var]}\par
{\f1     - OFFSET est obligatoire pour obtenir l'adresse d'une variable}\par
{\f1     - Les structures utilisent la syntaxe . pour les champs}\par
\par
{\f1   Exemple (MASM vs IDEAL) :}\par
\par
{\f1     ; MASM :}\par
{\f1     MOV EAX, variable             ; Acces memoire}\par
{\f1     MOV EAX, OFFSET variable      ; Adresse}\par
{\f1     MOV EAX, DWORD PTR [ESI]     ; Acces via pointeur}\par
\par
{\f1     ; IDEAL :}\par
{\f1     MOV EAX, [variable]           ; Acces memoire}\par
{\f1     MOV EAX, OFFSET variable      ; Adresse}\par
{\f1     MOV EAX, [DWORD ESI]         ; Acces via pointeur}\par
\par
{\f1   10.18.2 Directives specifiques a TASM}\par
\par
{\f1     IDEAL           ; Mode de syntaxe IDEAL}\par
{\f1     MASM            ; Mode de syntaxe MASM (defaut)}\par
{\f1     QUIRKS          ; Active les compatibilites MASM (bugs inclus)}\par
{\f1     SMART           ; Optimisation automatique des sauts}\par
{\f1     NOSMART         ; Desactive l'optimisation des sauts}\par
{\f1     JUMPS           ; Genere des sauts longs si necessaire}\par
{\f1     NOJUMPS         ; Pas de sauts longs automatiques}\par
{\f1     LOCALS prefix   ; Active les etiquettes locales (@@)}\par
{\f1     NOLOCALS        ; Desactive les etiquettes locales}\par
{\f1     WARN            ; Active tous les avertissements}\par
{\f1     NOWARN          ; Desactive les avertissements}\par
{\f1     EMUL            ; Active l'emulation du coprocesseur}\par
{\f1     NOEMUL          ; Pas d'emulation}\par
\par
{\f1   10.18.3 Directives specifiques a MASM 6+}\par
\par
{\f1     OPTION          ; Configuration de l'assembleur (voir 10.13)}\par
{\f1     INVOKE          ; Appel de procedure avec verification de types}\par
{\f1     PROTO           ; Prototype de procedure}\par
{\f1     EXTERNDEF       ; Declaration/definition externe}\par
{\f1     .WHILE          ; Boucle while de haut niveau}\par
{\f1     .ENDW           ; Fin de la boucle while}\par
{\f1     .REPEAT         ; Boucle repeat}\par
{\f1     .UNTIL condition; Fin de la boucle repeat (condition de sortie)}\par
{\f1     .BREAK          ; Sortie de boucle}\par
{\f1     .CONTINUE       ; Iteration suivante}\par
{\f1     .IF condition   ; Condition de haut niveau}\par
{\f1     .ELSEIF condition}\par
{\f1     .ELSE}\par
{\f1     .ENDIF}\par
\par
{\f1   Exemple de constructions de haut niveau (MASM 6+) :}\par
\par
{\f1     .IF EAX == 0}\par
{\f1       CALL GererErreur}\par
{\f1     .ELSEIF EAX > 100}\par
{\f1       MOV EAX, 100}\par
{\f1     .ELSE}\par
{\f1       INC EAX}\par
{\f1     .ENDIF}\par
\par
{\f1     .WHILE ECX > 0}\par
{\f1       LODSB}\par
{\f1       CALL TraiterOctet}\par
{\f1       DEC ECX}\par
{\f1     .ENDW}\par
\par
{\f1     .REPEAT}\par
{\f1       CALL LireOctet}\par
{\f1     .UNTIL AL == 0}\par
\par
{\f1   L'assembleur traduit ces constructions en CMP/Jcc et JMP}\par
{\f1   standards. Elles n'ajoutent aucun surcout par rapport au}\par
{\f1   code ecrit manuellement.}\par
\par
\par
