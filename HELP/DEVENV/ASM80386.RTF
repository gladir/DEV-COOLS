{\footnote # IDH_ASM80386_12}
{\footnote $ Assembleur 80386 - CONVERSION DE CODE 8086 EN 80386}
{\footnote K Assembleur 80386 conversion 8086;correspondance registres 16 32 bits;modes adressage;conversion instructions}
\b\fs24 CONVERSION DE CODE 8086 EN 80386 \b0\fs20\par
\par
{\f1   Cette section presente les techniques et les regles pour convertir du}\par
{\f1   code assembleur 8086 (mode reel 16 bits) en code 80386 (mode protege}\par
{\f1   32 bits). La migration permet d'exploiter les registres etendus, l'espace}\par
{\f1   d'adressage lineaire de 4 Go et les nouveaux modes d'adressage.}\par
\par
\par
\b 12.1 Principes generaux \b0\par
\par
{\f1   Le 80386 est retro-compatible avec le 8086 : tout programme 8086 peut}\par
{\f1   tourner en mode reel sur un 80386 sans modification. Toutefois, pour}\par
{\f1   profiter des capacites 32 bits (mode protege, modele FLAT), il faut}\par
{\f1   adapter le code source. Les grandes lignes de la conversion sont :}\par
\par
{\f1     1. Remplacer les registres 16 bits par leurs equivalents 32 bits}\par
{\f1     2. Adapter les directives assembleur (.MODEL, .386, segments)}\par
{\f1     3. Convertir les appels systeme (INT 21h -> API Win32 ou INT 80h)}\par
{\f1     4. Ajuster les tailles de donnees et d'adresses}\par
{\f1     5. Eliminer la segmentation et passer en modele FLAT}\par
{\f1     6. Exploiter les nouveaux modes d'adressage et instructions}\par
\par
\par
\b 12.2 Correspondance des registres \b0\par
\par
{\f1   La table suivante montre l'equivalence directe des registres :}\par
\par
{\f1     8086 (16 bits)    80386 (32 bits)    Notes}\par
{\f1     ----------------  -----------------  --------------------------------}\par
{\f1     AX                EAX                Accumulateur etendu a 32 bits}\par
{\f1     BX                EBX                Base etendue}\par
{\f1     CX                ECX                Compteur etendu}\par
{\f1     DX                EDX                Donnees etendu}\par
{\f1     SI                ESI                Index source etendu}\par
{\f1     DI                EDI                Index destination etendu}\par
{\f1     BP                EBP                Pointeur de base etendu}\par
{\f1     SP                ESP                Pointeur de pile etendu}\par
{\f1     IP                EIP                Pointeur d'instruction (implicite)}\par
{\f1     FLAGS             EFLAGS             Registre d'etat etendu}\par
\par
{\f1   Les registres de segment (CS, DS, ES, SS) existent toujours mais en}\par
{\f1   mode protege FLAT, ils pointent tous sur le meme descripteur couvrant}\par
{\f1   4 Go. FS et GS sont deux nouveaux registres de segment du 80386.}\par
\par
{\f1   Regles de conversion des registres :}\par
\par
{\f1     - AX -> EAX, BX -> EBX, CX -> ECX, DX -> EDX}\par
{\f1     - SI -> ESI, DI -> EDI, BP -> EBP, SP -> ESP}\par
{\f1     - AH, AL, BH, BL, CH, CL, DH, DL restent identiques}\par
{\f1     - Les registres 16 bits (AX, BX...) restent utilisables dans du}\par
{\f1       code 32 bits mais provoquent des prefixes de taille (ralentissement)}\par
\par
\par
\b 12.3 Adaptation des directives assembleur \b0\par
\par
{\f1   12.3.1 En-tete du programme}\par
\par
{\f1     8086 :                              80386 :}\par
{\f1     --------------------------------    --------------------------------}\par
{\f1     .MODEL SMALL                        .386}\par
{\f1     .STACK 100h                         .MODEL FLAT, STDCALL}\par
{\f1     .DATA                               .DATA}\par
{\f1     ...                                 ...}\par
{\f1     .CODE                               .CODE}\par
{\f1     main:                               main PROC}\par
{\f1       MOV AX, @DATA                       ; Pas besoin de charger DS}\par
{\f1       MOV DS, AX                          ; DS est deja configure}\par
{\f1       ...                                 ...}\par
{\f1       MOV AX, 4C00h                       PUSH 0}\par
{\f1       INT 21h                             CALL ExitProcess@4}\par
{\f1     END main                            main ENDP}\par
{\f1                                         END main}\par
\par
{\f1   12.3.2 Directive processeur}\par
\par
{\f1     8086 : pas de directive necessaire (defaut)}\par
{\f1     80386 : ajouter .386 ou .386P (mode privilegie) en premiere ligne}\par
\par
{\f1   12.3.3 Modele memoire}\par
\par
{\f1     8086 : .MODEL TINY / SMALL / MEDIUM / COMPACT / LARGE / HUGE}\par
{\f1     80386 : .MODEL FLAT, STDCALL (un seul segment de 4 Go)}\par
\par
{\f1   12.3.4 Initialisation des segments}\par
\par
{\f1     En 8086, il faut initialiser DS manuellement :}\par
\par
{\f1       MOV AX, @DATA}\par
{\f1       MOV DS, AX}\par
\par
{\f1     En 80386 mode FLAT, DS, ES, SS pointent deja sur le meme espace}\par
{\f1     d'adressage. Ces deux lignes doivent etre supprimees.}\par
\par
\par
\b 12.4 Conversion des types de donnees \b0\par
\par
{\f1     8086                    80386                   Notes}\par
{\f1     ----------------------  ----------------------  -----------------------}\par
{\f1     DB  (1 octet)           DB  (1 octet)           Identique}\par
{\f1     DW  (2 octets, WORD)    DW  (2 octets, WORD)    Identique}\par
{\f1     DD  (4 octets, DWORD)   DD  (4 octets, DWORD)   Identique}\par
{\f1     -                       DQ  (8 octets, QWORD)    Nouveau}\par
{\f1     -                       DT  (10 octets, TBYTE)   Nouveau}\par
\par
{\f1   Regles de conversion des donnees :}\par
\par
{\f1     - Les pointeurs passent de DW (16 bits) a DD (32 bits)}\par
{\f1     - Les offsets passent de 16 a 32 bits}\par
{\f1     - OFFSET retourne 32 bits au lieu de 16}\par
{\f1     - Les tableaux de pointeurs : DW -> DD}\par
{\f1     - Les variables compteur utilisant CX (16 bits max 65535)}\par
{\f1       peuvent maintenant utiliser ECX (32 bits max 4 milliards)}\par
\par
{\f1   Exemple :}\par
\par
{\f1     ; 8086                          ; 80386}\par
{\f1     msg    DB 'Hello',0             msg    DB 'Hello',0}\par
{\f1     msgptr DW OFFSET msg            msgptr DD OFFSET msg}\par
{\f1     count  DW 0                     count  DD 0}\par
{\f1     buffer DB 256 DUP(0)            buffer DB 256 DUP(0)}\par
\par
\par
\b 12.5 Conversion des instructions courantes \b0\par
\par
{\f1   12.5.1 Instructions de deplacement de donnees}\par
\par
{\f1     8086                              80386}\par
{\f1     --------------------------------  --------------------------------}\par
{\f1     MOV AX, valeur                    MOV EAX, valeur}\par
{\f1     MOV AX, [BX]                      MOV EAX, [EBX]}\par
{\f1     MOV AX, [BX+SI]                   MOV EAX, [EBX+ESI]}\par
{\f1     MOV AX, [BX+SI+4]                MOV EAX, [EBX+ESI+4]}\par
{\f1     MOV AL, [BX]                      MOV AL, [EBX]}\par
{\f1     LEA BX, [var]                     LEA EBX, [var]}\par
{\f1     LDS SI, [ptr]                     (non utilise en FLAT)}\par
{\f1     LES DI, [ptr]                     (non utilise en FLAT)}\par
{\f1     XCHG AX, BX                      XCHG EAX, EBX}\par
{\f1     PUSH AX                           PUSH EAX}\par
{\f1     POP AX                            POP EAX}\par
\par
{\f1   Note : LDS et LES ne sont plus necessaires en modele FLAT car il}\par
{\f1   n'y a qu'un seul segment. Remplacer par un simple MOV :}\par
\par
{\f1     ; 8086                          ; 80386}\par
{\f1     LDS SI, [ptr]                   MOV ESI, [ptr]}\par
{\f1     LES DI, [ptr]                   MOV EDI, [ptr]}\par
\par
{\f1   12.5.2 Instructions arithmetiques}\par
\par
{\f1     8086                              80386}\par
{\f1     --------------------------------  --------------------------------}\par
{\f1     ADD AX, BX                        ADD EAX, EBX}\par
{\f1     SUB AX, 10                        SUB EAX, 10}\par
{\f1     MUL BX                            MUL EBX         (ou IMUL EAX,EBX)}\par
{\f1     DIV BX                            DIV EBX}\par
{\f1     INC AX                            INC EAX}\par
{\f1     DEC CX                            DEC ECX}\par
{\f1     NEG AX                            NEG EAX}\par
{\f1     CWD                               CDQ              (etend EAX -> EDX:EAX)}\par
{\f1     CBW                               CWDE             (etend AX -> EAX)}\par
\par
{\f1   Nouvelles instructions utiles du 80386 :}\par
\par
{\f1     IMUL EAX, EBX, 10      ; Multiplication 3 operandes (nouveau)}\par
{\f1     MOVZX EAX, AL           ; Extension zero 8->32 bits (nouveau)}\par
{\f1     MOVSX EAX, AX           ; Extension signe 16->32 bits (nouveau)}\par
{\f1     MOVZX EAX, BYTE PTR [ESI]  ; Chargement avec extension zero}\par
{\f1     MOVSX ECX, WORD PTR [EDI]  ; Chargement avec extension signe}\par
\par
{\f1   12.5.3 Instructions de chaines}\par
\par
{\f1     8086                              80386}\par
{\f1     --------------------------------  --------------------------------}\par
{\f1     REP MOVSB                         REP MOVSB        (identique)}\par
{\f1     REP MOVSW                         REP MOVSD        (deplacer DWORD)}\par
{\f1     REP STOSB                         REP STOSD        (stocker DWORD)}\par
{\f1     LODSB                             LODSD            (charger DWORD dans EAX)}\par
{\f1     SCASB                             SCASD            (comparer DWORD)}\par
{\f1     CLD                               CLD              (identique)}\par
\par
{\f1   En 8086, les operations de chaines utilisent DS:SI et ES:DI.}\par
{\f1   En 80386 mode FLAT, elles utilisent ESI et EDI (meme segment).}\par
\par
{\f1   12.5.4 Instructions de branchement}\par
\par
{\f1     8086                              80386}\par
{\f1     --------------------------------  --------------------------------}\par
{\f1     JMP SHORT label                   JMP SHORT label   (identique)}\par
{\f1     JMP label                         JMP label         (rel32 maintenant)}\par
{\f1     CALL proc                         CALL proc         (identique)}\par
{\f1     RET                               RET               (identique)}\par
{\f1     Jcc label (rel8 seulement)        Jcc label         (rel8 ou rel32)}\par
{\f1     LOOP label                        LOOP label        (utilise ECX)}\par
{\f1     JCXZ label                        JECXZ label       (teste ECX)}\par
\par
{\f1   Note importante : en 8086, les sauts conditionnels (Jcc) ne peuvent}\par
{\f1   atteindre que des cibles a +/-128 octets (rel8). En 80386, ils}\par
{\f1   acceptent aussi des deplacements rel32 (portee quasi illimitee).}\par
\par
{\f1   12.5.5 Instructions de pile}\par
\par
{\f1     8086                              80386}\par
{\f1     --------------------------------  --------------------------------}\par
{\f1     PUSH AX                           PUSH EAX          (empile 32 bits)}\par
{\f1     POP BX                            POP EBX           (depile 32 bits)}\par
{\f1     PUSH 1234h                        PUSH 12345678h    (immediats 32 bits)}\par
{\f1     PUSHF                             PUSHFD            (EFLAGS 32 bits)}\par
{\f1     POPF                              POPFD             (EFLAGS 32 bits)}\par
{\f1     PUSHA                             PUSHAD            (tous les reg 32 bits)}\par
{\f1     POPA                              POPAD             (tous les reg 32 bits)}\par
\par
{\f1   En mode 32 bits, chaque PUSH/POP manipule 4 octets (au lieu de 2).}\par
\par
\par
\b 12.6 Conversion des appels systeme \b0\par
\par
{\f1   C'est le changement le plus important. En 8086 sous DOS, les appels}\par
{\f1   systeme se font par INT 21h. En 80386, on utilise les API du systeme}\par
{\f1   d'exploitation (Win32, Linux, etc.).}\par
\par
{\f1   12.6.1 Afficher une chaine de caracteres}\par
\par
{\f1     ; 8086 (DOS, INT 21h)              ; 80386 (Win32)}\par
{\f1     ; -------------------------------- ; --------------------------------}\par
{\f1     .DATA                               .DATA}\par
{\f1     msg DB 'Hello$'                     msg DB 'Hello', 0}\par
{\f1                                         written DD 0}\par
{\f1     .CODE                               .CODE}\par
{\f1     MOV AH, 09h                         PUSH -11}\par
{\f1     LEA DX, msg                         CALL GetStdHandle@4}\par
{\f1     INT 21h                             PUSH 0}\par
{\f1                                         PUSH OFFSET written}\par
{\f1                                         PUSH 5}\par
{\f1                                         PUSH OFFSET msg}\par
{\f1                                         PUSH EAX}\par
{\f1                                         CALL WriteConsoleA@20}\par
\par
{\f1   12.6.2 Lire un caractere au clavier}\par
\par
{\f1     ; 8086 (DOS)                       ; 80386 (Win32)}\par
{\f1     ; -------------------------------- ; --------------------------------}\par
{\f1     MOV AH, 01h                         PUSH -10}\par
{\f1     INT 21h                             CALL GetStdHandle@4}\par
{\f1     ; caractere dans AL                 MOV [hStdIn], EAX}\par
{\f1                                         PUSH 0}\par
{\f1                                         PUSH OFFSET bytesRead}\par
{\f1                                         PUSH 1}\par
{\f1                                         PUSH OFFSET charBuf}\par
{\f1                                         PUSH [hStdIn]}\par
{\f1                                         CALL ReadConsoleA@20}\par
{\f1                                         ; caractere dans charBuf}\par
\par
{\f1   12.6.3 Quitter le programme}\par
\par
{\f1     ; 8086 (DOS)                       ; 80386 (Win32)}\par
{\f1     ; -------------------------------- ; --------------------------------}\par
{\f1     MOV AX, 4C00h                       PUSH 0}\par
{\f1     INT 21h                             CALL ExitProcess@4}\par
\par
{\f1   12.6.4 Ouvrir un fichier}\par
\par
{\f1     ; 8086 (DOS)                       ; 80386 (Win32)}\par
{\f1     ; -------------------------------- ; --------------------------------}\par
{\f1     MOV AH, 3Dh                         PUSH 0            ; template}\par
{\f1     MOV AL, 00h  ; lecture              PUSH 80h           ; attribut normal}\par
{\f1     LEA DX, filename                    PUSH 3             ; OPEN_EXISTING}\par
{\f1     INT 21h                             PUSH 0             ; securite}\par
{\f1     ; handle dans AX                    PUSH 1             ; FILE_SHARE_READ}\par
{\f1                                         PUSH 80000000h     ; GENERIC_READ}\par
{\f1                                         PUSH OFFSET filename}\par
{\f1                                         CALL CreateFileA@28}\par
{\f1                                         ; handle dans EAX}\par
\par
{\f1   12.6.5 Table de correspondance DOS -> Win32}\par
\par
{\f1     Fonction DOS (INT 21h)       API Win32 equivalente}\par
{\f1     --------------------------   ----------------------------}\par
{\f1     AH=01h  Lire caractere       ReadConsoleA}\par
{\f1     AH=02h  Ecrire caractere     WriteConsoleA}\par
{\f1     AH=09h  Afficher chaine $    WriteConsoleA}\par
{\f1     AH=0Ah  Lire chaine          ReadConsoleA}\par
{\f1     AH=3Ch  Creer fichier        CreateFileA}\par
{\f1     AH=3Dh  Ouvrir fichier       CreateFileA}\par
{\f1     AH=3Eh  Fermer fichier       CloseHandle}\par
{\f1     AH=3Fh  Lire fichier         ReadFile}\par
{\f1     AH=40h  Ecrire fichier       WriteFile}\par
{\f1     AH=41h  Supprimer fichier    DeleteFileA}\par
{\f1     AH=43h  Attributs fichier    GetFileAttributesA}\par
{\f1     AH=48h  Allouer memoire      VirtualAlloc / HeapAlloc}\par
{\f1     AH=49h  Liberer memoire      VirtualFree / HeapFree}\par
{\f1     AH=4Ch  Quitter programme    ExitProcess}\par
\par
\par
\b 12.7 Conversion des modes d'adressage \b0\par
\par
{\f1   Le 80386 offre des modes d'adressage beaucoup plus flexibles.}\par
\par
{\f1   12.7.1 Adressage indirect}\par
\par
{\f1     8086 : seulement [BX], [SI], [DI], [BP]}\par
{\f1     80386 : tout registre sauf ESP -> [EAX], [EBX], [ECX], [EDX],}\par
{\f1             [ESI], [EDI], [EBP]}\par
\par
{\f1     ; 8086                          ; 80386 (equivalent + plus)}\par
{\f1     MOV AX, [BX]                    MOV EAX, [EBX]}\par
{\f1     MOV AX, [SI]                    MOV EAX, [ESI]}\par
{\f1                                     MOV EAX, [ECX]       ; nouveau!}\par
{\f1                                     MOV EAX, [EDX]       ; nouveau!}\par
\par
{\f1   12.7.2 Adressage base+index}\par
\par
{\f1     8086 : seulement [BX+SI], [BX+DI], [BP+SI], [BP+DI]}\par
{\f1     80386 : toute combinaison [reg_base + reg_index]}\par
\par
{\f1     ; 8086                          ; 80386}\par
{\f1     MOV AX, [BX+SI]                 MOV EAX, [EBX+ESI]}\par
{\f1     MOV AX, [BP+DI]                 MOV EAX, [EBP+EDI]}\par
{\f1                                     MOV EAX, [EAX+ECX]   ; nouveau!}\par
{\f1                                     MOV EAX, [EDX+EDI]   ; nouveau!}\par
\par
{\f1   12.7.3 Adressage avec facteur d'echelle (nouveau 80386)}\par
\par
{\f1     Le 80386 introduit le facteur d'echelle (SIB) qui n'existait pas}\par
{\f1     sur le 8086. Il permet de multiplier l'index par 1, 2, 4 ou 8 :}\par
\par
{\f1     MOV EAX, [EBX + ESI*4]          ; acces tableau de DWORD}\par
{\f1     MOV EAX, [EBX + ECX*8]          ; acces tableau de QWORD}\par
{\f1     MOV EAX, [array + ESI*4]        ; tableau global indexe}\par
{\f1     LEA EAX, [EAX + EAX*4]          ; EAX = EAX * 5 (astuce)}\par
{\f1     LEA EAX, [EAX + EAX*2]          ; EAX = EAX * 3}\par
\par
{\f1   Conversion typique d'acces tableau :}\par
\par
{\f1     ; 8086 : acces tableau de WORD       ; 80386 : acces tableau de DWORD}\par
{\f1     MOV BX, index                        MOV ECX, index}\par
{\f1     SHL BX, 1          ; *2              ; pas de shift necessaire}\par
{\f1     MOV AX, [table+BX]                   MOV EAX, [table + ECX*4]}\par
\par
\par
\b 12.8 Conversion des structures de controle \b0\par
\par
{\f1   12.8.1 Boucle avec compteur}\par
\par
{\f1     ; 8086                          ; 80386}\par
{\f1     ; --------------------------------  --------------------------------}\par
{\f1     MOV CX, 100                     MOV ECX, 100}\par
{\f1     boucle:                         boucle:}\par
{\f1       ; ... corps ...                 ; ... corps ...}\par
{\f1       LOOP boucle                     LOOP boucle       ; ou DEC ECX/JNZ}\par
\par
{\f1   Note : sur 80386, LOOP utilise ECX en mode 32 bits. Si la boucle}\par
{\f1   depasse 65535 iterations, il faut obligatoirement passer en 32 bits.}\par
\par
{\f1   12.8.2 Boucle avec index de tableau}\par
\par
{\f1     ; 8086                          ; 80386}\par
{\f1     ; --------------------------------  --------------------------------}\par
{\f1     XOR SI, SI                      XOR ESI, ESI}\par
{\f1     MOV CX, 10                      MOV ECX, 10}\par
{\f1     boucle:                         boucle:}\par
{\f1       MOV AX, [table+SI]             MOV EAX, [table + ESI*4]}\par
{\f1       ADD SI, 2                       INC ESI}\par
{\f1       LOOP boucle                     DEC ECX}\par
{\f1                                       JNZ boucle}\par
\par
{\f1   12.8.3 Comparaison de chaines}\par
\par
{\f1     ; 8086                          ; 80386}\par
{\f1     ; --------------------------------  --------------------------------}\par
{\f1     LEA SI, str1                    LEA ESI, str1}\par
{\f1     LEA DI, str2                    LEA EDI, str2}\par
{\f1     MOV CX, longueur                MOV ECX, longueur}\par
{\f1     CLD                             CLD}\par
{\f1     REPE CMPSB                      REPE CMPSB         ; identique}\par
{\f1     JE egal                         JE egal}\par
\par
\par
\b 12.9 Conversion des procedures et conventions d'appel \b0\par
\par
{\f1   12.9.1 Cadre de pile (stack frame)}\par
\par
{\f1     ; 8086                          ; 80386}\par
{\f1     ; --------------------------------  --------------------------------}\par
{\f1     maProc PROC NEAR                maProc PROC}\par
{\f1       PUSH BP                         PUSH EBP}\par
{\f1       MOV BP, SP                       MOV EBP, ESP}\par
{\f1       SUB SP, 4    ; 2 vars locales    SUB ESP, 8    ; 2 vars locales (DD)}\par
{\f1       ; [BP+4] = adr retour            ; [EBP+4] = adr retour}\par
{\f1       ; [BP+6] = 1er parametre         ; [EBP+8] = 1er parametre}\par
{\f1       ; [BP-2] = 1ere locale           ; [EBP-4] = 1ere locale}\par
{\f1       MOV SP, BP                       MOV ESP, EBP}\par
{\f1       POP BP                           POP EBP}\par
{\f1       RET                              RET}\par
{\f1     maProc ENDP                     maProc ENDP}\par
\par
{\f1   Differences principales :}\par
{\f1     - BP -> EBP, SP -> ESP}\par
{\f1     - L'adresse de retour occupe 4 octets (au lieu de 2)}\par
{\f1     - Les parametres commencent a [EBP+8] (au lieu de [BP+4])}\par
{\f1     - Chaque variable locale occupe 4 octets (DWORD)}\par
\par
{\f1   12.9.2 Passage de parametres}\par
\par
{\f1     ; 8086 : convention C             ; 80386 : convention C}\par
{\f1     ; --------------------------------  --------------------------------}\par
{\f1     PUSH word_param2                  PUSH dword_param2}\par
{\f1     PUSH word_param1                  PUSH dword_param1}\par
{\f1     CALL maProc                       CALL maProc}\par
{\f1     ADD SP, 4      ; 2 * 2 octets    ADD ESP, 8     ; 2 * 4 octets}\par
\par
{\f1     ; 8086 : convention Pascal        ; 80386 : convention STDCALL}\par
{\f1     ; --------------------------------  --------------------------------}\par
{\f1     PUSH word_param1                  PUSH dword_param1}\par
{\f1     PUSH word_param2                  PUSH dword_param2}\par
{\f1     CALL maProc                       CALL maProc}\par
{\f1     ; pas d'ajustement                ; pas d'ajustement (RET 8)}\par
\par
{\f1   12.9.3 Conventions d'appel Win32}\par
\par
{\f1     En mode 32 bits Win32, la convention STDCALL est la norme pour}\par
{\f1     les API systeme. Les parametres sont empiles de droite a gauche}\par
{\f1     et la procedure appelee nettoie la pile (RET n).}\par
\par
\par
\b 12.10 Conversion des interruptions \b0\par
\par
{\f1   Les interruptions materielles et BIOS changent en mode protege :}\par
\par
{\f1     8086 (mode reel)                  80386 (mode protege)}\par
{\f1     --------------------------------  --------------------------------}\par
{\f1     INT 10h (video BIOS)              API graphiques du SE}\par
{\f1     INT 13h (disque BIOS)             API fichiers du SE}\par
{\f1     INT 16h (clavier BIOS)            API console du SE}\par
{\f1     INT 21h (DOS)                     API Win32 / syscall Linux}\par
{\f1     INT 33h (souris)                  API souris du SE}\par
{\f1     CLI / STI                         Niveau privilege 0 requis}\par
\par
{\f1   En mode protege, les interruptions logicielles DOS (INT 21h) ne sont}\par
{\f1   plus disponibles. Il faut les remplacer par les API du systeme cible.}\par
\par
{\f1   Sous Linux 32 bits, les appels systeme utilisent INT 80h :}\par
\par
{\f1     ; Equivalent de AH=09h INT 21h sous Linux}\par
{\f1     MOV EAX, 4            ; sys_write}\par
{\f1     MOV EBX, 1            ; stdout}\par
{\f1     MOV ECX, OFFSET msg   ; adresse du message}\par
{\f1     MOV EDX, msg_len      ; longueur}\par
{\f1     INT 80h}\par
\par
\par
\b 12.11 Exemple complet de conversion \b0\par
\par
{\f1   Voici un programme 8086 complet et sa version 80386 equivalente.}\par
\par
{\f1   Programme original 8086 (DOS) :}\par
\par
{\f1     ; Programme : affiche "Hello World" puis quitte}\par
{\f1     .MODEL SMALL}\par
{\f1     .STACK 100h}\par
{\f1     .DATA}\par
{\f1     msg DB 'Hello World!$'}\par
{\f1     .CODE}\par
{\f1     main:}\par
{\f1       MOV AX, @DATA}\par
{\f1       MOV DS, AX}\par
{\f1       MOV AH, 09h}\par
{\f1       LEA DX, msg}\par
{\f1       INT 21h}\par
{\f1       MOV AX, 4C00h}\par
{\f1       INT 21h}\par
{\f1     END main}\par
\par
{\f1   Version convertie 80386 (Win32 console) :}\par
\par
{\f1     ; Programme : affiche "Hello World" puis quitte}\par
{\f1     .386}\par
{\f1     .MODEL FLAT, STDCALL}\par
\par
{\f1     EXTRN GetStdHandle@4  : PROC}\par
{\f1     EXTRN WriteConsoleA@20 : PROC}\par
{\f1     EXTRN ExitProcess@4   : PROC}\par
\par
{\f1     .DATA}\par
{\f1     msg     DB 'Hello World!', 0}\par
{\f1     msg_len EQU $ - msg - 1}\par
{\f1     written DD 0}\par
\par
{\f1     .CODE}\par
{\f1     main PROC}\par
{\f1       ; Obtenir le handle stdout}\par
{\f1       PUSH -11                       ; STD_OUTPUT_HANDLE}\par
{\f1       CALL GetStdHandle@4}\par
{\f1       ; EAX = handle}\par
\par
{\f1       ; Ecrire le message}\par
{\f1       PUSH 0                         ; lpReserved}\par
{\f1       PUSH OFFSET written            ; lpNumberOfCharsWritten}\par
{\f1       PUSH msg_len                   ; nNumberOfCharsToWrite}\par
{\f1       PUSH OFFSET msg                ; lpBuffer}\par
{\f1       PUSH EAX                       ; hConsoleOutput}\par
{\f1       CALL WriteConsoleA@20}\par
\par
{\f1       ; Quitter}\par
{\f1       PUSH 0                         ; code de retour}\par
{\f1       CALL ExitProcess@4}\par
{\f1     main ENDP}\par
{\f1     END main}\par
\par
\par
\b 12.12 Resume : aide-memoire de conversion \b0\par
\par
{\f1   Etape   Action}\par
{\f1   ------  ----------------------------------------------------------------}\par
{\f1   1       Ajouter .386 (ou .386P) en premiere ligne}\par
{\f1   2       Remplacer .MODEL SMALL par .MODEL FLAT, STDCALL}\par
{\f1   3       Supprimer .STACK (geree par le SE)}\par
{\f1   4       Supprimer MOV AX,@DATA / MOV DS,AX}\par
{\f1   5       Remplacer AX->EAX, BX->EBX, CX->ECX, DX->EDX}\par
{\f1   6       Remplacer SI->ESI, DI->EDI, BP->EBP, SP->ESP}\par
{\f1   7       Remplacer DW par DD pour les pointeurs et offsets}\par
{\f1   8       Remplacer les INT 21h par les API equivalentes}\par
{\f1   9       Remplacer [BX+SI] par [EBX+ESI] (et profiter du SIB)}\par
{\f1   10      Ajuster [BP+4] -> [EBP+8] dans les cadres de pile}\par
{\f1   11      Remplacer PUSHF/POPF par PUSHFD/POPFD}\par
{\f1   12      Remplacer PUSHA/POPA par PUSHAD/POPAD}\par
{\f1   13      Remplacer CWD par CDQ, CBW par CWDE}\par
{\f1   14      Remplacer JCXZ par JECXZ}\par
{\f1   15      Supprimer LDS/LES (inutiles en FLAT)}\par
{\f1   16      Utiliser MOVZX/MOVSX pour les extensions de taille}\par
{\f1   17      Profiter de IMUL a 3 operandes}\par
{\f1   18      Profiter du facteur d'echelle [reg + reg*n]}\par
{\f1   19      Ajuster ADD SP,n -> ADD ESP,2n (parametres 32 bits)}\par
{\f1   20      Declarer EXTRN pour les API Win32 utilisees}\par
\par
\par
\b 12.13 Pieges et erreurs frequentes \b0\par
\par
{\f1   (a) Oublier le prefixe de taille}\par
\par
{\f1     En mode 32 bits, utiliser un registre 16 bits genere un prefixe}\par
{\f1     de remplacement de taille operande (66h), ce qui ralentit le code.}\par
{\f1     Privilegier les registres 32 bits :}\par
\par
{\f1       ; Lent (prefixe 66h)            ; Rapide (pas de prefixe)}\par
{\f1       MOV AX, 0                       MOV EAX, 0}\par
{\f1       ADD CX, 1                       ADD ECX, 1}\par
\par
{\f1   (b) Melanger tailles de pile}\par
\par
{\f1     En mode 32 bits, PUSH empile toujours 4 octets. Ne pas faire :}\par
\par
{\f1       PUSH AX            ; empile 2 octets -> desaligne la pile!}\par
{\f1       PUSH EAX           ; correct : empile 4 octets}\par
\par
{\f1   (c) Oublier d'ajuster les offsets dans le cadre de pile}\par
\par
{\f1     ; 8086 : parametres a [BP+4], [BP+6], [BP+8]...}\par
{\f1     ; 80386 : parametres a [EBP+8], [EBP+12], [EBP+16]...}\par
{\f1     ; (decalage de 4 car l'adresse de retour fait 4 octets)}\par
\par
{\f1   (d) Utiliser des adresses segmentees en mode FLAT}\par
\par
{\f1     Les instructions FAR (CALL FAR, JMP FAR, RET FAR) ne sont plus}\par
{\f1     necessaires en modele FLAT. Utiliser les versions NEAR :}\par
\par
{\f1       ; 8086                          ; 80386}\par
{\f1       CALL FAR proc                   CALL proc}\par
{\f1       JMP FAR label                   JMP label}\par
{\f1       RETF                            RET}\par
\par
{\f1   (e) Interruptions DOS en mode protege}\par
\par
{\f1     INT 21h n'est pas disponible en mode protege Win32. Tout appel}\par
{\f1     INT 21h provoquera une exception. Utiliser les API Win32.}\par
\par
{\f1   (f) Alignement des donnees}\par
\par
{\f1     En 80386, les acces memoire alignes sur 4 octets sont plus rapides.}\par
{\f1     Aligner les variables DD avec ALIGN 4 :}\par
\par
{\f1       ALIGN 4}\par
{\f1       compteur DD 0}\par
{\f1       ALIGN 4}\par
{\f1       resultat DD 0}\par
\par
\par
