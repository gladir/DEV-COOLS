{\f1   Types              BYTE PTR, WORD PTR, DWORD PTR, TYPE,}\par
{\f1                      SIZEOF, LENGTHOF, OFFSET, SEG, THIS}\par
{\f1   Procedures         PROC, ENDP, LOCAL, INVOKE, PROTO, USES}\par
{\f1   Visibilite         PUBLIC, EXTRN, EXTERN, EXTERNDEF}\par
{\f1   Inclusion          INCLUDE, INCLUDELIB, COMMENT}\par
{\f1   Conditionnel       IF, ELSE, ELSEIF, ENDIF, IFDEF, IFNDEF,}\par
{\f1                      IFB, IFNB, IFIDN, IFDIF}\par
{\f1   Macros             MACRO, ENDM, LOCAL, EXITM, REPT, IRP, IRPC}\par
{\f1   Alignement         ALIGN, EVEN, ORG}\par
