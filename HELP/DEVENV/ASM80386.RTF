{\footnote # IDH_ASM80386_05}
{\footnote $ Assembleur 80386 - CODAGE DES INSTRUCTIONS (FORMAT BINAIRE)}
{\footnote K Assembleur 80386 codage instructions format binaire;prefixes opcode ModRM SIB displacement immediate;prefixes 66 67 F0 F2 F3 26 2E 36 3E 64 65;encodage 32 bits;extension REX}
\b\fs24 CODAGE DES INSTRUCTIONS (FORMAT BINAIRE) \b0\fs20\par
\par
\par
\b 5.1 Vue d'ensemble du format d'instruction \b0\par
\par
{\f1   Chaque instruction du 80386 est codee en binaire sous la forme d'une}\par
{\f1   sequence de 1 a 15 octets. Le format general est :}\par
\par
{\f1   +----------+--------+----------+-------+--------------+----------+}\par
{\f1   | Prefixes | Opcode | Mod R/M  |  SIB  | Deplacement  | Immediat |}\par
{\f1   | 0-4 oct  | 1-2 o  | 0-1 oct  | 0-1 o | 0,1 ou 4 oct | 0,1,2,4o |}\par
{\f1   +----------+--------+----------+-------+--------------+----------+}\par
\par
{\f1   Chaque champ est optionnel sauf l'opcode. La presence des champs}\par
{\f1   Mod R/M, SIB, deplacement et immediat depend de l'instruction et}\par
{\f1   de ses operandes.}\par
\par
{\f1   Taille maximale d'une instruction : 15 octets. Si une combinaison}\par
{\f1   de prefixes et d'operandes depasse cette limite, le processeur}\par
{\f1   genere une exception #GP (General Protection Fault).}\par
\par
\par
\b 5.2 Prefixes d'instruction \b0\par
\par
{\f1   Les prefixes sont des octets optionnels places avant l'opcode.}\par
{\f1   Ils modifient le comportement de l'instruction. Il existe quatre}\par
{\f1   groupes de prefixes ; au maximum un prefixe de chaque groupe peut}\par
{\f1   etre utilise simultanement.}\par
\par
{\f1   5.2.1 Groupe 1 : Prefixes de verrouillage et de repetition}\par
\par
{\f1   F0h  LOCK       Verrouillage du bus (operations atomiques)}\par
{\f1                    Valide uniquement avec : ADD, ADC, AND, BTC, BTR,}\par
{\f1                    BTS, CMPXCHG, DEC, INC, NEG, NOT, OR, SBB, SUB,}\par
{\f1                    XADD, XCHG, XOR (avec operande memoire)}\par
\par
{\f1   F2h  REPNE      Repetition tant que ZF=0 et ECX<>0}\par
{\f1        REPNZ      (pour CMPS, SCAS)}\par
\par
{\f1   F3h  REP        Repetition tant que ECX<>0}\par
{\f1        REPE       (pour MOVS, STOS, INS, OUTS)}\par
{\f1        REPZ       Repetition tant que ZF=1 et ECX<>0}\par
{\f1                    (pour CMPS, SCAS)}\par
\par
{\f1   5.2.2 Groupe 2 : Prefixes de remplacement de segment}\par
\par
{\f1   2Eh  CS:        Utiliser le segment CS}\par
{\f1   36h  SS:        Utiliser le segment SS}\par
{\f1   3Eh  DS:        Utiliser le segment DS}\par
{\f1   26h  ES:        Utiliser le segment ES}\par
{\f1   64h  FS:        Utiliser le segment FS (nouveau 80386)}\par
{\f1   65h  GS:        Utiliser le segment GS (nouveau 80386)}\par
\par
{\f1   En l'absence de prefixe, le segment par defaut est :}\par
{\f1     - SS pour les acces via EBP ou ESP (pile)}\par
{\f1     - DS pour tous les autres acces memoire}\par
{\f1     - CS pour les lectures d'instructions (fetch)}\par
{\f1     - ES pour la destination des operations sur les chaines}\par
\par
{\f1   5.2.3 Groupe 3 : Prefixe de taille d'operande}\par
\par
{\f1   66h  Bascule la taille d'operande par defaut :}\par
{\f1        - En mode 32 bits (mode protege avec D=1) :}\par
{\f1          les operandes deviennent 16 bits}\par
{\f1        - En mode 16 bits (mode reel ou D=0) :}\par
{\f1          les operandes deviennent 32 bits}\par
\par
{\f1   Exemple :}\par
{\f1     En mode 32 bits, MOV EAX, EBX est l'instruction par defaut.}\par
{\f1     Avec le prefixe 66h, elle devient MOV AX, BX.}\par
\par
{\f1   5.2.4 Groupe 4 : Prefixe de taille d'adresse}\par
\par
{\f1   67h  Bascule la taille d'adresse par defaut :}\par
{\f1        - En mode 32 bits : les adresses deviennent 16 bits}\par
{\f1          (modes d'adressage du 8086)}\par
{\f1        - En mode 16 bits : les adresses deviennent 32 bits}\par
{\f1          (modes d'adressage etendus du 80386 avec SIB)}\par
\par
\par
\b 5.3 Opcode (code operation) \b0\par
\par
{\f1   L'opcode identifie l'instruction a executer. Il fait 1 ou 2 octets.}\par
\par
{\f1   5.3.1 Opcodes sur 1 octet}\par
\par
{\f1   La plupart des instructions courantes utilisent un opcode sur 1 octet.}\par
{\f1   Certains bits de l'opcode encodent des informations supplementaires :}\par
\par
{\f1   Bit 0 (w) : Taille de l'operande}\par
{\f1     w=0 : operande 8 bits}\par
{\f1     w=1 : operande 16 ou 32 bits (selon le mode et le prefixe 66h)}\par
\par
{\f1   Bit 1 (d) : Direction (pour les instructions a deux operandes)}\par
{\f1     d=0 : r/m <- reg  (le registre est la source)}\par
{\f1     d=1 : reg <- r/m  (le registre est la destination)}\par
\par
{\f1   Exemple pour MOV :}\par
{\f1     88h = MOV r/m8, reg8        (d=0, w=0)}\par
{\f1     89h = MOV r/m16/32, reg16/32 (d=0, w=1)}\par
{\f1     8Ah = MOV reg8, r/m8        (d=1, w=0)}\par
{\f1     8Bh = MOV reg16/32, r/m16/32 (d=1, w=1)}\par
\par
{\f1   Bit 0-2 (reg) : Certaines instructions a 1 octet encodent le}\par
{\f1   registre directement dans l'opcode :}\par
{\f1     PUSH reg  : 50h + reg   (50h=EAX, 51h=ECX, ..., 57h=EDI)}\par
{\f1     POP reg   : 58h + reg}\par
{\f1     INC reg   : 40h + reg}\par
{\f1     DEC reg   : 48h + reg}\par
{\f1     XCHG EAX, reg : 90h + reg  (90h=NOP car XCHG EAX,EAX)}\par
{\f1     MOV reg, imm  : B8h + reg (32 bits) ou B0h + reg (8 bits)}\par
\par
{\f1   5.3.2 Opcodes sur 2 octets (prefixe 0Fh)}\par
\par
{\f1   Les instructions ajoutees a partir du 80386 utilisent souvent}\par
{\f1   un opcode de 2 octets commencant par 0Fh :}\par
\par
{\f1   0Fh + opcode2    Instruction}\par
{\f1   ---------------  ------------------------------------------}\par
{\f1   0F 80..0F 8F     Jcc rel32 (sauts conditionnels etendus)}\par
{\f1   0F 90..0F 9F     SETcc r/m8}\par
{\f1   0F A3             BT r/m, reg}\par
{\f1   0F A4             SHLD r/m, reg, imm8}\par
{\f1   0F A5             SHLD r/m, reg, CL}\par
{\f1   0F AB             BTS r/m, reg}\par
{\f1   0F AC             SHRD r/m, reg, imm8}\par
{\f1   0F AD             SHRD r/m, reg, CL}\par
{\f1   0F AF             IMUL reg, r/m}\par
{\f1   0F B3             BTR r/m, reg}\par
{\f1   0F B6             MOVZX reg, r/m8}\par
{\f1   0F B7             MOVZX reg, r/m16}\par
{\f1   0F BB             BTC r/m, reg}\par
{\f1   0F BC             BSF reg, r/m}\par
{\f1   0F BD             BSR reg, r/m}\par
{\f1   0F BE             MOVSX reg, r/m8}\par
{\f1   0F BF             MOVSX reg, r/m16}\par
{\f1   0F 20..0F 23     MOV CRn/DRn (registres de controle/debug)}\par
\par
{\f1   5.3.3 Extensions d'opcode dans le champ reg}\par
\par
{\f1   Pour certains opcodes, le champ reg de l'octet Mod R/M ne designe}\par
{\f1   pas un registre mais sert d'extension d'opcode. On parle alors de}\par
{\f1   "groupe d'instructions". Exemples :}\par
\par
{\f1   Opcode 80h-83h (operations arithmetiques/logiques immediates) :}\par
{\f1     reg=0 : ADD r/m, imm}\par
{\f1     reg=1 : OR  r/m, imm}\par
{\f1     reg=2 : ADC r/m, imm}\par
{\f1     reg=3 : SBB r/m, imm}\par
{\f1     reg=4 : AND r/m, imm}\par
{\f1     reg=5 : SUB r/m, imm}\par
{\f1     reg=6 : XOR r/m, imm}\par
{\f1     reg=7 : CMP r/m, imm}\par
\par
{\f1   Opcode FEh/FFh (operations unaires) :}\par
{\f1     reg=0 : INC r/m}\par
{\f1     reg=1 : DEC r/m}\par
{\f1     reg=2 : CALL r/m (indirect, proche)}\par
{\f1     reg=3 : CALL mem (indirect, lointain)}\par
{\f1     reg=4 : JMP r/m (indirect, proche)}\par
{\f1     reg=5 : JMP mem (indirect, lointain)}\par
{\f1     reg=6 : PUSH r/m}\par
\par
{\f1   Opcode F6h/F7h (operations unaires arithmetiques) :}\par
{\f1     reg=0 : TEST r/m, imm}\par
{\f1     reg=2 : NOT r/m}\par
{\f1     reg=3 : NEG r/m}\par
{\f1     reg=4 : MUL r/m}\par
{\f1     reg=5 : IMUL r/m}\par
{\f1     reg=6 : DIV r/m}\par
{\f1     reg=7 : IDIV r/m}\par
\par
{\f1   Opcode D0h-D3h (decalages et rotations) :}\par
{\f1     reg=0 : ROL        reg=4 : SHL/SAL}\par
{\f1     reg=1 : ROR        reg=5 : SHR}\par
{\f1     reg=2 : RCL        reg=7 : SAR}\par
{\f1     reg=3 : RCR}\par
\par
\par
\b 5.4 Octet Mod R/M \b0\par
\par
{\f1   L'octet Mod R/M (ModRegR/M) specifie les operandes de l'instruction.}\par
{\f1   Il est present des qu'une instruction utilise un operande registre}\par
{\f1   ou memoire via le format general reg, r/m.}\par
\par
{\f1   Structure (8 bits) :}\par
\par
{\f1     7  6  5  4  3  2  1  0}\par
{\f1   +-----+--------+--------+}\par
{\f1   | Mod |  Reg   |  R/M   |}\par
{\f1   +-----+--------+--------+}\par
{\f1     2b     3b       3b}\par
\par
{\f1   Mod (bits 7-6) : Mode d'adressage}\par
{\f1     00 : Acces memoire, pas de deplacement}\par
{\f1          (sauf R/M=101 : deplacement 32 bits seul, [disp32])}\par
{\f1     01 : Acces memoire + deplacement 8 bits (signe-etendu)}\par
{\f1     10 : Acces memoire + deplacement 32 bits}\par
{\f1     11 : Operande registre (pas d'acces memoire)}\par
\par
{\f1   Reg (bits 5-3) : Numero du registre (ou extension d'opcode)}\par
{\f1     000=EAX/AL    001=ECX/CL    010=EDX/DL    011=EBX/BL}\par
{\f1     100=ESP/AH    101=EBP/CH    110=ESI/DH    111=EDI/BH}\par
\par
{\f1     Pour les registres 16 bits : AX, CX, DX, BX, SP, BP, SI, DI}\par
{\f1     Pour les registres de segment : ES, CS, SS, DS, FS, GS}\par
\par
{\f1   R/M (bits 2-0) : Registre ou mode memoire}\par
{\f1     Si Mod=11 : meme codage que Reg (operande registre)}\par
{\f1     Si Mod<>11 :}\par
{\f1       000 = [EAX]      001 = [ECX]      010 = [EDX]}\par
{\f1       011 = [EBX]      100 = [SIB]      101 = [disp32] (si Mod=00)}\par
{\f1                                                [EBP+disp] (si Mod=01/10)}\par
{\f1       110 = [ESI]      111 = [EDI]}\par
\par
{\f1   Note : R/M=100 (ESP) indique toujours la presence d'un octet SIB.}\par
{\f1   R/M=101 avec Mod=00 signifie un deplacement 32 bits absolu sans}\par
{\f1   registre de base.}\par
\par
{\f1   Tableau complet du Mod R/M en mode 32 bits :}\par
\par
{\f1   Mod  R/M   Mode effectif                Deplacement}\par
{\f1   ---  ---   --------------------------   -----------}\par
{\f1   00   000   [EAX]                        aucun}\par
{\f1   00   001   [ECX]                        aucun}\par
{\f1   00   010   [EDX]                        aucun}\par
{\f1   00   011   [EBX]                        aucun}\par
{\f1   00   100   [SIB]                        aucun}\par
{\f1   00   101   [disp32]                     32 bits}\par
{\f1   00   110   [ESI]                        aucun}\par
{\f1   00   111   [EDI]                        aucun}\par
{\f1   01   000   [EAX + disp8]               8 bits}\par
{\f1   01   001   [ECX + disp8]               8 bits}\par
{\f1   01   010   [EDX + disp8]               8 bits}\par
{\f1   01   011   [EBX + disp8]               8 bits}\par
{\f1   01   100   [SIB + disp8]               8 bits}\par
{\f1   01   101   [EBP + disp8]               8 bits}\par
{\f1   01   110   [ESI + disp8]               8 bits}\par
{\f1   01   111   [EDI + disp8]               8 bits}\par
{\f1   10   000   [EAX + disp32]              32 bits}\par
{\f1   10   001   [ECX + disp32]              32 bits}\par
{\f1   10   010   [EDX + disp32]              32 bits}\par
{\f1   10   011   [EBX + disp32]              32 bits}\par
{\f1   10   100   [SIB + disp32]              32 bits}\par
{\f1   10   101   [EBP + disp32]              32 bits}\par
{\f1   10   110   [ESI + disp32]              32 bits}\par
{\f1   10   111   [EDI + disp32]              32 bits}\par
{\f1   11   000   EAX / AL                    -}\par
{\f1   11   001   ECX / CL                    -}\par
{\f1   11   010   EDX / DL                    -}\par
{\f1   11   011   EBX / BL                    -}\par
{\f1   11   100   ESP / AH                    -}\par
{\f1   11   101   EBP / CH                    -}\par
{\f1   11   110   ESI / DH                    -}\par
{\f1   11   111   EDI / BH                    -}\par
\par
\par
\b 5.5 Octet SIB (Scale-Index-Base) \b0\par
\par
{\f1   L'octet SIB est present lorsque le champ R/M du Mod R/M vaut 100}\par
{\f1   (binaire). Il permet les modes d'adressage avec echelle}\par
{\f1   (scaled index) qui sont nouveaux sur le 80386.}\par
\par
{\f1   Structure (8 bits) :}\par
\par
{\f1     7  6  5  4  3  2  1  0}\par
{\f1   +-----+--------+--------+}\par
{\f1   |Scale| Index  |  Base  |}\par
{\f1   +-----+--------+--------+}\par
{\f1     2b     3b       3b}\par
\par
{\f1   Scale (bits 7-6) : Facteur d'echelle pour le registre d'index}\par
{\f1     00 = x1}\par
{\f1     01 = x2}\par
{\f1     10 = x4}\par
{\f1     11 = x8}\par
\par
{\f1   Index (bits 5-3) : Registre d'index}\par
{\f1     000=EAX    001=ECX    010=EDX    011=EBX}\par
{\f1     100=(aucun index, echelle ignoree)}\par
{\f1     101=EBP    110=ESI    111=EDI}\par
\par
{\f1     Note : Index=100 signifie "pas d'index". Cela permet d'encoder}\par
{\f1     [base] seul quand R/M=100 serait normalement [SIB].}\par
{\f1     ESP ne peut jamais etre utilise comme registre d'index.}\par
\par
{\f1   Base (bits 2-0) : Registre de base}\par
{\f1     000=EAX    001=ECX    010=EDX    011=EBX}\par
{\f1     100=ESP    101=EBP (ou disp32 si Mod=00)}\par
{\f1     110=ESI    111=EDI}\par
\par
{\f1     Note : Base=101 avec Mod=00 signifie pas de registre de base,}\par
{\f1     seulement [Index*Scale + disp32]. Avec Mod=01 ou 10, la base}\par
{\f1     est EBP normalement.}\par
\par
{\f1   Formule d'adresse avec SIB :}\par
\par
{\f1     Si Mod=00 et Base=101 :}\par
{\f1       EA = Index * Scale + disp32}\par
{\f1     Si Mod=00 et Base<>101 :}\par
{\f1       EA = Base + Index * Scale}\par
{\f1     Si Mod=01 :}\par
{\f1       EA = Base + Index * Scale + disp8 (signe-etendu)}\par
{\f1     Si Mod=10 :}\par
{\f1       EA = Base + Index * Scale + disp32}\par
\par
{\f1   Exemples de SIB :}\par
\par
{\f1     [EAX + ECX*4]     : Scale=10, Index=001, Base=000}\par
{\f1                          SIB = 10_001_000 = 88h}\par
\par
{\f1     [EBP + ESI*2 + 8] : Scale=01, Index=110, Base=101, Mod=01}\par
{\f1                          SIB = 01_110_101 = 75h, disp8 = 08h}\par
\par
{\f1     [EDX*8 + 1000h]   : Scale=11, Index=010, Base=101, Mod=00}\par
{\f1                          SIB = 11_010_101 = D5h, disp32 = 00001000h}\par
\par
{\f1     [ESP]              : R/M=100, Scale=00, Index=100, Base=100}\par
{\f1                          SIB = 00_100_100 = 24h}\par
\par
\par
\b 5.6 Deplacement \b0\par
\par
{\f1   Le deplacement est une valeur entiere signee ajoutee a l'adresse}\par
{\f1   de base calculee par Mod R/M et SIB. Sa taille depend du champ Mod :}\par
\par
{\f1   Mod=00 : Pas de deplacement (sauf cas speciaux R/M=101 ou Base=101)}\par
{\f1   Mod=01 : Deplacement de 8 bits, etendu en signe sur 32 bits}\par
{\f1   Mod=10 : Deplacement de 32 bits}\par
\par
{\f1   Cas special (Mod=00, R/M=101) :}\par
{\f1     Deplacement absolu de 32 bits, sans registre de base.}\par
{\f1     Utilise pour l'adressage direct : MOV EAX, [adresse_absolue]}\par
\par
{\f1   L'assembleur choisit automatiquement la taille optimale :}\par
{\f1     - Si le deplacement tient dans [-128, +127], il utilise disp8}\par
{\f1     - Sinon, il utilise disp32}\par
{\f1     - Le programmeur peut forcer la taille avec BYTE PTR ou DWORD PTR}\par
\par
\par
\b 5.7 Valeur immediate \b0\par
\par
{\f1   La valeur immediate est une constante codee directement dans}\par
{\f1   l'instruction. Sa taille depend de l'instruction et du bit w :}\par
\par
{\f1   w=0 : Immediat 8 bits (instructions sur octets)}\par
{\f1   w=1 : Immediat 16 ou 32 bits (selon la taille d'operande)}\par
\par
{\f1   Cas special (opcode 83h) :}\par
{\f1     Immediat de 8 bits etendu en signe sur 16 ou 32 bits.}\par
{\f1     Cela permet de coder ADD EAX, 5 sur 3 octets au lieu de 6 :}\par
{\f1       83 C0 05  au lieu de  05 00000005}\par
\par
{\f1   L'immediat est toujours encode en format little-endian :}\par
{\f1     L'octet de poids faible est place en premier.}\par
{\f1     Exemple : MOV EAX, 12345678h est code : B8 78 56 34 12}\par
\par
\par
\b 5.8 Exemples de codage complets \b0\par
\par
{\f1   Voici des exemples detailles de codage d'instructions courantes.}\par
{\f1   Chaque octet est donne en hexadecimal.}\par
\par
{\f1   5.8.1 NOP}\par
\par
{\f1   Instruction : NOP}\par
{\f1   Codage      : 90}\par
{\f1   Explication : XCHG EAX, EAX (opcode 90h = 90h + 0 pour EAX)}\par
\par
{\f1   5.8.2 MOV EAX, EBX (registre a registre)}\par
\par
{\f1   Instruction : MOV EAX, EBX}\par
{\f1   Codage      : 89 D8}\par
{\f1   Explication :}\par
{\f1     89h = MOV r/m32, reg32 (opcode d=0, w=1)}\par
{\f1     D8h = Mod R/M = 11_011_000}\par
{\f1       Mod=11 (registre)}\par
{\f1       Reg=011 (EBX = source)}\par
{\f1       R/M=000 (EAX = destination)}\par
\par
{\f1   Variante   : 8B C3  (opcode 8Bh avec d=1 : reg=EAX dest, R/M=EBX src)}\par
\par
{\f1   5.8.3 MOV EAX, [EBX] (registre indirect)}\par
\par
{\f1   Instruction : MOV EAX, [EBX]}\par
{\f1   Codage      : 8B 03}\par
{\f1   Explication :}\par
{\f1     8Bh = MOV reg32, r/m32 (d=1, w=1)}\par
{\f1     03h = Mod R/M = 00_000_011}\par
{\f1       Mod=00 (memoire, pas de deplacement)}\par
{\f1       Reg=000 (EAX = destination)}\par
{\f1       R/M=011 ([EBX])}\par
\par
{\f1   5.8.4 MOV EAX, [EBP+8] (base + deplacement)}\par
\par
{\f1   Instruction : MOV EAX, [EBP+8]}\par
{\f1   Codage      : 8B 45 08}\par
{\f1   Explication :}\par
{\f1     8Bh = MOV reg32, r/m32 (d=1, w=1)}\par
{\f1     45h = Mod R/M = 01_000_101}\par
{\f1       Mod=01 (memoire + disp8)}\par
{\f1       Reg=000 (EAX = destination)}\par
{\f1       R/M=101 ([EBP + disp8])}\par
{\f1     08h = deplacement = +8}\par
\par
{\f1   5.8.5 MOV EAX, [ESI+ECX*4] (base + index scale)}\par
\par
{\f1   Instruction : MOV EAX, [ESI+ECX*4]}\par
{\f1   Codage      : 8B 04 8E}\par
{\f1   Explication :}\par
{\f1     8Bh = MOV reg32, r/m32}\par
{\f1     04h = Mod R/M = 00_000_100}\par
{\f1       Mod=00 (memoire, pas de deplacement)}\par
{\f1       Reg=000 (EAX = destination)}\par
{\f1       R/M=100 (SIB suit)}\par
{\f1     8Eh = SIB = 10_001_110}\par
{\f1       Scale=10 (x4)}\par
{\f1       Index=001 (ECX)}\par
{\f1       Base=110 (ESI)}\par
\par
{\f1   5.8.6 MOV EAX, [EBX+ESI*2+100h] (base + index scale + disp32)}\par
\par
{\f1   Instruction : MOV EAX, [EBX+ESI*2+100h]}\par
{\f1   Codage      : 8B 84 73 00 01 00 00}\par
{\f1   Explication :}\par
{\f1     8Bh = MOV reg32, r/m32}\par
{\f1     84h = Mod R/M = 10_000_100}\par
{\f1       Mod=10 (memoire + disp32)}\par
{\f1       Reg=000 (EAX = destination)}\par
{\f1       R/M=100 (SIB suit)}\par
{\f1     73h = SIB = 01_110_011}\par
{\f1       Scale=01 (x2)}\par
{\f1       Index=110 (ESI)}\par
{\f1       Base=011 (EBX)}\par
{\f1     00 01 00 00 = deplacement 00000100h = 256}\par
\par
{\f1   5.8.7 ADD EAX, 42 (immediat optimise)}\par
\par
{\f1   Instruction : ADD EAX, 42}\par
{\f1   Codage      : 83 C0 2A}\par
{\f1   Explication :}\par
{\f1     83h = ADD r/m32, imm8 (extension signe)}\par
{\f1     C0h = Mod R/M = 11_000_000}\par
{\f1       Mod=11 (registre)}\par
{\f1       Reg=000 (extension opcode = ADD)}\par
{\f1       R/M=000 (EAX)}\par
{\f1     2Ah = 42 en hexadecimal}\par
\par
{\f1   Codage alternatif (non optimise) :}\par
{\f1     05 2A 00 00 00  (ADD EAX, imm32 : opcode special pour EAX)}\par
\par
{\f1   5.8.8 PUSH 0FFFFFFFFh (immediat 32 bits)}\par
\par
{\f1   Instruction : PUSH -1}\par
{\f1   Codage      : 6A FF}\par
{\f1   Explication :}\par
{\f1     6Ah = PUSH imm8 (etendu en signe)}\par
{\f1     FFh = -1 en complement a deux (8 bits -> 32 bits)}\par
\par
{\f1   5.8.9 JE label (saut conditionnel rel32)}\par
\par
{\f1   Instruction : JE label  (avec label a +256 octets)}\par
{\f1   Codage      : 0F 84 00 01 00 00}\par
{\f1   Explication :}\par
{\f1     0Fh 84h = JE rel32 (opcode sur 2 octets)}\par
{\f1     00 01 00 00 = deplacement relatif = +256}\par
\par
{\f1   5.8.10 MOV AX, [BX+SI] (mode 16 bits avec prefixe)}\par
\par
{\f1   Instruction : MOV AX, [BX+SI]  (en mode 32 bits)}\par
{\f1   Codage      : 67 66 8B 00}\par
{\f1   Explication :}\par
{\f1     67h = prefixe taille d'adresse (-> adresses 16 bits)}\par
{\f1     66h = prefixe taille d'operande (-> operandes 16 bits)}\par
{\f1     8Bh = MOV reg, r/m}\par
{\f1     00h = Mod R/M 16 bits = 00_000_000 = [BX+SI] sans deplacement}\par
\par
{\f1   5.8.11 LEA EAX, [EBX+ECX*8+10h]}\par
\par
{\f1   Instruction : LEA EAX, [EBX+ECX*8+10h]}\par
{\f1   Codage      : 8D 44 CB 10}\par
{\f1   Explication :}\par
{\f1     8Dh = LEA reg32, mem}\par
{\f1     44h = Mod R/M = 01_000_100}\par
{\f1       Mod=01 (memoire + disp8)}\par
{\f1       Reg=000 (EAX)}\par
{\f1       R/M=100 (SIB suit)}\par
{\f1     CBh = SIB = 11_001_011}\par
{\f1       Scale=11 (x8)}\par
{\f1       Index=001 (ECX)}\par
{\f1       Base=011 (EBX)}\par
{\f1     10h = deplacement = +16}\par
\par
{\f1   5.8.12 LOCK XADD [EDI], EAX}\par
\par
{\f1   Instruction : LOCK XADD [EDI], EAX}\par
{\f1   Codage      : F0 0F C1 07}\par
{\f1   Explication :}\par
{\f1     F0h = prefixe LOCK (operation atomique)}\par
{\f1     0Fh C1h = XADD r/m32, reg32}\par
{\f1     07h = Mod R/M = 00_000_111}\par
{\f1       Mod=00 (memoire)}\par
{\f1       Reg=000 (EAX)}\par
{\f1       R/M=111 ([EDI])}\par
\par
\par
\b 5.9 Mod R/M en mode 16 bits (adressage du 8086) \b0\par
\par
{\f1   En mode 16 bits (mode reel ou avec prefixe 67h en mode 32 bits),}\par
{\f1   l'octet Mod R/M utilise un codage different, herite du 8086.}\par
{\f1   Il n'y a pas d'octet SIB et les modes d'adressage sont limites.}\par
\par
{\f1   Mod  R/M   Mode effectif 16 bits}\par
{\f1   ---  ---   -------------------------}\par
{\f1   00   000   [BX + SI]}\par
{\f1   00   001   [BX + DI]}\par
{\f1   00   010   [BP + SI]}\par
{\f1   00   011   [BP + DI]}\par
{\f1   00   100   [SI]}\par
{\f1   00   101   [DI]}\par
{\f1   00   110   [disp16]  (adressage direct)}\par
{\f1   00   111   [BX]}\par
{\f1   01   000   [BX + SI + disp8]}\par
{\f1   01   001   [BX + DI + disp8]}\par
{\f1   01   010   [BP + SI + disp8]}\par
{\f1   01   011   [BP + DI + disp8]}\par
{\f1   01   100   [SI + disp8]}\par
{\f1   01   101   [DI + disp8]}\par
{\f1   01   110   [BP + disp8]}\par
{\f1   01   111   [BX + disp8]}\par
{\f1   10   000   [BX + SI + disp16]}\par
{\f1   10   001   [BX + DI + disp16]}\par
{\f1   10   010   [BP + SI + disp16]}\par
{\f1   10   011   [BP + DI + disp16]}\par
{\f1   10   100   [SI + disp16]}\par
{\f1   10   101   [DI + disp16]}\par
{\f1   10   110   [BP + disp16]}\par
{\f1   10   111   [BX + disp16]}\par
{\f1   11   nnn   Registre (meme codage que mode 32 bits)}\par
\par
{\f1   Differences avec le mode 32 bits :}\par
{\f1     - Pas d'octet SIB}\par
{\f1     - Pas de facteur d'echelle}\par
{\f1     - Seulement BX et BP comme registres de base}\par
{\f1     - Seulement SI et DI comme registres d'index}\par
{\f1     - Deplacements de 0, 8 ou 16 bits (au lieu de 0, 8 ou 32)}\par
\par
\par
\b 5.10 Resume du processus de decodage \b0\par
\par
{\f1   Le processeur decode une instruction selon l'algorithme suivant :}\par
\par
{\f1   1. Lire les prefixes (F0h, F2h, F3h, 2Eh, 36h, 3Eh, 26h,}\par
{\f1      64h, 65h, 66h, 67h). Arreter des qu'un octet n'est pas}\par
{\f1      un prefixe reconnu.}\par
\par
{\f1   2. Lire l'opcode (1 octet). Si l'opcode est 0Fh, lire un}\par
{\f1      second octet pour former un opcode de 2 octets.}\par
\par
{\f1   3. Si l'instruction requiert un Mod R/M, lire l'octet Mod R/M.}\par
{\f1      Determiner si un SIB est necessaire (R/M=100 et Mod<>11).}\par
\par
{\f1   4. Si un SIB est necessaire, lire l'octet SIB.}\par
\par
{\f1   5. Lire le deplacement (0, 1 ou 4 octets selon Mod et les}\par
{\f1      cas speciaux R/M=101/Base=101).}\par
\par
{\f1   6. Lire la valeur immediate si l'instruction en requiert une}\par
{\f1      (0, 1, 2 ou 4 octets).}\par
\par
{\f1   7. Executer l'instruction.}\par
\par
{\f1   Longueur totale de l'instruction :}\par
{\f1     = prefixes + opcode + [Mod R/M] + [SIB] + [depl.] + [imm.]}\par
{\f1     Minimum : 1 octet (NOP = 90h)}\par
{\f1     Maximum : 15 octets}\par
\par
{\f1   Tableau recapitulatif des tailles de chaque champ :}\par
\par
{\f1   Champ            Taille (octets)   Condition}\par
{\f1   ---------------  ----------------  ---------------------------}\par
{\f1   Prefixes         0 a 4             Optionnel}\par
{\f1   Opcode           1 ou 2            Toujours present}\par
{\f1   Mod R/M          0 ou 1            Si operande r/m requis}\par
{\f1   SIB              0 ou 1            Si R/M=100 et Mod<>11}\par
{\f1   Deplacement      0, 1 ou 4         Selon Mod (0, 8 ou 32 bits)}\par
{\f1   Immediat         0, 1, 2 ou 4      Si operande immediat requis}\par
\par
\par
