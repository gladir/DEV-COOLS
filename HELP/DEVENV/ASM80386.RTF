{\footnote # IDH_ASM80386_11}
{\footnote $ Assembleur 80386 - EXEMPLES DE CODE}
{\footnote K Assembleur 80386 exemples;Hello World;factorielle;tri a bulles;multiplication 32 64 bits;copie bloc memoire;routine delai}
\b\fs24 EXEMPLES DE CODE \b0\fs20\par
\par
{\f1   Cette section presente des exemples complets de programmes assembleur}\par
{\f1   80386, illustrant les concepts decrits dans les sections precedentes.}\par
{\f1   Tous les exemples utilisent la syntaxe MASM en mode 32 bits FLAT.}\par
\par
\par
\b 11.1 Hello World (Win32 Console) \b0\par
\par
{\f1   Programme minimal affichant "Hello, World!" sur la console Windows}\par
{\f1   en utilisant les API WriteConsoleA et ExitProcess.}\par
\par
{\f1     .386}\par
{\f1     .MODEL FLAT, STDCALL}\par
{\f1     OPTION CASEMAP:NONE}\par
\par
{\f1     ; Declarations externes des fonctions Win32}\par
{\f1     EXTRN GetStdHandle@4:NEAR}\par
{\f1     EXTRN WriteConsoleA@20:NEAR}\par
{\f1     EXTRN ExitProcess@4:NEAR}\par
\par
{\f1     .STACK 4096}\par
\par
{\f1     .DATA}\par
{\f1     message   DB  'Hello, World!', 0Dh, 0Ah, 0}\par
{\f1     msg_len   EQU $ - message - 1     ; Longueur sans le zero final}\par
\par
{\f1     .DATA?}\par
{\f1     hStdOut   DD  ?                    ; Handle de la sortie standard}\par
{\f1     written   DD  ?                    ; Nombre de caracteres ecrits}\par
\par
{\f1     .CODE}\par
{\f1     main PROC}\par
{\f1       ; Obtenir le handle de la sortie standard}\par
{\f1       PUSH -11                         ; STD_OUTPUT_HANDLE}\par
{\f1       CALL GetStdHandle@4}\par
{\f1       MOV [hStdOut], EAX}\par
\par
{\f1       ; Ecrire le message}\par
{\f1       PUSH 0                           ; Parametre reserve (NULL)}\par
{\f1       PUSH OFFSET written              ; Adresse du compteur}\par
{\f1       PUSH msg_len                     ; Nombre de caracteres}\par
{\f1       PUSH OFFSET message              ; Adresse du message}\par
{\f1       PUSH [hStdOut]                   ; Handle de sortie}\par
{\f1       CALL WriteConsoleA@20}\par
\par
{\f1       ; Terminer le programme}\par
{\f1       PUSH 0                           ; Code de sortie 0}\par
{\f1       CALL ExitProcess@4}\par
{\f1     main ENDP}\par
{\f1     END main}\par
\par
\par
\b 11.2 Calcul factoriel (iteratif et recursif) \b0\par
\par
{\f1   11.2.1 Version iterative}\par
\par
{\f1     ; Calcule n! de maniere iterative}\par
{\f1     ; Entree : ECX = n}\par
{\f1     ; Sortie : EAX = n!}\par
{\f1     Factoriel_Iter PROC}\par
{\f1       MOV EAX, 1                 ; Resultat = 1}\par
{\f1       CMP ECX, 1                 ; Si n <= 1, retourner 1}\par
{\f1       JLE @fin}\par
{\f1     @boucle:}\par
{\f1       MUL ECX                    ; EAX = EAX * ECX}\par
{\f1       DEC ECX                    ; ECX = ECX - 1}\par
{\f1       CMP ECX, 1                 ; Continuer si ECX > 1}\par
{\f1       JG  @boucle}\par
{\f1     @fin:}\par
{\f1       RET}\par
{\f1     Factoriel_Iter ENDP}\par
\par
{\f1   11.2.2 Version recursive}\par
\par
{\f1     ; Calcule n! de maniere recursive}\par
{\f1     ; Parametre sur la pile : n (DWORD)}\par
{\f1     ; Sortie : EAX = n!}\par
{\f1     Factoriel_Rec PROC}\par
{\f1       PUSH EBP}\par
{\f1       MOV EBP, ESP}\par
{\f1       MOV EAX, [EBP+8]          ; EAX = n}\par
\par
{\f1       CMP EAX, 1                ; Si n <= 1}\par
{\f1       JLE @cas_base              ; Retourner 1}\par
\par
{\f1       DEC EAX                    ; n - 1}\par
{\f1       PUSH EAX                   ; Empiler (n-1)}\par
{\f1       CALL Factoriel_Rec         ; EAX = (n-1)!}\par
{\f1       ADD ESP, 4                 ; Nettoyer la pile}\par
\par
{\f1       MOV ECX, [EBP+8]          ; ECX = n}\par
{\f1       MUL ECX                    ; EAX = (n-1)! * n}\par
{\f1       JMP @fin}\par
\par
{\f1     @cas_base:}\par
{\f1       MOV EAX, 1                 ; Retourner 1}\par
\par
{\f1     @fin:}\par
{\f1       MOV ESP, EBP}\par
{\f1       POP EBP}\par
{\f1       RET}\par
{\f1     Factoriel_Rec ENDP}\par
\par
\par
\b 11.3 Manipulation de chaines \b0\par
\par
{\f1   11.3.1 Longueur d'une chaine (strlen)}\par
\par
{\f1     ; Calcule la longueur d'une chaine terminee par zero}\par
{\f1     ; Entree : ESI = adresse de la chaine}\par
{\f1     ; Sortie : ECX = longueur}\par
{\f1     StrLen PROC}\par
{\f1       PUSH ESI                   ; Sauvegarder ESI}\par
{\f1       XOR ECX, ECX               ; Compteur = 0}\par
{\f1     @boucle:}\par
{\f1       LODSB                      ; AL = [ESI], ESI++}\par
{\f1       TEST AL, AL                ; AL == 0 ?}\par
{\f1       JZ @fin                    ; Oui : fin de chaine}\par
{\f1       INC ECX                    ; Compteur++}\par
{\f1       JMP @boucle}\par
{\f1     @fin:}\par
{\f1       POP ESI                    ; Restaurer ESI}\par
{\f1       RET}\par
{\f1     StrLen ENDP}\par
\par
{\f1   11.3.2 Copie de chaine (strcpy)}\par
\par
{\f1     ; Copie une chaine source vers une destination}\par
{\f1     ; Entree : EDI = destination, ESI = source}\par
{\f1     StrCpy PROC}\par
{\f1       PUSH ESI}\par
{\f1       PUSH EDI}\par
{\f1     @boucle:}\par
{\f1       LODSB                      ; AL = [ESI], ESI++}\par
{\f1       STOSB                      ; [EDI] = AL, EDI++}\par
{\f1       TEST AL, AL                ; Caractere nul ?}\par
{\f1       JNZ @boucle                ; Non : continuer}\par
{\f1       POP EDI}\par
{\f1       POP ESI}\par
{\f1       RET}\par
{\f1     StrCpy ENDP}\par
\par
{\f1   11.3.3 Comparaison de chaines (strcmp)}\par
\par
{\f1     ; Compare deux chaines}\par
{\f1     ; Entree : ESI = chaine1, EDI = chaine2}\par
{\f1     ; Sortie : Flags ZF=1 si egales, EAX = difference}\par
{\f1     StrCmp PROC}\par
{\f1       PUSH ESI}\par
{\f1       PUSH EDI}\par
{\f1     @boucle:}\par
{\f1       LODSB                      ; AL = [ESI], ESI++}\par
{\f1       MOV AH, [EDI]              ; AH = [EDI]}\par
{\f1       INC EDI}\par
{\f1       CMP AL, AH                 ; Comparer les caracteres}\par
{\f1       JNE @different             ; Differents : sortir}\par
{\f1       TEST AL, AL                ; Fin de chaine ?}\par
{\f1       JNZ @boucle                ; Non : continuer}\par
{\f1       XOR EAX, EAX               ; Egal : retourner 0}\par
{\f1       JMP @fin}\par
{\f1     @different:}\par
{\f1       MOVZX EAX, AL              ; Etendre AL en EAX}\par
{\f1       MOVZX ECX, AH              ; Etendre AH en ECX}\par
{\f1       SUB EAX, ECX               ; Difference}\par
{\f1     @fin:}\par
{\f1       POP EDI}\par
{\f1       POP ESI}\par
{\f1       RET}\par
{\f1     StrCmp ENDP}\par
\par
{\f1   11.3.4 Recherche de caractere (strchr)}\par
\par
{\f1     ; Recherche un caractere dans une chaine}\par
{\f1     ; Entree : ESI = chaine, AL = caractere a chercher}\par
{\f1     ; Sortie : EDI = adresse du caractere (0 si non trouve)}\par
{\f1     StrChr PROC}\par
{\f1       MOV AH, AL                 ; Sauvegarder le caractere}\par
{\f1     @boucle:}\par
{\f1       MOV AL, [ESI]}\par
{\f1       CMP AL, AH                 ; Caractere trouve ?}\par
{\f1       JE @trouve}\par
{\f1       TEST AL, AL                ; Fin de chaine ?}\par
{\f1       JZ @pas_trouve}\par
{\f1       INC ESI}\par
{\f1       JMP @boucle}\par
{\f1     @trouve:}\par
{\f1       MOV EDI, ESI               ; Retourner l'adresse}\par
{\f1       RET}\par
{\f1     @pas_trouve:}\par
{\f1       XOR EDI, EDI               ; Retourner 0}\par
{\f1       RET}\par
{\f1     StrChr ENDP}\par
\par
\par
\b 11.4 Conversion nombre-chaine \b0\par
\par
{\f1   11.4.1 Entier en chaine decimale (itoa)}\par
\par
{\f1     ; Convertit un entier 32 bits non signe en chaine decimale}\par
{\f1     ; Entree : EAX = nombre, EDI = tampon de sortie (min 11 octets)}\par
{\f1     IntToStr PROC}\par
{\f1       PUSH EBX}\par
{\f1       PUSH ECX}\par
{\f1       PUSH EDX}\par
{\f1       PUSH EDI}\par
\par
{\f1       MOV EBX, 10                ; Diviseur = 10}\par
{\f1       XOR ECX, ECX               ; Compteur de chiffres = 0}\par
\par
{\f1       ; Extraire les chiffres (ordre inverse)}\par
{\f1     @extraire:}\par
{\f1       XOR EDX, EDX               ; Preparer la division}\par
{\f1       DIV EBX                    ; EAX = quotient, EDX = reste}\par
{\f1       ADD DL, '0'                ; Convertir en ASCII}\par
{\f1       PUSH EDX                   ; Empiler le chiffre}\par
{\f1       INC ECX                    ; Compteur++}\par
{\f1       TEST EAX, EAX              ; Quotient = 0 ?}\par
{\f1       JNZ @extraire              ; Non : continuer}\par
\par
{\f1       ; Depiler les chiffres (ordre correct)}\par
{\f1       POP EDI                    ; Restaurer EDI}\par
{\f1       PUSH EDI                   ; Re-empiler pour la fin}\par
{\f1     @ecrire:}\par
{\f1       POP EDX                    ; Depiler un chiffre}\par
{\f1       MOV [EDI], DL              ; Ecrire dans le tampon}\par
{\f1       INC EDI}\par
{\f1       DEC ECX}\par
{\f1       JNZ @ecrire}\par
\par
{\f1       MOV BYTE PTR [EDI], 0     ; Terminateur nul}\par
\par
{\f1       POP EDI}\par
{\f1       POP EDX}\par
{\f1       POP ECX}\par
{\f1       POP EBX}\par
{\f1       RET}\par
{\f1     IntToStr ENDP}\par
\par
{\f1   11.4.2 Chaine decimale en entier (atoi)}\par
\par
{\f1     ; Convertit une chaine decimale en entier 32 bits non signe}\par
{\f1     ; Entree : ESI = adresse de la chaine}\par
{\f1     ; Sortie : EAX = valeur}\par
{\f1     StrToInt PROC}\par
{\f1       PUSH EBX}\par
{\f1       PUSH ECX}\par
{\f1       XOR EAX, EAX               ; Resultat = 0}\par
{\f1       MOV EBX, 10                ; Multiplicateur}\par
\par
{\f1     @boucle:}\par
{\f1       MOVZX ECX, BYTE PTR [ESI]  ; Lire un caractere}\par
{\f1       TEST CL, CL                ; Fin de chaine ?}\par
{\f1       JZ @fin}\par
{\f1       SUB CL, '0'                ; Convertir en valeur}\par
{\f1       CMP CL, 9                  ; Chiffre valide ?}\par
{\f1       JA @fin                    ; Non : arreter}\par
{\f1       MUL EBX                    ; EAX = EAX * 10}\par
{\f1       ADD EAX, ECX               ; EAX = EAX + chiffre}\par
{\f1       INC ESI}\par
{\f1       JMP @boucle}\par
\par
{\f1     @fin:}\par
{\f1       POP ECX}\par
{\f1       POP EBX}\par
{\f1       RET}\par
{\f1     StrToInt ENDP}\par
\par
\par
\b 11.5 Tri a bulles (Bubble Sort) \b0\par
\par
{\f1     ; Tri a bulles d'un tableau de DWORD}\par
{\f1     ; Entree : ESI = adresse du tableau, ECX = nombre d'elements}\par
{\f1     BubbleSort PROC}\par
{\f1       PUSH EAX}\par
{\f1       PUSH EBX}\par
{\f1       PUSH ECX}\par
{\f1       PUSH EDX}\par
{\f1       PUSH ESI}\par
\par
{\f1       DEC ECX                    ; n-1 comparaisons max}\par
{\f1       JLE @fin                   ; Tableau vide ou 1 element}\par
\par
{\f1     @passe:}\par
{\f1       XOR EDX, EDX               ; Flag echange = 0}\par
{\f1       MOV EBX, ECX               ; Compteur de la passe}\par
{\f1       PUSH ESI                   ; Sauvegarder le debut du tableau}\par
\par
{\f1     @comparer:}\par
{\f1       MOV EAX, [ESI]             ; EAX = element courant}\par
{\f1       CMP EAX, [ESI+4]           ; Comparer avec le suivant}\par
{\f1       JLE @pas_echanger          ; Ordre correct : passer}\par
\par
{\f1       ; Echanger les deux elements}\par
{\f1       XCHG EAX, [ESI+4]         ; Echanger EAX <-> [ESI+4]}\par
{\f1       MOV [ESI], EAX             ; Stocker dans [ESI]}\par
{\f1       INC EDX                    ; Flag echange = 1}\par
\par
{\f1     @pas_echanger:}\par
{\f1       ADD ESI, 4                 ; Element suivant}\par
{\f1       DEC EBX                    ; Decrementation compteur}\par
{\f1       JNZ @comparer              ; Continuer la passe}\par
\par
{\f1       POP ESI                    ; Restaurer le debut du tableau}\par
{\f1       TEST EDX, EDX              ; Des echanges ont ete faits ?}\par
{\f1       JZ @fin                    ; Non : tableau trie}\par
{\f1       DEC ECX                    ; Reduire la zone a trier}\par
{\f1       JNZ @passe                 ; Passe suivante}\par
\par
{\f1     @fin:}\par
{\f1       POP ESI}\par
{\f1       POP EDX}\par
{\f1       POP ECX}\par
{\f1       POP EBX}\par
{\f1       POP EAX}\par
{\f1       RET}\par
{\f1     BubbleSort ENDP}\par
\par
\par
\b 11.6 Recherche binaire (Binary Search) \b0\par
\par
{\f1     ; Recherche binaire dans un tableau de DWORD trie}\par
{\f1     ; Entree : ESI = tableau, ECX = nombre d'elements,}\par
{\f1     ;          EAX = valeur recherchee}\par
{\f1     ; Sortie : EDI = index (ou -1 si non trouve)}\par
{\f1     BinarySearch PROC}\par
{\f1       PUSH EBX}\par
{\f1       PUSH EDX}\par
\par
{\f1       XOR EBX, EBX               ; gauche = 0}\par
{\f1       DEC ECX                    ; droite = n - 1}\par
\par
{\f1     @boucle:}\par
{\f1       CMP EBX, ECX               ; gauche > droite ?}\par
{\f1       JG @non_trouve}\par
\par
{\f1       MOV EDI, EBX               ; milieu = (gauche + droite) / 2}\par
{\f1       ADD EDI, ECX}\par
{\f1       SHR EDI, 1}\par
\par
{\f1       MOV EDX, [ESI + EDI*4]    ; EDX = tableau[milieu]}\par
{\f1       CMP EAX, EDX               ; Comparer avec la valeur cherchee}\par
{\f1       JE @trouve                 ; Egal : trouve !}\par
{\f1       JL @gauche                 ; Inferieur : chercher a gauche}\par
\par
{\f1       ; Chercher a droite}\par
{\f1       LEA EBX, [EDI+1]          ; gauche = milieu + 1}\par
{\f1       JMP @boucle}\par
\par
{\f1     @gauche:}\par
{\f1       LEA ECX, [EDI-1]          ; droite = milieu - 1}\par
{\f1       JMP @boucle}\par
\par
{\f1     @non_trouve:}\par
{\f1       MOV EDI, -1                ; Retourner -1 (non trouve)}\par
\par
{\f1     @trouve:                     ; EDI contient l'index}\par
{\f1       POP EDX}\par
{\f1       POP EBX}\par
{\f1       RET}\par
{\f1     BinarySearch ENDP}\par
\par
\par
\b 11.7 Operations sur les bits \b0\par
\par
{\f1   11.7.1 Compter les bits a 1 (popcount)}\par
\par
{\f1     ; Compte le nombre de bits a 1 dans un registre 32 bits}\par
{\f1     ; Entree : EAX = valeur}\par
{\f1     ; Sortie : ECX = nombre de bits a 1}\par
{\f1     PopCount PROC}\par
{\f1       XOR ECX, ECX               ; Compteur = 0}\par
{\f1     @boucle:}\par
{\f1       TEST EAX, EAX              ; EAX == 0 ?}\par
{\f1       JZ @fin}\par
{\f1       MOV EDX, EAX}\par
{\f1       DEC EDX                    ; EDX = EAX - 1}\par
{\f1       AND EAX, EDX               ; Effacer le bit le plus bas}\par
{\f1       INC ECX                    ; Compteur++}\par
{\f1       JMP @boucle}\par
{\f1     @fin:}\par
{\f1       RET}\par
{\f1     PopCount ENDP}\par
\par
{\f1   11.7.2 Inversion des bits (bit reverse)}\par
\par
{\f1     ; Inverse l'ordre des bits dans EAX (bit 0 <-> bit 31, etc.)}\par
{\f1     ; Entree/Sortie : EAX}\par
{\f1     BitReverse PROC}\par
{\f1       PUSH EBX}\par
{\f1       PUSH ECX}\par
{\f1       MOV ECX, 32                ; 32 bits a traiter}\par
{\f1       XOR EBX, EBX               ; Resultat = 0}\par
{\f1     @boucle:}\par
{\f1       SHL EBX, 1                 ; Decaler le resultat a gauche}\par
{\f1       MOV EDX, EAX}\par
{\f1       AND EDX, 1                 ; Extraire le bit de poids faible}\par
{\f1       OR EBX, EDX                ; Ajouter au resultat}\par
{\f1       SHR EAX, 1                 ; Bit suivant de la source}\par
{\f1       DEC ECX}\par
{\f1       JNZ @boucle}\par
{\f1       MOV EAX, EBX               ; Resultat dans EAX}\par
{\f1       POP ECX}\par
{\f1       POP EBX}\par
{\f1       RET}\par
{\f1     BitReverse ENDP}\par
\par
{\f1   11.7.3 Plus grande puissance de 2 inferieure ou egale}\par
\par
{\f1     ; Trouve la plus grande puissance de 2 <= EAX}\par
{\f1     ; Entree : EAX = valeur (> 0)}\par
{\f1     ; Sortie : EAX = puissance de 2}\par
{\f1     FloorPow2 PROC}\par
{\f1       BSR ECX, EAX               ; ECX = position du bit le plus haut}\par
{\f1       MOV EAX, 1}\par
{\f1       SHL EAX, CL                ; EAX = 2^ECX}\par
{\f1       RET}\par
{\f1     FloorPow2 ENDP}\par
\par
\par
\b 11.8 Utilisation de la pile et cadres de pile \b0\par
\par
{\f1     ; Exemple de fonction avec variables locales et cadre de pile}\par
{\f1     ;}\par
{\f1     ; int Exemple(int a, int b) \{}\par
{\f1     ;   int temp = a + b;}\par
{\f1     ;   int result = temp * 2;}\par
{\f1     ;   return result;}\par
{\f1     ; \}}\par
\par
{\f1     Exemple PROC}\par
{\f1       PUSH EBP                   ; Sauvegarder l'ancien cadre}\par
{\f1       MOV EBP, ESP               ; Etablir le nouveau cadre}\par
{\f1       SUB ESP, 8                 ; Reserver 2 variables locales}\par
\par
{\f1       ; [EBP+8]  = parametre a}\par
{\f1       ; [EBP+12] = parametre b}\par
{\f1       ; [EBP-4]  = variable locale temp}\par
{\f1       ; [EBP-8]  = variable locale result}\par
\par
{\f1       MOV EAX, [EBP+8]          ; EAX = a}\par
{\f1       ADD EAX, [EBP+12]         ; EAX = a + b}\par
{\f1       MOV [EBP-4], EAX          ; temp = a + b}\par
\par
{\f1       SHL EAX, 1                 ; EAX = temp * 2}\par
{\f1       MOV [EBP-8], EAX          ; result = temp * 2}\par
\par
{\f1       MOV EAX, [EBP-8]          ; Retourner result dans EAX}\par
\par
{\f1       MOV ESP, EBP               ; Restaurer la pile}\par
{\f1       POP EBP                    ; Restaurer l'ancien cadre}\par
{\f1       RET                        ; Retourner a l'appelant}\par
{\f1     Exemple ENDP}\par
\par
{\f1     ; Appel de la fonction :}\par
{\f1     ;   PUSH 20                  ; Parametre b = 20}\par
{\f1     ;   PUSH 10                  ; Parametre a = 10}\par
{\f1     ;   CALL Exemple}\par
{\f1     ;   ADD ESP, 8               ; Nettoyer la pile (convention C)}\par
{\f1     ;   ; EAX = (10 + 20) * 2 = 60}\par
\par
{\f1     ; Etat de la pile pendant l'execution :}\par
{\f1     ;}\par
{\f1     ;   ESP -> [EBP-8] result}\par
{\f1     ;          [EBP-4] temp}\par
{\f1     ;   EBP -> [EBP]   ancien EBP}\par
{\f1     ;          [EBP+4] adresse de retour}\par
{\f1     ;          [EBP+8] parametre a = 10}\par
{\f1     ;          [EBP+12] parametre b = 20}\par
\par
\par
\b 11.9 Acces memoire avec modes d'adressage avances \b0\par
\par
{\f1     ; Exemples des modes d'adressage du 80386}\par
\par
{\f1     .DATA}\par
{\f1     tableau   DD 10, 20, 30, 40, 50   ; Tableau de 5 DWORD}\par
{\f1     matrice   DD 1, 2, 3              ; Ligne 0}\par
{\f1               DD 4, 5, 6              ; Ligne 1}\par
{\f1               DD 7, 8, 9              ; Ligne 2}\par
{\f1     COLS      EQU 3                    ; 3 colonnes}\par
\par
{\f1     .CODE}\par
{\f1     ExempleAdressage PROC}\par
{\f1       ; Adressage direct}\par
{\f1       MOV EAX, [tableau]              ; Premier element}\par
\par
{\f1       ; Adressage base + deplacement}\par
{\f1       MOV ESI, OFFSET tableau}\par
{\f1       MOV EAX, [ESI + 8]              ; Troisieme element (offset 8)}\par
\par
{\f1       ; Adressage indexe avec facteur d'echelle}\par
{\f1       MOV ECX, 2                       ; Index = 2}\par
{\f1       MOV EAX, [tableau + ECX*4]      ; tableau[2] = 30}\par
\par
{\f1       ; Adressage base + index * echelle + deplacement}\par
{\f1       ; Acces matrice[ligne][colonne] :}\par
{\f1       ; adresse = matrice + (ligne * COLS + colonne) * 4}\par
{\f1       MOV EBX, 1                       ; ligne = 1}\par
{\f1       IMUL EBX, COLS                   ; EBX = ligne * COLS}\par
{\f1       ADD EBX, 2                       ; EBX = ligne * COLS + colonne}\par
{\f1       MOV EAX, [matrice + EBX*4]      ; matrice[1][2] = 6}\par
\par
{\f1       ; Meme chose avec LEA}\par
{\f1       MOV ESI, OFFSET matrice}\par
{\f1       MOV EBX, 1                       ; ligne = 1}\par
{\f1       IMUL EBX, COLS * 4              ; EBX = ligne * COLS * 4}\par
{\f1       MOV ECX, 2                       ; colonne = 2}\par
{\f1       LEA EAX, [ESI + EBX + ECX*4]   ; Adresse de matrice[1][2]}\par
{\f1       MOV EAX, [EAX]                  ; Valeur = 6}\par
\par
{\f1       RET}\par
{\f1     ExempleAdressage ENDP}\par
\par
\par
\b 11.10 Utilisation des instructions de chaine (REP) \b0\par
\par
{\f1     ; Copie rapide de bloc memoire (memcpy)}\par
{\f1     ; Entree : EDI = destination, ESI = source, ECX = taille en octets}\par
{\f1     MemCopy PROC}\par
{\f1       PUSH ECX}\par
{\f1       PUSH ESI}\par
{\f1       PUSH EDI}\par
{\f1       CLD                        ; Direction : increment}\par
\par
{\f1       ; Copier par blocs de 4 octets (DWORD)}\par
{\f1       MOV EBX, ECX               ; Sauvegarder la taille totale}\par
{\f1       SHR ECX, 2                 ; Nombre de DWORD}\par
{\f1       REP MOVSD                  ; Copier les DWORD}\par
\par
{\f1       ; Copier les octets restants}\par
{\f1       MOV ECX, EBX}\par
{\f1       AND ECX, 3                 ; Reste = taille MOD 4}\par
{\f1       REP MOVSB                  ; Copier les octets restants}\par
\par
{\f1       POP EDI}\par
{\f1       POP ESI}\par
{\f1       POP ECX}\par
{\f1       RET}\par
{\f1     MemCopy ENDP}\par
\par
{\f1     ; Remplissage de bloc memoire (memset)}\par
{\f1     ; Entree : EDI = destination, AL = valeur, ECX = taille en octets}\par
{\f1     MemSet PROC}\par
{\f1       PUSH ECX}\par
{\f1       PUSH EDI}\par
{\f1       CLD}\par
\par
{\f1       ; Etendre AL sur les 4 octets de EAX}\par
{\f1       MOV AH, AL                 ; AX = AL:AL}\par
{\f1       MOV BX, AX}\par
{\f1       SHL EAX, 16}\par
{\f1       MOV AX, BX                 ; EAX = AL:AL:AL:AL}\par
\par
{\f1       ; Remplir par blocs de 4 octets}\par
{\f1       MOV EBX, ECX}\par
{\f1       SHR ECX, 2}\par
{\f1       REP STOSD}\par
\par
{\f1       ; Remplir les octets restants}\par
{\f1       MOV ECX, EBX}\par
{\f1       AND ECX, 3}\par
{\f1       REP STOSB}\par
\par
{\f1       POP EDI}\par
{\f1       POP ECX}\par
{\f1       RET}\par
{\f1     MemSet ENDP}\par
\par
{\f1     ; Recherche d'un octet dans un bloc (memchr)}\par
{\f1     ; Entree : EDI = bloc, AL = octet, ECX = taille}\par
{\f1     ; Sortie : EDI = adresse (0 si non trouve), ZF = 1 si trouve}\par
{\f1     MemChr PROC}\par
{\f1       CLD}\par
{\f1       REPNE SCASB                ; Chercher AL dans [EDI]}\par
{\f1       JNE @non_trouve}\par
{\f1       DEC EDI                    ; Revenir sur l'octet trouve}\par
{\f1       RET}\par
{\f1     @non_trouve:}\par
{\f1       XOR EDI, EDI               ; Retourner 0}\par
{\f1       RET}\par
{\f1     MemChr ENDP}\par
\par
\par
\b 11.11 Exemple avec macro et assemblage conditionnel \b0\par
\par
{\f1     ; Macro de trace pour le debug}\par
{\f1     DEBUG_MODE = 1}\par
\par
{\f1     PrintDebug MACRO msg}\par
{\f1       IF DEBUG_MODE}\par
{\f1         PUSH OFFSET msg}\par
{\f1         CALL _puts}\par
{\f1         ADD ESP, 4}\par
{\f1       ENDIF}\par
{\f1     ENDM}\par
\par
{\f1     ; Macro d'assertion}\par
{\f1     ASSERT MACRO condition}\par
{\f1       LOCAL ok}\par
{\f1       IF DEBUG_MODE}\par
{\f1         condition}\par
{\f1         JMP ok}\par
{\f1         INT 3                    ; Point d'arret en mode debug}\par
{\f1       ok:}\par
{\f1       ENDIF}\par
{\f1     ENDM}\par
\par
{\f1     ; Macro pour declarer une chaine avec sa longueur}\par
{\f1     DEFSTR MACRO nom, texte}\par
{\f1       nom       DB texte, 0}\par
{\f1       nom&_len  EQU $ - nom - 1}\par
{\f1     ENDM}\par
\par
{\f1     .DATA}\par
{\f1     DEFSTR salut, 'Bonjour le monde'}\par
{\f1     ; Genere :}\par
{\f1     ;   salut     DB 'Bonjour le monde', 0}\par
{\f1     ;   salut_len EQU 16}\par
\par
{\f1     ; Macro de boucle FOR (haut niveau)}\par
{\f1     FOR_LOOP MACRO reg, debut, fin}\par
{\f1       MOV reg, debut}\par
{\f1     ENDM}\par
\par
{\f1     FOR_NEXT MACRO reg, etiq_debut}\par
{\f1       INC reg}\par
{\f1       JMP etiq_debut}\par
{\f1     ENDM}\par
\par
\par
\b 11.12 Programme complet : Conversion hexadecimale \b0\par
\par
{\f1   Programme Win32 complet qui convertit un nombre 32 bits en}\par
{\f1   sa representation hexadecimale et l'affiche sur la console.}\par
\par
{\f1     .386}\par
{\f1     .MODEL FLAT, STDCALL}\par
{\f1     OPTION CASEMAP:NONE}\par
\par
{\f1     EXTRN GetStdHandle@4:NEAR}\par
{\f1     EXTRN WriteConsoleA@20:NEAR}\par
{\f1     EXTRN ExitProcess@4:NEAR}\par
\par
{\f1     .STACK 4096}\par
\par
{\f1     .DATA}\par
{\f1     hexchars  DB '0123456789ABCDEF'   ; Table de conversion}\par
{\f1     buffer    DB '00000000', 0Dh, 0Ah, 0  ; 8 chiffres + CRLF + nul}\par
{\f1     buf_len   EQU 10                   ; 8 chiffres + CR + LF}\par
{\f1     nombre    DD 0DEADBEEFh           ; Valeur a convertir}\par
\par
{\f1     .DATA?}\par
{\f1     hStdOut   DD ?}\par
{\f1     written   DD ?}\par
\par
{\f1     .CODE}\par
{\f1     ; Convertit EAX en hexadecimal dans le buffer}\par
{\f1     DwordToHex PROC}\par
{\f1       PUSH EBX}\par
{\f1       PUSH ECX}\par
{\f1       PUSH EDI}\par
\par
{\f1       MOV EDI, OFFSET buffer + 7 ; Pointer sur le dernier chiffre}\par
{\f1       MOV ECX, 8                  ; 8 chiffres hexadecimaux}\par
\par
{\f1     @boucle:}\par
{\f1       MOV EBX, EAX}\par
{\f1       AND EBX, 0Fh               ; Extraire le quartet bas}\par
{\f1       MOV BL, [hexchars + EBX]  ; Convertir en caractere}\par
{\f1       MOV [EDI], BL              ; Ecrire dans le buffer}\par
{\f1       SHR EAX, 4                 ; Quartet suivant}\par
{\f1       DEC EDI                    ; Position precedente}\par
{\f1       DEC ECX}\par
{\f1       JNZ @boucle}\par
\par
{\f1       POP EDI}\par
{\f1       POP ECX}\par
{\f1       POP EBX}\par
{\f1       RET}\par
{\f1     DwordToHex ENDP}\par
\par
{\f1     main PROC}\par
{\f1       ; Obtenir le handle de sortie}\par
{\f1       PUSH -11}\par
{\f1       CALL GetStdHandle@4}\par
{\f1       MOV [hStdOut], EAX}\par
\par
{\f1       ; Convertir le nombre en hexadecimal}\par
{\f1       MOV EAX, [nombre]}\par
{\f1       CALL DwordToHex}\par
\par
{\f1       ; Afficher le resultat}\par
{\f1       PUSH 0}\par
{\f1       PUSH OFFSET written}\par
{\f1       PUSH buf_len}\par
{\f1       PUSH OFFSET buffer}\par
{\f1       PUSH [hStdOut]}\par
{\f1       CALL WriteConsoleA@20}\par
\par
{\f1       ; Quitter}\par
{\f1       PUSH 0}\par
{\f1       CALL ExitProcess@4}\par
{\f1     main ENDP}\par
{\f1     END main}\par
\par
