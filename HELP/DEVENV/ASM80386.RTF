{\footnote # IDH_ASM80386_02}
{\footnote $ Assembleur 80386 - ARCHITECTURE ET REGISTRES}
{\footnote K Assembleur 80386 architecture registres;registres generaux EAX EBX ECX EDX;ESI EDI EBP ESP;CS DS ES FS GS SS;EIP;EFLAGS;registres controle CR0-CR4;registres debug DR0-DR7;registres test;registres systeme GDTR LDTR IDTR TR}
\b\fs24 ARCHITECTURE ET REGISTRES \b0\fs20\par
\par
\par
\b 2.1 Vue d'ensemble de l'architecture \b0\par
\par
{\f1   Le 80386 est un processeur 32 bits a architecture CISC (Complex}\par
{\f1   Instruction Set Computer). Son architecture interne comprend :}\par
\par
{\f1     - Une unite de bus (Bus Interface Unit) pour les acces memoire}\par
{\f1       et E/S sur un bus externe de 32 bits de donnees et 32 bits}\par
{\f1       d'adresses}\par
{\f1     - Une unite de prefetch de code (Code Prefetch Unit) avec une}\par
{\f1       file d'attente de 16 octets}\par
{\f1     - Une unite de decodage d'instructions (Instruction Decode Unit)}\par
{\f1     - Une unite d'execution (Execution Unit) avec une ALU 32 bits,}\par
{\f1       un multiplicateur et un decaleur (barrel shifter)}\par
{\f1     - Une unite de segmentation (Segmentation Unit) pour la}\par
{\f1       traduction des adresses logiques en adresses lineaires}\par
{\f1     - Une unite de pagination (Paging Unit) pour la traduction}\par
{\f1       des adresses lineaires en adresses physiques}\par
\par
{\f1   Le pipeline du 80386 comporte 6 etapes, ce qui permet un}\par
{\f1   recouvrement partiel entre les phases de traitement des}\par
{\f1   instructions successives.}\par
\par
\par
\b 2.2 Registres generaux 32 bits \b0\par
\par
{\f1   Le 80386 dispose de 8 registres generaux de 32 bits. Chacun peut}\par
{\f1   etre accede en totalite (32 bits), en partie basse 16 bits, et}\par
{\f1   pour les 4 premiers, en sous-registres de 8 bits.}\par
\par
{\f1   Schema de decomposition (exemple avec EAX) :}\par
\par
{\f1     Bits :  31 ............. 16  15 ...... 8  7 ....... 0}\par
{\f1             |                 |  |         |  |         |}\par
{\f1             |     (non        |  |   AH    |  |   AL    |}\par
{\f1             |   accessible    |  |         |  |         |}\par
{\f1             |  directement)   |  |         |  |         |}\par
{\f1             |                 |  |--- AX --|--|---------|}\par
{\f1             |------- EAX -----|--|---------|--|---------|}\par
\par
{\f1   Registre  32 bits  16 bits  8 bits haut  8 bits bas  Utilisation}\par
{\f1   --------  -------  -------  ----------  ----------  ------------------}\par
{\f1   EAX       EAX      AX       AH          AL          Accumulateur}\par
{\f1   EBX       EBX      BX       BH          BL          Base (adressage)}\par
{\f1   ECX       ECX      CX       CH          CL          Compteur (boucles)}\par
{\f1   EDX       EDX      DX       DH          DL          Donnees (E/S, MUL)}\par
{\f1   ESI       ESI      SI       -           -           Source (chaines)}\par
{\f1   EDI       EDI      DI       -           -           Destination (chaines)}\par
{\f1   EBP       EBP      BP       -           -           Pointeur de base}\par
{\f1   ESP       ESP      SP       -           -           Pointeur de pile}\par
\par
{\f1   Roles conventionnels :}\par
\par
{\f1     EAX (Accumulator) :}\par
{\f1       - Operande implicite pour MUL, IMUL, DIV, IDIV, CBW, CWD, CDQ}\par
{\f1       - Port de retour des fonctions (convention C et stdcall)}\par
{\f1       - Operande implicite pour IN/OUT (E/S)}\par
{\f1       - Formes courtes d'instructions (1 octet de moins avec AL/AX/EAX)}\par
\par
{\f1     EBX (Base) :}\par
{\f1       - Registre de base pour l'adressage indirect}\par
{\f1       - Souvent utilise pour pointer sur des structures de donnees}\par
{\f1       - XLAT utilise DS:[EBX+AL] implicitement}\par
\par
{\f1     ECX (Counter) :}\par
{\f1       - Compteur implicite pour LOOP, REP, JCXZ/JECXZ}\par
{\f1       - Compteur de decalage pour SHL/SHR/ROL/ROR (via CL)}\par
{\f1       - Souvent utilise comme compteur de boucle}\par
\par
{\f1     EDX (Data) :}\par
{\f1       - Extension de EAX pour MUL/IMUL (resultat 64 bits EDX:EAX)}\par
{\f1       - Extension de EAX pour DIV/IDIV (dividende EDX:EAX)}\par
{\f1       - Numero de port pour IN/OUT (via DX)}\par
{\f1       - CDQ etend le signe de EAX dans EDX}\par
\par
{\f1     ESI (Source Index) :}\par
{\f1       - Pointeur source implicite pour MOVS, CMPS, LODS (DS:[ESI])}\par
{\f1       - Incremente/decremente automatiquement par les instructions}\par
{\f1         de chaines selon le drapeau DF}\par
\par
{\f1     EDI (Destination Index) :}\par
{\f1       - Pointeur destination implicite pour MOVS, CMPS, STOS,}\par
{\f1         SCAS (ES:[EDI])}\par
{\f1       - Incremente/decremente automatiquement par les instructions}\par
{\f1         de chaines selon le drapeau DF}\par
\par
{\f1     EBP (Base Pointer) :}\par
{\f1       - Pointeur de cadre de pile (stack frame) par convention}\par
{\f1       - Utilise pour acceder aux parametres et variables locales}\par
{\f1         dans les procedures : [EBP+8] = 1er parametre,}\par
{\f1         [EBP-4] = 1ere variable locale}\par
{\f1       - Adresse implicitement le segment SS}\par
\par
{\f1     ESP (Stack Pointer) :}\par
{\f1       - Pointeur de sommet de pile, modifie par PUSH/POP/CALL/RET}\par
{\f1       - Adresse implicitement le segment SS}\par
{\f1       - Doit toujours pointer sur une adresse valide}\par
{\f1       - Ne doit pas etre utilise comme registre general}\par
\par
\par
\b 2.3 Registres de segment \b0\par
\par
{\f1   Le 80386 dispose de 6 registres de segment de 16 bits. En mode}\par
{\f1   reel, ils contiennent la base du segment (adresse >> 4). En mode}\par
{\f1   protege, ils contiennent un selecteur qui reference un descripteur}\par
{\f1   dans la GDT ou la LDT.}\par
\par
{\f1   Registre  Nom complet             Utilisation}\par
{\f1   --------  ----------------------  -----------------------------------}\par
{\f1   CS        Code Segment            Segment du code en cours d'execution}\par
{\f1   DS        Data Segment            Segment de donnees par defaut}\par
{\f1   SS        Stack Segment           Segment de la pile}\par
{\f1   ES        Extra Segment           Segment supplementaire (destination}\par
{\f1                                     pour les instructions de chaines)}\par
{\f1   FS        (pas de nom officiel)   Segment supplementaire (nouveau 386)}\par
{\f1   GS        (pas de nom officiel)   Segment supplementaire (nouveau 386)}\par
\par
{\f1   Notes :}\par
{\f1     - CS ne peut etre modifie que par JMP FAR, CALL FAR, RET FAR,}\par
{\f1       IRET ou une interruption}\par
{\f1     - FS et GS sont de nouveaux registres introduits par le 80386}\par
{\f1     - En mode protege, chaque registre de segment possede une partie}\par
{\f1       cachee (base, limite, droits d'acces) chargee depuis le}\par
{\f1       descripteur lors de l'affectation du selecteur}\par
{\f1     - En mode FLAT (Windows 32 bits), CS/DS/ES/SS pointent}\par
{\f1       generalement tous sur le meme espace d'adressage de 4 Go}\par
\par
\par
\b 2.4 Pointeur d'instruction (EIP) \b0\par
\par
{\f1   Le registre EIP (Extended Instruction Pointer) contient l'adresse}\par
{\f1   (offset) de la prochaine instruction a executer dans le segment}\par
{\f1   de code courant (CS).}\par
\par
{\f1     Taille : 32 bits (16 bits en mode reel, via IP)}\par
{\f1     Acces  : Non accessible directement par les instructions MOV}\par
{\f1     Modification : Uniquement via JMP, CALL, RET, IRET, INT,}\par
{\f1                    interruptions et exceptions}\par
\par
{\f1   En mode reel, seuls les 16 bits bas (IP) sont significatifs,}\par
{\f1   limitant l'offset dans le segment de code a 64 Ko.}\par
{\f1   En mode protege 32 bits, EIP permet d'adresser jusqu'a 4 Go}\par
{\f1   dans le segment de code.}\par
\par
\par
\b 2.5 Registre de drapeaux (EFLAGS) \b0\par
\par
{\f1   Le registre EFLAGS est un registre de 32 bits contenant les}\par
{\f1   drapeaux d'etat, de controle et systeme du processeur. Les bits}\par
{\f1   16 a 31 sont nouveaux par rapport au registre FLAGS du 8086/80286.}\par
\par
{\f1   Bit  Sigle  Nom                     Description}\par
{\f1   ---  -----  ----------------------  --------------------------------}\par
{\f1    0   CF     Carry Flag              Retenue/emprunt non signe}\par
{\f1    1   (1)    (reserve, toujours 1)}\par
{\f1    2   PF     Parity Flag             Parite de l'octet bas du resultat}\par
{\f1    3   (0)    (reserve)}\par
{\f1    4   AF     Auxiliary Carry Flag     Retenue BCD (bit 3 vers bit 4)}\par
{\f1    5   (0)    (reserve)}\par
{\f1    6   ZF     Zero Flag               Resultat egal a zero}\par
{\f1    7   SF     Sign Flag               Bit de signe du resultat}\par
{\f1    8   TF     Trap Flag               Mode pas-a-pas (debug)}\par
{\f1    9   IF     Interrupt Enable Flag   Autorise les interruptions}\par
{\f1                                       materielles (masquables)}\par
{\f1   10   DF     Direction Flag           Sens des operations de chaines}\par
{\f1                                       (0 = croissant, 1 = decroissant)}\par
{\f1   11   OF     Overflow Flag           Debordement signe}\par
{\f1   12-13 IOPL  I/O Privilege Level     Niveau de privilege pour E/S}\par
{\f1                                       (0 a 3, mode protege uniquement)}\par
{\f1   14   NT     Nested Task              Tache imbriquee (mode protege)}\par
{\f1   15   (0)    (reserve)}\par
{\f1   16   RF     Resume Flag              Reprendre apres un point d'arret}\par
{\f1                                       debug (nouveau 80386)}\par
{\f1   17   VM     Virtual 8086 Mode        Active le mode V86 (nouveau 386)}\par
{\f1   18-31 (0)   (reserves sur le 80386, utilises sur les processeurs}\par
{\f1               ulterieurs : AC, VIF, VIP, ID)}\par
\par
{\f1   Drapeaux d'etat (modifies par les instructions arithmetiques}\par
{\f1   et logiques) :}\par
{\f1     CF : Retenue pour les operations non signees}\par
{\f1     PF : 1 si le nombre de bits a 1 dans l'octet bas est pair}\par
{\f1     AF : Retenue auxiliaire pour l'arithmetique BCD}\par
{\f1     ZF : 1 si le resultat est zero}\par
{\f1     SF : Copie du bit de poids fort du resultat}\par
{\f1     OF : 1 si debordement signe (le resultat ne tient pas dans}\par
{\f1          la taille de la destination en complement a deux)}\par
\par
{\f1   Drapeaux de controle :}\par
{\f1     DF : Controle le sens de ESI/EDI pour MOVS, CMPS, STOS, LODS,}\par
{\f1          SCAS. Modifie par CLD (DF=0) et STD (DF=1)}\par
{\f1     IF : Active/desactive les interruptions masquables. Modifie}\par
{\f1          par CLI (IF=0) et STI (IF=1)}\par
{\f1     TF : Provoque une exception INT 1 apres chaque instruction}\par
{\f1          (mode de trace pour les debogueurs)}\par
\par
{\f1   Drapeaux systeme (mode protege) :}\par
{\f1     IOPL : Determine le niveau de privilege minimum pour executer}\par
{\f1            les instructions d'E/S (IN, OUT, INS, OUTS, CLI, STI)}\par
{\f1     NT   : Indique que la tache courante est imbriquee (chainee}\par
{\f1            via le TSS)}\par
{\f1     RF   : Empeche les exceptions de debogage (#DB) lors de la}\par
{\f1            prochaine instruction (evite les boucles infinies}\par
{\f1            sur les points d'arret)}\par
{\f1     VM   : Active le mode Virtual 8086 (le processeur execute le}\par
{\f1            code comme un 8086 mais sous supervision du noyau}\par
{\f1            protege)}\par
\par
\par
\b 2.6 Registres de controle \b0\par
\par
{\f1   Le 80386 possede 3 registres de controle de 32 bits accessibles}\par
{\f1   uniquement en mode protege (anneau 0) via MOV CRn, reg / MOV reg, CRn.}\par
\par
{\f1   CR0 (Control Register 0) :}\par
{\f1     Bit 0  : PE (Protection Enable) - Active le mode protege}\par
{\f1     Bit 1  : MP (Monitor Coprocessor) - Surveillance du coprocesseur}\par
{\f1     Bit 2  : EM (Emulation) - Emulation du coprocesseur x87}\par
{\f1     Bit 3  : TS (Task Switched) - Indique un changement de tache}\par
{\f1     Bit 4  : ET (Extension Type) - Type de coprocesseur (387 vs 287)}\par
{\f1     Bit 16 : WP (Write Protect) - Protection en ecriture des pages}\par
{\f1              utilisateur meme en anneau 0 (absent sur 80386 initial,}\par
{\f1              ajoute sur 80486)}\par
{\f1     Bit 31 : PG (Paging) - Active la pagination}\par
\par
{\f1     Passage en mode protege : activer PE (bit 0 de CR0)}\par
{\f1     Activation de la pagination : activer PG (bit 31 de CR0)}\par
{\f1     Les deux peuvent etre actives simultanement}\par
\par
{\f1   CR1 (Control Register 1) :}\par
{\f1     Reserve par Intel. Non utilise sur le 80386.}\par
\par
{\f1   CR2 (Control Register 2) :}\par
{\f1     Contient l'adresse lineaire de 32 bits qui a provoque le}\par
{\f1     dernier defaut de page (#PF, exception 14). Le gestionnaire}\par
{\f1     de defaut de page lit CR2 pour identifier la page fautive.}\par
\par
{\f1   CR3 (Control Register 3) - PDBR (Page Directory Base Register) :}\par
{\f1     Contient l'adresse physique de base du repertoire de pages}\par
{\f1     (Page Directory). Les 12 bits de poids faible sont ignores}\par
{\f1     (le repertoire doit etre aligne sur une limite de 4 Ko).}\par
{\f1     La modification de CR3 invalide le TLB (Translation Lookaside}\par
{\f1     Buffer).}\par
\par
\par
\b 2.7 Registres de debogage \b0\par
\par
{\f1   Le 80386 possede 8 registres de debogage de 32 bits (DR0 a DR7)}\par
{\f1   permettant de definir des points d'arret materiels sans modifier}\par
{\f1   le code.}\par
\par
{\f1   DR0, DR1, DR2, DR3 :}\par
{\f1     Contiennent les adresses lineaires des 4 points d'arret}\par
{\f1     materiels. Chaque point d'arret est independant et peut}\par
{\f1     surveiller une adresse differente.}\par
\par
{\f1   DR4, DR5 :}\par
{\f1     Reserves (aliases de DR6/DR7 sur le 80386).}\par
\par
{\f1   DR6 (Debug Status Register) :}\par
{\f1     Indique la cause de la derniere exception de debogage (#DB) :}\par
{\f1     Bit 0 (B0) : Point d'arret 0 declenche}\par
{\f1     Bit 1 (B1) : Point d'arret 1 declenche}\par
{\f1     Bit 2 (B2) : Point d'arret 2 declenche}\par
{\f1     Bit 3 (B3) : Point d'arret 3 declenche}\par
{\f1     Bit 13 (BD) : Acces a un registre de debogage detecte}\par
{\f1     Bit 14 (BS) : Mode pas-a-pas (TF) declenche}\par
{\f1     Bit 15 (BT) : Changement de tache declenche}\par
{\f1     Le processeur ne remet pas DR6 a zero automatiquement;}\par
{\f1     le gestionnaire d'exception doit le faire manuellement.}\par
\par
{\f1   DR7 (Debug Control Register) :}\par
{\f1     Configure le comportement des 4 points d'arret :}\par
{\f1     Bits 0-7 : Activation locale (L0-L3) et globale (G0-G3)}\par
{\f1       pour chaque point d'arret (L = tache courante, G = toutes)}\par
{\f1     Bits 16-31 : Conditions et taille pour chaque point d'arret}\par
{\f1       (4 bits par point d'arret : R/Wn sur 2 bits + LENn sur 2 bits)}\par
\par
{\f1     Conditions (R/Wn) :}\par
{\f1       00 = Execution d'instruction uniquement}\par
{\f1       01 = Ecriture en memoire uniquement}\par
{\f1       10 = Acces port E/S (non supporte sur 80386)}\par
{\f1       11 = Lecture ou ecriture en memoire}\par
\par
{\f1     Taille (LENn) :}\par
{\f1       00 = 1 octet}\par
{\f1       01 = 2 octets (adresse alignee sur mot)}\par
{\f1       10 = (non defini sur 80386)}\par
{\f1       11 = 4 octets (adresse alignee sur double mot)}\par
\par
\par
\b 2.8 Registres de test \b0\par
\par
{\f1   Le 80386 possede 2 registres de test de 32 bits pour le}\par
{\f1   diagnostic du TLB (Translation Lookaside Buffer) :}\par
\par
{\f1   TR6 (Test Command Register) :}\par
{\f1     Permet d'ecrire une entree dans le TLB ou de rechercher}\par
{\f1     une correspondance. Contient l'adresse lineaire, les}\par
{\f1     attributs et la commande (lecture/ecriture).}\par
\par
{\f1   TR7 (Test Data Register) :}\par
{\f1     Contient l'adresse physique et les donnees associees a}\par
{\f1     l'operation de test du TLB. Le bit HT indique si la}\par
{\f1     recherche a trouve une correspondance.}\par
\par
{\f1   Ces registres sont principalement utilises par le BIOS et les}\par
{\f1   systemes d'exploitation pour tester le bon fonctionnement du}\par
{\f1   TLB. Ils sont rarement utilises en programmation applicative.}\par
\par
\par
\b 2.9 Resume des registres \b0\par
\par
{\f1   Categorie                  Registres            Taille  Nombre}\par
{\f1   -------------------------  -------------------  ------  ------}\par
{\f1   Registres generaux         EAX EBX ECX EDX      32 bits     4}\par
{\f1                              ESI EDI EBP ESP      32 bits     4}\par
{\f1   Registres de segment       CS DS ES FS GS SS    16 bits     6}\par
{\f1   Pointeur d'instruction     EIP                  32 bits     1}\par
{\f1   Drapeaux                   EFLAGS               32 bits     1}\par
{\f1   Registres de controle      CR0 CR1 CR2 CR3      32 bits     4}\par
{\f1   Registres de debogage      DR0-DR3 DR6 DR7      32 bits     6}\par
{\f1   Registres de test          TR6 TR7              32 bits     2}\par
{\f1   -------------------------  -------------------  ------  ------}\par
{\f1   Total                                                      28}\par
\par
\par
