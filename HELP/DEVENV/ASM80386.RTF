{\footnote # IDH_ASM80386_04}
{\footnote $ Assembleur 80386 - JEU D'INSTRUCTIONS (OPCODES)}
{\footnote K Assembleur 80386 jeu instructions opcodes;MOV LEA XCHG PUSH POP;ADD SUB MUL IMUL DIV IDIV INC DEC NEG CMP;AND OR XOR NOT TEST;SHL SHR SAR ROL ROR RCL RCR SHLD SHRD;Jcc JMP CALL RET LOOP;BSF BSR BT BTS BTR BTC;MOVSX MOVZX;STOS LODS MOVS CMPS SCAS REP;CLI STI HLT NOP}
\b\fs24 JEU D'INSTRUCTIONS (OPCODES) \b0\fs20\par
\par
\par
\b 4.1 Vue d'ensemble \b0\par
\par
{\f1   Le 80386 herite du jeu d'instructions du 8086/80286 et l'etend}\par
{\f1   avec de nouvelles instructions 32 bits. Toutes les instructions}\par
{\f1   existantes sont disponibles en version 32 bits grace aux prefixes}\par
{\f1   de taille d'operande (66h) et de taille d'adresse (67h).}\par
\par
{\f1   Le jeu d'instructions se divise en categories :}\par
{\f1     - Transfert de donnees}\par
{\f1     - Arithmetique entiere}\par
{\f1     - Logique et manipulation de bits}\par
{\f1     - Comparaison et test}\par
{\f1     - Branchements et sauts}\par
{\f1     - Operations sur les chaines}\par
{\f1     - Manipulation des drapeaux}\par
{\f1     - Entrees/sorties}\par
{\f1     - Instructions systeme et mode protege}\par
{\f1     - Conversions de type}\par
{\f1     - Instructions nouvelles du 80386}\par
\par
{\f1   Conventions de notation utilisees dans cette section :}\par
{\f1     reg    : Registre general (8, 16 ou 32 bits)}\par
{\f1     r/m    : Registre ou operande memoire}\par
{\f1     imm    : Valeur immediate (constante)}\par
{\f1     mem    : Operande memoire}\par
{\f1     seg    : Registre de segment}\par
{\f1     acc    : Accumulateur (AL, AX ou EAX)}\par
{\f1     [F]    : Drapeaux affectes}\par
\par
\par
\b 4.2 Transfert de donnees \b0\par
\par
{\f1   Ces instructions copient des donnees entre registres, memoire et}\par
{\f1   valeurs immediates sans modifier les drapeaux (sauf indication).}\par
\par
{\f1   4.2.1 Transfert general}\par
\par
{\f1   MOV  dest, src         Copier src dans dest}\par
{\f1                          Formes : reg<-reg, reg<-mem, mem<-reg,}\par
{\f1                                   reg<-imm, mem<-imm, reg<-seg,}\par
{\f1                                   seg<-r/m}\par
{\f1                          MOV ne peut pas : mem<-mem, seg<-imm}\par
\par
{\f1   XCHG reg, r/m          Echanger les contenus de deux operandes}\par
{\f1                          XCHG EAX,reg a un codage sur 1 octet (90h+r)}\par
{\f1                          XCHG avec memoire implique un verrou LOCK}\par
\par
{\f1   4.2.2 Pile}\par
\par
{\f1   PUSH src               Empiler : ESP -= taille, [ESP] <- src}\par
{\f1                          Formes : reg, mem, imm, seg}\par
{\f1                          PUSH imm est nouveau depuis le 80186}\par
\par
{\f1   POP  dest              Depiler : dest <- [ESP], ESP += taille}\par
{\f1                          Formes : reg, mem, seg (sauf CS)}\par
\par
{\f1   PUSHA                  Empiler les 8 registres generaux}\par
{\f1   PUSHAD                 (version 32 bits : EAX,ECX,EDX,EBX,}\par
{\f1                           ESP_original,EBP,ESI,EDI)}\par
\par
{\f1   POPA                   Depiler les 8 registres generaux}\par
{\f1   POPAD                  (version 32 bits, restaure dans l'ordre inverse)}\par
\par
{\f1   PUSHF                  Empiler le registre EFLAGS (16 bits : FLAGS)}\par
{\f1   PUSHFD                 Empiler le registre EFLAGS (32 bits)}\par
\par
{\f1   POPF                   Depiler dans FLAGS [F: tous]}\par
{\f1   POPFD                  Depiler dans EFLAGS [F: tous]}\par
\par
{\f1   4.2.3 Chargement d'adresse et de pointeur}\par
\par
{\f1   LEA  reg, mem          Charger l'adresse effective de mem dans reg}\par
{\f1                          (pas d'acces memoire, calcul d'adresse seul)}\par
{\f1                          Souvent utilise pour l'arithmetique :}\par
{\f1                            LEA EAX, [EBX+ECX*4+8]}\par
\par
{\f1   LDS  reg, mem          Charger un pointeur FAR 48 bits :}\par
{\f1                          reg <- [mem], DS <- [mem+4]}\par
\par
{\f1   LES  reg, mem          Idem avec ES}\par
{\f1   LFS  reg, mem          Idem avec FS (nouveau 80386)}\par
{\f1   LGS  reg, mem          Idem avec GS (nouveau 80386)}\par
{\f1   LSS  reg, mem          Idem avec SS (nouveau 80386)}\par
\par
{\f1   4.2.4 Conversion et extension}\par
\par
{\f1   CBW                    Etendre AL (signe) dans AX}\par
{\f1   CWDE                   Etendre AX (signe) dans EAX (nouveau 80386)}\par
{\f1   CWD                    Etendre AX (signe) dans DX:AX}\par
{\f1   CDQ                    Etendre EAX (signe) dans EDX:EAX (nouveau 80386)}\par
\par
{\f1   MOVZX reg, r/m         Charger avec extension zero (nouveau 80386)}\par
{\f1                          reg16 <- r/m8, reg32 <- r/m8, reg32 <- r/m16}\par
\par
{\f1   MOVSX reg, r/m         Charger avec extension de signe (nouveau 80386)}\par
{\f1                          reg16 <- r/m8, reg32 <- r/m8, reg32 <- r/m16}\par
\par
{\f1   4.2.5 Transfert conditionnel de drapeaux}\par
\par
{\f1   LAHF                   AH <- FLAGS (bits SF, ZF, AF, PF, CF)}\par
{\f1   SAHF                   FLAGS <- AH [F: SF, ZF, AF, PF, CF]}\par
\par
\par
\b 4.3 Arithmetique entiere \b0\par
\par
{\f1   4.3.1 Addition}\par
\par
{\f1   ADD  dest, src         dest <- dest + src [F: OF,SF,ZF,AF,PF,CF]}\par
{\f1   ADC  dest, src         dest <- dest + src + CF [F: OF,SF,ZF,AF,PF,CF]}\par
{\f1                          (addition avec retenue, pour l'arithmetique}\par
{\f1                           multi-precision)}\par
\par
{\f1   INC  r/m               r/m <- r/m + 1 [F: OF,SF,ZF,AF,PF]}\par
{\f1                          (ne modifie pas CF, utile dans les boucles)}\par
\par
{\f1   4.3.2 Soustraction}\par
\par
{\f1   SUB  dest, src         dest <- dest - src [F: OF,SF,ZF,AF,PF,CF]}\par
{\f1   SBB  dest, src         dest <- dest - src - CF [F: OF,SF,ZF,AF,PF,CF]}\par
{\f1                          (soustraction avec emprunt)}\par
\par
{\f1   DEC  r/m               r/m <- r/m - 1 [F: OF,SF,ZF,AF,PF]}\par
{\f1                          (ne modifie pas CF)}\par
\par
{\f1   NEG  r/m               r/m <- 0 - r/m [F: OF,SF,ZF,AF,PF,CF]}\par
{\f1                          (complement a deux, negation)}\par
\par
{\f1   4.3.3 Multiplication}\par
\par
{\f1   MUL  r/m               Multiplication non signee}\par
{\f1                          8 bits  : AX <- AL * r/m8}\par
{\f1                          16 bits : DX:AX <- AX * r/m16}\par
{\f1                          32 bits : EDX:EAX <- EAX * r/m32}\par
{\f1                          [F: OF,CF (definis si partie haute non nulle)]}\par
\par
{\f1   IMUL r/m               Multiplication signee (meme format que MUL)}\par
\par
{\f1   IMUL reg, r/m          reg <- reg * r/m (forme a 2 operandes)}\par
{\f1                          (nouveau 80386, resultat tronque a la taille}\par
{\f1                           du registre destination)}\par
\par
{\f1   IMUL reg, r/m, imm     reg <- r/m * imm (forme a 3 operandes)}\par
{\f1                          (nouveau 80186)}\par
\par
{\f1   4.3.4 Division}\par
\par
{\f1   DIV  r/m               Division non signee}\par
{\f1                          8 bits  : AL <- AX / r/m8, AH <- AX MOD r/m8}\par
{\f1                          16 bits : AX <- DX:AX / r/m16, DX <- reste}\par
{\f1                          32 bits : EAX <- EDX:EAX / r/m32, EDX <- reste}\par
{\f1                          Exception #DE si diviseur = 0 ou quotient}\par
{\f1                          depasse la taille du registre destination}\par
\par
{\f1   IDIV r/m               Division signee (meme format que DIV)}\par
\par
{\f1   4.3.5 Ajustement BCD (decimal code binaire)}\par
\par
{\f1   DAA                    Ajustement decimal apres addition (AL)}\par
{\f1   DAS                    Ajustement decimal apres soustraction (AL)}\par
{\f1   AAA                    Ajustement ASCII apres addition (AX)}\par
{\f1   AAS                    Ajustement ASCII apres soustraction (AX)}\par
{\f1   AAM                    Ajustement ASCII apres multiplication (AX)}\par
{\f1   AAD                    Ajustement ASCII avant division (AX)}\par
\par
{\f1   Note : Ces instructions operent uniquement sur AL/AX et sont}\par
{\f1   rarement utilisees en programmation 32 bits moderne.}\par
\par
\par
\b 4.4 Logique et manipulation de bits \b0\par
\par
{\f1   4.4.1 Operations logiques}\par
\par
{\f1   AND  dest, src         dest <- dest AND src [F: OF=0,SF,ZF,PF,CF=0]}\par
{\f1   OR   dest, src         dest <- dest OR src  [F: OF=0,SF,ZF,PF,CF=0]}\par
{\f1   XOR  dest, src         dest <- dest XOR src [F: OF=0,SF,ZF,PF,CF=0]}\par
{\f1   NOT  r/m               r/m <- NOT r/m (complement a un) [F: aucun]}\par
\par
{\f1   Idiomes courants :}\par
{\f1     XOR EAX, EAX         Mettre EAX a zero (2 octets, plus rapide}\par
{\f1                           que MOV EAX, 0 qui fait 5 octets)}\par
{\f1     OR  EAX, EAX         Tester si EAX est zero (positionne ZF)}\par
{\f1     AND EAX, 0FFh        Masquer les bits de poids fort}\par
\par
{\f1   4.4.2 Decalages}\par
\par
{\f1   SHL  r/m, count        Decalage logique a gauche [F: CF,OF,SF,ZF,PF]}\par
{\f1   SHR  r/m, count        Decalage logique a droite [F: CF,OF,SF,ZF,PF]}\par
{\f1   SAR  r/m, count        Decalage arithmetique a droite (preserve signe)}\par
{\f1   SAL  r/m, count        Synonyme de SHL}\par
\par
{\f1   Le compteur (count) peut etre :}\par
{\f1     1    : Decalage d'une position (codage specifique)}\par
{\f1     imm8 : Constante immediate (masquee a 5 bits, max 31)}\par
{\f1     CL   : Valeur du registre CL (masquee a 5 bits)}\par
\par
{\f1   Note : SHL de n positions equivaut a une multiplication par 2^n.}\par
{\f1   SHR de n positions equivaut a une division non signee par 2^n.}\par
{\f1   SAR de n positions equivaut a une division signee par 2^n.}\par
\par
{\f1   4.4.3 Rotations}\par
\par
{\f1   ROL  r/m, count        Rotation a gauche [F: CF,OF]}\par
{\f1   ROR  r/m, count        Rotation a droite [F: CF,OF]}\par
{\f1   RCL  r/m, count        Rotation a gauche a travers CF [F: CF,OF]}\par
{\f1   RCR  r/m, count        Rotation a droite a travers CF [F: CF,OF]}\par
\par
{\f1   Les rotations sont circulaires : les bits qui sortent d'un cote}\par
{\f1   rentrent de l'autre. RCL/RCR incluent CF dans la rotation,}\par
{\f1   formant une chaine de (n+1) bits.}\par
\par
{\f1   4.4.4 Decalage double (nouveau 80386)}\par
\par
{\f1   SHLD dest, src, count  Decalage a gauche double precision}\par
{\f1                          Les bits sortants de src remplissent dest}\par
{\f1                          [F: CF,SF,ZF,PF]}\par
\par
{\f1   SHRD dest, src, count  Decalage a droite double precision}\par
{\f1                          Les bits sortants de src remplissent dest}\par
{\f1                          [F: CF,SF,ZF,PF]}\par
\par
{\f1   Ces instructions sont tres utiles pour les operations sur des}\par
{\f1   entiers de plus de 32 bits et pour les operations sur les bitmaps.}\par
\par
{\f1   4.4.5 Test et recherche de bits (nouveau 80386)}\par
\par
{\f1   BT   r/m, reg/imm      Test du bit : CF <- bit selectionne}\par
{\f1   BTS  r/m, reg/imm      Test et mise a 1 : CF <- bit, bit <- 1}\par
{\f1   BTR  r/m, reg/imm      Test et mise a 0 : CF <- bit, bit <- 0}\par
{\f1   BTC  r/m, reg/imm      Test et complement : CF <- bit, bit <- NOT bit}\par
\par
{\f1   BSF  reg, r/m          Recherche du premier bit a 1 (depuis bit 0)}\par
{\f1                          reg <- index du bit, ZF=1 si aucun bit a 1}\par
\par
{\f1   BSR  reg, r/m          Recherche du dernier bit a 1 (depuis bit MSB)}\par
{\f1                          reg <- index du bit, ZF=1 si aucun bit a 1}\par
\par
\par
\b 4.5 Comparaison et test \b0\par
\par
{\f1   CMP  dest, src         Calcule dest - src, positionne les drapeaux}\par
{\f1                          mais ne stocke pas le resultat}\par
{\f1                          [F: OF,SF,ZF,AF,PF,CF]}\par
\par
{\f1   TEST dest, src         Calcule dest AND src, positionne les drapeaux}\par
{\f1                          mais ne stocke pas le resultat}\par
{\f1                          [F: OF=0,SF,ZF,PF,CF=0]}\par
\par
{\f1   Utilisation typique :}\par
{\f1     CMP EAX, 10          Comparer EAX avec 10}\par
{\f1     JE  _egal            Sauter si egal (ZF=1)}\par
\par
{\f1     TEST EAX, EAX        Tester si EAX est zero}\par
{\f1     JZ  _est_zero        Sauter si zero (ZF=1)}\par
\par
{\f1     TEST AL, 01h         Tester si le bit 0 est a 1}\par
{\f1     JNZ _impair          Sauter si non-zero (bit 0 = 1)}\par
\par
\par
\b 4.6 Branchements et sauts \b0\par
\par
{\f1   4.6.1 Saut inconditionnel}\par
\par
{\f1   JMP  cible             Saut inconditionnel}\par
{\f1                          Court (rel8), proche (rel32), ou lointain}\par
{\f1                          (seg:offset pour inter-segment)}\par
{\f1                          Peut etre direct (label) ou indirect ([reg])}\par
\par
{\f1   4.6.2 Sauts conditionnels}\par
\par
{\f1   Les sauts conditionnels testent les drapeaux positionnes par}\par
{\f1   CMP, TEST, ou toute instruction arithmetique/logique precedente.}\par
\par
{\f1   Sur le 80386, tous les sauts conditionnels acceptent les}\par
{\f1   deplacements rel8 (court) et rel32 (proche), alors que le 8086}\par
{\f1   ne supportait que rel8.}\par
\par
{\f1   Condition             Mnemoniques         Drapeaux testes}\par
{\f1   --------------------  ------------------  ----------------}\par
{\f1   Egal / zero           JE   / JZ           ZF = 1}\par
{\f1   Non egal / non zero   JNE  / JNZ          ZF = 0}\par
{\f1   Retenue / inf. (ns)   JC   / JB  / JNAE   CF = 1}\par
{\f1   Pas de retenue         JNC  / JNB / JAE    CF = 0}\par
{\f1   Signe (negatif)       JS                   SF = 1}\par
{\f1   Pas de signe          JNS                  SF = 0}\par
{\f1   Debordement           JO                   OF = 1}\par
{\f1   Pas de debordement    JNO                  OF = 0}\par
{\f1   Parite paire          JP   / JPE           PF = 1}\par
{\f1   Parite impaire        JNP  / JPO           PF = 0}\par
\par
{\f1   Comparaisons non signees (unsigned) :}\par
{\f1   Inferieur             JB   / JNAE / JC     CF = 1}\par
{\f1   Inf. ou egal          JBE  / JNA           CF = 1 ou ZF = 1}\par
{\f1   Superieur             JA   / JNBE          CF = 0 et ZF = 0}\par
{\f1   Sup. ou egal          JAE  / JNB / JNC     CF = 0}\par
\par
{\f1   Comparaisons signees (signed) :}\par
{\f1   Inferieur             JL   / JNGE          SF <> OF}\par
{\f1   Inf. ou egal          JLE  / JNG           SF <> OF ou ZF = 1}\par
{\f1   Superieur             JG   / JNLE          SF = OF et ZF = 0}\par
{\f1   Sup. ou egal          JGE  / JNL           SF = OF}\par
\par
{\f1   4.6.3 Boucles}\par
\par
{\f1   LOOP  cible            ECX <- ECX - 1, sauter si ECX <> 0}\par
{\f1   LOOPE cible            ECX <- ECX - 1, sauter si ECX <> 0 et ZF = 1}\par
{\f1   LOOPNE cible           ECX <- ECX - 1, sauter si ECX <> 0 et ZF = 0}\par
{\f1   JECXZ cible            Sauter si ECX = 0 (sans modifier ECX)}\par
\par
{\f1   Note : LOOP et JECXZ n'acceptent que des deplacements rel8.}\par
{\f1   En mode 16 bits, LOOP utilise CX au lieu de ECX.}\par
\par
{\f1   4.6.4 Appels de sous-programmes}\par
\par
{\f1   CALL cible             Empiler EIP, sauter a cible}\par
{\f1                          Proche (rel32 ou r/m32) : PUSH EIP, JMP cible}\par
{\f1                          Lointain (seg:offset) : PUSH CS, PUSH EIP,}\par
{\f1                            puis saut inter-segment}\par
\par
{\f1   RET                    Depiler EIP et reprendre l'execution}\par
{\f1   RET  imm16             Depiler EIP, puis ESP <- ESP + imm16}\par
{\f1                          (pour nettoyer les parametres de la pile,}\par
{\f1                           convention stdcall)}\par
\par
{\f1   ENTER imm16, level     Creer un cadre de pile :}\par
{\f1                          PUSH EBP, EBP <- ESP, ESP <- ESP - imm16}\par
{\f1                          (level > 0 pour les cadres imbriques)}\par
\par
{\f1   LEAVE                  Detruire un cadre de pile :}\par
{\f1                          ESP <- EBP, POP EBP}\par
{\f1                          (equivalent a MOV ESP,EBP / POP EBP)}\par
\par
{\f1   4.6.5 Interruptions logicielles}\par
\par
{\f1   INT  imm8              Appel d'interruption logicielle}\par
{\f1                          PUSH EFLAGS, PUSH CS, PUSH EIP,}\par
{\f1                          IF <- 0, TF <- 0, saut via IDT[imm8]}\par
\par
{\f1   INTO                   INT 4 si OF = 1 (debordement)}\par
\par
{\f1   IRET                   Retour d'interruption}\par
{\f1   IRETD                  POP EIP, POP CS, POP EFLAGS}\par
\par
{\f1   4.6.6 Positionnement conditionnel d'octets (nouveau 80386)}\par
\par
{\f1   SETcc r/m8             Mettre r/m8 a 1 si condition vraie, 0 sinon}\par
\par
{\f1   Les suffixes cc sont les memes que pour les sauts Jcc :}\par
{\f1     SETE/SETZ, SETNE/SETNZ, SETB/SETC, SETNB/SETNC,}\par
{\f1     SETS, SETNS, SETO, SETNO, SETP, SETNP,}\par
{\f1     SETL, SETLE, SETG, SETGE, SETA, SETBE, SETAE, SETB}\par
\par
{\f1   Utilisation typique :}\par
{\f1     CMP  EAX, EBX}\par
{\f1     SETL AL               ; AL = 1 si EAX < EBX (signe), sinon 0}\par
{\f1     MOVZX EAX, AL          ; etendre a 32 bits}\par
\par
\par
\b 4.7 Operations sur les chaines \b0\par
\par
{\f1   Les instructions de chaines operent sur des blocs de memoire.}\par
{\f1   Elles utilisent :}\par
{\f1     - ESI (source) avec DS par defaut}\par
{\f1     - EDI (destination) avec ES obligatoire}\par
{\f1     - ECX comme compteur (avec REP)}\par
{\f1     - DF (Direction Flag) : 0 = incrementer, 1 = decrementer}\par
\par
{\f1   4.7.1 Instructions de base}\par
\par
{\f1   MOVSB / MOVSW / MOVSD  Copier [ESI] vers ES:[EDI], avancer les deux}\par
{\f1                          (B=octet, W=mot, D=double mot)}\par
\par
{\f1   CMPSB / CMPSW / CMPSD  Comparer [ESI] avec ES:[EDI], avancer}\par
{\f1                          [F: OF,SF,ZF,AF,PF,CF]}\par
\par
{\f1   SCASB / SCASW / SCASD  Comparer AL/AX/EAX avec ES:[EDI], avancer}\par
{\f1                          [F: OF,SF,ZF,AF,PF,CF]}\par
\par
{\f1   LODSB / LODSW / LODSD  Charger [ESI] dans AL/AX/EAX, avancer ESI}\par
\par
{\f1   STOSB / STOSW / STOSD  Stocker AL/AX/EAX dans ES:[EDI], avancer EDI}\par
\par
{\f1   INSB / INSW / INSD     Lire port DX dans ES:[EDI], avancer EDI}\par
{\f1   OUTSB / OUTSW / OUTSD  Ecrire [ESI] vers port DX, avancer ESI}\par
\par
{\f1   4.7.2 Prefixes de repetition}\par
\par
{\f1   REP                    Repeter ECX fois (pour MOVS, STOS, INS, OUTS)}\par
{\f1   REPE / REPZ            Repeter tant que ECX <> 0 et ZF = 1}\par
{\f1                          (pour CMPS, SCAS)}\par
{\f1   REPNE / REPNZ          Repeter tant que ECX <> 0 et ZF = 0}\par
{\f1                          (pour CMPS, SCAS)}\par
\par
{\f1   Exemples :}\par
{\f1     ; Copier 100 octets de ESI vers EDI}\par
{\f1     MOV  ECX, 100}\par
{\f1     CLD                    ; direction = incrementer}\par
{\f1     REP  MOVSB}\par
\par
{\f1     ; Remplir 256 octets a zero}\par
{\f1     MOV  ECX, 64           ; 256 / 4 = 64 double mots}\par
{\f1     XOR  EAX, EAX}\par
{\f1     CLD}\par
{\f1     REP  STOSD}\par
\par
{\f1     ; Chercher un octet nul dans une chaine (strlen)}\par
{\f1     MOV  ECX, -1           ; compter le maximum}\par
{\f1     XOR  AL, AL            ; chercher 0}\par
{\f1     CLD}\par
{\f1     REPNE SCASB}\par
{\f1     NOT  ECX}\par
{\f1     DEC  ECX               ; ECX = longueur de la chaine}\par
\par
\par
\b 4.8 Manipulation des drapeaux \b0\par
\par
{\f1   CLC                    CF <- 0 (Clear Carry)}\par
{\f1   STC                    CF <- 1 (Set Carry)}\par
{\f1   CMC                    CF <- NOT CF (Complement Carry)}\par
\par
{\f1   CLD                    DF <- 0 (direction = incrementer)}\par
{\f1   STD                    DF <- 1 (direction = decrementer)}\par
\par
{\f1   CLI                    IF <- 0 (desactiver les interruptions)}\par
{\f1   STI                    IF <- 1 (activer les interruptions)}\par
\par
{\f1   Note : CLI/STI sont des instructions privilegiees en mode}\par
{\f1   protege et ne peuvent etre executees qu'au niveau de privilege}\par
{\f1   IOPL ou superieur.}\par
\par
\par
\b 4.9 Entrees/sorties \b0\par
\par
{\f1   IN   acc, port         Lire un port d'E/S dans l'accumulateur}\par
{\f1                          IN AL, imm8   (port 0-255, codage compact)}\par
{\f1                          IN AL, DX     (port 0-65535, via DX)}\par
{\f1                          IN AX, DX     (lecture 16 bits)}\par
{\f1                          IN EAX, DX    (lecture 32 bits, nouveau 80386)}\par
\par
{\f1   OUT  port, acc         Ecrire l'accumulateur vers un port d'E/S}\par
{\f1                          OUT imm8, AL  (port 0-255)}\par
{\f1                          OUT DX, AL    (port 0-65535, via DX)}\par
{\f1                          OUT DX, AX    (ecriture 16 bits)}\par
{\f1                          OUT DX, EAX   (ecriture 32 bits, nouveau 80386)}\par
\par
{\f1   Note : Les instructions IN/OUT sont privilegiees en mode protege.}\par
{\f1   L'acces est controle par le bitmap d'E/S dans le TSS et le}\par
{\f1   niveau IOPL dans EFLAGS.}\par
\par
\par
\b 4.10 Instructions systeme et mode protege \b0\par
\par
{\f1   4.10.1 Registres de controle et descripteurs}\par
\par
{\f1   LGDT mem               Charger le registre GDTR (limite + base)}\par
{\f1   SGDT mem               Stocker GDTR en memoire}\par
{\f1   LIDT mem               Charger le registre IDTR (limite + base)}\par
{\f1   SIDT mem               Stocker IDTR en memoire}\par
{\f1   LLDT r/m16             Charger le registre LDTR (selecteur)}\par
{\f1   SLDT r/m16             Stocker LDTR}\par
{\f1   LTR  r/m16             Charger le registre TR (Task Register)}\par
{\f1   STR  r/m16             Stocker TR}\par
{\f1   LMSW r/m16             Charger le mot d'etat machine (bits bas de CR0)}\par
{\f1   SMSW r/m16             Stocker le mot d'etat machine}\par
\par
{\f1   4.10.2 Registres de controle (nouveau 80386)}\par
\par
{\f1   MOV  CRn, reg32        Charger un registre de controle (CR0-CR3)}\par
{\f1   MOV  reg32, CRn        Lire un registre de controle}\par
{\f1   MOV  DRn, reg32        Charger un registre de debug (DR0-DR7)}\par
{\f1   MOV  reg32, DRn        Lire un registre de debug}\par
{\f1   MOV  TRn, reg32        Charger un registre de test (TR6-TR7)}\par
{\f1   MOV  reg32, TRn        Lire un registre de test}\par
\par
{\f1   4.10.3 Verification et protection}\par
\par
{\f1   ARPL r/m16, reg16      Ajuster le champ RPL d'un selecteur}\par
{\f1   LAR  reg, r/m16        Charger les droits d'acces d'un descripteur}\par
{\f1   LSL  reg, r/m16        Charger la limite d'un segment}\par
{\f1   VERR r/m16             Verifier qu'un segment est lisible (ZF=1 si oui)}\par
{\f1   VERW r/m16             Verifier qu'un segment est inscriptible}\par
\par
{\f1   4.10.4 Commutation de taches et divers}\par
\par
{\f1   CLTS                   Effacer le drapeau TS dans CR0}\par
{\f1                          (utilise apres une commutation de tache}\par
{\f1                           pour eviter les exceptions #NM)}\par
\par
{\f1   HLT                    Arreter le processeur jusqu'a une interruption}\par
{\f1                          ou un signal RESET}\par
\par
{\f1   WAIT / FWAIT           Attendre que le coprocesseur ait termine}\par
{\f1   NOP                    Pas d'operation (XCHG EAX, EAX, codage 90h)}\par
{\f1   LOCK                   Prefixe de verrouillage du bus (pour les}\par
{\f1                          operations atomiques en multiprocesseur)}\par
\par
\par
\b 4.11 Instructions nouvelles du 80386 \b0\par
\par
{\f1   Le 80386 ajoute les instructions suivantes par rapport au 80286 :}\par
\par
{\f1   Extensions 32 bits de toutes les instructions existantes :}\par
{\f1     - Tous les registres peuvent etre utilises en 32 bits}\par
{\f1     - Les deplacements sont de 32 bits en mode protege}\par
{\f1     - Les sauts conditionnels acceptent rel32}\par
\par
{\f1   Nouvelles instructions :}\par
\par
{\f1   Instruction            Description}\par
{\f1   ---------------------  ------------------------------------------}\par
{\f1   MOVZX reg, r/m         Extension zero (8->16, 8->32, 16->32)}\par
{\f1   MOVSX reg, r/m         Extension de signe (8->16, 8->32, 16->32)}\par
{\f1   CWDE                   Etendre AX signe dans EAX}\par
{\f1   CDQ                    Etendre EAX signe dans EDX:EAX}\par
{\f1   PUSHAD / POPAD         Empiler/depiler tous les registres 32 bits}\par
{\f1   PUSHFD / POPFD         Empiler/depiler EFLAGS 32 bits}\par
{\f1   SHLD  dest, src, cnt   Decalage double a gauche}\par
{\f1   SHRD  dest, src, cnt   Decalage double a droite}\par
{\f1   BT    r/m, reg/imm     Test de bit}\par
{\f1   BTS   r/m, reg/imm     Test et mise a 1}\par
{\f1   BTR   r/m, reg/imm     Test et mise a 0}\par
{\f1   BTC   r/m, reg/imm     Test et complement}\par
{\f1   BSF   reg, r/m         Recherche de bit vers l'avant}\par
{\f1   BSR   reg, r/m         Recherche de bit vers l'arriere}\par
{\f1   SETcc r/m8             Positionnement conditionnel d'octet}\par
{\f1   JECXZ cible            Saut si ECX = 0}\par
{\f1   LFS   reg, mem         Charger pointeur avec FS}\par
{\f1   LGS   reg, mem         Charger pointeur avec GS}\par
{\f1   LSS   reg, mem         Charger pointeur avec SS}\par
{\f1   MOV   CRn, reg32       Acces aux registres de controle}\par
{\f1   MOV   DRn, reg32       Acces aux registres de debug}\par
{\f1   MOV   TRn, reg32       Acces aux registres de test}\par
{\f1   MOVSD                  MOVS en 32 bits (double mot)}\par
{\f1   CMPSD                  CMPS en 32 bits}\par
{\f1   SCASD                  SCAS en 32 bits}\par
{\f1   LODSD                  LODS en 32 bits}\par
{\f1   STOSD                  STOS en 32 bits}\par
{\f1   INSD                   INS en 32 bits}\par
{\f1   OUTSD                  OUTS en 32 bits}\par
\par
\par
\b 4.12 Resume et tableau recapitulatif \b0\par
\par
{\f1   Nombre approximatif d'instructions par categorie :}\par
\par
{\f1   Categorie                          Nombre}\par
{\f1   ---------------------------------  ------}\par
{\f1   Transfert de donnees                  25}\par
{\f1   Arithmetique entiere                  20}\par
{\f1   Logique et bits                       18}\par
{\f1   Comparaison et test                    2}\par
{\f1   Sauts conditionnels                   30+}\par
{\f1   Boucles et branchements               8}\par
{\f1   Chaines                              12}\par
{\f1   Drapeaux                              7}\par
{\f1   Entrees/sorties                       4}\par
{\f1   Systeme et mode protege              20+}\par
{\f1   Positionnement conditionnel          30+}\par
{\f1   Divers (NOP, HLT, LOCK, etc.)        5}\par
{\f1   ---------------------------------  ------}\par
{\f1   Total (hors variantes de taille)    ~180}\par
\par
{\f1   Instructions les plus frequemment utilisees en pratique :}\par
\par
{\f1   Instruction   Usage typique}\par
{\f1   -----------   ------------------------------------------}\par
{\f1   MOV           Transfert de donnees (40-50% des instructions)}\par
{\f1   PUSH/POP      Passage de parametres, sauvegarde de registres}\par
{\f1   ADD/SUB       Arithmetique de base}\par
{\f1   CMP/TEST      Preparation des sauts conditionnels}\par
{\f1   JMP/Jcc       Controle de flux}\par
{\f1   CALL/RET      Appels de fonctions}\par
{\f1   LEA           Calcul d'adresses et arithmetique rapide}\par
{\f1   XOR           Mise a zero de registres}\par
{\f1   AND/OR        Masquage et combinaison de bits}\par
{\f1   SHL/SHR       Multiplications/divisions par puissances de 2}\par
{\f1   INC/DEC       Compteurs de boucles}\par
{\f1   MOVZX/MOVSX   Conversions de taille (nouveau 80386)}\par
{\f1   IMUL          Multiplication avec resultat dans un registre}\par
\par
