{\footnote # IDH_RUST_10}
{\footnote $ Rust - Macros}
{\footnote K Rust macros;macro_rules!;println! print! format! eprintln!;vec!;assert! assert_eq!;panic! todo! unimplemented!;dbg!;include_str!;cfg! env!;procedurales;derive;attribute macros}
\b\fs24 Macros \b0\fs20\par
\par
10.1 Macros declaratives (macro_rules!)\par
\par
{\f1   macro_rules! carre \{}\par
{\f1       ($x:expr) => \{ $x * $x \};}\par
{\f1   \}}\par
{\f1   let c = carre!(5);                 // 25}\par
\par
10.2 Macros standards courantes\par
\par
{\f1   println!, print!, eprintln!, eprint!}\par
{\f1   format!                            // formate dans une String}\par
{\f1   write!, writeln!                   // ecrit dans un Writer}\par
{\f1   vec![1, 2, 3]                      // cree un Vec<i32>}\par
{\f1   assert!, assert_eq!, assert_ne!}\par
