\par
{\f1   enum Forme \{ Cercle(f64), Rect(f64, f64) \}}\par
\par
{\f1   fn aire(f: Forme) -> f64 \{}\par
{\f1       match f \{}\par
{\f1           Forme::Cercle(r) => std::f64::consts::PI * r * r,}\par
{\f1           Forme::Rect(l, h) => l * h,}\par
{\f1       \}}\par
{\f1   \}}\par
