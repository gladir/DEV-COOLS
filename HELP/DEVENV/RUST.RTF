{\footnote # IDH_RUST_07}
{\footnote $ Rust - Instructions et expressions}
{\footnote K Rust instructions expressions;if let;while let;loop;for;match;if let-else;break continue label;return;expression bloc;question mark}
\b\fs24 Instructions et expressions \b0\fs20\par
\par
Rust est principalement une langage a expressions : la plupart des constructions\par
retournent une valeur. Le bloc \{ ... \} evalue a son expression finale (sans ;).\par
\par
if / else (expression) :\par
{\f1   let max = if a > b \{ a \} else \{ b \};}\par
\par
if let :\par
{\f1   if let Some(v) = option \{ println!("\{\}", v); \}}\par
\par
while :\par
{\f1   while cond \{ ... \}}\par
\par
while let :\par
{\f1   while let Some(top) = pile.pop() \{ ... \}}\par
\par
loop (infinie, expression) :\par
{\f1   let r = loop \{}\par
{\f1       compteur += 1;}\par
{\f1       if compteur == 10 \{ break compteur * 2; \}}\par
{\f1   \};}\par
\par
for :\par
{\f1   for i in 0..10 \{ ... \}}\par
{\f1   for elem in &vec \{ ... \}}\par
{\f1   for (i, v) in vec.iter().enumerate() \{ ... \}}\par
\par
break / continue avec etiquettes :\par
{\f1   'externe: for i in 0..n \{}\par
{\f1       for j in 0..m \{}\par
{\f1           if cond \{ break 'externe; \}}\par
{\f1       \}}\par
{\f1   \}}\par
\par
match (pattern matching exhaustif) :\par
{\f1   match x \{}\par
{\f1       0 => println!("zero"),}\par
{\f1       1 | 2 => println!("un ou deux"),}\par
{\f1       3..=9 => println!("petit"),}\par
{\f1       n if n < 0 => println!("negatif"),}\par
{\f1       _ => println!("autre"),}\par
{\f1   \}}\par
\par
{\f1   let r = match option \{}\par
{\f1       Some(v) => v * 2,}\par
{\f1       None => 0,}\par
{\f1   \};}\par
\par
let-else (1.65+) :\par
{\f1   let Some(v) = option else \{ return; \};}\par
\par
Question mark (?) :\par
{\f1   fn lire() -> Result<String, std::io::Error> \{}\par
{\f1       let mut s = String::new();}\par
{\f1       std::fs::File::open("a.txt")?.read_to_string(&mut s)?;}\par
{\f1       Ok(s)}\par
{\f1   \}}\par
\par
\par
\par
