18.6 HashMap mots frequents\par
\par
{\f1   use std::collections::HashMap;}\par
{\f1   let texte = "le chat le chien le chat";}\par
{\f1   let mut freq = HashMap::new();}\par
{\f1   for mot in texte.split_whitespace() \{}\par
{\f1       *freq.entry(mot).or_insert(0) += 1;}\par
{\f1   \}}\par
{\f1   println!("\{:?\}", freq);}\par
\par
