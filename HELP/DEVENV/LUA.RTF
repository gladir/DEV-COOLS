{\footnote # IDH_LUA_07}
{\footnote $ Lua - FONCTIONS}
{\footnote K Lua fonctions;function;closure;varargs;multiple return}
\b\fs24 FONCTIONS \b0\fs20\par
\par
{\f1    7.1 Declaration}\par
{\f1        function nom(params)       -- fonction globale}\par
{\f1          stmts}\par
{\f1        end}\par
\par
{\f1        local function nom(params) -- fonction locale}\par
{\f1          stmts}\par
{\f1        end}\par
\par
{\f1    7.2 Fonction anonyme}\par
{\f1        function(params) stmts end}\par
{\f1        Expression evaluant a une valeur de type function.}\par
\par
{\f1    7.3 Parametres}\par
{\f1        Parametres nommes : function f(a, b, c)}\par
{\f1        Parametres excedentaires ignores ; manquants valent nil.}\par
{\f1        Varargs : function f(a, ...) -- ... collecte les args restants}\par
{\f1          select('#', ...) : nombre de varargs}\par
{\f1          select(n, ...) : n-ieme vararg}\par
\par
{\f1    7.4 Valeur de retour}\par
{\f1        return expr1, expr2, ...}\par
{\f1        Retour multiple (max 8 valeurs par defaut).}\par
{\f1        return sans valeur retourne nil.}\par
\par
{\f1    7.5 Appel de fonction}\par
{\f1        nom(args)          -- appel direct}\par
{\f1        expr(args)         -- appel indirect (pointeur de fonction)}\par
{\f1        obj:methode(args)  -- sucre pour obj.methode(obj, args)}\par
\par
{\f1    7.6 Appel terminal (tail call)}\par
{\f1        return f(args) : optimise en JMP (pas de nouveau cadre de pile).}\par
\par
{\f1    7.7 Convention d appel}\par
{\f1        cdecl 16 bits : arguments empiles de droite a gauche.}\par
{\f1        Prologue : PUSH BP / MOV BP,SP / SUB SP, taille_locales}\par
{\f1        Epilogue : MOV SP,BP / POP BP / RET}\par
{\f1        L appelant nettoie la pile apres le retour.}\par
\par
\par
