{\footnote # IDH_LUA_05}
{\footnote $ Lua - OPERATEURS}
{\footnote K Lua operateurs;arithmetiques;comparaison;logiques;concatenation}
\b\fs24 OPERATEURS \b0\fs20\par
\par
{\f1    5.1 Operateurs arithmetiques}\par
{\f1        +   addition}\par
{\f1        -   soustraction (binaire) ou negation (unaire)}\par
{\f1        *   multiplication}\par
{\f1        /   division entiere (quotient)}\par
{\f1        //  division entiere (quotient, arrondi vers -infini)}\par
{\f1        %   modulo (reste de la division)}\par
{\f1        ^   puissance (associatif a droite)}\par
\par
{\f1    5.2 Operateurs de comparaison}\par
{\f1        ==  egalite}\par
{\f1        ~=  difference}\par
{\f1        <   inferieur strict}\par
{\f1        >   superieur strict}\par
{\f1        <=  inferieur ou egal}\par
{\f1        >=  superieur ou egal}\par
{\f1        Comparaison de chaines : lexicographique via STRCMP.}\par
\par
{\f1    5.3 Operateurs logiques}\par
{\f1        and   ET logique (court-circuit, retourne une valeur)}\par
{\f1        or    OU logique (court-circuit, retourne une valeur)}\par
{\f1        not   negation logique (retourne true ou false)}\par
{\f1        Court-circuit : ?? and ?? retourne le premier operande si faux,}\par
{\f1        sinon le second. ?? or ?? retourne le premier si vrai, sinon le}\par
{\f1        second.}\par
\par
{\f1    5.4 Operateur de concatenation}\par
{\f1        ..  concatenation de chaines (cree une nouvelle chaine)}\par
\par
{\f1    5.5 Operateur de longueur}\par
{\f1        #   longueur d une chaine (nombre d octets) ou d une table}\par
{\f1            (nombre d elements dans la partie tableau)}\par
\par
{\f1    5.6 Precedence des operateurs (du plus faible au plus fort)}\par
{\f1          1. or}\par
{\f1          2. and}\par
{\f1          3. < > <= >= ~= ==}\par
{\f1          4. | (bitwise or, stub)}\par
{\f1          5. ~ (bitwise xor, stub)}\par
{\f1          6. & (bitwise and, stub)}\par
{\f1          7. << >> (decalages, stub)}\par
{\f1          8. .. (concatenation, associatif a droite)}\par
{\f1          9. + -}\par
{\f1         10. * / // %}\par
{\f1         11. not  #  - (unaires)}\par
{\f1         12. ^ (puissance, associatif a droite)}\par
\par
\par
