{\footnote # IDH_LUA_13}
{\footnote $ Lua - CIBLE DE COMPILATION}
{\footnote K Lua cible compilation;8086;DOS;assembleur;backend}
\b\fs24 CIBLE DE COMPILATION \b0\fs20\par
\par
{\f1     13.1 Architecture}\par
{\f1          Processeur Intel 8086 en mode reel 16 bits.}\par
{\f1          Modele memoire : SMALL (.MODEL SMALL).}\par
{\f1          Systeme d exploitation : MS-DOS.}\par
{\f1          Appels systeme : INT 21h.}\par
\par
{\f1     13.2 Format de sortie}\par
{\f1          Assembleur compatible MASM (.ASM).}\par
{\f1          Segments : _TEXT (code) et _DATA (donnees).}\par
{\f1          Point d entree : _LUAF_main.}\par
{\f1          Pile : .STACK directive.}\par
\par
{\f1     13.3 Conventions de nommage ASM}\par
{\f1          _LUAV_   : variable globale}\par
{\f1          _LUAF_   : fonction}\par
{\f1          _LUAK_   : constante chaine litterale}\par
{\f1          _LUART_  : routine runtime}\par
{\f1          _LUAL_   : label de saut interne}\par
{\f1          _LUAT_   : table donnees}\par
{\f1          _LUAU_   : upvalue}\par
{\f1          _LUAX_   : handler d erreur}\par
{\f1          _LUAC_   : coroutines}\par

\par
