{\footnote # IDH_LUA_08}
{\footnote $ Lua - TABLES}
{\footnote K Lua tables;array;dictionary;constructor}
\b\fs24 TABLES \b0\fs20\par
\par
{\f1    8.1 Constructeurs}\par
{\f1        \{\}                     -- table vide}\par
{\f1        \{10, 20, 30\}           -- partie tableau (indices 1, 2, 3)}\par
{\f1        \{x = 1, y = 2\}        -- partie hash (cles chaines)}\par
{\f1        \{10, x = 1, [e] = v\}  -- mixte}\par
\par
{\f1    8.2 Acces}\par
{\f1        t[i]       -- acces par indice (base 1)}\par
{\f1        t.champ    -- sucre pour t["champ"]}\par
\par
{\f1    8.3 Affectation}\par
{\f1        t[k] = v   -- affecte la valeur v a la cle k}\par
{\f1        t.champ = v}\par
\par
{\f1    8.4 Longueur}\par
{\f1        #t : nombre d elements dans la partie tableau.}\par
\par
{\f1    8.5 Fonctions table}\par
{\f1        table.insert(t, v)       -- insere v a la fin}\par
{\f1        table.remove(t, pos)     -- supprime l element a la position}\par
{\f1        table.concat(t, sep)     -- joint les elements en chaine}\par
{\f1        table.sort(t [, comp])   -- tri a bulles in-place}\par
{\f1        table.unpack(t)          -- retour multiple des elements}\par
\par
\par
