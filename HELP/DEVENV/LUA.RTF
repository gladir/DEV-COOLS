{\footnote # IDH_LUA_12}
{\footnote $ Lua - LIMITES D IMPLEMENTATION LUA86}
{\footnote K Lua limites;implementation;LUA86;sous-ensemble}
\b\fs24 LIMITES D IMPLEMENTATION LUA86 \b0\fs20\par
\par
{\f1     12.1 Nombres}\par
{\f1          Entiers signes 16 bits uniquement (-32768 a 32767).}\par
{\f1          Pas de nombres flottants IEEE 754. Les litteraux flottants}\par
{\f1          sont tronques. Les operations a virgule flottante ne sont}\par
{\f1          pas disponibles.}\par
\par
{\f1     12.2 Memoire}\par
{\f1          Pile : 1024 octets par defaut (configurable STACK_SIZE).}\par
{\f1          Heap statique : 4096 octets pour l allocation dynamique.}\par
{\f1          Segment DATA : variables globales, constantes chaines.}\par
\par
{\f1     12.3 Symboles}\par
{\f1          Maximum 2048 symboles (Free Pascal) ou 100 (Turbo Pascal).}\par
{\f1          Maximum 64 portees imbriquees.}\par
{\f1          Maximum 32 parametres par fonction.}\par
{\f1          Maximum 32 upvalues par closure.}\par
\par
{\f1     12.4 Tables}\par
{\f1          Maximum 125 elements en partie tableau.}\par
{\f1          Maximum 63 paires en partie hash.}\par
{\f1          Bloc fixe de 512 octets par table.}\par
\par
{\f1     12.5 Retours multiples}\par
{\f1          Maximum 8 valeurs de retour.}\par
\par
{\f1     12.6 Coroutines}\par
{\f1          Maximum 4 coroutines simultanees.}\par
{\f1          Pile fixe de 512 octets par coroutine.}\par
\par
{\f1     12.7 Fonctionnalites non supportees}\par
{\f1          - Nombres flottants IEEE 754}\par
{\f1          - Patterns Lua complets (string.gmatch, patterns %d %a etc.)}\par
{\f1          - Operateurs bitwise natifs (|, &, ~, <<, >>)}\par
{\f1          - Chaines de metatables (un seul niveau)}\par
{\f1          - Gestion avancee de fichiers (io.open complet)}\par
{\f1          - Module require/module}\par
{\f1          - Environnements (_ENV avance)}\par
{\f1          - Finalisation __gc}\par
{\f1          - Weak tables}\par
{\f1          - Debug library}\par
\par
\par
