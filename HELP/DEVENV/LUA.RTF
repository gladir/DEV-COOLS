{\footnote # IDH_LUA_09}
{\footnote $ Lua - METATABLES}
{\footnote K Lua metatables;__index;__newindex;__add;metamethods}
\b\fs24 METATABLES \b0\fs20\par
\par
{\f1    9.1 setmetatable(t, mt) / getmetatable(t)}\par
{\f1        Chaque table peut avoir une metatable associee.}\par
\par
{\f1    9.2 Metamethodes arithmetiques}\par
{\f1        __add __sub __mul __div __mod __pow __unm}\par
\par
{\f1    9.3 Metamethodes de comparaison}\par
{\f1        __eq __lt __le}\par
\par
{\f1    9.4 Metamethodes speciales}\par
{\f1        __concat : surcharge de l operateur ..}\par
{\f1        __len    : surcharge de l operateur #}\par
{\f1        __index  : acces a une cle absente (table ou fonction)}\par
{\f1        __newindex : affectation a une cle absente}\par
{\f1        __call   : appel d une table comme fonction}\par
{\f1        __tostring : conversion en chaine (pour tostring et print)}\par
\par
{\f1    9.5 rawget(t, k) / rawset(t, k, v)}\par
{\f1        Acces direct sans passer par les metamethodes.}\par
\par
{\f1    9.6 Limitation}\par
{\f1        Un seul niveau de delegation (pas de chaine de metatables).}\par
\par
\par
