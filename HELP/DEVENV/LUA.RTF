{\footnote # IDH_LUA_10}
{\footnote $ Lua - BIBLIOTHEQUES STANDARD}
{\footnote K Lua bibliotheques standard;math;string;table;io;os}
\b\fs24 BIBLIOTHEQUES STANDARD \b0\fs20\par
\par
{\f1     10.1 Fonctions globales}\par
{\f1          print(...)          : affiche les arguments separes par \\t, \\n final}\par
{\f1          type(x)             : retourne la chaine du type ("nil", "number", ...)}\par
{\f1          tostring(x)         : convertit en chaine}\par
{\f1          tonumber(s)         : convertit en nombre}\par
{\f1          assert(v [, msg])   : erreur si v est nil ou false}\par
{\f1          error(msg [, level]): leve une erreur}\par
{\f1          pcall(f, ...)       : appel protege -> true+retours ou false+msg}\par
{\f1          xpcall(f, msgh, ...): appel protege avec handler de message}\par
{\f1          select(n, ...)      : n-ieme vararg ou nombre de varargs}\par
{\f1          pairs(t)            : iterateur sur toutes les cles d une table}\par
{\f1          ipairs(t)           : iterateur sur les indices entiers 1..#t}\par
{\f1          next(t, k)          : cle/valeur suivantes dans la table}\par
{\f1          rawget(t, k)        : acces table sans metamethode}\par
{\f1          rawset(t, k, v)     : affectation table sans metamethode}\par
{\f1          setmetatable(t, mt) : associe une metatable}\par
{\f1          getmetatable(t)     : retourne la metatable}\par
\par
{\f1     10.2 Bibliotheque string}\par
{\f1          string.len(s)            : longueur en octets}\par
{\f1          string.sub(s, i [, j])   : sous-chaine}\par
{\f1          string.byte(s [, i])     : code octet du caractere}\par
{\f1          string.char(n1, ...)     : chaine a partir de codes}\par
{\f1          string.rep(s, n)         : repetition n fois}\par
{\f1          string.reverse(s)        : inversion}\par
{\f1          string.upper(s)          : majuscules}\par
{\f1          string.lower(s)          : minuscules}\par
{\f1          string.find(s, pattern)  : recherche (litterale basique)}\par
{\f1          string.gsub(s, pat, rep) : remplacement premiere occurrence}\par
{\f1          string.format(fmt, ...)  : formatage (%d %s %%)}\par
{\f1          Limitation : les patterns Lua (%d, %a, etc.) ne sont pas}\par
{\f1          implementes ; la recherche est purement litterale.}\par
\par
{\f1     10.3 Bibliotheque math}\par
{\f1          math.abs(n)             : valeur absolue}\par
{\f1          math.max(a, b)          : maximum}\par
{\f1          math.min(a, b)          : minimum}\par
{\f1          math.floor(n)           : pass-through (deja entier)}\par
{\f1          math.ceil(n)            : pass-through}\par
{\f1          math.sqrt(n)            : racine carree entiere (Newton-Raphson)}\par
{\f1          math.random([m [, n]])  : nombre pseudo-aleatoire (LCG 16 bits)}\par
{\f1          math.randomseed(n)      : initialise la graine}\par
{\f1          math.pi                 : 3 (troncature entiere)}\par
{\f1          math.huge               : 32767}\par
{\f1          math.maxinteger         : 32767}\par
{\f1          math.mininteger         : -32768}\par
{\f1          math.tointeger(n)       : pass-through}\par
{\f1          math.type(n)            : "integer"}\par
\par
{\f1     10.4 Bibliotheque table}\par
{\f1          table.insert(t, v)       : insere a la fin}\par
{\f1          table.remove(t [, pos])  : supprime et retourne l element}\par
{\f1          table.concat(t [, sep])  : joint les elements}\par
{\f1          table.sort(t [, comp])   : tri a bulles}\par
{\f1          table.unpack(t)          : retour multiple des elements}\par
{\f1          table.move : stub + avertissement}\par
{\f1          table.pack : stub + avertissement}\par
\par
{\f1     10.5 Bibliotheque os}\par
{\f1          os.clock()               : approximation en secondes}\par
{\f1          os.exit([code])          : termine le programme}\par
{\f1          os.time()                : stub (retourne 0)}\par
{\f1          os.date()                : stub}\par
{\f1          os.execute(cmd)          : stub}\par
\par
{\f1     10.6 Bibliotheque io}\par
{\f1          io.write(...)            : ecriture sans \\n ni separateurs}\par
{\f1          io.read("*l")            : lecture d une ligne}\par
{\f1          io.read("*n")            : lecture d un nombre}\par
{\f1          io.read("*a")            : stub + avertissement}\par
{\f1          io.open, io.close        : stubs + avertissement}\par
\par
{\f1     10.7 Bibliotheque coroutine}\par
{\f1          coroutine.create(f)      : cree une coroutine}\par
{\f1          coroutine.resume(co, ...) : reprend l execution}\par
{\f1          coroutine.yield(...)     : suspend l execution}\par
{\f1          coroutine.status(co)     : "running"/"suspended"/"dead"/"normal"}\par
{\f1          coroutine.wrap(f)        : cree un iterateur}\par
{\f1          coroutine.isyieldable()  : test si yield possible}\par
{\f1          Limitation : pile fixe de 512 octets par coroutine,}\par
{\f1          maximum 4 coroutines simultanees.}\par
\par
