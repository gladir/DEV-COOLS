{\footnote # IDH_TPMEM_11}
{\footnote $ Gestion Memoire - EXEMPLES}
{\footnote K Turbo Pascal;Gestion Memoire;EXEMPLES}
\b\fs24 EXEMPLES \b0\fs20\par
\par
{\f1   --- Exemple 1 : Utilisation basique ---}\par
\par
{\f1   program MemDemo;}\par
{\f1   uses Memory;}\par
{\f1   var}\par
{\f1     P : Pointer;}\par
{\f1   begin}\par
{\f1     MaxHeapSize := 320000 div 16;  \{ limiter ?? ~320 Ko \}}\par
{\f1     LowMemSize := 8192 div 16;    \{ seuil de 8 Ko \}}\par
{\f1     InitMemory;}\par
\par
{\f1     P := MemAlloc(4096);}\par
