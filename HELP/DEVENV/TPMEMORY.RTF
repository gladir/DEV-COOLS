\par
{\f1       DisposeBuffer(Buf);}\par
{\f1     end;}\par
\par
{\f1     DoneMemory;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 4 : Pr??paration pour Exec ---}\par
\par
