{\footnote # IDH_TPMEM_10}
{\footnote $ Gestion Memoire - PRIORIT?? DE LIB??RATION}
{\footnote K Turbo Pascal;Gestion Memoire;PRIORIT?? DE LIB??RATION}
\b\fs24 PRIORIT?? DE LIB??RATION \b0\fs20\par
\par
{\f1   Quand une allocation permanente (MemAlloc, New, GetMem) ne}\par
