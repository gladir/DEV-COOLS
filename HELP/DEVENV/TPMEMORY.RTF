{\f1       OldMemTop := Ptr(HeapOrg.Seg, HeapOrg.Ofs);}\par
{\f1       SetMemTop(HeapPtr);  \{ r??duire au strict n??cessaire \}}\par
{\f1       Exec('COMMAND.COM', '/C DIR');}\par
