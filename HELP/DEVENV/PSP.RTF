{\footnote # IDH_PSP_21}
{\footnote $ PSP - Compilateurs PSP86.PAS et PSPCW32.PAS}
{\footnote K PSP86 PSPCW32 compilateurs;cible 8086 MASM SMALL;Win32 natif;prefixes _PSP_ _PSPF_ _PSPK_ _PSPRT_ _PSPL_ _PSPA_ _PSPR_ _PSPE_ _PSPK_HTML_ _PSPX_;MAX_SYM 2048}
\b\fs24 Compilateurs PSP86.PAS et PSPCW32.PAS \b0\fs20\par
\par
\par
\b 21.1 PSP86.PAS \b0\par
\par
{\f1     - Cible : assembleur 8086 MASM, modele SMALL, DOS 16 bits.}\par
{\f1     - Sortie : fichier .ASM autonome, assemblable par MASM ou TASM.}\par
{\f1     - Mode CGI DOS : sortie sur stdout.}\par
{\f1     - Types : Integer 16 bits, String[255], Real tronque.}\par
{\f1     - Limites (en mode FPC) :}\par
{\f1         MAX_SYM       = 2048 symboles}\par
{\f1         MAX_LABEL     = 2048 labels}\par
{\f1         MAX_DATA      = 512 entrees de donnees}\par
{\f1         MAX_INCLUDE   = 8 niveaux d inclusion}\par
{\f1         STACK_SIZE    = 1024 octets}\par
\par
{\f1   Compilation du compilateur :}\par
\par
{\f1     fpc -Mtp PSP86.PAS}\par
\par
{\f1   Utilisation :}\par
\par
{\f1     PSP86 page.psp -o page.asm}\par
{\f1     ASM86 page.asm}\par
{\f1     LINK  page.obj}\par
\par
\par
\b 21.2 PSPCW32.PAS \b0\par
\par
{\f1     - Cible : Win32 executable natif.}\par
{\f1     - Compatible IIS, Apache, mode CGI 1.1.}\par
{\f1     - Integer 32 bits, String typage Pascal.}\par
{\f1     - Support partiel COM/OLE via CreateObject.}\par
\par
{\f1   Compilation du compilateur :}\par
\par
{\f1     fpc -Mtp PSPCW32.PAS}\par
\par
{\f1   Utilisation :}\par
\par
{\f1     PSPCW32 page.psp}\par
\par
\par
\b 21.3 Prefixes de nommage ASM (PSP86) \b0\par
\par
{\f1   Les symboles emis par PSP86.PAS sont prefixes pour eviter les}\par
{\f1   collisions :}\par
\par
{\f1     _PSP_         variable globale}\par
{\f1     _PSPF_        fonction / procedure}\par
{\f1     _PSPK_        constante chaine litterale}\par
{\f1     _PSPRT_       routine runtime}\par
{\f1     _PSPL_        label interne}\par
{\f1     _PSPA_        tableau}\par
{\f1     _PSPR_        record}\par
{\f1     _PSPE_        enumeration}\par
{\f1     _PSPK_HTML_   fragment HTML statique}\par
{\f1     _PSPX_        gestionnaire d exception}\par
\par
\par
