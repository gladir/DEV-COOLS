{\footnote # IDH_PSP_08}
{\footnote $ PSP - Declarations (const, var, type)}
{\footnote K PSP declarations const var type;sections multiples;constantes typees;Turbo Pascal mode}
\b\fs24 Declarations (const, var, type) \b0\fs20\par
\par
\par
\b 8.1 Constantes \b0\par
\par
{\f1     const}\par
{\f1       N      = 10;}\par
{\f1       PI     = 3.14159;}\par
{\f1       TITRE  = 'Page d accueil';}\par
\par
{\f1   Constantes typees (avec valeur initiale) :}\par
\par
{\f1     const}\par
{\f1       Buffer: array[1..5] of Integer = (10, 20, 30, 40, 50);}\par
\par
\par
\b 8.2 Variables \b0\par
\par
{\f1     var}\par
{\f1       i, j   : Integer;}\par
{\f1       nom    : String;}\par
{\f1       total  : Word;}\par
{\f1       actif  : Boolean;}\par
{\f1       arr    : array[1..N] of Integer;}\par
\par
\par
\b 8.3 Types \b0\par
\par
{\f1     type}\par
{\f1       TJour = (Lundi, Mardi, Mercredi, Jeudi, Vendredi, Samedi, Dimanche);}\par
{\f1       TPoint = record}\par
{\f1         x, y: Integer;}\par
{\f1       end;}\par
\par
{\f1   Les sections const, var, type peuvent apparaitre plusieurs fois dans}\par
{\f1   un meme bloc <% %>, dans n importe quel ordre (mode Turbo Pascal).}\par
\par
\par
