{\footnote # IDH_PSP_07}
{\footnote $ PSP - Types de donnees}
{\footnote K PSP types donnees;Integer Word Byte Char Boolean String Real Pointer Text;array record enumeration set sous-intervalle pointeur typee}
\b\fs24 Types de donnees \b0\fs20\par
\par
\par
\b 7.1 Types primitifs \b0\par
\par
{\f1   Les compilateurs PSP86 et PSPCW32 connaissent les types suivants}\par
{\f1   (indices internes TY_IDX_* dans PSP86.PAS) :}\par
\par
{\f1     Integer     entier 16 bits signe        (-32768..32767 en DOS)}\par
{\f1     Word        entier 16 bits non signe    (0..65535)}\par
{\f1     Byte        entier 8 bits non signe     (0..255)}\par
{\f1     Char        caractere 8 bits ASCII}\par
{\f1     Boolean     valeur True / False}\par
{\f1     String      chaine ASCIIZ (jusqu a 255 caracteres en mode TP)}\par
{\f1     Real        flottant (tronque en entier dans le backend 8086)}\par
{\f1     Pointer     pointeur generique}\par
{\f1     Text        fichier texte (handle DOS)}\par
\par
{\f1   Sur cible Win32, Integer est generalement 32 bits.}\par
\par
\par
\b 7.2 Types definis par l utilisateur \b0\par
\par
{\f1   Tableaux :}\par
\par
{\f1     type}\par
{\f1       TTab = array[1..10] of Integer;}\par
{\f1       TMat = array[0..2, 0..2] of Word;}\par
\par
{\f1   Records :}\par
\par
{\f1     type}\par
{\f1       TPoint = record}\par
{\f1         x, y: Integer;}\par
{\f1       end;}\par
\par
{\f1   Enumerations :}\par
\par
{\f1     type}\par
{\f1       TJour = (Lundi, Mardi, Mercredi, Jeudi, Vendredi, Samedi, Dimanche);}\par
\par
{\f1   Ensembles :}\par
\par
{\f1     type}\par
{\f1       TSetJours = set of TJour;}\par
\par
{\f1   Sous-intervalles :}\par
\par
{\f1     type}\par
{\f1       TDigit = 0..9;}\par
{\f1       TLettre = 'A'..'Z';}\par
\par
{\f1   Pointeurs typees :}\par
\par
{\f1     type}\par
{\f1       PInt = ^Integer;}\par
\par
\par
