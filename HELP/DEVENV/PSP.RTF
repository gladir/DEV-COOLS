{\footnote # IDH_PSP_10}
{\footnote $ PSP - Instructions de controle}
{\footnote K PSP controle flux;affectation :=;if then else;case;for to downto;while;repeat until;with;break continue exit}
\b\fs24 Instructions de controle \b0\fs20\par
\par
\par
\b 10.1 Affectation \b0\par
\par
{\f1     i := 42;}\par
{\f1     nom := 'Bob';}\par
\par
\par
\b 10.2 if / then / else \b0\par
\par
{\f1     if x > 0 then}\par
{\f1       WriteLn('positif')}\par
{\f1     else if x < 0 then}\par
{\f1       WriteLn('negatif')}\par
{\f1     else}\par
{\f1       WriteLn('nul');}\par
\par
\par
\b 10.3 case \b0\par
\par
{\f1     case jour of}\par
{\f1       Lundi, Mardi, Mercredi, Jeudi, Vendredi: WriteLn('Semaine');}\par
{\f1       Samedi, Dimanche: WriteLn('Weekend');}\par
{\f1     else}\par
{\f1       WriteLn('?');}\par
{\f1     end;}\par
\par
\par
\b 10.4 for / to / downto \b0\par
\par
{\f1     for i := 1 to 10 do}\par
{\f1       WriteLn(i);}\par
\par
{\f1     for i := 10 downto 1 do}\par
{\f1       WriteLn(i);}\par
\par
\par
\b 10.5 while \b0\par
\par
{\f1     while x > 0 do}\par
{\f1       x := x - 1;}\par
\par
\par
\b 10.6 repeat / until \b0\par
\par
{\f1     repeat}\par
{\f1       x := x + 1;}\par
{\f1     until x >= 10;}\par
\par
\par
\b 10.7 with \b0\par
\par
{\f1     with mon_point do}\par
{\f1     begin}\par
{\f1       x := 10;}\par
{\f1       y := 20;}\par
{\f1     end;}\par
\par
\par
\b 10.8 break, continue, exit \b0\par
\par
{\f1   Le compilateur supporte exit (sortie immediate de la procedure courante)}\par
{\f1   et selon les versions break / continue pour les boucles.}\par
\par
\par
{\uldb << Precedent}{\v IDH_PSP_09}     {\uldb Suivant >>}{\v IDH_PSP_11}     {\uldb Table des matieres}{\v IDH_PSP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_PSP_11}
{\footnote $ PSP - Procedures et fonctions}
{\footnote K PSP procedures fonctions;procedure;function Result;parametres valeur var;variables locales;Exit;forward}
\b\fs24 Procedures et fonctions \b0\fs20\par
\par
\par
\b 11.1 Procedure \b0\par
\par
{\f1     procedure SayHello;}\par
{\f1     begin}\par
{\f1       Write('Hello from proc');}\par
{\f1       WriteLn;}\par
{\f1     end;}\par
\par
\par
\b 11.2 Fonction \b0\par
\par
{\f1     function Double(n: Integer): Integer;}\par
{\f1     begin}\par
{\f1       Double := n + n;}\par
{\f1     end;}\par
\par
{\f1   Le nom de la fonction sert de variable de retour, comme en Turbo Pascal.}\par
{\f1   La variable speciale Result est aussi reconnue :}\par
\par
{\f1     function Triple(n: Integer): Integer;}\par
{\f1     begin}\par
{\f1       Result := n * 3;}\par
{\f1     end;}\par
\par
\par
\b 11.3 Parametres \b0\par
\par
{\f1   Par valeur (defaut) :}\par
\par
{\f1     procedure PrintNum(x: Integer);}\par
\par
{\f1   Par reference (var) :}\par
\par
{\f1     procedure Echange(var a, b: Integer);}\par
{\f1     var t: Integer;}\par
{\f1     begin}\par
{\f1       t := a; a := b; b := t;}\par
{\f1     end;}\par
\par
{\f1   Plusieurs parametres du meme type :}\par
\par
{\f1     function Add(a, b: Integer): Integer;}\par
{\f1     begin}\par
{\f1       Add := a + b;}\par
{\f1     end;}\par
\par
\par
\b 11.4 Variables locales \b0\par
\par
{\f1     function Square(n: Integer): Integer;}\par
{\f1     var tmp: Integer;}\par
{\f1     begin}\par
{\f1       tmp := n * n;}\par
{\f1       Square := tmp;}\par
{\f1     end;}\par
\par
\par
\b 11.5 Exit \b0\par
\par
{\f1     function AbsVal(n: Integer): Integer;}\par
{\f1     begin}\par
{\f1       if n < 0 then}\par
{\f1       begin}\par
{\f1         AbsVal := 0 - n;}\par
{\f1         Exit;}\par
{\f1       end;}\par
{\f1       AbsVal := n;}\par
{\f1     end;}\par
\par
\par
\b 11.6 Forward \b0\par
\par
{\f1   Pour les procedures mutuellement recursives :}\par
\par
{\f1     function Fwd(x: Integer): Integer; forward;}\par
\par
{\f1     function Autre(x: Integer): Integer;}\par
{\f1     begin}\par
{\f1       Autre := Fwd(x) + 1;}\par
{\f1     end;}\par
\par
{\f1     function Fwd(x: Integer): Integer;}\par
{\f1     begin}\par
{\f1       Fwd := x + 100;}\par
{\f1     end;}\par
\par
\par
