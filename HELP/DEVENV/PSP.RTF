{\footnote # IDH_PSP_23}
{\footnote $ PSP - Exemples complets}
{\footnote K PSP exemples;Hello World;compteur;tableau somme;procedures fonctions;COM CreateObject;directives conditionnelles}
\b\fs24 Exemples complets \b0\fs20\par
\par
\par
\b 23.1 Hello World \b0\par
\par
{\f1     <html>}\par
{\f1       <head><title>Hello PSP</title></head>}\par
{\f1       <body>}\par
{\f1         <% begin}\par
{\f1              Write('Bonjour le monde !');}\par
{\f1            end. %>}\par
{\f1       </body>}\par
{\f1     </html>}\par
\par
\par
\b 23.2 Compteur dynamique \b0\par
\par
{\f1     <% var i: Integer; %>}\par
{\f1     <html>}\par
{\f1       <body>}\par
{\f1         <h1>Nombres de 1 a 10</h1>}\par
{\f1         <ul>}\par
{\f1         <% for i := 1 to 10 do %>}\par
{\f1           <li><%= i %></li>}\par
{\f1         </ul>}\par
{\f1       </body>}\par
{\f1     </html>}\par
\par
\par
\b 23.3 Tableau avec somme \b0\par
\par
{\f1     <%}\par
{\f1       program test_array;}\par
{\f1       const N = 5;}\par
{\f1       var}\par
{\f1         arr: array[1..N] of Integer;}\par
{\f1         total, i: Integer;}\par
{\f1       begin}\par
{\f1         arr[1] := 10; arr[2] := 20; arr[3] := 30;}\par
{\f1         arr[4] := 40; arr[5] := 50;}\par
{\f1         total := 0;}\par
{\f1         for i := 1 to N do}\par
{\f1           total := total + arr[i];}\par
{\f1         WriteLn(total);    \{ 150 \}}\par
{\f1       end.}\par
{\f1     %>}\par
\par
\par
\b 23.4 Fonctions et procedures \b0\par
\par
{\f1     <%}\par
{\f1       procedure SayHello;}\par
{\f1       begin}\par
{\f1         WriteLn('Hello from proc');}\par
{\f1       end;}\par
\par
{\f1       function Add(a, b: Integer): Integer;}\par
{\f1       begin}\par
{\f1         Add := a + b;}\par
{\f1       end;}\par
\par
{\f1       var r: Integer;}\par
{\f1     begin}\par
{\f1       SayHello;}\par
{\f1       r := Add(10, 20);}\par
{\f1       WriteLn(r);}\par
{\f1     end.}\par
{\f1     %>}\par
\par
\par
\b 23.5 COM/OLE (cible Win32) \b0\par
\par
{\f1     <%@ Language="PascalScript" %>}\par
{\f1     <html>}\par
{\f1     <body>}\par
{\f1     <%}\par
{\f1       var obj: Object;}\par
{\f1     begin}\par
{\f1       obj := CreateObject('Scripting.FileSystemObject');}\par
{\f1       if obj <> nil then}\par
{\f1       begin}\par
{\f1         WriteLn('<p>Objet COM cree</p>');}\par
{\f1         obj := nil;}\par
{\f1       end}\par
{\f1       else}\par
{\f1         WriteLn('<p>Echec creation COM</p>');}\par
{\f1     end.}\par
{\f1     %>}\par
{\f1     </body>}\par
{\f1     </html>}\par
\par
\par
\b 23.6 Directives conditionnelles \b0\par
\par
{\f1     <%}\par
{\f1       \{$DEFINE TESTMODE\}}\par
{\f1       program test_dir;}\par
{\f1       var x: Integer;}\par
{\f1       begin}\par
{\f1         x := 100;}\par
{\f1         \{$IFDEF TESTMODE\}}\par
{\f1           WriteLn('Mode test : ', x);}\par
{\f1         \{$ELSE\}}\par
{\f1           WriteLn('Production');}\par
{\f1         \{$ENDIF\}}\par
{\f1       end.}\par
{\f1     %>}\par
\par
\par
