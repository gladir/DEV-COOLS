{\footnote # IDH_PSP_15}
{\footnote $ PSP - Bibliotheque standard}
{\footnote K PSP bibliotheque standard;Write WriteLn Read ReadLn;Abs Sqr Inc Dec Odd Pred Succ Random;Format Str Val}
\b\fs24 Bibliotheque standard \b0\fs20\par
\par
{\f1   Les compilateurs PSP86 et PSPCW32 fournissent un sous-ensemble de la}\par
{\f1   bibliotheque standard Turbo Pascal :}\par
\par
\par
\b 15.1 E/S \b0\par
\par
{\f1     Write(args...)          ecrit sans saut de ligne}\par
{\f1     WriteLn(args...)        ecrit puis saut de ligne}\par
{\f1     Read(var)               lit depuis stdin}\par
{\f1     ReadLn(var)             lit une ligne}\par
\par
\par
\b 15.2 Numerique \b0\par
\par
{\f1     Abs(n)        Sqr(n)         Inc(v)         Dec(v)}\par
{\f1     Odd(n)        Pred(v)        Succ(v)        Random(n)}\par
\par
\par
\b 15.3 Chaines \b0\par
\par
{\f1     Length, Copy, Pos, Concat, UpCase, Chr, Ord, IntToStr, StrToInt}\par
\par
\par
\b 15.4 Conversion et formatage \b0\par
\par
{\f1     Format(fmt, args)       formatage de type printf}\par
{\f1     Str(v, s)               variable vers chaine}\par
{\f1     Val(s, v, code)         chaine vers variable}\par
\par
\par
{\uldb << Precedent}{\v IDH_PSP_14}     {\uldb Suivant >>}{\v IDH_PSP_16}     {\uldb Table des matieres}{\v IDH_PSP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
