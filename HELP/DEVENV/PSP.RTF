{\footnote # IDH_PSP_09}
{\footnote $ PSP - Operateurs et expressions}
{\footnote K PSP operateurs;arithmetiques + - * / div mod;relationnels = <> < <= > >= in;logiques and or xor not shl shr;concatenation +}
\b\fs24 Operateurs et expressions \b0\fs20\par
\par
\par
\b 9.1 Operateurs arithmetiques \b0\par
\par
{\f1     +    addition}\par
{\f1     -    soustraction}\par
{\f1     *    multiplication}\par
{\f1     /    division reelle}\par
{\f1     div  division entiere}\par
{\f1     mod  modulo}\par
\par
\par
\b 9.2 Operateurs relationnels \b0\par
\par
{\f1     =    egalite}\par
{\f1     <>   difference}\par
{\f1     <    inferieur}\par
{\f1     <=   inferieur ou egal}\par
{\f1     >    superieur}\par
{\f1     >=   superieur ou egal}\par
{\f1     in   appartenance a un ensemble}\par
\par
\par
\b 9.3 Operateurs logiques et bit-a-bit \b0\par
\par
{\f1     and  ET logique / bit-a-bit}\par
{\f1     or   OU logique / bit-a-bit}\par
{\f1     xor  OU exclusif}\par
{\f1     not  NON logique / bit-a-bit}\par
{\f1     shl  decalage gauche}\par
{\f1     shr  decalage droite}\par
\par
\par
\b 9.4 Concatenation \b0\par
\par
{\f1     +    concatenation pour les chaines (operande String + String)}\par
\par
\par
\b 9.5 Precedence \b0\par
\par
{\f1   De la plus haute a la plus basse :}\par
\par
{\f1     1. not, @}\par
{\f1     2. *, /, div, mod, and, shl, shr}\par
{\f1     3. +, -, or, xor}\par
{\f1     4. =, <>, <, <=, >, >=, in}\par
\par
\par
