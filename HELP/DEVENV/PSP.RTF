{\footnote # IDH_PSP_06}
{\footnote $ PSP - Lexique et conventions du Pascal embarque}
{\footnote K PSP lexique;identificateurs;mots-cles Pascal;commentaires { } (* *);litteraux #10 #13 $1A %1010;True False nil}
\b\fs24 Lexique et conventions du Pascal embarque \b0\fs20\par
\par
\par
\b 6.1 Identificateurs \b0\par
\par
{\f1   Un identificateur commence par une lettre ou un souligne et peut}\par
{\f1   contenir des lettres, chiffres et soulignes. Le langage est insensible}\par
{\f1   a la casse, comme Pascal :}\par
\par
{\f1     nom_variable    Compteur    _temp    XYZ123}\par
\par
\par
\b 6.2 Mots-cles \b0\par
\par
{\f1   Les mots-cles principaux sont (ordre alphabetique) :}\par
\par
{\f1     and       array     begin     boolean   case      char}\par
{\f1     const     div       do        downto    else      end}\par
{\f1     exit      file      for       forward   function  if}\par
{\f1     in        integer   label     mod       nil       not}\par
{\f1     of        or        procedure program   record    repeat}\par
{\f1     set       shl       shr       string    then      to}\par
{\f1     type      until     uses      var       while     with}\par
{\f1     write     writeln   xor}\par
\par
\par
\b 6.3 Commentaires \b0\par
\par
{\f1   Trois styles, comme en Turbo Pascal :}\par
\par
{\f1     \{ commentaire avec accolades \}}\par
{\f1     (* commentaire avec parentheses-etoiles *)}\par
{\f1     // commentaire jusqu en fin de ligne     (selon implementation)}\par
\par
{\f1   Les directives compilateur sont des commentaires speciaux commencant}\par
{\f1   par "$" :}\par
\par
{\f1     \{$DEFINE DEBUG\}}\par
{\f1     \{$I header.inc\}}\par
\par
\par
\b 6.4 Litteraux \b0\par
\par
{\f1   Numeriques :}\par
\par
{\f1     42            \{ entier decimal \}}\par
{\f1     -100          \{ entier negatif \}}\par
{\f1     $1A           \{ entier hexadecimal (26) \}}\par
{\f1     %1010         \{ entier binaire (10) \}}\par
{\f1     3.14          \{ reel (tronque en entier par defaut) \}}\par
\par
{\f1   Caracteres et chaines :}\par
\par
{\f1     'A'           \{ caractere \}}\par
{\f1     'Hello'       \{ chaine \}}\par
{\f1     'L''ami'      \{ apostrophe doublee \}}\par
{\f1     #10           \{ caractere par code ASCII (newline) \}}\par
{\f1     #13#10        \{ CR + LF \}}\par
{\f1     'Pre' + #9 + 'Post'   \{ concatenation \}}\par
\par
{\f1   Booleens et pointeur :}\par
\par
{\f1     True      False     nil}\par
\par
\par
