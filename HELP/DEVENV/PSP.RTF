\page

{\footnote # IDH_PSP_13}
{\footnote $ PSP - Enumerations et ensembles}
{\footnote K PSP enumerations ensembles;type enum;Ord;set of;in;operations ensemblistes}
\b\fs24 Enumerations et ensembles \b0\fs20\par
\par
\par
\b 13.1 Enumerations \b0\par
\par
{\f1     type}\par
{\f1       TJour = (Lundi, Mardi, Mercredi, Jeudi,}\par
{\f1                Vendredi, Samedi, Dimanche);}\par
\par
{\f1     var j: TJour;}\par
{\f1     j := Mardi;}\par
\par
{\f1     if j = Lundi then ...}\par
\par
{\f1   Les valeurs commencent a 0 (Lundi = 0, Mardi = 1, ...) et peuvent etre}\par
{\f1   converties via Ord :}\par
\par
{\f1     Ord(Mercredi)    \{ retourne 2 \}}\par
\par
\par
\b 13.2 Ensembles \b0\par
\par
{\f1     type}\par
{\f1       TSetJours = set of TJour;}\par
\par
{\f1     var ouvrables: TSetJours;}\par
{\f1     ouvrables := [Lundi, Mardi, Mercredi, Jeudi, Vendredi];}\par
\par
{\f1     if j in ouvrables then}\par
{\f1       WriteLn('Jour ouvrable');}\par
\par
\par
