\page

{\footnote # IDH_PSP_14}
{\footnote $ PSP - Chaines de caracteres}
{\footnote K PSP chaines;String;Length Copy Pos Concat Chr Ord UpCase IntToStr StrToInt Trim}
\b\fs24 Chaines de caracteres \b0\fs20\par
\par
{\f1   Le type String est une chaine de caracteres ASCIIZ avec une longueur}\par
{\f1   maximale fixe (255 par defaut, configurable).}\par
\par
\par
\b 14.1 Operations \b0\par
\par
{\f1     s1 := 'Hello, ';}\par
{\f1     s2 := 'World';}\par
{\f1     s3 := s1 + s2;            \{ concatenation \}}\par
{\f1     n  := Length(s3);}\par
{\f1     c  := s3[1];              \{ acces par indice 1-based \}}\par
\par
\par
\b 14.2 Fonctions standard \b0\par
\par
{\f1     Length(s)               longueur}\par
{\f1     Copy(s, idx, count)     sous-chaine}\par
{\f1     Pos(sub, s)             position de sub dans s (0 si absent)}\par
{\f1     Concat(s1, s2, ...)     concatenation explicite}\par
{\f1     Chr(n)                  caractere de code n}\par
{\f1     Ord(c)                  code ASCII de c}\par
{\f1     UpCase(c)               majuscule}\par
{\f1     IntToStr(n)             entier vers chaine}\par
{\f1     StrToInt(s)             chaine vers entier}\par
{\f1     Trim(s)                 sans espaces aux extremites}\par
\par
\par
