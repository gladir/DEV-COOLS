\page

{\footnote # IDH_PSP_12}
{\footnote $ PSP - Tableaux et records}
{\footnote K PSP tableaux records;array of;bornes;multidimensionnels;record;Length Low High SizeOf}
\b\fs24 Tableaux et records \b0\fs20\par
\par
\par
\b 12.1 Tableaux statiques \b0\par
\par
{\f1     var arr: array[1..5] of Integer;}\par
{\f1     arr[1] := 10;}\par
{\f1     arr[2] := 20;}\par
\par
{\f1   Bornes arbitraires, indice de n importe quel type ordinal :}\par
\par
{\f1     var notes: array['A'..'E'] of Integer;}\par
\par
\par
\b 12.2 Tableaux multidimensionnels \b0\par
\par
{\f1     var matrice: array[1..3, 1..3] of Integer;}\par
{\f1     matrice[2, 3] := 99;}\par
\par
\par
\b 12.3 Records \b0\par
\par
{\f1     type}\par
{\f1       TPoint = record}\par
{\f1         x, y: Integer;}\par
{\f1       end;}\par
\par
{\f1     var p: TPoint;}\par
{\f1     p.x := 10;}\par
{\f1     p.y := 20;}\par
\par
\par
\b 12.4 Fonctions intrinseques sur tableau \b0\par
\par
{\f1     Length(arr)    nombre d elements}\par
{\f1     Low(arr)       borne inferieure}\par
{\f1     High(arr)      borne superieure}\par
{\f1     SizeOf(arr)    taille en octets}\par
\par
\par
