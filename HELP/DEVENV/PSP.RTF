{\footnote # IDH_PSP_04}
{\footnote $ PSP - Balises PSP}
{\footnote K PSP balises;<% %>;<%= %>;<%@ %>;<%-- --%>;include serveur;#include file virtual}
\b\fs24 Balises PSP \b0\fs20\par
\par
\par
\b 4.1 Bloc de code <% ... %> \b0\par
\par
{\f1   Contient du code Pascal qui sera execute :}\par
\par
{\f1     <% var nom: String;}\par
{\f1        begin}\par
{\f1          nom := 'Alice';}\par
{\f1          WriteLn('Bonjour ', nom);}\par
{\f1        end. %>}\par
\par
\par
\b 4.2 Expression inline <%= ... %> \b0\par
\par
{\f1   Ecrit la valeur d une expression directement dans la sortie HTML :}\par
\par
{\f1     <p>L heure courante est <%= Now %></p>}\par
\par
{\f1   Equivalent a :}\par
\par
{\f1     <p>L heure courante est <% Write(Now); %></p>}\par
\par
\par
\b 4.3 Commentaire de page <%-- ... --%> \b0\par
\par
{\f1   Reconnu par certaines variantes : le contenu est ignore et n est pas}\par
{\f1   envoye au client. (Selon implementation, on peut aussi utiliser les}\par
{\f1   commentaires Pascal \{ \} et (* *) a l interieur de blocs <% %>.)}\par
\par
\par
\b 4.4 Directive de page <%@ ... %> \b0\par
\par
{\f1   Specifie des options pour la page entiere. Toujours en debut de fichier :}\par
\par
{\f1     <%@ Language="PascalScript" %>}\par
{\f1     <%@ CodePage="65001" %>}\par
\par
{\f1   Le compilateur reconnait l attribut Language mais ne change pas de}\par
{\f1   langage (PSP est toujours du Pascal). C est essentiellement un marqueur}\par
{\f1   de compatibilite avec ASP.}\par
\par
\par
\b 4.5 Include serveur <!--#include ... --> \b0\par
\par
{\f1     <!--#include file="header.psp" -->}\par
{\f1     <!--#include virtual="/inc/footer.psp" -->}\par
\par
{\f1   Inclus le contenu d un autre fichier avant compilation.}\par
\par
\par
