{\footnote # IDH_PSP_24}
{\footnote $ PSP - Differences avec ASP 3.0 (VBScript / JScript)}
{\footnote K PSP vs ASP 3.0;Pascal vs VBScript JScript;AOT vs interprete;Response.Write;objets intrinseques Request Response Server Session Application}
\b\fs24 Differences avec ASP 3.0 (VBScript / JScript) \b0\fs20\par
\par
\par
\b 24.1 Langage \b0\par
\par
{\f1     Aspect              PSP                 ASP 3.0 (VBScript)}\par
{\f1     ------------------  ------------------- ------------------}\par
{\f1     Langage             Pascal              VBScript / JScript}\par
{\f1     Typage              statique            dynamique}\par
{\f1     Compilation         AOT (binaire .EXE)  interpretee (a la volee)}\par
{\f1     Sortie              Write / WriteLn     Response.Write}\par
{\f1     Expression inline   <%= expr %>         <%= expr %>}\par
{\f1     Directive Language  <%@ Language=...%>  <%@ Language=...%>}\par
\par
\par
\b 24.2 Objets intrinseques \b0\par
\par
{\f1   ASP fournit Request, Response, Server, Session, Application. PSP}\par
{\f1   ne fournit pas ces objets directement : le developpeur ecrit}\par
{\f1   directement sur stdout via Write/WriteLn.}\par
\par
{\f1   Equivalences approximatives :}\par
\par
{\f1     Response.Write x     -> Write(x)}\par
{\f1     Response.End         -> Exit (ou Halt)}\par
{\f1     Server.HTMLEncode    -> fonction utilisateur}\par
{\f1     Request.QueryString  -> ParamStr() ou variables d environnement}\par
\par
\par
