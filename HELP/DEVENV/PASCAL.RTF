{\f1   Copy(s, 1, 3)           sous-chaine}\par
{\f1   Pos('jour', s)          recherche (0 si absent)}\par
{\f1   Delete(s, 4, 2)         suppression dans s}\par
{\f1   Insert('XX', s, 3)      insertion}\par
{\f1   UpCase(c)               majuscule (caractere unique)}\par
