{\footnote # IDH_PASCAL_20}
{\footnote $ Pascal - DIRECTIVES DE COMPILATION}
{\footnote K Pascal directives compilation;MODE;IFDEF;DEFINE;UNDEF;I+;R+;H+;Q+}
\b\fs24 DIRECTIVES DE COMPILATION \b0\fs20\par
\par
\par
\b 20.1 Directives globales \b0\par
\par
{\f1   \{$MODE TP\}            mode Turbo Pascal}\par
{\f1   \{$MODE OBJFPC\}        mode FPC objet (defaut)}\par
{\f1   \{$MODE DELPHI\}        mode Delphi compatibilite}\par
{\f1   \{$MODE ISO\}           ISO 7185 strict}\par
\par
\par
\b 20.2 Directives locales \b0\par
\par
{\f1   \{$I+\} \{$I-\}           E/S verifiee / non verifiee}\par
{\f1   \{$R+\} \{$R-\}           bornes verifiees / non}\par
{\f1   \{$Q+\} \{$Q-\}           overflow entier verifie / non}\par
{\f1   \{$B+\} \{$B-\}           Boolean court-circuit OFF / ON}\par
