{\footnote # IDH_PASCAL_15}
{\footnote $ Pascal - POINTEURS ET ALLOCATION DYNAMIQUE}
{\footnote K Pascal pointeurs;allocation dynamique;New;Dispose;GetMem;FreeMem;nil;reference}
\b\fs24 POINTEURS ET ALLOCATION DYNAMIQUE \b0\fs20\par
\par
\par
\b 15.1 Declaration \b0\par
\par
{\f1   type}\par
{\f1     PInt   = ^Integer;}\par
{\f1     PNoeud = ^TNoeud;}\par
{\f1     TNoeud = record}\par
{\f1       valeur : Integer;}\par
{\f1       suivant: PNoeud}\par
{\f1     end;}\par
\par
{\f1   var p: PInt;}\par
\par
\par
\b 15.2 Allocation \b0\par
\par
Style Turbo Pascal :\par
\par
{\f1   New(p);            \{ alloue sizeof(Integer) \}}\par
{\f1   p^ := 42;          \{ dereference \}}\par
{\f1   Dispose(p);        \{ libere \}}\par
\par
Pour un tampon arbitraire :\par
\par
{\f1   GetMem(p, 1024);}\par
{\f1   FreeMem(p, 1024);}\par
\par
\par
\b 15.3 Nil \b0\par
\par
{\f1   p := nil;}\par
{\f1   if p <> nil then ...}\par
\par
\par
\b 15.4 Operateurs lies aux pointeurs \b0\par
\par
{\f1   @x       adresse de la variable x}\par
{\f1   p^       contenu pointe par p}\par
{\f1   Addr(x)  equivalent de @x}\par
\par
\par
\par
