{\footnote # IDH_PASCAL_23}
{\footnote $ Pascal - EXEMPLE COMPLET}
{\footnote K Pascal exemple complet;Fibonacci;programme exemple}
\b\fs24 EXEMPLE COMPLET \b0\fs20\par
\par
Programme calculant la suite de Fibonacci :\par
\par
{\f1   program Fibonacci;}\par
\par
{\f1   uses Crt;}\par
\par
{\f1   function Fib(n: Integer): LongInt;}\par
{\f1   begin}\par
{\f1     if n < 2 then}\par
{\f1       Fib := n}\par
{\f1     else}\par
{\f1       Fib := Fib(n-1) + Fib(n-2)}\par
{\f1   end;}\par
\par
{\f1   var}\par
{\f1     i, n: Integer;}\par
\par
{\f1   begin}\par
{\f1     ClrScr;}\par
{\f1     Write('Entrez n : '); ReadLn(n);}\par
{\f1     WriteLn('Suite de Fibonacci jusqu''a F(', n, ') :');}\par
{\f1     for i := 0 to n do}\par
{\f1       WriteLn('  F(', i:2, ') = ', Fib(i));}\par
{\f1     ReadLn}\par
{\f1   end.}\par
\par
Compilation et execution sous Free Pascal :\par
\par
{\f1   fpc fibonacci.pas}\par
{\f1   ./fibonacci}\par
\par
\par
