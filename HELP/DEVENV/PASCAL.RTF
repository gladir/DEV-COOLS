{\footnote # IDH_PASCAL_16}
{\footnote $ Pascal - OBJETS (TURBO PASCAL)}
{\footnote K Pascal objets;object;virtual;constructor;destructor;heritage;Turbo Pascal}
\b\fs24 OBJETS (TURBO PASCAL) \b0\fs20\par
\par
\par
\b 16.1 Declaration \b0\par
\par
{\f1   type}\par
{\f1     TForme = object}\par
{\f1       x, y: Integer;}\par
{\f1       constructor Init(ax, ay: Integer);}\par
{\f1       procedure Affiche; virtual;}\par
{\f1       destructor Done; virtual;}\par
{\f1     end;}\par
\par
{\f1     TCercle = object(TForme)}\par
{\f1       Rayon: Integer;}\par
{\f1       constructor Init(ax, ay, ar: Integer);}\par
{\f1       procedure Affiche; virtual;}\par
{\f1     end;}\par
\par
\par
\b 16.2 Implementation \b0\par
\par
{\f1   constructor TForme.Init(ax, ay: Integer);}\par
{\f1   begin}\par
{\f1     x := ax; y := ay}\par
{\f1   end;}\par
\par
{\f1   procedure TForme.Affiche;}\par
{\f1   begin}\par
{\f1     WriteLn('Forme en (', x, ',', y, ')')}\par
{\f1   end;}\par
\par
\par
\b 16.3 Allocation \b0\par
\par
Statique :\par
\par
{\f1   var c: TCercle;}\par
{\f1   c.Init(10, 20, 5);}\par
\par
Dynamique :\par
\par
{\f1   var pc: ^TCercle;}\par
{\f1   New(pc, Init(10, 20, 5));}\par
{\f1   pc^.Affiche;}\par
{\f1   Dispose(pc, Done);}\par
\par
\par
\par
