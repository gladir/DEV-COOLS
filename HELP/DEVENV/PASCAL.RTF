{\footnote # IDH_PASCAL_13}
{\footnote $ Pascal - FICHIERS}
{\footnote K Pascal fichiers;file of;Text;BlockRead;Assign;Reset;Rewrite;Read;Write;Eof}
\b\fs24 FICHIERS \b0\fs20\par
\par
\par
\b 13.1 Fichiers typed \b0\par
\par
{\f1   type TEnreg = record n: Integer; nom: string[40] end;}\par
{\f1   var f: file of TEnreg;}\par
{\f1       r: TEnreg;}\par
\par
{\f1   Assign(f, 'data.dat');}\par
{\f1   Rewrite(f);             \{ creation \}}\par
{\f1   Write(f, r);}\par
{\f1   Close(f);}\par
\par
{\f1   Reset(f);               \{ ouverture lecture/ecriture \}}\par
{\f1   while not Eof(f) do Read(f, r);}\par
{\f1   Close(f);}\par
\par
\par
\b 13.2 Fichiers texte \b0\par
\par
{\f1   var f: Text;}\par
{\f1   Assign(f, 'rapport.txt');}\par
{\f1   Rewrite(f);}\par
{\f1   WriteLn(f, 'Ligne 1');}\par
{\f1   Close(f);}\par
\par
{\f1   Reset(f);}\par
{\f1   while not Eof(f) do begin}\par
{\f1     ReadLn(f, ligne);}\par
{\f1     WriteLn(ligne)}\par
{\f1   end;}\par
{\f1   Close(f);}\par
\par
\par
\b 13.3 Fichiers non typed \b0\par
\par
{\f1   var f: file;}\par
{\f1   Assign(f, 'image.bin');}\par
{\f1   Reset(f, 1);            \{ taille de bloc = 1 octet \}}\par
{\f1   BlockRead(f, buf, n, lus);}\par
{\f1   Close(f);}\par
\par
\par
\b 13.4 Fonctions I/O \b0\par
\par
{\f1   Eof(f)         fin de fichier}\par
{\f1   Eoln(f)        fin de ligne (text)}\par
{\f1   Seek(f, pos)   positionnement (typed/non-typed)}\par
{\f1   FilePos(f)     position courante}\par
{\f1   FileSize(f)    taille en enregistrements}\par
{\f1   IOResult       code d'erreur (avec \{$I-\})}\par
{\f1   Erase(f)       supprimer fichier}\par
{\f1   Rename(f, s)   renommer}\par
\par
\par
\par
