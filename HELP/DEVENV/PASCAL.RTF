{\footnote # IDH_PASCAL_09}
{\footnote $ Pascal - TABLEAUX}
{\footnote K Pascal tableaux;array;statiques;dynamiques;SetLength;open array}
\b\fs24 TABLEAUX \b0\fs20\par
\par
\par
\b 9.1 Tableaux statiques \b0\par
\par
{\f1   var}\par
{\f1     v: array[1..10] of Integer;}\par
{\f1     m: array[1..3, 1..4] of Real;}\par
{\f1     Mots: array['A'..'Z'] of string;}\par
\par
Acces : v[i], m[i, j] ou m[i][j].\par
\par
\par
\b 9.2 Tableaux dynamiques (FPC / Delphi) \b0\par
\par
{\f1   var t: array of Integer;}\par
{\f1   begin}\par
{\f1     SetLength(t, 100);     \{ allocation \}}\par
{\f1     t[0] := 42;}\par
{\f1     SetLength(t, 0);       \{ liberation \}}\par
{\f1   end;}\par
\par
Pour tableaux 2D dynamiques : array of array of T.\par
\par
\par
\b 9.3 Constantes tableaux \b0\par
\par
{\f1   const}\par
{\f1     Jours: array[1..7] of string = (}\par
{\f1       'Lundi', 'Mardi', 'Mercredi', 'Jeudi',}\par
{\f1       'Vendredi', 'Samedi', 'Dimanche');}\par
\par
\par
\b 9.4 Open arrays (parametre tableau ouvert) \b0\par
\par
{\f1   procedure Sum(const v: array of Integer): Integer;}\par
{\f1   var i, s: Integer;}\par
{\f1   begin}\par
{\f1     s := 0;}\par
{\f1     for i := Low(v) to High(v) do s := s + v[i];}\par
{\f1     Sum := s}\par
{\f1   end;}\par
\par
\par
\par
