{\f1   StrToInt(s)             FPC/Delphi}\par
{\f1   FloatToStr(x)           FPC/Delphi}\par
{\f1   StrToFloat(s)           FPC/Delphi}\par
{\f1   Format('%d %s', [n,s])  FPC/Delphi}\par
\par
\par
\par
