{\footnote # IDH_PASCAL_06}
{\footnote $ Pascal - OPERATEURS ET EXPRESSIONS}
{\footnote K Pascal operateurs;arithmetique;relationnel;logique;ensemble;chaine;div;mod;shl;shr;precedence}
\b\fs24 OPERATEURS ET EXPRESSIONS \b0\fs20\par
\par
\par
\b 6.1 Operateurs arithmetiques \b0\par
\par
{\f1   +    addition          a + b}\par
{\f1   -    soustraction      a - b   (ou unaire -a)}\par
{\f1   *    multiplication    a * b}\par
{\f1   /    division reelle   a / b     (toujours Real)}\par
{\f1   div  division entiere  a div b}\par
{\f1   mod  modulo            a mod b}\par
\par
\par
\b 6.2 Operateurs relationnels \b0\par
\par
{\f1   =     egalite}\par
{\f1   <>    difference}\par
{\f1   <     inferieur}\par
{\f1   >     superieur}\par
{\f1   <=    inferieur ou egal}\par
{\f1   >=    superieur ou egal}\par
{\f1   in    appartenance a un ensemble}\par
\par
Tous renvoient un Boolean.\par
\par
\par
\b 6.3 Operateurs logiques / bit a bit \b0\par
\par
Sur Boolean : court-circuit selon $B+/$B-.\par
Sur entiers : operations bit a bit.\par
\par
{\f1   and    ET     a and b}\par
{\f1   or     OU     a or b}\par
{\f1   xor    OU exclusif}\par
{\f1   not    NON    not a}\par
{\f1   shl    decalage gauche  a shl n}\par
{\f1   shr    decalage droite  a shr n}\par
\par
\par
\b 6.4 Operateurs sur ensembles \b0\par
\par
{\f1   +     union           [1,2] + [3,4]   ->  [1..4]}\par
{\f1   -     difference      [1..5] - [2,4]  ->  [1,3,5]}\par
{\f1   *     intersection    [1..5] * [3..8] ->  [3,4,5]}\par
{\f1   <=    inclusion       A <= B  (A sous-ensemble de B)}\par
{\f1   >=    inclusion inverse}\par
{\f1   in    appartenance    x in [1,3,5]}\par
\par
\par
\b 6.5 Operateur de chaine \b0\par
\par
{\f1   +     concatenation   'Hello, ' + 'World'}\par
\par
\par
\b 6.6 Affectation \b0\par
\par
{\f1   :=    affectation     i := 10;}\par
\par
(Note : '=' est strictement le test d'egalite.)\par
\par
\par
\b 6.7 Precedence (de la plus haute a la plus basse) \b0\par
\par
{\f1   1.  not, @, +unaire, -unaire}\par
{\f1   2.  *, /, div, mod, and, shl, shr}\par
{\f1   3.  +, -, or, xor}\par
{\f1   4.  =, <>, <, >, <=, >=, in}\par
\par
\par
\par
