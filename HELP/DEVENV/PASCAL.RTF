{\footnote # IDH_PASCAL_18}
{\footnote $ Pascal - EXCEPTIONS}
{\footnote K Pascal exceptions;try;except;finally;raise;Exception;EConvertError}
\b\fs24 EXCEPTIONS \b0\fs20\par
\par
\par
\b 18.1 try/except \b0\par
\par
{\f1   try}\par
{\f1     valeur := StrToInt(s);}\par
{\f1   except}\par
{\f1     on E: EConvertError do}\par
{\f1       WriteLn('Format invalide: ', E.Message);}\par
{\f1     on E: Exception do}\par
{\f1       WriteLn('Erreur: ', E.Message);}\par
{\f1   end;}\par
\par
\par
\b 18.2 try/finally \b0\par
\par
{\f1   L := TList.Create;}\par
{\f1   try}\par
{\f1     L.Add(...);}\par
{\f1     ...}\par
{\f1   finally}\par
{\f1     L.Free;}\par
{\f1   end;}\par
\par
\par
\b 18.3 Lever une exception \b0\par
\par
{\f1   raise EConvertError.Create('Donnee invalide');}\par
\par
\par
\b 18.4 Combinaison \b0\par
\par
{\f1   try}\par
{\f1     try}\par
{\f1       ...}\par
{\f1     except}\par
{\f1       on E: Exception do begin}\par
{\f1         Log(E.Message);}\par
{\f1         raise;          \{ re-lever la meme exception \}}\par
{\f1       end;}\par
{\f1     end;}\par
{\f1   finally}\par
{\f1     Cleanup;}\par
{\f1   end;}\par
\par
\par
\par
