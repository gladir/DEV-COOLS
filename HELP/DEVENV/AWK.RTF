\page

{\footnote # IDH_AWK_10}
{\footnote $ AWK - TABLEAUX ASSOCIATIFS}
{\footnote K AWK tableaux associatifs;in;delete}
\b\fs24 TABLEAUX ASSOCIATIFS \b0\fs20\par
\par
10.1 Generalites\par
\par
{\f1     Les tableaux AWK sont des collections associatives (tables de}\par
{\f1     hachage) ou les indices sont des chaines de caracteres. Ils}\par
{\f1     ne sont pas declares ; ils sont crees implicitement lors de}\par
{\f1     la premiere utilisation.}\par
\par
10.2 Affectation et acces\par
\par
{\f1         tab["cle"] = valeur}\par
{\f1         print tab["cle"]}\par
\par
{\f1     Un indice numerique est automatiquement converti en chaine :}\par
\par
{\f1         tab[1] = "premier"     # equivalent a tab["1"]}\par
\par
10.3 Test d'appartenance\par
\par
{\f1     L'operateur in teste si une cle existe dans un tableau sans}\par
{\f1     creer d'entree :}\par
\par
{\f1         if ("cle" in tab) print "existe"}\par
\par
10.4 Suppression\par
\par
{\f1     L'instruction delete supprime un element ou un tableau entier :}\par
\par
{\f1         delete tab["cle"]      # supprime un element}\par
{\f1         delete tab             # supprime tout le tableau}\par
\par
10.5 Parcours\par
\par
{\f1     La boucle for-in permet de parcourir toutes les cles d'un}\par
{\f1     tableau. L'ordre de parcours n'est pas garanti.}\par
\par
{\f1         for (cle in tab) \{}\par
{\f1             print cle, tab[cle]}\par
{\f1         \}}\par
\par
10.6 Tableaux multi-dimensionnels\par
\par
{\f1     AWK simule les tableaux multi-dimensionnels en concatenant}\par
{\f1     les indices avec SUBSEP (defaut : "\\034") :}\par
\par
{\f1         tab[i, j] = valeur     # equivalent a tab[i SUBSEP j]}\par
\par
{\f1     Le test d'appartenance utilise la meme syntaxe :}\par
\par
{\f1         if ((i, j) in tab) print tab[i, j]}\par
\par
10.7 Limitations AWK86\par
\par
{\f1     Chaque tableau peut contenir au maximum 64 paires cle-valeur}\par
{\f1     (MAX_HASH_PAIRS). Les cles sont des chaines de caracteres.}\par
\par
\par
