{\footnote # IDH_AWK_07}
{\footnote $ AWK - INSTRUCTIONS ET STRUCTURES DE CONTROLE}
{\footnote K AWK instructions;if;while;for;do;next;exit;getline}
\b\fs24 INSTRUCTIONS ET STRUCTURES DE CONTROLE \b0\fs20\par
\par
7.1 Instruction conditionnelle (if / else)\par
\par
{\f1     if (condition) instruction}\par
{\f1     if (condition) instruction else instruction}\par
\par
{\f1     Exemple :}\par
{\f1         if (NF > 3) \{}\par
{\f1             print "Beaucoup de champs"}\par
{\f1         \} else \{}\par
{\f1             print "Peu de champs"}\par
{\f1         \}}\par
\par
7.2 Boucle while\par
\par
{\f1     while (condition) instruction}\par
\par
{\f1     Exemple :}\par
{\f1         i = 1}\par
{\f1         while (i <= 10) \{}\par
{\f1             print i}\par
{\f1             i++}\par
{\f1         \}}\par
\par
7.3 Boucle do-while\par
\par
{\f1     do instruction while (condition)}\par
\par
{\f1     Exemple :}\par
{\f1         i = 1}\par
{\f1         do \{}\par
{\f1             print i}\par
{\f1             i++}\par
{\f1         \} while (i <= 10)}\par
\par
7.4 Boucle for (style C)\par
\par
{\f1     for (initialisation; condition; increment) instruction}\par
\par
{\f1     Exemple :}\par
{\f1         for (i = 1; i <= NF; i++) \{}\par
{\f1             print i, $i}\par
{\f1         \}}\par
\par
7.5 Boucle for-in (iteration sur un tableau)\par
\par
{\f1     for (variable in tableau) instruction}\par
\par
{\f1     L'ordre d'iteration n'est pas garanti.}\par
\par
{\f1     Exemple :}\par
{\f1         for (cle in tab) \{}\par
{\f1             print cle, tab[cle]}\par
{\f1         \}}\par
\par
7.6 Instructions de controle de boucle\par
\par
{\f1     break       Sortie immediate de la boucle englobante}\par
{\f1     continue    Passe a l'iteration suivante}\par
\par
{\f1     Exemple :}\par
{\f1         for (i = 1; i <= 100; i++) \{}\par
{\f1             if (i % 7 == 0) continue}\par
{\f1             if (i > 50) break}\par
{\f1             print i}\par
{\f1         \}}\par
\par
7.7 Instructions de controle de flux\par
\par
{\f1     next        Arrete le traitement de la ligne courante et}\par
{\f1                 passe a la ligne suivante}\par
{\f1     nextfile    Arrete le traitement du fichier courant et}\par
{\f1                 passe au fichier suivant}\par
{\f1     exit [code] Termine le programme avec le code de sortie}\par
{\f1                 optionnel (defaut : 0). Les blocs END sont}\par
{\f1                 executes avant la sortie.}\par
\par
{\f1     Exemple :}\par
{\f1         /^#/ \{ next \}          # ignorer les commentaires}\par
{\f1         NR > 1000 \{ exit 0 \}  # arreter apres 1000 lignes}\par
\par
7.8 Bloc d'instructions\par
\par
{\f1     Un bloc est une sequence d'instructions entre accolades :}\par
\par
{\f1         \{ instruction1; instruction2; ... \}}\par
\par
\par
