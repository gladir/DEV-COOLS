\page

{\footnote # IDH_AWK_12}
{\footnote $ AWK - EXPRESSIONS REGULIERES}
{\footnote K AWK expressions regulieres;regex;ERE}
\b\fs24 EXPRESSIONS REGULIERES \b0\fs20\par
\par
12.1 Syntaxe\par
\par
{\f1     Les expressions regulieres sont delimitees par des slashs :}\par
\par
{\f1         /motif/}\par
\par
12.2 Metacaracteres supportes\par
\par
{\f1         .       N'importe quel caractere}\par
{\f1         ^       Debut de chaine}\par
{\f1         $       Fin de chaine}\par
{\f1         *       Zero ou plus du caractere precedent}\par
{\f1         +       Un ou plus du caractere precedent}\par
{\f1         ?       Zero ou un du caractere precedent}\par
{\f1         [...]   Classe de caracteres}\par
{\f1         [^...]  Classe de caracteres inversee}\par
{\f1         |       Alternance (ou)}\par
{\f1         (...)   Groupement}\par
{\f1         \\       Echappement du caractere suivant}\par
\par
12.3 Classes de caracteres\par
\par
{\f1         [abc]       a, b ou c}\par
{\f1         [a-z]       Lettre minuscule}\par
{\f1         [A-Z]       Lettre majuscule}\par
{\f1         [0-9]       Chiffre}\par
{\f1         [a-zA-Z]    Lettre quelconque}\par
{\f1         [^0-9]      Tout sauf un chiffre}\par
\par
12.4 Utilisation dans les motifs\par
\par
{\f1     Comme motif de regle :}\par
{\f1         /^[0-9]/ \{ print "Commence par un chiffre" \}}\par
\par
{\f1     Avec les operateurs de correspondance :}\par
{\f1         $1 ~ /^[A-Z]/ \{ print "Majuscule" \}}\par
\par
{\f1     Dans les fonctions de chaines :}\par
{\f1         gsub(/[[:space:]]+/, " ")}\par
{\f1         if (match($0, /[0-9]+/)) print RSTART}\par
\par
\par
