{\footnote # IDH_AWK_03}
{\footnote $ AWK - CONVENTIONS LEXICALES}
{\footnote K AWK lexical;identificateurs;commentaires;litteraux}
\b\fs24 CONVENTIONS LEXICALES \b0\fs20\par
\par
3.1 Commentaires\par
{\f1     Un commentaire commence par le caractere # et s'etend jusqu'a}\par
{\f1     la fin de la ligne :}\par
\par
{\f1         # Ceci est un commentaire}\par
{\f1         x = 42  # commentaire en fin de ligne}\par
\par
3.2 Identificateurs\par
{\f1     Un identificateur commence par une lettre (a-z, A-Z) ou un}\par
{\f1     underscore (_), suivi de lettres, chiffres (0-9) ou}\par
{\f1     underscores. Les identificateurs sont sensibles a la casse.}\par
\par
{\f1     Exemples : x  total  my_var  NR  _temp  compteur2}\par
\par
3.3 Mots-cles reserves\par
{\f1     Les mots-cles suivants sont reserves et ne peuvent pas etre}\par
{\f1     utilises comme noms de variables ou de fonctions :}\par
\par
{\f1         BEGIN       END         BEGINFILE}\par
{\f1         break       continue    delete}\par
{\f1         do          else        exit}\par
{\f1         for         function    getline}\par
{\f1         if          in          next}\par
{\f1         nextfile    print       printf}\par
{\f1         return      while}\par
\par
3.4 Chaines de caracteres\par
{\f1     Les chaines sont delimitees par des guillemets doubles :}\par
\par
{\f1         "Bonjour le monde"}\par
{\f1         ""}\par
{\f1         "Ligne 1\\nLigne 2"}\par
\par
{\f1     Sequences d'echappement supportees :}\par
{\f1       \\n  saut de ligne           \\t  tabulation horizontale}\par
{\f1       \\r  retour chariot          \\\\  backslash}\par
{\f1       \\"  guillemet double        \\a  alerte (bip)}\par
{\f1       \\b  retour arriere          \\f  saut de page}\par
{\f1       \\v  tabulation verticale    \\0  octet nul}\par
{\f1       \\/  slash (dans les regex)}\par
\par
3.5 Litteraux numeriques\par
{\f1     Entiers decimaux    : 0, 42, 255, 32767}\par
{\f1     Entiers octaux      : 0377 (prefixe 0)}\par
{\f1     Entiers hexadecimaux: 0xFF, 0x1A (prefixe 0x ou 0X)}\par
{\f1     Flottants           : 3.14, 1.5e3, 2.0E-4}\par
\par
{\f1     Limitation AWK86 : les nombres sont stockes en entiers signes}\par
{\f1     16 bits (-32768 a 32767). Les litteraux flottants sont tronques}\par
{\f1     en entiers.}\par
\par
3.6 Expressions regulieres\par
{\f1     Les expressions regulieres sont delimitees par des slashs :}\par
\par
{\f1         /motif/}\par
{\f1         /^debut/}\par
{\f1         /fin$/}\par
{\f1         /[0-9]+/}\par
\par
\par
