{\footnote # IDH_AWK_09}
{\footnote $ AWK - FONCTIONS UTILISATEUR}
{\footnote K AWK fonctions utilisateur;function;return}
\b\fs24 FONCTIONS UTILISATEUR \b0\fs20\par
\par
9.1 Declaration\par
\par
{\f1     Les fonctions utilisateur sont declarees avec le mot-cle}\par
{\f1     function :}\par
\par
{\f1         function nom(param1, param2, ...) \{}\par
{\f1             corps}\par
{\f1             return valeur}\par
{\f1         \}}\par
\par
{\f1     Les fonctions peuvent etre declarees n'importe ou dans le}\par
{\f1     programme (avant ou apres leur utilisation).}\par
\par
9.2 Parametres\par
\par
{\f1     Les parametres sont passes par valeur. Le nombre maximum}\par
{\f1     de parametres est de 32 (MAX_PARAM).}\par
\par
{\f1     Les variables locales sont declarees comme parametres}\par
{\f1     supplementaires (convention AWK standard) :}\par
\par
{\f1         function ma_fonction(param1, param2,    i, j, temp) \{}\par
{\f1             # i, j et temp sont des variables locales}\par
{\f1         \}}\par
\par
9.3 Valeur de retour\par
\par
{\f1     L'instruction return termine la fonction et retourne une}\par
{\f1     valeur optionnelle. Si return est omis ou sans valeur, la}\par
{\f1     fonction retourne 0.}\par
\par
{\f1         function carre(x) \{}\par
{\f1             return x * x}\par
{\f1         \}}\par
\par
9.4 Recursivite\par
\par
{\f1     Les fonctions peuvent s'appeler elles-memes recursivement.}\par
\par
{\f1         function factorielle(n) \{}\par
{\f1             if (n <= 1) return 1}\par
{\f1             return n * factorielle(n - 1)}\par
{\f1         \}}\par
\par
{\f1         function fibonacci(n) \{}\par
{\f1             if (n <= 1) return n}\par
{\f1             return fibonacci(n - 1) + fibonacci(n - 2)}\par
{\f1         \}}\par
\par
9.5 Portee des variables\par
\par
{\f1     Les variables dans AWK sont globales par defaut. Les seules}\par
{\f1     variables locales sont les parametres de la fonction (y}\par
{\f1     compris les parametres supplementaires servant de locales).}\par
\par
\par
