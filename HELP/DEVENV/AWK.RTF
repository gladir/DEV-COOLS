{\footnote # IDH_AWK_08}
{\footnote $ AWK - FONCTIONS PREDEFINIES}
{\footnote K AWK fonctions predefinies;length;substr;split;sprintf;sub;gsub}
\b\fs24 FONCTIONS PREDEFINIES \b0\fs20\par
\par
8.1 Fonctions de chaines\par
\par
{\f1     length([s])}\par
{\f1         Retourne la longueur de la chaine s.}\par
{\f1         Sans argument, retourne la longueur de $0.}\par
\par
{\f1         print length("Bonjour")     # 7}\par
\par
{\f1     substr(s, debut [, longueur])}\par
{\f1         Retourne une sous-chaine de s commencant a la position}\par
{\f1         debut (1-base). Si longueur est omise, retourne jusqu'a}\par
{\f1         la fin de la chaine.}\par
\par
{\f1         print substr("ABCDEF", 2, 3)   # BCD}\par
\par
{\f1     index(s, sous_chaine)}\par
{\f1         Retourne la position de la premiere occurrence de}\par
{\f1         sous_chaine dans s (1-base). Retourne 0 si non trouve.}\par
\par
{\f1         print index("Bonjour", "jour")  # 4}\par
\par
{\f1     split(s, tableau [, separateur])}\par
{\f1         Decoupe la chaine s en elements stockes dans tableau,}\par
{\f1         en utilisant separateur (defaut : FS). Retourne le}\par
{\f1         nombre d'elements.}\par
\par
{\f1         n = split("a:b:c", arr, ":")}\par
{\f1         # arr[1]="a", arr[2]="b", arr[3]="c", n=3}\par
\par
{\f1     sub(regex, remplacement [, cible])}\par
{\f1         Remplace la premiere occurrence de regex dans cible}\par
{\f1         (defaut : $0) par remplacement. Retourne le nombre}\par
{\f1         de substitutions effectuees (0 ou 1).}\par
\par
{\f1         sub(/ancien/, "nouveau")}\par
\par
{\f1     gsub(regex, remplacement [, cible])}\par
{\f1         Remplace toutes les occurrences de regex dans cible}\par
{\f1         (defaut : $0) par remplacement. Retourne le nombre}\par
{\f1         de substitutions effectuees.}\par
\par
{\f1         gsub(/[ \\t]+/, " ")     # compresser les espaces}\par
\par
{\f1     match(s, regex)}\par
{\f1         Recherche la premiere occurrence de regex dans s.}\par
{\f1         Retourne la position de debut (1-base) ou 0 si non}\par
{\f1         trouve. Met a jour RSTART et RLENGTH.}\par
\par
{\f1         if (match($0, /[0-9]+/))}\par
{\f1             print substr($0, RSTART, RLENGTH)}\par
\par
{\f1     tolower(s)}\par
{\f1         Retourne une copie de s avec toutes les lettres}\par
{\f1         majuscules converties en minuscules.}\par
\par
{\f1         print tolower("BONJOUR")    # bonjour}\par
\par
{\f1     toupper(s)}\par
{\f1         Retourne une copie de s avec toutes les lettres}\par
{\f1         minuscules converties en majuscules.}\par
\par
{\f1         print toupper("bonjour")    # BONJOUR}\par
\par
{\f1     sprintf(format, expr, ...)}\par
{\f1         Retourne une chaine formatee selon le format printf.}\par
\par
{\f1         s = sprintf("%-10s %5d", nom, age)}\par
\par
8.2 Fonctions mathematiques\par
\par
{\f1     int(x)}\par
{\f1         Retourne la partie entiere de x (troncature vers zero).}\par
\par
{\f1         print int(3.9)      # 3}\par
{\f1         print int(-3.9)     # -3}\par
\par
{\f1     sqrt(x)}\par
{\f1         Retourne la racine carree de x.}\par
\par
{\f1         print sqrt(144)     # 12}\par
\par
{\f1     sin(x)}\par
{\f1         Retourne le sinus de x (x en radians).}\par
\par
{\f1     cos(x)}\par
{\f1         Retourne le cosinus de x (x en radians).}\par
\par
{\f1     atan2(y, x)}\par
{\f1         Retourne l'arctangente de y/x en radians, dans}\par
{\f1         l'intervalle [-pi, pi].}\par
\par
{\f1     exp(x)}\par
{\f1         Retourne e eleve a la puissance x (approximation).}\par
\par
{\f1     log(x)}\par
{\f1         Retourne le logarithme naturel de x (approximation).}\par
\par
{\f1     rand()}\par
{\f1         Retourne un nombre pseudo-aleatoire entre 0 et 1.}\par
\par
{\f1     srand([graine])}\par
{\f1         Initialise le generateur de nombres aleatoires avec}\par
{\f1         la graine specifiee. Sans argument, utilise l'heure}\par
{\f1         courante. Retourne la graine precedente.}\par
\par
{\f1         Exemple :}\par
{\f1             BEGIN \{ srand() \}}\par
{\f1             \{ print int(rand() * 100) \}}\par
\par
8.3 Fonctions d'entree/sortie\par
\par
{\f1     print [expr, ...]}\par
{\f1         Affiche les expressions separees par OFS, suivies de}\par
{\f1         ORS. Sans argument, affiche $0.}\par
\par
{\f1         print $1, $2, $3}\par
\par
{\f1     printf(format, expr, ...)}\par
{\f1         Affichage formate. Les specificateurs de format suivants}\par
{\f1         sont supportes :}\par
{\f1           %d    entier decimal}\par
{\f1           %s    chaine de caracteres}\par
{\f1           %x    entier hexadecimal}\par
{\f1           %o    entier octal}\par
{\f1           %c    caractere}\par
{\f1           %%    caractere pourcentage litteral}\par
{\f1         Modificateurs : largeur de champ, alignement a gauche (-)}\par
\par
{\f1         printf("%-20s %5d\\n", nom, valeur)}\par
\par
{\f1     getline [var]}\par
{\f1         Lit la prochaine ligne d'entree. Sans argument, met a}\par
{\f1         jour $0 et les champs $1..$NF. Avec un argument, stocke}\par
{\f1         la ligne dans var sans modifier $0.}\par
\par
{\f1         getline ligne < "fichier.txt"}\par
\par
{\f1     close(fichier)}\par
{\f1         Ferme le fichier ou la commande ouverte precedemment.}\par
\par
{\f1     fflush([fichier])}\par
{\f1         Vide le tampon de sortie du fichier specifie.}\par
\par
\par
