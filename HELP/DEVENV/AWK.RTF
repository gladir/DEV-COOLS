{\footnote # IDH_AWK_11}
{\footnote $ AWK - ENTREES / SORTIES ET REDIRECTIONS}
{\footnote K AWK entrees sorties;print;printf;redirection;pipe}
\b\fs24 ENTREES / SORTIES ET REDIRECTIONS \b0\fs20\par
\par
11.1 Entree standard\par
\par
{\f1     Par defaut, AWK lit l'entree ligne par ligne depuis stdin ou}\par
{\f1     depuis les fichiers passes en arguments sur la ligne de}\par
{\f1     commande. Chaque ligne est decoupee en champs selon FS.}\par
\par
11.2 Fichiers multiples\par
\par
{\f1     AWK traite les fichiers d'entree sequentiellement. Les}\par
{\f1     variables FILENAME et FNR permettent de distinguer les}\par
{\f1     fichiers.}\par
\par
{\f1         \{ print FILENAME, FNR, $0 \}}\par
\par
11.3 Instruction getline\par
\par
{\f1     getline permet de lire une ligne supplementaire :}\par
\par
{\f1         getline              # lit dans $0 depuis l'entree courante}\par
{\f1         getline var          # lit dans var depuis l'entree courante}\par
{\f1         getline var < "f"    # lit dans var depuis le fichier "f"}\par
\par
11.4 Redirection de sortie\par
\par
{\f1     La sortie de print et printf peut etre redirigee :}\par
\par
{\f1         print "texte" > "fichier.txt"     # ecriture (ecrasement)}\par
{\f1         print "texte" >> "fichier.txt"    # ajout (append)}\par
\par
11.5 Instruction close\par
\par
{\f1     Les fichiers ouverts doivent etre fermes avec close() :}\par
\par
{\f1         close("fichier.txt")}\par
\par
\par
