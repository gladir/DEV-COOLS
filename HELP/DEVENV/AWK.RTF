{\footnote # IDH_AWK_06}
{\footnote $ AWK - OPERATEURS}
{\footnote K AWK operateurs;arithmetiques;comparaison;logiques;chaine}
\b\fs24 OPERATEURS \b0\fs20\par
\par
6.1 Operateurs arithmetiques\par
{\f1         +       addition}\par
{\f1         -       soustraction}\par
{\f1         *       multiplication}\par
{\f1         /       division entiere}\par
{\f1         %       modulo (reste de la division)}\par
{\f1         ^       exponentiation (puissance)}\par
\par
{\f1     Exemple :}\par
{\f1         \{ print 2 ^ 10 \}       # affiche 1024}\par
{\f1         \{ print 17 % 5 \}       # affiche 2}\par
\par
6.2 Operateurs d'affectation\par
{\f1         =       affectation simple}\par
{\f1         +=      addition et affectation}\par
{\f1         -=      soustraction et affectation}\par
{\f1         *=      multiplication et affectation}\par
{\f1         /=      division et affectation}\par
{\f1         %=      modulo et affectation}\par
{\f1         ^=      exponentiation et affectation}\par
\par
{\f1     Exemple :}\par
{\f1         \{ total += $1 \}}\par
\par
6.3 Operateurs d'increment et de decrement\par
{\f1         ++      pre-increment}\par
{\f1         --      pre-decrement}\par
\par
{\f1     Exemple :}\par
{\f1         \{ ++compteur \}}\par
\par
6.4 Operateurs de comparaison\par
{\f1         ==      egal a}\par
{\f1         !=      different de}\par
{\f1         <       inferieur a}\par
{\f1         <=      inferieur ou egal a}\par
{\f1         >       superieur a}\par
{\f1         >=      superieur ou egal a}\par
\par
6.5 Operateurs logiques\par
{\f1         &&      ET logique (evaluation court-circuit)}\par
{\f1         ||      OU logique (evaluation court-circuit)}\par
{\f1         !       NON logique (negation)}\par
\par
{\f1     Exemple :}\par
{\f1         NR > 5 && NR < 20 \{ print \}}\par
\par
6.6 Operateurs de correspondance de motifs\par
{\f1         ~       correspond au motif (match)}\par
{\f1         !~      ne correspond pas au motif (not match)}\par
\par
{\f1     Exemple :}\par
{\f1         $1 ~ /^[A-Z]/ \{ print "Majuscule:", $1 \}}\par
{\f1         $0 !~ /error/ \{ print "OK:", $0 \}}\par
\par
6.7 Operateur de reference de champ\par
{\f1         $       reference de champ ($0, $1, $NF, $expr)}\par
\par
{\f1     Exemple :}\par
{\f1         \{ print $(NF-1) \}      # avant-dernier champ}\par
\par
6.8 Operateur ternaire\par
{\f1         condition ? valeur_vraie : valeur_fausse}\par
\par
{\f1     Exemple :}\par
{\f1         \{ print (x > 0 ? "positif" : "negatif") \}}\par
\par
6.9 Operateur d'appartenance a un tableau\par
{\f1         cle in tableau}\par
\par
{\f1     Exemple :}\par
{\f1         if ("nom" in tab) print tab["nom"]}\par
\par
6.10 Concatenation de chaines\par
{\f1      La concatenation est implicite par juxtaposition :}\par
\par
{\f1         \{ s = "Hello" " " "World" ; print s \}}\par
\par
6.11 Operateurs unaires\par
{\f1         +       plus unaire}\par
{\f1         -       moins unaire (negation)}\par
\par
6.12 Precedence des operateurs (du plus faible au plus fort)\par
{\f1       1.  = += -= *= /= %= ^=        (affectation)}\par
{\f1       2.  ? :                         (ternaire)}\par
{\f1       3.  ||                          (OU logique)}\par
{\f1       4.  &&                          (ET logique)}\par
{\f1       5.  in                          (appartenance tableau)}\par
{\f1       6.  ~ !~                        (correspondance motif)}\par
{\f1       7.  == != < <= > >=             (comparaison)}\par
{\f1       8.  concatenation               (juxtaposition)}\par
{\f1       9.  + -                         (addition, soustraction)}\par
{\f1      10.  * / %                       (multiplication, division)}\par
{\f1      11.  ^                           (exponentiation, associatif a droite)}\par
{\f1      12.  ! + - ++ -- $               (unaires et reference champ)}\par
\par
\par
