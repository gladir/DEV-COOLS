{\footnote # IDH_ASM6502_04}
{\footnote $ Assembleur 6502 - JEU D'INSTRUCTIONS (OPCODES)}
{\footnote K Assembleur 6502 jeu instructions opcodes;LDA LDX LDY STA STX STY;TAX TAY TXA TYA TSX TXS;ADC SBC INC INX INY DEC DEX DEY;AND ORA EOR;ASL LSR ROL ROR;CMP CPX CPY BIT;BCC BCS BEQ BNE BMI BPL BVC BVS;JMP JSR RTS RTI BRK;PHA PLA PHP PLP;CLC SEC CLD SED CLI SEI CLV;NOP}
\b\fs24 JEU D'INSTRUCTIONS (OPCODES) \b0\fs20\par
\par
\par
\b 4.1 Vue d'ensemble \b0\par
\par
{\f1   Le 6502 possede un jeu de 56 instructions officielles. Malgre}\par
{\f1   ce nombre reduit, le processeur est capable de realiser des}\par
{\f1   programmes complets et performants grace a l'utilisation}\par
{\f1   combinee de ses modes d'adressage varies.}\par
\par
{\f1   Chaque instruction est codee sur un octet (opcode). Selon le}\par
{\f1   mode d'adressage, l'instruction complete occupe 1, 2 ou 3}\par
{\f1   octets en memoire. Le nombre total d'opcodes valides est de}\par
{\f1   151 (sur 256 combinaisons possibles).}\par
\par
{\f1   Le jeu d'instructions se divise en categories :}\par
{\f1     - Transfert de donnees (chargement, stockage, transfert}\par
{\f1       entre registres)}\par
{\f1     - Arithmetique (addition, soustraction, increment, decrement)}\par
{\f1     - Operations logiques (ET, OU, OU exclusif)}\par
{\f1     - Decalages et rotations}\par
{\f1     - Comparaison et test de bits}\par
{\f1     - Branchements conditionnels}\par
{\f1     - Sauts et appels de sous-programmes}\par
{\f1     - Operations de pile}\par
{\f1     - Controle des drapeaux}\par
{\f1     - Instruction NOP}\par
\par
{\f1   Conventions de notation utilisees dans cette section :}\par
{\f1     A       : Accumulateur}\par
{\f1     X       : Registre d'index X}\par
{\f1     Y       : Registre d'index Y}\par
{\f1     SP      : Pointeur de pile}\par
{\f1     PC      : Compteur programme}\par
{\f1     P       : Registre d'etat du processeur}\par
{\f1     M       : Contenu de l'emplacement memoire adresse}\par
{\f1     nn      : Valeur 8 bits (operande immediat ou adresse page zero)}\par
{\f1     nnnn    : Valeur 16 bits (adresse absolue)}\par
{\f1     [CCR]   : Drapeaux affectes (N, V, -, B, D, I, Z, C)}\par
{\f1     ->      : Affectation (resultat vers destination)}\par
{\f1     $       : Prefixe hexadecimal}\par
{\f1     #       : Prefixe immediat (la valeur elle-meme, pas une adresse)}\par
\par
{\f1   Pour chaque instruction, les informations suivantes sont donnees :}\par
{\f1     - Mnemonique et description}\par
{\f1     - Modes d'adressage disponibles avec l'opcode correspondant}\par
{\f1     - Taille de l'instruction en octets}\par
{\f1     - Nombre de cycles d'execution}\par
{\f1     - Drapeaux affectes}\par
\par
\par
\b 4.2 Instructions de transfert de donnees \b0\par
\par
{\f1   Ces instructions copient des donnees entre les registres et la}\par
{\f1   memoire, ou entre les registres eux-memes.}\par
\par
{\f1   4.2.1 LDA - Load Accumulator (Charger l'accumulateur)}\par
\par
{\f1   Charge une valeur dans l'accumulateur A.}\par
\par
{\f1   Operation : A <- M}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
{\f1     N = 1 si le bit 7 du resultat est 1}\par
{\f1     Z = 1 si le resultat est 0}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          LDA #$nn      $A9     2       2}\par
{\f1     Page zero         LDA $nn       $A5     2       3}\par
{\f1     Page zero,X       LDA $nn,X     $B5     2       4}\par
{\f1     Absolu            LDA $nnnn     $AD     3       4}\par
{\f1     Absolu,X          LDA $nnnn,X   $BD     3       4(+1)}\par
{\f1     Absolu,Y          LDA $nnnn,Y   $B9     3       4(+1)}\par
{\f1     (Indirect,X)      LDA ($nn,X)   $A1     2       6}\par
{\f1     (Indirect),Y      LDA ($nn),Y   $B1     2       5(+1)}\par
\par
{\f1     (+1) = +1 cycle si franchissement de page (page boundary crossing)}\par
\par
{\f1   Exemples :}\par
{\f1     LDA #$42          ; A := $42 (immediat)}\par
{\f1     LDA $80           ; A := contenu de l'adresse $0080}\par
{\f1     LDA $2000         ; A := contenu de l'adresse $2000}\par
{\f1     LDA $2000,X       ; A := contenu de l'adresse $2000+X}\par
{\f1     LDA ($80),Y       ; A := contenu de l'adresse [($80)]+Y}\par
\par
{\f1   4.2.2 LDX - Load X Register (Charger le registre X)}\par
\par
{\f1   Charge une valeur dans le registre d'index X.}\par
\par
{\f1   Operation : X <- M}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          LDX #$nn      $A2     2       2}\par
{\f1     Page zero         LDX $nn       $A6     2       3}\par
{\f1     Page zero,Y       LDX $nn,Y     $B6     2       4}\par
{\f1     Absolu            LDX $nnnn     $AE     3       4}\par
{\f1     Absolu,Y          LDX $nnnn,Y   $BE     3       4(+1)}\par
\par
{\f1   Exemples :}\par
{\f1     LDX #$00          ; X := 0}\par
{\f1     LDX $80           ; X := contenu de $0080}\par
{\f1     LDX Table,Y       ; X := contenu de Table+Y}\par
\par
{\f1   Remarque :}\par
{\f1     - LDX utilise Zero Page,Y (et non Zero Page,X), car indexer}\par
{\f1       le chargement de X par X serait un conflit logique}\par
\par
{\f1   4.2.3 LDY - Load Y Register (Charger le registre Y)}\par
\par
{\f1   Charge une valeur dans le registre d'index Y.}\par
\par
{\f1   Operation : Y <- M}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          LDY #$nn      $A0     2       2}\par
{\f1     Page zero         LDY $nn       $A4     2       3}\par
{\f1     Page zero,X       LDY $nn,X     $B4     2       4}\par
{\f1     Absolu            LDY $nnnn     $AC     3       4}\par
{\f1     Absolu,X          LDY $nnnn,X   $BC     3       4(+1)}\par
\par
{\f1   Exemples :}\par
{\f1     LDY #$09          ; Y := 9}\par
{\f1     LDY $80,X         ; Y := contenu de ($80+X) AND $FF}\par
{\f1     LDY Table,X       ; Y := contenu de Table+X}\par
\par
{\f1   4.2.4 STA - Store Accumulator (Stocker l'accumulateur)}\par
\par
{\f1   Stocke le contenu de l'accumulateur A en memoire.}\par
\par
{\f1   Operation : M <- A}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Page zero         STA $nn       $85     2       3}\par
{\f1     Page zero,X       STA $nn,X     $95     2       4}\par
{\f1     Absolu            STA $nnnn     $8D     3       4}\par
{\f1     Absolu,X          STA $nnnn,X   $9D     3       5}\par
{\f1     Absolu,Y          STA $nnnn,Y   $99     3       5}\par
{\f1     (Indirect,X)      STA ($nn,X)   $81     2       6}\par
{\f1     (Indirect),Y      STA ($nn),Y   $91     2       6}\par
\par
{\f1   Exemples :}\par
{\f1     STA $80           ; stocker A a l'adresse $0080}\par
{\f1     STA $2000         ; stocker A a l'adresse $2000}\par
{\f1     STA $0400,X       ; stocker A a l'adresse $0400+X}\par
{\f1     STA ($80),Y       ; stocker A a l'adresse [($80)]+Y}\par
\par
{\f1   Remarques :}\par
{\f1     - STA n'a pas de mode immediat (on ne peut pas stocker dans}\par
{\f1       une constante)}\par
{\f1     - Les modes indexes prennent toujours le meme nombre de}\par
{\f1       cycles, sans penalite de franchissement de page}\par
{\f1       (contrairement a LDA)}\par
\par
{\f1   4.2.5 STX - Store X Register (Stocker le registre X)}\par
\par
{\f1   Stocke le contenu du registre X en memoire.}\par
\par
{\f1   Operation : M <- X}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Page zero         STX $nn       $86     2       3}\par
{\f1     Page zero,Y       STX $nn,Y     $96     2       4}\par
{\f1     Absolu            STX $nnnn     $8E     3       4}\par
\par
{\f1   Exemples :}\par
{\f1     STX $80           ; stocker X a l'adresse $0080}\par
{\f1     STX $2000         ; stocker X a l'adresse $2000}\par
\par
{\f1   4.2.6 STY - Store Y Register (Stocker le registre Y)}\par
\par
{\f1   Stocke le contenu du registre Y en memoire.}\par
\par
{\f1   Operation : M <- Y}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Page zero         STY $nn       $84     2       3}\par
{\f1     Page zero,X       STY $nn,X     $94     2       4}\par
{\f1     Absolu            STY $nnnn     $8C     3       4}\par
\par
{\f1   Exemples :}\par
{\f1     STY $80           ; stocker Y a l'adresse $0080}\par
{\f1     STY $2000         ; stocker Y a l'adresse $2000}\par
\par
{\f1   4.2.7 Transferts entre registres}\par
\par
{\f1   Ces instructions copient une valeur d'un registre vers un autre.}\par
{\f1   Elles n'ont pas d'operande (mode implicite), occupent 1 octet et}\par
{\f1   s'executent en 2 cycles.}\par
\par
{\f1   TAX  ($AA)  : A -> X    Drapeaux : N, Z}\par
{\f1   TAY  ($A8)  : A -> Y    Drapeaux : N, Z}\par
{\f1   TXA  ($8A)  : X -> A    Drapeaux : N, Z}\par
{\f1   TYA  ($98)  : Y -> A    Drapeaux : N, Z}\par
{\f1   TSX  ($BA)  : SP -> X   Drapeaux : N, Z}\par
{\f1   TXS  ($9A)  : X -> SP   Drapeaux : aucun}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; Copier A dans X pour utiliser X comme index}\par
{\f1     TAX               ; X := A}\par
\par
{\f1     ; Sauvegarder le pointeur de pile dans X}\par
{\f1     TSX               ; X := SP}\par
\par
{\f1     ; Initialiser le pointeur de pile}\par
{\f1     LDX #$FF}\par
{\f1     TXS               ; SP := $FF (pile pleine)}\par
\par
{\f1     ; Echanger A et X (pas d'instruction directe)}\par
{\f1     TAX               ; sauver A dans X}\par
{\f1     ; ... (utiliser A pour autre chose)}\par
{\f1     TXA               ; restaurer A depuis X}\par
\par
{\f1   Remarques :}\par
{\f1     - TXS est la SEULE instruction de transfert qui ne modifie}\par
{\f1       pas les drapeaux. Ceci permet d'initialiser la pile sans}\par
{\f1       perturber l'etat des drapeaux.}\par
{\f1     - TSX transfere le pointeur de pile (8 bits) dans X.}\par
{\f1       Le pointeur de pile va de $00 a $FF, representant les}\par
{\f1       adresses $0100 a $01FF.}\par
{\f1     - Il n'existe pas d'instruction directe pour echanger deux}\par
{\f1       registres (pas de SWAP, EXG ou XCHG).}\par
\par
\par
\b 4.3 Instructions arithmetiques \b0\par
\par
{\f1   Le 6502 dispose d'instructions d'addition et de soustraction}\par
{\f1   avec retenue, ainsi que d'instructions d'increment et de}\par
{\f1   decrement.}\par
\par
{\f1   4.3.1 ADC - Add with Carry (Addition avec retenue)}\par
\par
{\f1   Ajoute la valeur de l'operande et du drapeau de retenue (C) a}\par
{\f1   l'accumulateur.}\par
\par
{\f1   Operation : A <- A + M + C}\par
\par
{\f1   Drapeaux affectes : N, V, Z, C}\par
{\f1     N = 1 si le bit 7 du resultat est 1}\par
{\f1     V = 1 si debordement signe (le resultat sort de -128..+127)}\par
{\f1     Z = 1 si le resultat est 0}\par
{\f1     C = 1 si le resultat depasse 255 (retenue sortante)}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          ADC #$nn      $69     2       2}\par
{\f1     Page zero         ADC $nn       $65     2       3}\par
{\f1     Page zero,X       ADC $nn,X     $75     2       4}\par
{\f1     Absolu            ADC $nnnn     $6D     3       4}\par
{\f1     Absolu,X          ADC $nnnn,X   $7D     3       4(+1)}\par
{\f1     Absolu,Y          ADC $nnnn,Y   $79     3       4(+1)}\par
{\f1     (Indirect,X)      ADC ($nn,X)   $61     2       6}\par
{\f1     (Indirect),Y      ADC ($nn),Y   $71     2       5(+1)}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; Addition simple 8 bits : A = $30 + $10}\par
{\f1     CLC               ; TOUJOURS effacer C avant une addition}\par
{\f1     LDA #$30}\par
{\f1     ADC #$10          ; A = $40, C = 0}\par
\par
{\f1     ; Addition 16 bits : resultat = $80/$81 + $82/$83}\par
{\f1     CLC               ; effacer la retenue}\par
{\f1     LDA $80           ; poids faible de la 1ere valeur}\par
{\f1     ADC $82           ; + poids faible de la 2e valeur}\par
{\f1     STA $84           ; stocker le poids faible du resultat}\par
{\f1     LDA $81           ; poids fort de la 1ere valeur}\par
{\f1     ADC $83           ; + poids fort + retenue de l'addition precedente}\par
{\f1     STA $85           ; stocker le poids fort du resultat}\par
\par
{\f1     ; Addition 8 bits avec retenue entrante}\par
{\f1     ; (par ex. pour une chaine d'additions multi-precision)}\par
{\f1     ADC $90           ; A = A + [$90] + C}\par
\par
{\f1   Mode decimal (BCD) :}\par
{\f1     Si le drapeau D est positionne (SED), ADC effectue une addition}\par
{\f1     en decimal code binaire (BCD). Chaque octet represente deux}\par
{\f1     chiffres decimaux (0-9 dans chaque quartet).}\par
\par
{\f1     SED               ; activer le mode BCD}\par
{\f1     CLC}\par
{\f1     LDA #$15          ; 15 en BCD}\par
{\f1     ADC #$27          ; + 27 en BCD}\par
{\f1     ; A = $42 (42 en BCD), C = 0}\par
{\f1     CLD               ; desactiver le mode BCD}\par
\par
{\f1   Remarques :}\par
{\f1     - Il faut TOUJOURS effacer C (CLC) avant la premiere addition}\par
{\f1       d'une sequence, sinon un '1' residuel dans C faussera le}\par
{\f1       resultat}\par
{\f1     - Le 6502 n'a PAS d'instruction ADD sans retenue. ADC est la}\par
{\f1       seule instruction d'addition.}\par
{\f1     - Le drapeau V (overflow) detecte les debordements en}\par
{\f1       arithmetique signee (complement a deux)}\par
{\f1     - Le comportement du drapeau N apres une ADC en mode BCD}\par
{\f1       est indetermine sur le 6502 NMOS. Le 65C02 (CMOS)}\par
{\f1       corrige ce comportement.}\par
\par
{\f1   4.3.2 SBC - Subtract with Carry (Soustraction avec retenue)}\par
\par
{\f1   Soustrait la valeur de l'operande et le complement du drapeau}\par
{\f1   de retenue (borrow) de l'accumulateur.}\par
\par
{\f1   Operation : A <- A - M - NOT(C)}\par
{\f1     (equivalent a : A <- A - M - (1 - C))}\par
\par
{\f1   Drapeaux affectes : N, V, Z, C}\par
{\f1     N = 1 si le bit 7 du resultat est 1}\par
{\f1     V = 1 si debordement signe}\par
{\f1     Z = 1 si le resultat est 0}\par
{\f1     C = 0 si emprunt (le resultat est negatif en non signe)}\par
{\f1     C = 1 si pas d'emprunt}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          SBC #$nn      $E9     2       2}\par
{\f1     Page zero         SBC $nn       $E5     2       3}\par
{\f1     Page zero,X       SBC $nn,X     $F5     2       4}\par
{\f1     Absolu            SBC $nnnn     $ED     3       4}\par
{\f1     Absolu,X          SBC $nnnn,X   $FD     3       4(+1)}\par
{\f1     Absolu,Y          SBC $nnnn,Y   $F9     3       4(+1)}\par
{\f1     (Indirect,X)      SBC ($nn,X)   $E1     2       6}\par
{\f1     (Indirect),Y      SBC ($nn),Y   $F1     2       5(+1)}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; Soustraction simple 8 bits : A = $50 - $10}\par
{\f1     SEC               ; TOUJOURS positionner C avant une soustraction}\par
{\f1     LDA #$50}\par
{\f1     SBC #$10          ; A = $40, C = 1 (pas d'emprunt)}\par
\par
{\f1     ; Soustraction 16 bits : resultat = $80/$81 - $82/$83}\par
{\f1     SEC               ; positionner la retenue (pas d'emprunt)}\par
{\f1     LDA $80           ; poids faible de la 1ere valeur}\par
{\f1     SBC $82           ; - poids faible de la 2e valeur}\par
{\f1     STA $84           ; stocker le poids faible du resultat}\par
{\f1     LDA $81           ; poids fort de la 1ere valeur}\par
{\f1     SBC $83           ; - poids fort - emprunt eventuel}\par
{\f1     STA $85           ; stocker le poids fort du resultat}\par
\par
{\f1     ; Negation (complement a deux) : A = 0 - A}\par
{\f1     EOR #$FF          ; complement a un}\par
{\f1     CLC}\par
{\f1     ADC #$01          ; + 1 = complement a deux}\par
\par
{\f1   Remarques :}\par
{\f1     - Il faut TOUJOURS positionner C (SEC) avant la premiere}\par
{\f1       soustraction d'une sequence (C=1 signifie "pas d'emprunt")}\par
{\f1     - Le sens du drapeau C est INVERSE par rapport a l'emprunt :}\par
{\f1       C=1 apres SBC signifie PAS d'emprunt (resultat >= 0)}\par
{\f1       C=0 apres SBC signifie emprunt (resultat < 0 en non signe)}\par
{\f1     - Le 6502 n'a PAS d'instruction SUB sans retenue}\par
{\f1     - En mode BCD (drapeau D), SBC effectue une soustraction}\par
{\f1       en decimal code binaire}\par
\par
{\f1   4.3.3 INC - Increment Memory (Incrementer la memoire)}\par
\par
{\f1   Incremente de 1 la valeur a l'emplacement memoire specifie.}\par
\par
{\f1   Operation : M <- M + 1}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Page zero         INC $nn       $E6     2       5}\par
{\f1     Page zero,X       INC $nn,X     $F6     2       6}\par
{\f1     Absolu            INC $nnnn     $EE     3       6}\par
{\f1     Absolu,X          INC $nnnn,X   $FE     3       7}\par
\par
{\f1   Exemples :}\par
{\f1     INC $80           ; incrementer le contenu de $0080}\par
{\f1     INC $2000         ; incrementer le contenu de $2000}\par
{\f1     INC $2000,X       ; incrementer le contenu de $2000+X}\par
\par
{\f1   Remarque :}\par
{\f1     - INC ne peut pas operer directement sur l'accumulateur A.}\par
{\f1       Pour incrementer A, utiliser CLC + ADC #$01 (ou INA sur}\par
{\f1       le 65C02 qui ajoute l'instruction INC A).}\par
{\f1     - INC ne modifie pas le drapeau C (retenue). Si la valeur}\par
{\f1       passe de $FF a $00, seul Z est positionne.}\par
\par
{\f1   4.3.4 INX - Increment X Register (Incrementer X)}\par
\par
{\f1   Incremente de 1 le registre X.}\par
\par
{\f1   Operation : X <- X + 1}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Opcode : $E8    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Exemple :}\par
{\f1     INX               ; X := X + 1}\par
\par
{\f1   4.3.5 INY - Increment Y Register (Incrementer Y)}\par
\par
{\f1   Incremente de 1 le registre Y.}\par
\par
{\f1   Operation : Y <- Y + 1}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Opcode : $C8    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Exemple :}\par
{\f1     INY               ; Y := Y + 1}\par
\par
{\f1   4.3.6 DEC - Decrement Memory (Decrementer la memoire)}\par
\par
{\f1   Decremente de 1 la valeur a l'emplacement memoire specifie.}\par
\par
{\f1   Operation : M <- M - 1}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Page zero         DEC $nn       $C6     2       5}\par
{\f1     Page zero,X       DEC $nn,X     $D6     2       6}\par
{\f1     Absolu            DEC $nnnn     $CE     3       6}\par
{\f1     Absolu,X          DEC $nnnn,X   $DE     3       7}\par
\par
{\f1   Exemples :}\par
{\f1     DEC $80           ; decrementer le contenu de $0080}\par
{\f1     DEC Compteur      ; decrementer la variable Compteur}\par
\par
{\f1   Remarque :}\par
{\f1     - Comme INC, DEC ne peut pas operer sur A directement.}\par
{\f1       Utiliser SEC + SBC #$01 (ou DEC A / DEA sur le 65C02).}\par
\par
{\f1   4.3.7 DEX - Decrement X Register (Decrementer X)}\par
\par
{\f1   Decremente de 1 le registre X.}\par
\par
{\f1   Operation : X <- X - 1}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Opcode : $CA    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Exemple :}\par
{\f1     ; Boucle simple avec X comme compteur}\par
{\f1     LDX #$10          ; X := 16}\par
{\f1   Boucle:}\par
{\f1     DEX               ; X := X - 1}\par
{\f1     BNE Boucle        ; boucler tant que X != 0}\par
\par
{\f1   4.3.8 DEY - Decrement Y Register (Decrementer Y)}\par
\par
{\f1   Decremente de 1 le registre Y.}\par
\par
{\f1   Operation : Y <- Y - 1}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Opcode : $88    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Exemple :}\par
{\f1     ; Boucle simple avec Y comme compteur}\par
{\f1     LDY #$08          ; Y := 8}\par
{\f1   Boucle:}\par
{\f1     DEY               ; Y := Y - 1}\par
{\f1     BNE Boucle        ; boucler tant que Y != 0}\par
\par
\par
\b 4.4 Instructions logiques \b0\par
\par
{\f1   Le 6502 dispose de trois operations logiques bit a bit qui}\par
{\f1   operent sur l'accumulateur A.}\par
\par
{\f1   4.4.1 AND - Logical AND (ET logique)}\par
\par
{\f1   Effectue un ET logique bit a bit entre l'accumulateur et}\par
{\f1   l'operande.}\par
\par
{\f1   Operation : A <- A AND M}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Table de verite :}\par
{\f1     A  M  Resultat}\par
{\f1     0  0     0}\par
{\f1     0  1     0}\par
{\f1     1  0     0}\par
{\f1     1  1     1}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          AND #$nn      $29     2       2}\par
{\f1     Page zero         AND $nn       $25     2       3}\par
{\f1     Page zero,X       AND $nn,X     $35     2       4}\par
{\f1     Absolu            AND $nnnn     $2D     3       4}\par
{\f1     Absolu,X          AND $nnnn,X   $3D     3       4(+1)}\par
{\f1     Absolu,Y          AND $nnnn,Y   $39     3       4(+1)}\par
{\f1     (Indirect,X)      AND ($nn,X)   $21     2       6}\par
{\f1     (Indirect),Y      AND ($nn),Y   $31     2       5(+1)}\par
\par
{\f1   Exemples :}\par
{\f1     AND #$0F          ; masquer les 4 bits de poids fort (garder 0-F)}\par
{\f1     AND #$F0          ; masquer les 4 bits de poids faible}\par
{\f1     AND #%11110000    ; equivalent en binaire}\par
{\f1     AND #$FE          ; effacer le bit 0}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Masquage de bits (isoler certains bits)}\par
{\f1     - Tester si un bit est positionne (AND + BEQ/BNE)}\par
{\f1     - Effacer des bits specifiques}\par
\par
{\f1   4.4.2 ORA - Logical Inclusive OR (OU inclusif logique)}\par
\par
{\f1   Effectue un OU logique bit a bit entre l'accumulateur et}\par
{\f1   l'operande.}\par
\par
{\f1   Operation : A <- A OR M}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Table de verite :}\par
{\f1     A  M  Resultat}\par
{\f1     0  0     0}\par
{\f1     0  1     1}\par
{\f1     1  0     1}\par
{\f1     1  1     1}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          ORA #$nn      $09     2       2}\par
{\f1     Page zero         ORA $nn       $05     2       3}\par
{\f1     Page zero,X       ORA $nn,X     $15     2       4}\par
{\f1     Absolu            ORA $nnnn     $0D     3       4}\par
{\f1     Absolu,X          ORA $nnnn,X   $1D     3       4(+1)}\par
{\f1     Absolu,Y          ORA $nnnn,Y   $19     3       4(+1)}\par
{\f1     (Indirect,X)      ORA ($nn,X)   $01     2       6}\par
{\f1     (Indirect),Y      ORA ($nn),Y   $11     2       5(+1)}\par
\par
{\f1   Exemples :}\par
{\f1     ORA #$80          ; forcer le bit 7 a 1}\par
{\f1     ORA #$01          ; forcer le bit 0 a 1}\par
{\f1     ORA #%00001111    ; forcer les 4 bits de poids faible a 1}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Positionner (mettre a 1) des bits specifiques}\par
{\f1     - Combiner des valeurs masquees}\par
{\f1     - Construire un octet bit par bit}\par
\par
{\f1   4.4.3 EOR - Exclusive OR (OU exclusif logique)}\par
\par
{\f1   Effectue un OU exclusif (XOR) bit a bit entre l'accumulateur et}\par
{\f1   l'operande.}\par
\par
{\f1   Operation : A <- A XOR M}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Table de verite :}\par
{\f1     A  M  Resultat}\par
{\f1     0  0     0}\par
{\f1     0  1     1}\par
{\f1     1  0     1}\par
{\f1     1  1     0}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          EOR #$nn      $49     2       2}\par
{\f1     Page zero         EOR $nn       $45     2       3}\par
{\f1     Page zero,X       EOR $nn,X     $55     2       4}\par
{\f1     Absolu            EOR $nnnn     $4D     3       4}\par
{\f1     Absolu,X          EOR $nnnn,X   $5D     3       4(+1)}\par
{\f1     Absolu,Y          EOR $nnnn,Y   $59     3       4(+1)}\par
{\f1     (Indirect,X)      EOR ($nn,X)   $41     2       6}\par
{\f1     (Indirect),Y      EOR ($nn),Y   $51     2       5(+1)}\par
\par
{\f1   Exemples :}\par
{\f1     EOR #$FF          ; inverser tous les bits (complement a 1)}\par
{\f1     EOR #$80          ; inverser le bit 7 (changer le signe)}\par
{\f1     EOR #$01          ; inverser le bit 0 (basculer un flag)}\par
\par
{\f1   Utilisation typique :}\par
{\f1     - Inverser (basculer) des bits specifiques}\par
{\f1     - Complement a 1 (EOR #$FF)}\par
{\f1     - Clignotement d'un caractere a l'ecran (EOR avec un masque)}\par
{\f1     - Cryptage simple (XOR avec une cle)}\par
{\f1     - Tester si deux valeurs sont egales (EOR + BEQ)}\par
\par
\par
\b 4.5 Instructions de decalage et rotation \b0\par
\par
{\f1   Ces instructions decalent ou font tourner les bits d'un octet}\par
{\f1   vers la gauche ou la droite. Elles peuvent operer sur}\par
{\f1   l'accumulateur A ou directement sur un emplacement memoire.}\par
\par
{\f1   4.5.1 ASL - Arithmetic Shift Left (Decalage arithmetique a gauche)}\par
\par
{\f1   Decale tous les bits d'une position vers la gauche. Le bit 7}\par
{\f1   sort dans C et un 0 entre dans le bit 0.}\par
\par
{\f1   Operation : C <- [76543210] <- 0}\par
\par
{\f1   Drapeaux affectes : N, Z, C}\par
{\f1     C = ancien bit 7}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Accumulateur      ASL A         $0A     1       2}\par
{\f1     Page zero         ASL $nn       $06     2       5}\par
{\f1     Page zero,X       ASL $nn,X     $16     2       6}\par
{\f1     Absolu            ASL $nnnn     $0E     3       6}\par
{\f1     Absolu,X          ASL $nnnn,X   $1E     3       7}\par
\par
{\f1   Exemples :}\par
{\f1     ASL A             ; A = A * 2 (decalage a gauche)}\par
{\f1     ASL $80           ; contenu de $0080 *= 2}\par
{\f1     ; Multiplier A par 8 :}\par
{\f1     ASL A             ; A * 2}\par
{\f1     ASL A             ; A * 4}\par
{\f1     ASL A             ; A * 8}\par
\par
{\f1   4.5.2 LSR - Logical Shift Right (Decalage logique a droite)}\par
\par
{\f1   Decale tous les bits d'une position vers la droite. Un 0 entre}\par
{\f1   dans le bit 7 et le bit 0 sort dans C.}\par
\par
{\f1   Operation : 0 -> [76543210] -> C}\par
\par
{\f1   Drapeaux affectes : N (toujours 0), Z, C}\par
{\f1     C = ancien bit 0}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Accumulateur      LSR A         $4A     1       2}\par
{\f1     Page zero         LSR $nn       $46     2       5}\par
{\f1     Page zero,X       LSR $nn,X     $56     2       6}\par
{\f1     Absolu            LSR $nnnn     $4E     3       6}\par
{\f1     Absolu,X          LSR $nnnn,X   $5E     3       7}\par
\par
{\f1   Exemples :}\par
{\f1     LSR A             ; A = A / 2 (division entiere non signee)}\par
{\f1     ; Diviser A par 4 :}\par
{\f1     LSR A             ; A / 2}\par
{\f1     LSR A             ; A / 4}\par
\par
{\f1     ; Tester le bit 0 de A :}\par
{\f1     LSR A             ; bit 0 -> C}\par
{\f1     BCS BitEstUn      ; brancher si le bit 0 etait 1}\par
\par
{\f1   4.5.3 ROL - Rotate Left (Rotation a gauche via C)}\par
\par
{\f1   Fait tourner tous les bits d'une position vers la gauche a}\par
{\f1   travers le drapeau C. Le bit 7 sort dans C et l'ancien C entre}\par
{\f1   dans le bit 0.}\par
\par
{\f1   Operation : C <- [76543210] <- C}\par
\par
{\f1   Drapeaux affectes : N, Z, C}\par
{\f1     C = ancien bit 7}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Accumulateur      ROL A         $2A     1       2}\par
{\f1     Page zero         ROL $nn       $26     2       5}\par
{\f1     Page zero,X       ROL $nn,X     $36     2       6}\par
{\f1     Absolu            ROL $nnnn     $2E     3       6}\par
{\f1     Absolu,X          ROL $nnnn,X   $3E     3       7}\par
\par
{\f1   Exemples :}\par
{\f1     ; Rotation 16 bits a gauche de la valeur $80/$81}\par
{\f1     ASL $80           ; decaler le poids faible, bit 7 -> C}\par
{\f1     ROL $81           ; rotation du poids fort, C -> bit 0}\par
\par
{\f1     ; Lecture serie bit par bit dans C}\par
{\f1     ROL A             ; injecter C dans le bit 0, bit 7 -> C}\par
\par
{\f1   4.5.4 ROR - Rotate Right (Rotation a droite via C)}\par
\par
{\f1   Fait tourner tous les bits d'une position vers la droite a}\par
{\f1   travers le drapeau C. Le bit 0 sort dans C et l'ancien C entre}\par
{\f1   dans le bit 7.}\par
\par
{\f1   Operation : C -> [76543210] -> C}\par
\par
{\f1   Drapeaux affectes : N, Z, C}\par
{\f1     C = ancien bit 0}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Accumulateur      ROR A         $6A     1       2}\par
{\f1     Page zero         ROR $nn       $66     2       5}\par
{\f1     Page zero,X       ROR $nn,X     $76     2       6}\par
{\f1     Absolu            ROR $nnnn     $6E     3       6}\par
{\f1     Absolu,X          ROR $nnnn,X   $7E     3       7}\par
\par
{\f1   Exemples :}\par
{\f1     ; Rotation 16 bits a droite de la valeur $80/$81}\par
{\f1     LSR $81           ; decaler le poids fort, bit 0 -> C}\par
{\f1     ROR $80           ; rotation du poids faible, C -> bit 7}\par
\par
{\f1     ; Division signee par 2 (conserver le signe)}\par
{\f1     CMP #$80          ; copier le bit 7 (signe) dans C}\par
{\f1     ROR A             ; diviser par 2 en conservant le signe}\par
\par
{\f1   Note historique :}\par
{\f1     L'instruction ROR n'existait pas dans les premieres revisions}\par
{\f1     du 6502 (avant juin 1976). Elle a ete ajoutee plus tard. Les}\par
{\f1     premieres documentations de MOS Technology ne la mentionnaient}\par
{\f1     pas, et elle fonctionnait de maniere erratique sur les}\par
{\f1     premiers exemplaires du processeur.}\par
\par
\par
\b 4.6 Instructions de comparaison \b0\par
\par
{\f1   Ces instructions comparent un registre avec une valeur en memoire}\par
{\f1   en effectuant une soustraction interne sans modifier le registre.}\par
{\f1   Seuls les drapeaux sont affectes.}\par
\par
{\f1   4.6.1 CMP - Compare Accumulator (Comparer avec A)}\par
\par
{\f1   Compare l'accumulateur avec la valeur en memoire.}\par
\par
{\f1   Operation : A - M (resultat non conserve)}\par
\par
{\f1   Drapeaux affectes : N, Z, C}\par
{\f1     N = 1 si le bit 7 du resultat (A-M) est 1}\par
{\f1     Z = 1 si A = M}\par
{\f1     C = 1 si A >= M (non signe)}\par
{\f1     C = 0 si A < M (non signe)}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          CMP #$nn      $C9     2       2}\par
{\f1     Page zero         CMP $nn       $C5     2       3}\par
{\f1     Page zero,X       CMP $nn,X     $D5     2       4}\par
{\f1     Absolu            CMP $nnnn     $CD     3       4}\par
{\f1     Absolu,X          CMP $nnnn,X   $DD     3       4(+1)}\par
{\f1     Absolu,Y          CMP $nnnn,Y   $D9     3       4(+1)}\par
{\f1     (Indirect,X)      CMP ($nn,X)   $C1     2       6}\par
{\f1     (Indirect),Y      CMP ($nn),Y   $D1     2       5(+1)}\par
\par
{\f1   Exemples et idiomes :}\par
\par
{\f1     ; Tester si A = $42}\par
{\f1     CMP #$42}\par
{\f1     BEQ Egal          ; brancher si A = $42}\par
\par
{\f1     ; Tester si A < $20 (non signe)}\par
{\f1     CMP #$20}\par
{\f1     BCC Inferieur     ; brancher si A < $20}\par
\par
{\f1     ; Tester si A >= $80 (non signe)}\par
{\f1     CMP #$80}\par
{\f1     BCS SupOuEgal     ; brancher si A >= $80}\par
\par
{\f1     ; Tester si A est dans la plage 'A'-'Z'}\par
{\f1     CMP #'A'}\par
{\f1     BCC PasLettre     ; A < 'A'}\par
{\f1     CMP #'Z'+1}\par
{\f1     BCS PasLettre     ; A > 'Z'}\par
{\f1     ; Ici, A est une lettre majuscule}\par
\par
{\f1   4.6.2 CPX - Compare X Register (Comparer avec X)}\par
\par
{\f1   Compare le registre X avec la valeur en memoire.}\par
\par
{\f1   Operation : X - M (resultat non conserve)}\par
\par
{\f1   Drapeaux affectes : N, Z, C (memes regles que CMP)}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          CPX #$nn      $E0     2       2}\par
{\f1     Page zero         CPX $nn       $E4     2       3}\par
{\f1     Absolu            CPX $nnnn     $EC     3       4}\par
\par
{\f1   Exemples :}\par
{\f1     CPX #$10}\par
{\f1     BEQ XEstSeize     ; brancher si X = 16}\par
{\f1     CPX #$00}\par
{\f1     BEQ XEstZero      ; brancher si X = 0}\par
\par
{\f1   4.6.3 CPY - Compare Y Register (Comparer avec Y)}\par
\par
{\f1   Compare le registre Y avec la valeur en memoire.}\par
\par
{\f1   Operation : Y - M (resultat non conserve)}\par
\par
{\f1   Drapeaux affectes : N, Z, C (memes regles que CMP)}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Immediat          CPY #$nn      $C0     2       2}\par
{\f1     Page zero         CPY $nn       $C4     2       3}\par
{\f1     Absolu            CPY $nnnn     $CC     3       4}\par
\par
{\f1   Exemples :}\par
{\f1     CPY #$18          ; comparer Y avec 24}\par
{\f1     BCS SupOuEgal     ; brancher si Y >= 24}\par
\par
{\f1   4.6.4 BIT - Test Bits (Test de bits)}\par
\par
{\f1   Teste des bits en memoire contre l'accumulateur sans modifier}\par
{\f1   ni A ni M. C'est une instruction unique qui positionne trois}\par
{\f1   drapeaux de manieres differentes.}\par
\par
{\f1   Operation :}\par
{\f1     Z = 1 si (A AND M) = 0 (resultat du masquage est zero)}\par
{\f1     N = bit 7 de M (copie directe, sans tenir compte de A)}\par
{\f1     V = bit 6 de M (copie directe, sans tenir compte de A)}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Page zero         BIT $nn       $24     2       3}\par
{\f1     Absolu            BIT $nnnn     $2C     3       4}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; Tester si le bit 7 d'un registre materiel est positionne}\par
{\f1     BIT $D011         ; lire le registre VIC-II}\par
{\f1     BMI BitSept       ; brancher si bit 7 = 1 (N = bit 7 de M)}\par
\par
{\f1     ; Tester si le bit 6 est positionne}\par
{\f1     BIT $D011}\par
{\f1     BVS BitSix        ; brancher si bit 6 = 1 (V = bit 6 de M)}\par
\par
{\f1     ; Tester si certains bits sont a 1 dans un registre}\par
{\f1     LDA #%00001100    ; masque : bits 2 et 3}\par
{\f1     BIT Registre      ; tester}\par
{\f1     BNE AuMoinsUnBit  ; au moins un des bits 2 ou 3 est a 1}\par
\par
{\f1     ; Attendre qu'un peripherique soit pret (polling)}\par
{\f1   Attendre:}\par
{\f1     BIT StatutPerif   ; tester le registre de statut}\par
{\f1     BPL Attendre      ; boucler tant que bit 7 = 0}\par
\par
{\f1   Remarques :}\par
{\f1     - BIT est tres utile pour tester des registres materiels}\par
{\f1       (memory-mapped I/O) sans modifier l'accumulateur}\par
{\f1     - Le comportement de N et V est unique : ils recoivent}\par
{\f1       directement les bits 7 et 6 de l'operande memoire,}\par
{\f1       independamment de la valeur de A}\par
{\f1     - Le 65C02 ajoute le mode immediat (BIT #$nn) ou seul Z}\par
{\f1       est affecte (N et V ne sont pas modifies)}\par
\par
\par
\b 4.7 Instructions de branchement \b0\par
\par
{\f1   Les instructions de branchement effectuent un saut relatif}\par
{\f1   conditionnel. Elles testent un drapeau du registre d'etat et,}\par
{\f1   si la condition est vraie, ajoutent un deplacement signe de 8}\par
{\f1   bits au compteur programme.}\par
\par
{\f1   Toutes les instructions de branchement :}\par
{\f1     - Font 2 octets (opcode + deplacement)}\par
{\f1     - Prennent 2 cycles si le branchement n'est pas pris}\par
{\f1     - Prennent 3 cycles si le branchement est pris (meme page)}\par
{\f1     - Prennent 4 cycles si le branchement est pris avec}\par
{\f1       franchissement de page}\par
\par
{\f1   4.7.1 BCC - Branch if Carry Clear (Brancher si C = 0)}\par
\par
{\f1   Branche si le drapeau de retenue est efface.}\par
\par
{\f1   Opcode : $90}\par
\par
{\f1   Utilisation : apres CMP/CPX/CPY pour tester "inferieur a"}\par
{\f1                 (comparaison non signee)}\par
\par
{\f1   Exemple :}\par
{\f1     CMP #$80}\par
{\f1     BCC InferieurA128 ; brancher si A < $80}\par
\par
{\f1   4.7.2 BCS - Branch if Carry Set (Brancher si C = 1)}\par
\par
{\f1   Branche si le drapeau de retenue est positionne.}\par
\par
{\f1   Opcode : $B0}\par
\par
{\f1   Utilisation : apres CMP/CPX/CPY pour tester "superieur ou egal"}\par
{\f1                 (comparaison non signee)}\par
\par
{\f1   Exemple :}\par
{\f1     CMP #$80}\par
{\f1     BCS SupOuEgalA128 ; brancher si A >= $80}\par
\par
{\f1   4.7.3 BEQ - Branch if Equal (Brancher si Z = 1)}\par
\par
{\f1   Branche si le drapeau zero est positionne (resultat egal a zero).}\par
\par
{\f1   Opcode : $F0}\par
\par
{\f1   Utilisation : apres CMP pour tester "egal a", apres LDA/LDX/LDY}\par
{\f1                 pour tester si la valeur chargee est zero}\par
\par
{\f1   Exemples :}\par
{\f1     CMP #'A'}\par
{\f1     BEQ EstUnA        ; brancher si A = 'A'}\par
\par
{\f1     LDA $80}\par
{\f1     BEQ EstZero       ; brancher si le contenu de $80 est 0}\par
\par
{\f1     DEX}\par
{\f1     BEQ XEstZero      ; brancher si X est devenu 0}\par
\par
{\f1   4.7.4 BNE - Branch if Not Equal (Brancher si Z = 0)}\par
\par
{\f1   Branche si le drapeau zero est efface (resultat non nul).}\par
\par
{\f1   Opcode : $D0}\par
\par
{\f1   Utilisation : apres CMP pour tester "different de", comme}\par
{\f1                 condition de boucle (compteur != 0)}\par
\par
{\f1   Exemples :}\par
{\f1     ; Boucle standard avec compteur X}\par
{\f1     LDX #$10}\par
{\f1   Boucle:}\par
{\f1     ; ... code de la boucle ...}\par
{\f1     DEX}\par
{\f1     BNE Boucle        ; boucler tant que X != 0}\par
\par
{\f1     CMP #$0D}\par
{\f1     BNE PasReturn     ; brancher si A != $0D (retour chariot)}\par
\par
{\f1   4.7.5 BMI - Branch if Minus (Brancher si N = 1)}\par
\par
{\f1   Branche si le drapeau negatif est positionne (bit 7 du resultat}\par
{\f1   est 1).}\par
\par
{\f1   Opcode : $30}\par
\par
{\f1   Utilisation : tester le signe d'une valeur, tester le bit 7}\par
\par
{\f1   Exemples :}\par
{\f1     LDA Temperature}\par
{\f1     BMI Negatif       ; brancher si la temperature est negative}\par
\par
{\f1     BIT $D011}\par
{\f1     BMI Pret          ; brancher si bit 7 du registre = 1}\par
\par
{\f1   4.7.6 BPL - Branch if Plus (Brancher si N = 0)}\par
\par
{\f1   Branche si le drapeau negatif est efface (bit 7 du resultat}\par
{\f1   est 0).}\par
\par
{\f1   Opcode : $10}\par
\par
{\f1   Utilisation : tester le signe d'une valeur, polling de}\par
{\f1                 peripheriques}\par
\par
{\f1   Exemples :}\par
{\f1     ; Attendre que le bit 7 d'un registre passe a 1}\par
{\f1   Attendre:}\par
{\f1     BIT Registre}\par
{\f1     BPL Attendre      ; boucler tant que bit 7 = 0}\par
\par
{\f1     LDA Valeur}\par
{\f1     BPL Positif       ; brancher si >= 0 (en signe)}\par
\par
{\f1   4.7.7 BVC - Branch if Overflow Clear (Brancher si V = 0)}\par
\par
{\f1   Branche si le drapeau de debordement est efface.}\par
\par
{\f1   Opcode : $50}\par
\par
{\f1   Utilisation : rarement utilise, principalement pour}\par
{\f1                 l'arithmetique signee}\par
\par
{\f1   Exemple :}\par
{\f1     ADC Valeur}\par
{\f1     BVC PasDebordement ; brancher si pas de debordement signe}\par
\par
{\f1   4.7.8 BVS - Branch if Overflow Set (Brancher si V = 1)}\par
\par
{\f1   Branche si le drapeau de debordement est positionne.}\par
\par
{\f1   Opcode : $70}\par
\par
{\f1   Utilisation : detection de debordement en arithmetique signee,}\par
{\f1                 lecture du pin SO (Set Overflow) de certains}\par
{\f1                 peripheriques}\par
\par
{\f1   Exemple :}\par
{\f1     ADC Valeur}\par
{\f1     BVS Debordement   ; brancher si debordement signe}\par
\par
{\f1   Remarques generales sur les branchements :}\par
{\f1     - Le deplacement est un entier signe de 8 bits : -128 a +127}\par
{\f1       par rapport a l'instruction suivant le branchement}\par
{\f1     - Portee effective : -126 a +129 octets par rapport a}\par
{\f1       l'instruction de branchement elle-meme}\par
{\f1     - Si la cible est hors de portee, utiliser un saut}\par
{\f1       intermediaire (trampoline) via JMP}\par
{\f1     - Le 65C02 ajoute BRA (branch always, branchement}\par
{\f1       inconditionnel relatif)}\par
{\f1     - Le 6502 n'a PAS de branchements "branch if greater",}\par
{\f1       "branch if less" en arithmetique signee en une seule}\par
{\f1       instruction. Il faut combiner CMP + BCC/BCS/BEQ/BMI/BPL.}\par
\par
\par
\b 4.8 Instructions de saut et d'appel \b0\par
\par
{\f1   Ces instructions modifient le compteur programme (PC) pour}\par
{\f1   effectuer des sauts inconditionnels ou des appels de sous-}\par
{\f1   programmes.}\par
\par
{\f1   4.8.1 JMP - Jump (Saut inconditionnel)}\par
\par
{\f1   Charge une nouvelle adresse dans le compteur programme.}\par
\par
{\f1   Operation : PC <- adresse}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Modes d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Absolu            JMP $nnnn     $4C     3       3}\par
{\f1     Indirect          JMP ($nnnn)   $6C     3       5}\par
\par
{\f1   Exemples :}\par
{\f1     JMP $C000         ; sauter a l'adresse $C000}\par
{\f1     JMP Suite         ; sauter a l'etiquette Suite}\par
{\f1     JMP ($FFFC)       ; saut indirect via le vecteur RESET}\par
{\f1     JMP (VecteurJmp)  ; saut indirect via un pointeur en memoire}\par
\par
{\f1   Remarque :}\par
{\f1     - Voir la section 3.11 pour le bug de JMP indirect sur}\par
{\f1       limite de page du 6502 NMOS}\par
\par
{\f1   4.8.2 JSR - Jump to Subroutine (Appel de sous-programme)}\par
\par
{\f1   Empile l'adresse de retour (PC - 1) sur la pile, puis saute a}\par
{\f1   l'adresse specifiee.}\par
\par
{\f1   Operation : PUSH (PC - 1), PC <- adresse}\par
{\f1     (PC - 1 car le 6502 empile l'adresse du DERNIER octet de}\par
{\f1     l'instruction JSR, pas l'adresse de l'instruction suivante.}\par
{\f1     RTS ajoutera 1 pour obtenir la bonne adresse de retour.)}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Mode d'adressage :}\par
\par
{\f1     Mode              Syntaxe       Opcode  Octets  Cycles}\par
{\f1     ----------------  -----------   ------  ------  ------}\par
{\f1     Absolu            JSR $nnnn     $20     3       6}\par
\par
{\f1   Exemples :}\par
{\f1     JSR SousRoutine   ; appeler SousRoutine}\par
{\f1     JSR $FFD2         ; appeler CHROUT du Kernal C64}\par
\par
{\f1   Detail de l'empilage :}\par
{\f1     1. SP pointe sur l'emplacement libre en haut de pile}\par
{\f1     2. L'octet de poids fort de (PC-1) est empile : [$0100+SP] = PCH}\par
{\f1        SP := SP - 1}\par
{\f1     3. L'octet de poids faible de (PC-1) est empile : [$0100+SP] = PCL}\par
{\f1        SP := SP - 1}\par
{\f1     4. PC := adresse cible}\par
\par
{\f1   4.8.3 RTS - Return from Subroutine (Retour de sous-programme)}\par
\par
{\f1   Depile l'adresse de retour de la pile et y ajoute 1 pour}\par
{\f1   continuer l'execution apres l'instruction JSR correspondante.}\par
\par
{\f1   Operation : PULL PC, PC <- PC + 1}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Opcode : $60    Taille : 1 octet    Cycles : 6}\par
\par
{\f1   Detail du depilage :}\par
{\f1     1. SP := SP + 1}\par
{\f1     2. PCL := [$0100+SP] (poids faible)}\par
{\f1     3. SP := SP + 1}\par
{\f1     4. PCH := [$0100+SP] (poids fort)}\par
{\f1     5. PC := PC + 1}\par
\par
{\f1   Exemple :}\par
{\f1     JSR MaRoutine     ; appel}\par
{\f1     ; ... continue ici apres RTS ...}\par
\par
{\f1   MaRoutine:}\par
{\f1     ; ... code ...}\par
{\f1     RTS               ; retour a l'appelant}\par
\par
{\f1   Astuce : JMP indirect simule par PUSH + RTS :}\par
{\f1     ; Pour simuler un JMP indirect via un pointeur en page zero :}\par
{\f1     LDA $81           ; poids fort de l'adresse cible}\par
{\f1     PHA}\par
{\f1     LDA $80           ; poids faible de l'adresse cible}\par
{\f1     PHA}\par
{\f1     RTS               ; "retourner" a l'adresse ($80)/$81}\par
{\f1     ; Note : empiler (adresse - 1) car RTS ajoute 1}\par
\par
{\f1   4.8.4 RTI - Return from Interrupt (Retour d'interruption)}\par
\par
{\f1   Depile le registre d'etat puis l'adresse de retour depuis la}\par
{\f1   pile. Contrairement a RTS, RTI ne modifie PAS l'adresse depilee}\par
{\f1   (pas de +1), car lors d'une interruption, le PC exact est empile.}\par
\par
{\f1   Operation : PULL P, PULL PC}\par
\par
{\f1   Drapeaux affectes : tous (restaures depuis la pile)}\par
\par
{\f1   Opcode : $40    Taille : 1 octet    Cycles : 6}\par
\par
{\f1   Detail du depilage :}\par
{\f1     1. SP := SP + 1}\par
{\f1     2. P := [$0100+SP] (registre d'etat)}\par
{\f1     3. SP := SP + 1}\par
{\f1     4. PCL := [$0100+SP]}\par
{\f1     5. SP := SP + 1}\par
{\f1     6. PCH := [$0100+SP]}\par
\par
{\f1   Exemple :}\par
{\f1     ; Gestionnaire d'interruption IRQ}\par
{\f1   GestionnaireIRQ:}\par
{\f1     PHA               ; sauvegarder A}\par
{\f1     TXA}\par
{\f1     PHA               ; sauvegarder X}\par
{\f1     TYA}\par
{\f1     PHA               ; sauvegarder Y}\par
\par
{\f1     ; ... traitement de l'interruption ...}\par
\par
{\f1     PLA}\par
{\f1     TAY               ; restaurer Y}\par
{\f1     PLA}\par
{\f1     TAX               ; restaurer X}\par
{\f1     PLA               ; restaurer A}\par
{\f1     RTI               ; retourner de l'interruption}\par
\par
{\f1   Remarques :}\par
{\f1     - RTI restaure completement le registre P, y compris le}\par
{\f1       drapeau I (Interrupt Disable)}\par
{\f1     - La difference entre RTS et RTI est importante : RTS ajoute}\par
{\f1       1 a l'adresse depilee, RTI non. Utiliser l'un a la place}\par
{\f1       de l'autre causerait une erreur d'un octet.}\par
{\f1     - Le drapeau B (Break) dans le P empile est positionne pour}\par
{\f1       BRK et efface pour les interruptions materielles}\par
\par
{\f1   4.8.5 BRK - Break (Interruption logicielle)}\par
\par
{\f1   Genere une interruption logicielle. Empile PC+2 et P sur la}\par
{\f1   pile, positionne le drapeau I, et saute au vecteur d'interruption}\par
{\f1   IRQ/BRK ($FFFE-$FFFF).}\par
\par
{\f1   Operation :}\par
{\f1     PC := PC + 2 (pointe apres BRK + octet de signature)}\par
{\f1     PUSH PCH}\par
{\f1     PUSH PCL}\par
{\f1     PUSH P (avec B = 1)}\par
{\f1     I := 1}\par
{\f1     PC := [$FFFE]:[$FFFF]}\par
\par
{\f1   Drapeaux affectes : I est positionne. B est positionne dans la}\par
{\f1     copie empilee de P (mais pas dans P lui-meme).}\par
\par
{\f1   Opcode : $00    Taille : 1 octet*   Cycles : 7}\par
\par
{\f1   * Note : BRK est formellement une instruction de 1 octet, mais}\par
{\f1     le PC empile pointe 2 octets APRES le BRK. L'octet suivant}\par
{\f1     le BRK est considere comme un "octet de signature" (padding}\par
{\f1     byte) qui est saute. Cet octet peut etre utilise par le}\par
{\f1     gestionnaire d'interruption pour identifier la raison du BRK.}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; Interruption logicielle simple}\par
{\f1     BRK               ; declencher une interruption logicielle}\par
{\f1     .BYTE $01         ; signature (optionnel, utilise par le handler)}\par
\par
{\f1     ; Dans le gestionnaire d'interruption, distinguer BRK de IRQ :}\par
{\f1   GestionnaireIRQ:}\par
{\f1     ; ... sauvegarder les registres ...}\par
{\f1     PLA               ; recuperer P de la pile}\par
{\f1     PHA               ; le remettre}\par
{\f1     AND #$10          ; tester le bit B (Break)}\par
{\f1     BNE EstBRK        ; si B=1, c'est un BRK}\par
{\f1     ; Sinon, c'est une IRQ materielle}\par
{\f1     ; ...}\par
{\f1   EstBRK:}\par
{\f1     ; Traiter le BRK}\par
{\f1     ; ...}\par
\par
{\f1   Remarques :}\par
{\f1     - BRK utilise le meme vecteur que IRQ ($FFFE-$FFFF)}\par
{\f1     - Pour distinguer BRK de IRQ, examiner le drapeau B dans}\par
{\f1       la copie de P empilee sur la pile}\par
{\f1     - BRK est souvent utilise comme point d'arret (breakpoint)}\par
{\f1       par les debogueurs et les moniteurs}\par
{\f1     - Certains systemes utilisent BRK + signature comme appel}\par
{\f1       systeme (l'octet de signature identifie le service)}\par
{\f1     - Sur le 6502 NMOS, si un NMI survient en meme temps qu'un}\par
{\f1       BRK, le BRK peut etre "avale" (race condition connue)}\par
\par
\par
\b 4.9 Instructions de pile \b0\par
\par
{\f1   Ces instructions empilent ou depilent des valeurs sur la pile}\par
{\f1   situee en page 1 ($0100-$01FF).}\par
\par
{\f1   4.9.1 PHA - Push Accumulator (Empiler A)}\par
\par
{\f1   Empile le contenu de l'accumulateur sur la pile.}\par
\par
{\f1   Operation : [$0100+SP] <- A, SP <- SP - 1}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Opcode : $48    Taille : 1 octet    Cycles : 3}\par
\par
{\f1   Exemple :}\par
{\f1     PHA               ; sauvegarder A sur la pile}\par
\par
{\f1   4.9.2 PLA - Pull Accumulator (Depiler A)}\par
\par
{\f1   Depile une valeur de la pile dans l'accumulateur.}\par
\par
{\f1   Operation : SP <- SP + 1, A <- [$0100+SP]}\par
\par
{\f1   Drapeaux affectes : N, Z}\par
\par
{\f1   Opcode : $68    Taille : 1 octet    Cycles : 4}\par
\par
{\f1   Exemple :}\par
{\f1     PLA               ; restaurer A depuis la pile}\par
\par
{\f1   Remarque : PLA affecte N et Z, contrairement a PHA.}\par
\par
{\f1   4.9.3 PHP - Push Processor Status (Empiler P)}\par
\par
{\f1   Empile le registre d'etat du processeur sur la pile.}\par
\par
{\f1   Operation : [$0100+SP] <- P (avec B=1), SP <- SP - 1}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Opcode : $08    Taille : 1 octet    Cycles : 3}\par
\par
{\f1   Remarque : PHP empile TOUJOURS P avec le drapeau B positionne}\par
{\f1     a 1 et le bit 5 (inutilise) a 1.}\par
\par
{\f1   4.9.4 PLP - Pull Processor Status (Depiler P)}\par
\par
{\f1   Depile une valeur de la pile dans le registre d'etat.}\par
\par
{\f1   Operation : SP <- SP + 1, P <- [$0100+SP]}\par
\par
{\f1   Drapeaux affectes : tous (restaures depuis la valeur depilee)}\par
\par
{\f1   Opcode : $28    Taille : 1 octet    Cycles : 4}\par
\par
{\f1   Exemple :}\par
{\f1     ; Sauvegarder et restaurer les drapeaux}\par
{\f1     PHP               ; sauvegarder P}\par
{\f1     ; ... code qui modifie les drapeaux ...}\par
{\f1     PLP               ; restaurer P (tous les drapeaux)}\par
\par
{\f1   Remarques :}\par
{\f1     - PLP restaure tous les drapeaux, y compris I et D}\par
{\f1     - Ceci peut etre utilise pour activer/desactiver les}\par
{\f1       interruptions de maniere atomique}\par
{\f1     - Les bits B (bit 4) et le bit 5 (inutilise) sont ignores}\par
{\f1       par PLP et toujours lus comme 1}\par
\par
{\f1   Exemple : sauvegarder X et Y via la pile :}\par
{\f1     ; Le 6502 n'a pas de PHX/PHY (ajoutes sur le 65C02)}\par
{\f1     ; Pour sauvegarder X :}\par
{\f1     TXA               ; A := X}\par
{\f1     PHA               ; empiler A (qui contient X)}\par
{\f1     ; Pour restaurer X :}\par
{\f1     PLA               ; depiler dans A}\par
{\f1     TAX               ; X := A}\par
{\f1     ; Idem pour Y avec TYA/PHA et PLA/TAY}\par
\par
\par
\b 4.10 Instructions de controle des drapeaux \b0\par
\par
{\f1   Ces instructions modifient directement les drapeaux du registre}\par
{\f1   d'etat P. Elles sont en mode implicite (1 octet, 2 cycles).}\par
\par
{\f1   4.10.1 CLC - Clear Carry Flag (Effacer la retenue)}\par
\par
{\f1   Operation : C <- 0}\par
\par
{\f1   Opcode : $18    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisation : OBLIGATOIRE avant ADC pour eviter une retenue}\par
{\f1     parasite dans l'addition}\par
\par
{\f1   Exemple :}\par
{\f1     CLC}\par
{\f1     LDA #$30}\par
{\f1     ADC #$10          ; A = $40 (et non $41 si C etait 1)}\par
\par
{\f1   4.10.2 SEC - Set Carry Flag (Positionner la retenue)}\par
\par
{\f1   Operation : C <- 1}\par
\par
{\f1   Opcode : $38    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisation : OBLIGATOIRE avant SBC pour eviter un emprunt}\par
{\f1     parasite dans la soustraction}\par
\par
{\f1   Exemple :}\par
{\f1     SEC}\par
{\f1     LDA #$50}\par
{\f1     SBC #$20          ; A = $30 (et non $2F si C etait 0)}\par
\par
{\f1   4.10.3 CLD - Clear Decimal Mode (Desactiver le mode decimal)}\par
\par
{\f1   Operation : D <- 0}\par
\par
{\f1   Opcode : $D8    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisation : revenir en mode binaire apres des calculs BCD,}\par
{\f1     ou en debut de programme pour s'assurer du mode binaire}\par
\par
{\f1   Exemple :}\par
{\f1     CLD               ; s'assurer que le mode binaire est actif}\par
{\f1     ; ... code arithmetique normal ...}\par
\par
{\f1   Remarque : le 6502 NMOS ne definit pas l'etat du drapeau D}\par
{\f1     apres un RESET ou une IRQ. Il est recommande de faire CLD}\par
{\f1     au debut de tout programme et de tout gestionnaire}\par
{\f1     d'interruption.}\par
\par
{\f1   4.10.4 SED - Set Decimal Mode (Activer le mode decimal)}\par
\par
{\f1   Operation : D <- 1}\par
\par
{\f1   Opcode : $F8    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisation : activer le mode BCD pour ADC et SBC}\par
\par
{\f1   Exemple :}\par
{\f1     SED               ; activer le mode BCD}\par
{\f1     CLC}\par
{\f1     LDA #$15}\par
{\f1     ADC #$27          ; A = $42 (15 + 27 = 42 en decimal)}\par
{\f1     CLD               ; revenir en mode binaire}\par
\par
{\f1   Remarque : en mode BCD, seuls ADC et SBC sont affectes.}\par
{\f1     Les autres instructions (INC, DEC, etc.) continuent a}\par
{\f1     fonctionner en binaire.}\par
\par
{\f1   4.10.5 CLI - Clear Interrupt Disable (Autoriser les interruptions)}\par
\par
{\f1   Operation : I <- 0}\par
\par
{\f1   Opcode : $58    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisation : re-autoriser les interruptions IRQ apres les}\par
{\f1     avoir desactivees}\par
\par
{\f1   Exemple :}\par
{\f1     CLI               ; autoriser les interruptions IRQ}\par
\par
{\f1   Remarque : les interruptions NMI ne sont PAS affectees par le}\par
{\f1     drapeau I. Elles sont toujours actives.}\par
\par
{\f1   4.10.6 SEI - Set Interrupt Disable (Masquer les interruptions)}\par
\par
{\f1   Operation : I <- 1}\par
\par
{\f1   Opcode : $78    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisation : desactiver les interruptions IRQ pendant une}\par
{\f1     section critique du code}\par
\par
{\f1   Exemple :}\par
{\f1     SEI               ; desactiver les interruptions IRQ}\par
{\f1     ; ... section critique ...}\par
{\f1     ; ... modifier des donnees partagees avec l'IRQ ...}\par
{\f1     CLI               ; re-autoriser les interruptions}\par
\par
{\f1   4.10.7 CLV - Clear Overflow Flag (Effacer le debordement)}\par
\par
{\f1   Operation : V <- 0}\par
\par
{\f1   Opcode : $B8    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisation : effacer le drapeau de debordement. Rarement}\par
{\f1     utilise en pratique.}\par
\par
{\f1   Remarques :}\par
{\f1     - Il n'existe PAS d'instruction SEV (Set Overflow).}\par
{\f1     - Le drapeau V peut etre positionne par le pin SO (Set}\par
{\f1       Overflow) du processeur, utilise par certains}\par
{\f1       peripheriques (lecteur de disquette du Commodore 1541)}\par
{\f1     - V est automatiquement positionne par ADC/SBC en cas de}\par
{\f1       debordement signe, et par BIT (bit 6 de M -> V)}\par
\par
{\f1   Resume des instructions de controle des drapeaux :}\par
\par
{\f1     Instruction  Opcode  Operation     Utilisation principale}\par
{\f1     -----------  ------  ----------    --------------------------------}\par
{\f1     CLC          $18     C <- 0        Avant ADC}\par
{\f1     SEC          $38     C <- 1        Avant SBC}\par
{\f1     CLD          $D8     D <- 0        Mode binaire (debut programme)}\par
{\f1     SED          $F8     D <- 1        Mode BCD}\par
{\f1     CLI          $58     I <- 0        Autoriser les IRQ}\par
{\f1     SEI          $78     I <- 1        Masquer les IRQ}\par
{\f1     CLV          $B8     V <- 0        Effacer le debordement}\par
\par
\par
\b 4.11 Instruction NOP \b0\par
\par
{\f1   NOP - No Operation (Pas d'operation)}\par
\par
{\f1   Ne fait rien. Le processeur consomme du temps et de l'espace}\par
{\f1   sans modifier l'etat du processeur (aucun registre ni drapeau}\par
{\f1   modifie).}\par
\par
{\f1   Operation : aucune}\par
\par
{\f1   Drapeaux affectes : aucun}\par
\par
{\f1   Opcode : $EA    Taille : 1 octet    Cycles : 2}\par
\par
{\f1   Utilisations :}\par
{\f1     - Ajustement de timing (chaque NOP consomme 2 cycles)}\par
{\f1     - Reserve d'espace pour des corrections futures (patcher}\par
{\f1       du code avec des NOP)}\par
{\f1     - Remplacement d'instructions supprimees (NOP-out)}\par
{\f1     - Alignement de code}\par
{\f1     - Debogage}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; Delai precis de 10 cycles}\par
{\f1     NOP               ; 2 cycles}\par
{\f1     NOP               ; 2 cycles}\par
{\f1     NOP               ; 2 cycles}\par
{\f1     NOP               ; 2 cycles}\par
{\f1     NOP               ; 2 cycles (total : 10 cycles)}\par
\par
{\f1     ; Patcher du code : remplacer un JSR par des NOP}\par
{\f1     ; Avant : JSR $C000 (3 octets: $20 $00 $C0)}\par
{\f1     ; Apres : NOP NOP NOP (3 octets: $EA $EA $EA)}\par
\par
\par
\b 4.12 Resume et tableau recapitulatif \b0\par
\par
{\f1   Le 6502 possede 56 instructions officielles reparties en 11}\par
{\f1   categories. Voici le tableau recapitulatif complet :}\par
\par
