{\footnote # IDH_ASM6502_09}
{\footnote $ Assembleur 6502 - EXEMPLES DE CODE}
{\footnote K Assembleur 6502 exemples;Hello World;factorielle;tri a bulles;multiplication 16 bits;delai temporisation;copie bloc memoire}
\b\fs24 EXEMPLES DE CODE \b0\fs20\par
\par
{\f1   Cette section presente des exemples complets de programmes en}\par
{\f1   assembleur 6502. Chaque exemple est commente et illustre une}\par
{\f1   technique ou un algorithme fondamental. Les exemples utilisent}\par
{\f1   les conventions de l'assembleur ASM6502.PAS (syntaxe compatible}\par
{\f1   Motorola/MOS Technology).}\par
\par
{\f1   Note : Les exemples utilisent les routines KERNAL du Commodore 64}\par
{\f1   pour les entrees/sorties, ce qui est la convention la plus repandue}\par
{\f1   pour le 6502. Sur d'autres systemes (Apple II, Atari 800, NES),}\par
{\f1   les appels d'E/S varient mais le code algorithmique reste identique.}\par
\par
{\f1   Conventions communes aux exemples :}\par
{\f1     - CHROUT ($FFD2) : afficher un caractere (dans A) sur l'ecran}\par
{\f1     - GETIN ($FFE4)  : lire un caractere au clavier (dans A)}\par
{\f1     - CHRIN ($FFCF)  : lire un caractere avec echo}\par
{\f1     - $0400-$07E7    : memoire ecran (Commodore 64)}\par
{\f1     - $D020/$D021    : registres de couleur bordure/fond}\par
\par
\par
\b 9.1 Hello World \b0\par
\par
{\f1   Programme minimal affichant un message a l'ecran.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.1 : Hello World}\par
{\f1   ; Affiche "Hello, World!" puis retourne au BASIC.}\par
{\f1   ; Cible : Commodore 64 (KERNAL)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $C000}\par
\par
{\f1   CHROUT    EQU   $FFD2          ; Routine KERNAL : afficher caractere}\par
\par
{\f1   start:}\par
{\f1             LDX   #0             ; Index dans la chaine}\par
{\f1   @loop:}\par
{\f1             LDA   message,X      ; Charger le caractere suivant}\par
{\f1             BEQ   @done          ; Si zero, fin de chaine}\par
{\f1             JSR   CHROUT         ; Afficher le caractere}\par
{\f1             INX                  ; Caractere suivant}\par
{\f1             BNE   @loop          ; Boucler (max 256 caracteres)}\par
{\f1   @done:}\par
{\f1             RTS                  ; Retour au BASIC}\par
\par
{\f1   message:}\par
{\f1             DB    'Hello, World!', $0D, 0}\par
\par
{\f1             END   start}\par
\par
{\f1   Variante Apple II (moniteur) :}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.1b : Hello World - Apple II}\par
{\f1   ; Utilise la routine COUT du moniteur Apple II.}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $0300}\par
\par
{\f1   COUT      EQU   $FDED          ; Routine moniteur : afficher caractere}\par
\par
{\f1   start:}\par
{\f1             LDY   #0             ; Index dans la chaine}\par
{\f1   @loop:}\par
{\f1             LDA   message,Y      ; Charger le caractere}\par
{\f1             BEQ   @done          ; Zero = fin}\par
{\f1             ORA   #$80           ; Mettre le bit 7 (Apple II normal)}\par
{\f1             JSR   COUT           ; Afficher}\par
{\f1             INY                  ; Suivant}\par
{\f1             BNE   @loop          ; Boucler}\par
{\f1   @done:}\par
{\f1             RTS}\par
\par
{\f1   message:}\par
{\f1             DB    'Hello, World!', $0D, 0}\par
\par
{\f1             END   start}\par
\par
{\f1   Variante NES (PPU) :}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.1c : Hello World - NES}\par
{\f1   ; Ecrit directement dans la memoire video PPU.}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $8000}\par
\par
{\f1   PPUCTRL   EQU   $2000}\par
{\f1   PPUMASK   EQU   $2001}\par
{\f1   PPUSTAT   EQU   $2002}\par
{\f1   PPUADDR   EQU   $2006}\par
{\f1   PPUDATA   EQU   $2007}\par
\par
{\f1   start:}\par
{\f1             ; Attendre 2 VBlank pour que le PPU soit pret}\par
{\f1             LDA   PPUSTAT        ; Effacer le flag VBlank}\par
{\f1   @vb1:     LDA   PPUSTAT}\par
{\f1             BPL   @vb1           ; Attendre bit 7 = 1}\par
{\f1   @vb2:     LDA   PPUSTAT}\par
{\f1             BPL   @vb2           ; Deuxieme VBlank}\par
\par
{\f1             ; Positionner l'adresse PPU (nametable 0, ligne 14, col 10)}\par
{\f1             LDA   #$21           ; Adresse haute = $21}\par
{\f1             STA   PPUADDR}\par
{\f1             LDA   #$CA           ; Adresse basse = $CA}\par
{\f1             STA   PPUADDR}\par
\par
{\f1             ; Ecrire les tiles "Hello, World!"}\par
{\f1             LDX   #0}\par
{\f1   @loop:    LDA   message,X}\par
{\f1             BEQ   @done}\par
{\f1             STA   PPUDATA        ; Ecrire le tile dans la VRAM}\par
{\f1             INX}\par
{\f1             BNE   @loop}\par
{\f1   @done:}\par
\par
{\f1             ; Activer l'affichage}\par
{\f1             LDA   #%00001010     ; Afficher le fond, pas de clip gauche}\par
{\f1             STA   PPUMASK}\par
\par
{\f1   @infini:  JMP   @infini        ; Boucle infinie (le NES ne retourne pas)}\par
\par
{\f1   message:}\par
{\f1             DB    'Hello, World!', 0}\par
\par
{\f1             ; Vecteurs d'interruption}\par
{\f1             ORG   $FFFA}\par
{\f1             DW    start          ; NMI}\par
{\f1             DW    start          ; RESET}\par
{\f1             DW    start          ; IRQ/BRK}\par
\par
{\f1             END}\par
\par
\par
\b 9.2 Calcul de factorielle \b0\par
\par
{\f1   Calcul iteratif de N! pour des valeurs petites (resultat 8 bits}\par
{\f1   ou 16 bits). La recursion est peu pratique sur le 6502 en raison}\par
{\f1   de la pile limitee a 256 octets.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.2 : Factorielle iterative (8 bits)}\par
{\f1   ; Entree : X = N (0 a 5 pour rester en 8 bits)}\par
{\f1   ; Sortie : A = N!}\par
{\f1   ; Note : 5! = 120 (max pour un resultat 8 bits)}\par
{\f1   ;        Pour N > 5, utiliser la version 16 bits ci-dessous.}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $C000}\par
\par
{\f1   CHROUT    EQU   $FFD2}\par
\par
{\f1   start:}\par
{\f1             LDX   #5             ; Calculer 5!}\par
{\f1             JSR   factorielle    ; A = 120}\par
{\f1             JSR   print_dec      ; Afficher en decimal}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : factorielle}\par
{\f1   ; Entree : X = N (0-5)}\par
{\f1   ; Sortie : A = N!}\par
{\f1   ; Modifie : A, X, Y}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   factorielle:}\par
{\f1             CPX   #0             ; N == 0 ?}\par
{\f1             BEQ   @un            ; 0! = 1}\par
{\f1             CPX   #1             ; N == 1 ?}\par
{\f1             BEQ   @un            ; 1! = 1}\par
\par
{\f1             LDA   #1             ; Accumulateur = 1}\par
{\f1             STX   @count         ; Sauvegarder N}\par
{\f1             LDY   #1             ; Compteur de boucle = 1}\par
{\f1   @loop:}\par
{\f1             ; Multiplier A par Y (addition repetee)}\par
{\f1             TAX                  ; Sauvegarder A dans X}\par
{\f1             LDA   #0             ; Resultat partiel = 0}\par
{\f1             STY   @mult          ; Nombre de fois a ajouter}\par
{\f1   @madd:    CLC}\par
{\f1             ADC   @mult+1        ; Ajouter... non, on va simplifier}\par
{\f1             ; Methode simple : table de multiplication}\par
{\f1             ; Pour factorielle, on multiplie A * (Y+1)}\par
{\f1             ; On va utiliser une approche directe par table}\par
\par
{\f1             ; Version simplifiee avec table precalculee :}\par
{\f1             LDX   #0             ; Trouver X dans la table}\par
{\f1             RTS                  ; (voir version 16 bits ci-dessous)}\par
\par
{\f1   @un:      LDA   #1}\par
{\f1             RTS}\par
\par
{\f1   @count:   DB    0}\par
{\f1   @mult:    DW    0}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Version 16 bits : factorielle avec resultat sur 2 octets}\par
{\f1   ; Entree : A = N (0-8, car 8! = 40320 < 65535)}\par
{\f1   ; Sortie : result (2 octets, little-endian)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   result:   DW    0              ; Resultat 16 bits}\par
{\f1   temp:     DW    0              ; Temporaire pour multiplication}\par
\par
{\f1   fact16:}\par
{\f1             CMP   #0}\par
{\f1             BEQ   @un16}\par
{\f1             CMP   #1}\par
{\f1             BEQ   @un16}\par
\par
{\f1             TAX                  ; X = N (compteur)}\par
{\f1             LDA   #1             ; result = 1}\par
{\f1             STA   result}\par
{\f1             LDA   #0}\par
{\f1             STA   result+1}\par
\par
{\f1             LDY   #2             ; Multiplicateur = 2}\par
{\f1   @loop16:}\par
{\f1             ; Multiplier result par Y}\par
{\f1             ; result = result * Y (multiplication 16x8 -> 16)}\par
{\f1             LDA   result}\par
{\f1             STA   temp}\par
{\f1             LDA   result+1}\par
{\f1             STA   temp+1}\par
\par
{\f1             LDA   #0}\par
{\f1             STA   result}\par
{\f1             STA   result+1}\par
\par
{\f1             ; Additionner temp Y fois}\par
{\f1             STY   @cnt}\par
{\f1   @addlp:   CLC}\par
{\f1             LDA   result}\par
{\f1             ADC   temp}\par
{\f1             STA   result}\par
{\f1             LDA   result+1}\par
{\f1             ADC   temp+1}\par
{\f1             STA   result+1}\par
{\f1             DEC   @cnt}\par
{\f1             BNE   @addlp}\par
\par
{\f1             INY                  ; Multiplicateur suivant}\par
{\f1             DEX                  ; Decrementer N}\par
{\f1             CPX   #1}\par
{\f1             BNE   @loop16        ; Continuer si N > 1}\par
\par
{\f1             RTS}\par
\par
{\f1   @un16:    LDA   #1}\par
{\f1             STA   result}\par
{\f1             LDA   #0}\par
{\f1             STA   result+1}\par
{\f1             RTS}\par
\par
{\f1   @cnt:     DB    0}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : print_dec}\par
{\f1   ; Affiche la valeur de A en decimal (0-255).}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   print_dec:}\par
{\f1             LDX   #0             ; Flag centaines}\par
{\f1             CMP   #100}\par
{\f1             BCC   @dizaines}\par
{\f1   @cent:    SBC   #100           ; Soustraire 100}\par
{\f1             INX                  ; Compter les centaines}\par
{\f1             CMP   #100}\par
{\f1             BCS   @cent}\par
{\f1             PHA                  ; Sauvegarder le reste}\par
{\f1             TXA}\par
{\f1             CLC}\par
{\f1             ADC   #'0'           ; Convertir en ASCII}\par
{\f1             JSR   CHROUT         ; Afficher centaines}\par
{\f1             PLA}\par
{\f1             LDX   #1             ; Marquer qu'on a affiche}\par
{\f1   @dizaines:}\par
{\f1             LDY   #0             ; Compteur dizaines}\par
{\f1             CMP   #10}\par
{\f1             BCC   @unites_chk}\par
{\f1   @diz:     SBC   #10}\par
{\f1             INY}\par
{\f1             CMP   #10}\par
{\f1             BCS   @diz}\par
{\f1             PHA}\par
{\f1             TYA}\par
{\f1             CLC}\par
{\f1             ADC   #'0'}\par
{\f1             JSR   CHROUT         ; Afficher dizaines}\par
{\f1             PLA}\par
{\f1             JMP   @unites}\par
{\f1   @unites_chk:}\par
{\f1             CPX   #0             ; A-t-on deja affiche un chiffre ?}\par
{\f1             BEQ   @unites        ; Non -> afficher directement}\par
{\f1             PHA}\par
{\f1             LDA   #'0'           ; Afficher '0' pour les dizaines}\par
{\f1             JSR   CHROUT}\par
{\f1             PLA}\par
{\f1   @unites:}\par
{\f1             CLC}\par
{\f1             ADC   #'0'           ; Convertir en ASCII}\par
{\f1             JSR   CHROUT         ; Afficher unites}\par
{\f1             RTS}\par
\par
{\f1             END   start}\par
\par
\par
\b 9.3 Tri a bulles \b0\par
\par
{\f1   Tri d'un tableau d'octets par l'algorithme du tri a bulles}\par
{\f1   (bubble sort). Algorithme simple mais O(n^2).}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.3 : Tri a bulles (Bubble Sort)}\par
{\f1   ; Trie un tableau d'octets en ordre croissant.}\par
{\f1   ; Entree : tableau = adresse du tableau}\par
{\f1   ;          taille  = nombre d'elements}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $C000}\par
\par
{\f1   CHROUT    EQU   $FFD2}\par
\par
{\f1   taille    EQU   8              ; Nombre d'elements}\par
\par
{\f1   start:}\par
{\f1             JSR   bubble_sort    ; Trier le tableau}\par
{\f1             JSR   afficher       ; Afficher le resultat}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : bubble_sort}\par
{\f1   ; Trie 'tableau' (taille octets) en ordre croissant.}\par
{\f1   ; Algorithme :}\par
{\f1   ;   Repeter}\par
{\f1   ;     echange = faux}\par
{\f1   ;     Pour i = 0 a taille-2}\par
{\f1   ;       Si tableau[i] > tableau[i+1] Alors}\par
{\f1   ;         Echanger tableau[i] et tableau[i+1]}\par
{\f1   ;         echange = vrai}\par
{\f1   ;   Jusqu'a echange = faux}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   bubble_sort:}\par
{\f1   @passe:}\par
{\f1             LDA   #0}\par
{\f1             STA   @echange       ; echange = faux (0)}\par
{\f1             LDX   #0             ; i = 0}\par
{\f1   @comp:}\par
{\f1             LDA   tableau,X      ; A = tableau[i]}\par
{\f1             CMP   tableau+1,X    ; Comparer avec tableau[i+1]}\par
{\f1             BCC   @ok            ; Si tableau[i] < tableau[i+1], ok}\par
{\f1             BEQ   @ok            ; Si egaux, ok}\par
\par
{\f1             ; Echanger}\par
{\f1             LDY   tableau+1,X    ; Y = tableau[i+1]}\par
{\f1             STA   tableau+1,X    ; tableau[i+1] = A (ancien tableau[i])}\par
{\f1             TYA}\par
{\f1             STA   tableau,X      ; tableau[i] = Y (ancien tableau[i+1])}\par
{\f1             LDA   #1}\par
{\f1             STA   @echange       ; echange = vrai}\par
{\f1   @ok:}\par
{\f1             INX                  ; i++}\par
{\f1             CPX   #taille-1      ; i < taille-1 ?}\par
{\f1             BNE   @comp          ; Oui -> continuer}\par
\par
{\f1             LDA   @echange       ; Y a-t-il eu un echange ?}\par
{\f1             BNE   @passe         ; Oui -> nouvelle passe}\par
\par
{\f1             RTS}\par
\par
{\f1   @echange: DB    0}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : afficher}\par
{\f1   ; Affiche les elements du tableau separes par des espaces.}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   afficher:}\par
{\f1             LDX   #0}\par
{\f1   @loop:}\par
{\f1             LDA   tableau,X}\par
{\f1             JSR   print_dec      ; Afficher en decimal (voir 9.2)}\par
{\f1             LDA   #' '}\par
{\f1             JSR   CHROUT         ; Espace separateur}\par
{\f1             INX}\par
{\f1             CPX   #taille}\par
{\f1             BNE   @loop}\par
{\f1             LDA   #$0D}\par
{\f1             JSR   CHROUT         ; Retour chariot}\par
{\f1             RTS}\par
\par
{\f1   ; Donnees de test (non triees)}\par
{\f1   tableau:}\par
{\f1             DB    64, 25, 12, 99, 1, 47, 83, 36}\par
\par
{\f1   ; (print_dec : voir exemple 9.2)}\par
{\f1   print_dec:}\par
{\f1             ; ... (meme code que dans l'exemple 9.2)}\par
{\f1             RTS}\par
\par
{\f1             END   start}\par
\par
{\f1   Analyse de complexite :}\par
{\f1     - Pire cas (tableau inverse) : n*(n-1)/2 comparaisons}\par
{\f1     - Meilleur cas (deja trie) : n-1 comparaisons (1 passe)}\par
{\f1     - Pour 8 elements : 7 a 28 comparaisons}\par
{\f1     - Chaque comparaison/echange : ~20 cycles}\par
{\f1     - Temps approximatif : 0.14 ms a 0.56 ms a 1 MHz}\par
\par
\par
\b 9.4 Multiplication 16 bits \b0\par
\par
{\f1   Multiplication de deux nombres 16 bits non signes avec resultat}\par
{\f1   sur 32 bits, par l'algorithme de decalage et addition.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.4 : Multiplication 16 bits non signee}\par
{\f1   ; Entree : mplier (2 octets) = multiplicande}\par
{\f1   ;          mpcand (2 octets) = multiplicateur}\par
{\f1   ; Sortie : result (4 octets) = produit 32 bits}\par
{\f1   ; Methode : decalage et addition (shift-and-add)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $C000}\par
\par
{\f1   mplier:   DW    0              ; Multiplicande (16 bits)}\par
{\f1   mpcand:   DW    0              ; Multiplicateur (16 bits)}\par
{\f1   result:   DS    4              ; Resultat (32 bits)}\par
\par
{\f1   start:}\par
{\f1             ; Exemple : 1000 * 500 = 500000}\par
{\f1             LDA   #<1000         ; $E8}\par
{\f1             STA   mplier}\par
{\f1             LDA   #>1000         ; $03}\par
{\f1             STA   mplier+1}\par
\par
{\f1             LDA   #<500          ; $F4}\par
{\f1             STA   mpcand}\par
{\f1             LDA   #>500          ; $01}\par
{\f1             STA   mpcand+1}\par
\par
{\f1             JSR   mult16}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : mult16}\par
{\f1   ; Multiplication 16x16 -> 32 bits non signee}\par
{\f1   ; Algorithme :}\par
{\f1   ;   result = 0}\par
{\f1   ;   Pour chaque bit du multiplicateur (16 bits) :}\par
{\f1   ;     Decaler result a droite}\par
{\f1   ;     Si bit courant du multiplicateur = 1 :}\par
{\f1   ;       Ajouter multiplicande aux 16 bits hauts de result}\par
{\f1   ;     Decaler multiplicateur a droite}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   mult16:}\par
{\f1             ; Initialiser result a 0}\par
{\f1             LDA   #0}\par
{\f1             STA   result}\par
{\f1             STA   result+1}\par
{\f1             STA   result+2}\par
{\f1             STA   result+3}\par
\par
{\f1             LDX   #16            ; 16 bits a traiter}\par
{\f1   @loop:}\par
{\f1             ; Decaler result (32 bits) a droite}\par
{\f1             LSR   result+3}\par
{\f1             ROR   result+2}\par
{\f1             ROR   result+1}\par
{\f1             ROR   result}\par
\par
{\f1             ; Tester le bit 0 du multiplicateur}\par
{\f1             LSR   mpcand+1       ; Decaler mpcand a droite}\par
{\f1             ROR   mpcand}\par
{\f1             BCC   @noadd         ; Bit = 0 -> pas d'addition}\par
\par
{\f1             ; Ajouter mplier aux octets hauts de result}\par
{\f1             CLC}\par
{\f1             LDA   result+2}\par
{\f1             ADC   mplier}\par
{\f1             STA   result+2}\par
{\f1             LDA   result+3}\par
{\f1             ADC   mplier+1}\par
{\f1             STA   result+3}\par
\par
{\f1   @noadd:}\par
{\f1             DEX}\par
{\f1             BNE   @loop}\par
\par
{\f1             RTS}\par
\par
{\f1             END   start}\par
\par
{\f1   Verification : 1000 * 500 = 500000 = $0007A120}\par
{\f1     result+3 = $00, result+2 = $07, result+1 = $A1, result = $20}\par
\par
{\f1   Variante optimisee (multiplicande 8 bits) :}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Multiplication rapide 8x8 -> 16 bits}\par
{\f1   ; Entree : A = multiplicande, Y = multiplicateur}\par
{\f1   ; Sortie : prod (2 octets)}\par
{\f1   ; Plus rapide pour les petites valeurs.}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   prod:     DW    0}\par
\par
{\f1   mult8x8:}\par
{\f1             STA   @mcand         ; Sauvegarder multiplicande}\par
{\f1             LDA   #0}\par
{\f1             STA   prod}\par
{\f1             STA   prod+1}\par
\par
{\f1             TYA                  ; A = multiplicateur}\par
{\f1             LDX   #8             ; 8 bits}\par
{\f1   @loop:}\par
{\f1             LSR                  ; Bit de poids faible dans C}\par
{\f1             BCC   @noadd}\par
{\f1             PHA                  ; Sauvegarder A}\par
{\f1             CLC}\par
{\f1             LDA   prod}\par
{\f1             ADC   @mcand}\par
{\f1             STA   prod}\par
{\f1             LDA   prod+1}\par
{\f1             ADC   #0}\par
{\f1             STA   prod+1}\par
{\f1             PLA                  ; Restaurer A}\par
{\f1   @noadd:}\par
{\f1             ASL   @mcand         ; Decaler multiplicande a gauche}\par
{\f1             DEX}\par
{\f1             BNE   @loop}\par
{\f1             RTS}\par
\par
{\f1   @mcand:   DB    0}\par
\par
{\f1   Performances :}\par
{\f1     - Multiplication 16x16 : ~400 cycles (~0.4 ms a 1 MHz)}\par
{\f1     - Multiplication 8x8 : ~180 cycles (~0.18 ms a 1 MHz)}\par
{\f1     - Par comparaison, un MUL 16 bits sur 8086 : ~130 cycles}\par
{\f1     - Le 6502 n'a pas d'instruction de multiplication native,}\par
{\f1       d'ou la necessite de ces routines logicielles.}\par
\par
\par
\b 9.5 Routine de delai (temporisation) \b0\par
\par
{\f1   Routines de temporisation utilisant des boucles calibrees.}\par
{\f1   Le temps est calcule en cycles d'horloge du processeur.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.5 : Routines de delai}\par
{\f1   ; Base sur un processeur a 1 MHz (1 cycle = 1 microseconde).}\par
{\f1   ;}\par
{\f1   ; Delai court : delai_256us (~256 microsecondes)}\par
{\f1   ; Delai moyen : delai_ms (A millisecondes, 1-255)}\par
{\f1   ; Delai long  : delai_sec (A secondes, 1-255)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $C000}\par
\par
{\f1   start:}\par
{\f1             ; Exemple : clignoter la bordure pendant 5 secondes}\par
{\f1             LDX   #10            ; 10 clignotements}\par
{\f1   @blink:}\par
{\f1             LDA   #1             ; Couleur blanche}\par
{\f1             STA   $D020          ; Bordure blanche}\par
\par
{\f1             LDA   #250           ; 250 ms}\par
{\f1             JSR   delai_ms       ; Attendre}\par
\par
{\f1             LDA   #0             ; Couleur noire}\par
{\f1             STA   $D020          ; Bordure noire}\par
\par
{\f1             LDA   #250           ; 250 ms}\par
{\f1             JSR   delai_ms       ; Attendre}\par
\par
{\f1             DEX}\par
{\f1             BNE   @blink         ; Repeter}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : delai_256us}\par
{\f1   ; Delai d'environ 256 microsecondes (a 1 MHz).}\par
{\f1   ; Modifie : Y}\par
{\f1   ;}\par
{\f1   ; Calcul exact :}\par
{\f1   ;   LDY #$33 = 2 cycles}\par
{\f1   ;   DEY = 2 cycles * 51}\par
{\f1   ;   BNE = 3 cycles * 50 + 2 cycles * 1}\par
{\f1   ;   RTS = 6 cycles}\par
{\f1   ;   Total = 2 + (2+3)*50 + (2+2) + 6 = 260 cycles ??? 260 us}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   delai_256us:}\par
{\f1             LDY   #$33           ; 51 iterations}\par
{\f1   @loop:    DEY                  ; 2 cycles}\par
{\f1             BNE   @loop          ; 3 cycles (2 si pas de branchement)}\par
{\f1             RTS                  ; 6 cycles}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : delai_ms}\par
{\f1   ; Delai de A millisecondes (1-255).}\par
{\f1   ; Entree : A = nombre de millisecondes}\par
{\f1   ; Modifie : A, X, Y}\par
{\f1   ;}\par
{\f1   ; 1 ms = 1000 cycles a 1 MHz}\par
{\f1   ; Boucle interne : ~5 cycles * 200 = 1000 cycles = 1 ms}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   delai_ms:}\par
{\f1             TAX                  ; X = nombre de ms}\par
{\f1   @outer:}\par
{\f1             LDY   #200           ; 200 iterations internes}\par
{\f1   @inner:   NOP                  ; 2 cycles (ajustement)}\par
{\f1             DEY                  ; 2 cycles}\par
{\f1             BNE   @inner         ; 3 cycles -> 5 * 200 = 1000 cycles}\par
{\f1             DEX                  ; ms restantes}\par
{\f1             BNE   @outer         ; Boucler}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : delai_sec}\par
{\f1   ; Delai de A secondes (1-255).}\par
{\f1   ; Entree : A = nombre de secondes}\par
{\f1   ; Modifie : A, X, Y, @sec_cnt}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   delai_sec:}\par
{\f1             STA   @sec_cnt       ; Sauvegarder le compteur}\par
{\f1   @sec_lp:}\par
{\f1             ; 1 seconde = 4 * 250 ms}\par
{\f1             LDA   #250}\par
{\f1             JSR   delai_ms}\par
{\f1             LDA   #250}\par
{\f1             JSR   delai_ms}\par
{\f1             LDA   #250}\par
{\f1             JSR   delai_ms}\par
{\f1             LDA   #250}\par
{\f1             JSR   delai_ms}\par
\par
{\f1             DEC   @sec_cnt}\par
{\f1             BNE   @sec_lp}\par
{\f1             RTS}\par
\par
{\f1   @sec_cnt: DB    0}\par
\par
{\f1             END   start}\par
\par
{\f1   Notes sur la precision :}\par
{\f1     - Les delais sont approximatifs (??5%) en raison des cycles}\par
{\f1       supplementaires des instructions de controle de boucle}\par
{\f1     - Pour une temporisation precise, utiliser les timers CIA}\par
{\f1       du Commodore 64 ($DC04-$DC05) ou un timer equivalent}\par
{\f1     - Les interruptions (IRQ) perturbent le timing ; pour un}\par
{\f1       delai precis, desactiver les interruptions (SEI) avant}\par
{\f1       et les reactiver (CLI) apres}\par
{\f1     - Frequences courantes :}\par
{\f1       * Commodore 64 (PAL)  : 985248 Hz}\par
{\f1       * Commodore 64 (NTSC) : 1022727 Hz}\par
{\f1       * Apple II             : 1020484 Hz}\par
{\f1       * Atari 800 (PAL)     : 1773447 Hz}\par
{\f1       * NES (NTSC)           : 1789773 Hz}\par
\par
\par
\b 9.6 Copie de bloc memoire \b0\par
\par
{\f1   Routines pour copier, remplir et deplacer des blocs de memoire.}\par
{\f1   Le 6502 n'a pas d'instructions de bloc (comme REP MOVSB sur x86),}\par
{\f1   donc ces operations doivent etre codees manuellement.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.6a : Copie de bloc (jusqu'a 256 octets)}\par
{\f1   ; Entree : src  = adresse source (page zero, 2 octets)}\par
{\f1   ;          dst  = adresse destination (page zero, 2 octets)}\par
{\f1   ;          Y    = nombre d'octets a copier (1-256, 0 = 256)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1             ORG   $C000}\par
\par
{\f1   src       EQU   $FB            ; Pointeur source (page zero)}\par
{\f1   dst       EQU   $FD            ; Pointeur destination (page zero)}\par
\par
{\f1   start:}\par
{\f1             ; Copier 128 octets de $2000 vers $4000}\par
{\f1             LDA   #<$2000}\par
{\f1             STA   src}\par
{\f1             LDA   #>$2000}\par
{\f1             STA   src+1}\par
\par
{\f1             LDA   #<$4000}\par
{\f1             STA   dst}\par
{\f1             LDA   #>$4000}\par
{\f1             STA   dst+1}\par
\par
{\f1             LDY   #128           ; 128 octets}\par
{\f1             JSR   copy_blk}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : copy_blk}\par
{\f1   ; Copie Y octets de (src) vers (dst).}\par
{\f1   ; Copie de la fin vers le debut (Y-1 a 0).}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   copy_blk:}\par
{\f1             DEY                  ; Commencer a l'offset Y-1}\par
{\f1   @loop:}\par
{\f1             LDA   (src),Y        ; Charger octet source}\par
{\f1             STA   (dst),Y        ; Stocker a destination}\par
{\f1             DEY                  ; Octet precedent}\par
{\f1             BPL   @loop          ; Continuer tant que Y >= 0}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.6b : Copie de grand bloc (plus de 256 octets)}\par
{\f1   ; Entree : src    = adresse source (page zero)}\par
{\f1   ;          dst    = adresse destination (page zero)}\par
{\f1   ;          blklen = longueur en octets (2 octets)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   blklen:   DW    0              ; Longueur du bloc}\par
\par
{\f1   copy_big:}\par
{\f1             LDY   #0             ; Index dans la page courante}\par
{\f1             LDX   blklen+1       ; Nombre de pages completes}\par
{\f1             BEQ   @reste         ; Si 0, aller au reste}\par
\par
{\f1             ; Copier les pages completes (256 octets chacune)}\par
{\f1   @page:}\par
{\f1             LDA   (src),Y        ; Charger}\par
{\f1             STA   (dst),Y        ; Stocker}\par
{\f1             INY                  ; Octet suivant}\par
{\f1             BNE   @page          ; 256 octets par page}\par
\par
{\f1             INC   src+1          ; Page source suivante}\par
{\f1             INC   dst+1          ; Page destination suivante}\par
{\f1             DEX                  ; Page suivante}\par
{\f1             BNE   @page          ; Continuer}\par
\par
{\f1             ; Copier le reste (0 a 255 octets)}\par
{\f1   @reste:}\par
{\f1             LDX   blklen         ; Nombre d'octets restants}\par
{\f1             BEQ   @done          ; Si 0, termine}\par
{\f1   @tail:}\par
{\f1             LDA   (src),Y}\par
{\f1             STA   (dst),Y}\par
{\f1             INY}\par
{\f1             DEX}\par
{\f1             BNE   @tail}\par
{\f1   @done:}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.6c : Remplissage de bloc (memset)}\par
{\f1   ; Entree : dst    = adresse destination (page zero)}\par
{\f1   ;          A      = valeur de remplissage}\par
{\f1   ;          blklen = longueur en octets (2 octets)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   fill_blk:}\par
{\f1             LDY   #0}\par
{\f1             LDX   blklen+1       ; Pages completes}\par
{\f1             BEQ   @reste}\par
{\f1   @page:}\par
{\f1             STA   (dst),Y        ; Remplir}\par
{\f1             INY}\par
{\f1             BNE   @page          ; 256 octets}\par
{\f1             INC   dst+1          ; Page suivante}\par
{\f1             DEX}\par
{\f1             BNE   @page}\par
{\f1   @reste:}\par
{\f1             LDX   blklen         ; Octets restants}\par
{\f1             BEQ   @done}\par
{\f1   @tail:}\par
{\f1             STA   (dst),Y}\par
{\f1             INY}\par
{\f1             DEX}\par
{\f1             BNE   @tail}\par
{\f1   @done:}\par
{\f1             RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 9.6d : Copie avec recouvrement (memmove)}\par
{\f1   ; Si src < dst : copier de la fin vers le debut}\par
{\f1   ; Si src >= dst : copier du debut vers la fin}\par
{\f1   ; Entree : src, dst, blklen}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   move_blk:}\par
{\f1             ; Comparer src et dst}\par
{\f1             LDA   src+1}\par
{\f1             CMP   dst+1}\par
{\f1             BCC   @backward      ; src < dst (page haute)}\par
{\f1             BNE   @forward       ; src > dst}\par
{\f1             LDA   src}\par
{\f1             CMP   dst}\par
{\f1             BCC   @backward      ; src < dst (page basse)}\par
\par
{\f1   @forward:}\par
{\f1             ; Copie avant (src >= dst) - identique a copy_big}\par
{\f1             JMP   copy_big}\par
\par
{\f1   @backward:}\par
{\f1             ; Copie arriere (src < dst)}\par
{\f1             ; Positionner a la fin du bloc}\par
{\f1             CLC}\par
{\f1             LDA   src}\par
{\f1             ADC   blklen}\par
{\f1             STA   src}\par
{\f1             LDA   src+1}\par
{\f1             ADC   blklen+1}\par
{\f1             STA   src+1}\par
\par
{\f1             CLC}\par
{\f1             LDA   dst}\par
{\f1             ADC   blklen}\par
{\f1             STA   dst}\par
{\f1             LDA   dst+1}\par
{\f1             ADC   blklen+1}\par
{\f1             STA   dst+1}\par
\par
{\f1             ; Copier du dernier octet vers le premier}\par
{\f1             LDX   blklen+1       ; Pages}\par
{\f1             LDY   blklen         ; Reste}\par
{\f1             BEQ   @bkpage        ; Si reste = 0, commencer par pages}\par
{\f1   @bktail:}\par
{\f1             DEY}\par
{\f1             LDA   (src),Y}\par
{\f1             STA   (dst),Y}\par
{\f1             CPY   #0}\par
{\f1             BNE   @bktail}\par
\par
{\f1   @bkpage:}\par
{\f1             CPX   #0}\par
{\f1             BEQ   @bkdone}\par
{\f1             DEC   src+1}\par
{\f1             DEC   dst+1}\par
{\f1             LDY   #$FF}\par
{\f1   @bklp:}\par
{\f1             LDA   (src),Y}\par
{\f1             STA   (dst),Y}\par
{\f1             DEY}\par
{\f1             CPY   #$FF           ; Wraparound de 0 a $FF}\par
{\f1             BNE   @bklp}\par
{\f1             DEX}\par
{\f1             BNE   @bkpage}\par
\par
{\f1   @bkdone:}\par
{\f1             RTS}\par
\par
{\f1             END   start}\par
\par
{\f1   Performances comparees (copie de 1024 octets a 1 MHz) :}\par
\par
{\f1     Methode               Cycles       Temps}\par
{\f1     --------------------  -----------  ----------}\par
{\f1     copy_blk (256 oct.)   ~1540        ~1.5 ms}\par
{\f1     copy_big (1024 oct.)  ~9240        ~9.2 ms}\par
{\f1     fill_blk (1024 oct.)  ~6160        ~6.2 ms}\par
{\f1     DMA (C64, si dispo)   ~1024        ~1.0 ms}\par
\par
{\f1   Comparaison avec d'autres processeurs :}\par
\par
{\f1     Processeur     Instruction        Cycles/1024 oct.}\par
{\f1     -------------  -----------------  ----------------}\par
{\f1     MOS 6502       Boucle LDA/STA     ~9240}\par
{\f1     Zilog Z80      LDIR               ~5120}\par
{\f1     Intel 8086     REP MOVSB          ~9216}\par
{\f1     Motorola 68000 MOVE.L (loop)      ~12288}\par
{\f1     Intel 80386    REP MOVSD          ~2048}\par
\par
\par
