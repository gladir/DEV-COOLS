{\footnote # IDH_ASM6502_05}
{\footnote $ Assembleur 6502 - CODAGE DES INSTRUCTIONS (FORMAT BINAIRE)}
{\footnote K Assembleur 6502 codage instructions format binaire;opcode table;taille instruction;illegal opcodes;non documentes}
\b\fs24 CODAGE DES INSTRUCTIONS (FORMAT BINAIRE) \b0\fs20\par
\par
\par
\b 5.1 Structure generale de l'encodage \b0\par
\par
{\f1   Chaque instruction du 6502 est codee en binaire sous la forme d'une}\par
{\f1   sequence de 1, 2 ou 3 octets. Le format general est :}\par
\par
{\f1   +--------+-------------------+-------------------+}\par
{\f1   | Opcode | Operande bas      | Operande haut     |}\par
{\f1   | 1 oct  | 0 ou 1 octet      | 0 ou 1 octet      |}\par
{\f1   +--------+-------------------+-------------------+}\par
\par
{\f1   Le premier octet est toujours l'opcode, qui identifie a la fois}\par
{\f1   l'instruction et le mode d'adressage. Les octets suivants sont}\par
{\f1   l'operande (adresse ou valeur immediate), si necessaire.}\par
\par
{\f1   Proprietes fondamentales du codage 6502 :}\par
{\f1     - Pas de prefixes : l'opcode est toujours le premier octet}\par
{\f1     - Pas d'alignement : les instructions peuvent commencer a}\par
{\f1       n'importe quelle adresse}\par
{\f1     - Format little-endian : l'octet de poids faible d'une}\par
{\f1       adresse 16 bits est stocke en premier}\par
{\f1     - La taille d'une instruction est entierement determinee}\par
{\f1       par l'opcode (1, 2 ou 3 octets)}\par
{\f1     - Sur les 256 opcodes possibles ($00-$FF), seuls 151 sont}\par
{\f1       officiellement definis}\par
\par
{\f1   Taille des instructions selon le mode d'adressage :}\par
\par
{\f1     1 octet  : modes implicite et accumulateur}\par
{\f1                (pas d'operande)}\par
{\f1     2 octets : modes immediat, page zero, page zero indexe}\par
{\f1                (X ou Y), relatif, indirect indexe}\par
{\f1                (operande 8 bits)}\par
{\f1     3 octets : modes absolu, absolu indexe (X ou Y), indirect}\par
{\f1                (operande 16 bits en little-endian)}\par
\par
{\f1   Exemples de codage en memoire :}\par
\par
{\f1     CLC              -> $18             (1 octet)}\par
{\f1     LDA #$42         -> $A9 $42         (2 octets)}\par
{\f1     LDA $80          -> $A5 $80         (2 octets)}\par
{\f1     LDA $80,X        -> $B5 $80         (2 octets)}\par
{\f1     BEQ $FD          -> $F0 $FD         (2 octets, depl. = -3)}\par
{\f1     LDA $2000        -> $AD $00 $20     (3 octets, little-endian)}\par
{\f1     LDA $2000,X      -> $BD $00 $20     (3 octets)}\par
{\f1     JMP ($FFFC)      -> $6C $FC $FF     (3 octets)}\par
\par
{\f1   5.1.1 Structure de l'octet opcode}\par
\par
{\f1   L'opcode du 6502 encode simultanement l'instruction et le mode}\par
{\f1   d'adressage. Contrairement au 68000 ou au 80386, il n'y a pas}\par
{\f1   de champs reguliers dans l'opcode : le decodage est effectue}\par
{\f1   par une table de correspondance (lookup table) dans le processeur.}\par
\par
{\f1   Cependant, il existe un schema partiel dans la structure des}\par
{\f1   opcodes. En decomposant un opcode en trois champs de bits :}\par
\par
{\f1     7  6  5  4  3  2  1  0}\par
{\f1   +--+--+--+--+--+--+--+--+}\par
{\f1   |  aaa  |  bbb  |  cc   |}\par
{\f1   +--+--+--+--+--+--+--+--+}\par
\par
{\f1   Ou :}\par
{\f1     cc  (bits 1-0) : identifie le "groupe" d'instructions}\par
{\f1     bbb (bits 4-2) : identifie le mode d'adressage}\par
{\f1     aaa (bits 7-5) : identifie l'instruction dans le groupe}\par
\par
{\f1   Groupe cc = 01 (instructions ALU principales) :}\par
\par
{\f1     Les instructions du groupe 01 sont les plus regulieres.}\par
{\f1     Le champ bbb determine le mode d'adressage :}\par
\par
{\f1     bbb  Mode d'adressage}\par
{\f1     ---  --------------------------}\par
{\f1     000  (Indirect,X)  ($nn,X)}\par
{\f1     001  Page zero      $nn}\par
{\f1     010  Immediat       #$nn}\par
{\f1     011  Absolu         $nnnn}\par
{\f1     100  (Indirect),Y  ($nn),Y}\par
{\f1     101  Page zero,X    $nn,X}\par
{\f1     110  Absolu,Y       $nnnn,Y}\par
{\f1     111  Absolu,X       $nnnn,X}\par
\par
{\f1     Le champ aaa determine l'instruction :}\par
\par
{\f1     aaa  Instruction}\par
{\f1     ---  -----------}\par
{\f1     000  ORA}\par
{\f1     001  AND}\par
{\f1     010  EOR}\par
{\f1     011  ADC}\par
{\f1     100  STA}\par
{\f1     101  LDA}\par
{\f1     110  CMP}\par
{\f1     111  SBC}\par
\par
{\f1     Exemples de decodage (groupe 01) :}\par
{\f1     $A9 = 101 010 01 -> aaa=101 (LDA), bbb=010 (immediat), cc=01}\par
{\f1     $6D = 011 011 01 -> aaa=011 (ADC), bbb=011 (absolu), cc=01}\par
{\f1     $D1 = 110 100 01 -> aaa=110 (CMP), bbb=100 ((Ind),Y), cc=01}\par
{\f1     $85 = 100 001 01 -> aaa=100 (STA), bbb=001 (page zero), cc=01}\par
\par
{\f1     Exception : STA (aaa=100) n'a pas de mode immediat (bbb=010).}\par
{\f1     L'opcode $89 n'est pas defini officiellement.}\par
\par
{\f1   Groupe cc = 10 (decalages, chargements X/Y) :}\par
\par
{\f1     bbb  Mode d'adressage}\par
{\f1     ---  --------------------------}\par
{\f1     000  Immediat       #$nn}\par
{\f1     001  Page zero      $nn}\par
{\f1     010  Accumulateur   A (ou implicite)}\par
{\f1     011  Absolu         $nnnn}\par
{\f1     101  Page zero,X    $nn,X  (ou Page zero,Y pour LDX/STX)}\par
{\f1     111  Absolu,X       $nnnn,X (ou Absolu,Y pour LDX)}\par
\par
{\f1     aaa  Instruction}\par
{\f1     ---  -----------}\par
{\f1     000  ASL}\par
{\f1     001  ROL}\par
{\f1     010  LSR}\par
{\f1     011  ROR}\par
{\f1     100  STX (modes limites)}\par
{\f1     101  LDX}\par
{\f1     110  DEC}\par
{\f1     111  INC}\par
\par
{\f1     Note : ce groupe est moins regulier que le groupe 01.}\par
{\f1     Certaines combinaisons aaa/bbb ne sont pas definies.}\par
{\f1     STX et LDX utilisent l'indexation par Y au lieu de X}\par
{\f1     (Page zero,Y et Absolu,Y).}\par
\par
{\f1   Groupe cc = 00 (branchements, comparaisons, divers) :}\par
\par
{\f1     Ce groupe est le moins regulier. Il contient les instructions}\par
{\f1     de branchement, BIT, CPX, CPY, STY, LDY et les instructions}\par
{\f1     de controle.}\par
\par
{\f1     bbb  Mode d'adressage (quand applicable)}\par
{\f1     ---  --------------------------}\par
{\f1     000  Immediat       #$nn}\par
{\f1     001  Page zero      $nn}\par
{\f1     011  Absolu         $nnnn}\par
{\f1     101  Page zero,X    $nn,X}\par
{\f1     111  Absolu,X       $nnnn,X}\par
\par
{\f1     Les branchements conditionnels suivent un schema separe :}\par
{\f1     $10, $30, $50, $70, $90, $B0, $D0, $F0}\par
{\f1     soit aaa = 000 a 111, bbb = 100, cc = 00}\par
\par
{\f1     aaa  Branchement     Condition}\par
{\f1     ---  -----------     ---------}\par
{\f1     000  BPL             N = 0}\par
{\f1     001  BMI             N = 1}\par
{\f1     010  BVC             V = 0}\par
{\f1     011  BVS             V = 1}\par
{\f1     100  BCC             C = 0}\par
{\f1     101  BCS             C = 1}\par
{\f1     110  BNE             Z = 0}\par
{\f1     111  BEQ             Z = 1}\par
\par
\par
\b 5.2 Table complete des opcodes \b0\par
\par
{\f1   La table suivante liste les 256 opcodes possibles du 6502.}\par
{\f1   Les opcodes non documentes sont marques "---" (voir 5.4 pour}\par
{\f1   les details sur les opcodes non documentes).}\par
\par
{\f1   Format : les colonnes representent le quartet de poids faible}\par
{\f1   (bits 3-0), les lignes representent le quartet de poids fort}\par
{\f1   (bits 7-4).}\par
\par
{\f1        $x0     $x1     $x2     $x3     $x4     $x5     $x6     $x7}\par
{\f1   $0x  BRK     ORA     ---     ---     ---     ORA     ASL     ---}\par
{\f1        impl    (ind,X)                 zp      zp      zp}\par
\par
{\f1        $x8     $x9     $xA     $xB     $xC     $xD     $xE     $xF}\par
{\f1   $0x  PHP     ORA     ASL     ---     ---     ORA     ASL     ---}\par
{\f1        impl    #imm    A                       abs     abs}\par
\par
{\f1        $x0     $x1     $x2     $x3     $x4     $x5     $x6     $x7}\par
{\f1   $1x  BPL     ORA     ---     ---     ---     ORA     ASL     ---}\par
{\f1        rel     (ind),Y                 zp,X    zp,X    zp,X}\par
\par
{\f1        $x8     $x9     $xA     $xB     $xC     $xD     $xE     $xF}\par
{\f1   $1x  CLC     ORA     ---     ---     ---     ORA     ASL     ---}\par
{\f1        impl    abs,Y                           abs,X   abs,X}\par
\par
{\f1        $x0     $x1     $x2     $x3     $x4     $x5     $x6     $x7}\par
{\f1   $2x  JSR     AND     ---     ---     BIT     AND     ROL     ---}\par
{\f1        abs     (ind,X)                 zp      zp      zp}\par
\par
{\f1        $x8     $x9     $xA     $xB     $xC     $xD     $xE     $xF}\par
{\f1   $2x  PLP     AND     ROL     ---     BIT     AND     ROL     ---}\par
{\f1        impl    #imm    A               abs     abs     abs}\par
\par
{\f1        $x0     $x1     $x2     $x3     $x4     $x5     $x6     $x7}\par
{\f1   $3x  BMI     AND     ---     ---     ---     AND     ROL     ---}\par
{\f1        rel     (ind),Y                 zp,X    zp,X    zp,X}\par
\par
{\f1        $x8     $x9     $xA     $xB     $xC     $xD     $xE     $xF}\par
{\f1   $3x  SEC     AND     ---     ---     ---     AND     ROL     ---}\par
{\f1        impl    abs,Y                           abs,X   abs,X}\par
\par
{\f1        $x0     $x1     $x2     $x3     $x4     $x5     $x6     $x7}\par
{\f1   $4x  RTI     EOR     ---     ---     ---     EOR     LSR     ---}\par
{\f1        impl    (ind,X)                 zp      zp      zp}\par
\par
