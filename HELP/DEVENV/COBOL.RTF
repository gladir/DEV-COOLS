{\footnote # IDH_COBOL_15}
{\footnote $ COBOL - COMPILATEURS DU PROJET}
{\footnote K COBOL compilateurs projet;COBOL86.PAS;COBOLW32.PAS;MS-DOS;Win32 PE;LARGE;MASM}
\b\fs24 COMPILATEURS DU PROJET \b0\fs20\par
\par
\par
\b 15.1 COBOL86.PAS \b0\par
\par
{\f1   Cible             : MS-DOS, assembleur MASM .MODEL LARGE}\par
{\f1   Modele memoire    : LARGE (multi-segments 64KO)}\par
{\f1   Dialecte          : COBOL-85 sous-ensemble}\par
{\f1   Sortie            : fichier .ASM, MASM compatible}\par
\par
{\f1   Fonctionnalites :}\par
{\f1     - 4 DIVISIONS standard}\par
{\f1     - WORKING-STORAGE et LINKAGE SECTION}\par
{\f1     - PICTURE complet (9, X, A, V, S, P, edition)}\par
{\f1     - USAGE : DISPLAY, COMP, COMP-3, COMP-5}\par
{\f1     - Niveaux 01-49, 77, 88}\par
{\f1     - OCCURS et OCCURS DEPENDING ON, REDEFINES}\par
{\f1     - MOVE, COMPUTE, ADD, SUBTRACT, MULTIPLY, DIVIDE}\par
{\f1     - DISPLAY, ACCEPT}\par
{\f1     - PERFORM (simple, TIMES, UNTIL, VARYING, inline)}\par
{\f1     - IF/ELSE/END-IF, EVALUATE/END-EVALUATE}\par
{\f1     - STRING, UNSTRING, INSPECT}\par
{\f1     - Fichiers SEQUENTIAL, LINE SEQUENTIAL, INDEXED}\par
{\f1     - CALL/USING (BY REFERENCE, BY CONTENT)}\par
{\f1     - COPY (sans REPLACING)}\par
\par
{\f1   Limitations :}\par
{\f1     - Pas d'OO (CLASS-ID, METHOD-ID)}\par
{\f1     - Pas de Report Writer}\par
{\f1     - Pas de types nationaux (UTF-16)}\par
{\f1     - Pas de SORT/MERGE}\par
{\f1     - Pas de >>EXCEPTION (2002)}\par
\par
\par
\b 15.2 COBOLW32.PAS \b0\par
\par
{\f1   Cible             : Win32 PE}\par
{\f1   Modele memoire    : flat 32-bit}\par
{\f1   Dialecte          : COBOL-85 + extensions COBOL-2002}\par
{\f1   Sortie            : fichier .EXE Win32}\par
\par
{\f1   Fonctionnalites supplementaires vs COBOL86 :}\par
{\f1     - Format libre}\par
{\f1     - Types nationaux (NATIONAL, UTF-16)}\par
{\f1     - POINTER, ALLOCATE/FREE}\par
{\f1     - Fonctions intrinseques (LENGTH, UPPER-CASE,}\par
{\f1       LOWER-CASE, NUMVAL, CURRENT-DATE, etc.)}\par
{\f1     - SORT et MERGE}\par
{\f1     - COPY ... REPLACING}\par
\par
\par
\par
