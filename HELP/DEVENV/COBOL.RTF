{\footnote # IDH_COBOL_16}
{\footnote $ COBOL - EXEMPLES}
{\footnote K COBOL exemples;Hello World;boucle PERFORM VARYING;Factorielle;lecture fichier;sous-programme}
\b\fs24 EXEMPLES \b0\fs20\par
\par
\par
\b 16.1 Hello World \b0\par
\par
{\f1   IDENTIFICATION DIVISION.}\par
{\f1   PROGRAM-ID. HELLO.}\par
{\f1   PROCEDURE DIVISION.}\par
{\f1     DISPLAY "Hello, World!".}\par
{\f1     STOP RUN.}\par
\par
\par
\b 16.2 Boucle avec compteur \b0\par
\par
{\f1   IDENTIFICATION DIVISION.}\par
{\f1   PROGRAM-ID. COMPTE.}\par
\par
{\f1   DATA DIVISION.}\par
{\f1   WORKING-STORAGE SECTION.}\par
{\f1   01 WS-I    PIC 9(3).}\par
\par
{\f1   PROCEDURE DIVISION.}\par
{\f1   MAIN.}\par
{\f1     PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > 10}\par
{\f1       DISPLAY "Valeur: " WS-I}\par
{\f1     END-PERFORM.}\par
{\f1     STOP RUN.}\par
\par
\par
\b 16.3 Factorielle \b0\par
\par
{\f1   IDENTIFICATION DIVISION.}\par
{\f1   PROGRAM-ID. FACT.}\par
\par
{\f1   DATA DIVISION.}\par
{\f1   WORKING-STORAGE SECTION.}\par
{\f1   01 WS-N         PIC 9(2)  VALUE 10.}\par
{\f1   01 WS-I         PIC 9(2).}\par
{\f1   01 WS-RESULT    PIC 9(15) VALUE 1.}\par
\par
{\f1   PROCEDURE DIVISION.}\par
{\f1   MAIN.}\par
{\f1     PERFORM VARYING WS-I FROM 1 BY 1 UNTIL WS-I > WS-N}\par
{\f1       COMPUTE WS-RESULT = WS-RESULT * WS-I}\par
{\f1     END-PERFORM.}\par
{\f1     DISPLAY WS-N "! = " WS-RESULT.}\par
{\f1     STOP RUN.}\par
\par
\par
\b 16.4 Lecture de fichier \b0\par
\par
{\f1   IDENTIFICATION DIVISION.}\par
{\f1   PROGRAM-ID. LIRE-CLI.}\par
\par
{\f1   ENVIRONMENT DIVISION.}\par
{\f1   INPUT-OUTPUT SECTION.}\par
{\f1   FILE-CONTROL.}\par
{\f1     SELECT CLIENTS ASSIGN TO "CLIENTS.DAT"}\par
{\f1       ORGANIZATION IS LINE SEQUENTIAL}\par
{\f1       FILE STATUS  IS WS-FS.}\par
\par
{\f1   DATA DIVISION.}\par
{\f1   FILE SECTION.}\par
{\f1   FD CLIENTS.}\par
{\f1   01 CLI-REC.}\par
{\f1      05 CLI-CODE   PIC 9(5).}\par
{\f1      05 CLI-NOM    PIC X(30).}\par
{\f1      05 CLI-SOLDE  PIC 9(7)V99.}\par
\par
{\f1   WORKING-STORAGE SECTION.}\par
{\f1   01 WS-FS         PIC 99 VALUE 0.}\par
{\f1   01 WS-EOF        PIC X  VALUE "N".}\par
{\f1      88 FIN        VALUE "O".}\par
{\f1   01 WS-TOTAL      PIC 9(9)V99 VALUE 0.}\par
\par
{\f1   PROCEDURE DIVISION.}\par
{\f1   MAIN.}\par
{\f1     OPEN INPUT CLIENTS.}\par
{\f1     PERFORM UNTIL FIN}\par
{\f1       READ CLIENTS}\par
{\f1         AT END SET FIN TO TRUE}\par
{\f1         NOT AT END}\par
{\f1           DISPLAY CLI-CODE " " CLI-NOM " " CLI-SOLDE}\par
{\f1           ADD CLI-SOLDE TO WS-TOTAL}\par
{\f1       END-READ}\par
{\f1     END-PERFORM.}\par
{\f1     CLOSE CLIENTS.}\par
{\f1     DISPLAY "Total des soldes: " WS-TOTAL.}\par
{\f1     STOP RUN.}\par
\par
\par
\b 16.5 Sous-programme appele \b0\par
\par
Programme principal :\par
\par
{\f1   IDENTIFICATION DIVISION.}\par
{\f1   PROGRAM-ID. PRINCIPAL.}\par
\par
{\f1   DATA DIVISION.}\par
{\f1   WORKING-STORAGE SECTION.}\par
{\f1   01 WS-A   PIC 9(5)   VALUE 15.}\par
{\f1   01 WS-B   PIC 9(5)   VALUE 27.}\par
{\f1   01 WS-R   PIC 9(6).}\par
\par
{\f1   PROCEDURE DIVISION.}\par
{\f1     CALL "SOMME" USING WS-A WS-B WS-R.}\par
{\f1     DISPLAY WS-A " + " WS-B " = " WS-R.}\par
{\f1     STOP RUN.}\par
\par
Sous-programme SOMME :\par
\par
{\f1   IDENTIFICATION DIVISION.}\par
{\f1   PROGRAM-ID. SOMME.}\par
\par
{\f1   DATA DIVISION.}\par
{\f1   LINKAGE SECTION.}\par
{\f1   01 LK-A    PIC 9(5).}\par
{\f1   01 LK-B    PIC 9(5).}\par
{\f1   01 LK-R    PIC 9(6).}\par
\par
{\f1   PROCEDURE DIVISION USING LK-A LK-B LK-R.}\par
{\f1     COMPUTE LK-R = LK-A + LK-B.}\par
{\f1     EXIT PROGRAM.}\par
