{\footnote # IDH_ASM68000_09}
{\footnote $ Assembleur 68000 - DIRECTIVES ASSEMBLEUR}
{\footnote K Assembleur 68000 directives;ASM68.PAS;DC.B DC.W DC.L;DS.B DS.W DS.L;DCB;ORG END EQU SET;OPT LIST;MACRO ENDM;etiquettes symboles;expressions;formats numeriques}
\b\fs24 DIRECTIVES ASSEMBLEUR \b0\fs20\par
\par
{\f1   Les directives assembleur (aussi appelees pseudo-instructions ou}\par
{\f1   pseudo-opcodes) ne generent pas de code machine directement mais}\par
{\f1   controlent le processus d'assemblage : definition de donnees,}\par
{\f1   organisation memoire, symboles, macros, assemblage conditionnel}\par
{\f1   et generation de listing.}\par
\par
{\f1   Les directives varient selon l'assembleur utilise (Motorola ASM68K,}\par
{\f1   Devpac, VASM, AS, etc.) mais les concepts fondamentaux sont communs.}\par
{\f1   Cette section presente les directives les plus repandues.}\par
\par
\par
\b 9.1 Directives de definition de donnees \b0\par
\par
{\f1   9.1.1 DC - Define Constant}\par
\par
{\f1   La directive DC reserve de la memoire et l'initialise avec des}\par
{\f1   valeurs constantes. Le suffixe de taille determine l'unite :}\par
\par
{\f1     Syntaxe : [etiquette]  DC.s  valeur[,valeur,...]}\par
{\f1               s = B (octet), W (mot, defaut), L (long mot)}\par
\par
{\f1   Exemples :}\par
\par
{\f1     octet1:     DC.B    42               ; 1 octet = $2A}\par
{\f1     octets:     DC.B    1,2,3,4,5        ; 5 octets consecutifs}\par
{\f1     chaine:     DC.B    'Hello',0        ; Chaine terminee par zero}\par
{\f1     mot1:       DC.W    $1234            ; 1 mot = $1234}\par
{\f1     mots:       DC.W    100,200,300      ; 3 mots consecutifs}\par
{\f1     long1:      DC.L    $12345678        ; 1 long mot}\par
{\f1     adresse:    DC.L    ma_routine       ; Adresse 32 bits (relocalisable)}\par
{\f1     mixte:      DC.W    label2-label1    ; Expression (difference d'adresses)}\par
\par
{\f1   Notes :}\par
{\f1     - DC.B avec des chaines : chaque caractere occupe un octet}\par
{\f1     - DC.W et DC.L alignent automatiquement sur une adresse paire}\par
{\f1     - Les expressions symboliques sont evaluees a l'assemblage}\par
{\f1     - Certains assembleurs acceptent DC sans suffixe (defaut = .W)}\par
\par
{\f1   Codage memoire de DC.B 'AB',0,$FF :}\par
{\f1     Adresse    Contenu}\par
{\f1     --------   -------}\par
{\f1     $xxxx      $41      ; 'A'}\par
{\f1     $xxxx+1    $42      ; 'B'}\par
{\f1     $xxxx+2    $00      ; zero}\par
{\f1     $xxxx+3    $FF      ; $FF}\par
\par
{\f1   9.1.2 DCB - Define Constant Block}\par
\par
{\f1   DCB reserve un bloc de memoire initialise avec une valeur repetee :}\par
\par
{\f1     Syntaxe : [etiquette]  DCB.s  nombre, valeur}\par
\par
{\f1   Exemples :}\par
\par
{\f1     buffer:     DCB.B   256, 0           ; 256 octets a zero}\par
{\f1     tableau:    DCB.W   100, -1          ; 100 mots a $FFFF}\par
{\f1     longs:      DCB.L   50, $DEADBEEF   ; 50 long mots}\par
\par
{\f1   Note : Certains assembleurs utilisent BLKB/BLKW/BLKL a la place.}\par
\par
{\f1   9.1.3 DS - Define Storage (reserve sans initialiser)}\par
\par
{\f1   DS reserve de l'espace memoire sans initialisation (ou initialise}\par
{\f1   a zero selon l'assembleur) :}\par
\par
{\f1     Syntaxe : [etiquette]  DS.s  nombre}\par
\par
{\f1   Exemples :}\par
\par
{\f1     tampon:     DS.B    512              ; 512 octets reserves}\par
{\f1     variables:  DS.W    10               ; 10 mots reserves}\par
{\f1     pointeurs:  DS.L    8                ; 8 long mots reserves}\par
\par
{\f1   Notes :}\par
{\f1     - DS.W 0 est souvent utilise comme synonyme de EVEN (alignement)}\par
{\f1     - L'espace reserve n'est pas forcement initialise a zero en ROM}\par
{\f1     - En section BSS, DS est la directive habituelle}\par
\par
{\f1   Equivalences entre assembleurs :}\par
\par
{\f1     Motorola     Devpac       VASM/GNU     Description}\par
{\f1     ----------   ----------   ----------   -------------------------}\par
{\f1     DC.B         DC.B         .byte        Definir octet(s)}\par
{\f1     DC.W         DC.W         .word/.short Definir mot(s)}\par
{\f1     DC.L         DC.L         .long        Definir long mot(s)}\par
{\f1     DCB.B n,v    DCB.B n,v    .fill n,1,v  Bloc d'octets}\par
{\f1     DCB.W n,v    DCB.W n,v    .fill n,2,v  Bloc de mots}\par
{\f1     DS.B n       DS.B n       .space n     Reserve octets}\par
{\f1     DS.W n       DS.W n       .skip n*2    Reserve mots}\par
{\f1     DS.L n       DS.L n       .skip n*4    Reserve long mots}\par
\par
\par
\b 9.2 Directives d'organisation memoire \b0\par
\par
{\f1   9.2.1 ORG - Origin (adresse de base)}\par
\par
{\f1   ORG definit l'adresse a laquelle le code ou les donnees suivants}\par
{\f1   seront assembles :}\par
\par
{\f1     Syntaxe : ORG  adresse}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ORG     $000000          ; Vecteurs d'exception (debut ROM)}\par
{\f1     DC.L    $00FF0000        ; Vecteur SSP initial}\par
{\f1     DC.L    start            ; Vecteur PC initial (Reset)}\par
\par
{\f1     ORG     $001000          ; Code a l'adresse $1000}\par
{\f1     start:}\par
{\f1       LEA     pile, SP}\par
{\f1       ; ...}\par
\par
{\f1   Notes :}\par
{\f1     - ORG est principalement utilise pour le code absolu (ROM)}\par
{\f1     - Pour le code relocalisable, on utilise SECTION}\par
{\f1     - ORG n'est pas disponible dans tous les modes d'assemblage}\par
\par
{\f1   9.2.2 SECTION - Definition de section}\par
\par
{\f1   SECTION definit une section nommee du programme (code, donnees,}\par
{\f1   BSS). L'editeur de liens (linker) combine les sections de meme}\par
{\f1   nom et type.}\par
\par
{\f1     Syntaxe : SECTION  nom[,type]}\par
{\f1               type = CODE, DATA, BSS}\par
\par
{\f1   Exemples :}\par
\par
{\f1     SECTION  "text",CODE     ; Section de code}\par
{\f1     start:}\par
{\f1       MOVE.L  #message, A0}\par
{\f1       BSR     afficher}\par
{\f1       RTS}\par
\par
{\f1     SECTION  "data",DATA     ; Section de donnees initialisees}\par
{\f1     message:}\par
{\f1       DC.B    'Bonjour', 10, 0}\par
\par
{\f1     SECTION  "bss",BSS       ; Section de donnees non initialisees}\par
{\f1     tampon:}\par
{\f1       DS.B    1024}\par
\par
{\f1   Types de sections courants :}\par
\par
{\f1     Type     Description                     Contenu typique}\par
{\f1     ------   -----------------------------   -------------------------}\par
{\f1     CODE     Code executable (lecture seule)  Instructions, constantes}\par
{\f1     DATA     Donnees initialisees (R/W)       Variables globales init.}\par
{\f1     BSS      Donnees non initialisees (R/W)   Buffers, variables a zero}\par
\par
{\f1   Variantes selon les assembleurs :}\par
\par
{\f1     Motorola : SECTION nom,type}\par
{\f1     Devpac   : SECTION nom,type  ou  CODE/DATA/BSS (raccourcis)}\par
{\f1     VASM/GNU : .text / .data / .bss}\par
{\f1     AmigaOS  : SECTION nom,CODE_C (chip), CODE_F (fast), etc.}\par
\par
{\f1   9.2.3 ALIGN et EVEN - Alignement}\par
\par
{\f1   Ces directives alignent le compteur d'adresse sur une frontiere}\par
{\f1   specifique :}\par
\par
{\f1     EVEN                     ; Aligner sur mot (adresse paire)}\par
{\f1     ALIGN   4                ; Aligner sur long mot (multiple de 4)}\par
{\f1     ALIGN   16               ; Aligner sur paragraphe (16 octets)}\par
{\f1     CNOP    0,4              ; Aligner sur multiple de 4}\par
\par
{\f1   Exemples d'utilisation :}\par
\par
{\f1     chaine:  DC.B   'ABC'    ; 3 octets, adresse suivante impaire}\par
{\f1     EVEN                     ; Insere un octet de padding ($00)}\par
{\f1     mot1:    DC.W   $1234    ; Maintenant aligne sur adresse paire}\par
\par
{\f1   Notes :}\par
{\f1     - EVEN est equivalent a ALIGN 2 ou CNOP 0,2}\par
{\f1     - L'alignement est obligatoire pour DC.W et DC.L sur le 68000}\par
{\f1     - L'octet de padding est generalement $00 ou une valeur NOP}\par
{\f1     - CNOP offset,alignment permet un alignement avec decalage}\par
\par
{\f1   9.2.4 ODD - Alignement impair}\par
\par
{\f1   ODD force l'adresse suivante a etre impaire (rare, mais utile}\par
{\f1   dans certains cas specifiques) :}\par
\par
{\f1     ODD                      ; Adresse suivante impaire}\par
{\f1     ; Utilise tres rarement car le 68000 exige des acces pairs}\par
\par
{\f1   9.2.5 RORG - Relative Origin}\par
\par
{\f1   RORG definit un deplacement relatif au debut de la section}\par
{\f1   courante :}\par
\par
{\f1     Syntaxe : RORG  deplacement}\par
\par
{\f1     SECTION "data",DATA}\par
{\f1     RORG    $100             ; Aller au deplacement $100 dans DATA}\par
{\f1     table:}\par
{\f1       DC.W  1,2,3,4}\par
\par
{\f1   9.2.6 OFFSET - Section virtuelle pour les offsets}\par
\par
{\f1   OFFSET cree une section virtuelle pour calculer des offsets}\par
{\f1   de structure sans generer de code :}\par
\par
{\f1     Syntaxe : OFFSET  adresse_base}\par
\par
{\f1     OFFSET  0}\par
{\f1     obj_type:    DS.W  1     ; Offset 0, taille 2}\par
{\f1     obj_x:       DS.W  1     ; Offset 2, taille 2}\par
{\f1     obj_y:       DS.W  1     ; Offset 4, taille 2}\par
{\f1     obj_sprite:  DS.L  1     ; Offset 6, taille 4}\par
{\f1     obj_SIZE:    DS.W  0     ; Offset 10 = taille totale}\par
\par
{\f1     ; Utilisation :}\par
{\f1     MOVE.W  obj_x(A0), D0   ; Charger le champ x de l'objet en A0}\par
{\f1     MOVE.L  obj_sprite(A0), A1}\par
\par
{\f1   Cette technique est equivalente a utiliser EQU pour chaque offset,}\par
{\f1   mais DS calcule automatiquement les decalages.}\par
\par
\par
\b 9.3 Directives de symboles et etiquettes \b0\par
\par
{\f1   9.3.1 EQU - Equate (constante symbolique)}\par
\par
{\f1   EQU associe une valeur constante a un symbole. La valeur ne peut}\par
{\f1   pas etre changee apres definition.}\par
\par
{\f1     Syntaxe : symbole  EQU  expression}\par
\par
{\f1   Exemples :}\par
\par
{\f1     BUFFER_SIZE  EQU  1024        ; Taille du buffer}\par
{\f1     MAX_SPRITES  EQU  64          ; Nombre max de sprites}\par
{\f1     SCREEN_W     EQU  320         ; Largeur ecran}\par
{\f1     SCREEN_H     EQU  256         ; Hauteur ecran}\par
{\f1     SCREEN_SIZE  EQU  SCREEN_W*SCREEN_H ; Expression calculee}\par
\par
{\f1     ; Registres hardware Amiga}\par
{\f1     CUSTOM       EQU  $DFF000     ; Base des registres custom}\par
{\f1     DMACON       EQU  $096        ; Offset DMA control}\par
{\f1     INTENA       EQU  $09A        ; Offset interrupt enable}\par
{\f1     COLOR00      EQU  $180        ; Offset couleur 0}\par
\par
{\f1     ; Appels systeme (TRAP)}\par
{\f1     TRAP_DOS     EQU  1           ; Numero TRAP pour le DOS}\par
{\f1     GEMDOS       EQU  1           ; Atari ST : GEMDOS}\par
{\f1     BIOS         EQU  13          ; Atari ST : BIOS}\par
{\f1     XBIOS        EQU  14          ; Atari ST : XBIOS}\par
\par
{\f1   9.3.2 SET - Symbol Set (constante modifiable)}\par
\par
{\f1   SET est similaire a EQU mais permet de redefinir le symbole :}\par
\par
{\f1     Syntaxe : symbole  SET  expression}\par
\par
{\f1   Exemples :}\par
\par
{\f1     compteur  SET  0}\par
{\f1     ; ...}\par
{\f1     compteur  SET  compteur+1    ; Redefini a 1}\par
{\f1     ; ...}\par
{\f1     compteur  SET  compteur+1    ; Redefini a 2}\par
\par
{\f1   Note : SET est utile dans les macros pour creer des compteurs}\par
{\f1   ou des valeurs incrementales.}\par
\par
{\f1   9.3.3 = (assignation rapide)}\par
\par
{\f1   Certains assembleurs acceptent = comme synonyme de EQU ou SET :}\par
\par
{\f1     TAILLE = 256                  ; Equivalent a TAILLE EQU 256}\par
\par
{\f1   9.3.4 REG - Register List}\par
\par
{\f1   REG definit une liste de registres pour MOVEM :}\par
\par
{\f1     Syntaxe : symbole  REG  liste_registres}\par
\par
{\f1   Exemples :}\par
\par
{\f1     SAVEREGS   REG  D2-D7/A2-A6    ; Registres a sauvegarder}\par
{\f1     WORKREGS   REG  D0-D3/A0-A1    ; Registres de travail}\par
\par
{\f1     ; Utilisation :}\par
{\f1     MOVEM.L  SAVEREGS, -(SP)       ; Sauvegarder}\par
{\f1     ; ... travail ...}\par
{\f1     MOVEM.L  (SP)+, SAVEREGS       ; Restaurer}\par
\par
{\f1   9.3.5 XDEF / XREF - Symboles globaux et externes}\par
\par
{\f1   XDEF exporte un symbole pour le rendre visible a l'editeur de}\par
{\f1   liens. XREF importe un symbole defini dans un autre module.}\par
\par
{\f1     Syntaxe : XDEF  symbole[,symbole,...]}\par
{\f1               XREF  symbole[,symbole,...]}\par
\par
{\f1   Exemples :}\par
\par
{\f1     ; --- Module A (main.asm) ---}\par
{\f1     XREF    init_screen      ; Importer de screen.asm}\par
{\f1     XREF    draw_sprite      ; Importer de sprite.asm}\par
{\f1     XDEF    _start           ; Exporter le point d'entree}\par
\par
{\f1     _start:}\par
{\f1       BSR     init_screen}\par
{\f1       BSR     draw_sprite}\par
{\f1       RTS}\par
\par
{\f1     ; --- Module B (screen.asm) ---}\par
{\f1     XDEF    init_screen      ; Exporter}\par
{\f1     init_screen:}\par
{\f1       ; ... initialiser l'ecran ...}\par
{\f1       RTS}\par
\par
{\f1   Equivalences :}\par
\par
{\f1     Motorola  Devpac    VASM/GNU   Description}\par
{\f1     --------  --------  --------   ----------------------------}\par
{\f1     XDEF      XDEF      .global    Exporter symbole}\par
{\f1     XREF      XREF      .extern    Importer symbole}\par
{\f1     PUBLIC    PUBLIC     .globl     Exporter (syntaxe alternative)}\par
{\f1     EXTERN    EXTERN     .extern    Importer (syntaxe alternative)}\par
\par
{\f1   9.3.6 LOCAL - Etiquettes locales}\par
\par
{\f1   Les etiquettes locales sont visibles uniquement entre deux}\par
{\f1   etiquettes globales. Elles evitent les conflits de noms.}\par
\par
{\f1     Syntaxe : .etiquette   (prefixe point)}\par
{\f1               ou : chiffre$  (selon l'assembleur)}\par
\par
{\f1   Exemples :}\par
\par
{\f1     routine1:}\par
{\f1       MOVEQ    #10, D0}\par
{\f1     .loop:                       ; Locale a routine1}\par
{\f1       DBRA     D0, .loop}\par
{\f1       RTS}\par
\par
{\f1     routine2:}\par
{\f1       MOVEQ    #20, D0}\par
{\f1     .loop:                       ; Locale a routine2, pas de conflit}\par
{\f1       DBRA     D0, .loop}\par
{\f1       RTS}\par
\par
{\f1   Certains assembleurs utilisent des numeros :}\par
\par
{\f1     1$:  NOP                     ; Etiquette locale numerique}\par
{\f1          BRA  1$                 ; Reference avant ou arriere}\par
\par
\par
\b 9.4 Directives de controle d'assemblage \b0\par
\par
{\f1   9.4.1 IF / ELSE / ENDC - Assemblage conditionnel}\par
\par
{\f1   L'assemblage conditionnel permet d'inclure ou exclure du code}\par
{\f1   selon des conditions evaluees a l'assemblage :}\par
\par
{\f1     Syntaxe : IF[condition]  expression}\par
{\f1               [ELSE]}\par
{\f1               ENDC  (ou ENDIF)}\par
\par
{\f1   Variantes :}\par
\par
{\f1     IFEQ  expr       ; Si expr == 0}\par
{\f1     IFNE  expr       ; Si expr != 0}\par
{\f1     IFGT  expr       ; Si expr > 0}\par
{\f1     IFGE  expr       ; Si expr >= 0}\par
{\f1     IFLT  expr       ; Si expr < 0}\par
{\f1     IFLE  expr       ; Si expr <= 0}\par
{\f1     IFD   symbole    ; Si symbole est defini}\par
{\f1     IFND  symbole    ; Si symbole n'est pas defini}\par
{\f1     IFC   s1,s2      ; Si les chaines sont identiques}\par
{\f1     IFNC  s1,s2      ; Si les chaines sont differentes}\par
\par
{\f1   Exemples :}\par
\par
{\f1     DEBUG   EQU  1}\par
\par
{\f1     IFEQ  DEBUG}\par
{\f1       ; Code de production uniquement}\par
{\f1     ELSE}\par
{\f1       ; Code de debug uniquement}\par
{\f1       BSR     afficher_debug}\par
{\f1     ENDC}\par
\par
{\f1     MACHINE EQU 68020}\par
\par
{\f1     IFGE  MACHINE-68020}\par
{\f1       ; Utiliser des instructions 68020+}\par
{\f1       MULU.L  D1, D0           ; Multiplication 32x32}\par
{\f1     ELSE}\par
{\f1       ; Emulation 68000}\par
{\f1       BSR     mul32            ; Appel routine de multiplication}\par
{\f1     ENDC}\par
\par
{\f1     IFD   AMIGA}\par
{\f1       ; Code specifique Amiga}\par
{\f1       MOVE.L  4.W, A6          ; ExecBase}\par
{\f1     ENDC}\par
\par
{\f1     IFND  STANDALONE}\par
{\f1       ; Code avec OS}\par
{\f1       XREF    _LVOOpenLibrary}\par
{\f1     ENDC}\par
\par
{\f1   9.4.2 INCLUDE - Inclusion de fichier source}\par
\par
{\f1   INCLUDE insere le contenu d'un autre fichier source a l'endroit}\par
{\f1   de la directive :}\par
\par
{\f1     Syntaxe : INCLUDE  "fichier"}\par
\par
{\f1   Exemples :}\par
\par
{\f1     INCLUDE  "hardware.i"        ; Definitions hardware}\par
{\f1     INCLUDE  "macros.i"          ; Macros utilitaires}\par
{\f1     INCLUDE  "equates.i"         ; Constantes}\par
\par
{\f1   Notes :}\par
{\f1     - Les fichiers inclus peuvent eux-memes contenir des INCLUDE}\par
{\f1     - Le chemin est relatif au fichier source ou aux chemins d'inclusion}\par
{\f1     - Convention : extension .i pour les fichiers d'inclusion (includes)}\par
{\f1     - Convention : extension .s ou .asm pour les fichiers source}\par
\par
{\f1   9.4.3 INCBIN - Inclusion de fichier binaire}\par
\par
{\f1   INCBIN insere le contenu brut d'un fichier binaire dans le code}\par
{\f1   assemble :}\par
\par
{\f1     Syntaxe : INCBIN  "fichier"}\par
\par
{\f1   Exemples :}\par
\par
{\f1     sprite_data:}\par
{\f1       INCBIN   "player.raw"     ; Donnees graphiques brutes}\par
{\f1     font_data:}\par
{\f1       INCBIN   "font8x8.bin"    ; Police de caracteres}\par
{\f1     music_mod:}\par
{\f1       INCBIN   "music.mod"      ; Module musical}\par
\par
{\f1   Notes :}\par
{\f1     - Pas de transformation du contenu, insertion octet par octet}\par
{\f1     - Utilise pour les ressources : graphiques, sons, donnees}\par
{\f1     - Certains assembleurs permettent de specifier un offset et une taille :}\par
{\f1       INCBIN "fichier", offset, taille}\par
\par
{\f1   9.4.4 OPT - Options d'assemblage}\par
\par
{\f1   OPT modifie les options de l'assembleur en cours d'assemblage :}\par
\par
{\f1     Syntaxe : OPT  option[,option,...]}\par
\par
{\f1   Options courantes (Devpac) :}\par
\par
{\f1     OPT    O+          ; Optimisations activees}\par
{\f1     OPT    O-          ; Optimisations desactivees}\par
{\f1     OPT    OW+         ; Optimisation des branches (BRA.W -> BRA.S)}\par
{\f1     OPT    OW-         ; Pas d'optimisation des branches}\par
{\f1     OPT    P+          ; Afficher la passe d'assemblage}\par
{\f1     OPT    D+          ; Informations de debug}\par
{\f1     OPT    L+          ; Listing actif}\par
{\f1     OPT    S+          ; Table des symboles dans le listing}\par
{\f1     OPT    X+          ; Symboles etendus dans l'executable}\par
\par
{\f1   Options courantes (Motorola ASM68K) :}\par
\par
{\f1     OPT    BRL         ; Permettre les branches longues}\par
{\f1     OPT    CEX         ; Afficher les expansions conditionnelles}\par
{\f1     OPT    MEX         ; Afficher les expansions de macros}\par
{\f1     OPT    NOPAGE      ; Pas de saut de page dans le listing}\par
\par
{\f1   9.4.5 FAIL - Arret force de l'assemblage}\par
\par
{\f1   FAIL provoque une erreur d'assemblage volontaire, utile dans}\par
{\f1   les conditions non supportees :}\par
\par
{\f1     Syntaxe : FAIL  [message]}\par
\par
{\f1   Exemple :}\par
\par
{\f1     IFND  TARGET}\par
{\f1       FAIL  "TARGET doit etre defini (AMIGA, ATARI, ou GENERIC)"}\par
{\f1     ENDC}\par
\par
{\f1   9.4.6 END - Fin du source}\par
\par
{\f1   END marque la fin du fichier source. Tout ce qui suit est ignore.}\par
{\f1   Un parametre optionnel indique l'adresse de demarrage :}\par
\par
{\f1     Syntaxe : END  [adresse_demarrage]}\par
\par
{\f1   Exemples :}\par
\par
{\f1     END                          ; Fin sans adresse de demarrage}\par
{\f1     END     start                ; Fin avec point d'entree}\par
\par
\par
\b 9.5 Directives de listing \b0\par
\par
{\f1   Les directives de listing controlent la generation du fichier}\par
{\f1   listing (.lst) pendant l'assemblage.}\par
\par
{\f1   9.5.1 LIST / NOLIST - Activer/desactiver le listing}\par
\par
{\f1     LIST                         ; Reprendre le listing}\par
{\f1     NOLIST                       ; Suspendre le listing}\par
{\f1     ; Le code ici n'apparait pas dans le listing}\par
{\f1     LIST                         ; Reprendre}\par
\par
{\f1   Utilisation typique :}\par
\par
{\f1     NOLIST}\par
{\f1     INCLUDE  "hardware.i"        ; Ne pas lister les definitions}\par
{\f1     LIST}\par
\par
{\f1   9.5.2 PAGE - Saut de page}\par
\par
{\f1     PAGE                         ; Nouvelle page dans le listing}\par
\par
{\f1   9.5.3 TTL / TITLE - Titre du listing}\par
\par
{\f1     TTL     "Mon Programme 68000"  ; Titre en haut de chaque page}\par
\par
{\f1   9.5.4 SPC - Espacement}\par
\par
{\f1     SPC     3                    ; Inserer 3 lignes vides dans le listing}\par
\par
{\f1   9.5.5 FORMAT - Format du listing}\par
\par
{\f1     FORMAT                       ; Specifique a certains assembleurs}\par
{\f1     PLEN    66                   ; Longueur de page (lignes)}\par
{\f1     LLEN    132                  ; Largeur de ligne (colonnes)}\par
\par
\par
\b 9.6 Directives de macro \b0\par
\par
{\f1   Les macros permettent de definir des blocs de code reutilisables}\par
{\f1   avec des parametres.}\par
\par
{\f1   9.6.1 MACRO / ENDM - Definition de macro}\par
\par
{\f1     Syntaxe : nom  MACRO}\par
{\f1               ; corps de la macro avec \\1, \\2, ... pour les parametres}\par
{\f1               ENDM}\par
\par
{\f1   Exemple simple :}\par
\par
{\f1     PUSH    MACRO}\par
{\f1       MOVE.L  \\1, -(SP)           ; \\1 = premier parametre}\par
{\f1     ENDM}\par
\par
{\f1     POP     MACRO}\par
{\f1       MOVE.L  (SP)+, \\1           ; \\1 = premier parametre}\par
{\f1     ENDM}\par
\par
{\f1     ; Utilisation :}\par
{\f1     PUSH    D0                   ; Genere : MOVE.L D0, -(SP)}\par
{\f1     PUSH    A0                   ; Genere : MOVE.L A0, -(SP)}\par
{\f1     POP     A0                   ; Genere : MOVE.L (SP)+, A0}\par
{\f1     POP     D0                   ; Genere : MOVE.L (SP)+, D0}\par
\par
{\f1   9.6.2 Macros avec plusieurs parametres}\par
\par
{\f1     SWAP_MEM  MACRO}\par
{\f1       ; Echanger le contenu de deux adresses memoire}\par
{\f1       ; \\1 = adresse source, \\2 = adresse destination}\par
{\f1       MOVE.L  \\1, D0}\par
{\f1       MOVE.L  \\2, \\1}\par
{\f1       MOVE.L  D0, \\2}\par
{\f1     ENDM}\par
\par
{\f1     ; Utilisation :}\par
{\f1     SWAP_MEM  var_a, var_b}\par
\par
{\f1   9.6.3 NARG - Nombre d'arguments}\par
\par
{\f1   NARG contient le nombre de parametres passes a la macro :}\par
\par
{\f1     PUSHALL MACRO}\par
{\f1       IFGE  NARG-1}\par
{\f1         MOVE.L  \\1, -(SP)}\par
{\f1       ENDC}\par
{\f1       IFGE  NARG-2}\par
{\f1         MOVE.L  \\2, -(SP)}\par
{\f1       ENDC}\par
{\f1       IFGE  NARG-3}\par
{\f1         MOVE.L  \\3, -(SP)}\par
{\f1       ENDC}\par
{\f1     ENDM}\par
\par
{\f1     PUSHALL  D0               ; Empile D0}\par
{\f1     PUSHALL  D0, D1           ; Empile D0 puis D1}\par
{\f1     PUSHALL  D0, D1, A0       ; Empile D0, D1, A0}\par
\par
{\f1   9.6.4 MEXIT - Sortie anticipee de macro}\par
\par
{\f1   MEXIT termine l'expansion de la macro avant ENDM :}\par
\par
{\f1     SAFE_DIV  MACRO}\par
{\f1       ; Division securisee : \\1 / \\2 -> \\1}\par
{\f1       TST.L    \\2}\par
{\f1       BNE.S    .\\@ok}\par
{\f1       MOVEQ    #0, \\1           ; Division par zero -> 0}\par
{\f1       MEXIT}\par
{\f1     .\\@ok:}\par
{\f1       DIVS     \\2, \\1}\par
{\f1     ENDM}\par
\par
{\f1   9.6.5 \\@ - Etiquettes locales dans les macros}\par
\par
{\f1   \\@ genere un numero unique a chaque expansion de la macro,}\par
{\f1   evitant les conflits d'etiquettes :}\par
\par
{\f1     BSWAP16  MACRO}\par
{\f1       ; Inverser les octets d'un mot dans \\1}\par
{\f1       ROL.W    #8, \\1}\par
{\f1     ENDM}\par
\par
{\f1     WAITVBL  MACRO}\par
{\f1     .\\@wait:}\par
{\f1       MOVE.L  $DFF004, D0       ; VPOSR}\par
{\f1       AND.L   #$1FF00, D0}\par
{\f1       CMP.L   #$12C00, D0       ; Ligne 300 ?}\par
{\f1       BNE.S   .\\@wait}\par
{\f1     ENDM}\par
\par
{\f1     ; Chaque appel de WAITVBL genere des etiquettes uniques :}\par
{\f1     ;   .1wait, .2wait, .3wait, etc.}\par
\par
{\f1   9.6.6 Macros recursives}\par
\par
{\f1     COUNTDOWN  MACRO}\par
{\f1       IFC   '\\1','0'}\par
{\f1         MEXIT                   ; Fin de la recursion}\par
{\f1       ENDC}\par
{\f1       DC.W    \\1                ; Generer la valeur}\par
{\f1       COUNTDOWN \\1-1            ; Appel recursif (si supporte)}\par
{\f1     ENDM}\par
\par
{\f1   Note : La recursion de macros est limitee en profondeur et n'est}\par
{\f1   pas supportee par tous les assembleurs.}\par
\par
{\f1   9.6.7 Exemples pratiques de macros}\par
\par
{\f1     ; Macro d'appel systeme Amiga}\par
{\f1     CALLEXEC  MACRO}\par
{\f1       MOVE.L  4.W, A6           ; ExecBase}\par
{\f1       JSR     _LVO\\1(A6)        ; Appel fonction \\1}\par
{\f1     ENDM}\par
\par
{\f1     ; Utilisation :}\par
{\f1     CALLEXEC  AllocMem           ; JSR _LVOAllocMem(A6)}\par
{\f1     CALLEXEC  FreeMem            ; JSR _LVOFreeMem(A6)}\par
\par
{\f1     ; Macro d'affichage de chaine (Atari ST, GEMDOS)}\par
{\f1     PRINT   MACRO}\par
{\f1       PEA     \\1                 ; Adresse de la chaine}\par
{\f1       MOVE.W  #9, -(SP)         ; Fonction Cconws}\par
{\f1       TRAP    #1                 ; GEMDOS}\par
{\f1       ADDQ.L  #6, SP            ; Nettoyer la pile}\par
{\f1     ENDM}\par
\par
{\f1     ; Macro pour les structures}\par
{\f1     STRUCT_BEGIN  MACRO}\par
{\f1     \\1_BASE  SET  0}\par
{\f1     ENDM}\par
\par
{\f1     STRUCT_BYTE  MACRO}\par
{\f1     \\1  EQU  \\2_BASE}\par
{\f1     \\2_BASE  SET  \\2_BASE+1}\par
{\f1     ENDM}\par
\par
{\f1     STRUCT_WORD  MACRO}\par
{\f1     \\1  EQU  \\2_BASE}\par
{\f1     \\2_BASE  SET  \\2_BASE+2}\par
{\f1     ENDM}\par
\par
{\f1     STRUCT_LONG  MACRO}\par
{\f1     \\1  EQU  \\2_BASE}\par
{\f1     \\2_BASE  SET  \\2_BASE+4}\par
{\f1     ENDM}\par
\par
{\f1     STRUCT_END  MACRO}\par
{\f1     \\1_SIZE  EQU  \\1_BASE}\par
{\f1     ENDM}\par
\par
{\f1     ; Definition d'une structure via macros :}\par
{\f1     STRUCT_BEGIN  Player}\par
{\f1     STRUCT_WORD   Player_x, Player}\par
{\f1     STRUCT_WORD   Player_y, Player}\par
{\f1     STRUCT_LONG   Player_score, Player}\par
{\f1     STRUCT_BYTE   Player_lives, Player}\par
{\f1     STRUCT_END    Player}\par
{\f1     ; Genere : Player_x=0, Player_y=2, Player_score=4,}\par
{\f1     ;          Player_lives=8, Player_SIZE=9}\par
\par
\par
\b 9.7 Directives specifiques aux environnements \b0\par
\par
{\f1   9.7.1 Directives Amiga (assembleur Devpac/VASM)}\par
\par
{\f1     MACHINE  68000            ; Processeur cible}\par
{\f1     ; ou}\par
{\f1     MC68000                   ; Alternative}\par
\par
{\f1     FPU      68881            ; Coprocesseur flottant}\par
{\f1     ; ou}\par
{\f1     MC68881                   ; Alternative}\par
\par
{\f1     NEAR     A4               ; Adressage relatif via A4 (small data)}\par
{\f1     FAR                       ; Adressage absolu (annule NEAR)}\par
\par
{\f1     OPT      X+               ; Symboles etendus (pour debugger)}\par
\par
{\f1     ; Sections specifiques Amiga :}\par
{\f1     SECTION  "code",CODE_C    ; Code en chip RAM}\par
{\f1     SECTION  "data",DATA_F    ; Donnees en fast RAM}\par
{\f1     SECTION  "bss",BSS_C      ; BSS en chip RAM}\par
\par
{\f1   9.7.2 Directives Atari ST (assembleur Devpac ST)}\par
\par
{\f1     OPT      D+               ; Debug info pour MonST}\par
{\f1     OPT      X+               ; Symboles dans l'executable}\par
\par
{\f1     ; Programme TOS standard :}\par
{\f1     SECTION  TEXT              ; Section code}\par
{\f1     SECTION  DATA              ; Section donnees}\par
{\f1     SECTION  BSS               ; Section non initialisee}\par
\par
{\f1     ; Macros systeme :}\par
{\f1     gemdos   MACRO             ; Appel GEMDOS}\par
{\f1       MOVE.W  #\\1, -(SP)}\par
{\f1       TRAP    #1}\par
{\f1       ADDQ.L  #2, SP}\par
{\f1     ENDM}\par
\par
{\f1   9.7.3 Directives de ciblage processeur}\par
\par
{\f1   Ces directives indiquent au assembleur quel jeu d'instructions}\par
{\f1   est autorise :}\par
\par
{\f1     MC68000                   ; Instructions 68000 uniquement}\par
{\f1     MC68010                   ; + MOVEC, MOVES, BKPT, RTD}\par
{\f1     MC68020                   ; + BFCHG, BFCLR, CAS, MUL/DIV 32 bits}\par
{\f1     MC68030                   ; + PFLUSH, PLOAD (MMU integree)}\par
{\f1     MC68040                   ; + MOVE16, CINV, CPUSH}\par
{\f1     MC68060                   ; + quelques nouvelles instructions}\par
{\f1     MC68881                   ; Instructions FPU 68881}\par
{\f1     MC68882                   ; Instructions FPU 68882}\par
{\f1     MC68851                   ; Instructions MMU externe}\par
\par
{\f1   Equivalences VASM/GNU :}\par
\par
{\f1     .cpu 68000}\par
{\f1     .cpu 68020}\par
{\f1     .fpu 68881}\par
\par
\par
\b 9.8 Tableau recapitulatif des directives \b0\par
\par
{\f1   Directive        Syntaxe courte          Description}\par
{\f1   ---------------  ----------------------  --------------------------------}\par
{\f1   DC.B/W/L         DC.W $1234              Definir constante(s)}\par
{\f1   DCB.B/W/L        DCB.W 10,$FF            Bloc de constantes}\par
{\f1   DS.B/W/L         DS.L 100                Reserver espace}\par
{\f1   ORG              ORG $1000               Adresse de base}\par
{\f1   SECTION          SECTION "t",CODE        Section nommee}\par
{\f1   EVEN             EVEN                    Aligner sur mot}\par
{\f1   ALIGN            ALIGN 4                 Aligner sur frontiere}\par
{\f1   CNOP             CNOP 0,4                Aligner (offset,align)}\par
{\f1   EQU              SYM EQU 42              Constante symbolique}\par
{\f1   SET              SYM SET val             Constante modifiable}\par
{\f1   REG              R REG D2-D7/A2-A5      Liste de registres}\par
{\f1   XDEF             XDEF sym                Exporter symbole}\par
{\f1   XREF             XREF sym                Importer symbole}\par
{\f1   IFEQ/IFNE/...    IFEQ DEBUG              Assemblage conditionnel}\par
{\f1   IFD/IFND         IFD AMIGA               Test symbole defini}\par
{\f1   IFC/IFNC         IFC 'a','b'             Test chaines}\par
{\f1   ELSE             ELSE                    Branche alternative}\par
{\f1   ENDC             ENDC                    Fin de condition}\par
{\f1   INCLUDE          INCLUDE "f.i"           Inclure source}\par
{\f1   INCBIN           INCBIN "f.bin"          Inclure binaire}\par
{\f1   OPT              OPT O+,L+              Options assembleur}\par
{\f1   FAIL             FAIL "msg"              Erreur forcee}\par
{\f1   END              END [adr]               Fin du source}\par
{\f1   LIST/NOLIST      NOLIST                  Controle listing}\par
{\f1   PAGE             PAGE                    Saut de page}\par
{\f1   TTL              TTL "titre"             Titre listing}\par
{\f1   SPC              SPC 3                   Espacement listing}\par
{\f1   MACRO/ENDM       NOM MACRO/ENDM          Definition macro}\par
{\f1   MEXIT            MEXIT                   Sortie de macro}\par
{\f1   NARG             IFGE NARG-2             Nombre d'arguments}\par
{\f1   MACHINE          MC68000                 Processeur cible}\par
\par
\par
\b 9.9 Comparaison avec les directives 80386 \b0\par
\par
{\f1   Directive 68000       Directive 80386       Description}\par
{\f1   --------------------  --------------------  --------------------------}\par
{\f1   DC.B 'Hello',0        DB 'Hello',0          Definir octets}\par
{\f1   DC.W $1234            DW 1234h              Definir mots}\par
{\f1   DC.L $12345678        DD 12345678h          Definir double mots}\par
{\f1   DCB.B 100,0           DB 100 DUP(0)         Bloc repete}\par
{\f1   DS.B 256              DB 256 DUP(?)         Reserve sans init}\par
{\f1   DS.W 100              DW 100 DUP(?)         Reserve mots}\par
{\f1   ORG $1000             ORG 1000h             Adresse de base}\par
{\f1   SECTION "t",CODE      .CODE                 Section code}\par
{\f1   SECTION "d",DATA      .DATA                 Section donnees}\par
{\f1   SECTION "b",BSS       .DATA?                Section BSS}\par
{\f1   EVEN                  ALIGN 2               Aligner sur mot}\par
{\f1   ALIGN 4               ALIGN 4               Aligner sur dword}\par
{\f1   EQU                   EQU                   Constante}\par
{\f1   SET                   = (redefinissable)     Constante modifiable}\par
{\f1   XDEF                  PUBLIC                Exporter symbole}\par
{\f1   XREF                  EXTRN / EXTERN        Importer symbole}\par
{\f1   IFEQ/IFNE             IF / IFE              Condition}\par
{\f1   ELSE                  ELSE                  Branche sinon}\par
{\f1   ENDC                  ENDIF                 Fin condition}\par
{\f1   IFD                   IFDEF                 Si defini}\par
{\f1   IFND                  IFNDEF                Si non defini}\par
{\f1   INCLUDE "f"           INCLUDE f             Inclure source}\par
{\f1   INCBIN "f"            (pas d'equivalent)    Inclure binaire}\par
{\f1   MACRO/ENDM            MACRO/ENDM            Definition macro}\par
{\f1   \\1, \\2, ...           ARG1, ARG2, ...       Parametres macro}\par
{\f1   \\@                    LOCAL                 Etiquette locale macro}\par
{\f1   NARG                  (pas d'equivalent)    Nombre d'arguments}\par
{\f1   END                   END                   Fin source}\par
{\f1   LIST/NOLIST           .LIST / .NOLIST       Controle listing}\par
\par
{\f1   Differences notables :}\par
\par
{\f1   - La syntaxe 68000 utilise DC.B/W/L avec suffixe de taille ;}\par
{\f1     le 80386 utilise DB/DW/DD/DQ avec des mnemoniques distincts}\par
{\f1   - Le 68000 utilise \\1, \\2, ... pour les parametres de macros ;}\par
{\f1     le 80386 (MASM) utilise des noms de parametres explicites}\par
{\f1   - INCBIN n'a pas d'equivalent standard en MASM/TASM ;}\par
{\f1     il faut utiliser des outils externes ou des scripts}\par
{\f1   - DCB (bloc repete) utilise une syntaxe nombre,valeur ;}\par
{\f1     le 80386 utilise DUP(valeur) apres le nombre}\par
{\f1   - Les etiquettes locales de macros utilisent \\@ sur 68000 ;}\par
{\f1     MASM utilise la directive LOCAL}\par
{\f1   - SECTION du 68000 est plus flexible (nommage libre) ;}\par
{\f1     le 80386 utilise .CODE/.DATA/.STACK predefinies}\par
{\f1   - OPT du 68000 controle l'assembleur en ligne ;}\par
{\f1     le 80386 utilise OPTION ou des directives separees}\par
{\f1   - REG du 68000 nomme des listes de registres pour MOVEM ;}\par
{\f1     le 80386 n'a pas d'equivalent (PUSHA/POPA couvrent tous les reg.)}\par
\par
\par
\b 9.10 Resume \b0\par
\par
{\f1   Les directives assembleur du 68000 fournissent un ensemble complet}\par
{\f1   d'outils pour organiser et controler le processus d'assemblage.}\par
\par
{\f1   Points cles a retenir :}\par
\par
{\f1   - DC.B/W/L definissent des constantes avec alignement automatique}\par
{\f1     pour les tailles mot et long mot}\par
{\f1   - DS.B/W/L reservent de l'espace sans initialisation (section BSS)}\par
{\f1   - DCB.B/W/L creent des blocs repetes d'une valeur}\par
{\f1   - SECTION organise le code en sections CODE, DATA et BSS pour}\par
{\f1     l'editeur de liens}\par
{\f1   - EQU cree des constantes non modifiables, SET des constantes}\par
{\f1     modifiables (utile dans les macros)}\par
{\f1   - XDEF/XREF gerent la visibilite des symboles entre modules}\par
{\f1   - L'assemblage conditionnel (IF/ELSE/ENDC) permet des configurations}\par
{\f1     multi-cibles et multi-processeurs}\par
{\f1   - INCLUDE et INCBIN permettent la modularisation du source et}\par
{\f1     l'inclusion de ressources binaires}\par
{\f1   - Les macros (MACRO/ENDM) avec parametres \\1..\\9, \\@ et NARG}\par
{\f1     offrent une meta-programmation puissante}\par
{\f1   - EVEN et ALIGN sont essentiels sur le 68000 qui exige des acces}\par
{\f1     alignes pour les mots et longs mots}\par
{\f1   - OFFSET fournit un mecanisme elegant pour definir des structures}\par
\par
{\f1   Categories de directives :}\par
\par
{\f1   Categorie                     Directives principales}\par
{\f1   ----------------------------  --------------------------------}\par
{\f1   Definition de donnees         DC.B/W/L, DCB.B/W/L, DS.B/W/L}\par
{\f1   Organisation memoire          ORG, SECTION, EVEN, ALIGN, CNOP}\par
{\f1   Symboles et etiquettes        EQU, SET, REG, XDEF, XREF}\par
{\f1   Controle assemblage           IF/ELSE/ENDC, INCLUDE, INCBIN}\par
{\f1   Options et erreurs            OPT, FAIL, END}\par
{\f1   Listing                       LIST, NOLIST, PAGE, TTL, SPC}\par
{\f1   Macros                        MACRO/ENDM, MEXIT, NARG, \\@}\par
{\f1   Ciblage processeur            MC68000..MC68060, MC68881/MC68882}\par
\par
\par
