{\footnote $ Assembleur 68000 - EXEMPLES DE CODE}
{\footnote K Assembleur 68000 exemples;Hello World;factorielle;tri a bulles;multiplication 32 bits;routine delai;copie bloc memoire}
\b\fs24 EXEMPLES DE CODE \b0\fs20\par
\par
{\f1   Cette section presente des exemples complets de programmes en}\par
{\f1   assembleur 68000. Chaque exemple est commente et illustre une}\par
{\f1   technique ou un algorithme fondamental. Les exemples utilisent}\par
{\f1   les conventions de l'assembleur Motorola (syntaxe standard).}\par
\par
{\f1   Note : Les exemples utilisent TRAP #15 avec des codes de fonction}\par
{\f1   dans D0 pour les entrees/sorties, ce qui est une convention}\par
{\f1   courante dans les simulateurs 68000 (Easy68K, etc.). Sur un}\par
{\f1   systeme reel, les appels systeme varient selon l'OS (AmigaOS,}\par
{\f1   Atari TOS, etc.).}\par
\par
\par
\b 10.1 Hello World \b0\par
\par
{\f1   Programme minimal affichant un message a l'ecran.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.1 : Hello World}\par
{\f1   ; Affiche "Hello, World!" puis termine le programme.}\par
{\f1   ; Convention : TRAP #15, D0=13 pour afficher chaine (A1=adresse)}\par
{\f1   ;              TRAP #15, D0=9 pour terminer}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       message(PC), A1    ; Adresse du message dans A1}\par
{\f1     MOVE.B    #14, D0            ; Fonction : afficher chaine (A1)}\par
{\f1     TRAP      #15                ; Appel systeme}\par
{\f1     MOVE.B    #9, D0             ; Fonction : terminer le programme}\par
{\f1     TRAP      #15                ; Fin}\par
\par
{\f1   message:}\par
{\f1     DC.B      'Hello, World!', $0D, $0A, 0}\par
\par
{\f1     END       start}\par
\par
{\f1   Variante Atari ST (GEMDOS) :}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     PEA       message            ; Empiler adresse du message}\par
{\f1     MOVE.W    #9, -(SP)          ; Fonction Cconws (afficher chaine)}\par
{\f1     TRAP      #1                 ; Appel GEMDOS}\par
{\f1     ADDQ.L    #6, SP             ; Nettoyer la pile}\par
\par
{\f1     CLR.W     -(SP)              ; Code de retour 0}\par
{\f1     TRAP      #1                 ; Pterm0 - terminer le programme}\par
\par
{\f1   message:}\par
{\f1     DC.B      'Hello, World!', $0D, $0A, 0}\par
\par
{\f1     END       start}\par
\par
{\f1   Variante AmigaOS :}\par
\par
{\f1     XREF      _LVOOpenLibrary}\par
{\f1     XREF      _LVOCloseLibrary}\par
{\f1     XREF      _LVOOutput}\par
{\f1     XREF      _LVOWrite}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     MOVE.L    4.W, A6            ; ExecBase}\par
{\f1     LEA       dosname(PC), A1    ; "dos.library"}\par
{\f1     MOVEQ     #0, D0             ; Version minimale}\par
{\f1     JSR       _LVOOpenLibrary(A6)}\par
{\f1     MOVE.L    D0, A6             ; DOSBase dans A6}\par
{\f1     BEQ.S     .quit              ; Echec -> sortir}\par
\par
{\f1     JSR       _LVOOutput(A6)     ; Obtenir le handle stdout}\par
{\f1     MOVE.L    D0, D1             ; Handle dans D1}\par
{\f1     LEA       message(PC), A0}\par
{\f1     MOVE.L    A0, D2             ; Buffer dans D2}\par
{\f1     MOVEQ     #15, D3            ; Longueur "Hello, World!\\n"}\par
{\f1     JSR       _LVOWrite(A6)      ; Ecrire}\par
\par
{\f1     MOVE.L    A6, A1             ; DOSBase}\par
{\f1     MOVE.L    4.W, A6            ; ExecBase}\par
{\f1     JSR       _LVOCloseLibrary(A6)}\par
\par
{\f1   .quit:}\par
{\f1     RTS}\par
\par
{\f1   dosname:}\par
{\f1     DC.B      'dos.library', 0}\par
{\f1   message:}\par
{\f1     DC.B      'Hello, World!', $0A, 0}\par
{\f1     EVEN}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.2 Calcul de factorielle (recursif) \b0\par
\par
{\f1   Calcul recursif de N! utilisant la pile pour sauvegarder}\par
{\f1   les valeurs intermediaires.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.2 : Factorielle recursive}\par
{\f1   ; Entree : D0.L = N (entier positif)}\par
{\f1   ; Sortie : D0.L = N!}\par
{\f1   ; Utilise la pile pour la recursion.}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     MOVEQ     #7, D0             ; Calculer 7!}\par
{\f1     BSR       factorielle        ; Appel -> D0 = 5040}\par
\par
{\f1     ; Afficher le resultat (specifique au simulateur)}\par
{\f1     MOVE.B    #3, D0             ; Fonction : afficher entier D1}\par
{\f1     MOVE.L    D0, D1}\par
{\f1     TRAP      #15}\par
\par
{\f1     MOVE.B    #9, D0             ; Terminer}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : factorielle}\par
{\f1   ; Entree : D0.L = N}\par
{\f1   ; Sortie : D0.L = N!}\par
{\f1   ; Preservee : D1-D7, A0-A6}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   factorielle:}\par
{\f1     TST.L     D0                 ; N == 0 ?}\par
{\f1     BEQ.S     .cas_base          ; Oui -> retourner 1}\par
{\f1     CMP.L     #1, D0             ; N == 1 ?}\par
{\f1     BEQ.S     .cas_base          ; Oui -> retourner 1}\par
\par
{\f1     ; Cas recursif : N! = N * (N-1)!}\par
{\f1     MOVE.L    D0, -(SP)          ; Sauvegarder N sur la pile}\par
{\f1     SUBQ.L    #1, D0             ; D0 = N-1}\par
{\f1     BSR       factorielle        ; Appel recursif -> D0 = (N-1)!}\par
{\f1     MOVE.L    (SP)+, D1          ; Restaurer N dans D1}\par
{\f1     MULU      D1, D0             ; D0 = N * (N-1)! (16 bits)}\par
{\f1     RTS}\par
\par
{\f1   .cas_base:}\par
{\f1     MOVEQ     #1, D0             ; 0! = 1! = 1}\par
{\f1     RTS}\par
\par
{\f1     END       start}\par
\par
{\f1   Note : MULU est limite a 16 bits x 16 bits -> 32 bits sur le}\par
{\f1   68000. Pour des valeurs plus grandes, il faudrait une routine}\par
{\f1   de multiplication 32 bits (voir Section 8).}\par
\par
{\f1   Version iterative (plus efficace) :}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Factorielle iterative}\par
{\f1   ; Entree : D0.L = N}\par
{\f1   ; Sortie : D0.L = N!}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   fact_iter:}\par
{\f1     MOVE.L    D0, D1             ; D1 = N (compteur)}\par
{\f1     MOVEQ     #1, D0             ; D0 = resultat = 1}\par
{\f1     BRA.S     .test}\par
{\f1   .boucle:}\par
{\f1     MULU      D1, D0             ; resultat = resultat * compteur}\par
{\f1     SUBQ.W    #1, D1             ; compteur--}\par
{\f1   .test:}\par
{\f1     CMP.W     #1, D1             ; compteur > 1 ?}\par
{\f1     BGT.S     .boucle            ; Oui -> continuer}\par
{\f1     RTS}\par
\par
\par
\b 10.3 Tri a bulles \b0\par
\par
{\f1   Tri d'un tableau de mots (16 bits) en ordre croissant}\par
{\f1   par l'algorithme du tri a bulles (bubble sort).}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.3 : Tri a bulles}\par
{\f1   ; Trie un tableau de mots en ordre croissant.}\par
{\f1   ; Entree : A0 = adresse du tableau}\par
{\f1   ;          D7 = nombre d'elements - 1}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       tableau(PC), A0    ; Adresse du tableau}\par
{\f1     MOVE.W    #7, D7             ; 8 elements - 1}\par
{\f1     BSR       tri_bulles         ; Trier}\par
\par
{\f1     ; Afficher le tableau trie}\par
{\f1     LEA       tableau(PC), A0}\par
{\f1     MOVEQ     #7, D7}\par
{\f1   .affiche:}\par
{\f1     MOVE.W    (A0)+, D1          ; Lire element}\par
{\f1     EXT.L     D1                 ; Etendre a 32 bits}\par
{\f1     MOVE.B    #3, D0             ; Afficher entier}\par
{\f1     TRAP      #15}\par
{\f1     MOVE.B    #' ', D1           ; Espace separateur}\par
{\f1     MOVE.B    #6, D0             ; Afficher caractere}\par
{\f1     TRAP      #15}\par
{\f1     DBRA      D7, .affiche}\par
\par
{\f1     MOVE.B    #9, D0             ; Terminer}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : tri_bulles}\par
{\f1   ; Entree : A0 = adresse du tableau de mots}\par
{\f1   ;          D7 = nombre d'elements - 1}\par
{\f1   ; Modifie : D0-D2, D6-D7, A1}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   tri_bulles:}\par
{\f1     MOVEM.L   D0-D2/D6-D7/A0-A1, -(SP)  ; Sauvegarder registres}\par
\par
{\f1   .passe:}\par
{\f1     CLR.B     D6                 ; Flag : pas d'echange}\par
{\f1     MOVE.L    A0, A1             ; A1 pointe sur le debut}\par
{\f1     MOVE.W    D7, D2             ; Compteur interne}\par
\par
{\f1   .compare:}\par
{\f1     MOVE.W    (A1), D0           ; D0 = element courant}\par
{\f1     MOVE.W    2(A1), D1          ; D1 = element suivant}\par
{\f1     CMP.W     D1, D0             ; Comparer}\par
{\f1     BLE.S     .pas_echange       ; Si courant <= suivant, OK}\par
\par
{\f1     ; Echanger les deux elements}\par
{\f1     MOVE.W    D1, (A1)           ; Stocker le plus petit en premier}\par
{\f1     MOVE.W    D0, 2(A1)          ; Stocker le plus grand ensuite}\par
{\f1     MOVE.B    #1, D6             ; Marquer qu'un echange a eu lieu}\par
\par
{\f1   .pas_echange:}\par
{\f1     ADDQ.L    #2, A1             ; Avancer au mot suivant}\par
{\f1     SUBQ.W    #1, D2             ; Decrementer compteur}\par
{\f1     BNE.S     .compare           ; Continuer la passe}\par
\par
{\f1     TST.B     D6                 ; Y a-t-il eu des echanges ?}\par
{\f1     BNE.S     .passe             ; Oui -> refaire une passe}\par
\par
{\f1     MOVEM.L   (SP)+, D0-D2/D6-D7/A0-A1  ; Restaurer registres}\par
{\f1     RTS}\par
\par
{\f1   tableau:}\par
{\f1     DC.W      45, 12, 78, 3, 56, 99, 23, 67}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.4 Conversion ASCII vers entier (atoi) \b0\par
\par
{\f1   Convertit une chaine de caracteres decimaux en entier 32 bits.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.4 : atoi (ASCII to Integer)}\par
{\f1   ; Entree : A0 = adresse de la chaine ASCII terminee par 0}\par
{\f1   ; Sortie : D0.L = valeur entiere}\par
{\f1   ;          D1.B = 0 si OK, $FF si erreur}\par
{\f1   ; Gere le signe negatif en debut de chaine.}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       chaine(PC), A0     ; Adresse de la chaine}\par
{\f1     BSR       atoi               ; Convertir}\par
{\f1     ; D0 contient maintenant la valeur entiere}\par
\par
{\f1     MOVE.L    D0, D1}\par
{\f1     MOVE.B    #3, D0             ; Afficher le resultat}\par
{\f1     TRAP      #15}\par
{\f1     MOVE.B    #9, D0             ; Terminer}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : atoi}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   atoi:}\par
{\f1     MOVEM.L   D2-D4/A0, -(SP)   ; Sauvegarder registres}\par
{\f1     CLR.L     D0                 ; Resultat = 0}\par
{\f1     CLR.L     D1                 ; Flag erreur = OK}\par
{\f1     CLR.L     D2                 ; Caractere courant}\par
{\f1     MOVEQ     #0, D4             ; Flag signe (0 = positif)}\par
\par
{\f1     ; Verifier le signe}\par
{\f1     MOVE.B    (A0), D2}\par
{\f1     CMP.B     #'-', D2           ; Signe negatif ?}\par
{\f1     BNE.S     .test_plus}\par
{\f1     MOVEQ     #1, D4             ; Marquer negatif}\par
{\f1     ADDQ.L    #1, A0             ; Avancer}\par
{\f1     BRA.S     .boucle}\par
\par
{\f1   .test_plus:}\par
{\f1     CMP.B     #'+', D2           ; Signe positif explicite ?}\par
{\f1     BNE.S     .boucle}\par
{\f1     ADDQ.L    #1, A0             ; Avancer (signe + ignore)}\par
\par
{\f1   .boucle:}\par
{\f1     MOVE.B    (A0)+, D2          ; Lire caractere suivant}\par
{\f1     BEQ.S     .fin               ; Fin de chaine (zero terminal)}\par
\par
{\f1     ; Verifier que c'est un chiffre (0-9)}\par
{\f1     CMP.B     #'0', D2}\par
{\f1     BLT.S     .erreur}\par
{\f1     CMP.B     #'9', D2}\par
{\f1     BGT.S     .erreur}\par
\par
{\f1     ; resultat = resultat * 10 + chiffre}\par
{\f1     SUB.B     #'0', D2           ; Convertir ASCII -> valeur}\par
{\f1     EXT.W     D2}\par
{\f1     EXT.L     D2}\par
\par
{\f1     ; Multiplier D0 par 10 : D0*10 = D0*8 + D0*2}\par
{\f1     MOVE.L    D0, D3}\par
{\f1     LSL.L     #3, D0             ; D0 * 8}\par
{\f1     ADD.L     D3, D0             ; D0 * 9}\par
{\f1     ADD.L     D3, D0             ; D0 * 10}\par
{\f1     ADD.L     D2, D0             ; + chiffre}\par
{\f1     BRA.S     .boucle}\par
\par
{\f1   .erreur:}\par
{\f1     MOVE.B    #$FF, D1           ; Marquer erreur}\par
{\f1     BRA.S     .sortie}\par
\par
{\f1   .fin:}\par
{\f1     TST.B     D4                 ; Negatif ?}\par
{\f1     BEQ.S     .sortie}\par
{\f1     NEG.L     D0                 ; Inverser le signe}\par
\par
{\f1   .sortie:}\par
{\f1     MOVEM.L   (SP)+, D2-D4/A0   ; Restaurer registres}\par
{\f1     RTS}\par
\par
{\f1   chaine:}\par
{\f1     DC.B      '-12345', 0}\par
{\f1     EVEN}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.5 Conversion entier vers ASCII (itoa) \b0\par
\par
{\f1   Convertit un entier 32 bits signe en chaine ASCII decimale.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.5 : itoa (Integer to ASCII)}\par
{\f1   ; Entree : D0.L = valeur entiere signee}\par
{\f1   ;          A0 = adresse du buffer (au moins 12 octets)}\par
{\f1   ; Sortie : A0 = adresse du debut de la chaine dans le buffer}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     MOVE.L    #-9876, D0         ; Valeur a convertir}\par
{\f1     LEA       buffer(PC), A0     ; Buffer de sortie}\par
{\f1     BSR       itoa               ; Convertir}\par
\par
{\f1     ; Afficher le resultat}\par
{\f1     MOVE.L    A0, A1}\par
{\f1     MOVE.B    #14, D0            ; Afficher chaine}\par
{\f1     TRAP      #15}\par
{\f1     MOVE.B    #9, D0             ; Terminer}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : itoa}\par
{\f1   ; Methode : diviser par 10, empiler les restes, puis depiler.}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   itoa:}\par
{\f1     MOVEM.L   D0-D3/A1, -(SP)   ; Sauvegarder registres}\par
{\f1     MOVE.L    A0, A1             ; A1 = debut du buffer}\par
{\f1     CLR.L     D3                 ; Compteur de chiffres}\par
{\f1     TST.L     D0                 ; Nombre negatif ?}\par
{\f1     BPL.S     .positif}\par
\par
{\f1     ; Nombre negatif}\par
{\f1     NEG.L     D0                 ; Rendre positif}\par
{\f1     MOVE.B    #'-', (A1)+        ; Ecrire le signe}\par
\par
{\f1   .positif:}\par
{\f1     ; Empiler les chiffres (du moins significatif au plus significatif)}\par
{\f1     MOVE.L    A1, A0             ; Sauvegarder position debut chiffres}\par
\par
{\f1   .div_boucle:}\par
{\f1     ; Division par 10 : quotient dans D0, reste dans D1}\par
{\f1     MOVE.L    D0, D1}\par
{\f1     DIVU      #10, D0            ; D0[31:16] = reste, D0[15:0] = quotient}\par
{\f1     SWAP      D0                 ; D0[15:0] = reste}\par
{\f1     MOVE.W    D0, D2             ; D2 = reste (chiffre)}\par
{\f1     SWAP      D0                 ; D0[15:0] = quotient}\par
{\f1     AND.L     #$FFFF, D0         ; Nettoyer bits hauts}\par
\par
{\f1     ADD.B     #'0', D2           ; Convertir en ASCII}\par
{\f1     MOVE.B    D2, -(SP)          ; Empiler le chiffre}\par
{\f1     ADDQ.L    #1, D3             ; Compteur++}\par
\par
{\f1     TST.L     D0                 ; Quotient == 0 ?}\par
{\f1     BNE.S     .div_boucle        ; Non -> continuer}\par
\par
{\f1     ; Depiler les chiffres dans le buffer (ordre correct)}\par
{\f1   .depile:}\par
{\f1     MOVE.B    (SP)+, (A1)+       ; Chiffre de la pile vers le buffer}\par
{\f1     SUBQ.L    #1, D3}\par
{\f1     BNE.S     .depile}\par
\par
{\f1     MOVE.B    #0, (A1)           ; Terminateur zero}\par
{\f1     MOVEM.L   (SP)+, D0-D3/A1   ; Restaurer registres}\par
{\f1     RTS}\par
\par
{\f1   buffer:}\par
{\f1     DS.B      12                 ; Buffer pour la chaine (max 11 + zero)}\par
\par
{\f1     END       start}\par
\par
{\f1   Note : Cet exemple utilise DIVU (16 bits). Pour des nombres}\par
{\f1   superieurs a 65535, une routine de division 32 bits est necessaire.}\par
\par
\par
\b 10.6 Recherche binaire \b0\par
\par
{\f1   Recherche d'une valeur dans un tableau trie de mots (16 bits)}\par
{\f1   par dichotomie.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.6 : Recherche binaire (binary search)}\par
{\f1   ; Entree : A0 = adresse du tableau trie de mots}\par
{\f1   ;          D0.W = nombre d'elements}\par
{\f1   ;          D1.W = valeur cherchee}\par
{\f1   ; Sortie : D0.W = index si trouve, -1 si non trouve}\par
{\f1   ;          CCR : Z=1 si trouve, Z=0 si non trouve}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       tableau(PC), A0    ; Tableau trie}\par
{\f1     MOVE.W    #10, D0            ; 10 elements}\par
{\f1     MOVE.W    #56, D1            ; Chercher 56}\par
{\f1     BSR       recherche_bin      ; Rechercher}\par
\par
{\f1     BEQ.S     .trouve}\par
{\f1     ; Non trouve}\par
{\f1     LEA       msg_non(PC), A1}\par
{\f1     BRA.S     .affiche}\par
\par
{\f1   .trouve:}\par
{\f1     ; Trouve a l'index D0}\par
{\f1     MOVE.W    D0, D1}\par
{\f1     EXT.L     D1}\par
{\f1     MOVE.B    #3, D0             ; Afficher index}\par
{\f1     TRAP      #15}\par
\par
{\f1   .affiche:}\par
{\f1     MOVE.B    #9, D0             ; Terminer}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : recherche_bin}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   recherche_bin:}\par
{\f1     MOVEM.L   D2-D5/A1, -(SP)   ; Sauvegarder registres}\par
{\f1     CLR.W     D2                 ; D2 = gauche = 0}\par
{\f1     MOVE.W    D0, D3             ; D3 = droite = n}\par
{\f1     SUBQ.W    #1, D3             ; D3 = n - 1}\par
\par
{\f1   .boucle:}\par
{\f1     CMP.W     D3, D2             ; gauche > droite ?}\par
{\f1     BGT.S     .non_trouve        ; Oui -> non trouve}\par
\par
{\f1     ; milieu = (gauche + droite) / 2}\par
{\f1     MOVE.W    D2, D4}\par
{\f1     ADD.W     D3, D4}\par
{\f1     LSR.W     #1, D4             ; D4 = milieu}\par
\par
{\f1     ; Comparer tableau[milieu] avec la valeur cherchee}\par
{\f1     MOVE.W    D4, D5}\par
{\f1     LSL.W     #1, D5             ; D5 = milieu * 2 (offset en octets)}\par
{\f1     MOVE.W    0(A0,D5.W), D0    ; D0 = tableau[milieu]}\par
\par
{\f1     CMP.W     D1, D0             ; Comparer avec valeur cherchee}\par
{\f1     BEQ.S     .trouve            ; Egal -> trouve !}\par
{\f1     BLT.S     .aller_droite      ; tableau[milieu] < valeur}\par
\par
{\f1     ; tableau[milieu] > valeur : chercher a gauche}\par
{\f1     MOVE.W    D4, D3             ; droite = milieu - 1}\par
{\f1     SUBQ.W    #1, D3}\par
{\f1     BRA.S     .boucle}\par
\par
{\f1   .aller_droite:}\par
{\f1     ; tableau[milieu] < valeur : chercher a droite}\par
{\f1     MOVE.W    D4, D2             ; gauche = milieu + 1}\par
{\f1     ADDQ.W    #1, D2}\par
{\f1     BRA.S     .boucle}\par
\par
{\f1   .trouve:}\par
{\f1     MOVE.W    D4, D0             ; D0 = index trouve}\par
{\f1     ; Z flag est deja positionne par CMP.W D1,D0 (BEQ.S .trouve)}\par
{\f1     ORI       #%00000100, CCR    ; Forcer Z=1}\par
{\f1     MOVEM.L   (SP)+, D2-D5/A1}\par
{\f1     RTS}\par
\par
{\f1   .non_trouve:}\par
{\f1     MOVE.W    #-1, D0            ; D0 = -1 (non trouve)}\par
{\f1     ANDI      #%11111011, CCR    ; Forcer Z=0}\par
{\f1     MOVEM.L   (SP)+, D2-D5/A1}\par
{\f1     RTS}\par
\par
{\f1   msg_non:}\par
{\f1     DC.B      'Non trouve', $0D, $0A, 0}\par
{\f1     EVEN}\par
\par
{\f1   tableau:}\par
{\f1     DC.W      3, 12, 23, 34, 45, 56, 67, 78, 89, 99}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.7 Copie de chaine (strcpy) \b0\par
\par
{\f1   Copie une chaine terminee par zero d'une source vers une}\par
{\f1   destination.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.7 : strcpy}\par
{\f1   ; Entree : A0 = adresse destination}\par
{\f1   ;          A1 = adresse source}\par
{\f1   ; Sortie : A0 = adresse destination (inchangee)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       source(PC), A1     ; Chaine source}\par
{\f1     LEA       dest, A0           ; Buffer destination}\par
{\f1     BSR       strcpy             ; Copier}\par
\par
{\f1     ; Afficher la copie}\par
{\f1     MOVE.L    A0, A1}\par
{\f1     MOVE.B    #14, D0}\par
{\f1     TRAP      #15}\par
\par
{\f1     MOVE.B    #9, D0}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : strcpy (version simple)}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   strcpy:}\par
{\f1     MOVE.L    A0, -(SP)          ; Sauvegarder adresse debut}\par
{\f1     MOVE.L    A2, -(SP)          ; Sauvegarder A2}\par
{\f1     MOVE.L    A0, A2             ; A2 = pointeur destination}\par
\par
{\f1   .copie:}\par
{\f1     MOVE.B    (A1)+, (A2)+       ; Copier un octet}\par
{\f1     BNE.S     .copie             ; Continuer si pas zero}\par
\par
{\f1     MOVE.L    (SP)+, A2          ; Restaurer A2}\par
{\f1     MOVE.L    (SP)+, A0          ; Restaurer adresse debut}\par
{\f1     RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : strcpy optimisee (copie par long mots)}\par
{\f1   ; Suppose que source et destination sont alignees sur 4 octets}\par
{\f1   ; et que la longueur est connue.}\par
{\f1   ; Entree : A0 = dest (alignee), A1 = src (alignee), D0.L = longueur}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   strcpy_fast:}\par
{\f1     MOVEM.L   D0-D1/A0-A1, -(SP)}\par
\par
{\f1     ; Copier par blocs de 4 octets}\par
{\f1     MOVE.L    D0, D1}\par
{\f1     LSR.L     #2, D1             ; Nombre de long mots}\par
{\f1     BRA.S     .test_long}\par
\par
{\f1   .copie_long:}\par
{\f1     MOVE.L    (A1)+, (A0)+       ; Copier 4 octets}\par
{\f1   .test_long:}\par
{\f1     DBRA      D1, .copie_long}\par
\par
{\f1     ; Copier les octets restants}\par
{\f1     AND.L     #3, D0             ; D0 = octets restants}\par
{\f1     BRA.S     .test_reste}\par
\par
{\f1   .copie_reste:}\par
{\f1     MOVE.B    (A1)+, (A0)+       ; Copier 1 octet}\par
{\f1   .test_reste:}\par
{\f1     DBRA      D0, .copie_reste}\par
\par
{\f1     MOVEM.L   (SP)+, D0-D1/A0-A1}\par
{\f1     RTS}\par
\par
{\f1   source:}\par
{\f1     DC.B      'Assembleur 68000 est puissant !', 0}\par
{\f1     EVEN}\par
\par
{\f1   dest:}\par
{\f1     DS.B      64                 ; Buffer destination}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.8 Longueur de chaine (strlen) \b0\par
\par
{\f1   Calcule la longueur d'une chaine terminee par zero.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.8 : strlen}\par
{\f1   ; Entree : A0 = adresse de la chaine}\par
{\f1   ; Sortie : D0.L = longueur (sans le zero terminal)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       chaine(PC), A0     ; Adresse de la chaine}\par
{\f1     BSR       strlen             ; Calculer longueur}\par
\par
{\f1     MOVE.L    D0, D1}\par
{\f1     MOVE.B    #3, D0             ; Afficher longueur}\par
{\f1     TRAP      #15}\par
{\f1     MOVE.B    #9, D0             ; Terminer}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : strlen (version simple)}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   strlen:}\par
{\f1     MOVE.L    A0, -(SP)          ; Sauvegarder A0}\par
{\f1     CLR.L     D0                 ; Compteur = 0}\par
\par
{\f1   .boucle:}\par
{\f1     TST.B     (A0)+              ; Caractere nul ?}\par
{\f1     BEQ.S     .fin               ; Oui -> fin}\par
{\f1     ADDQ.L    #1, D0             ; Compteur++}\par
{\f1     BRA.S     .boucle            ; Continuer}\par
\par
{\f1   .fin:}\par
{\f1     MOVE.L    (SP)+, A0          ; Restaurer A0}\par
{\f1     RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : strlen optimisee}\par
{\f1   ; Utilise la soustraction de pointeurs pour eviter le compteur.}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   strlen_fast:}\par
{\f1     MOVE.L    A0, D0             ; Sauvegarder adresse debut}\par
{\f1     MOVE.L    A0, -(SP)}\par
\par
{\f1   .scan:}\par
{\f1     TST.B     (A0)+              ; Caractere nul ?}\par
{\f1     BNE.S     .scan              ; Non -> continuer}\par
\par
{\f1     SUBQ.L    #1, A0             ; Reculer (on a depasse le zero)}\par
{\f1     SUB.L     D0, A0             ; A0 = adresse_fin - adresse_debut}\par
{\f1     MOVE.L    A0, D0             ; D0 = longueur}\par
{\f1     MOVE.L    (SP)+, A0          ; Restaurer A0}\par
{\f1     RTS}\par
\par
{\f1   chaine:}\par
{\f1     DC.B      'Ceci est un test de longueur de chaine', 0}\par
{\f1     EVEN}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.9 Comparaison de chaines (strcmp) \b0\par
\par
{\f1   Compare deux chaines terminee par zero.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.9 : strcmp}\par
{\f1   ; Entree : A0 = adresse chaine 1}\par
{\f1   ;          A1 = adresse chaine 2}\par
{\f1   ; Sortie : D0.B = 0 si egales}\par
{\f1   ;          D0.B < 0 si chaine1 < chaine2}\par
{\f1   ;          D0.B > 0 si chaine1 > chaine2}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       ch1(PC), A0}\par
{\f1     LEA       ch2(PC), A1}\par
{\f1     BSR       strcmp}\par
\par
{\f1     TST.B     D0}\par
{\f1     BEQ.S     .egales}\par
{\f1     BMI.S     .inf}\par
{\f1     ; Superieur}\par
{\f1     LEA       msg_sup(PC), A1}\par
{\f1     BRA.S     .affiche}\par
{\f1   .inf:}\par
{\f1     LEA       msg_inf(PC), A1}\par
{\f1     BRA.S     .affiche}\par
{\f1   .egales:}\par
{\f1     LEA       msg_egal(PC), A1}\par
\par
{\f1   .affiche:}\par
{\f1     MOVE.B    #14, D0}\par
{\f1     TRAP      #15}\par
{\f1     MOVE.B    #9, D0}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : strcmp}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   strcmp:}\par
{\f1     MOVEM.L   A0-A1, -(SP)}\par
\par
{\f1   .boucle:}\par
{\f1     MOVE.B    (A0)+, D0          ; Lire caractere chaine 1}\par
{\f1     CMP.B     (A1)+, D0          ; Comparer avec chaine 2}\par
{\f1     BNE.S     .different          ; Differents -> sortir}\par
{\f1     TST.B     D0                 ; Fin des deux chaines ?}\par
{\f1     BNE.S     .boucle            ; Non -> continuer}\par
\par
{\f1     ; Les chaines sont identiques}\par
{\f1     CLR.B     D0                 ; D0 = 0 (egal)}\par
{\f1     MOVEM.L   (SP)+, A0-A1}\par
{\f1     RTS}\par
\par
{\f1   .different:}\par
{\f1     ; D0 contient le caractere de chaine 1}\par
{\f1     SUB.B     -1(A1), D0         ; D0 = ch1[i] - ch2[i]}\par
{\f1     MOVEM.L   (SP)+, A0-A1}\par
{\f1     RTS}\par
\par
{\f1   ch1:      DC.B  'Hello', 0}\par
{\f1   ch2:      DC.B  'Hello', 0}\par
{\f1   msg_egal: DC.B  'Chaines egales', $0D, $0A, 0}\par
{\f1   msg_inf:  DC.B  'Chaine 1 < Chaine 2', $0D, $0A, 0}\par
{\f1   msg_sup:  DC.B  'Chaine 1 > Chaine 2', $0D, $0A, 0}\par
{\f1     EVEN}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.10 Gestionnaire d'interruption (timer) \b0\par
\par
{\f1   Exemple d'installation d'un gestionnaire d'interruption pour}\par
{\f1   un timer. Illustre le mode superviseur, la sauvegarde de}\par
{\f1   registres et le retour par RTE.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.10 : Gestionnaire de timer}\par
{\f1   ; Installe un vecteur d'interruption pour le Level 4 Autovector}\par
{\f1   ; (typiquement utilise pour le VBL sur Atari ST ou Amiga).}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     ; Passer en mode superviseur (si necessaire)}\par
{\f1     ; Sur Atari ST : MOVE.L #0,-(SP) / MOVE.W #$20,-(SP) / TRAP #1}\par
\par
{\f1     ; Sauvegarder l'ancien vecteur}\par
{\f1     MOVE.L    $70, ancien_vbl    ; Vecteur Level 4 ($70)}\par
\par
{\f1     ; Installer le nouveau gestionnaire}\par
{\f1     MOVE.L    #mon_vbl, $70      ; Nouveau vecteur}\par
\par
{\f1     ; ... le programme principal tourne ici ...}\par
{\f1     ; Le compteur sera incremente a chaque VBL (50 ou 60 Hz)}\par
{\f1     LEA       compteur_vbl(PC), A0}\par
\par
{\f1   .attente:}\par
{\f1     MOVE.L    (A0), D0           ; Lire le compteur}\par
{\f1     CMP.L     #300, D0           ; 300 VBLs = ~5 secondes (60 Hz)}\par
{\f1     BLT.S     .attente           ; Attendre}\par
\par
{\f1     ; Restaurer l'ancien vecteur}\par
{\f1     MOVE.L    ancien_vbl, $70}\par
\par
{\f1     MOVE.B    #9, D0             ; Terminer}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Gestionnaire VBL (interruption Level 4)}\par
{\f1   ; Doit sauvegarder tous les registres utilises et finir par RTE.}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   mon_vbl:}\par
{\f1     MOVEM.L   D0/A0, -(SP)      ; Sauvegarder registres utilises}\par
\par
{\f1     LEA       compteur_vbl(PC), A0}\par
{\f1     ADDQ.L    #1, (A0)           ; Incrementer le compteur}\par
\par
{\f1     MOVEM.L   (SP)+, D0/A0      ; Restaurer registres}\par
{\f1     RTE                          ; Retour d'exception (pas RTS !)}\par
\par
{\f1   compteur_vbl:}\par
{\f1     DC.L      0                  ; Compteur de VBLs}\par
\par
{\f1   ancien_vbl:}\par
{\f1     DC.L      0                  ; Sauvegarde ancien vecteur}\par
\par
{\f1     END       start}\par
\par
{\f1   Points importants :}\par
{\f1   - RTE (Return from Exception) depile SR puis PC (6 octets sur}\par
{\f1     68000, 8 octets sur 68010+)}\par
{\f1   - Les registres utilises dans le gestionnaire doivent etre}\par
{\f1     sauvegardes et restaures (MOVEM)}\par
{\f1   - Le gestionnaire doit etre le plus court possible pour ne pas}\par
{\f1     bloquer les autres interruptions}\par
{\f1   - L'acces aux vecteurs d'interruption necessite le mode superviseur}\par
\par
\par
\b 10.11 Programme complet : recherche dans une chaine \b0\par
\par
{\f1   Recherche la premiere occurrence d'un caractere dans une chaine.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.11 : strchr (recherche de caractere)}\par
{\f1   ; Entree : A0 = adresse de la chaine}\par
{\f1   ;          D0.B = caractere a chercher}\par
{\f1   ; Sortie : A0 = adresse du caractere trouve, ou 0 si non trouve}\par
{\f1   ;          CCR : Z=1 si trouve}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     LEA       chaine(PC), A0}\par
{\f1     MOVE.B    #'e', D0           ; Chercher 'e'}\par
{\f1     BSR       strchr}\par
\par
{\f1     TST.L     A0                 ; Trouve ?}\par
{\f1     BEQ.S     .non_trouve}\par
\par
{\f1     ; Afficher la sous-chaine a partir du caractere trouve}\par
{\f1     MOVE.L    A0, A1}\par
{\f1     MOVE.B    #14, D0}\par
{\f1     TRAP      #15}\par
{\f1     BRA.S     .fin}\par
\par
{\f1   .non_trouve:}\par
{\f1     LEA       msg_non(PC), A1}\par
{\f1     MOVE.B    #14, D0}\par
{\f1     TRAP      #15}\par
\par
{\f1   .fin:}\par
{\f1     MOVE.B    #9, D0}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : strchr}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   strchr:}\par
{\f1     MOVE.L    D1, -(SP)          ; Sauvegarder D1}\par
\par
{\f1   .boucle:}\par
{\f1     MOVE.B    (A0), D1           ; Lire caractere courant}\par
{\f1     CMP.B     D0, D1             ; Compare avec le caractere cherche}\par
{\f1     BEQ.S     .trouve            ; Trouve !}\par
{\f1     TST.B     D1                 ; Fin de chaine ?}\par
{\f1     BEQ.S     .non_trouve        ; Oui -> non trouve}\par
{\f1     ADDQ.L    #1, A0             ; Avancer dans la chaine}\par
{\f1     BRA.S     .boucle}\par
\par
{\f1   .trouve:}\par
{\f1     ; A0 pointe sur le caractere trouve}\par
{\f1     MOVE.L    (SP)+, D1}\par
{\f1     RTS}\par
\par
{\f1   .non_trouve:}\par
{\f1     SUB.L     A0, A0             ; A0 = 0 (NULL)}\par
{\f1     MOVE.L    (SP)+, D1}\par
{\f1     RTS}\par
\par
{\f1   chaine:}\par
{\f1     DC.B      'Assembleur 68000', 0}\par
{\f1   msg_non:}\par
{\f1     DC.B      'Caractere non trouve', $0D, $0A, 0}\par
{\f1     EVEN}\par
\par
{\f1     END       start}\par
\par
\par
\b 10.12 Exemples avec le coprocesseur flottant \b0\par
\par
{\f1   Exemples utilisant le coprocesseur flottant 68881/68882.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.12a : Calcul de la norme d'un vecteur 2D}\par
{\f1   ; Entree : FP0 = x, FP1 = y}\par
{\f1   ; Sortie : FP0 = sqrt(x*x + y*y)}\par
{\f1   ; Necessite un 68020+ avec 68881/68882 ou 68040+}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1     MC68020}\par
{\f1     MC68881}\par
\par
{\f1     ORG       $1000}\par
\par
{\f1   start:}\par
{\f1     FMOVE.D   #3.0, FP0          ; x = 3.0}\par
{\f1     FMOVE.D   #4.0, FP1          ; y = 4.0}\par
{\f1     BSR       norme_2d            ; FP0 = sqrt(9+16) = 5.0}\par
\par
{\f1     ; Afficher le resultat (specifique au systeme)}\par
{\f1     MOVE.B    #9, D0}\par
{\f1     TRAP      #15}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Sous-routine : norme_2d}\par
{\f1   ; Calcule sqrt(x^2 + y^2)}\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   norme_2d:}\par
{\f1     FMUL.X    FP0, FP0            ; FP0 = x*x}\par
{\f1     FMUL.X    FP1, FP1            ; FP1 = y*y}\par
{\f1     FADD.X    FP1, FP0            ; FP0 = x*x + y*y}\par
{\f1     FSQRT.X   FP0                 ; FP0 = sqrt(x*x + y*y)}\par
{\f1     RTS}\par
\par
{\f1     END       start}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.12b : Conversion degres -> radians}\par
{\f1   ; Entree : FP0 = angle en degres}\par
{\f1   ; Sortie : FP0 = angle en radians}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   deg_to_rad:}\par
{\f1     FMUL.D    #0.01745329251994, FP0  ; FP0 = degres * (PI/180)}\par
{\f1     RTS                              ; Alternative : FMUL PI / FDIV #180}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.12c : Evaluation du polynome ax^2 + bx + c (Horner)}\par
{\f1   ; Entree : FP0 = x}\par
{\f1   ;          A0 = adresse des coefficients (a, b, c en double)}\par
{\f1   ; Sortie : FP0 = resultat}\par
{\f1   ; Methode de Horner : ((a)*x + b)*x + c}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   eval_poly2:}\par
{\f1     FMOVE.D   (A0)+, FP1          ; FP1 = a}\par
{\f1     FMUL.X    FP0, FP1            ; FP1 = a*x}\par
{\f1     FADD.D    (A0)+, FP1          ; FP1 = a*x + b}\par
{\f1     FMUL.X    FP0, FP1            ; FP1 = (a*x + b)*x}\par
{\f1     FADD.D    (A0)+, FP1          ; FP1 = (a*x + b)*x + c}\par
{\f1     FMOVE.X   FP1, FP0            ; FP0 = resultat}\par
{\f1     RTS}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.12d : Calcul de sinus par serie de Taylor}\par
{\f1   ; sin(x) = x - x^3/3! + x^5/5! - x^7/7! + ...}\par
{\f1   ; Entree : FP0 = x (en radians)}\par
{\f1   ; Sortie : FP0 = sin(x)}\par
{\f1   ; Note : La FPU a FSIN, cet exemple est pedagogique.}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   sin_taylor:}\par
{\f1     FMOVE.X   FP0, FP1            ; FP1 = x (terme courant)}\par
{\f1     FMOVE.X   FP0, FP2            ; FP2 = resultat = x}\par
{\f1     FMUL.X    FP0, FP0            ; FP0 = x*x}\par
{\f1     FMOVE.X   FP0, FP3            ; FP3 = x*x (sauvegarde)}\par
\par
{\f1     ; Terme 2 : -x^3/3! = -x^3/6}\par
{\f1     FMUL.X    FP3, FP1            ; FP1 = x^3}\par
{\f1     FDIV.D    #6.0, FP1           ; FP1 = x^3/6}\par
{\f1     FSUB.X    FP1, FP2            ; resultat -= x^3/6}\par
\par
{\f1     ; Terme 3 : +x^5/5! = +x^5/120}\par
{\f1     FMUL.X    FP3, FP1            ; FP1 = x^5}\par
{\f1     FDIV.D    #20.0, FP1          ; FP1 = x^5/120 (6*20=120)}\par
{\f1     FADD.X    FP1, FP2            ; resultat += x^5/120}\par
\par
{\f1     ; Terme 4 : -x^7/7! = -x^7/5040}\par
{\f1     FMUL.X    FP3, FP1            ; FP1 = x^7}\par
{\f1     FDIV.D    #42.0, FP1          ; FP1 = x^7/5040 (120*42=5040)}\par
{\f1     FSUB.X    FP1, FP2            ; resultat -= x^7/5040}\par
\par
{\f1     FMOVE.X   FP2, FP0            ; FP0 = resultat}\par
{\f1     RTS}\par
\par
\par
\b 10.13 Remplissage de memoire (memset) \b0\par
\par
{\f1   Remplit une zone memoire avec une valeur donnee.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.13 : memset}\par
{\f1   ; Entree : A0 = adresse de debut}\par
{\f1   ;          D0.L = nombre d'octets}\par
{\f1   ;          D1.B = valeur de remplissage}\par
{\f1   ; Sortie : A0 = adresse de debut (inchangee)}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   memset:}\par
{\f1     MOVEM.L   D0-D2/A0, -(SP)}\par
\par
{\f1     ; Preparer D2 avec la valeur repetee sur 32 bits}\par
{\f1     ; Ex: si D1.B = $FF, alors D2.L = $FFFFFFFF}\par
{\f1     MOVE.B    D1, D2}\par
{\f1     LSL.W     #8, D2}\par
{\f1     MOVE.B    D1, D2             ; D2.W = D1:D1}\par
{\f1     MOVE.W    D2, D1}\par
{\f1     SWAP      D2}\par
{\f1     MOVE.W    D1, D2             ; D2.L = D1:D1:D1:D1}\par
\par
{\f1     ; Remplir par long mots si possible}\par
{\f1     MOVE.L    D0, D1}\par
{\f1     LSR.L     #2, D1             ; Nombre de long mots}\par
{\f1     BRA.S     .test_long}\par
\par
{\f1   .fill_long:}\par
{\f1     MOVE.L    D2, (A0)+          ; Ecrire 4 octets}\par
{\f1   .test_long:}\par
{\f1     DBRA      D1, .fill_long}\par
\par
{\f1     ; Remplir les octets restants}\par
{\f1     AND.L     #3, D0}\par
{\f1     BRA.S     .test_byte}\par
\par
{\f1   .fill_byte:}\par
{\f1     MOVE.B    D2, (A0)+          ; Ecrire 1 octet}\par
{\f1   .test_byte:}\par
{\f1     DBRA      D0, .fill_byte}\par
\par
{\f1     MOVEM.L   (SP)+, D0-D2/A0}\par
{\f1     RTS}\par
\par
\par
\b 10.14 Copie de memoire (memcpy) \b0\par
\par
{\f1   Copie un bloc de memoire d'une source vers une destination.}\par
\par
{\f1   ; ------------------------------------------------------------------}\par
{\f1   ; Exemple 10.14 : memcpy}\par
{\f1   ; Entree : A0 = destination}\par
{\f1   ;          A1 = source}\par
{\f1   ;          D0.L = nombre d'octets}\par
{\f1   ; Sortie : A0 = destination (inchangee)}\par
{\f1   ; Gere le chevauchement (copie arriere si necessaire).}\par
{\f1   ; ------------------------------------------------------------------}\par
\par
{\f1   memcpy:}\par
{\f1     MOVEM.L   D0-D1/A0-A2, -(SP)}\par
{\f1     MOVE.L    A0, A2             ; Sauvegarder adresse debut}\par
\par
{\f1     ; Verifier le chevauchement}\par
{\f1     CMP.L     A1, A0}\par
{\f1     BEQ.S     .fin               ; Source == dest -> rien a faire}\par
{\f1     BHI.S     .copie_arriere     ; dest > source -> copie arriere}\par
\par
{\f1     ; Copie avant (source -> destination, croissant)}\par
{\f1     ; Copier par long mots}\par
{\f1     MOVE.L    D0, D1}\par
{\f1     LSR.L     #2, D1}\par
{\f1     BRA.S     .test_fwd_l}\par
\par
{\f1   .fwd_long:}\par
{\f1     MOVE.L    (A1)+, (A0)+}\par
{\f1   .test_fwd_l:}\par
{\f1     DBRA      D1, .fwd_long}\par
\par
{\f1     ; Octets restants}\par
{\f1     AND.L     #3, D0}\par
{\f1     BRA.S     .test_fwd_b}\par
\par
{\f1   .fwd_byte:}\par
{\f1     MOVE.B    (A1)+, (A0)+}\par
{\f1   .test_fwd_b:}\par
{\f1     DBRA      D0, .fwd_byte}\par
{\f1     BRA.S     .fin}\par
\par
{\f1   .copie_arriere:}\par
{\f1     ; Copie arriere (fin -> debut, decroissant)}\par
{\f1     ADD.L     D0, A0             ; Pointer apres la fin}\par
{\f1     ADD.L     D0, A1}\par
\par
{\f1     ; Octets de queue (pour aligner)}\par
{\f1     MOVE.L    D0, D1}\par
{\f1     AND.L     #3, D1}\par
{\f1     BRA.S     .test_bwd_b}\par
\par
{\f1   .bwd_byte:}\par
{\f1     MOVE.B    -(A1), -(A0)}\par
{\f1   .test_bwd_b:}\par
{\f1     DBRA      D1, .bwd_byte}\par
\par
{\f1     ; Long mots}\par
{\f1     LSR.L     #2, D0}\par
{\f1     BRA.S     .test_bwd_l}\par
\par
{\f1   .bwd_long:}\par
{\f1     MOVE.L    -(A1), -(A0)}\par
{\f1   .test_bwd_l:}\par
{\f1     DBRA      D0, .bwd_long}\par
\par
{\f1   .fin:}\par
{\f1     MOVE.L    A2, A0             ; Restaurer adresse debut}\par
{\f1     MOVEM.L   (SP)+, D0-D1/A0-A2}\par
{\f1     RTS}\par
\par
\par
