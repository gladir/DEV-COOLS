{\footnote # IDH_ASM68000_08}
{\footnote $ Assembleur 68000 - TECHNIQUES DE PROGRAMMATION}
{\footnote K Assembleur 68000 techniques programmation;arithmetique 32 64 bits;multiplication division logicielles;chaines caracteres;tables saut;optimisations;sous-routines conventions appel;stack frame LINK UNLK}
\b\fs24 TECHNIQUES DE PROGRAMMATION \b0\fs20\par
\par
{\f1   Cette section presente les techniques de programmation courantes}\par
{\f1   en assembleur 68000, incluant les conventions d'appel, la gestion}\par
{\f1   de la pile, les structures de controle, et les optimisations.}\par
\par
\par
\b 8.1 Conventions d'appel de sous-programmes \b0\par
\par
{\f1   8.1.1 Appel et retour de base}\par
\par
{\f1   L'instruction BSR (Branch to Subroutine) ou JSR (Jump to Subroutine)}\par
{\f1   empile automatiquement l'adresse de retour (PC courant) sur la pile}\par
{\f1   et transfere le controle au sous-programme. RTS (Return from}\par
{\f1   Subroutine) depile cette adresse et reprend l'execution.}\par
\par
{\f1     BSR     ma_routine         ; Appel relatif (deplacement 16 bits)}\par
{\f1     BSR.S   ma_routine         ; Appel relatif court (deplacement 8 bits)}\par
{\f1     JSR     ma_routine         ; Appel absolu}\par
{\f1     JSR     (A0)               ; Appel indirect via registre}\par
{\f1     JSR     $1000(A0,D0.W)     ; Appel indirect indexe}\par
{\f1     ...}\par
{\f1   ma_routine:}\par
{\f1     ; Corps du sous-programme}\par
{\f1     RTS                        ; Retour (depile PC)}\par
\par
{\f1   Etat de la pile lors de l'appel :}\par
\par
{\f1     Avant BSR/JSR :    SP -> [ancien contenu]}\par
{\f1     Apres BSR/JSR :    SP -> [adresse retour (32 bits)]}\par
{\f1                               [ancien contenu]}\par
\par
{\f1   8.1.2 Passage de parametres par registre}\par
\par
{\f1   La methode la plus simple et rapide. Les parametres sont places}\par
{\f1   dans les registres de donnees (D0-D7) et d'adresses (A0-A6)}\par
{\f1   avant l'appel. Le resultat est retourne dans D0 (convention}\par
{\f1   standard).}\par
\par
{\f1     ; Appel : resultat = addition(a, b)}\par
{\f1     MOVE.L   a, D0             ; Premier parametre dans D0}\par
{\f1     MOVE.L   b, D1             ; Deuxieme parametre dans D1}\par
{\f1     BSR      addition}\par
{\f1     ; D0 contient le resultat}\par
\par
{\f1   addition:}\par
{\f1     ADD.L    D1, D0            ; D0 = D0 + D1}\par
{\f1     RTS}\par
\par
{\f1   Conventions courantes pour les registres :}\par
\par
{\f1     Registre   Usage typique}\par
{\f1     ---------  ---------------------------------}\par
{\f1     D0         Parametre 1 / Valeur de retour}\par
{\f1     D1         Parametre 2 / Valeur de retour secondaire}\par
{\f1     D2-D7      Parametres supplementaires}\par
{\f1     A0         Pointeur source / Adresse de retour (donnees)}\par
{\f1     A1         Pointeur destination}\par
{\f1     A2-A5      Pointeurs supplementaires}\par
{\f1     A6         Pointeur de cadre (Frame Pointer)}\par
{\f1     A7 (SP)    Pointeur de pile (ne pas utiliser comme parametre)}\par
\par
{\f1   8.1.3 Passage de parametres par la pile}\par
\par
{\f1   Methode utilisee quand le nombre de parametres depasse les}\par
{\f1   registres disponibles, ou pour la compatibilite avec le C.}\par
{\f1   Les parametres sont empiles avant l'appel.}\par
\par
{\f1     ; Appel : resultat = ma_fonction(arg1, arg2, arg3)}\par
{\f1     MOVE.L   arg3, -(SP)      ; Empiler arg3 en dernier (convention C)}\par
{\f1     MOVE.L   arg2, -(SP)      ; Empiler arg2}\par
{\f1     MOVE.L   arg1, -(SP)      ; Empiler arg1}\par
{\f1     BSR      ma_fonction}\par
{\f1     LEA      12(SP), SP       ; Nettoyer la pile (3 * 4 octets)}\par
{\f1     ; D0 contient le resultat}\par
\par
{\f1   Etat de la pile dans le sous-programme :}\par
\par
{\f1     SP+12 -> [arg3]}\par
{\f1     SP+8  -> [arg2]}\par
{\f1     SP+4  -> [arg1]}\par
{\f1     SP    -> [adresse retour]}\par
\par
{\f1   Acces aux parametres dans le sous-programme :}\par
\par
{\f1   ma_fonction:}\par
{\f1     MOVE.L   4(SP), D0        ; D0 = arg1}\par
{\f1     ADD.L    8(SP), D0        ; D0 = arg1 + arg2}\par
{\f1     ADD.L    12(SP), D0       ; D0 = arg1 + arg2 + arg3}\par
{\f1     RTS}\par
\par
{\f1   8.1.4 Sauvegarde et restauration des registres}\par
\par
{\f1   Convention : les registres que le sous-programme modifie doivent}\par
{\f1   etre sauvegardes (sauf les registres "scratch" D0-D1/A0-A1).}\par
\par
{\f1     ma_routine:}\par
{\f1       MOVEM.L  D2-D7/A2-A5, -(SP)  ; Sauvegarder registres}\par
{\f1       ; ... corps du sous-programme ...}\par
{\f1       MOVEM.L  (SP)+, D2-D7/A2-A5  ; Restaurer registres}\par
{\f1       RTS}\par
\par
{\f1   Registres typiques a preserver :}\par
\par
{\f1     Categorie       Registres     Responsabilite}\par
{\f1     --------------  ------------  ---------------------------}\par
{\f1     Scratch         D0-D1, A0-A1 L'appelant sauvegarde si besoin}\par
{\f1     Preserves       D2-D7, A2-A5 Le sous-programme sauvegarde}\par
{\f1     Frame Pointer   A6           Le sous-programme sauvegarde}\par
{\f1     Stack Pointer   A7 (SP)      Doit etre restaure par convention}\par
\par
\par
\b 8.2 Gestion de la pile et cadres de pile (stack frames) \b0\par
\par
{\f1   8.2.1 Cadre de pile standard avec LINK/UNLK}\par
\par
{\f1   Les instructions LINK et UNLK creent et detruisent un cadre de}\par
{\f1   pile (stack frame) permettant un acces facile aux parametres et}\par
{\f1   aux variables locales.}\par
\par
{\f1     LINK A6, #-N   ; Creer cadre : PUSH A6, A6=SP, SP=SP-N}\par
{\f1     UNLK A6        ; Detruire cadre : SP=A6, POP A6}\par
\par
{\f1   Etat de la pile apres LINK A6, #-8 (8 octets de variables locales) :}\par
\par
{\f1     A6+12 -> [parametre 2]          ; Acces : 12(A6)}\par
{\f1     A6+8  -> [parametre 1]          ; Acces : 8(A6)}\par
{\f1     A6+4  -> [adresse retour]       ; (gere par BSR/JSR)}\par
{\f1     A6    -> [ancien A6]            ; (sauve par LINK)}\par
{\f1     A6-4  -> [variable locale 1]    ; Acces : -4(A6)}\par
{\f1     A6-8  -> [variable locale 2]    ; Acces : -8(A6)}\par
{\f1     SP -> [sommet de pile]}\par
\par
{\f1   Exemple complet :}\par
\par
{\f1     ; int ma_fonction(int a, int b) \{}\par
{\f1     ;   int local1, local2;}\par
{\f1     ;   local1 = a + b;}\par
{\f1     ;   local2 = a * b;}\par
{\f1     ;   return local1 + local2;}\par
{\f1     ; \}}\par
\par
{\f1     ma_fonction:}\par
{\f1       LINK     A6, #-8          ; Cadre avec 2 variables locales (4+4)}\par
{\f1       MOVE.L   8(A6), D0        ; D0 = a (premier parametre)}\par
{\f1       MOVE.L   12(A6), D1       ; D1 = b (deuxieme parametre)}\par
{\f1       MOVE.L   D0, D2           ; D2 = a (copie)}\par
{\f1       ADD.L    D1, D0           ; D0 = a + b}\par
{\f1       MOVE.L   D0, -4(A6)       ; local1 = a + b}\par
{\f1       MULS     D1, D2           ; D2 = a * b (16 bits)}\par
{\f1       MOVE.L   D2, -8(A6)       ; local2 = a * b}\par
{\f1       ADD.L    D2, D0           ; D0 = local1 + local2}\par
{\f1       UNLK     A6               ; Detruire cadre}\par
{\f1       RTS}\par
\par
{\f1   8.2.2 Cadre de pile sans LINK/UNLK}\par
\par
{\f1   Pour les routines simples, on peut gerer la pile manuellement :}\par
\par
{\f1     ma_routine:}\par
{\f1       SUB.L    #8, SP           ; Reserver 8 octets pour locales}\par
{\f1       MOVE.L   D0, (SP)         ; Variable locale 1}\par
{\f1       MOVE.L   D1, 4(SP)        ; Variable locale 2}\par
{\f1       ; ... travail ...}\par
{\f1       ADD.L    #8, SP           ; Liberer les variables locales}\par
{\f1       RTS}\par
\par
{\f1   8.2.3 Recursivite}\par
\par
{\f1   La pile permet naturellement la recursivite. Chaque appel}\par
{\f1   recursif cree son propre cadre de pile.}\par
\par
{\f1     ; unsigned factorielle(unsigned n) \{}\par
{\f1     ;   if (n <= 1) return 1;}\par
{\f1     ;   return n * factorielle(n - 1);}\par
{\f1     ; \}}\par
\par
{\f1     factorielle:}\par
{\f1       LINK     A6, #0           ; Cadre (pas de variables locales)}\par
{\f1       MOVE.L   8(A6), D0        ; D0 = n}\par
{\f1       CMP.L    #1, D0           ; n <= 1 ?}\par
{\f1       BLE.S    .fact_base        ; Oui : cas de base}\par
{\f1       MOVE.L   D0, -(SP)        ; Sauvegarder n}\par
{\f1       SUBQ.L   #1, D0           ; D0 = n - 1}\par
{\f1       MOVE.L   D0, -(SP)        ; Empiler parametre n-1}\par
{\f1       BSR      factorielle      ; Appel recursif}\par
{\f1       ADDQ.L   #4, SP           ; Nettoyer parametre}\par
{\f1       MOVE.L   (SP)+, D1        ; Restaurer n}\par
{\f1       MULU     D1, D0           ; D0 = n * factorielle(n-1)}\par
{\f1       BRA.S    .fact_end}\par
{\f1     .fact_base:}\par
{\f1       MOVEQ    #1, D0           ; Retourner 1}\par
{\f1     .fact_end:}\par
{\f1       UNLK     A6}\par
{\f1       RTS}\par
\par
\par
\b 8.3 Structures de controle \b0\par
\par
{\f1   8.3.1 Conditionnelle if/else}\par
\par
{\f1     ; if (D0 == 0) \{ ... \} else \{ ... \}}\par
{\f1     TST.L    D0}\par
{\f1     BNE.S    .else_bloc}\par
{\f1     ; --- bloc then ---}\par
{\f1     ; ...}\par
{\f1     BRA.S    .endif}\par
{\f1   .else_bloc:}\par
{\f1     ; --- bloc else ---}\par
{\f1     ; ...}\par
{\f1   .endif:}\par
\par
{\f1     ; if (D0 > D1) \{ ... \}}\par
{\f1     CMP.L    D1, D0}\par
{\f1     BLE.S    .endif2}\par
{\f1     ; --- bloc then ---}\par
{\f1     ; ...}\par
{\f1   .endif2:}\par
\par
{\f1     ; if (D0 >= 10 && D0 <= 20) \{ ... \}}\par
{\f1     CMP.L    #10, D0}\par
{\f1     BLT.S    .endif3}\par
{\f1     CMP.L    #20, D0}\par
{\f1     BGT.S    .endif3}\par
{\f1     ; --- bloc : D0 est dans [10, 20] ---}\par
{\f1     ; ...}\par
{\f1   .endif3:}\par
\par
{\f1   8.3.2 Boucle while}\par
\par
{\f1     ; while (D0 > 0) \{ D1 += D0; D0--; \}}\par
{\f1   .while_top:}\par
{\f1     TST.L    D0}\par
{\f1     BLE.S    .while_end}\par
{\f1     ADD.L    D0, D1}\par
{\f1     SUBQ.L   #1, D0}\par
{\f1     BRA.S    .while_top}\par
{\f1   .while_end:}\par
\par
{\f1   8.3.3 Boucle do-while}\par
\par
{\f1     ; do \{ D1 += D0; D0--; \} while (D0 > 0);}\par
{\f1   .do_top:}\par
{\f1     ADD.L    D0, D1}\par
{\f1     SUBQ.L   #1, D0}\par
{\f1     BGT.S    .do_top}\par
\par
{\f1   8.3.4 Boucle for avec DBcc}\par
\par
{\f1   L'instruction DBcc (Decrement and Branch) est optimisee pour}\par
{\f1   les boucles comptees. Elle decremente le registre Dn et branche}\par
{\f1   si le resultat n'est pas -1 (elle compte donc de N-1 a 0 si on}\par
{\f1   initialise a N-1, ou de N a 1 si on initialise a N et teste -1).}\par
\par
{\f1     ; for (i = 99; i >= 0; i--) \{ ... \}}\par
{\f1     MOVEQ    #99, D7            ; Compteur (attention: mot bas de D7)}\par
{\f1   .for_loop:}\par
{\f1     ; --- corps de la boucle ---}\par
{\f1     ; D7 contient i (99, 98, ..., 0)}\par
{\f1     DBRA     D7, .for_loop      ; D7--, branche si D7 != -1}\par
\par
{\f1   Note : DBRA (DBF) teste toujours faux, donc decremente et branche}\par
{\f1   systematiquement. Les autres variantes (DBEQ, DBNE, etc.) combinent}\par
{\f1   une condition et le compteur.}\par
\par
{\f1     ; Chercher un zero dans un tableau de 100 octets}\par
{\f1     LEA      tableau, A0}\par
{\f1     MOVEQ    #99, D7}\par
{\f1   .search:}\par
{\f1     TST.B    (A0)+}\par
{\f1     DBEQ     D7, .search        ; Sortir si zero trouve OU D7 = -1}\par
{\f1     BEQ.S    .found              ; Zero trouve}\par
{\f1     ; Non trouve}\par
{\f1     BRA.S    .not_found}\par
{\f1   .found:}\par
{\f1     ; A0 pointe juste apres le zero}\par
{\f1   .not_found:}\par
\par
{\f1   8.3.5 Boucle for croissante}\par
\par
{\f1     ; for (i = 0; i < 100; i++) \{ array[i] = 0; \}}\par
{\f1     LEA      array, A0}\par
{\f1     MOVEQ    #99, D7}\par
{\f1   .clear_loop:}\par
{\f1     CLR.L    (A0)+              ; array[i] = 0, avancer A0}\par
{\f1     DBRA     D7, .clear_loop}\par
\par
{\f1   8.3.6 Selection multiple (switch/case)}\par
\par
{\f1   Methode 1 : Cascade de comparaisons (pour peu de cas)}\par
\par
{\f1     ; switch (D0) \{ case 1: ...; case 2: ...; case 5: ...; \}}\par
{\f1     CMP.L    #1, D0}\par
{\f1     BEQ.S    .case_1}\par
{\f1     CMP.L    #2, D0}\par
{\f1     BEQ.S    .case_2}\par
{\f1     CMP.L    #5, D0}\par
{\f1     BEQ.S    .case_5}\par
{\f1     BRA.S    .default}\par
{\f1   .case_1:}\par
{\f1     ; ...}\par
{\f1     BRA.S    .end_switch}\par
{\f1   .case_2:}\par
{\f1     ; ...}\par
{\f1     BRA.S    .end_switch}\par
{\f1   .case_5:}\par
{\f1     ; ...}\par
{\f1     BRA.S    .end_switch}\par
{\f1   .default:}\par
{\f1     ; ...}\par
{\f1   .end_switch:}\par
\par
{\f1   Methode 2 : Table de sauts (pour des cas contigus, voir 8.6)}\par
\par
\par
\b 8.4 Manipulation de chaines de caracteres \b0\par
\par
{\f1   Le 68000 n'a pas d'instructions de chaines dediees (contrairement}\par
{\f1   au 80386 avec REP MOVSB etc.), mais ses modes d'adressage avec}\par
{\f1   post-incrementation et pre-decrementation sont tres efficaces.}\par
\par
{\f1   8.4.1 Copie de chaine (strcpy)}\par
\par
{\f1     ; Copier chaine terminee par zero de (A0) vers (A1)}\par
{\f1     strcpy:}\par
{\f1       MOVE.B   (A0)+, (A1)+     ; Copier un octet}\par
{\f1       BNE.S    strcpy            ; Continuer si pas le zero final}\par
\par
{\f1   8.4.2 Longueur de chaine (strlen)}\par
\par
{\f1     ; Chaine en (A0), longueur retournee dans D0}\par
{\f1     strlen:}\par
{\f1       MOVEQ    #-1, D0}\par
{\f1     .strlen_loop:}\par
{\f1       ADDQ.L   #1, D0}\par
{\f1       TST.B    (A0)+}\par
{\f1       BNE.S    .strlen_loop}\par
{\f1       RTS}\par
\par
{\f1   8.4.3 Comparaison de chaines (strcmp)}\par
\par
{\f1     ; Comparer (A0) et (A1), resultat dans D0 (<0, 0, >0)}\par
{\f1     strcmp:}\par
{\f1       MOVE.B   (A0)+, D0}\par
{\f1       SUB.B    (A1)+, D0        ; D0 = *A0 - *A1}\par
{\f1       BNE.S    .strcmp_end       ; Caracteres differents}\par
{\f1       TST.B    -1(A0)           ; Fin de chaine ?}\par
{\f1       BNE.S    strcmp            ; Non, continuer}\par
{\f1     .strcmp_end:}\par
{\f1       EXT.W    D0               ; Etendre signe a mot}\par
{\f1       EXT.L    D0               ; Etendre signe a long}\par
{\f1       RTS}\par
\par
{\f1   8.4.4 Recherche de caractere (strchr)}\par
\par
{\f1     ; Chercher D1.B dans la chaine (A0)}\par
{\f1     ; Retourne adresse dans A0 (ou 0 si non trouve)}\par
{\f1     strchr:}\par
{\f1       MOVE.B   (A0), D0}\par
{\f1       CMP.B    D1, D0}\par
{\f1       BEQ.S    .strchr_found}\par
{\f1       TST.B    D0}\par
{\f1       BEQ.S    .strchr_not}\par
{\f1       ADDQ.L   #1, A0}\par
{\f1       BRA.S    strchr}\par
{\f1     .strchr_not:}\par
{\f1       SUB.L    A0, A0           ; A0 = 0 (NULL)}\par
{\f1     .strchr_found:}\par
{\f1       RTS}\par
\par
{\f1   8.4.5 Copie de bloc memoire (memcpy)}\par
\par
{\f1     ; Copier D0.L octets de (A0) vers (A1)}\par
{\f1     memcpy:}\par
{\f1       SUBQ.L   #1, D0}\par
{\f1       BMI.S    .memcpy_end}\par
{\f1     .memcpy_loop:}\par
{\f1       MOVE.B   (A0)+, (A1)+}\par
{\f1       DBRA     D0, .memcpy_loop}\par
{\f1     .memcpy_end:}\par
{\f1       RTS}\par
\par
{\f1   Version optimisee par mots longs (si les adresses sont alignees) :}\par
\par
{\f1     memcpy_fast:}\par
{\f1       MOVE.L   D0, D1}\par
{\f1       LSR.L    #2, D0           ; Nombre de longs mots}\par
{\f1       BEQ.S    .copy_bytes}\par
{\f1       SUBQ.L   #1, D0}\par
{\f1     .copy_longs:}\par
{\f1       MOVE.L   (A0)+, (A1)+}\par
{\f1       DBRA     D0, .copy_longs}\par
{\f1     .copy_bytes:}\par
{\f1       MOVEQ    #3, D0}\par
{\f1       AND.L    D1, D0           ; Octets restants}\par
{\f1       BEQ.S    .done}\par
{\f1       SUBQ.L   #1, D0}\par
{\f1     .copy_rest:}\par
{\f1       MOVE.B   (A0)+, (A1)+}\par
{\f1       DBRA     D0, .copy_rest}\par
{\f1     .done:}\par
{\f1       RTS}\par
\par
{\f1   8.4.6 Remplissage de bloc (memset)}\par
\par
{\f1     ; Remplir D0.L octets a l'adresse (A0) avec D1.B}\par
{\f1     memset:}\par
{\f1       SUBQ.L   #1, D0}\par
{\f1       BMI.S    .memset_end}\par
{\f1     .memset_loop:}\par
{\f1       MOVE.B   D1, (A0)+}\par
{\f1       DBRA     D0, .memset_loop}\par
{\f1     .memset_end:}\par
{\f1       RTS}\par
\par
\par
\b 8.5 Arithmetique multi-precision \b0\par
\par
{\f1   Le 68000 travaille nativement avec des operandes de 8, 16 et}\par
{\f1   32 bits. Pour les calculs sur des entiers plus grands, on}\par
{\f1   utilise les instructions ADDX, SUBX et le drapeau X (eXtend).}\par
\par
{\f1   8.5.1 Addition 64 bits}\par
\par
{\f1     ; Additionner deux nombres 64 bits :}\par
{\f1     ;   (D0:D1) = (D0:D1) + (D2:D3)}\par
{\f1     ;   D0/D2 = poids fort, D1/D3 = poids faible}\par
{\f1     ADD.L    D3, D1             ; Addition poids faible}\par
{\f1     ADDX.L   D2, D0             ; Addition poids fort + retenue (X)}\par
\par
{\f1   8.5.2 Soustraction 64 bits}\par
\par
{\f1     ; (D0:D1) = (D0:D1) - (D2:D3)}\par
{\f1     SUB.L    D3, D1             ; Soustraction poids faible}\par
{\f1     SUBX.L   D2, D0             ; Soustraction poids fort + emprunt (X)}\par
\par
{\f1   8.5.3 Negation 64 bits}\par
\par
{\f1     ; (D0:D1) = -(D0:D1)}\par
{\f1     NEG.L    D1                 ; Negate poids faible}\par
{\f1     NEGX.L   D0                 ; Negate poids fort avec emprunt}\par
\par
{\f1   8.5.4 Decalage 64 bits a gauche}\par
\par
{\f1     ; (D0:D1) <<= 1  (decalage d'un bit)}\par
{\f1     LSL.L    #1, D1             ; Decaler poids faible (bit 31 -> X)}\par
{\f1     ROXL.L   #1, D0             ; Decaler poids fort avec X entrant}\par
\par
{\f1   8.5.5 Decalage 64 bits a droite}\par
\par
{\f1     ; (D0:D1) >>= 1  (decalage logique d'un bit)}\par
{\f1     LSR.L    #1, D0             ; Decaler poids fort (bit 0 -> X)}\par
{\f1     ROXR.L   #1, D1             ; Decaler poids faible avec X entrant}\par
\par
{\f1   8.5.6 Comparaison 64 bits}\par
\par
{\f1     ; Comparer (D0:D1) avec (D2:D3)}\par
{\f1     CMP.L    D2, D0             ; Comparer poids forts}\par
{\f1     BNE.S    .cmp_done           ; Si differents, flags suffisent}\par
{\f1     CMP.L    D3, D1             ; Comparer poids faibles}\par
{\f1   .cmp_done:}\par
{\f1     ; Utiliser BEQ, BNE, BHI, BLS pour non signe}\par
{\f1     ; Utiliser BGT, BLT, BGE, BLE pour signe (apres poids fort)}\par
\par
{\f1   8.5.7 Multiplication 32x32 -> 64 bits}\par
\par
{\f1   Le 68000 a MULU/MULS pour 16x16 -> 32 bits. Pour une}\par
{\f1   multiplication 32 bits complete, il faut decomposer :}\par
\par
{\f1     ; (D0:D1) = D2 * D3  (non signe, 32x32 -> 64)}\par
{\f1     ; D2 = aH:aL, D3 = bH:bL (a et b en deux mots de 16 bits)}\par
{\f1     mul32x32:}\par
{\f1       MOVE.L   D2, D0}\par
{\f1       MOVE.L   D3, D1}\par
{\f1       SWAP     D0               ; D0 = aL:aH}\par
{\f1       SWAP     D1               ; D1 = bL:bH}\par
{\f1       MOVE.W   D2, D4           ; D4.W = aL}\par
{\f1       MOVE.W   D3, D5           ; D5.W = bL}\par
{\f1       MULU     D5, D4           ; D4 = aL * bL (poids faible)}\par
{\f1       MOVE.W   D0, D6           ; D6.W = aH}\par
{\f1       MULU     D5, D6           ; D6 = aH * bL}\par
{\f1       MOVE.W   D2, D5           ; D5.W = aL}\par
{\f1       MULU     D1, D5           ; D5 = aL * bH}\par
{\f1       ADD.L    D5, D6           ; D6 = aH*bL + aL*bH (termes croises)}\par
{\f1       MOVE.W   D0, D5           ; D5.W = aH}\par
{\f1       MULU     D1, D5           ; D5 = aH * bH (poids fort)}\par
{\f1       ; Assembler le resultat 64 bits}\par
{\f1       MOVE.L   D4, D1           ; D1 = poids faible (aL*bL)}\par
{\f1       CLR.L    D0}\par
{\f1       MOVE.W   D6, D0}\par
{\f1       SWAP     D0               ; D0 = termes croises poids fort << 16}\par
{\f1       ADD.L    D5, D0           ; D0 += aH*bH}\par
{\f1       SWAP     D6               ; D6 poids fort des croises}\par
{\f1       CLR.W    D6}\par
{\f1       ADD.L    D6, D0           ; Ajouter retenue des croises}\par
{\f1       ; Reporter la retenue du mot bas des croises}\par
{\f1       SWAP     D6}\par
{\f1       CLR.L    D5}\par
{\f1       MOVE.W   D6, D5}\par
{\f1       SWAP     D5               ; D5 = croises_bas << 16}\par
{\f1       ADD.L    D5, D1           ; Ajouter au poids faible}\par
{\f1       BCC.S    .no_carry}\par
{\f1       ADDQ.L   #1, D0           ; Reporter retenue}\par
{\f1     .no_carry:}\par
{\f1       RTS}\par
\par
\par
\b 8.6 Tables de sauts et dispatch \b0\par
\par
{\f1   Les tables de sauts permettent un branchement en O(1) pour les}\par
{\f1   selections multiples (switch/case avec valeurs contigues).}\par
\par
{\f1   8.6.1 Table de sauts par deplacement}\par
\par
{\f1     ; switch(D0) \{ case 0: ...; case 1: ...; case 2: ...; case 3: \}}\par
{\f1     ; D0 contient l'index (0-3)}\par
{\f1     CMP.L    #3, D0}\par
{\f1     BHI.S    .default            ; Hors limites -> defaut}\par
{\f1     ADD.W    D0, D0             ; D0 * 2 (taille d'un mot)}\par
{\f1     MOVE.W   .jmptable(PC,D0.W), D0 ; Lire le deplacement}\par
{\f1     JMP      .jmptable(PC,D0.W)     ; Sauter a l'adresse}\par
\par
{\f1   .jmptable:}\par
{\f1     DC.W     .case_0-.jmptable}\par
{\f1     DC.W     .case_1-.jmptable}\par
{\f1     DC.W     .case_2-.jmptable}\par
{\f1     DC.W     .case_3-.jmptable}\par
\par
{\f1   .case_0:}\par
{\f1     ; ... traitement cas 0 ...}\par
{\f1     BRA.S    .end_switch}\par
{\f1   .case_1:}\par
{\f1     ; ... traitement cas 1 ...}\par
{\f1     BRA.S    .end_switch}\par
{\f1   .case_2:}\par
{\f1     ; ... traitement cas 2 ...}\par
{\f1     BRA.S    .end_switch}\par
{\f1   .case_3:}\par
{\f1     ; ... traitement cas 3 ...}\par
{\f1     BRA.S    .end_switch}\par
{\f1   .default:}\par
{\f1     ; ... traitement par defaut ...}\par
{\f1   .end_switch:}\par
\par
{\f1   8.6.2 Table de sauts par adresses absolues}\par
\par
{\f1     ; Table d'adresses absolues (32 bits)}\par
{\f1     CMP.L    #3, D0}\par
{\f1     BHI.S    .default2}\par
{\f1     LSL.L    #2, D0             ; D0 * 4 (taille d'un long mot)}\par
{\f1     LEA      .addr_table, A0}\par
{\f1     MOVE.L   0(A0,D0.L), A0    ; Charger l'adresse du handler}\par
{\f1     JMP      (A0)               ; Sauter}\par
\par
{\f1   .addr_table:}\par
{\f1     DC.L     handler_0}\par
{\f1     DC.L     handler_1}\par
{\f1     DC.L     handler_2}\par
{\f1     DC.L     handler_3}\par
\par
{\f1   8.6.3 Table de fonctions (dispatch virtuel)}\par
\par
{\f1   Utilise pour les tables de methodes virtuelles ou les callbacks :}\par
\par
{\f1     ; A0 = pointeur vers un objet}\par
{\f1     ; L'objet a un pointeur vers sa table de methodes en offset 0}\par
{\f1     ; Appeler la methode numero D0}\par
{\f1     MOVE.L   (A0), A1           ; A1 = pointeur table de methodes}\par
{\f1     LSL.L    #2, D0             ; D0 * 4}\par
{\f1     MOVE.L   0(A1,D0.L), A1    ; A1 = adresse de la methode}\par
{\f1     JSR      (A1)               ; Appeler la methode}\par
\par
\par
\b 8.7 Programmation position-independante (PIC) \b0\par
\par
{\f1   Le code position-independant (PIC) peut s'executer a n'importe}\par
{\f1   quelle adresse memoire sans modification. C'est essentiel pour}\par
{\f1   les bibliotheques partagees et le code relocatable.}\par
\par
{\f1   8.7.1 Branchements relatifs}\par
\par
{\f1   Les instructions Bcc et BSR utilisent un deplacement relatif}\par
{\f1   par rapport au PC. Elles sont naturellement position-independantes.}\par
\par
{\f1     BRA.S    label              ; Branchement relatif court}\par
{\f1     BSR      routine            ; Appel relatif}\par
{\f1     ; Pas besoin de relocation}\par
\par
{\f1   8.7.2 Acces aux donnees avec PC relatif}\par
\par
{\f1   Le mode d'adressage d(PC) permet d'acceder aux donnees}\par
{\f1   relativement au PC, sans adresse absolue :}\par
\par
{\f1     ; Acces non PIC (adresse absolue) :}\par
{\f1     MOVE.L   ma_variable, D0   ; Utilise une adresse absolue}\par
\par
{\f1     ; Acces PIC (relatif au PC) :}\par
{\f1     MOVE.L   ma_variable(PC), D0 ; Utilise un deplacement relatif}\par
{\f1     LEA      ma_table(PC), A0    ; Charger adresse relative}\par
\par
{\f1   8.7.3 Acces aux donnees avec base register}\par
\par
{\f1   Pour les donnees eloignees du code, on utilise un registre}\par
{\f1   de base pointant vers la zone de donnees :}\par
\par
{\f1     ; Initialiser le registre de base}\par
{\f1     LEA      data_base(PC), A5  ; A5 = base des donnees}\par
\par
{\f1     ; Acceder aux variables via A5}\par
{\f1     MOVE.L   var1_offset(A5), D0  ; Charger variable 1}\par
{\f1     MOVE.L   D1, var2_offset(A5)  ; Stocker variable 2}\par
\par
{\f1   8.7.4 Limitations du mode PC relatif sur le 68000}\par
\par
{\f1     - Le deplacement est limite a 16 bits signes (-32768 a +32767)}\par
{\f1     - Le PC ne peut pas etre utilise comme destination}\par
{\f1     - LEA label(PC), An est la forme la plus courante}\par
{\f1     - Le 68020+ etend a 32 bits avec les mots d'extension}\par
\par
\par
\b 8.8 Optimisations courantes \b0\par
\par
{\f1   8.8.1 Utilisation de MOVEQ}\par
\par
{\f1   MOVEQ charge une constante 8 bits signee (-128 a +127) dans un}\par
{\f1   registre de donnees en seulement 2 octets (1 mot) et 4 cycles :}\par
\par
{\f1     MOVEQ    #0, D0             ; 2 octets, 4 cycles (mieux que CLR.L)}\par
{\f1     MOVEQ    #1, D0             ; 2 octets, 4 cycles}\par
{\f1     MOVEQ    #-1, D0            ; D0 = $FFFFFFFF (2 octets)}\par
\par
{\f1   Comparaison :}\par
{\f1     MOVEQ    #0, D0             ; 2 octets,  4 cycles}\par
{\f1     CLR.L    D0                 ; 2 octets,  6 cycles (lecture-modif-ecrit)}\par
{\f1     MOVE.L   #0, D0             ; 6 octets, 12 cycles}\par
\par
{\f1   8.8.2 Utilisation de ADDQ/SUBQ}\par
\par
{\f1   ADDQ et SUBQ ajoutent/soustraient 1-8 en seulement 2 octets :}\par
\par
{\f1     ADDQ.L   #1, D0             ; 2 octets, 4 cycles (registre)}\par
{\f1     ADDQ.L   #1, (A0)           ; 2 octets, 12 cycles (memoire)}\par
\par
{\f1   Comparaison :}\par
{\f1     ADDQ.L   #1, D0             ;  2 octets,  4 cycles}\par
{\f1     ADD.L    #1, D0             ;  6 octets,  8 cycles (immediate long)}\par
{\f1     ADDI.L   #1, D0             ;  6 octets,  8 cycles}\par
\par
{\f1   8.8.3 Effacement rapide avec MOVEQ}\par
\par
{\f1     MOVEQ    #0, D0             ; Effacer un registre (4 cycles)}\par
{\f1     ; Puis utiliser comme source :}\par
{\f1     MOVE.L   D0, (A0)+          ; Effacer une case memoire}\par
{\f1     MOVE.L   D0, (A0)+          ; Et la suivante...}\par
\par
{\f1   8.8.4 Decalages au lieu de multiplications}\par
\par
{\f1     ; D0 *= 2}\par
{\f1     ADD.L    D0, D0             ; Plus rapide que LSL.L #1, D0}\par
{\f1     ; ou}\par
{\f1     LSL.L    #1, D0}\par
\par
{\f1     ; D0 *= 4}\par
{\f1     LSL.L    #2, D0}\par
\par
{\f1     ; D0 *= 8}\par
{\f1     LSL.L    #3, D0}\par
\par
{\f1     ; D0 *= 10 (sans MULU)}\par
{\f1     MOVE.L   D0, D1}\par
{\f1     LSL.L    #3, D0             ; D0 *= 8}\par
{\f1     ADD.L    D1, D0             ; D0 += original}\par
{\f1     ADD.L    D1, D0             ; D0 += original -> D0 = 10 * original}\par
\par
{\f1     ; D0 *= 320 (pour adressage ecran, 320 = 256 + 64)}\par
{\f1     MOVE.L   D0, D1}\par
{\f1     LSL.L    #8, D0             ; D0 *= 256}\par
{\f1     LSL.L    #6, D1             ; D1 *= 64}\par
{\f1     ADD.L    D1, D0             ; D0 = 320 * original}\par
\par
{\f1   8.8.5 Test de bit sans BTST}\par
\par
{\f1     ; Tester si D0 est pair/impair}\par
{\f1     BTST     #0, D0             ; Tester bit 0}\par
{\f1     BNE.S    .impair}\par
{\f1     ; Alternative :}\par
{\f1     AND.W    #1, D0             ; D0 = D0 & 1}\par
{\f1     BNE.S    .impair}\par
\par
{\f1     ; Tester si D0 est negatif}\par
{\f1     TST.L    D0}\par
{\f1     BMI.S    .negatif}\par
\par
{\f1   8.8.6 Echange sans variable temporaire}\par
\par
{\f1     EXG      D0, D1             ; Echanger D0 et D1 (4 cycles, registres)}\par
\par
{\f1     ; Pour la memoire (pas d'EXG memoire) :}\par
{\f1     MOVE.L   (A0), D0}\par
{\f1     MOVE.L   (A1), D1}\par
{\f1     MOVE.L   D0, (A1)}\par
{\f1     MOVE.L   D1, (A0)}\par
\par
{\f1   8.8.7 Boucle de delai}\par
\par
{\f1     ; Attendre environ N iterations}\par
{\f1     MOVE.L   #N, D0}\par
{\f1   .delay:}\par
{\f1     SUBQ.L   #1, D0}\par
{\f1     BNE.S    .delay}\par
\par
{\f1     ; Ou avec DBRA (plus precis, mais compteur 16 bits) :}\par
{\f1     MOVE.W   #N-1, D0}\par
{\f1   .delay2:}\par
{\f1     DBRA     D0, .delay2}\par
\par
{\f1   8.8.8 Alignement des donnees}\par
\par
{\f1   Le 68000 requiert que les acces mot (16 bits) et long mot}\par
{\f1   (32 bits) soient alignes sur des adresses paires. Un acces}\par
{\f1   non aligne provoque une exception Address Error.}\par
\par
{\f1     ; S'assurer que l'adresse dans A0 est paire}\par
{\f1     MOVE.L   A0, D0}\par
{\f1     BTST     #0, D0}\par
{\f1     BEQ.S    .aligned}\par
{\f1     ADDQ.L   #1, A0            ; Avancer d'un octet pour aligner}\par
{\f1   .aligned:}\par
\par
{\f1     ; En assembleur, utiliser EVEN ou ALIGN :}\par
{\f1     EVEN                        ; Aligner sur mot}\par
{\f1     ; ou}\par
{\f1     ALIGN    4                  ; Aligner sur long mot (si supporte)}\par
\par
\par
\b 8.9 Interfacage avec le langage C \b0\par
\par
{\f1   8.9.1 Convention d'appel C standard (cdecl)}\par
\par
{\f1   La convention C sur 68000 suit generalement ces regles :}\par
{\f1     - Parametres empiles de droite a gauche}\par
{\f1     - L'appelant nettoie la pile apres l'appel}\par
{\f1     - Valeur de retour dans D0 (32 bits) ou D0:D1 (64 bits)}\par
{\f1     - Registres scratch : D0, D1, A0, A1 (non preserves)}\par
{\f1     - Registres preserves : D2-D7, A2-A5, A6 (Frame Pointer)}\par
\par
{\f1   8.9.2 Appeler une fonction C depuis l'assembleur}\par
\par
{\f1     ; extern int printf(const char *fmt, ...);}\par
{\f1     ; printf("Valeur = %d\\n", 42);}\par
\par
{\f1     PEA      #42               ; Empiler 42 (de droite a gauche)}\par
{\f1     PEA      .fmt_str(PC)      ; Empiler adresse du format}\par
{\f1     JSR      _printf            ; Appeler (noms C prefixes par _)}\par
{\f1     ADDQ.L   #8, SP            ; Nettoyer 2 parametres (4+4)}\par
\par
{\f1   .fmt_str:}\par
{\f1     DC.B     'Valeur = %d', 10, 0}\par
{\f1     EVEN}\par
\par
{\f1   8.9.3 Ecrire une fonction appelee depuis le C}\par
\par
{\f1     ; int ma_somme(int a, int b);}\par
{\f1     ; Appelee comme : resultat = ma_somme(10, 20);}\par
\par
{\f1     XDEF     _ma_somme         ; Exporter le symbole}\par
{\f1   _ma_somme:}\par
{\f1     LINK     A6, #0            ; Cadre de pile}\par
{\f1     MOVE.L   8(A6), D0         ; D0 = a (premier parametre)}\par
{\f1     ADD.L    12(A6), D0        ; D0 += b (deuxieme parametre)}\par
{\f1     UNLK     A6                ; Detruire cadre}\par
{\f1     RTS                        ; Retourner (D0 = resultat)}\par
\par
{\f1   8.9.4 Structures et alignement}\par
\par
{\f1   Le C sur 68000 aligne generalement les champs de structure}\par
{\f1   sur des limites de mot (2 octets) ou de long mot (4 octets)}\par
{\f1   selon le compilateur. En assembleur, respecter le meme alignement :}\par
\par
{\f1     ; struct Point \{ int x; int y; \};}\par
{\f1     ; sizeof(struct Point) = 8}\par
{\f1     POINT_X  EQU  0             ; Offset du champ x}\par
{\f1     POINT_Y  EQU  4             ; Offset du champ y}\par
\par
{\f1     ; Acceder aux champs :}\par
{\f1     MOVE.L   POINT_X(A0), D0   ; D0 = point->x}\par
{\f1     MOVE.L   POINT_Y(A0), D1   ; D1 = point->y}\par
\par
{\f1   8.9.5 Tableaux et indexation}\par
\par
{\f1     ; int tab[100]; tab[i] = valeur;}\par
{\f1     ; A0 = adresse de tab, D0 = i, D1 = valeur}\par
{\f1     LSL.L    #2, D0             ; i *= 4 (taille d'un int)}\par
{\f1     MOVE.L   D1, 0(A0,D0.L)    ; tab[i] = valeur}\par
\par
{\f1     ; char *str; c = str[i];}\par
{\f1     ; A0 = str, D0 = i}\par
{\f1     MOVE.B   0(A0,D0.L), D1    ; D1 = str[i]}\par
\par
\par
\b 8.10 Comparaison avec les techniques 80386 \b0\par
\par
{\f1   Technique               68000                80386}\par
{\f1   ----------------------  -------------------  -------------------}\par
{\f1   Cadre de pile           LINK A6, #-N         PUSH EBP / MOV EBP,ESP}\par
{\f1                           UNLK A6              MOV ESP,EBP / POP EBP}\par
{\f1   Appel/retour            BSR/JSR + RTS        CALL + RET}\par
{\f1   Passage params pile     MOVE.L arg, -(SP)    PUSH arg}\par
{\f1   Nettoyage pile          LEA n(SP), SP        ADD ESP, n}\par
{\f1   Sauvegarde registres    MOVEM.L regs, -(SP)  PUSH reg (un par un)}\par
{\f1   Restauration registres  MOVEM.L (SP)+, regs  POP reg (un par un)}\par
{\f1   Boucle comptee          DBRA Dn, label       LOOP label (ECX)}\par
{\f1   Copie de chaine         MOVE.B (A0)+,(A1)+   REP MOVSB}\par
{\f1   Copie par blocs         MOVE.L (A0)+,(A1)+   REP MOVSD}\par
{\f1   Remplissage             MOVE.B D0,(A0)+      REP STOSB}\par
{\f1   Recherche               DBEQ/TST (A0)+       REPNE SCASB}\par
{\f1   Table de sauts          JMP table(PC,D0.W)   JMP [table+EAX*4]}\par
{\f1   Test de bit             BTST #n, Dn          BT reg, n}\par
{\f1   Alignement              EVEN / adresses paires  Pas de contrainte}\par
{\f1   PC-relatif              d(PC), d(PC,Xn)      Pas de mode PC-relatif}\par
{\f1   Immediate rapide        MOVEQ #n, Dn         (pas d'equivalent)}\par
{\f1   Ajout rapide            ADDQ #n, ea          (pas d'equivalent)}\par
{\f1   Multi-precision         ADDX, SUBX           ADC, SBB}\par
{\f1   Multiplication          MULU/MULS (16x16)    MUL/IMUL (32x32)}\par
{\f1   Division                DIVU/DIVS (32/16)    DIV/IDIV (64/32)}\par
{\f1   Registres generaux      D0-D7 (donnees)      EAX,EBX,ECX,EDX}\par
{\f1                           A0-A6 (adresses)     ESI,EDI,EBP}\par
\par
{\f1   Differences notables :}\par
\par
{\f1   - Le 68000 separe donnees (D0-D7) et adresses (A0-A6) ; le 80386}\par
{\f1     utilise des registres generaux pour les deux usages}\par
{\f1   - MOVEM.L permet de sauvegarder/restaurer plusieurs registres en}\par
{\f1     une seule instruction (equivalent a PUSHA/POPA du 80386)}\par
{\f1   - Le 68000 a le mode PC-relatif natif, facilitant le PIC ;}\par
{\f1     le 80386 ne l'a pas (utilise des GOT/PLT a la place)}\par
{\f1   - DBRA combine decrementation et branchement en une instruction}\par
{\f1     efficace ; LOOP du 80386 est similaire mais utilise ECX uniquement}\par
{\f1   - Le 68000 n'a pas d'instructions de chaines comme REP MOVSx ;}\par
{\f1     la copie se fait avec des boucles MOVE.B (A0)+, (A1)+}\par
{\f1   - Le 80386 a des multiplications 32x32 en materiel ;}\par
{\f1     le 68000 est limite a 16x16 (32x32 sur 68020+)}\par
{\f1   - Le 68000 exige l'alignement pair pour les mots et longs mots ;}\par
{\f1     le 80386 tolere les acces non alignes (avec penalite)}\par
{\f1   - MOVEQ et ADDQ/SUBQ du 68000 n'ont pas d'equivalent direct sur}\par
{\f1     80386 (mais les instructions immediates courtes existent)}\par
\par
\par
\b 8.11 Exemples complets \b0\par
\par
{\f1   8.11.1 Tri a bulles (Bubble Sort)}\par
\par
{\f1     ; Trier un tableau de N longs mots en ordre croissant}\par
{\f1     ; A0 = adresse du tableau, D7 = N-1 (nombre d'elements - 1)}\par
{\f1     bubble_sort:}\par
{\f1       MOVE.L   D7, D6           ; D6 = compteur externe}\par
{\f1     .outer:}\par
{\f1       MOVEQ    #0, D5           ; D5 = flag "echange effectue"}\par
{\f1       MOVE.L   D6, D4           ; D4 = compteur interne}\par
{\f1       MOVE.L   A0, A1           ; A1 = debut du tableau}\par
{\f1       SUBQ.L   #1, D4}\par
{\f1     .inner:}\par
{\f1       MOVE.L   (A1), D0         ; D0 = element[i]}\par
{\f1       CMP.L    4(A1), D0        ; Comparer avec element[i+1]}\par
{\f1       BLE.S    .no_swap}\par
{\f1       MOVE.L   4(A1), (A1)      ; Echanger}\par
{\f1       MOVE.L   D0, 4(A1)}\par
{\f1       MOVEQ    #1, D5           ; Marquer echange}\par
{\f1     .no_swap:}\par
{\f1       ADDQ.L   #4, A1           ; Avancer au prochain element}\par
{\f1       DBRA     D4, .inner}\par
{\f1       TST.L    D5               ; Des echanges ont ete faits ?}\par
{\f1       BEQ.S    .sorted           ; Non : tableau trie}\par
{\f1       SUBQ.L   #1, D6           ; Reduire la plage}\par
{\f1       BNE.S    .outer}\par
{\f1     .sorted:}\par
{\f1       RTS}\par
\par
{\f1   8.11.2 Conversion entier en chaine decimale (itoa)}\par
\par
{\f1     ; Convertir D0.L (non signe) en chaine decimale dans (A0)}\par
{\f1     ; Retourne longueur dans D0}\par
{\f1     itoa:}\par
{\f1       LINK     A6, #-12         ; Buffer temporaire (12 chiffres max)}\par
{\f1       LEA      -1(A6), A1       ; A1 = fin du buffer temporaire}\par
{\f1       CLR.B    (A1)             ; Terminateur zero}\par
{\f1       MOVEQ    #0, D1           ; D1 = compteur de chiffres}\par
{\f1     .itoa_loop:}\par
{\f1       DIVU     #10, D0          ; D0.W = quotient, D0 haut = reste}\par
{\f1       SWAP     D0               ; D0.W = reste}\par
{\f1       ADD.B    #'0', D0         ; Convertir en ASCII}\par
{\f1       MOVE.B   D0, -(A1)        ; Stocker le chiffre (ordre inverse)}\par
{\f1       ADDQ.L   #1, D1           ; Compter}\par
{\f1       SWAP     D0               ; D0.W = quotient}\par
{\f1       AND.L    #$FFFF, D0       ; Masquer les bits hauts}\par
{\f1       BNE.S    .itoa_loop        ; Continuer si quotient != 0}\par
{\f1     .copy_result:}\par
{\f1       MOVE.B   (A1)+, (A0)+     ; Copier vers le buffer de sortie}\par
{\f1       BNE.S    .copy_result}\par
{\f1       MOVE.L   D1, D0           ; D0 = longueur}\par
{\f1       UNLK     A6}\par
{\f1       RTS}\par
\par
{\f1   8.11.3 Conversion chaine decimale en entier (atoi)}\par
\par
{\f1     ; Convertir la chaine en (A0) en entier dans D0}\par
{\f1     ; Supporte le signe negatif}\par
{\f1     atoi:}\par
{\f1       MOVEQ    #0, D0           ; Resultat = 0}\par
{\f1       MOVEQ    #0, D1           ; D1 = flag signe (0 = positif)}\par
{\f1       MOVE.B   (A0), D2}\par
{\f1       CMP.B    #'-', D2}\par
{\f1       BNE.S    .atoi_plus}\par
{\f1       MOVEQ    #1, D1           ; Negatif}\par
{\f1       ADDQ.L   #1, A0}\par
{\f1       BRA.S    .atoi_digit}\par
{\f1     .atoi_plus:}\par
{\f1       CMP.B    #'+', D2}\par
{\f1       BNE.S    .atoi_digit}\par
{\f1       ADDQ.L   #1, A0           ; Sauter le '+'}\par
{\f1     .atoi_digit:}\par
{\f1       MOVE.B   (A0)+, D2}\par
{\f1       SUB.B    #'0', D2}\par
{\f1       BMI.S    .atoi_end         ; < '0' : fin}\par
{\f1       CMP.B    #9, D2}\par
{\f1       BHI.S    .atoi_end         ; > '9' : fin}\par
{\f1       MULU     #10, D0          ; D0 *= 10}\par
{\f1       AND.L    #$FF, D2}\par
{\f1       ADD.L    D2, D0           ; D0 += chiffre}\par
{\f1       BRA.S    .atoi_digit}\par
{\f1     .atoi_end:}\par
{\f1       TST.L    D1               ; Signe negatif ?}\par
{\f1       BEQ.S    .atoi_done}\par
{\f1       NEG.L    D0               ; D0 = -D0}\par
{\f1     .atoi_done:}\par
{\f1       RTS}\par
\par
{\f1   8.11.4 Recherche binaire (binary search)}\par
\par
{\f1     ; Recherche D0 dans un tableau trie de longs mots}\par
{\f1     ; A0 = tableau, D1 = nombre d'elements}\par
{\f1     ; Retourne index dans D0 (-1 si non trouve)}\par
{\f1     binary_search:}\par
{\f1       MOVEM.L  D2-D5, -(SP)}\par
{\f1       MOVE.L   D0, D5           ; D5 = valeur cherchee}\par
{\f1       MOVEQ    #0, D2           ; D2 = low}\par
{\f1       MOVE.L   D1, D3}\par
{\f1       SUBQ.L   #1, D3           ; D3 = high = N-1}\par
{\f1     .bs_loop:}\par
{\f1       CMP.L    D3, D2}\par
{\f1       BGT.S    .bs_not_found     ; low > high : pas trouve}\par
{\f1       MOVE.L   D2, D4}\par
{\f1       ADD.L    D3, D4}\par
{\f1       LSR.L    #1, D4           ; D4 = mid = (low + high) / 2}\par
{\f1       MOVE.L   D4, D0}\par
{\f1       LSL.L    #2, D0           ; D0 = mid * 4}\par
{\f1       CMP.L    0(A0,D0.L), D5   ; Comparer valeur avec tab[mid]}\par
{\f1       BEQ.S    .bs_found}\par
{\f1       BGT.S    .bs_go_right}\par
{\f1       ; Valeur < tab[mid] : chercher a gauche}\par
{\f1       MOVE.L   D4, D3}\par
{\f1       SUBQ.L   #1, D3           ; high = mid - 1}\par
{\f1       BRA.S    .bs_loop}\par
{\f1     .bs_go_right:}\par
{\f1       ; Valeur > tab[mid] : chercher a droite}\par
{\f1       MOVE.L   D4, D2}\par
{\f1       ADDQ.L   #1, D2           ; low = mid + 1}\par
{\f1       BRA.S    .bs_loop}\par
{\f1     .bs_found:}\par
{\f1       MOVE.L   D4, D0           ; D0 = index trouve}\par
{\f1       BRA.S    .bs_end}\par
{\f1     .bs_not_found:}\par
{\f1       MOVEQ    #-1, D0          ; D0 = -1 (non trouve)}\par
{\f1     .bs_end:}\par
{\f1       MOVEM.L  (SP)+, D2-D5}\par
{\f1       RTS}\par
\par
\par
\b 8.12 Resume \b0\par
\par
{\f1   Les techniques de programmation du 68000 exploitent les forces}\par
{\f1   de son architecture orthogonale, ses 16 registres et ses modes}\par
{\f1   d'adressage riches.}\par
\par
{\f1   Points cles a retenir :}\par
\par
{\f1   - LINK/UNLK creent des cadres de pile propres et permettent}\par
{\f1     un acces facile aux parametres et variables locales}\par
{\f1   - Les registres D2-D7/A2-A5 sont preserves par convention ;}\par
{\f1     D0-D1/A0-A1 sont des registres scratch}\par
{\f1   - MOVEM.L permet la sauvegarde/restauration groupee de registres}\par
{\f1   - DBRA est l'instruction de boucle optimale pour le comptage}\par
{\f1   - Les modes post-increment (An)+ et pre-decrement -(An) rendent}\par
{\f1     les operations de copie et pile tres compactes}\par
{\f1   - MOVEQ, ADDQ et SUBQ sont des formes compactes (2 octets) et}\par
{\f1     rapides pour les petites constantes}\par
{\f1   - Le mode PC-relatif d(PC) permet du code position-independant}\par
{\f1   - L'alignement pair est obligatoire pour les acces mot et long mot}\par
{\f1   - L'arithmetique multi-precision utilise ADDX/SUBX avec le flag X}\par
{\f1   - L'interfacage C suit la convention cdecl : parametres empiles}\par
{\f1     de droite a gauche, l'appelant nettoie la pile}\par
\par
{\f1   Comparaison des techniques :}\par
\par
{\f1   Technique               Instruction(s) cle(s)}\par
{\f1   ----------------------  -----------------------------------}\par
{\f1   Cadre de pile           LINK An, #-N / UNLK An}\par
{\f1   Sauvegarde registres    MOVEM.L regs, -(SP) / (SP)+, regs}\par
{\f1   Boucle comptee          DBRA Dn, label}\par
{\f1   Boucle conditionnelle   DBcc Dn, label}\par
{\f1   Copie de chaine         MOVE.B (A0)+, (A1)+ / BNE}\par
{\f1   Table de sauts          JMP table(PC, Dn.W)}\par
{\f1   Addition 64 bits        ADD.L + ADDX.L}\par
{\f1   Code PIC                LEA data(PC), An}\par
{\f1   Immediate rapide        MOVEQ #n, Dn (2 octets, 4 cycles)}\par
{\f1   Ajout rapide            ADDQ.L #n, ea (2 octets)}\par
{\f1   Multiplication rapide   LSL.L + ADD.L (decalages + additions)}\par
{\f1   Interface C             LINK/UNLK + acces 8(A6), 12(A6)...}\par
\par
\par
