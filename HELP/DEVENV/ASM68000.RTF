{\footnote # IDH_ASM68000_04}
{\footnote $ Assembleur 68000 - JEU D'INSTRUCTIONS (OPCODES)}
{\footnote K Assembleur 68000 jeu instructions opcodes;MOVE MOVEA MOVEM MOVEP MOVEQ;ADD SUB MULU MULS DIVU DIVS;AND OR EOR NOT NEG;ASL ASR LSL LSR ROL ROR ROXL ROXR;CMP TST BTST BSET BCLR BCHG;Bcc BRA BSR JMP JSR RTS RTE;LINK UNLK;TRAP TRAPV CHK;NOP STOP RESET}
\b\fs24 JEU D'INSTRUCTIONS (OPCODES) \b0\fs20\par
\par
\par
\b 4.1 Vue d'ensemble \b0\par
\par
{\f1   Le 68000 possede un jeu d'instructions orthogonal et regulier.}\par
{\f1   La plupart des instructions acceptent plusieurs modes d'adressage}\par
{\f1   et peuvent operer sur des tailles differentes (.B, .W, .L),}\par
{\f1   ce qui reduit considerablement le nombre de mnemoniques a}\par
{\f1   memoriser.}\par
\par
{\f1   Le jeu d'instructions se divise en categories :}\par
{\f1     - Transfert de donnees}\par
{\f1     - Arithmetique entiere}\par
{\f1     - Operations logiques}\par
{\f1     - Decalages et rotations}\par
{\f1     - Manipulation de bits}\par
{\f1     - Arithmetique BCD (decimal code binaire)}\par
{\f1     - Branchements et controle de flux}\par
{\f1     - Operations sur le registre d'etat}\par
{\f1     - Instructions systeme et privilegiees}\par
\par
{\f1   Conventions de notation utilisees dans cette section :}\par
{\f1     Dn      : Registre de donnees (D0-D7)}\par
{\f1     An      : Registre d'adresses (A0-A7)}\par
{\f1     Xn      : Registre quelconque (Dn ou An)}\par
{\f1     ea      : Adresse effective (effective address)}\par
{\f1     #imm    : Valeur immediate (constante)}\par
{\f1     label   : Etiquette (adresse cible)}\par
{\f1     .B      : Taille octet (8 bits)}\par
{\f1     .W      : Taille mot (16 bits)}\par
{\f1     .L      : Taille long mot (32 bits)}\par
{\f1     [CCR]   : Drapeaux affectes (X, N, Z, V, C)}\par
{\f1     SR      : Registre d'etat complet (16 bits)}\par
{\f1     CCR     : Partie condition codes du SR (octet bas)}\par
\par
{\f1   Tailles par defaut :}\par
{\f1     - Si aucun suffixe n'est specifie, la taille par defaut est .W}\par
{\f1       pour la plupart des instructions}\par
{\f1     - Les instructions sur les registres d'adresses (MOVEA, ADDA,}\par
{\f1       SUBA, CMPA) n'acceptent que .W et .L}\par
{\f1     - Les instructions rapides (MOVEQ, ADDQ, SUBQ) ont des}\par
{\f1       contraintes de taille specifiques}\par
\par
\par
\b 4.2 Transfert de donnees \b0\par
\par
{\f1   Ces instructions copient des donnees entre registres, memoire et}\par
{\f1   valeurs immediates.}\par
\par
{\f1   4.2.1 Transfert general}\par
\par
{\f1   MOVE.s  ea, ea       Copier la source vers la destination}\par
{\f1                        Formes : presque toutes les combinaisons}\par
{\f1                        d'adresses effectives sont valides}\par
{\f1                        s = B, W ou L}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   MOVEA.s ea, An       Copier la source dans un registre d'adresses}\par
{\f1                        s = W (signe-etendu a 32 bits) ou L}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   MOVEQ   #imm8, Dn   Charger une constante 8 bits signee dans Dn}\par
{\f1                        (signe-etendue a 32 bits)}\par
{\f1                        La constante est codee dans l'instruction}\par
{\f1                        (pas de mot d'extension, tres rapide)}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   Exemples :}\par
{\f1     MOVE.L  D0, D1                 ; D1 := D0}\par
{\f1     MOVE.W  #$1234, D0             ; D0.W := $1234}\par
{\f1     MOVE.L  (A0), D1               ; D1 := long mot pointe par A0}\par
{\f1     MOVE.B  D0, (A1)+              ; [A1] := D0.B, A1 += 1}\par
{\f1     MOVEA.L #$00100000, A0         ; A0 := $00100000}\par
{\f1     MOVEQ   #-1, D0                ; D0 := $FFFFFFFF}\par
{\f1     MOVEQ   #0, D0                 ; D0 := 0 (idiome de mise a zero)}\par
\par
{\f1   Remarques :}\par
{\f1     - MOVE est l'instruction la plus utilisee (~40% du code)}\par
{\f1     - MOVEQ est prefere a MOVE.L #imm,Dn quand la constante}\par
{\f1       tient sur 8 bits signes (-128 a +127)}\par
{\f1     - MOVE modifie les drapeaux, contrairement a MOV sur x86}\par
{\f1     - MOVEA ne modifie JAMAIS les drapeaux}\par
\par
{\f1   4.2.2 Transfert de blocs de registres}\par
\par
{\f1   MOVEM.s liste, ea   Sauvegarder plusieurs registres en memoire}\par
{\f1   MOVEM.s ea, liste   Restaurer plusieurs registres depuis la memoire}\par
{\f1                       s = W ou L}\par
{\f1                       La liste specifie les registres concernes}\par
{\f1                       [CCR: non modifie]}\par
\par
{\f1   La liste de registres peut etre specifiee de plusieurs manieres :}\par
{\f1     D0-D7/A0-A6       Tous les registres (sauf A7)}\par
{\f1     D0-D3/A0-A2       Registres D0 a D3 et A0 a A2}\par
{\f1     D0/D2/D4/A0       Registres individuels separes par /}\par
\par
{\f1   Exemples :}\par
{\f1     MOVEM.L D0-D7/A0-A6, -(A7)    ; sauvegarder tous les registres}\par
{\f1     MOVEM.L (A7)+, D0-D7/A0-A6    ; restaurer tous les registres}\par
{\f1     MOVEM.L D0-D3/A0-A1, -(A7)    ; sauvegarder D0-D3 et A0-A1}\par
{\f1     MOVEM.W (A0), D0-D3            ; charger 4 mots consecutifs}\par
\par
{\f1   Remarques :}\par
{\f1     - Pour la sauvegarde (vers memoire), le mode -(An) est}\par
{\f1       typiquement utilise (pre-decrement)}\par
{\f1     - Pour la restauration (depuis memoire), le mode (An)+ est}\par
{\f1       typiquement utilise (post-increment)}\par
{\f1     - MOVEM avec -(An) sauve les registres dans l'ordre inverse}\par
{\f1       (A7 d'abord, D0 en dernier) pour que MOVEM avec (An)+}\par
{\f1       restaure correctement dans l'ordre normal}\par
\par
{\f1   4.2.3 Transfert avec les peripheriques}\par
\par
{\f1   MOVEP.s Dn, d16(An) Transferer un registre vers des octets alternes}\par
{\f1   MOVEP.s d16(An), Dn  Transferer des octets alternes vers un registre}\par
{\f1                        s = W (2 octets) ou L (4 octets)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   MOVEP transfere les octets d'un registre vers des adresses}\par
{\f1   paires (ou impaires) separees de 2 octets. Ceci permet}\par
{\f1   d'acceder a des peripheriques 8 bits connectes sur un bus de}\par
{\f1   donnees 16 bits.}\par
\par
{\f1   Exemple :}\par
{\f1     MOVEP.W D0, 0(A0)    ; [A0] := D0 bits 15-8}\par
{\f1                           ; [A0+2] := D0 bits 7-0}\par
\par
{\f1   4.2.4 Chargement d'adresse}\par
\par
{\f1   LEA  ea, An          Charger l'adresse effective dans An}\par
{\f1                        (pas d'acces memoire, calcul d'adresse seul)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   PEA  ea              Empiler l'adresse effective sur la pile}\par
{\f1                        A7 -= 4, [A7] := adresse effective}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   Exemples :}\par
{\f1     LEA     Table(PC), A0      ; A0 := adresse de Table (PIC)}\par
{\f1     LEA     8(A6), A0          ; A0 := A6 + 8 (adresse parametre)}\par
{\f1     LEA     0(A0,D0.W), A1    ; A1 := A0 + D0.W (adresse calculee)}\par
{\f1     PEA     Buffer(PC)         ; empiler l'adresse de Buffer}\par
\par
{\f1   Remarques :}\par
{\f1     - LEA est tres utilisee pour calculer des adresses sans}\par
{\f1       acceder a la memoire}\par
{\f1     - LEA avec PC-relatif permet du code relogeable}\par
{\f1     - PEA est utile pour passer des adresses en parametre}\par
{\f1       sur la pile avant un appel de sous-routine}\par
\par
{\f1   4.2.5 Echange et permutation}\par
\par
{\f1   EXG  Xn, Xn         Echanger le contenu de deux registres 32 bits}\par
{\f1                        (donnees-donnees, adresses-adresses, ou mixte)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   SWAP Dn              Echanger les mots haut et bas d'un registre}\par
{\f1                        Dn[31:16] <-> Dn[15:0]}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   Exemples :}\par
{\f1     EXG     D0, D1             ; D0 <-> D1}\par
{\f1     EXG     A0, A1             ; A0 <-> A1}\par
{\f1     EXG     D0, A0             ; D0 <-> A0}\par
{\f1     SWAP    D0                 ; echange mots haut et bas de D0}\par
\par
{\f1   4.2.6 Gestion du cadre de pile}\par
\par
{\f1   LINK An, #d16        Creer un cadre de pile :}\par
{\f1                        A7 -= 4, [A7] := An, An := A7, A7 += d16}\par
{\f1                        (d16 est generalement negatif pour reserver}\par
{\f1                         de l'espace pour les variables locales)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   UNLK An              Detruire un cadre de pile :}\par
{\f1                        A7 := An, An := [A7], A7 += 4}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   Exemple typique d'appel de fonction :}\par
{\f1     ; Appelant}\par
{\f1     MOVE.L  #param1, -(A7)     ; empiler le parametre}\par
{\f1     JSR     MaFonction         ; appeler la fonction}\par
{\f1     ADDQ.L  #4, A7             ; nettoyer la pile}\par
\par
{\f1     ; MaFonction}\par
{\f1     LINK    A6, #-8            ; creer cadre, reserver 8 octets}\par
{\f1     MOVE.L  8(A6), D0          ; D0 := 1er parametre}\par
{\f1     MOVE.W  D0, -2(A6)         ; variable locale}\par
{\f1     ...}\par
{\f1     UNLK    A6                 ; detruire le cadre}\par
{\f1     RTS                        ; retourner a l'appelant}\par
\par
\par
\b 4.3 Arithmetique entiere \b0\par
\par
{\f1   4.3.1 Addition}\par
\par
{\f1   ADD.s  ea, Dn        Dn <- Dn + ea [CCR: X, N, Z, V, C]}\par
{\f1   ADD.s  Dn, ea        ea <- ea + Dn [CCR: X, N, Z, V, C]}\par
\par
{\f1   ADDA.s ea, An        An <- An + ea (s = W signe-etendu ou L)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   ADDI.s #imm, ea      ea <- ea + imm [CCR: X, N, Z, V, C]}\par
\par
{\f1   ADDQ.s #imm3, ea     ea <- ea + imm (imm = 1 a 8)}\par
{\f1                        Constante codee dans l'instruction (rapide)}\par
{\f1                        [CCR: X, N, Z, V, C]}\par
{\f1                        (CCR non modifie si destination est An)}\par
\par
{\f1   ADDX.s Dn, Dn        Dn <- Dn + Dn + X [CCR: X, N, Z, V, C]}\par
{\f1   ADDX.s -(An), -(An)  Addition avec retenue (multi-precision)}\par
{\f1                        Le drapeau Z n'est mis a zero QUE si le}\par
{\f1                        resultat est non-nul (pour la multi-precision)}\par
\par
{\f1   Exemples :}\par
{\f1     ADD.L   D0, D1             ; D1 := D1 + D0}\par
{\f1     ADD.W   #100, D0           ; D0.W := D0.W + 100}\par
{\f1     ADDA.L  #4, A0             ; A0 := A0 + 4 (pas de modif CCR)}\par
{\f1     ADDQ.L  #1, D0             ; D0 := D0 + 1 (tres rapide)}\par
{\f1     ADDQ.W  #2, A7             ; A7 := A7 + 2 (ajuster la pile)}\par
\par
{\f1     ; Addition 64 bits : D0:D1 := D0:D1 + D2:D3}\par
{\f1     ADD.L   D3, D1             ; additionner les mots bas}\par
{\f1     ADDX.L  D2, D0             ; additionner les mots hauts + retenue}\par
\par
{\f1   4.3.2 Soustraction}\par
\par
{\f1   SUB.s  ea, Dn        Dn <- Dn - ea [CCR: X, N, Z, V, C]}\par
{\f1   SUB.s  Dn, ea        ea <- ea - Dn [CCR: X, N, Z, V, C]}\par
\par
{\f1   SUBA.s ea, An        An <- An - ea (s = W signe-etendu ou L)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   SUBI.s #imm, ea      ea <- ea - imm [CCR: X, N, Z, V, C]}\par
\par
{\f1   SUBQ.s #imm3, ea     ea <- ea - imm (imm = 1 a 8)}\par
{\f1                        [CCR: X, N, Z, V, C]}\par
{\f1                        (CCR non modifie si destination est An)}\par
\par
{\f1   SUBX.s Dn, Dn        Dn <- Dn - Dn - X [CCR: X, N, Z, V, C]}\par
{\f1   SUBX.s -(An), -(An)  Soustraction avec emprunt (multi-precision)}\par
\par
{\f1   NEG.s  ea            ea <- 0 - ea [CCR: X, N, Z, V, C]}\par
{\f1                        (complement a deux, negation)}\par
\par
{\f1   NEGX.s ea            ea <- 0 - ea - X [CCR: X, N, Z, V, C]}\par
{\f1                        (negation avec emprunt, multi-precision)}\par
\par
{\f1   CLR.s  ea            ea <- 0 [CCR: N=0, Z=1, V=0, C=0]}\par
\par
{\f1   Exemples :}\par
{\f1     SUB.L   D0, D1             ; D1 := D1 - D0}\par
{\f1     SUBA.L  #100, A0           ; A0 := A0 - 100}\par
{\f1     SUBQ.L  #1, D7             ; D7 := D7 - 1 (compteur)}\par
{\f1     NEG.L   D0                 ; D0 := -D0}\par
{\f1     CLR.L   D0                 ; D0 := 0}\par
\par
{\f1   Remarques :}\par
{\f1     - ADDQ/SUBQ sont les instructions les plus rapides pour}\par
{\f1       ajouter/soustraire une petite constante (1 a 8)}\par
{\f1     - ADDA/SUBA ne modifient pas les drapeaux, ce qui est}\par
{\f1       pratique pour manipuler des pointeurs sans perturber}\par
{\f1       les tests en cours}\par
{\f1     - CLR effectue d'abord une lecture puis une ecriture de}\par
{\f1       la destination (important pour les registres materiels)}\par
\par
{\f1   4.3.3 Multiplication}\par
\par
{\f1   MULS.W ea, Dn        Dn[31:0] <- Dn[15:0] * ea[15:0] (signe)}\par
{\f1                        Multiplication signee 16x16 -> 32 bits}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   MULU.W ea, Dn        Dn[31:0] <- Dn[15:0] * ea[15:0] (non signe)}\par
{\f1                        Multiplication non signee 16x16 -> 32 bits}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   Exemples :}\par
{\f1     MULU.W  #10, D0            ; D0 := D0.W * 10 (non signe)}\par
{\f1     MULS.W  D1, D0             ; D0 := D0.W * D1.W (signe)}\par
{\f1     MULU.W  #640, D0           ; D0 := D0.W * 640 (coord. ecran)}\par
\par
{\f1   Remarques :}\par
{\f1     - Le 68000 ne fait que des multiplications 16x16 -> 32}\par
{\f1     - Le 68020 ajoute les multiplications 32x32 -> 32/64}\par
{\f1     - La multiplication prend environ 70 cycles sur le 68000,}\par
{\f1       ce qui est relativement lent}\par
\par
{\f1   4.3.4 Division}\par
\par
{\f1   DIVS.W ea, Dn        Dn[15:0] <- Dn[31:0] / ea[15:0] (quotient)}\par
{\f1                        Dn[31:16] <- Dn[31:0] MOD ea[15:0] (reste)}\par
{\f1                        Division signee 32/16 -> 16 bits}\par
{\f1                        [CCR: N, Z, V mis a jour; C=0]}\par
{\f1                        Exception si ea = 0 (division par zero)}\par
\par
{\f1   DIVU.W ea, Dn        Dn[15:0] <- Dn[31:0] / ea[15:0] (quotient)}\par
{\f1                        Dn[31:16] <- Dn[31:0] MOD ea[15:0] (reste)}\par
{\f1                        Division non signee 32/16 -> 16 bits}\par
{\f1                        [CCR: N, Z, V mis a jour; C=0]}\par
{\f1                        Exception si ea = 0 (division par zero)}\par
\par
{\f1   Exemples :}\par
{\f1     DIVU.W  #10, D0            ; D0.W := D0 / 10, D0 haut := reste}\par
{\f1     DIVS.W  D1, D0             ; D0.W := D0 / D1.W (signe)}\par
\par
{\f1     ; Extraire quotient et reste}\par
{\f1     DIVU.W  #100, D0           ; diviser D0 par 100}\par
{\f1     MOVE.L  D0, D1             ; copier le resultat}\par
{\f1     SWAP    D1                 ; D1.W := reste (etait dans mot haut)}\par
{\f1     ; D0.W = quotient, D1.W = reste}\par
\par
{\f1   Remarques :}\par
{\f1     - Le 68000 ne fait que des divisions 32/16 -> 16+16}\par
{\f1     - Le 68020 ajoute les divisions 32/32 -> 32 et 64/32 -> 32}\par
{\f1     - Si le quotient ne tient pas sur 16 bits, V est mis a 1}\par
{\f1       et le registre destination n'est pas modifie}\par
{\f1     - La division prend environ 140 cycles sur le 68000}\par
{\f1     - La division par zero genere l'exception vecteur 5}\par
\par
{\f1   4.3.5 Extension de signe}\par
\par
{\f1   EXT.W  Dn            Etendre D0.B (bits 7-0) avec signe dans D0.W}\par
{\f1                        (bit 7 copie dans bits 15-8)}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   EXT.L  Dn            Etendre D0.W (bits 15-0) avec signe dans D0.L}\par
{\f1                        (bit 15 copie dans bits 31-16)}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   Exemples :}\par
{\f1     MOVE.B  #-5, D0            ; D0.B := $FB}\par
{\f1     EXT.W   D0                 ; D0.W := $FFFB (-5 sur 16 bits)}\par
{\f1     EXT.L   D0                 ; D0.L := $FFFFFFFB (-5 sur 32 bits)}\par
\par
{\f1   Remarques :}\par
{\f1     - Sur le 68000, il n'y a pas d'extension directe .B -> .L.}\par
{\f1       Il faut faire EXT.W puis EXT.L}\par
{\f1     - Le 68020 ajoute EXTB.L Dn pour l'extension .B -> .L directe}\par
\par
{\f1   4.3.6 Test et comparaison}\par
\par
{\f1   TST.s  ea            Tester l'operande (comparer avec zero)}\par
{\f1                        [CCR: N, Z mis a jour; V=0, C=0]}\par
\par
{\f1   CMP.s  ea, Dn        Calculer Dn - ea, positionner les drapeaux}\par
{\f1                        mais ne stocker pas le resultat}\par
{\f1                        [CCR: N, Z, V, C]}\par
\par
{\f1   CMPA.s ea, An        Calculer An - ea, positionner les drapeaux}\par
{\f1                        (s = W signe-etendu ou L)}\par
{\f1                        [CCR: N, Z, V, C]}\par
\par
{\f1   CMPI.s #imm, ea      Calculer ea - imm, positionner les drapeaux}\par
{\f1                        [CCR: N, Z, V, C]}\par
\par
{\f1   CMPM.s (An)+, (Am)+  Comparer deux blocs memoire element par element}\par
{\f1                        Calcule [Am]+ - [An]+, positionne les drapeaux}\par
{\f1                        (post-increment sur les deux registres)}\par
{\f1                        [CCR: N, Z, V, C]}\par
\par
{\f1   Exemples :}\par
{\f1     TST.L   D0                 ; tester si D0 est zero}\par
{\f1     BEQ     _est_zero          ; sauter si D0 = 0}\par
\par
{\f1     CMP.W   #100, D0           ; comparer D0.W avec 100}\par
{\f1     BGT     _superieur         ; sauter si D0.W > 100 (signe)}\par
\par
{\f1     CMPA.L  A0, A1             ; comparer A1 avec A0}\par
{\f1     BEQ     _meme_adresse      ; sauter si A0 = A1}\par
\par
{\f1     ; Comparer deux chaines de 10 octets}\par
{\f1     LEA     Str1, A0}\par
{\f1     LEA     Str2, A1}\par
{\f1     MOVEQ   #9, D7             ; compteur = 10 - 1}\par
{\f1   cmp_loop:}\par
{\f1     CMPM.B  (A0)+, (A1)+       ; comparer octet par octet}\par
{\f1     DBNE    D7, cmp_loop       ; continuer si egal et D7 >= 0}\par
\par
{\f1   Remarques :}\par
{\f1     - TST ne modifie PAS X (contrairement a CMP)}\par
{\f1     - CMP ne modifie PAS X (contrairement a SUB)}\par
{\f1     - CMPM est specialement concu pour la comparaison de blocs}\par
{\f1       memoire, avec auto-increment des deux pointeurs}\par
{\f1     - CMPA signe-etend l'operande .W a 32 bits avant la}\par
{\f1       comparaison}\par
\par
\par
\b 4.4 Operations logiques \b0\par
\par
{\f1   4.4.1 Operations logiques de base}\par
\par
{\f1   AND.s  ea, Dn        Dn <- Dn AND ea [CCR: N, Z; V=0, C=0]}\par
{\f1   AND.s  Dn, ea        ea <- ea AND Dn [CCR: N, Z; V=0, C=0]}\par
\par
{\f1   ANDI.s #imm, ea      ea <- ea AND imm [CCR: N, Z; V=0, C=0]}\par
\par
{\f1   OR.s   ea, Dn        Dn <- Dn OR ea [CCR: N, Z; V=0, C=0]}\par
{\f1   OR.s   Dn, ea        ea <- ea OR Dn [CCR: N, Z; V=0, C=0]}\par
\par
{\f1   ORI.s  #imm, ea      ea <- ea OR imm [CCR: N, Z; V=0, C=0]}\par
\par
{\f1   EOR.s  Dn, ea        ea <- ea XOR Dn [CCR: N, Z; V=0, C=0]}\par
\par
{\f1   EORI.s #imm, ea      ea <- ea XOR imm [CCR: N, Z; V=0, C=0]}\par
\par
{\f1   NOT.s  ea            ea <- NOT ea (complement a un)}\par
{\f1                        [CCR: N, Z; V=0, C=0]}\par
\par
{\f1   Exemples :}\par
{\f1     AND.L   #$FF, D0           ; masquer les bits hauts (garder octet)}\par
{\f1     OR.W    #$8000, D0         ; mettre le bit 15 a 1}\par
{\f1     EOR.L   D0, D0             ; D0 := 0 (idiome de mise a zero)}\par
{\f1     NOT.L   D0                 ; inverser tous les bits de D0}\par
{\f1     ANDI.B  #$0F, D0           ; garder les 4 bits bas}\par
\par
{\f1   Remarques :}\par
{\f1     - EOR (XOR) sur le 68000 n'accepte comme source QUE Dn}\par
{\f1       (pas d'autre mode d'adressage en source)}\par
{\f1     - Pour faire ea XOR ea, il faut d'abord charger dans Dn}\par
{\f1     - ANDI/ORI/EORI acceptent les immediats en source}\par
\par
{\f1   4.4.2 Operations logiques sur le CCR et le SR}\par
\par
{\f1   ANDI.B #imm, CCR     CCR <- CCR AND imm}\par
{\f1   ORI.B  #imm, CCR     CCR <- CCR OR imm}\par
{\f1   EORI.B #imm, CCR     CCR <- CCR XOR imm}\par
\par
{\f1   ANDI.W #imm, SR      SR <- SR AND imm (privilegiee)}\par
{\f1   ORI.W  #imm, SR      SR <- SR OR imm (privilegiee)}\par
{\f1   EORI.W #imm, SR      SR <- SR XOR imm (privilegiee)}\par
\par
{\f1   Exemples :}\par
{\f1     ANDI.B  #$FE, CCR          ; effacer le drapeau C}\par
{\f1     ORI.B   #$04, CCR          ; mettre le drapeau Z a 1}\par
{\f1     ANDI.W  #$F8FF, SR         ; passer au niveau d'interruption 0}\par
{\f1     ORI.W   #$0700, SR         ; masquer toutes les interruptions}\par
\par
\par
\b 4.5 Decalages et rotations \b0\par
\par
{\f1   4.5.1 Decalages arithmetiques}\par
\par
{\f1   ASL.s  #cnt, Dn      Decalage arithmetique a gauche}\par
{\f1   ASL.s  Dn, Dn        (cnt = 1 a 8 en immediat, ou valeur de Dn)}\par
{\f1   ASL.W  ea             (decalage de 1 position en memoire)}\par
{\f1                        Bit de poids fort -> C et X, 0 -> bit 0}\par
{\f1                        [CCR: X, N, Z, V, C]}\par
\par
{\f1   ASR.s  #cnt, Dn      Decalage arithmetique a droite}\par
{\f1   ASR.s  Dn, Dn        (preserve le bit de signe)}\par
{\f1   ASR.W  ea             Bit 0 -> C et X, signe preserve}\par
{\f1                        [CCR: X, N, Z, V, C]}\par
\par
{\f1   Exemples :}\par
{\f1     ASL.L   #1, D0             ; D0 := D0 * 2}\par
{\f1     ASL.L   #3, D0             ; D0 := D0 * 8}\par
{\f1     ASR.W   #1, D0             ; D0.W := D0.W / 2 (signe)}\par
{\f1     ASL.W   (A0)               ; decaler le mot en memoire}\par
\par
{\f1   4.5.2 Decalages logiques}\par
\par
{\f1   LSL.s  #cnt, Dn      Decalage logique a gauche}\par
{\f1   LSL.s  Dn, Dn        Identique a ASL pour le decalage a gauche}\par
{\f1   LSL.W  ea             [CCR: X, N, Z, V=0, C]}\par
\par
{\f1   LSR.s  #cnt, Dn      Decalage logique a droite}\par
{\f1   LSR.s  Dn, Dn        0 -> bit de poids fort, bit 0 -> C et X}\par
{\f1   LSR.W  ea             (ne preserve PAS le signe)}\par
{\f1                        [CCR: X, N, Z, V=0, C]}\par
\par
{\f1   Exemples :}\par
{\f1     LSL.L   #2, D0             ; D0 := D0 * 4 (non signe)}\par
{\f1     LSR.L   #4, D0             ; D0 := D0 / 16 (non signe)}\par
{\f1     LSL.W   #1, D0             ; equivalent a ASL.W #1, D0}\par
\par
{\f1   Remarques :}\par
{\f1     - ASL et LSL produisent le meme resultat}\par
{\f1     - ASR preserve le signe, LSR insere des zeros}\par
{\f1     - Le compteur immediat va de 1 a 8 ; pour des decalages}\par
{\f1       plus grands, utiliser un registre Dn comme compteur}\par
{\f1     - Les decalages en memoire ne deplacent que d'1 position}\par
{\f1       et operent uniquement en .W}\par
\par
{\f1   4.5.3 Rotations}\par
\par
{\f1   ROL.s  #cnt, Dn      Rotation a gauche}\par
{\f1   ROL.s  Dn, Dn        Bit de poids fort -> C et bit 0}\par
{\f1   ROL.W  ea             [CCR: N, Z, V=0, C]}\par
\par
{\f1   ROR.s  #cnt, Dn      Rotation a droite}\par
{\f1   ROR.s  Dn, Dn        Bit 0 -> C et bit de poids fort}\par
{\f1   ROR.W  ea             [CCR: N, Z, V=0, C]}\par
\par
{\f1   ROXL.s #cnt, Dn      Rotation a gauche a travers X}\par
{\f1   ROXL.s Dn, Dn        MSB -> C et X, ancien X -> bit 0}\par
{\f1   ROXL.W ea             [CCR: X, N, Z, V=0, C]}\par
\par
{\f1   ROXR.s #cnt, Dn      Rotation a droite a travers X}\par
{\f1   ROXR.s Dn, Dn        Bit 0 -> C et X, ancien X -> MSB}\par
{\f1   ROXR.W ea             [CCR: X, N, Z, V=0, C]}\par
\par
{\f1   Exemples :}\par
{\f1     ROL.L   #8, D0             ; rotation de D0 de 8 bits a gauche}\par
{\f1     ROR.W   #1, D0             ; rotation de D0.W d'1 bit a droite}\par
{\f1     ROXL.L  #1, D0             ; rotation avec X (multi-precision)}\par
\par
{\f1   Remarques :}\par
{\f1     - ROL/ROR n'affectent PAS le drapeau X (seulement C)}\par
{\f1     - ROXL/ROXR incluent X dans la rotation, formant une chaine}\par
{\f1       de (taille+1) bits. C'est utile pour les rotations}\par
{\f1       multi-precision}\par
{\f1     - Les rotations en memoire ne tournent que d'1 position}\par
\par
\par
\b 4.6 Manipulation de bits \b0\par
\par
{\f1   Ces instructions testent, modifient ou complementent un bit}\par
{\f1   individuel dans un registre ou en memoire. Le bit teste est}\par
{\f1   copie (inverse) dans le drapeau Z du CCR.}\par
\par
{\f1   BTST  #bit, ea       Tester le bit : Z <- NOT bit selectionne}\par
{\f1   BTST  Dn, ea         [CCR: Z mis a jour]}\par
\par
{\f1   BSET  #bit, ea       Tester puis mettre a 1 : Z <- NOT bit, bit <- 1}\par
{\f1   BSET  Dn, ea         [CCR: Z mis a jour]}\par
\par
{\f1   BCLR  #bit, ea       Tester puis mettre a 0 : Z <- NOT bit, bit <- 0}\par
{\f1   BCLR  Dn, ea         [CCR: Z mis a jour]}\par
\par
{\f1   BCHG  #bit, ea       Tester puis completer : Z <- NOT bit,}\par
{\f1   BCHG  Dn, ea         bit <- NOT bit}\par
{\f1                        [CCR: Z mis a jour]}\par
\par
{\f1   Le numero de bit peut etre :}\par
{\f1     - Un immediat (0 a 31 pour Dn, 0 a 7 pour la memoire)}\par
{\f1     - Un registre Dn (modulo 32 pour Dn, modulo 8 pour memoire)}\par
\par
{\f1   Quand l'operande est un registre, l'operation porte sur les}\par
{\f1   32 bits du registre (bit 0 a 31).}\par
{\f1   Quand l'operande est en memoire, l'operation porte sur un}\par
{\f1   octet (bit 0 a 7).}\par
\par
{\f1   Exemples :}\par
{\f1     BTST    #0, D0             ; tester le bit 0 de D0}\par
{\f1     BNE     _impair            ; sauter si bit 0 = 1}\par
\par
{\f1     BSET    #7, D0             ; mettre le bit 7 de D0 a 1}\par
{\f1     BCLR    #31, D0            ; effacer le bit 31 de D0}\par
{\f1     BCHG    D1, D0             ; completer le bit D1 de D0}\par
\par
{\f1     BTST    #0, (A0)           ; tester le bit 0 de l'octet [A0]}\par
{\f1     BSET    #7, (A0)           ; mettre le bit 7 de l'octet [A0]}\par
\par
{\f1   Remarques :}\par
{\f1     - Le drapeau Z est l'INVERSE du bit teste :}\par
{\f1       Z = 1 si le bit etait 0, Z = 0 si le bit etait 1}\par
{\f1     - Sur le 68000, BTST peut tester n'importe quel mode}\par
{\f1       d'adressage, mais BSET/BCLR/BCHG ne peuvent pas}\par
{\f1       modifier un registre d'adresses directement}\par
\par
\par
\b 4.7 Arithmetique BCD (decimal code binaire) \b0\par
\par
{\f1   Le 68000 supporte l'arithmetique BCD (Binary Coded Decimal)}\par
{\f1   pour les applications financieres et commerciales.}\par
\par
{\f1   ABCD.B Dn, Dn        Dn <- Dn + Dn + X (addition BCD)}\par
{\f1   ABCD.B -(An), -(An)  [CCR: X, C mis a jour; Z non remis a zero]}\par
\par
{\f1   SBCD.B Dn, Dn        Dn <- Dn - Dn - X (soustraction BCD)}\par
{\f1   SBCD.B -(An), -(An)  [CCR: X, C mis a jour; Z non remis a zero]}\par
\par
{\f1   NBCD.B ea            ea <- 0 - ea - X (negation BCD)}\par
{\f1                        [CCR: X, C mis a jour; Z non remis a zero]}\par
\par
{\f1   Exemples :}\par
{\f1     ; Additionner deux nombres BCD de 4 chiffres}\par
{\f1     ; D0 = $1234, D1 = $5678, resultat dans D0}\par
{\f1     MOVE    #$04, CCR          ; mettre X = 0 (effacer la retenue)}\par
{\f1     ABCD.B  D1, D0             ; additionner les octets bas (BCD)}\par
{\f1     SWAP    D0}\par
{\f1     SWAP    D1}\par
{\f1     ABCD.B  D1, D0             ; additionner les octets hauts + retenue}\par
\par
{\f1   Remarques :}\par
{\f1     - Les operations BCD ne travaillent que sur des octets}\par
{\f1     - Le drapeau Z n'est PAS remis a zero si le resultat est}\par
{\f1       non-nul (il est seulement mis a 1 si le resultat est 0).}\par
{\f1       Ceci permet de tester le zero sur des operations multi-}\par
{\f1       octets en initialisant Z a 1 au depart}\par
{\f1     - Le mode -(An), -(An) est prevu pour traiter des chaines}\par
{\f1       BCD en memoire de droite a gauche}\par
\par
\par
\b 4.8 Branchements et controle de flux \b0\par
\par
{\f1   4.8.1 Sauts inconditionnels}\par
\par
{\f1   JMP  ea              Saut inconditionnel a l'adresse effective}\par
{\f1                        PC := ea}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   BRA  label           Branchement relatif inconditionnel}\par
{\f1   BRA.S label          PC := PC + deplacement (8 ou 16 bits)}\par
{\f1   BRA.W label          [CCR: non modifie]}\par
\par
{\f1   Exemples :}\par
{\f1     JMP     (A0)               ; saut via pointeur dans A0}\par
{\f1     JMP     Table(PC,D0.W)     ; saut via table indexee}\par
{\f1     BRA     Boucle             ; branchement relatif}\par
{\f1     BRA.S   Suite              ; branchement court (8 bits)}\par
\par
{\f1   Remarques :}\par
{\f1     - BRA est prefere a JMP pour le code relogeable (PIC)}\par
{\f1     - BRA.S (short) utilise un deplacement 8 bits (-128 a +126)}\par
{\f1     - BRA.W utilise un deplacement 16 bits (-32768 a +32766)}\par
{\f1     - JMP accepte les modes indirects et indexes, pas BRA}\par
\par
{\f1   4.8.2 Appels de sous-programmes}\par
\par
{\f1   JSR  ea              Appel : A7 -= 4, [A7] := PC, PC := ea}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   BSR  label           Appel relatif : A7 -= 4, [A7] := PC,}\par
{\f1   BSR.S label          PC := PC + deplacement}\par
{\f1   BSR.W label          [CCR: non modifie]}\par
\par
{\f1   RTS                  Retour de sous-programme :}\par
{\f1                        PC := [A7], A7 += 4}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   RTR                  Retour avec restauration CCR :}\par
{\f1                        CCR := [A7], A7 += 2,}\par
{\f1                        PC := [A7], A7 += 4}\par
{\f1                        [CCR: restaure depuis la pile]}\par
\par
{\f1   RTE                  Retour d'exception (privilegiee) :}\par
{\f1                        SR := [A7], A7 += 2,}\par
{\f1                        PC := [A7], A7 += 4}\par
{\f1                        [CCR: restaure depuis la pile]}\par
\par
{\f1   Exemples :}\par
{\f1     JSR     MaRoutine          ; appel direct}\par
{\f1     BSR     MaRoutine          ; appel relatif (PIC)}\par
{\f1     BSR.S   Proche             ; appel relatif court}\par
{\f1     JSR     (A0)               ; appel indirect via pointeur}\par
\par
{\f1   Remarques :}\par
{\f1     - BSR est prefere a JSR pour le code relogeable}\par
{\f1     - RTS depile uniquement PC (4 octets)}\par
{\f1     - RTR depile CCR (2 octets) puis PC (4 octets)}\par
{\f1     - RTE depile SR (2 octets) puis PC (4 octets) et est}\par
{\f1       reservee au mode superviseur}\par
\par
{\f1   4.8.3 Branchements conditionnels}\par
\par
{\f1   Bcc  label           Branchement si condition cc vraie}\par
{\f1   Bcc.S label          PC := PC + deplacement (8 ou 16 bits)}\par
{\f1   Bcc.W label          [CCR: non modifie]}\par
\par
{\f1   Les conditions cc sont :}\par
\par
{\f1   Condition            Mnemonique  Drapeaux testes}\par
{\f1   -------------------  ----------  ----------------------}\par
{\f1   Egal / zero          BEQ         Z = 1}\par
{\f1   Non egal             BNE         Z = 0}\par
{\f1   Retenue              BCS         C = 1}\par
{\f1   Pas de retenue       BCC         C = 0}\par
{\f1   Negatif              BMI         N = 1}\par
{\f1   Positif ou zero      BPL         N = 0}\par
{\f1   Debordement          BVS         V = 1}\par
{\f1   Pas de debordement   BVC         V = 0}\par
\par
{\f1   Comparaisons non signees (unsigned) :}\par
{\f1   Inferieur            BCS / BLO   C = 1}\par
{\f1   Inf. ou egal         BLS         C = 1 ou Z = 1}\par
{\f1   Superieur            BHI         C = 0 et Z = 0}\par
{\f1   Sup. ou egal         BCC / BHS   C = 0}\par
\par
{\f1   Comparaisons signees (signed) :}\par
{\f1   Inferieur            BLT         N xor V = 1}\par
{\f1   Inf. ou egal         BLE         (N xor V) = 1 ou Z = 1}\par
{\f1   Superieur            BGT         (N xor V) = 0 et Z = 0}\par
{\f1   Sup. ou egal         BGE         N xor V = 0}\par
\par
{\f1   Toujours vrai         BRA         (inconditionnel)}\par
{\f1   Toujours faux         (pas de mnemonique ; utiliser NOP ou BRA.S *+2)}\par
\par
{\f1   Exemples :}\par
{\f1     CMP.W   #10, D0}\par
{\f1     BEQ     _egal              ; sauter si D0.W = 10}\par
{\f1     BNE     _different         ; sauter si D0.W <> 10}\par
{\f1     BGT     _superieur         ; sauter si D0.W > 10 (signe)}\par
{\f1     BHI     _au_dessus         ; sauter si D0.W > 10 (non signe)}\par
{\f1     BLT     _inferieur         ; sauter si D0.W < 10 (signe)}\par
{\f1     BCS     _en_dessous        ; sauter si D0.W < 10 (non signe)}\par
\par
{\f1     TST.L   D0}\par
{\f1     BMI     _negatif           ; sauter si D0 < 0}\par
{\f1     BPL     _positif           ; sauter si D0 >= 0}\par
\par
{\f1   4.8.4 Boucle avec decrementation (DBcc)}\par
\par
{\f1   DBcc Dn, label       Si condition cc est fausse :}\par
{\f1                          Dn.W <- Dn.W - 1}\par
{\f1                          Si Dn.W <> -1 : branchement a label}\par
{\f1                          Sinon : continuer (fin de boucle)}\par
{\f1                        Si condition cc est vraie :}\par
{\f1                          Continuer (sortie anticipee)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   Les conditions cc sont les memes que pour Bcc.}\par
\par
{\f1   DBF est la forme la plus courante (condition toujours fausse,}\par
{\f1   equivalente a DBRA sur certains assembleurs) :}\par
\par
{\f1   DBF  Dn, label       Dn.W -= 1, boucler si Dn.W <> -1}\par
{\f1   DBRA Dn, label       Synonyme de DBF}\par
\par
{\f1   Exemples :}\par
{\f1     ; Boucle de 10 iterations}\par
{\f1     MOVEQ   #9, D7             ; compteur = 10 - 1}\par
{\f1   boucle:}\par
{\f1     ...                        ; corps de la boucle}\par
{\f1     DBRA    D7, boucle         ; D7 -= 1, boucler si D7 >= 0}\par
\par
{\f1     ; Chercher un zero dans un buffer}\par
{\f1     MOVEQ   #99, D7            ; max 100 octets}\par
{\f1   cherche:}\par
{\f1     TST.B   (A0)+              ; tester l'octet courant}\par
{\f1     DBEQ    D7, cherche        ; sortir si zero ou fin du compteur}\par
\par
{\f1   Remarques :}\par
{\f1     - DBcc decremente UNIQUEMENT le mot bas (Dn.W) du registre}\par
{\f1     - La boucle se termine quand Dn.W passe de 0 a -1 ($FFFF)}\par
{\f1     - Pour N iterations, initialiser Dn a N-1}\par
{\f1     - DBcc est tres efficace pour les boucles avec condition}\par
{\f1       de sortie anticipee}\par
\par
{\f1   4.8.5 Positionnement conditionnel d'octets (Scc)}\par
\par
{\f1   Scc  ea              Si condition cc vraie : ea.B <- $FF}\par
{\f1                        Si condition cc fausse : ea.B <- $00}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   Les conditions cc sont les memes que pour Bcc.}\par
\par
{\f1   Exemples :}\par
{\f1     CMP.W   D0, D1}\par
{\f1     SEQ     D2                 ; D2.B := $FF si D0 = D1, $00 sinon}\par
{\f1     SLT     D3                 ; D3.B := $FF si D1 < D0 (signe)}\par
{\f1     SNE     (A0)               ; [A0] := $FF si D0 <> D1}\par
\par
{\f1   Remarques :}\par
{\f1     - Scc positionne un octet entier ($FF ou $00), pas un seul bit}\par
{\f1     - Cela permet d'utiliser le resultat comme masque pour les}\par
{\f1       operations logiques}\par
{\f1     - Equivalent de SETcc sur le 80386, mais utilise $FF au}\par
{\f1       lieu de $01}\par
\par
{\f1   4.8.6 Interruptions logicielles}\par
\par
{\f1   TRAP #vector         Exception logicielle (vecteur 32 + vector)}\par
{\f1                        vector = 0 a 15}\par
{\f1                        Sauvegarde PC et SR sur la pile superviseur,}\par
{\f1                        puis saut au handler via la table de vecteurs}\par
{\f1                        [CCR: non modifie (SR sauvegarde)]}\par
\par
{\f1   TRAPV                Exception si V = 1 (debordement)}\par
{\f1                        Equivalent a : if V then TRAP #7}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   CHK.W ea, Dn         Verifier les bornes d'un indice :}\par
{\f1                        Si Dn < 0 ou Dn > ea : exception CHK}\par
{\f1                        (vecteur 6)}\par
{\f1                        [CCR: N modifie, autres indefinis]}\par
\par
{\f1   Exemples :}\par
{\f1     TRAP    #0                 ; appel systeme (AmigaOS, Atari TOS)}\par
{\f1     TRAP    #15                ; appel au debugger (tradition 68K)}\par
{\f1     TRAPV                      ; exception si debordement}\par
{\f1     CHK.W   #99, D0            ; exception si D0 < 0 ou D0 > 99}\par
\par
{\f1   Remarques :}\par
{\f1     - TRAP est le mecanisme standard pour les appels systeme}\par
{\f1       sur les systemes 68000 (AmigaOS, Atari TOS, Mac OS)}\par
{\f1     - Les vecteurs TRAP #0 a TRAP #15 occupent les adresses}\par
{\f1       $80 a $BC dans la table des vecteurs d'exception}\par
{\f1     - CHK est utile pour la verification automatique des}\par
{\f1       bornes de tableaux}\par
\par
\par
\b 4.9 Operations sur le registre d'etat \b0\par
\par
{\f1   4.9.1 Acces au CCR et au SR}\par
\par
{\f1   MOVE.W  SR, ea       Lire le registre d'etat complet}\par
{\f1                        (privilegiee sur le 68010+, pas sur le 68000)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   MOVE.W  ea, SR       Charger le registre d'etat (privilegiee)}\par
{\f1                        [CCR: modifie selon la valeur chargee]}\par
\par
{\f1   MOVE.W  CCR, ea      Lire la partie CCR du registre d'etat}\par
{\f1                        (disponible a partir du 68010)}\par
\par
{\f1   MOVE.W  ea, CCR      Charger la partie CCR}\par
{\f1                        (seul l'octet bas est utilise)}\par
{\f1                        [CCR: modifie selon la valeur chargee]}\par
\par
{\f1   4.9.2 Acces au pointeur de pile utilisateur}\par
\par
{\f1   MOVE.L  USP, An      Lire le pointeur de pile utilisateur}\par
{\f1                        (privilegiee)}\par
{\f1   MOVE.L  An, USP      Charger le pointeur de pile utilisateur}\par
{\f1                        (privilegiee)}\par
\par
{\f1   Exemples :}\par
{\f1     MOVE.W  SR, D0             ; D0 := SR (lire le registre d'etat)}\par
{\f1     MOVE.W  #$2700, SR         ; SR := $2700 (niveau interruption 7)}\par
{\f1     MOVE.W  D0, CCR            ; CCR := D0 (bits bas)}\par
{\f1     MOVE.L  USP, A0            ; A0 := pile utilisateur (superviseur)}\par
\par
\par
\b 4.10 Instructions systeme et privilegiees \b0\par
\par
{\f1   4.10.1 Instructions privilegiees}\par
\par
{\f1   Les instructions suivantes ne peuvent etre executees qu'en}\par
{\f1   mode superviseur (bit S du SR = 1). Toute tentative d'execution}\par
{\f1   en mode utilisateur genere une exception de violation de privilege}\par
{\f1   (vecteur 8).}\par
\par
{\f1   STOP  #imm16         Charger SR avec imm16, puis arreter le}\par
{\f1                        processeur jusqu'a la prochaine interruption,}\par
{\f1                        exception ou reset}\par
{\f1                        [CCR: modifie selon imm16]}\par
\par
{\f1   RESET                Envoyer le signal RESET sur le bus externe}\par
{\f1                        (reinitialise les peripheriques sans}\par
{\f1                         affecter le processeur lui-meme)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   RTE                  Retour d'exception (voir section 4.8.2)}\par
\par
{\f1   MOVE.W ea, SR        Charger le registre d'etat (voir 4.9.1)}\par
{\f1   MOVE.L USP, An       Acces au pointeur de pile utilisateur}\par
{\f1   MOVE.L An, USP       (voir section 4.9.2)}\par
\par
{\f1   ANDI.W #imm, SR      Operations logiques sur le SR (voir 4.4.2)}\par
{\f1   ORI.W  #imm, SR}\par
{\f1   EORI.W #imm, SR}\par
\par
{\f1   4.10.2 Instructions de controle}\par
\par
{\f1   NOP                  Pas d'operation}\par
{\f1                        (force la synchronisation du pipeline)}\par
{\f1                        [CCR: non modifie]}\par
\par
{\f1   ILLEGAL              Generer une exception d'instruction illegale}\par
{\f1                        (vecteur 4). Le codage est $4AFC.}\par
{\f1                        Utile pour le debogage et comme point d'arret}\par
\par
{\f1   Remarques :}\par
{\f1     - STOP est utilisee dans les boucles d'attente d'interruption}\par
{\f1       pour reduire la consommation (idle loop)}\par
{\f1     - RESET n'affecte pas le processeur lui-meme, seulement}\par
{\f1       les peripheriques connectes au bus}\par
{\f1     - NOP sur le 68000 ne fait pas juste "rien" : elle force}\par
{\f1       la completion de toutes les operations en cours dans le}\par
{\f1       pipeline de pre-lecture}\par
\par
\par
\b 4.11 Resume et tableau recapitulatif \b0\par
\par
{\f1   Nombre approximatif d'instructions par categorie :}\par
\par
{\f1   Categorie                          Nombre}\par
{\f1   ---------------------------------  ------}\par
{\f1   Transfert de donnees                  15}\par
{\f1   Arithmetique entiere                  22}\par
{\f1   Operations logiques                    8}\par
{\f1   Decalages et rotations                 8}\par
{\f1   Manipulation de bits                   4}\par
{\f1   Arithmetique BCD                       3}\par
{\f1   Branchements et controle              20+}\par
{\f1   Positionnement conditionnel (Scc)     16}\par
{\f1   Boucles (DBcc)                        16}\par
{\f1   Registre d'etat                        8}\par
{\f1   Systeme et privilegiees                5}\par
{\f1   Divers (NOP, ILLEGAL, etc.)           2}\par
{\f1   ---------------------------------  ------}\par
{\f1   Total (hors variantes de taille)    ~130}\par
\par
{\f1   Instructions les plus frequemment utilisees en pratique :}\par
\par
{\f1   Instruction   Usage typique}\par
{\f1   -----------   ------------------------------------------}\par
{\f1   MOVE          Transfert de donnees (~40% des instructions)}\par
{\f1   MOVEQ         Chargement de petites constantes}\par
{\f1   LEA           Calcul d'adresses}\par
{\f1   ADD/SUB       Arithmetique de base}\par
{\f1   ADDQ/SUBQ     Increment/decrement rapide}\par
{\f1   CMP/TST       Preparation des branchements}\par
{\f1   BRA/Bcc       Controle de flux}\par
{\f1   BSR/JSR/RTS   Appels de fonctions}\par
{\f1   CLR           Mise a zero}\par
{\f1   AND/OR        Masquage et combinaison de bits}\par
{\f1   LSL/LSR       Multiplications/divisions par puissances de 2}\par
{\f1   DBRA          Boucles avec compteur}\par
{\f1   MOVEM         Sauvegarde/restauration de registres}\par
{\f1   LINK/UNLK     Gestion du cadre de pile}\par
{\f1   SWAP          Acces au mot haut d'un registre}\par
\par
{\f1   Comparaison avec l'Intel 80386 :}\par
\par
{\f1   Aspect                     68000               80386}\par
{\f1   -------------------------  -------------------  ----------------------}\par
{\f1   Nombre d'instructions      ~130                 ~180}\par
{\f1   Tailles d'operandes        .B / .W / .L         8 / 16 / 32 bits}\par
{\f1   Suffixe de taille          Obligatoire          Implicite (registre)}\par
{\f1   Operations memoire-memoire Non (sauf MOVEM,     MOV mem, mem indirect}\par
{\f1                              CMPM, ABCD, SBCD)}\par
{\f1   Multiplication             16x16 -> 32          8/16/32 -> double}\par
{\f1   Division                   32/16 -> 16+16       double -> simple}\par
{\f1   Branchement conditionnel   Bcc (8/16 bits)      Jcc (8/32 bits)}\par
{\f1   Boucle avec condition      DBcc (unique!)       LOOP (sans condition)}\par
{\f1   Positionnement cond.       Scc (-> $FF/$00)     SETcc (-> $01/$00)}\par
{\f1   Instructions de chaines    Non (utiliser DBRA)  MOVS, CMPS, etc.}\par
{\f1   Auto-increment/decrement   (An)+, -(An) en EA   Non (sauf PUSH/POP)}\par
{\f1   Modes d'adressage par instr Uniformes           Variables selon instr}\par
{\f1   Drapeaux apres MOVE        Modifies             Non modifies}\par
{\f1   Retenue etendue (X)        Oui (drapeau X)      Non (C sert pour tout)}\par
{\f1   Arithmetique BCD           ABCD, SBCD, NBCD     DAA, DAS, AAA, AAS}\par
{\f1   Ports E/S                  Memory-mapped         IN/OUT separes}\par
\par
{\f1   Le 68000 se distingue par son jeu d'instructions orthogonal :}\par
{\f1   la plupart des instructions acceptent les memes modes d'adressage}\par
{\f1   et les memes tailles d'operandes. Cette regularite simplifie}\par
{\f1   l'apprentissage et la generation de code. Le drapeau X (eXtend)}\par
{\f1   separe de C (Carry) facilite l'arithmetique multi-precision.}\par
{\f1   En revanche, le 80386 offre des instructions de chaines (REP MOVS,}\par
{\f1   etc.) et des operations memoire-memoire plus directes.}\par
\par
\par
