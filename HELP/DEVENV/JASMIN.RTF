{\footnote # IDH_JASMIN_11}
{\footnote $ Jasmin - Les opcodes de manipulation de la pile}
{\footnote K Jasmin opcodes manipulation pile;dup dup2 dup_x1 dup_x2;pop pop2;swap;nop}
\b\fs24 Les opcodes de manipulation de la pile \b0\fs20\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     pop             57     Retirer le sommet de la pile (1 mot)}\par
{\f1     pop2            58     Retirer 2 mots du sommet}\par
{\f1     dup             59     Dupliquer le sommet de la pile}\par
{\f1     dup_x1          5A     Dupliquer et inserer sous le 2e element}\par
{\f1     dup_x2          5B     Dupliquer et inserer sous le 3e element}\par
{\f1     dup2            5C     Dupliquer les 2 mots du sommet}\par
{\f1     dup2_x1         5D     Dupliquer 2 mots et inserer sous le 3e}\par
{\f1     dup2_x2         5E     Dupliquer 2 mots et inserer sous le 5e}\par
{\f1     swap            5F     Echanger les 2 elements du sommet}\par
{\f1     nop             00     Ne rien faire (aucune operation)}\par
\par
{\f1   Exemple d utilisation de dup pour affecter et utiliser une valeur :}\par
\par
{\f1     bipush 42             ; empiler 42}\par
{\f1     dup                   ; dupliquer : pile = 42, 42}\par
{\f1     istore 1              ; stocker dans var 1 : pile = 42}\par
{\f1     ; la valeur 42 est encore sur la pile pour une utilisation ulterieure}\par
\par
\par
