{\footnote # IDH_JASMIN_19}
{\footnote $ Jasmin - Tableau complet des instructions JVM}
{\footnote K Jasmin tableau complet instructions JVM;opcodes 00-FF;mnemoniques;reference complete}
\b\fs24 Tableau complet des instructions JVM \b0\fs20\par
\par
{\f1   Ce tableau recense les 256 opcodes de la machine virtuelle Java.}\par
{\f1   Chaque instruction est identifiee par son code hexadecimal, son}\par
{\f1   mnemonique Jasmin, ses operandes eventuels et son effet sur la pile.}\par
\par
{\f1   Notation de la pile :}\par
{\f1     -> val         : empile une valeur}\par
{\f1     val ->         : depile une valeur}\par
{\f1     a, b -> c      : depile a et b, empile c}\par
{\f1     [aucun]        : aucun effet sur la pile}\par
\par
{\f1   Abreviations :}\par
{\f1     var   = index de variable locale}\par
{\f1     idx   = index dans le bassin de constantes (constant pool)}\par
{\f1     off   = offset de branchement (etiquette en Jasmin)}\par
\par
\par
\b 19.1 Instructions 00-0F : constantes et nop \b0\par
\par
{\f1     Hex  Mnemonique     Operandes  Pile                Description}\par
{\f1     ---  -------------- ---------  ------------------  ---------------------------}\par
{\f1     00   nop            [aucun]    [aucun]             Ne rien faire}\par
{\f1     01   aconst_null    [aucun]    -> null             Empiler null}\par
{\f1     02   iconst_m1      [aucun]    -> -1               Empiler int -1}\par
{\f1     03   iconst_0       [aucun]    -> 0                Empiler int 0}\par
{\f1     04   iconst_1       [aucun]    -> 1                Empiler int 1}\par
{\f1     05   iconst_2       [aucun]    -> 2                Empiler int 2}\par
{\f1     06   iconst_3       [aucun]    -> 3                Empiler int 3}\par
{\f1     07   iconst_4       [aucun]    -> 4                Empiler int 4}\par
{\f1     08   iconst_5       [aucun]    -> 5                Empiler int 5}\par
{\f1     09   lconst_0       [aucun]    -> 0L               Empiler long 0}\par
{\f1     0A   lconst_1       [aucun]    -> 1L               Empiler long 1}\par
{\f1     0B   fconst_0       [aucun]    -> 0.0f             Empiler float 0.0}\par
{\f1     0C   fconst_1       [aucun]    -> 1.0f             Empiler float 1.0}\par
{\f1     0D   fconst_2       [aucun]    -> 2.0f             Empiler float 2.0}\par
{\f1     0E   dconst_0       [aucun]    -> 0.0d             Empiler double 0.0}\par
{\f1     0F   dconst_1       [aucun]    -> 1.0d             Empiler double 1.0}\par
\par
\par
\b 19.2 Instructions 10-14 : chargement de constantes \b0\par
\par
{\f1     Hex  Mnemonique     Operandes  Pile                Description}\par
{\f1     ---  -------------- ---------  ------------------  ---------------------------}\par
{\f1     10   bipush         byte       -> val              Empiler byte signe}\par
{\f1     11   sipush         short      -> val              Empiler short signe}\par
{\f1     12   ldc            idx        -> val              Charger int/float/String}\par
{\f1     13   ldc_w          idx        -> val              Charger (index large)}\par
{\f1     14   ldc2_w         idx        -> val              Charger long/double}\par
\par
\par
\b 19.3 Instructions 15-2D : chargement depuis variables locales \b0\par
\par
{\f1     Hex  Mnemonique     Operandes  Pile                Description}\par
{\f1     ---  -------------- ---------  ------------------  ---------------------------}\par
{\f1     15   iload          var        -> val              Charger int}\par
{\f1     16   lload          var        -> val              Charger long}\par
{\f1     17   fload          var        -> val              Charger float}\par
{\f1     18   dload          var        -> val              Charger double}\par
{\f1     19   aload          var        -> val              Charger reference}\par
{\f1     1A   iload_0        [aucun]    -> val              Charger int var 0}\par
{\f1     1B   iload_1        [aucun]    -> val              Charger int var 1}\par
{\f1     1C   iload_2        [aucun]    -> val              Charger int var 2}\par
{\f1     1D   iload_3        [aucun]    -> val              Charger int var 3}\par
{\f1     1E   lload_0        [aucun]    -> val              Charger long var 0}\par
{\f1     1F   lload_1        [aucun]    -> val              Charger long var 1}\par
{\f1     20   lload_2        [aucun]    -> val              Charger long var 2}\par
{\f1     21   lload_3        [aucun]    -> val              Charger long var 3}\par
{\f1     22   fload_0        [aucun]    -> val              Charger float var 0}\par
{\f1     23   fload_1        [aucun]    -> val              Charger float var 1}\par
{\f1     24   fload_2        [aucun]    -> val              Charger float var 2}\par
{\f1     25   fload_3        [aucun]    -> val              Charger float var 3}\par
{\f1     26   dload_0        [aucun]    -> val              Charger double var 0}\par
{\f1     27   dload_1        [aucun]    -> val              Charger double var 1}\par
{\f1     28   dload_2        [aucun]    -> val              Charger double var 2}\par
{\f1     29   dload_3        [aucun]    -> val              Charger double var 3}\par
{\f1     2A   aload_0        [aucun]    -> val              Charger reference var 0}\par
{\f1     2B   aload_1        [aucun]    -> val              Charger reference var 1}\par
{\f1     2C   aload_2        [aucun]    -> val              Charger reference var 2}\par
{\f1     2D   aload_3        [aucun]    -> val              Charger reference var 3}\par
\par
\par
\b 19.4 Instructions 2E-35 : chargement depuis tableaux \b0\par
\par
{\f1     Hex  Mnemonique     Operandes  Pile                Description}\par
{\f1     ---  -------------- ---------  ------------------  ---------------------------}\par
{\f1     2E   iaload         [aucun]    ref, idx -> val     Charger int du tableau}\par
{\f1     2F   laload         [aucun]    ref, idx -> val     Charger long du tableau}\par
{\f1     30   faload         [aucun]    ref, idx -> val     Charger float du tableau}\par
{\f1     31   daload         [aucun]    ref, idx -> val     Charger double du tableau}\par
{\f1     32   aaload         [aucun]    ref, idx -> val     Charger ref du tableau}\par
{\f1     33   baload         [aucun]    ref, idx -> val     Charger byte du tableau}\par
{\f1     34   caload         [aucun]    ref, idx -> val     Charger char du tableau}\par
{\f1     35   saload         [aucun]    ref, idx -> val     Charger short du tableau}\par
\par
\par
\b 19.5 Instructions 36-4E : stockage dans variables locales \b0\par
\par
{\f1     Hex  Mnemonique     Operandes  Pile                Description}\par
{\f1     ---  -------------- ---------  ------------------  ---------------------------}\par
{\f1     36   istore         var        val ->              Stocker int}\par
{\f1     37   lstore         var        val ->              Stocker long}\par
{\f1     38   fstore         var        val ->              Stocker float}\par
{\f1     39   dstore         var        val ->              Stocker double}\par
{\f1     3A   astore         var        val ->              Stocker reference}\par
{\f1     3B   istore_0       [aucun]    val ->              Stocker int var 0}\par
{\f1     3C   istore_1       [aucun]    val ->              Stocker int var 1}\par
{\f1     3D   istore_2       [aucun]    val ->              Stocker int var 2}\par
{\f1     3E   istore_3       [aucun]    val ->              Stocker int var 3}\par
{\f1     3F   lstore_0       [aucun]    val ->              Stocker long var 0}\par
{\f1     40   lstore_1       [aucun]    val ->              Stocker long var 1}\par
{\f1     41   lstore_2       [aucun]    val ->              Stocker long var 2}\par
{\f1     42   lstore_3       [aucun]    val ->              Stocker long var 3}\par
{\f1     43   fstore_0       [aucun]    val ->              Stocker float var 0}\par
{\f1     44   fstore_1       [aucun]    val ->              Stocker float var 1}\par
{\f1     45   fstore_2       [aucun]    val ->              Stocker float var 2}\par
{\f1     46   fstore_3       [aucun]    val ->              Stocker float var 3}\par
{\f1     47   dstore_0       [aucun]    val ->              Stocker double var 0}\par
{\f1     48   dstore_1       [aucun]    val ->              Stocker double var 1}\par
{\f1     49   dstore_2       [aucun]    val ->              Stocker double var 2}\par
{\f1     4A   dstore_3       [aucun]    val ->              Stocker double var 3}\par
{\f1     4B   astore_0       [aucun]    val ->              Stocker reference var 0}\par
