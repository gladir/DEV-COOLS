{\footnote # IDH_JASMIN_14}
{\footnote $ Jasmin - Exemples complets}
{\footnote K Jasmin exemples complets;Hello World;factorielle;classe Java;methodes;constructeur}
\b\fs24 Exemples complets \b0\fs20\par
\par
\par
\b 14.1 Hello World \b0\par
\par
{\f1     ; HelloWorld.j - Affiche "Hello, World!" sur la console}\par
\par
{\f1     .class public HelloWorld}\par
{\f1     .super java/lang/Object}\par
\par
{\f1     .method public <init>()V}\par
{\f1         aload_0}\par
{\f1         invokespecial java/lang/Object/<init>()V}\par
{\f1         return}\par
{\f1     .end method}\par
\par
{\f1     .method public static main([Ljava/lang/String;)V}\par
{\f1         .limit stack 2}\par
{\f1         .limit locals 1}\par
\par
{\f1         getstatic java/lang/System/out Ljava/io/PrintStream;}\par
{\f1         ldc "Hello, World!"}\par
{\f1         invokevirtual java/io/PrintStream/println(Ljava/lang/String;)V}\par
\par
{\f1         return}\par
{\f1     .end method}\par
\par
\par
\b 14.2 Calcul arithmetique \b0\par
\par
{\f1     ; Calcule (3 + 5) * 2 et affiche le resultat}\par
\par
{\f1     .class public Calcul}\par
{\f1     .super java/lang/Object}\par
\par
{\f1     .method public <init>()V}\par
{\f1         aload_0}\par
{\f1         invokespecial java/lang/Object/<init>()V}\par
{\f1         return}\par
{\f1     .end method}\par
\par
{\f1     .method public static main([Ljava/lang/String;)V}\par
{\f1         .limit stack 3}\par
{\f1         .limit locals 2}\par
\par
{\f1         bipush 3              ; empiler 3}\par
{\f1         bipush 5              ; empiler 5}\par
{\f1         iadd                  ; 3 + 5 = 8}\par
{\f1         iconst_2              ; empiler 2}\par
{\f1         imul                  ; 8 * 2 = 16}\par
{\f1         istore 1              ; stocker dans variable locale 1}\par
\par
{\f1         ; Afficher le resultat}\par
{\f1         getstatic java/lang/System/out Ljava/io/PrintStream;}\par
{\f1         iload 1}\par
{\f1         invokevirtual java/io/PrintStream/println(I)V}\par
\par
{\f1         return}\par
{\f1     .end method}\par
\par
\par
\b 14.3 Boucle avec compteur \b0\par
\par
{\f1     ; Affiche les nombres de 1 a 10}\par
\par
{\f1     .class public Boucle}\par
{\f1     .super java/lang/Object}\par
\par
{\f1     .method public <init>()V}\par
{\f1         aload_0}\par
{\f1         invokespecial java/lang/Object/<init>()V}\par
{\f1         return}\par
{\f1     .end method}\par
\par
{\f1     .method public static main([Ljava/lang/String;)V}\par
{\f1         .limit stack 3}\par
{\f1         .limit locals 2}\par
\par
{\f1         iconst_1              ; i = 1}\par
{\f1         istore 1}\par
\par
{\f1     Debut:}\par
{\f1         iload 1               ; charger i}\par
{\f1         bipush 11             ; charger 11}\par
{\f1         if_icmpge Fin         ; si i >= 11, sortir}\par
\par
{\f1         ; Afficher i}\par
{\f1         getstatic java/lang/System/out Ljava/io/PrintStream;}\par
{\f1         iload 1}\par
{\f1         invokevirtual java/io/PrintStream/println(I)V}\par
\par
{\f1         iinc 1 1              ; i++}\par
{\f1         goto Debut}\par
\par
{\f1     Fin:}\par
{\f1         return}\par
{\f1     .end method}\par
\par
\par
\b 14.4 Condition if/else \b0\par
\par
{\f1     ; Verifie si un nombre est positif, negatif ou zero}\par
\par
{\f1     .class public Condition}\par
{\f1     .super java/lang/Object}\par
\par
{\f1     .method public <init>()V}\par
{\f1         aload_0}\par
{\f1         invokespecial java/lang/Object/<init>()V}\par
{\f1         return}\par
{\f1     .end method}\par
\par
{\f1     .method public static main([Ljava/lang/String;)V}\par
{\f1         .limit stack 3}\par
{\f1         .limit locals 2}\par
\par
{\f1         bipush 42             ; valeur a tester}\par
{\f1         istore 1}\par
\par
{\f1         iload 1}\par
{\f1         ifgt Positif          ; si > 0, aller a Positif}\par
{\f1         iload 1}\par
{\f1         iflt Negatif          ; si < 0, aller a Negatif}\par
\par
{\f1         ; Cas zero}\par
{\f1         getstatic java/lang/System/out Ljava/io/PrintStream;}\par
{\f1         ldc "Zero"}\par
{\f1         invokevirtual java/io/PrintStream/println(Ljava/lang/String;)V}\par
{\f1         goto Suite}\par
\par
{\f1     Positif:}\par
{\f1         getstatic java/lang/System/out Ljava/io/PrintStream;}\par
{\f1         ldc "Positif"}\par
{\f1         invokevirtual java/io/PrintStream/println(Ljava/lang/String;)V}\par
{\f1         goto Suite}\par
\par
{\f1     Negatif:}\par
{\f1         getstatic java/lang/System/out Ljava/io/PrintStream;}\par
{\f1         ldc "Negatif"}\par
{\f1         invokevirtual java/io/PrintStream/println(Ljava/lang/String;)V}\par
\par
{\f1     Suite:}\par
{\f1         return}\par
{\f1     .end method}\par
\par
\par
\b 14.5 Appel de methode statique \b0\par
\par
{\f1     ; Definit une methode factorielle et l appelle}\par
\par
{\f1     .class public Factorielle}\par
{\f1     .super java/lang/Object}\par
\par
{\f1     .method public <init>()V}\par
{\f1         aload_0}\par
{\f1         invokespecial java/lang/Object/<init>()V}\par
{\f1         return}\par
{\f1     .end method}\par
\par
{\f1     .method public static fact(I)I}\par
{\f1         .limit stack 4}\par
{\f1         .limit locals 2}\par
\par
{\f1         iload 0               ; charger n}\par
{\f1         iconst_1}\par
{\f1         if_icmple CasBase     ; si n <= 1, retourner 1}\par
\par
{\f1         iload 0               ; empiler n}\par
{\f1         iload 0               ; empiler n}\par
{\f1         iconst_1}\par
{\f1         isub                  ; n - 1}\par
{\f1         invokestatic Factorielle/fact(I)I  ; fact(n-1)}\par
{\f1         imul                  ; n * fact(n-1)}\par
{\f1         ireturn}\par
\par
{\f1     CasBase:}\par
{\f1         iconst_1}\par
{\f1         ireturn}\par
{\f1     .end method}\par
\par
{\f1     .method public static main([Ljava/lang/String;)V}\par
{\f1         .limit stack 3}\par
{\f1         .limit locals 1}\par
\par
{\f1         getstatic java/lang/System/out Ljava/io/PrintStream;}\par
{\f1         bipush 10}\par
{\f1         invokestatic Factorielle/fact(I)I}\par
{\f1         invokevirtual java/io/PrintStream/println(I)V}\par
\par
{\f1         return}\par
{\f1     .end method}\par
\par
\par
