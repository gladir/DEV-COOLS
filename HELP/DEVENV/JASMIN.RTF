{\footnote # IDH_JASMIN_13}
{\footnote $ Jasmin - Les opcodes de comparaison}
{\footnote K Jasmin opcodes comparaison;lcmp fcmpl fcmpg dcmpl dcmpg;if_icmplt if_icmpgt;if_icmple if_icmpge}
\b\fs24 Les opcodes de comparaison \b0\fs20\par
\par
{\f1   Ces instructions comparent des valeurs long, float ou double et}\par
{\f1   empilent un int (-1, 0, ou 1) representant le resultat :}\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     lcmp            94     Comparer deux long}\par
{\f1     fcmpl           95     Comparer deux float (NaN -> -1)}\par
{\f1     fcmpg           96     Comparer deux float (NaN -> 1)}\par
{\f1     dcmpl           97     Comparer deux double (NaN -> -1)}\par
{\f1     dcmpg           98     Comparer deux double (NaN -> 1)}\par
\par
{\f1   Resultat empile :}\par
{\f1     -1 si a < b}\par
{\f1      0 si a == b}\par
{\f1      1 si a > b}\par
\par
{\f1   Exemple : comparer deux long et brancher si egal :}\par
{\f1     lload 0               ; charger premier long}\par
{\f1     lload 2               ; charger second long}\par
{\f1     lcmp                  ; comparer -> -1, 0, ou 1}\par
{\f1     ifeq SontEgaux        ; brancher si resultat == 0}\par
\par
\par
