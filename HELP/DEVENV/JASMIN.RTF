{\footnote # IDH_JASMIN_05}
{\footnote $ Jasmin - Les descripteurs de types JVM}
{\footnote K Jasmin descripteurs types JVM;B C D F I J S Z V;L classname;tableau;signatures methodes}
\b\fs24 Les descripteurs de types JVM \b0\fs20\par
\par
{\f1   Les descripteurs de types sont des codes compacts utilises dans les}\par
{\f1   signatures de methodes et les declarations de champs. Chaque type}\par
{\f1   Java possede un descripteur :}\par
\par
\par
\b 5.1 Types primitifs \b0\par
\par
{\f1     Descripteur   Type Java     Description}\par
{\f1     -----------   ---------     --------------------------}\par
{\f1     B             byte          Entier signe 8 bits}\par
{\f1     C             char          Caractere Unicode 16 bits}\par
{\f1     D             double        Flottant 64 bits}\par
{\f1     F             float         Flottant 32 bits}\par
{\f1     I             int           Entier signe 32 bits}\par
{\f1     J             long          Entier signe 64 bits}\par
{\f1     S             short         Entier signe 16 bits}\par
{\f1     Z             boolean       Booleen (true/false)}\par
{\f1     V             void          Aucune valeur (retour)}\par
\par
\par
\b 5.2 Types references \b0\par
\par
{\f1     Les classes sont representees par L<nom>;}\par
\par
{\f1       Ljava/lang/String;        -> java.lang.String}\par
{\f1       Ljava/lang/Object;        -> java.lang.Object}\par
{\f1       Ljava/io/PrintStream;     -> java.io.PrintStream}\par
{\f1       Ljava/util/ArrayList;     -> java.util.ArrayList}\par
\par
{\f1     Les separateurs de paquets utilisent / au lieu de .}\par
\par
\par
\b 5.3 Types tableaux \b0\par
\par
{\f1     Les tableaux sont prefixes par [ pour chaque dimension :}\par
\par
{\f1       [I                        -> int[]}\par
{\f1       [D                        -> double[]}\par
{\f1       [Ljava/lang/String;       -> String[]}\par
{\f1       [[I                       -> int[][]}\par
{\f1       [[[B                      -> byte[][][]}\par
\par
\par
\b 5.4 Signatures de methodes \b0\par
\par
{\f1     Les signatures de methodes sont de la forme :}\par
{\f1       (types_parametres)type_retour}\par
\par
{\f1     Exemples :}\par
{\f1       ()V                       -> void methode()}\par
{\f1       (I)V                      -> void methode(int)}\par
{\f1       (II)I                     -> int methode(int, int)}\par
{\f1       (Ljava/lang/String;)V     -> void methode(String)}\par
{\f1       ([Ljava/lang/String;)V    -> void methode(String[])}\par
{\f1       (ILjava/lang/String;)Z    -> boolean methode(int, String)}\par
{\f1       (DDF)D                    -> double methode(double, double, float)}\par
{\f1       ()Ljava/lang/String;      -> String methode()}\par
\par
\par
