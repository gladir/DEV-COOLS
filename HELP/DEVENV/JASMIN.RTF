{\footnote # IDH_JASMIN_06}
{\footnote $ Jasmin - Les opcodes de chargement et stockage}
{\footnote K Jasmin opcodes chargement stockage;iload aload fload dload lload;istore astore fstore dstore lstore;iconst bipush sipush ldc;iaload iastore;getstatic putstatic getfield putfield}
\b\fs24 Les opcodes de chargement et stockage \b0\fs20\par
\par
{\f1   Ces instructions transferent des valeurs entre les variables locales}\par
{\f1   et la pile d operandes.}\par
\par
\par
\b 6.1 Chargement de constantes \b0\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     aconst_null     01     Empiler la reference null}\par
{\f1     iconst_m1       02     Empiler la constante int -1}\par
{\f1     iconst_0        03     Empiler la constante int 0}\par
{\f1     iconst_1        04     Empiler la constante int 1}\par
{\f1     iconst_2        05     Empiler la constante int 2}\par
{\f1     iconst_3        06     Empiler la constante int 3}\par
{\f1     iconst_4        07     Empiler la constante int 4}\par
{\f1     iconst_5        08     Empiler la constante int 5}\par
{\f1     lconst_0        09     Empiler la constante long 0}\par
{\f1     lconst_1        0A     Empiler la constante long 1}\par
{\f1     fconst_0        0B     Empiler la constante float 0.0}\par
{\f1     fconst_1        0C     Empiler la constante float 1.0}\par
{\f1     fconst_2        0D     Empiler la constante float 2.0}\par
{\f1     dconst_0        0E     Empiler la constante double 0.0}\par
{\f1     dconst_1        0F     Empiler la constante double 1.0}\par
{\f1     bipush <byte>   10     Empiler un byte signe (-128 a 127)}\par
{\f1     sipush <short>  11     Empiler un short signe (-32768 a 32767)}\par
{\f1     ldc <val>       12     Charger constante du pool (int, float, String)}\par
{\f1     ldc_w <val>     13     Charger constante (index large)}\par
{\f1     ldc2_w <val>    14     Charger constante large (long, double)}\par
\par
\par
\b 6.2 Chargement depuis les variables locales \b0\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     iload <var>     15     Charger int depuis variable locale <var>}\par
{\f1     lload <var>     16     Charger long depuis variable locale <var>}\par
{\f1     fload <var>     17     Charger float depuis variable locale <var>}\par
{\f1     dload <var>     18     Charger double depuis variable locale <var>}\par
{\f1     aload <var>     19     Charger reference depuis variable locale <var>}\par
\par
{\f1     Formes abregees (sans operande, variable implicite) :}\par
\par
{\f1     iload_0         1A     Charger int depuis variable locale 0}\par
{\f1     iload_1         1B     Charger int depuis variable locale 1}\par
{\f1     iload_2         1C     Charger int depuis variable locale 2}\par
{\f1     iload_3         1D     Charger int depuis variable locale 3}\par
{\f1     lload_0         1E     Charger long depuis variable locale 0}\par
{\f1     lload_1         1F     Charger long depuis variable locale 1}\par
{\f1     lload_2         20     Charger long depuis variable locale 2}\par
{\f1     lload_3         21     Charger long depuis variable locale 3}\par
{\f1     fload_0         22     Charger float depuis variable locale 0}\par
{\f1     fload_1         23     Charger float depuis variable locale 1}\par
{\f1     fload_2         24     Charger float depuis variable locale 2}\par
{\f1     fload_3         25     Charger float depuis variable locale 3}\par
{\f1     dload_0         26     Charger double depuis variable locale 0}\par
{\f1     dload_1         27     Charger double depuis variable locale 1}\par
{\f1     dload_2         28     Charger double depuis variable locale 2}\par
{\f1     dload_3         29     Charger double depuis variable locale 3}\par
{\f1     aload_0         2A     Charger reference depuis variable locale 0}\par
{\f1     aload_1         2B     Charger reference depuis variable locale 1}\par
{\f1     aload_2         2C     Charger reference depuis variable locale 2}\par
{\f1     aload_3         2D     Charger reference depuis variable locale 3}\par
\par
\par
\b 6.3 Stockage dans les variables locales \b0\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     istore <var>    36     Stocker int dans variable locale <var>}\par
{\f1     lstore <var>    37     Stocker long dans variable locale <var>}\par
{\f1     fstore <var>    38     Stocker float dans variable locale <var>}\par
{\f1     dstore <var>    39     Stocker double dans variable locale <var>}\par
{\f1     astore <var>    3A     Stocker reference dans variable locale <var>}\par
\par
{\f1     Formes abregees :}\par
\par
{\f1     istore_0        3B     Stocker int dans variable locale 0}\par
{\f1     istore_1        3C     Stocker int dans variable locale 1}\par
{\f1     istore_2        3D     Stocker int dans variable locale 2}\par
{\f1     istore_3        3E     Stocker int dans variable locale 3}\par
{\f1     lstore_0        3F     Stocker long dans variable locale 0}\par
{\f1     lstore_1        40     Stocker long dans variable locale 1}\par
{\f1     lstore_2        41     Stocker long dans variable locale 2}\par
{\f1     lstore_3        42     Stocker long dans variable locale 3}\par
{\f1     fstore_0        43     Stocker float dans variable locale 0}\par
{\f1     fstore_1        44     Stocker float dans variable locale 1}\par
{\f1     fstore_2        45     Stocker float dans variable locale 2}\par
{\f1     fstore_3        46     Stocker float dans variable locale 3}\par
{\f1     dstore_0        47     Stocker double dans variable locale 0}\par
{\f1     dstore_1        48     Stocker double dans variable locale 1}\par
{\f1     dstore_2        49     Stocker double dans variable locale 2}\par
{\f1     dstore_3        4A     Stocker double dans variable locale 3}\par
{\f1     astore_0        4B     Stocker reference dans variable locale 0}\par
{\f1     astore_1        4C     Stocker reference dans variable locale 1}\par
{\f1     astore_2        4D     Stocker reference dans variable locale 2}\par
{\f1     astore_3        4E     Stocker reference dans variable locale 3}\par
\par
\par
\b 6.4 Chargement depuis les tableaux \b0\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     iaload          2E     Charger int depuis tableau}\par
