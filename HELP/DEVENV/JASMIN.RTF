{\footnote # IDH_JASMIN_10}
{\footnote $ Jasmin - Les opcodes d invocation de methodes}
{\footnote K Jasmin opcodes invocation methodes;invokevirtual;invokestatic;invokespecial;invokeinterface;invokedynamic;return}
\b\fs24 Les opcodes d invocation de methodes \b0\fs20\par
\par
\par
\b 10.1 Types d invocation \b0\par
\par
{\f1     Opcode                     Hex    Description}\par
{\f1     -------------------------- ----   --------------------------------}\par
{\f1     invokevirtual <methode>    B6     Appeler methode d instance}\par
{\f1     invokespecial <methode>    B7     Appeler constructeur ou super}\par
{\f1     invokestatic <methode>     B8     Appeler methode statique}\par
{\f1     invokeinterface <meth> <n> B9     Appeler methode d interface}\par
{\f1     invokedynamic <meth>       BA     Appel dynamique (Java 7+)}\par
\par
\par
\b 10.2 Format des references de methodes \b0\par
\par
{\f1     Les methodes sont referencees par leur chemin complet :}\par
{\f1       classe/methode(descripteur)type_retour}\par
\par
{\f1     Exemples :}\par
\par
{\f1       ; Appeler System.out.println(String)}\par
{\f1       invokevirtual java/io/PrintStream/println(Ljava/lang/String;)V}\par
\par
{\f1       ; Appeler le constructeur de Object}\par
{\f1       invokespecial java/lang/Object/<init>()V}\par
\par
{\f1       ; Appeler Integer.parseInt(String)}\par
{\f1       invokestatic java/lang/Integer/parseInt(Ljava/lang/String;)I}\par
\par
{\f1       ; Appeler Math.max(int, int)}\par
{\f1       invokestatic java/lang/Math/max(II)I}\par
\par
\par
\b 10.3 Acces aux champs \b0\par
\par
{\f1     Opcode                  Hex    Description}\par
{\f1     ----------------------- ----   -----------------------------------}\par
{\f1     getstatic <champ>       B2     Lire champ statique}\par
{\f1     putstatic <champ>       B3     Ecrire champ statique}\par
{\f1     getfield <champ>        B4     Lire champ d instance}\par
{\f1     putfield <champ>        B5     Ecrire champ d instance}\par
\par
{\f1     Exemples :}\par
\par
{\f1       ; Charger System.out (un PrintStream)}\par
{\f1       getstatic java/lang/System/out Ljava/io/PrintStream;}\par
\par
{\f1       ; Lire un champ d instance}\par
{\f1       getfield MaClasse/compteur I}\par
\par
\par
