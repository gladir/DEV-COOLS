{\footnote # IDH_JASMIN_12}
{\footnote $ Jasmin - Les opcodes de creation d objets et tableaux}
{\footnote K Jasmin opcodes creation objets tableaux;new;newarray anewarray multianewarray;arraylength;instanceof checkcast;monitorenter monitorexit;athrow}
\b\fs24 Les opcodes de creation d objets et tableaux \b0\fs20\par
\par
\par
\b 12.1 Creation d objets \b0\par
\par
{\f1     Opcode                  Hex    Description}\par
{\f1     ----------------------- ----   -----------------------------------}\par
{\f1     new <classe>            BB     Creer un nouvel objet (non initialise)}\par
{\f1     instanceof <classe>     C1     Verifier le type d un objet}\par
