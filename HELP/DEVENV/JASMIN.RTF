{\footnote # IDH_JASMIN_09}
{\footnote $ Jasmin - Les opcodes de controle de flux}
{\footnote K Jasmin opcodes controle flux;ifeq ifne iflt ifge ifgt ifle;if_icmpeq if_icmpne;if_acmpeq if_acmpnull;goto;tableswitch lookupswitch;ireturn areturn return}
\b\fs24 Les opcodes de controle de flux \b0\fs20\par
\par
\par
\b 9.1 Branchements inconditionnels \b0\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     goto <label>    A7     Branchement inconditionnel vers <label>}\par
{\f1     goto_w <label>  C8     Branchement inconditionnel (offset large)}\par
{\f1     jsr <label>     A8     Saut vers sous-routine, empile adresse retour}\par
{\f1     jsr_w <label>   C9     Saut vers sous-routine (offset large)}\par
{\f1     ret <var>       A9     Retour de sous-routine (adresse dans <var>)}\par
\par
\par
\b 9.2 Branchements conditionnels sur un int \b0\par
\par
{\f1     Ces instructions depilent un int et branchent selon sa valeur :}\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     ifeq <label>    99     Brancher si valeur == 0}\par
{\f1     ifne <label>    9A     Brancher si valeur != 0}\par
{\f1     iflt <label>    9B     Brancher si valeur < 0}\par
{\f1     ifge <label>    9C     Brancher si valeur >= 0}\par
{\f1     ifgt <label>    9D     Brancher si valeur > 0}\par
{\f1     ifle <label>    9E     Brancher si valeur <= 0}\par
\par
\par
\b 9.3 Branchements conditionnels sur deux int \b0\par
\par
{\f1     Ces instructions depilent deux int et comparent :}\par
\par
{\f1     Opcode            Hex    Description}\par
{\f1     ----------------- ----   ------------------------------------------}\par
{\f1     if_icmpeq <label> 9F     Brancher si a == b}\par
{\f1     if_icmpne <label> A0     Brancher si a != b}\par
{\f1     if_icmplt <label> A1     Brancher si a < b}\par
{\f1     if_icmpge <label> A2     Brancher si a >= b}\par
{\f1     if_icmpgt <label> A3     Brancher si a > b}\par
{\f1     if_icmple <label> A4     Brancher si a <= b}\par
\par
\par
\b 9.4 Branchements conditionnels sur les references \b0\par
\par
{\f1     Opcode            Hex    Description}\par
{\f1     ----------------- ----   ------------------------------------------}\par
{\f1     ifnull <label>    C6     Brancher si reference == null}\par
{\f1     ifnonnull <label> C7     Brancher si reference != null}\par
{\f1     if_acmpeq <label> A5     Brancher si ref_a == ref_b}\par
{\f1     if_acmpne <label> A6     Brancher si ref_a != ref_b}\par
\par
\par
\b 9.5 Instructions de choix multiple (switch) \b0\par
\par
{\f1     Opcode                  Hex    Description}\par
{\f1     ----------------------- ----   -----------------------------------}\par
{\f1     tableswitch             AA     Switch avec index contigus}\par
{\f1     lookupswitch            AB     Switch avec valeurs dispersees}\par
\par
{\f1     Exemple de tableswitch :}\par
{\f1       tableswitch 0 2        ; valeurs de 0 a 2}\par
{\f1           Label0             ; case 0}\par
{\f1           Label1             ; case 1}\par
{\f1           Label2             ; case 2}\par
{\f1           Default            ; default}\par
\par
{\f1     Exemple de lookupswitch :}\par
{\f1       lookupswitch}\par
{\f1           1 : Label1         ; case 1}\par
{\f1           5 : Label5         ; case 5}\par
{\f1           100 : Label100     ; case 100}\par
{\f1           default : Default  ; default}\par
\par
\par
\b 9.6 Retour de methode \b0\par
\par
{\f1     Opcode          Hex    Description}\par
{\f1     --------------- ----   ------------------------------------------}\par
{\f1     ireturn         AC     Retourner un int}\par
{\f1     lreturn         AD     Retourner un long}\par
{\f1     freturn         AE     Retourner un float}\par
{\f1     dreturn         AF     Retourner un double}\par
{\f1     areturn         B0     Retourner une reference}\par
{\f1     return          B1     Retourner void (aucune valeur)}\par
\par
\par
