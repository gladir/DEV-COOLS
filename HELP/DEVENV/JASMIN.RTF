{\footnote # IDH_JASMIN_04}
{\footnote $ Jasmin - Les directives Jasmin}
{\footnote K Jasmin directives;.class .super .implements;.field;.method .end method;.limit stack;.limit locals;.var;.line;.throws;.catch;.source}
\b\fs24 Les directives Jasmin \b0\fs20\par
\par
\par
\b 4.1 Directives de classe \b0\par
\par
{\f1   .class <acces> <nom>}\par
{\f1       Declare le nom de la classe et ses modificateurs d acces.}\par
{\f1       Exemples :}\par
{\f1         .class public Main}\par
{\f1         .class public final MaClasse}\par
{\f1         .class abstract MaClasseAbstraite}\par
\par
{\f1       Modificateurs d acces :}\par
{\f1         public       - accessible depuis n importe ou}\par
{\f1         final        - ne peut pas etre etendue (heritee)}\par
{\f1         abstract     - ne peut pas etre instanciee directement}\par
{\f1         interface    - declare une interface}\par
\par
{\f1   .super <nom>}\par
{\f1       Specifie la classe parente (superclasse).}\par
{\f1       Toute classe doit avoir une superclasse (sauf java/lang/Object).}\par
{\f1       Exemple :}\par
{\f1         .super java/lang/Object}\par
\par
{\f1   .implements <interface>}\par
{\f1       Declare qu une classe implemente une interface.}\par
{\f1       Exemple :}\par
{\f1         .implements java/io/Serializable}\par
\par
{\f1   .source <fichier>}\par
{\f1       Indique le fichier source d origine (optionnel, pour le debogage).}\par
{\f1       Exemple :}\par
{\f1         .source Main.java}\par
\par
\par
\b 4.2 Directives de champs (variables d instance / de classe) \b0\par
\par
{\f1   .field <acces> <nom> <descripteur> [= <valeur>]}\par
{\f1       Declare un champ (variable membre) de la classe.}\par
{\f1       Exemples :}\par
{\f1         .field public compteur I}\par
{\f1         .field private static PI D = 3.14159}\par
{\f1         .field protected nom Ljava/lang/String;}\par
\par
{\f1       Modificateurs d acces pour les champs :}\par
{\f1         public       - accessible depuis n importe ou}\par
{\f1         private      - accessible uniquement dans la classe}\par
{\f1         protected    - accessible dans la classe et ses sous-classes}\par
{\f1         static       - champ de classe (partage entre toutes les instances)}\par
{\f1         final        - valeur constante, ne peut pas etre modifiee}\par
{\f1         volatile     - acces atomique en environnement multi-thread}\par
\par
\par
\b 4.3 Directives de methodes \b0\par
\par
{\f1   .method <acces> <nom><descripteur>}\par
{\f1       Debut de la definition d une methode.}\par
{\f1       Exemples :}\par
{\f1         .method public static main([Ljava/lang/String;)V}\par
{\f1         .method public getValeur()I}\par
{\f1         .method private calculer(II)I}\par
\par
{\f1       Modificateurs d acces pour les methodes :}\par
{\f1         public       - accessible depuis n importe ou}\par
{\f1         private      - accessible uniquement dans la classe}\par
{\f1         protected    - accessible dans la classe et ses sous-classes}\par
{\f1         static       - methode de classe (pas besoin d instance)}\par
{\f1         final        - ne peut pas etre redefinie}\par
{\f1         abstract     - pas de corps, doit etre implementee}\par
{\f1         synchronized - acces synchronise en multi-thread}\par
{\f1         native       - implementee en code natif (JNI)}\par
\par
{\f1   .end method}\par
{\f1       Fin de la definition d une methode.}\par
\par
{\f1   .limit stack <N>}\par
{\f1       Declare la profondeur maximale de la pile d operandes pour cette}\par
{\f1       methode. La JVM verifie que cette limite n est jamais depassee.}\par
{\f1       Exemple :}\par
{\f1         .limit stack 100}\par
\par
{\f1   .limit locals <N>}\par
{\f1       Declare le nombre maximal de variables locales utilisees par la}\par
{\f1       methode. Inclut les parametres et la reference "this" pour les}\par
{\f1       methodes d instance.}\par
{\f1       Exemple :}\par
{\f1         .limit locals 100}\par
\par
{\f1   .line <N>}\par
{\f1       Associe un numero de ligne du source aux instructions suivantes.}\par
{\f1       Utilise par le debogueur pour localiser l instruction courante.}\par
{\f1       Exemple :}\par
{\f1         .line 42}\par
\par
{\f1   .throws <classe>}\par
{\f1       Declare qu une methode peut lancer une exception.}\par
{\f1       Exemple :}\par
{\f1         .throws java/io/IOException}\par
\par
{\f1   .catch <classe> from <debut> to <fin> using <gestionnaire>}\par
{\f1       Declare un bloc try-catch pour la gestion des exceptions.}\par
{\f1       Exemple :}\par
{\f1         .catch java/lang/Exception from Label1 to Label2 using Handler}\par
\par
\par
