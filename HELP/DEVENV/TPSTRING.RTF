{\footnote # IDH_TPSTR_07}
{\footnote $ Type String - EXEMPLES COMPARATIFS}
{\footnote K Turbo Pascal;Type String;EXEMPLES COMPARATIFS}
\b\fs24 EXEMPLES COMPARATIFS \b0\fs20\par
\par
\par
\b 7.1 Exemple String \b0\par
\par
{\f1   Program TestString;}\par
{\f1   Var S : String;}\par
{\f1   Begin}\par
{\f1     S := 'TEST';}\par
{\f1     WriteLn('Length = ', Length(S));     \{ 4 \}}\par
{\f1     WriteLn('S[0] = ', Ord(S[0]));      \{ 4 = longueur \}}\par
{\f1     WriteLn('S[1] = ', S[1]);           \{ 'T' = premier caractere \}}\par
{\f1     WriteLn('Copy = ', Copy(S, 2, 2));  \{ 'ES' \}}\par
{\f1     WriteLn('Pos = ', Pos('ST', S));    \{ 3 \}}\par
{\f1     Delete(S, 1, 2);                    \{ S = 'ST' \}}\par
{\f1     Insert('BE', S, 1);                 \{ S = 'BEST' \}}\par
{\f1   End.}\par
\par
\par
\b 7.2 Exemple PChar \b0\par
\par
{\f1   Program TestPChar;}\par
{\f1   Uses Strings;}\par
{\f1   Var}\par
{\f1     P : PChar;}\par
{\f1     Buf : Array[0..255] Of Char;}\par
{\f1   Begin}\par
{\f1     P := 'TEST';}\par
{\f1     WriteLn('StrLen = ', StrLen(P));    \{ 4 \}}\par
{\f1     WriteLn('P[0] = ', Ord(P[0]));     \{ 84 = Ord('T') = premier char \}}\par
{\f1     WriteLn('P[1] = ', P[1]);          \{ 'E' = deuxieme caractere \}}\par
{\f1     StrCopy(Buf, P);                   \{ Buf = 'TEST'#0 \}}\par
{\f1     StrCat(Buf, '!');                  \{ Buf = 'TEST!'#0 \}}\par
{\f1     WriteLn(StrComp(P, 'TEST'));       \{ 0 = egal \}}\par
{\f1   End.}\par
\par
\par
\b 7.3 Sortie attendue du programme test_length.pas \b0\par
\par
{\f1   Program TestLength;}\par
{\f1   Uses Strings;}\par
{\f1   Var}\par
{\f1     S : String;}\par
{\f1     P : PChar;}\par
{\f1   BEGIN}\par
{\f1     S := 'TEST';}\par
{\f1     P := 'TEST';}\par
{\f1     WriteLn('Length(''TEST'')=S[0], S[0]=4:');}\par
{\f1     WriteLn('Length(''TEST'')=', Length(S));   \{ 4 \}}\par
{\f1     WriteLn('S[0]=', Ord(S[0]));              \{ 4 = LONGUEUR \}}\par
{\f1     WriteLn;}\par
{\f1     WriteLn('StrLen(''TEST'')=4, P[0]=84');}\par
{\f1     WriteLn('StrLen(''TEST'')=', StrLen(P));  \{ 4 \}}\par
{\f1     WriteLn('P[0]=', Ord(P[0]));              \{ 84 = Ord('T') \}}\par
{\f1   END.}\par
\par
{\f1   Sortie :}\par
{\f1     Length('TEST')=S[0], S[0]=4:}\par
{\f1     Length('TEST')=4}\par
{\f1     S[0]=4}\par
\par
{\f1     StrLen('TEST')=4, P[0]=84}\par
{\f1     StrLen('TEST')=4}\par
{\f1     P[0]=84}\par
\par
\par
