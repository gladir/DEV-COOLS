{\footnote # IDH_TPSTR_08}
{\footnote $ Type String - REGLES POUR LE COMPILATEUR TPCW32}
{\footnote K Turbo Pascal;Type String;REGLES POUR LE COMPILATEUR TPCW32}
\b\fs24 REGLES POUR LE COMPILATEUR TPCW32 \b0\fs20\par
\par
\par
\b 8.1 Stockage des constantes String en memoire \b0\par
\par
{\f1   Une constante String 'TEST' doit etre emise comme :}\par
{\f1     _TPK_1  DB 4,'TEST',0       ; 4 = longueur, 0 = NUL (optionnel)}\par
\par
{\f1   Une constante PChar 'TEST' doit etre emise comme :}\par
{\f1     _TPK_2  DB 'TEST',0         ; pas de longueur, juste ASCIIZ}\par
\par
\par
\b 8.2 Affectation S := 'chaine' \b0\par
\par
{\f1   STRCPY pour String : copie S[0] (longueur) + S[1..N] (contenu)}\par
{\f1     - Source : pointe sur l'octet de longueur}\par
{\f1     - Destination : pointe sur l'octet de longueur de la variable}\par
{\f1     - Copie Ord(Source[0]) + 1 octets minimum}\par
\par
{\f1   Pour PChar : copie jusqu'au NUL terminal (lstrcpyA ou boucle ASCIIZ)}\par
\par
\par
\b 8.3 Length(S) vs StrLen(P) \b0\par
\par
{\f1   Length(S) pour String :}\par
{\f1     MOVZX EAX, BYTE PTR [ESI]    ; lire S[0] = longueur}\par
{\f1     ; EAX = longueur, c'est tout}\par
\par
{\f1   StrLen(P) pour PChar :}\par
{\f1     PUSH EAX}\par
{\f1     CALL lstrlenA                 ; appel API Windows}\par
{\f1     ; ou boucle manuelle jusqu'au NUL}\par
\par
\par
\b 8.4 Acces par index S[N] vs P[N] \b0\par
\par
{\f1   S[0] sur String = longueur :}\par
{\f1     LEA EAX,[S]          ; adresse de base = S[0]}\par
{\f1     MOVZX EAX,BYTE PTR [EAX]   ; lire l'octet de longueur}\par
\par
{\f1   S[1] sur String = premier caractere :}\par
{\f1     LEA EAX,[S]}\par
{\f1     MOVZX EAX,BYTE PTR [EAX+1]}\par
\par
{\f1   P[0] sur PChar = premier caractere :}\par
{\f1     MOV EAX,[P]          ; charger le pointeur}\par
{\f1     MOVZX EAX,BYTE PTR [EAX]   ; lire premier char}\par
\par
\par
\b 8.5 WriteLn et PRINTSTR \b0\par
\par
{\f1   Pour afficher une String :}\par
{\f1     - ESI pointe sur S[0]}\par
{\f1     - Lire longueur = MOVZX ECX, BYTE PTR [ESI]}\par
{\f1     - Buffer a afficher = ESI + 1}\par
{\f1     - WriteFile(hStdout, ESI+1, ECX, ...)}\par
\par
{\f1   Pour afficher un PChar (PRINTSTR_AZ) :}\par
{\f1     - ESI pointe sur le premier caractere}\par
{\f1     - Calculer longueur en bouclant jusqu'au NUL}\par
{\f1     - WriteFile(hStdout, ESI, longueur, ...)}\par
\par
{\f1   Pour les buffers internes (NUMBUF, CRLF, TRUE_STR, FALSE_STR) :}\par
{\f1     - Ces buffers sont ASCIIZ (pas de longueur prefixee)}\par
{\f1     - Utiliser PRINTSTR_AZ (version ASCIIZ) pour les afficher}\par
\par
\par
\b 8.6 Routines runtime a distinguer \b0\par
\par
{\f1   _TPRT_PRINTSTR     : afficher String Pascal (ESI = ptr, S[0]=len)}\par
{\f1   _TPRT_PRINTSTR_AZ  : afficher PChar ASCIIZ (ESI = ptr, termine NUL)}\par
{\f1   _TPRT_STRASSIGN    : copier String Pascal pour affectation S := expr}\par
{\f1                         (ESI = source, EDI = destination)}\par
{\f1   _TPRT_STRCPY       : StrCopy PChar ASCIIZ (ESI=src, EDI=dest) -> EAX}\par
{\f1                         = fonction StrCopy() de l'unite Strings}\par
{\f1   _TPRT_LENGTH       : longueur String Pascal (lire S[0]) -> EAX}\par
{\f1                         = fonction Length() de System}\par
{\f1   _TPRT_STRLEN       : longueur PChar ASCIIZ (boucle NUL) -> EAX}\par
{\f1                         = fonction StrLen() de l'unite Strings}\par
{\f1   _TPRT_CONCAT       : concatener deux String Pascal}\par
{\f1   _TPRT_STRCOMPARE   : comparer deux String Pascal (operateurs =, <>, <, >, <=, >=)}\par
{\f1                         = comparaison String de System}\par
{\f1   _TPRT_STRCMP        : comparer deux PChar ASCIIZ (registres ESI/EDI)}\par
{\f1                         = fonction StrComp() de l'unite Strings}\par
{\f1   _TPRT_COPY         : sous-chaine String Pascal -> STRBUF1}\par
{\f1                         = fonction Copy() de System}\par
{\f1   _TPRT_POS          : position sous-chaine dans String Pascal}\par
{\f1                         = fonction Pos() de System}\par
{\f1   _TPRT_DELETE        : supprimer dans String Pascal (modifie S[0])}\par
{\f1   _TPRT_INSERT        : inserer dans String Pascal (modifie S[0])}\par
\par
{\f1   Pour PChar : utiliser les API Windows (lstrlenA, lstrcpyA, etc.)}\par
{\f1   ou les wrappers de l'unite Strings.}\par
\par
