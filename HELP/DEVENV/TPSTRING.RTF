{\footnote # IDH_TPSTR_02}
{\footnote $ Type String - RESUME DES DIFFERENCES}
{\footnote K Turbo Pascal;Type String;RESUME DES DIFFERENCES}
\b\fs24 RESUME DES DIFFERENCES \b0\fs20\par
\par
{\f1   Propriete          | String              | PChar}\par
{\f1   -------------------+---------------------+---------------------}\par
{\f1   Type               | ShortString         | ^Char (pointeur)}\par
{\f1   Longueur max       | 255 caracteres      | Illimitee (memoire)}\par
{\f1   Stockage longueur  | S[0] (1 octet)      | Aucun (NUL termine)}\par
{\f1   Premier caractere  | S[1]                | P[0] ou P^}\par
{\f1   Acces S[0]/P[0]    | Longueur            | Premier caractere}\par
{\f1   Terminaison        | Pas de NUL requis   | NUL obligatoire}\par
{\f1   Taille memoire     | Ord(S[0]) + 1       | StrLen(P) + 1}\par
{\f1   Unite requise      | Aucune (System)     | Strings (unite)}\par
{\f1   Passage par valeur | Copie complete      | Copie du pointeur}\par
{\f1   Indexation base    | 1 (S[1] = 1er char) | 0 (P[0] = 1er char)}\par
\par
\par
