{\footnote # IDH_TPSTR_05}
{\footnote $ Type String - FONCTIONS DE CONVERSION String <-> PChar}
{\footnote K Turbo Pascal;Type String;FONCTIONS DE CONVERSION String <-> PChar}
\b\fs24 FONCTIONS DE CONVERSION String <-> PChar \b0\fs20\par
\par
{\f1   PChar -> String :   S := StrPas(P);          \{ Unite Strings \}}\par
{\f1   String -> PChar :   StrPCopy(P, S);          \{ Unite Strings \}}\par
{\f1   String -> PChar :   P := @S[1];              \{ Astuce, pas officiel \}}\par
\par
\par
