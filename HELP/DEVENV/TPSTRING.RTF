{\footnote # IDH_TPSTR_04}
{\footnote $ Type String - FONCTIONS PCHAR (Unite Strings - doit etre declaree dans Uses)}
{\footnote K Turbo Pascal;Type String;FONCTIONS PCHAR (Unite Strings - doit etre declaree dans Uses)}
\b\fs24 FONCTIONS PCHAR (Unite Strings - doit etre declaree dans Uses) \b0\fs20\par
\par
{\f1   Ces fonctions operent sur le type PCHAR (chaines C, ASCIIZ, terminees}\par
{\f1   par NUL). Elles sont dans l'unite STRINGS et doivent etre importees :}\par
\par
{\f1     Uses Strings;}\par
\par
{\f1   ATTENTION : Les noms commencent par "Str" (convention C).}\par
{\f1   NE PAS confondre avec les fonctions String de l'unite System.}\par
\par
\par
\b 4.1 Fonctions de mesure et recherche \b0\par
\par
{\f1   Function StrLen(S : PChar) : Word;}\par
{\f1     - Retourne la longueur de la chaine (nombre de chars avant NUL)}\par
{\f1     - Equivalent C : strlen()}\par
{\f1     - Exemple : StrLen('TEST') = 4}\par
\par
{\f1   Function StrPos(S1 : PChar; S2 : PChar) : PChar;}\par
{\f1     - Cherche S2 dans S1, retourne pointeur ou NIL}\par
{\f1     - Equivalent C : strstr()}\par
{\f1     - Exemple : StrPos(P, 'CD') -> pointeur vers 'CD...'}\par
\par
{\f1   Function StrScan(S : PChar; C : Char) : PChar;}\par
{\f1     - Cherche le caractere C dans S, retourne pointeur ou NIL}\par
{\f1     - Equivalent C : strchr()}\par
{\f1     - Exemple : StrScan(P, 'C') -> pointeur vers 'C...'}\par
\par
{\f1   Function StrRScan(S : PChar; C : Char) : PChar;}\par
{\f1     - Cherche la derniere occurrence de C dans S}\par
{\f1     - Equivalent C : strrchr()}\par
\par
{\f1   Function StrEnd(S : PChar) : PChar;}\par
{\f1     - Retourne pointeur vers le NUL terminal}\par
{\f1     - Exemple : StrEnd(P) pointe sur le #0 final}\par
\par
\par
\b 4.2 Fonctions de copie \b0\par
\par
{\f1   Function StrCopy(Dest : PChar; Source : PChar) : PChar;}\par
{\f1     - Copie Source vers Dest, retourne Dest}\par
{\f1     - Equivalent C : strcpy()}\par
{\f1     - ATTENTION : pas de verification de debordement !}\par
\par
{\f1   Function StrLCopy(Dest : PChar; Source : PChar; MaxLen : Word) : PChar;}\par
{\f1     - Copie au maximum MaxLen caracteres de Source vers Dest}\par
{\f1     - Equivalent C : strncpy()}\par
\par
{\f1   Function StrMove(Dest : PChar; Source : PChar; Count : Word) : PChar;}\par
{\f1     - Copie exactement Count octets (peut inclure des NUL)}\par
{\f1     - Equivalent C : memmove()}\par
\par
{\f1   Function StrECopy(Dest : PChar; Source : PChar) : PChar;}\par
{\f1     - Copie et retourne pointeur vers le NUL de fin dans Dest}\par
{\f1     - (Utile pour concatenation rapide)}\par
\par
{\f1   Function StrPCopy(Dest : PChar; Source : String) : PChar;}\par
{\f1     - Copie une String Pascal vers un buffer PChar}\par
{\f1     - CONVERSION String -> PChar}\par
{\f1     - Exemple : StrPCopy(P, S);}\par
\par
{\f1   Function StrPas(S : PChar) : String;}\par
{\f1     - Convertit un PChar en String Pascal}\par
{\f1     - CONVERSION PChar -> String}\par
{\f1     - Exemple : S := StrPas(P);}\par
\par
\par
\b 4.3 Fonctions de concatenation \b0\par
\par
{\f1   Function StrCat(Dest : PChar; Source : PChar) : PChar;}\par
{\f1     - Ajoute Source a la fin de Dest, retourne Dest}\par
{\f1     - Equivalent C : strcat()}\par
\par
{\f1   Function StrLCat(Dest : PChar; Source : PChar; MaxLen : Word) : PChar;}\par
{\f1     - Concatenation limitee a MaxLen caracteres total}\par
{\f1     - Equivalent C : strncat() (avec semantique differente)}\par
\par
\par
\b 4.4 Fonctions de comparaison \b0\par
\par
{\f1   Function StrComp(S1 : PChar; S2 : PChar) : Integer;}\par
{\f1     - Compare S1 et S2 (sensible a la casse)}\par
{\f1     - Retourne <0, 0, >0 (comme strcmp en C)}\par
{\f1     - Equivalent C : strcmp()}\par
\par
{\f1   Function StrIComp(S1 : PChar; S2 : PChar) : Integer;}\par
{\f1     - Compare sans tenir compte de la casse}\par
{\f1     - Equivalent C : stricmp() / strcasecmp()}\par
\par
{\f1   Function StrLComp(S1 : PChar; S2 : PChar; MaxLen : Word) : Integer;}\par
{\f1     - Compare au maximum MaxLen caracteres}\par
{\f1     - Equivalent C : strncmp()}\par
\par
{\f1   Function StrLIComp(S1 : PChar; S2 : PChar; MaxLen : Word) : Integer;}\par
{\f1     - Compare MaxLen caracteres sans casse}\par
{\f1     - Equivalent C : strnicmp()}\par
\par
\par
\b 4.5 Fonctions de transformation \b0\par
\par
{\f1   Function StrUpper(S : PChar) : PChar;}\par
{\f1     - Convertit en majuscules (modifie en place), retourne S}\par
{\f1     - Equivalent C : strupr()}\par
\par
{\f1   Function StrLower(S : PChar) : PChar;}\par
{\f1     - Convertit en minuscules (modifie en place), retourne S}\par
{\f1     - Equivalent C : strlwr()}\par
\par
\par
\b 4.6 Fonctions d'allocation \b0\par
\par
{\f1   Function StrNew(S : PChar) : PChar;}\par
{\f1     - Alloue une copie de S sur le heap, retourne le pointeur}\par
{\f1     - Equivalent C : strdup()}\par
\par
{\f1   Procedure StrDispose(S : PChar);}\par
{\f1     - Libere une chaine allouee par StrNew}\par
{\f1     - Equivalent C : free()}\par
\par
\par
