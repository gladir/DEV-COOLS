{\footnote # IDH_TPSTR_06}
{\footnote $ Type String - TABLE RECAPITULATIVE - NE PAS MELANGER}
{\footnote K Turbo Pascal;Type String;TABLE RECAPITULATIVE - NE PAS MELANGER}
\b\fs24 TABLE RECAPITULATIVE - NE PAS MELANGER \b0\fs20\par
\par
{\f1   OPERATION         | STRING (System)      | PCHAR (Strings)}\par
{\f1   ------------------+----------------------+----------------------}\par
{\f1   Longueur          | Length(S)            | StrLen(P)}\par
{\f1   Copie             | Copy(S,Pos,Len)      | StrCopy(D,S)}\par
{\f1   Copie limitee     | (n/a)                | StrLCopy(D,S,Max)}\par
{\f1   Position          | Pos(Sub,S)           | StrPos(S,Sub)}\par
{\f1   Concatenation     | Concat(S1,S2) ou +   | StrCat(D,S)}\par
{\f1   Concat limitee    | (n/a)                | StrLCat(D,S,Max)}\par
{\f1   Comparaison       | S1 = S2  (operateur) | StrComp(S1,S2)}\par
{\f1   Comp sans casse   | (n/a)                | StrIComp(S1,S2)}\par
{\f1   Suppression       | Delete(S,Pos,Len)    | (n/a, faire a la main)}\par
{\f1   Insertion         | Insert(Src,Dst,Pos)  | (n/a, faire a la main)}\par
{\f1   Num -> Chaine     | Str(N, S)            | (n/a)}\par
{\f1   Chaine -> Num     | Val(S, N, Err)       | (n/a)}\par
{\f1   Majuscule char    | Upcase(C)            | StrUpper(P)}\par
{\f1   Minuscule         | (n/a)                | StrLower(P)}\par
{\f1   Premier char      | S[1]                 | P[0] ou P^}\par
{\f1   Longueur byte     | S[0] = Ord->longueur | (n/a, pas de S[0])}\par
{\f1   Allocation heap   | (n/a)                | StrNew(P)}\par
{\f1   Liberation heap   | (n/a)                | StrDispose(P)}\par
{\f1   Conv Str->PChar   | (n/a)                | StrPCopy(P, S)}\par
{\f1   Conv PChar->Str   | (n/a)                | StrPas(P)}\par
{\f1   Fin de chaine     | (n/a)                | StrEnd(P)}\par
{\f1   Chercher char     | (n/a)                | StrScan(P, C)}\par
{\f1   Chercher dernier  | (n/a)                | StrRScan(P, C)}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPSTR_05}     {\uldb Suivant >>}{\v IDH_TPSTR_07}     {\uldb Sommaire}{\v IDH_TPSTR_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
