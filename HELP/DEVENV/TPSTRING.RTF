{\footnote # IDH_TPSTR_03}
{\footnote $ Type String - FONCTIONS STRING (Unite System - toujours disponibles)}
{\footnote K Turbo Pascal;Type String;FONCTIONS STRING (Unite System - toujours disponibles)}
\b\fs24 FONCTIONS STRING (Unite System - toujours disponibles) \b0\fs20\par
\par
{\f1   Ces fonctions operent sur le type STRING (Pascal String avec S[0]=longueur).}\par
{\f1   Elles font partie de l'unite System et sont toujours disponibles.}\par
\par
\par
\b 3.1 Fonctions retournant une valeur \b0\par
\par
{\f1   Function Length(S : String) : Integer;}\par
{\f1     - Retourne la longueur de S (equivalent a Ord(S[0]))}\par
{\f1     - Exemple : Length('TEST') = 4}\par
\par
{\f1   Function Copy(S : String; Pos : Integer; Len : Integer) : String;}\par
{\f1     - Retourne une sous-chaine de S}\par
{\f1     - Pos : position de depart (1-based)}\par
{\f1     - Len : nombre de caracteres a copier}\par
{\f1     - Exemple : Copy('ABCDEF', 2, 3) = 'BCD'}\par
\par
{\f1   Function Pos(SubStr : String; S : String) : Integer;}\par
{\f1     - Retourne la position de SubStr dans S (1-based), 0 si non trouve}\par
{\f1     - Exemple : Pos('CD', 'ABCDEF') = 3}\par
\par
{\f1   Function Concat(S1 : String; S2 : String; ...) : String;}\par
{\f1     - Concatene plusieurs chaines (equivalent a S1 + S2 + ...)}\par
{\f1     - Exemple : Concat('AB', 'CD', 'EF') = 'ABCDEF'}\par
\par
{\f1   Function Chr(X : Byte) : Char;}\par
{\f1     - Retourne le caractere correspondant au code ASCII X}\par
{\f1     - Exemple : Chr(65) = 'A'}\par
\par
{\f1   Function Ord(C : Char) : Integer;}\par
{\f1     - Retourne le code ASCII du caractere C}\par
{\f1     - Exemple : Ord('A') = 65}\par
{\f1     - Exemple : Ord(S[0]) = longueur de la chaine S}\par
\par
{\f1   Function Upcase(C : Char) : Char;}\par
{\f1     - Retourne le caractere en majuscule}\par
{\f1     - Exemple : Upcase('a') = 'A'}\par
\par
\par
\b 3.2 Procedures modifiant une chaine \b0\par
\par
{\f1   Procedure Delete(Var S : String; Pos : Integer; Len : Integer);}\par
{\f1     - Supprime Len caracteres de S a partir de Pos}\par
{\f1     - Modifie S directement (passage par reference)}\par
{\f1     - Exemple : S := 'ABCDEF'; Delete(S, 2, 3); \{ S = 'AEF' \}}\par
\par
{\f1   Procedure Insert(Source : String; Var Dest : String; Pos : Integer);}\par
{\f1     - Insere Source dans Dest a la position Pos}\par
{\f1     - Modifie Dest directement (passage par reference)}\par
{\f1     - Exemple : S := 'AEF'; Insert('BCD', S, 2); \{ S = 'ABCDEF' \}}\par
\par
{\f1   Procedure Str(X : Integer; Var S : String);}\par
{\f1   Procedure Str(X : Real; Var S : String);}\par
{\f1   Procedure Str(X : Integer:Width; Var S : String);}\par
{\f1   Procedure Str(X : Real:Width:Decimals; Var S : String);}\par
{\f1     - Convertit un nombre en sa representation chaine}\par
{\f1     - Exemple : Str(42, S); \{ S = '42' \}}\par
\par
{\f1   Procedure Val(S : String; Var V : Integer; Var Code : Integer);}\par
{\f1   Procedure Val(S : String; Var V : Real; Var Code : Integer);}\par
{\f1     - Convertit une chaine en nombre}\par
{\f1     - Code = 0 si OK, sinon position de l'erreur}\par
{\f1     - Exemple : Val('42', N, Err); \{ N = 42, Err = 0 \}}\par
\par
\par
\b 3.3 Operateurs sur String \b0\par
\par
{\f1   S1 + S2          Concatenation    'AB' + 'CD' = 'ABCD'}\par
{\f1   S1 = S2          Egalite          'ABC' = 'ABC' -> True}\par
{\f1   S1 <> S2         Inegalite        'ABC' <> 'DEF' -> True}\par
{\f1   S1 < S2          Inferieur        'ABC' < 'DEF' -> True}\par
{\f1   S1 > S2          Superieur        'DEF' > 'ABC' -> True}\par
{\f1   S1 <= S2         Inf ou egal}\par
{\f1   S1 >= S2         Sup ou egal}\par
{\f1   S[N]             Acces caractere  S[0] = longueur, S[1] = 1er char}\par
\par
\par
