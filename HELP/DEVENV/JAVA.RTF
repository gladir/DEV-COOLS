{\footnote # IDH_JAVA_12}
{\footnote $ Java - Concurrence et threads}
{\footnote K Java concurrence threads;Thread;synchronized volatile;Executor ExecutorService;Future CompletableFuture;atomic;ConcurrentHashMap;virtual threads;structured concurrency}
\b\fs24 Concurrence et threads \b0\fs20\par
\par
Thread classique :\par
{\f1   Thread t = new Thread(() -> System.out.println("Hello"));}\par
{\f1   t.start();}\par
{\f1   t.join();}\par
\par
Synchronisation :\par
{\f1   public synchronized void incrementer() \{ ... \}}\par
{\f1   synchronized (verrou) \{ ... \}}\par
{\f1   volatile int compteur;}\par
\par
java.util.concurrent (Java 5+) :\par
{\f1   ExecutorService exec = Executors.newFixedThreadPool(4);}\par
{\f1   Future<Integer> f = exec.submit(() -> calculer());}\par
{\f1   Integer r = f.get();}\par
\par
{\f1   CompletableFuture<String> cf = CompletableFuture}\par
{\f1       .supplyAsync(() -> telecharger())}\par
{\f1       .thenApply(String::toUpperCase)}\par
{\f1       .thenAccept(System.out::println);}\par
\par
{\f1   AtomicInteger compteur = new AtomicInteger();}\par
{\f1   ConcurrentHashMap<String, Integer> map = new ConcurrentHashMap<>();}\par
\par
Virtual threads (Java 21+) :\par
{\f1   Thread.startVirtualThread(() -> \{ ... \});}\par
\par
{\f1   try (var exec = Executors.newVirtualThreadPerTaskExecutor()) \{}\par
{\f1       exec.submit(() -> ...);}\par
{\f1   \}}\par
\par
\par
\par
