{\footnote # IDH_JAVA_16}
{\footnote $ Java - Exemples de programmes}
{\footnote K Java exemples;Hello;factorielle;lecture fichier;Stream;HttpClient;record pattern matching;sealed}
\b\fs24 Exemples de programmes \b0\fs20\par
\par
16.1 Hello World\par
\par
{\f1   public class Hello \{}\par
{\f1       public static void main(String[] args) \{}\par
{\f1           System.out.println("Bonjour le monde");}\par
{\f1       \}}\par
{\f1   \}}\par
\par
16.2 Factorielle recursive\par
\par
{\f1   public class Fact \{}\par
{\f1       public static long fact(int n) \{}\par
{\f1           return n <= 1 ? 1 : n * fact(n - 1);}\par
{\f1       \}}\par
{\f1       public static void main(String[] args) \{}\par
{\f1           System.out.println(fact(20));        // 2432902008176640000}\par
{\f1       \}}\par
{\f1   \}}\par
\par
16.3 Lecture d'un fichier (Java 11+)\par
\par
{\f1   import java.nio.file.*;}\par
{\f1   import java.util.List;}\par
\par
{\f1   public class Lecture \{}\par
{\f1       public static void main(String[] args) throws Exception \{}\par
{\f1           List<String> lignes = Files.readAllLines(Path.of("a.txt"));}\par
{\f1           lignes.forEach(System.out::println);}\par
{\f1       \}}\par
{\f1   \}}\par
\par
16.4 Stream : mots les plus frequents\par
\par
{\f1   Map<String, Long> top = Files.lines(Path.of("texte.txt"))}\par
{\f1       .flatMap(l -> Arrays.stream(l.toLowerCase().split("\\\\s+")))}\par
{\f1       .filter(w -> !w.isBlank())}\par
{\f1       .collect(Collectors.groupingBy(w -> w, Collectors.counting()))}\par
{\f1       .entrySet().stream()}\par
{\f1       .sorted(Map.Entry.<String, Long>comparingByValue().reversed())}\par
{\f1       .limit(10)}\par
{\f1       .collect(Collectors.toMap(}\par
{\f1           Map.Entry::getKey, Map.Entry::getValue,}\par
{\f1           (a, b) -> a, LinkedHashMap::new));}\par
\par
16.5 Telechargement HTTP (Java 11+)\par
\par
{\f1   HttpClient client = HttpClient.newHttpClient();}\par
{\f1   HttpRequest req = HttpRequest.newBuilder(URI.create("https://exemple.org"))}\par
{\f1       .GET().build();}\par
{\f1   HttpResponse<String> resp = client.send(req,}\par
{\f1       HttpResponse.BodyHandlers.ofString());}\par
{\f1   System.out.println(resp.body());}\par
\par
16.6 Record et pattern matching (Java 21+)\par
\par
{\f1   sealed interface Forme permits Cercle, Rectangle \{\}}\par
{\f1   record Cercle(double r) implements Forme \{\}}\par
{\f1   record Rectangle(double l, double h) implements Forme \{\}}\par
\par
{\f1   static double aire(Forme f) \{}\par
{\f1       return switch (f) \{}\par
{\f1           case Cercle(double r) -> Math.PI * r * r;}\par
{\f1           case Rectangle(double l, double h) -> l * h;}\par
{\f1       \};}\par
{\f1   \}}\par
\par
\par
\par
