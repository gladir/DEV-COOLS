{\footnote # IDH_JAVA_07}
{\footnote $ Java - Classes et orientation objet}
{\footnote K Java classes objets;heritage;polymorphisme;abstract final static;interfaces;default methods;static methods;classes internes;anonymes;enum;records;sealed permits non-sealed;modificateurs acces}
\b\fs24 Classes et orientation objet \b0\fs20\par
\par
7.1 Definition de classe\par
\par
{\f1   public class Personne \{}\par
{\f1       private String nom;}\par
{\f1       private int age;}\par
\par
{\f1       public Personne(String nom, int age) \{}\par
{\f1           this.nom = nom;}\par
{\f1           this.age = age;}\par
{\f1       \}}\par
\par
{\f1       public String getNom() \{ return nom; \}}\par
{\f1       public int getAge() \{ return age; \}}\par
{\f1       public void setNom(String nom) \{ this.nom = nom; \}}\par
\par
{\f1       @Override}\par
{\f1       public String toString() \{}\par
{\f1           return nom + " (" + age + ")";}\par
{\f1       \}}\par
{\f1   \}}\par
\par
7.2 Heritage et polymorphisme\par
\par
{\f1   public abstract class Forme \{}\par
{\f1       public abstract double aire();}\par
{\f1       public String nom() \{ return "Forme"; \}}\par
{\f1   \}}\par
\par
{\f1   public class Cercle extends Forme \{}\par
{\f1       private double rayon;}\par
{\f1       public Cercle(double r) \{ this.rayon = r; \}}\par
{\f1       @Override public double aire() \{ return Math.PI * rayon * rayon; \}}\par
{\f1       @Override public String nom() \{ return "Cercle"; \}}\par
{\f1   \}}\par
\par
Modificateurs d'acces : public, private, protected, package-private (defaut).\par
Mots-cles : abstract, final, static, synchronized, native, strictfp,\par
volatile, transient.\par
\par
7.3 Interfaces\par
\par
{\f1   public interface Comparable<T> \{}\par
{\f1       int compareTo(T autre);}\par
{\f1   \}}\par
\par
Default methods (Java 8+) :\par
{\f1   public interface ILog \{}\par
{\f1       void log(String msg);}\par
{\f1       default void logErreur(String msg) \{ log("ERREUR: " + msg); \}}\par
{\f1       static ILog console() \{ return msg -> System.out.println(msg); \}}\par
{\f1   \}}\par
\par
7.4 Classes internes et anonymes\par
\par
{\f1   public class Externe \{}\par
{\f1       class Interne \{ ... \}                    // inner class}\par
{\f1       static class Imbriquee \{ ... \}           // static nested class}\par
{\f1       void m() \{}\par
{\f1           class Locale \{ ... \}                 // local class}\par
{\f1           Runnable r = new Runnable() \{        // classe anonyme}\par
{\f1               public void run() \{ ... \}}\par
{\f1           \};}\par
{\f1       \}}\par
{\f1   \}}\par
\par
7.5 Enumerations (Java 5+)\par
\par
{\f1   public enum Couleur \{}\par
{\f1       ROUGE("R"), VERT("V"), BLEU("B");}\par
\par
{\f1       private final String code;}\par
{\f1       Couleur(String code) \{ this.code = code; \}}\par
{\f1       public String code() \{ return code; \}}\par
{\f1   \}}\par
\par
7.6 Records (Java 14 preview, 16 stable)\par
\par
{\f1   public record Point(double x, double y) \{}\par
{\f1       public double distance(Point autre) \{}\par
{\f1           return Math.hypot(x - autre.x, y - autre.y);}\par
{\f1       \}}\par
{\f1   \}}\par
\par
{\f1   // generes automatiquement : constructeur canonique, accesseurs,}\par
{\f1   // equals, hashCode, toString.}\par
\par
7.7 Sealed classes (Java 17+)\par
\par
{\f1   public sealed interface Forme}\par
{\f1       permits Cercle, Rectangle, Triangle \{\}}\par
\par
{\f1   public final class Cercle implements Forme \{ ... \}}\par
{\f1   public final class Rectangle implements Forme \{ ... \}}\par
{\f1   public non-sealed class Triangle implements Forme \{ ... \}}\par
\par
\par
\par
