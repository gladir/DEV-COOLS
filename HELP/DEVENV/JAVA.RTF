{\footnote # IDH_JAVA_06}
{\footnote $ Java - Instructions de controle}
{\footnote K Java controle;if else;switch instruction;switch expression;yield;pattern matching switch;while do-while;for;for-each;break continue label;try catch finally;multi-catch;try-with-resources;assert;throw}
\b\fs24 Instructions de controle \b0\fs20\par
\par
if / else :\par
{\f1   if (x > 0) \{ ... \} else if (x == 0) \{ ... \} else \{ ... \}}\par
\par
switch instruction (forme classique) :\par
{\f1   switch (jour) \{}\par
{\f1       case 1: case 7: System.out.println("WE"); break;}\par
{\f1       case 2: case 3: case 4: case 5: case 6:}\par
{\f1           System.out.println("Semaine"); break;}\par
{\f1       default: throw new IllegalArgumentException();}\par
{\f1   \}}\par
\par
switch expression (Java 14+) :\par
{\f1   String nom = switch (code) \{}\par
{\f1       case 1 -> "Un";}\par
{\f1       case 2 -> "Deux";}\par
{\f1       default -> "Autre";}\par
{\f1   \};}\par
\par
{\f1   int n = switch (code) \{}\par
{\f1       case 1 -> 100;}\par
{\f1       case 2 -> \{ int x = calculer(); yield x * 2; \}}\par
{\f1       default -> 0;}\par
{\f1   \};}\par
\par
Pattern matching pour switch (Java 21+) :\par
{\f1   String description = switch (obj) \{}\par
{\f1       case Integer i when i > 0 -> "entier positif " + i;}\par
{\f1       case Integer i -> "entier " + i;}\par
{\f1       case String s -> "chaine " + s;}\par
{\f1       case null -> "rien";}\par
{\f1       default -> "autre";}\par
{\f1   \};}\par
\par
while / do-while :\par
{\f1   while (cond) \{ ... \}}\par
{\f1   do \{ ... \} while (cond);}\par
\par
for classique :\par
{\f1   for (int i = 0; i < n; i++) \{ ... \}}\par
\par
for-each (Java 5+) :\par
{\f1   for (String s : liste) \{ ... \}}\par
{\f1   for (int i : tableau) \{ ... \}}\par
\par
break, continue (avec etiquette possible) :\par
{\f1   outer:}\par
{\f1   for (int i = 0; i < n; i++) \{}\par
{\f1       for (int j = 0; j < m; j++) \{}\par
{\f1           if (cond) break outer;}\par
{\f1           if (cond2) continue outer;}\par
{\f1       \}}\par
{\f1   \}}\par
\par
return :\par
{\f1   return;}\par
{\f1   return valeur;}\par
\par
throw / try / catch / finally :\par
{\f1   try \{}\par
{\f1       ...}\par
{\f1   \} catch (FileNotFoundException e) \{}\par
{\f1       ...}\par
{\f1   \} catch (IOException | SQLException e) \{     // multi-catch (Java 7+)}\par
{\f1       ...}\par
{\f1   \} finally \{}\par
{\f1       ...}\par
{\f1   \}}\par
\par
try-with-resources (Java 7+) :\par
{\f1   try (FileReader f = new FileReader("a.txt");}\par
{\f1        BufferedReader br = new BufferedReader(f)) \{}\par
{\f1       String line = br.readLine();}\par
{\f1   \} catch (IOException e) \{ ... \}}\par
\par
assert (Java 1.4+) :\par
{\f1   assert x > 0;}\par
{\f1   assert x > 0 : "x doit etre positif";}\par
\par
\par
\par
