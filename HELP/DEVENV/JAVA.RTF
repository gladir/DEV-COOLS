{\footnote # IDH_JAVA_04}
{\footnote $ Java - Types de donnees}
{\footnote K Java types donnees;primitifs;boolean byte short char int long float double;wrappers;autoboxing;Object String;tableaux;records;var inference;final constantes}
\b\fs24 Types de donnees \b0\fs20\par
\par
4.1 Types primitifs (8 types, allocation pile)\par
\par
{\f1   boolean    true ou false}\par
{\f1   byte       8 bits signe       -128..127}\par
{\f1   short      16 bits signe      -32768..32767}\par
{\f1   char       16 bits non signe  0..65535 (UTF-16)}\par
{\f1   int        32 bits signe      -2^31..2^31-1}\par
{\f1   long       64 bits signe      -2^63..2^63-1}\par
{\f1   float      32 bits IEEE 754}\par
{\f1   double     64 bits IEEE 754}\par
\par
Wrappers (boxing) : Boolean, Byte, Short, Character, Integer, Long, Float,\par
Double. Autoboxing depuis Java 5.\par
\par
4.2 Types reference\par
\par
{\f1   Object               racine de la hierarchie}\par
{\f1   String               chaine immuable UTF-16}\par
{\f1   classes utilisateur}\par
{\f1   interfaces}\par
{\f1   enum                 enumerations (depuis Java 5)}\par
{\f1   tableaux             int[], String[], int[][]}\par
{\f1   records              (Java 14+/16 stable)}\par
\par
4.3 Tableaux\par
\par
{\f1   int[] t = new int[10];}\par
{\f1   int[] u = \{1, 2, 3, 4\};}\par
{\f1   int[][] mat = new int[3][3];}\par
{\f1   String[] noms = new String[5];}\par
{\f1   t.length                       // attribut length}\par
{\f1   Arrays.sort(t);                // tri}\par
{\f1   Arrays.fill(t, 0);             // remplissage}\par
\par
4.4 Inference de type local (Java 10+)\par
\par
{\f1   var i = 42;                    // int}\par
{\f1   var s = "hello";               // String}\par
{\f1   var liste = new ArrayList<Integer>();}\par
\par
4.5 Constantes\par
\par
{\f1   static final int MAX = 100;}\par
{\f1   final double PI = 3.14159;}\par
{\f1   static final String VERSION = "1.0";}\par
\par
\par
\par
