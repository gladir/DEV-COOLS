{\footnote # IDH_PHP_04}
{\footnote $ PHP - OPERATEURS}
{\footnote K PHP operateurs;arithmetiques;comparaison;logiques;chaines;tableau}
\b\fs24 OPERATEURS \b0\fs20\par
\par
\par
\b 4.1 Operateurs arithmetiques \b0\par
\par
{\f1   Operateur    Description             Exemple}\par
{\f1   ---------    --------------------    -----------}\par
{\f1   +            Addition                $a + $b}\par
{\f1   -            Soustraction            $a - $b}\par
{\f1   *            Multiplication          $a * $b}\par
{\f1   /            Division                $a / $b}\par
{\f1   %            Modulo                  $a % $b}\par
{\f1   **           Exponentiation          $a ** $b}\par
\par
\par
\b 4.2 Operateurs d'affectation \b0\par
\par
{\f1   Operateur    Description}\par
{\f1   ---------    --------------------}\par
{\f1   =            Affectation simple}\par
{\f1   +=           Addition et affectation}\par
{\f1   -=           Soustraction et affectation}\par
{\f1   *=           Multiplication et affectation}\par
{\f1   /=           Division et affectation}\par
{\f1   %=           Modulo et affectation}\par
{\f1   **=          Exponentiation et affectation}\par
{\f1   .=           Concatenation et affectation}\par
{\f1   ??=          Affectation si null (PHP 7.4)}\par
\par
\par
\b 4.3 Operateurs de comparaison \b0\par
\par
{\f1   Operateur    Description                     Exemple}\par
{\f1   ---------    ----------------------------    -----------}\par
{\f1   ==           Egal (avec conversion)          $a == $b}\par
{\f1   ===          Identique (type et valeur)      $a === $b}\par
{\f1   !=           Different                       $a != $b}\par
{\f1   <>           Different                       $a <> $b}\par
{\f1   !==          Non identique                   $a !== $b}\par
{\f1   <            Inferieur                       $a < $b}\par
{\f1   >            Superieur                       $a > $b}\par
{\f1   <=           Inferieur ou egal               $a <= $b}\par
{\f1   >=           Superieur ou egal               $a >= $b}\par
{\f1   <=>          Comparaison combinee            $a <=> $b}\par
\par
{\f1   L'operateur <=> (spaceship) retourne -1, 0 ou 1.}\par
\par
\par
\b 4.4 Operateurs logiques \b0\par
\par
{\f1   Operateur    Description}\par
{\f1   ---------    --------------------}\par
{\f1   &&           ET logique}\par
{\f1   ||           OU logique}\par
{\f1   !            NON logique}\par
{\f1   and          ET logique (priorite basse)}\par
{\f1   or           OU logique (priorite basse)}\par
{\f1   xor          OU exclusif}\par
\par
\par
\b 4.5 Operateurs bit a bit \b0\par
\par
{\f1   Operateur    Description}\par
{\f1   ---------    --------------------}\par
{\f1   &            ET bit a bit}\par
{\f1   |            OU bit a bit}\par
{\f1   ^            XOR bit a bit}\par
{\f1   ~            NON bit a bit}\par
{\f1   <<           Decalage a gauche}\par
{\f1   >>           Decalage a droite}\par
\par
\par
\b 4.6 Operateurs de chaine \b0\par
\par
{\f1   Operateur    Description}\par
{\f1   ---------    --------------------}\par
{\f1   .            Concatenation}\par
{\f1   .=           Concatenation et affectation}\par
\par
\par
\b 4.7 Operateurs d'incrementation \b0\par
\par
{\f1   Operateur    Description}\par
{\f1   ---------    --------------------}\par
{\f1   ++$a         Pre-incrementation}\par
{\f1   $a++         Post-incrementation}\par
{\f1   --$a         Pre-decrementation}\par
{\f1   $a--         Post-decrementation}\par
\par
\par
\b 4.8 Operateurs speciaux \b0\par
\par
{\f1   Operateur    Description}\par
{\f1   ---------    ----------------------------------------}\par
{\f1   ?:           Operateur ternaire}\par
{\f1   ??           Coalescence nulle (PHP 7.0)}\par
{\f1   ?->          Appel de methode null-safe (PHP 8.0)}\par
{\f1   @            Suppression d'erreur}\par
{\f1   =>           Separateur clef/valeur dans un tableau}\par
{\f1   ->           Acces a un membre d'objet}\par
{\f1   ::           Operateur de resolution de portee}\par
{\f1   ...          Operateur de decomposition (splat)}\par
{\f1   instanceof   Verification de type d'objet}\par
\par
\par
