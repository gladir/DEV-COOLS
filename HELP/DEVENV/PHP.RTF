{\footnote # IDH_PHP_14}
{\footnote $ PHP - FONCTIONS AVANCEES}
{\footnote K PHP avancees;closure;generateur;yield;reflection;attribut}
\b\fs24 FONCTIONS AVANCEES \b0\fs20\par
\par
\par
\b 14.1 Generateurs \b0\par
\par
{\f1     function fibonacci(): Generator \{}\par
{\f1         [$a, $b] = [0, 1];}\par
{\f1         while (true) \{}\par
{\f1             yield $a;}\par
{\f1             [$a, $b] = [$b, $a + $b];}\par
{\f1         \}}\par
{\f1     \}}\par
\par
{\f1     foreach (fibonacci() as $nombre) \{}\par
{\f1         if ($nombre > 100) break;}\par
{\f1         echo $nombre . " ";}\par
{\f1     \}}\par
\par
{\f1     yield $clef => $valeur;    Retourner une paire clef/valeur}\par
{\f1     yield from $iterable;      Deleguer a un autre generateur}\par
\par
\par
\b 14.2 Fibres (PHP 8.1) \b0\par
\par
{\f1     $fibre = new Fiber(function (): void \{}\par
{\f1         $valeur = Fiber::suspend("suspendu");}\par
{\f1         echo "Recu : $valeur";}\par
{\f1     \});}\par
\par
{\f1     $resultat = $fibre->start();     // "suspendu"}\par
{\f1     $fibre->resume("bonjour");       // "Recu : bonjour"}\par
\par
\par
\b 14.3 Attributs (PHP 8.0) \b0\par
\par
{\f1     #[Attribute]}\par
{\f1     class Route \{}\par
{\f1         public function __construct(}\par
{\f1             public string $chemin,}\par
{\f1             public string $methode = "GET"}\par
{\f1         ) \{\}}\par
{\f1     \}}\par
\par
{\f1     #[Route("/utilisateurs", methode: "POST")]}\par
{\f1     function creerUtilisateur() \{ /* ... */ \}}\par
\par
{\f1     // Lire les attributs par reflexion}\par
{\f1     $ref = new ReflectionFunction('creerUtilisateur');}\par
{\f1     $attrs = $ref->getAttributes(Route::class);}\par
{\f1     $route = $attrs[0]->newInstance();}\par
\par
\par
\b 14.4 Clonage d'objets \b0\par
\par
{\f1     $copie = clone $objet;}\par
\par
{\f1   La methode magique __clone() est appelee apres le clonage}\par
{\f1   pour permettre la copie profonde.}\par
\par
\par
\b 14.5 Comparaison d'objets \b0\par
\par
{\f1     $a == $b     Meme classe et memes proprietes}\par
{\f1     $a === $b    Meme instance (meme reference)}\par
\par
\par
\b 14.6 Chargement automatique (Autoloading) \b0\par
\par
{\f1     spl_autoload_register(function (string $classe) \{}\par
{\f1         $fichier = __DIR__ . '/' . str_replace('\\\\', '/', $classe) . '.php';}\par
{\f1         if (file_exists($fichier)) \{}\par
{\f1             require $fichier;}\par
{\f1         \}}\par
{\f1     \});}\par
\par
{\f1   En pratique, le standard PSR-4 et Composer sont utilises :}\par
\par
{\f1     // composer.json}\par
{\f1     \{}\par
{\f1         "autoload": \{}\par
{\f1             "psr-4": \{}\par
{\f1                 "App\\\\": "src/"}\par
{\f1             \}}\par
{\f1         \}}\par
{\f1     \}}\par
\par
\par
