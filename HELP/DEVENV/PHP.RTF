{\footnote # IDH_PHP_09}
{\footnote $ PHP - CLASSES ET OBJETS}
{\footnote K PHP classes;objets;heritage;interface;trait;abstract;final;visibilite}
\b\fs24 CLASSES ET OBJETS \b0\fs20\par
\par
\par
\b 9.1 Declaration de classe \b0\par
\par
{\f1     class NomDeClasse \{}\par
{\f1         // Proprietes}\par
{\f1         public string $nom;}\par
{\f1         protected int $age;}\par
{\f1         private float $solde;}\par
\par
{\f1         // Constante de classe}\par
{\f1         public const VERSION = "1.0";}\par
\par
{\f1         // Constructeur}\par
{\f1         public function __construct(string $nom, int $age) \{}\par
{\f1             $this->nom = $nom;}\par
{\f1             $this->age = $age;}\par
{\f1         \}}\par
\par
{\f1         // Methode}\par
{\f1         public function saluer(): string \{}\par
{\f1             return "Bonjour, je suis \{$this->nom\}";}\par
{\f1         \}}\par
{\f1     \}}\par
\par
\par
\b 9.2 Promotion de proprietes du constructeur (PHP 8.0) \b0\par
\par
{\f1     class Utilisateur \{}\par
{\f1         public function __construct(}\par
{\f1             public string $nom,}\par
{\f1             protected int $age,}\par
{\f1             private string $email = ""}\par
{\f1         ) \{\}}\par
{\f1     \}}\par
\par
\par
\b 9.3 Instanciation \b0\par
\par
{\f1     $objet = new NomDeClasse("Alice", 30);}\par
{\f1     echo $objet->nom;}\par
{\f1     echo $objet->saluer();}\par
{\f1     echo NomDeClasse::VERSION;}\par
\par
\par
\b 9.4 Heritage \b0\par
\par
{\f1     class Animal \{}\par
{\f1         public function __construct(}\par
{\f1             protected string $nom}\par
{\f1         ) \{\}}\par
\par
{\f1         public function parler(): string \{}\par
{\f1             return "...";}\par
{\f1         \}}\par
{\f1     \}}\par
\par
{\f1     class Chat extends Animal \{}\par
{\f1         public function parler(): string \{}\par
{\f1             return "Miaou";}\par
{\f1         \}}\par
{\f1     \}}\par
\par
{\f1   PHP ne supporte que l'heritage simple (une seule classe parente).}\par
{\f1   Le mot-clef final empeche l'heritage ou la surcharge :}\par
\par
{\f1     final class ClasseFinale \{ \}}\par
{\f1     class Base \{}\par
{\f1         final public function methode() \{ \}}\par
{\f1     \}}\par
\par
\par
\b 9.5 Classes et methodes abstraites \b0\par
\par
{\f1     abstract class Forme \{}\par
{\f1         abstract public function aire(): float;}\par
\par
{\f1         public function decrire(): string \{}\par
{\f1             return "Je suis une forme d'aire " . $this->aire();}\par
{\f1         \}}\par
{\f1     \}}\par
\par
{\f1     class Cercle extends Forme \{}\par
{\f1         public function __construct(private float $rayon) \{\}}\par
\par
{\f1         public function aire(): float \{}\par
{\f1             return M_PI * $this->rayon ** 2;}\par
{\f1         \}}\par
{\f1     \}}\par
\par
\par
\b 9.6 Interfaces \b0\par
\par
{\f1     interface Affichable \{}\par
{\f1         public function afficher(): string;}\par
{\f1     \}}\par
\par
{\f1     interface Serialisable \{}\par
{\f1         public function serialiser(): string;}\par
{\f1     \}}\par
\par
{\f1     class Document implements Affichable, Serialisable \{}\par
{\f1         public function afficher(): string \{ /* ... */ \}}\par
{\f1         public function serialiser(): string \{ /* ... */ \}}\par
{\f1     \}}\par
\par
{\f1   Une classe peut implementer plusieurs interfaces.}\par
\par
\par
\b 9.7 Traits \b0\par
\par
{\f1     trait Horodatable \{}\par
{\f1         public DateTime $creeA;}\par
\par
{\f1         public function initialiserDate(): void \{}\par
{\f1             $this->creeA = new DateTime();}\par
{\f1         \}}\par
{\f1     \}}\par
\par
{\f1     trait Journalisable \{}\par
{\f1         public function journal(string $msg): void \{}\par
{\f1             echo "[LOG] $msg";}\par
{\f1         \}}\par
{\f1     \}}\par
\par
{\f1     class Commande \{}\par
{\f1         use Horodatable, Journalisable;}\par
{\f1     \}}\par
\par
{\f1   Resolution de conflit entre traits :}\par
\par
{\f1     class MaClasse \{}\par
{\f1         use TraitA, TraitB \{}\par
{\f1             TraitA::methode insteadof TraitB;}\par
{\f1             TraitB::methode as methodeB;}\par
{\f1         \}}\par
{\f1     \}}\par
\par
\par
\b 9.8 Visibilite \b0\par
\par
{\f1   Modificateur    Acces}\par
{\f1   ------------    -------------------------------------------}\par
{\f1   public          Accessible de partout}\par
{\f1   protected       Accessible dans la classe et ses enfants}\par
{\f1   private         Accessible uniquement dans la classe}\par
{\f1   readonly        Propriete en lecture seule (PHP 8.1)}\par
\par
\par
\b 9.9 Proprietes et methodes statiques \b0\par
\par
{\f1     class Compteur \{}\par
{\f1         private static int $nombre = 0;}\par
\par
{\f1         public static function incrementer(): void \{}\par
{\f1             self::$nombre++;}\par
{\f1         \}}\par
\par
{\f1         public static function obtenir(): int \{}\par
{\f1             return self::$nombre;}\par
{\f1         \}}\par
{\f1     \}}\par
\par
{\f1     Compteur::incrementer();}\par
{\f1     echo Compteur::obtenir();}\par
\par
\par
\b 9.10 Methodes magiques \b0\par
\par
{\f1   Methode              Declenchee quand}\par
{\f1   ----------------     -------------------------------------------}\par
{\f1   __construct()        L'objet est cree}\par
{\f1   __destruct()         L'objet est detruit}\par
{\f1   __get($nom)          Acces a une propriete inaccessible}\par
{\f1   __set($nom, $val)    Ecriture sur une propriete inaccessible}\par
{\f1   __isset($nom)        isset() sur une propriete inaccessible}\par
{\f1   __unset($nom)        unset() sur une propriete inaccessible}\par
{\f1   __call($nom, $args)  Appel d'une methode inaccessible}\par
{\f1   __callStatic($n,$a)  Appel statique d'une methode inaccessible}\par
{\f1   __toString()         Conversion en chaine}\par
{\f1   __invoke(...)        L'objet est utilise comme fonction}\par
{\f1   __clone()            L'objet est clone}\par
{\f1   __debugInfo()        var_dump() est appele sur l'objet}\par
{\f1   __serialize()        Serialisation de l'objet}\par
{\f1   __unserialize($d)    Deserialisation de l'objet}\par
{\f1   __sleep()            Avant serialisation (obsolete)}\par
{\f1   __wakeup()           Apres deserialisation (obsolete)}\par
\par
\par
\b 9.11 Enumerations (PHP 8.1) \b0\par
\par
{\f1   Enumeration simple (sans valeur) :}\par
\par
{\f1     enum Couleur \{}\par
{\f1         case Rouge;}\par
{\f1         case Vert;}\par
{\f1         case Bleu;}\par
{\f1     \}}\par
\par
{\f1     $c = Couleur::Rouge;}\par
\par
{\f1   Enumeration avec valeur (backed enum) :}\par
\par
{\f1     enum Statut: string \{}\par
{\f1         case Actif = "actif";}\par
{\f1         case Inactif = "inactif";}\par
{\f1         case Suspendu = "suspendu";}\par
{\f1     \}}\par
\par
{\f1     $s = Statut::Actif;}\par
{\f1     echo $s->value;             // "actif"}\par
{\f1     $s = Statut::from("actif"); // Statut::Actif}\par
\par
{\f1   Les enumerations peuvent implementer des interfaces et utiliser}\par
{\f1   des traits. Elles ne peuvent pas etre instanciees avec new.}\par
\par
\par
\b 9.12 Classes en lecture seule (PHP 8.2) \b0\par
\par
{\f1     readonly class Point \{}\par
{\f1         public function __construct(}\par
{\f1             public float $x,}\par
{\f1             public float $y}\par
{\f1         ) \{\}}\par
{\f1     \}}\par
\par
{\f1   Toutes les proprietes sont automatiquement readonly.}\par
\par
\par
