{\footnote # IDH_PHP_08}
{\footnote $ PHP - TABLEAUX}
{\footnote K PHP tableaux;indexe;associatif;multidimensionnel;foreach}
\b\fs24 TABLEAUX \b0\fs20\par
\par
\par
\b 8.1 Creation de tableaux \b0\par
\par
{\f1   Tableaux indexes :}\par
\par
{\f1     $fruits = ["pomme", "banane", "cerise"];}\par
{\f1     $fruits = array("pomme", "banane", "cerise");}\par
\par
{\f1   Tableaux associatifs :}\par
\par
{\f1     $personne = [}\par
{\f1         "nom"  => "Alice",}\par
{\f1         "age"  => 30,}\par
{\f1         "ville" => "Paris"}\par
{\f1     ];}\par
\par
\par
\b 8.2 Acces aux elements \b0\par
\par
{\f1     $fruits[0]             Premier element}\par
{\f1     $personne["nom"]       Acces par clef}\par
{\f1     $fruits[] = "orange";  Ajouter un element}\par
\par
\par
\b 8.3 Decomposition de tableaux \b0\par
\par
{\f1     [$a, $b, $c] = [1, 2, 3];}\par
{\f1     ["nom" => $nom, "age" => $age] = $personne;}\par
{\f1     [, , $troisieme] = $tableau;    // Ignorer des elements}\par
\par
\par
\b 8.4 Operateur de decomposition (spread) \b0\par
\par
{\f1     $a = [1, 2, 3];}\par
{\f1     $b = [0, ...$a, 4];    // [0, 1, 2, 3, 4]}\par
\par
\par
\b 8.5 Fonctions de tableaux principales \b0\par
\par
{\f1   Fonction                  Description}\par
{\f1   ----------------------    -------------------------------------------}\par
{\f1   count($a)                 Nombre d'elements}\par
{\f1   sizeof($a)                Alias de count}\par
{\f1   array_push($a, $v)        Ajouter a la fin}\par
{\f1   array_pop($a)             Retirer le dernier element}\par
{\f1   array_shift($a)           Retirer le premier element}\par
{\f1   array_unshift($a, $v)     Ajouter au debut}\par
{\f1   array_merge($a, $b)       Fusionner des tableaux}\par
{\f1   array_slice($a, $d, $l)   Extraire une portion}\par
{\f1   array_splice($a,$d,$l,$r) Remplacer une portion}\par
{\f1   array_keys($a)            Obtenir les clefs}\par
{\f1   array_values($a)          Obtenir les valeurs}\par
{\f1   array_key_exists($k, $a)  Verifier si une clef existe}\par
{\f1   in_array($v, $a)          Verifier si une valeur existe}\par
{\f1   array_search($v, $a)      Chercher une valeur}\par
{\f1   array_unique($a)          Supprimer les doublons}\par
{\f1   array_reverse($a)         Inverser l'ordre}\par
{\f1   array_flip($a)            Echanger clefs et valeurs}\par
{\f1   array_map($fn, $a)        Appliquer une fonction}\par
{\f1   array_filter($a, $fn)     Filtrer les elements}\par
{\f1   array_reduce($a, $fn)     Reduire a une seule valeur}\par
{\f1   array_walk($a, $fn)       Appliquer une fonction (en place)}\par
{\f1   array_column($a, $col)    Extraire une colonne}\par
{\f1   array_combine($k, $v)     Creer depuis clefs et valeurs}\par
{\f1   sort($a)                  Trier par valeur}\par
{\f1   rsort($a)                 Trier par valeur (decroissant)}\par
{\f1   asort($a)                 Trier par valeur (conserver clefs)}\par
{\f1   arsort($a)                Trier par valeur decroissant (clefs)}\par
{\f1   ksort($a)                 Trier par clef}\par
{\f1   krsort($a)                Trier par clef (decroissant)}\par
{\f1   usort($a, $fn)            Trier avec fonction personnalisee}\par
{\f1   array_chunk($a, $n)       Decouper en sous-tableaux}\par
{\f1   array_fill($d, $n, $v)    Remplir un tableau}\par
{\f1   array_diff($a, $b)        Difference entre tableaux}\par
{\f1   array_intersect($a, $b)   Intersection de tableaux}\par
{\f1   compact('var1', 'var2')   Creer un tableau depuis des variables}\par
{\f1   extract($a)               Creer des variables depuis un tableau}\par
{\f1   list($a, $b) = $arr       Affecter depuis un tableau}\par
\par
\par
