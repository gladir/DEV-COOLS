{\footnote # IDH_PHP_15}
{\footnote $ PHP - BASE DE DONNEES (PDO)}
{\footnote K PHP PDO;base de donnees;MySQL;PostgreSQL;prepared statement}
\b\fs24 BASE DE DONNEES (PDO) \b0\fs20\par
\par
\par
\b 15.1 Connexion \b0\par
\par
{\f1     $pdo = new PDO(}\par
{\f1         "mysql:host=localhost;dbname=mabase;charset=utf8mb4",}\par
{\f1         "utilisateur",}\par
{\f1         "motdepasse",}\par
{\f1         [}\par
{\f1             PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,}\par
{\f1             PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,}\par
{\f1             PDO::ATTR_EMULATE_PREPARES => false,}\par
{\f1         ]}\par
{\f1     );}\par
\par
\par
\b 15.2 Requetes preparees \b0\par
\par
{\f1     // Parametres nommes}\par
{\f1     $stmt = $pdo->prepare("SELECT * FROM users WHERE id = :id");}\par
{\f1     $stmt->execute(["id" => 42]);}\par
{\f1     $user = $stmt->fetch();}\par
\par
{\f1     // Parametres positionnels}\par
{\f1     $stmt = $pdo->prepare("SELECT * FROM users WHERE age > ?");}\par
{\f1     $stmt->execute([18]);}\par
{\f1     $users = $stmt->fetchAll();}\par
\par
\par
\b 15.3 Insertion et modification \b0\par
\par
{\f1     $stmt = $pdo->prepare(}\par
{\f1         "INSERT INTO users (nom, email) VALUES (:nom, :email)"}\par
{\f1     );}\par
{\f1     $stmt->execute(["nom" => "Alice", "email" => "alice@exemple.fr"]);}\par
{\f1     $id = $pdo->lastInsertId();}\par
\par
\par
\b 15.4 Transactions \b0\par
\par
{\f1     $pdo->beginTransaction();}\par
{\f1     try \{}\par
{\f1         $pdo->exec("UPDATE comptes SET solde = solde - 100 WHERE id = 1");}\par
{\f1         $pdo->exec("UPDATE comptes SET solde = solde + 100 WHERE id = 2");}\par
{\f1         $pdo->commit();}\par
{\f1     \} catch (Exception $e) \{}\par
{\f1         $pdo->rollBack();}\par
{\f1         throw $e;}\par
{\f1     \}}\par
\par
\par
