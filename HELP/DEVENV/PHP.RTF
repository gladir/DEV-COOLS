{\footnote # IDH_PHP_02}
{\footnote $ PHP - TYPES DE DONNEES}
{\footnote K PHP types;bool;int;float;string;array;object;null;mixed}
\b\fs24 TYPES DE DONNEES \b0\fs20\par
\par
\par
\b 2.1 Types scalaires \b0\par
\par
{\f1   Type         Description                    Exemple}\par
{\f1   -------      ---------------------------    ----------------}\par
{\f1   bool         Booleen                        true, false}\par
{\f1   int          Entier                         42, 0x1A, 0b1010, 0o17}\par
{\f1   float        Nombre a virgule flottante     3.14, 1.2e3}\par
{\f1   string       Chaine de caracteres           "texte", 'texte'}\par
\par
\par
\b 2.2 Types composes \b0\par
\par
{\f1   Type         Description}\par
{\f1   -------      ---------------------------}\par
{\f1   array        Tableau ordonne / associatif}\par
{\f1   object       Instance de classe}\par
{\f1   callable     Fonction appelable}\par
{\f1   iterable     Tableau ou objet Traversable}\par
\par
\par
\b 2.3 Types speciaux \b0\par
\par
{\f1   Type         Description}\par
{\f1   -------      ---------------------------}\par
{\f1   resource     Reference a une ressource externe}\par
{\f1   null         Absence de valeur}\par
{\f1   never        Fonction qui ne retourne jamais (PHP 8.1)}\par
{\f1   void         Fonction sans valeur de retour}\par
{\f1   mixed        Tout type (PHP 8.0)}\par
\par
\par
\b 2.4 Verification de type \b0\par
\par
{\f1     gettype($var)            Retourne le type sous forme de chaine}\par
{\f1     is_int($var)             Verifie si entier}\par
{\f1     is_float($var)           Verifie si flottant}\par
{\f1     is_string($var)          Verifie si chaine}\par
{\f1     is_bool($var)            Verifie si booleen}\par
{\f1     is_array($var)           Verifie si tableau}\par
{\f1     is_object($var)          Verifie si objet}\par
{\f1     is_null($var)            Verifie si null}\par
{\f1     is_numeric($var)         Verifie si numerique}\par
{\f1     isset($var)              Verifie si defini et non null}\par
{\f1     empty($var)              Verifie si vide}\par
{\f1     var_dump($var)           Affiche le type et la valeur}\par
\par
\par
\b 2.5 Transtypage (cast) \b0\par
\par
{\f1     (int) $var               Convertir en entier}\par
{\f1     (float) $var             Convertir en flottant}\par
{\f1     (string) $var            Convertir en chaine}\par
{\f1     (bool) $var              Convertir en booleen}\par
{\f1     (array) $var             Convertir en tableau}\par
{\f1     (object) $var            Convertir en objet}\par
{\f1     intval($var)             Convertir en entier (fonction)}\par
{\f1     floatval($var)           Convertir en flottant (fonction)}\par
{\f1     strval($var)             Convertir en chaine (fonction)}\par
{\f1     settype($var, "type")    Changer le type de la variable}\par
\par
\par
