{\footnote # IDH_PHP_03}
{\footnote $ PHP - VARIABLES ET CONSTANTES}
{\footnote K PHP variables;constantes;portee;global;static;define}
\b\fs24 VARIABLES ET CONSTANTES \b0\fs20\par
\par
\par
\b 3.1 Variables \b0\par
\par
{\f1   Les variables commencent par le signe dollar ($) :}\par
\par
{\f1     $nom = "PHP";}\par
{\f1     $age = 30;}\par
{\f1     $pi  = 3.14159;}\par
\par
{\f1   Les noms de variables doivent commencer par une lettre ou un}\par
{\f1   underscore, suivis de lettres, chiffres ou underscores.}\par
\par
\par
\b 3.2 Variables variables \b0\par
\par
{\f1     $nom = "langage";}\par
{\f1     $$nom = "PHP";       // equivalent a $langage = "PHP"}\par
\par
\par
\b 3.3 Variables predefinies (superglobales) \b0\par
\par
{\f1   Variable         Description}\par
{\f1   -------          -------------------------------------------}\par
{\f1   $GLOBALS         Toutes les variables globales}\par
{\f1   $_SERVER         Informations du serveur et de l'execution}\par
{\f1   $_GET            Variables HTTP GET}\par
{\f1   $_POST           Variables HTTP POST}\par
{\f1   $_FILES          Fichiers envoyes par HTTP}\par
{\f1   $_COOKIE         Cookies HTTP}\par
{\f1   $_SESSION        Variables de session}\par
{\f1   $_REQUEST        Contenu de $_GET, $_POST et $_COOKIE}\par
{\f1   $_ENV            Variables d'environnement}\par
\par
\par
\b 3.4 Constantes \b0\par
\par
{\f1     define("NOM", valeur);           Definir une constante}\par
{\f1     const NOM = valeur;              Definir une constante (classe/global)}\par
\par
{\f1   Constantes predefinies :}\par
\par
{\f1     PHP_VERSION       Version de PHP}\par
{\f1     PHP_INT_MAX       Entier maximum}\par
{\f1     PHP_INT_MIN       Entier minimum}\par
{\f1     PHP_INT_SIZE      Taille d'un entier en octets}\par
{\f1     PHP_FLOAT_MAX     Flottant maximum}\par
{\f1     PHP_FLOAT_MIN     Flottant minimum positif}\par
{\f1     PHP_EOL           Fin de ligne du systeme}\par
{\f1     PHP_OS            Systeme d'exploitation}\par
{\f1     PHP_SAPI          Interface serveur utilisee}\par
{\f1     DIRECTORY_SEPARATOR  Separateur de repertoire (/ ou \\)}\par
{\f1     PATH_SEPARATOR    Separateur de chemin (: ou ;)}\par
{\f1     TRUE              Booleen vrai}\par
{\f1     FALSE             Booleen faux}\par
{\f1     NULL              Valeur nulle}\par
{\f1     PHP_MAJOR_VERSION Version majeure}\par
{\f1     PHP_MINOR_VERSION Version mineure}\par
{\f1     INF               Infini}\par
{\f1     NAN               Not a Number}\par
{\f1     E_ERROR           Erreur fatale}\par
{\f1     E_WARNING         Avertissement}\par
{\f1     E_NOTICE          Notification}\par
{\f1     E_DEPRECATED      Fonctionnalite obsolete}\par
\par
\par
\b 3.5 Portee des variables \b0\par
\par
{\f1   Par defaut, les variables ont une portee locale a la fonction.}\par
{\f1   Pour acceder a une variable globale dans une fonction :}\par
\par
{\f1     $x = 10;}\par
{\f1     function test() \{}\par
{\f1         global $x;       // Acces a la variable globale}\par
{\f1         echo $x;}\par
{\f1     \}}\par
\par
{\f1   Le mot-clef static conserve la valeur entre les appels :}\par
\par
{\f1     function compteur() \{}\par
{\f1         static $n = 0;}\par
{\f1         $n++;}\par
{\f1         return $n;}\par
{\f1     \}}\par
\par
\par
