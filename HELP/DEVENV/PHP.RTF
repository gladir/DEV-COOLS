{\footnote # IDH_PHP_11}
{\footnote $ PHP - GESTION DES ERREURS ET EXCEPTIONS}
{\footnote K PHP erreurs;exceptions;try;catch;throw;finally}
\b\fs24 GESTION DES ERREURS ET EXCEPTIONS \b0\fs20\par
\par
\par
\b 11.1 Exceptions \b0\par
\par
{\f1     try \{}\par
{\f1         if ($diviseur == 0) \{}\par
{\f1             throw new DivisionByZeroError("Division par zero");}\par
{\f1         \}}\par
{\f1         $resultat = $dividende / $diviseur;}\par
{\f1     \} catch (DivisionByZeroError $e) \{}\par
{\f1         echo "Erreur : " . $e->getMessage();}\par
{\f1     \} catch (TypeError | ValueError $e) \{}\par
{\f1         echo "Erreur de type : " . $e->getMessage();}\par
{\f1     \} finally \{}\par
{\f1         echo "Bloc toujours execute";}\par
{\f1     \}}\par
\par
\par
\b 11.2 Hierarchie des exceptions \b0\par
\par
{\f1     Throwable (interface)}\par
{\f1     +-- Error}\par
{\f1     |   +-- ArithmeticError}\par
{\f1     |   |   +-- DivisionByZeroError}\par
{\f1     |   +-- TypeError}\par
{\f1     |   +-- ValueError}\par
{\f1     |   +-- UnhandledMatchError}\par
{\f1     |   +-- FiberError}\par
{\f1     +-- Exception}\par
{\f1         +-- RuntimeException}\par
{\f1         |   +-- OverflowException}\par
{\f1         |   +-- UnderflowException}\par
{\f1         |   +-- OutOfBoundsException}\par
{\f1         +-- LogicException}\par
{\f1         |   +-- InvalidArgumentException}\par
{\f1         |   +-- LengthException}\par
{\f1         |   +-- OutOfRangeException}\par
{\f1         |   +-- BadMethodCallException}\par
{\f1         |   +-- DomainException}\par
{\f1         +-- BadFunctionCallException}\par
\par
\par
\b 11.3 Exceptions personnalisees \b0\par
\par
{\f1     class MonException extends RuntimeException \{}\par
{\f1         public function __construct(}\par
{\f1             string $message,}\par
{\f1             private array $contexte = [],}\par
{\f1             int $code = 0,}\par
{\f1             ?\\Throwable $precedente = null}\par
{\f1         ) \{}\par
{\f1             parent::__construct($message, $code, $precedente);}\par
{\f1         \}}\par
\par
{\f1         public function getContexte(): array \{}\par
{\f1             return $this->contexte;}\par
{\f1         \}}\par
{\f1     \}}\par
\par
\par
\b 11.4 Gestion des erreurs \b0\par
\par
{\f1     error_reporting(E_ALL);}\par
{\f1     set_error_handler(function($niveau, $message, $fichier, $ligne) \{}\par
{\f1         throw new ErrorException($message, 0, $niveau, $fichier, $ligne);}\par
{\f1     \});}\par
\par
{\f1     set_exception_handler(function(Throwable $e) \{}\par
{\f1         echo "Exception non capturee : " . $e->getMessage();}\par
{\f1     \});}\par
\par
\par
