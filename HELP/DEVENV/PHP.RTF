{\footnote # IDH_PHP_10}
{\footnote $ PHP - ESPACES DE NOMS (NAMESPACES)}
{\footnote K PHP namespaces;use;as;\\;sous-espace}
\b\fs24 ESPACES DE NOMS (NAMESPACES) \b0\fs20\par
\par
\par
\b 10.1 Declaration \b0\par
\par
{\f1     namespace App\\Models;}\par
\par
{\f1     class Utilisateur \{}\par
{\f1         // ...}\par
{\f1     \}}\par
\par
\par
\b 10.2 Utilisation \b0\par
\par
{\f1     use App\\Models\\Utilisateur;}\par
{\f1     use App\\Models\\Utilisateur as User;}\par
{\f1     use App\\Services\\\{ServiceA, ServiceB\};}\par
\par
{\f1     use function App\\Helpers\\formater;}\par
{\f1     use const App\\Config\\VERSION;}\par
\par
\par
\b 10.3 Resolution de noms \b0\par
\par
{\f1   Type               Exemple}\par
{\f1   ------             ----------------------------------}\par
{\f1   Non qualifie       Classe             (resolution relative)}\par
{\f1   Qualifie           SousEspace\\Classe  (resolution relative)}\par
{\f1   Pleinement         \\App\\Models\\Classe (resolution absolue)}\par
{\f1   qualifie}\par
\par
\par
