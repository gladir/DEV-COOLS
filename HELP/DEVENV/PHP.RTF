{\footnote # IDH_PHP_13}
{\footnote $ PHP - PROGRAMMATION ORIENTEE WEB}
{\footnote K PHP web;GET;POST;COOKIE;SESSION;header;form}
\b\fs24 PROGRAMMATION ORIENTEE WEB \b0\fs20\par
\par
\par
\b 13.1 En-tetes HTTP \b0\par
\par
{\f1     header("Content-Type: text/html; charset=UTF-8");}\par
{\f1     header("Location: /nouvelle-page.php");}\par
{\f1     header("HTTP/1.1 404 Not Found");}\par
{\f1     http_response_code(200);}\par
\par
\par
\b 13.2 Sessions \b0\par
\par
{\f1     session_start();}\par
{\f1     $_SESSION["utilisateur"] = "Alice";}\par
{\f1     echo $_SESSION["utilisateur"];}\par
{\f1     session_destroy();}\par
\par
\par
\b 13.3 Cookies \b0\par
\par
{\f1     setcookie("nom", "valeur", time() + 3600, "/");}\par
{\f1     echo $_COOKIE["nom"];}\par
\par
\par
\b 13.4 Recuperation de donnees \b0\par
\par
{\f1     // Donnees GET (URL : ?nom=Alice&age=30)}\par
{\f1     $nom = $_GET["nom"];}\par
\par
{\f1     // Donnees POST (formulaire)}\par
{\f1     $nom = $_POST["nom"];}\par
\par
{\f1     // Filtrage et validation}\par
{\f1     $email = filter_input(INPUT_POST, "email", FILTER_VALIDATE_EMAIL);}\par
{\f1     $age = filter_var($_POST["age"], FILTER_VALIDATE_INT);}\par
\par
\par
\b 13.5 Envoi de fichiers \b0\par
\par
{\f1     // Fichier envoye via formulaire (enctype="multipart/form-data")}\par
{\f1     $fichier = $_FILES["document"];}\par
{\f1     $fichier["name"]       // Nom original}\par
{\f1     $fichier["type"]       // Type MIME}\par
{\f1     $fichier["size"]       // Taille en octets}\par
{\f1     $fichier["tmp_name"]   // Chemin temporaire}\par
{\f1     $fichier["error"]      // Code d'erreur}\par
\par
{\f1     move_uploaded_file($fichier["tmp_name"], "/chemin/destination");}\par
\par
\par
