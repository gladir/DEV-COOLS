{\footnote # IDH_PHP_01}
{\footnote $ PHP - SYNTAXE DE BASE}
{\footnote K PHP syntaxe;balises;commentaires;casse}
\b\fs24 SYNTAXE DE BASE \b0\fs20\par
\par
\par
\b 1.1 Balises PHP \b0\par
\par
{\f1   Le code PHP est delimite par des balises :}\par
\par
{\f1     <?php ... ?>          Balise standard (recommandee)}\par
{\f1     <?= expr ?>           Balise courte d'affichage (echo)}\par
\par
\par
\b 1.2 Instructions et separateurs \b0\par
\par
{\f1   Chaque instruction se termine par un point-virgule :}\par
\par
{\f1     $x = 10;}\par
{\f1     echo "Bonjour";}\par
\par
\par
\b 1.3 Commentaires \b0\par
\par
{\f1     // Commentaire sur une ligne}\par
{\f1     # Commentaire sur une ligne (style shell)}\par
{\f1     /* Commentaire}\par
{\f1        sur plusieurs lignes */}\par
{\f1     /** Commentaire de documentation (PHPDoc) */}\par
\par
\par
\b 1.4 Sensibilite a la casse \b0\par
\par
{\f1   Les noms de variables sont sensibles a la casse :}\par
\par
{\f1     $nom et $Nom sont deux variables differentes.}\par
\par
{\f1   Les mots-clefs, noms de fonctions et noms de classes ne sont}\par
{\f1   pas sensibles a la casse :}\par
\par
{\f1     echo, ECHO, Echo sont equivalents.}\par
\par
\par
