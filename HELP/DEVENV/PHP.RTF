{\footnote # IDH_PHP_12}
{\footnote $ PHP - FONCTIONS INTEGREES PRINCIPALES}
{\footnote K PHP fonctions integrees;chaine;tableau;math;date;fichier}
\b\fs24 FONCTIONS INTEGREES PRINCIPALES \b0\fs20\par
\par
\par
\b 12.1 Fonctions mathematiques \b0\par
\par
{\f1   Fonction           Description}\par
{\f1   ---------------    -------------------------------------------}\par
{\f1   abs($n)            Valeur absolue}\par
{\f1   ceil($n)           Arrondi superieur}\par
{\f1   floor($n)          Arrondi inferieur}\par
{\f1   round($n, $p)      Arrondi a la precision donnee}\par
{\f1   max($a, $b)        Maximum}\par
{\f1   min($a, $b)        Minimum}\par
{\f1   pow($b, $e)        Puissance}\par
{\f1   sqrt($n)           Racine carree}\par
{\f1   log($n)            Logarithme naturel}\par
{\f1   log10($n)          Logarithme base 10}\par
{\f1   rand($min, $max)   Nombre aleatoire}\par
{\f1   mt_rand($min,$max) Nombre aleatoire (Mersenne Twister)}\par
{\f1   random_int($m,$n)  Nombre aleatoire cryptographique}\par
{\f1   pi()               Valeur de Pi}\par
{\f1   fmod($a, $b)       Modulo flottant}\par
{\f1   intdiv($a, $b)     Division entiere}\par
{\f1   M_PI               Constante Pi}\par
{\f1   M_E                Constante e}\par
\par
\par
\b 12.2 Fonctions de date et heure \b0\par
\par
{\f1   Fonction                Description}\par
{\f1   ---------------------   -------------------------------------------}\par
{\f1   time()                  Timestamp Unix actuel}\par
{\f1   date($format, $t)       Formater une date}\par
{\f1   mktime(h,m,s,M,j,A)    Creer un timestamp}\par
{\f1   strtotime($s)           Convertir une chaine en timestamp}\par
{\f1   microtime(true)         Temps en microsecondes}\par
{\f1   checkdate($m, $j, $a)   Verifier une date}\par
\par
{\f1   Classe DateTime :}\par
\par
{\f1     $dt = new DateTime("2024-01-15");}\par
{\f1     $dt = new DateTime("now");}\par
{\f1     echo $dt->format("Y-m-d H:i:s");}\par
{\f1     $dt->modify("+1 day");}\par
{\f1     $diff = $dt1->diff($dt2);}\par
\par
{\f1   Classe DateTimeImmutable :}\par
\par
{\f1     $dt = new DateTimeImmutable("now");}\par
{\f1     $dt2 = $dt->modify("+1 hour");   // $dt n'est pas modifie}\par
\par
\par
\b 12.3 Fonctions de fichiers \b0\par
\par
{\f1   Fonction                    Description}\par
{\f1   -------------------------   -------------------------------------------}\par
{\f1   file_get_contents($f)       Lire un fichier entier}\par
{\f1   file_put_contents($f, $d)   Ecrire dans un fichier}\par
{\f1   file($f)                    Lire un fichier en tableau de lignes}\par
