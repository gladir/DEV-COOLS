{\footnote # IDH_PHP_07}
{\footnote $ PHP - CHAINES DE CARACTERES}
{\footnote K PHP chaines;simple;double;heredoc;nowdoc;concatenation}
\b\fs24 CHAINES DE CARACTERES \b0\fs20\par
\par
\par
\b 7.1 Types de chaines \b0\par
\par
{\f1   Guillemets simples (pas d'interpolation) :}\par
\par
{\f1     $s = 'Texte litteral avec \\'apostrophe\\'';}\par
\par
{\f1   Guillemets doubles (interpolation de variables) :}\par
\par
{\f1     $nom = "PHP";}\par
{\f1     $s = "Bonjour $nom";}\par
{\f1     $s = "Version \{$tableau['clef']\}";}\par
\par
{\f1   Heredoc (interpolation) :}\par
\par
{\f1     $texte = <<<EOT}\par
{\f1     Texte sur}\par
{\f1     plusieurs lignes avec $variable}\par
{\f1     EOT;}\par
\par
{\f1   Nowdoc (pas d'interpolation) :}\par
\par
{\f1     $texte = <<<'EOT'}\par
{\f1     Texte litteral sur}\par
{\f1     plusieurs lignes}\par
{\f1     EOT;}\par
\par
\par
\b 7.2 Fonctions de chaines principales \b0\par
\par
{\f1   Fonction             Description}\par
{\f1   ---------------      -------------------------------------------}\par
{\f1   strlen($s)           Longueur de la chaine}\par
{\f1   strtolower($s)       Convertir en minuscules}\par
{\f1   strtoupper($s)       Convertir en majuscules}\par
{\f1   trim($s)             Supprimer les espaces en debut et fin}\par
{\f1   ltrim($s)            Supprimer les espaces en debut}\par
{\f1   rtrim($s)            Supprimer les espaces en fin}\par
{\f1   substr($s, $d, $l)   Extraire une sous-chaine}\par
{\f1   strpos($s, $c)       Position d'une sous-chaine}\par
{\f1   str_replace($c,$r,$s) Remplacer dans une chaine}\par
{\f1   str_contains($s,$c)  Verifier si contient (PHP 8.0)}\par
{\f1   str_starts_with($s,$p) Verifier le debut (PHP 8.0)}\par
{\f1   str_ends_with($s,$p)   Verifier la fin (PHP 8.0)}\par
{\f1   explode($d, $s)      Decouper en tableau}\par
{\f1   implode($d, $a)      Joindre un tableau en chaine}\par
{\f1   sprintf($fmt, ...)   Formatage de chaine}\par
{\f1   number_format($n)    Formatage de nombre}\par
{\f1   str_repeat($s, $n)   Repeter une chaine}\par
{\f1   str_pad($s,$l,$c,$t) Completer une chaine}\par
{\f1   ucfirst($s)          Premiere lettre en majuscule}\par
{\f1   lcfirst($s)          Premiere lettre en minuscule}\par
{\f1   ucwords($s)          Premiere lettre de chaque mot en majuscule}\par
{\f1   nl2br($s)            Convertir les retours a la ligne en <br>}\par
{\f1   htmlspecialchars($s) Echapper les caracteres HTML}\par
{\f1   htmlentities($s)     Convertir en entites HTML}\par
{\f1   strip_tags($s)       Supprimer les balises HTML}\par
{\f1   md5($s)              Hachage MD5}\par
{\f1   sha1($s)             Hachage SHA1}\par
{\f1   base64_encode($s)    Encodage Base64}\par
{\f1   base64_decode($s)    Decodage Base64}\par
{\f1   urlencode($s)        Encodage URL}\par
{\f1   urldecode($s)        Decodage URL}\par
{\f1   json_encode($v)      Encodage JSON}\par
{\f1   json_decode($s)      Decodage JSON}\par
\par
\par
\b 7.3 Expressions regulieres (PCRE) \b0\par
\par
{\f1     preg_match($motif, $sujet, $resultats)}\par
{\f1     preg_match_all($motif, $sujet, $resultats)}\par
{\f1     preg_replace($motif, $remplacement, $sujet)}\par
{\f1     preg_split($motif, $sujet)}\par
\par
{\f1   Exemple :}\par
\par
{\f1     if (preg_match('/^[a-z]+$/i', $chaine)) \{}\par
{\f1         echo "Que des lettres";}\par
{\f1     \}}\par
\par
\par
