{\footnote # IDH_PHP_06}
{\footnote $ PHP - FONCTIONS}
{\footnote K PHP fonctions;arguments;valeur retour;variadic;type hint;fleche}
\b\fs24 FONCTIONS \b0\fs20\par
\par
\par
\b 6.1 Declaration de fonction \b0\par
\par
{\f1     function nom($param1, $param2) \{}\par
{\f1         // corps de la fonction}\par
{\f1         return $resultat;}\par
{\f1     \}}\par
\par
\par
\b 6.2 Parametres par defaut \b0\par
\par
{\f1     function saluer($nom = "monde") \{}\par
{\f1         echo "Bonjour $nom";}\par
{\f1     \}}\par
\par
\par
\b 6.3 Declaration de type (type hints) \b0\par
\par
{\f1     function additionner(int $a, int $b): int \{}\par
{\f1         return $a + $b;}\par
{\f1     \}}\par
\par
{\f1   Types acceptes pour les parametres et le retour :}\par
\par
{\f1     int, float, string, bool, array, callable, iterable,}\par
{\f1     object, mixed, void, never, null, false, true,}\par
{\f1     self, parent, static, NomDeClasse, ?Type (nullable)}\par
\par
\par
\b 6.4 Types d'union et d'intersection (PHP 8.0 / 8.1) \b0\par
\par
{\f1     function traiter(int|string $valeur): int|false \{}\par
{\f1         // ...}\par
{\f1     \}}\par
\par
{\f1     function filtrer(Iterator&Countable $collection): void \{}\par
{\f1         // ...}\par
{\f1     \}}\par
\par
\par
\b 6.5 Passage par reference \b0\par
\par
{\f1     function doubler(&$valeur) \{}\par
{\f1         $valeur *= 2;}\par
{\f1     \}}\par
\par
{\f1     $x = 5;}\par
{\f1     doubler($x);    // $x vaut maintenant 10}\par
\par
\par
\b 6.6 Nombre variable d'arguments \b0\par
\par
{\f1     function somme(int ...$nombres): int \{}\par
{\f1         return array_sum($nombres);}\par
{\f1     \}}\par
\par
{\f1     somme(1, 2, 3);    // 6}\par
\par
\par
\b 6.7 Arguments nommes (PHP 8.0) \b0\par
\par
{\f1     function creerUtilisateur(string $nom, int $age, string $ville) \{}\par
{\f1         // ...}\par
{\f1     \}}\par
\par
{\f1     creerUtilisateur(nom: "Alice", age: 30, ville: "Paris");}\par
\par
\par
\b 6.8 Fonctions anonymes (closures) \b0\par
\par
{\f1     $saluer = function($nom) \{}\par
{\f1         echo "Bonjour $nom";}\par
{\f1     \};}\par
\par
{\f1     $saluer("Alice");}\par
\par
{\f1   Capture de variables :}\par
\par
{\f1     $message = "Bonjour";}\par
{\f1     $fn = function($nom) use ($message) \{}\par
{\f1         echo "$message $nom";}\par
{\f1     \};}\par
\par
\par
\b 6.9 Fonctions flechees (PHP 7.4) \b0\par
\par
{\f1     $double = fn($x) => $x * 2;}\par
\par
{\f1   Les fonctions flechees capturent automatiquement les variables}\par
{\f1   du scope parent par valeur.}\par
\par
\par
\b 6.10 Fonctions de premiere classe (PHP 8.1) \b0\par
\par
{\f1     $fn = strlen(...);}\par
{\f1     echo $fn("test");    // 4}\par
\par
\par
