{\footnote # IDH_PHP_05}
{\footnote $ PHP - STRUCTURES DE CONTROLE}
{\footnote K PHP structures controle;if;switch;while;for;foreach;break;continue;match}
\b\fs24 STRUCTURES DE CONTROLE \b0\fs20\par
\par
\par
\b 5.1 Conditions \b0\par
\par
{\f1   if / elseif / else :}\par
\par
{\f1     if ($a > $b) \{}\par
{\f1         echo "a est plus grand";}\par
{\f1     \} elseif ($a == $b) \{}\par
{\f1         echo "a est egal a b";}\par
{\f1     \} else \{}\par
{\f1         echo "b est plus grand";}\par
{\f1     \}}\par
\par
{\f1   switch :}\par
\par
{\f1     switch ($couleur) \{}\par
{\f1         case "rouge":}\par
{\f1             echo "Rouge";}\par
{\f1             break;}\par
{\f1         case "bleu":}\par
{\f1             echo "Bleu";}\par
{\f1             break;}\par
{\f1         default:}\par
{\f1             echo "Autre";}\par
{\f1             break;}\par
{\f1     \}}\par
\par
{\f1   match (PHP 8.0) :}\par
\par
{\f1     $resultat = match ($code) \{}\par
{\f1         200     => "OK",}\par
{\f1         404     => "Non trouve",}\par
{\f1         500     => "Erreur serveur",}\par
{\f1         default => "Inconnu",}\par
{\f1     \};}\par
\par
\par
\b 5.2 Boucles \b0\par
\par
{\f1   while :}\par
\par
{\f1     while ($i < 10) \{}\par
{\f1         echo $i;}\par
{\f1         $i++;}\par
{\f1     \}}\par
\par
{\f1   do...while :}\par
\par
{\f1     do \{}\par
{\f1         echo $i;}\par
{\f1         $i++;}\par
{\f1     \} while ($i < 10);}\par
\par
{\f1   for :}\par
\par
{\f1     for ($i = 0; $i < 10; $i++) \{}\par
{\f1         echo $i;}\par
{\f1     \}}\par
\par
{\f1   foreach :}\par
\par
{\f1     foreach ($tableau as $valeur) \{}\par
{\f1         echo $valeur;}\par
{\f1     \}}\par
\par
{\f1     foreach ($tableau as $clef => $valeur) \{}\par
{\f1         echo "$clef : $valeur";}\par
{\f1     \}}\par
\par
\par
\b 5.3 Controle de boucle \b0\par
\par
{\f1     break;           Sortir de la boucle}\par
{\f1     break N;         Sortir de N niveaux de boucles}\par
{\f1     continue;        Passer a l'iteration suivante}\par
{\f1     continue N;      Passer a l'iteration suivante de N niveaux}\par
\par
\par
\b 5.4 Inclusion de fichiers \b0\par
\par
{\f1     include "fichier.php";         Inclure (avertissement si absent)}\par
{\f1     include_once "fichier.php";    Inclure une seule fois}\par
{\f1     require "fichier.php";         Inclure (erreur fatale si absent)}\par
{\f1     require_once "fichier.php";    Inclure une seule fois (erreur fatale)}\par
\par
\par
\b 5.5 Syntaxe alternative \b0\par
\par
{\f1   PHP supporte une syntaxe alternative pour les structures de}\par
{\f1   controle, utile dans les gabarits HTML :}\par
\par
{\f1     if ($cond):}\par
{\f1         ...}\par
{\f1     elseif ($cond2):}\par
{\f1         ...}\par
{\f1     else:}\par
{\f1         ...}\par
{\f1     endif;}\par
\par
{\f1     while ($cond):}\par
{\f1         ...}\par
{\f1     endwhile;}\par
\par
{\f1     for (...):}\par
{\f1         ...}\par
{\f1     endfor;}\par
\par
{\f1     foreach ($arr as $v):}\par
{\f1         ...}\par
{\f1     endforeach;}\par
\par
{\f1     switch ($v):}\par
{\f1         ...}\par
{\f1     endswitch;}\par
\par
\par
