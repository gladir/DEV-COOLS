{\footnote # IDH_FORTRAN77_05}
{\footnote $ FORTRAN 77 - Operateurs}
{\footnote K FORTRAN 77 operateurs;arithmetique;**;.EQ. .NE. .LT. .LE. .GT. .GE.;.NOT. .AND. .OR. .EQV. .NEQV.;concatenation //;precedence;conversions implicites}
\b\fs24 Operateurs \b0\fs20\par
\par
Arithmetiques : + - * / **         (** = puissance)\par
Relationnels  : .EQ. .NE. .LT. .LE. .GT. .GE.\par
Logiques      : .NOT. .AND. .OR. .EQV. .NEQV.\par
Caracteres    : //                 (concatenation)\par
Affectation   : =\par
\par
Precedence (du plus prioritaire au moins) :\par
{\f1   1. **         (associativite droite : 2**3**2 = 2**(3**2) = 512)}\par
{\f1   2. * /}\par
{\f1   3. + - (unaires puis binaires)}\par
{\f1   4. //}\par
{\f1   5. .EQ. .NE. .LT. .LE. .GT. .GE.}\par
{\f1   6. .NOT.}\par
{\f1   7. .AND.}\par
{\f1   8. .OR.}\par
{\f1   9. .EQV. .NEQV.}\par
\par
Conversions implicites : INTEGER -> REAL -> DOUBLE PRECISION -> COMPLEX dans\par
les expressions mixtes.\par
\par
\par
\par
