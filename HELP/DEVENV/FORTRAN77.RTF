{\footnote # IDH_FORTRAN77_06}
{\footnote $ FORTRAN 77 - Instructions de controle}
{\footnote K FORTRAN 77 controle;IF logique;IF arithmetique;IF THEN ELSE END IF;DO;CONTINUE;GOTO;GOTO calcule;STOP;END;PAUSE;RETURN}
\b\fs24 Instructions de controle \b0\fs20\par
\par
6.1 Affectation\par
{\f1         X = 3.14}\par
{\f1         T(I) = T(I) + 1.0}\par
{\f1         NOM = 'DUPONT'}\par
\par
6.2 IF logique (une ligne)\par
{\f1         IF (X .GT. 0.0) Y = SQRT(X)}\par
\par
6.3 IF arithmetique (legacy FORTRAN II/IV, deprecie)\par
{\f1         IF (X) 10, 20, 30}\par
C       saute en 10 si X<0, 20 si X=0, 30 si X>0\par
\par
6.4 IF/THEN/ELSE/ENDIF (bloc, ajoute en FORTRAN 77)\par
{\f1         IF (X .GT. 0.0) THEN}\par
{\f1           Y = LOG(X)}\par
{\f1         ELSE IF (X .EQ. 0.0) THEN}\par
{\f1           Y = 0.0}\par
{\f1         ELSE}\par
{\f1           Y = -1.0}\par
{\f1         END IF}\par
\par
6.5 DO (boucle iterative)\par
{\f1         DO 10 I = 1, 100}\par
{\f1           SOMME = SOMME + T(I)}\par
{\f1    10   CONTINUE}\par
\par
Avec pas explicite :\par
{\f1         DO 20 I = 100, 1, -1}\par
{\f1           T(I) = 0.0}\par
{\f1    20   CONTINUE}\par
\par
Forme DO/END DO (extension MIL-STD-1753, tres repandue) :\par
{\f1         DO I = 1, N}\par
{\f1           T(I) = I * I}\par
{\f1         END DO}\par
\par
6.6 GOTO\par
{\f1         GOTO 100}\par
{\f1         GOTO (10, 20, 30), I      ! GOTO calcule}\par
{\f1         GOTO LBL, (10, 20, 30)    ! GOTO assigne (deprecie)}\par
\par
6.7 CONTINUE\par
{\f1         Instruction nulle, sert souvent de point d'arrivee pour DO ou GOTO.}\par
\par
6.8 STOP et END\par
{\f1         STOP                       ! arret normal}\par
{\f1         STOP 'MESSAGE'             ! arret avec message}\par
{\f1         STOP 99                    ! code de sortie}\par
{\f1         END                        ! fin d'unite (obligatoire)}\par
\par
6.9 PAUSE\par
{\f1         PAUSE 'APPUYEZ SUR ENTREE' ! suspend l'execution (deprecie)}\par
\par
6.10 RETURN\par
{\f1         RETURN                     ! retour de SUBROUTINE/FUNCTION}\par
{\f1         RETURN 1                   ! retour alternatif (alternate return)}\par
\par
\par
\par
