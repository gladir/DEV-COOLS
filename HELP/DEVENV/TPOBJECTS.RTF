{\footnote # IDH_TPOBJ_32}
{\footnote $ Programmation Objet - EXEMPLES COMPLETS}
{\footnote K Turbo Pascal;Programmation Objet;EXEMPLES COMPLETS}
\b\fs24 EXEMPLES COMPLETS \b0\fs20\par
\par
{\f1   --- Exemple 1 : Collection simple ---}\par
\par
{\f1   program CollectionDemo;}\par
{\f1   uses Objects;}\par
{\f1   type}\par
{\f1     PAnimal = ^TAnimal;}\par
{\f1     TAnimal = object(TObject)}\par
{\f1       Nom : PString;}\par
{\f1       Pattes : Integer;}\par
{\f1       constructor Init(const ANom : String; APattes : Integer);}\par
{\f1       destructor Done; virtual;}\par
{\f1     end;}\par
\par
{\f1   constructor TAnimal.Init(const ANom: String; APattes: Integer);}\par
{\f1   begin}\par
{\f1     inherited Init;}\par
{\f1     Nom := NewStr(ANom);}\par
{\f1     Pattes := APattes;}\par
{\f1   end;}\par
\par
{\f1   destructor TAnimal.Done;}\par
{\f1   begin}\par
{\f1     DisposeStr(Nom);}\par
{\f1     inherited Done;}\par
{\f1   end;}\par
\par
{\f1   procedure AfficherAnimal(P : PAnimal); far;}\par
{\f1   begin}\par
{\f1     WriteLn(P^.Nom^, ' : ', P^.Pattes, ' pattes');}\par
{\f1   end;}\par
\par
{\f1   var}\par
{\f1     C : PCollection;}\par
{\f1   begin}\par
{\f1     C := New(PCollection, Init(10, 5));}\par
{\f1     C^.Insert(New(PAnimal, Init('Chat', 4)));}\par
{\f1     C^.Insert(New(PAnimal, Init('Poulet', 2)));}\par
{\f1     C^.Insert(New(PAnimal, Init('Araign??e', 8)));}\par
\par
{\f1     WriteLn('Nombre d''animaux : ', C^.Count);}\par
{\f1     C^.ForEach(@AfficherAnimal);}\par
\par
{\f1     Dispose(C, Done);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : Collection tri??e de cha??nes ---}\par
\par
{\f1   program StringCollDemo;}\par
{\f1   uses Objects;}\par
\par
{\f1   procedure AfficherStr(P : PString); far;}\par
{\f1   begin}\par
{\f1     if P <> nil then WriteLn(P^);}\par
{\f1   end;}\par
\par
{\f1   var}\par
{\f1     SC : PStringCollection;}\par
{\f1   begin}\par
{\f1     SC := New(PStringCollection, Init(20, 5));}\par
{\f1     SC^.Insert(NewStr('Orange'));}\par
{\f1     SC^.Insert(NewStr('Pomme'));}\par
{\f1     SC^.Insert(NewStr('Banane'));}\par
{\f1     SC^.Insert(NewStr('Cerise'));}\par
{\f1     SC^.Insert(NewStr('Ananas'));}\par
\par
{\f1     WriteLn('Fruits tri??s :');}\par
{\f1     SC^.ForEach(@AfficherStr);}\par
{\f1     \{ Affiche : Ananas, Banane, Cerise, Orange, Pomme \}}\par
\par
{\f1     Dispose(SC, Done);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Flux fichier avec tampon ---}\par
\par
{\f1   program StreamDemo;}\par
{\f1   uses Objects;}\par
{\f1   var}\par
{\f1     S   : TBufStream;}\par
{\f1     I   : Integer;}\par
{\f1     Buf : array[1..100] of Integer;}\par
{\f1   begin}\par
{\f1     \{ ??criture \}}\par
{\f1     S.Init('DONNEES.DAT', stCreate, 1024);}\par
{\f1     for I := 1 to 100 do}\par
{\f1       Buf[I] := I * I;}\par
{\f1     S.Write(Buf, SizeOf(Buf));}\par
{\f1     S.Done;}\par
\par
{\f1     \{ Lecture \}}\par
{\f1     FillChar(Buf, SizeOf(Buf), 0);}\par
{\f1     S.Init('DONNEES.DAT', stOpenRead, 1024);}\par
{\f1     S.Read(Buf, SizeOf(Buf));}\par
{\f1     if S.Status = stOk then}\par
{\f1       for I := 1 to 5 do}\par
{\f1         WriteLn('Buf[', I, '] = ', Buf[I]);}\par
{\f1     S.Done;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 4 : S??rialisation d'objets (Get/Put) ---}\par
\par
{\f1   program SerialDemo;}\par
{\f1   uses Objects;}\par
\par
{\f1   const}\par
{\f1     RMyRec : TStreamRec = (}\par
{\f1       ObjType: 100;}\par
{\f1       VmtLink: Ofs(TypeOf(TStringCollection)^);}\par
{\f1       Load:    @TStringCollection.Load;}\par
{\f1       Store:   @TStringCollection.Store);}\par
\par
{\f1   var}\par
{\f1     S  : TBufStream;}\par
{\f1     SC : PStringCollection;}\par
{\f1     P  : PString;}\par
{\f1     I  : Integer;}\par
{\f1   begin}\par
{\f1     RegisterType(RCollection);}\par
{\f1     RegisterType(RStringCollection);}\par
\par
{\f1     \{ ??criture \}}\par
{\f1     SC := New(PStringCollection, Init(10, 5));}\par
{\f1     SC^.Insert(NewStr('Alpha'));}\par
{\f1     SC^.Insert(NewStr('Beta'));}\par
{\f1     SC^.Insert(NewStr('Gamma'));}\par
\par
{\f1     S.Init('STRINGS.DAT', stCreate, 1024);}\par
{\f1     S.Put(SC);}\par
{\f1     S.Done;}\par
{\f1     Dispose(SC, Done);}\par
\par
{\f1     \{ Lecture \}}\par
{\f1     S.Init('STRINGS.DAT', stOpenRead, 1024);}\par
{\f1     SC := PStringCollection(S.Get);}\par
{\f1     S.Done;}\par
\par
{\f1     if SC <> nil then}\par
{\f1     begin}\par
{\f1       WriteLn('Cha??nes relues :');}\par
{\f1       for I := 0 to SC^.Count - 1 do}\par
{\f1       begin}\par
{\f1         P := SC^.At(I);}\par
{\f1         if P <> nil then WriteLn('  ', P^);}\par
{\f1       end;}\par
{\f1       Dispose(SC, Done);}\par
{\f1     end;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 5 : Rectangles ---}\par
\par
{\f1   program RectDemo;}\par
{\f1   uses Objects;}\par
{\f1   var}\par
{\f1     R1, R2 : TRect;}\par
{\f1     P      : TPoint;}\par
{\f1   begin}\par
{\f1     R1.Assign(10, 10, 50, 40);}\par
{\f1     R2.Assign(30, 20, 70, 60);}\par
\par
{\f1     WriteLn('R1 vide ? ', R1.Empty);}\par
\par
{\f1     P.X := 35; P.Y := 25;}\par
{\f1     WriteLn('R1 contient (35,25) ? ', R1.Contains(P));}\par
\par
{\f1     R1.Intersect(R2);}\par
{\f1     WriteLn('Intersection : (',}\par
{\f1       R1.A.X, ',', R1.A.Y, ') - (',}\par
{\f1       R1.B.X, ',', R1.B.Y, ')');}\par
{\f1     \{ R??sultat : (30,20) - (50,40) \}}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 6 : Liste de cha??nes (StringList) ---}\par
\par
{\f1   program StringListDemo;}\par
{\f1   uses Objects;}\par
{\f1   var}\par
{\f1     S   : TBufStream;}\par
{\f1     SLM : TStrListMaker;}\par
{\f1     SL  : PStringList;}\par
{\f1   begin}\par
{\f1     RegisterType(RStringList);}\par
{\f1     RegisterType(RStrListMaker);}\par
\par
{\f1     \{ Cr??ation \}}\par
{\f1     S.Init('MESSAGES.DAT', stCreate, 1024);}\par
{\f1     SLM.Init(2048, 256);}\par
{\f1     SLM.Put(0, 'Erreur inconnue');}\par
{\f1     SLM.Put(1, 'Fichier non trouv??');}\par
{\f1     SLM.Put(2, 'Acc??s refus??');}\par
{\f1     SLM.Put(3, 'M??moire insuffisante');}\par
{\f1     SLM.Store(S);}\par
{\f1     SLM.Done;}\par
{\f1     S.Done;}\par
\par
{\f1     \{ Lecture \}}\par
{\f1     S.Init('MESSAGES.DAT', stOpenRead, 1024);}\par
{\f1     SL := New(PStringList, Load(S));}\par
{\f1     WriteLn(SL^.Get(0));  \{ Erreur inconnue \}}\par
{\f1     WriteLn(SL^.Get(2));  \{ Acc??s refus?? \}}\par
{\f1     Dispose(SL, Done);}\par
{\f1     S.Done;}\par
{\f1   end.}\par
\par
