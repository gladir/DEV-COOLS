{\footnote # IDH_TPOBJ_13}
{\footnote $ Programmation Objet - OBJET TOBJECT}
{\footnote K Turbo Pascal;Programmation Objet;OBJET TOBJECT}
\b\fs24 OBJET TOBJECT \b0\fs20\par
\par
{\f1   PObject = ^TObject;}\par
{\f1   TObject = object}\par
{\f1     constructor Init;}\par
{\f1     procedure   Free;}\par
{\f1     destructor  Done; virtual;}\par
{\f1   end;}\par
{\f1   Objet racine de toute la hi??rarchie. Tout objet de l'unit??}\par
{\f1   Objects descend de TObject.}\par
\par
{\f1   constructor Init;}\par
{\f1   Constructeur de base. Initialise l'objet (la VMT est connect??e}\par
{\f1   automatiquement par le compilateur lors de l'appel au}\par
{\f1   constructeur). Ne fait rien d'autre dans TObject.}\par
\par
{\f1   procedure Free;}\par
{\f1   Lib??re l'objet s'il n'est pas nil. Appelle le destructeur Done}\par
{\f1   puis lib??re la m??moire sur le tas. ??quivalent s??r de :}\par
{\f1     if @Self <> nil then Dispose(PObject(@Self), Done);}\par
\par
{\f1   Toujours utiliser Free plut??t que Dispose directement pour}\par
{\f1   ??viter les erreurs sur pointeurs nil.}\par
\par
{\f1   destructor Done; virtual;}\par
{\f1   Destructeur virtuel. Ne fait rien dans TObject. Doit ??tre}\par
{\f1   surcharg?? dans les descendants pour lib??rer les ressources}\par
{\f1   (m??moire allou??e, fichiers ouverts, etc.).}\par
\par
{\f1   Exemple :}\par
{\f1     type}\par
{\f1       PMonObjet = ^TMonObjet;}\par
{\f1       TMonObjet = object(TObject)}\par
{\f1         Nom : PString;}\par
{\f1         constructor Init(const ANom : String);}\par
{\f1         destructor Done; virtual;}\par
{\f1       end;}\par
\par
{\f1     constructor TMonObjet.Init(const ANom : String);}\par
{\f1     begin}\par
{\f1       inherited Init;}\par
{\f1       Nom := NewStr(ANom);}\par
{\f1     end;}\par
\par
{\f1     destructor TMonObjet.Done;}\par
{\f1     begin}\par
{\f1       DisposeStr(Nom);}\par
{\f1       inherited Done;}\par
{\f1     end;}\par
