{\footnote # IDH_JOVIAL_07}
{\footnote $ JOVIAL - Procedures et fonctions}
{\footnote K JOVIAL procedures;PROC;RETURNS;parametres;IN OUT INOUT;appel}
\b\fs24 Procedures et fonctions \b0\fs20\par
\par
Definition :\par
{\f1   PROC NOM (P1 : INTEGER 16 S; P2 : FLOATING) RETURNS (FLOATING);}\par
{\f1    BEGIN}\par
{\f1     ITEM TEMP FLOATING;}\par
{\f1     TEMP = P1 * P2;}\par
{\f1     RETURN TEMP;}\par
{\f1    END}\par
\par
Sans valeur de retour :\par
{\f1   PROC AFFICHE (MSG : CHAR 80);}\par
{\f1    BEGIN}\par
{\f1     OUTPUT MSG;}\par
{\f1    END}\par
\par
Modes de passage :\par
- IN     : valeur (par defaut pour types simples).\par
- OUT    : sortie (variable assignee par la procedure).\par
- INOUT  : entree-sortie (reference).\par
\par
{\f1   PROC ECHANGE (INOUT A : INTEGER 16; INOUT B : INTEGER 16);}\par
{\f1    BEGIN}\par
{\f1     ITEM T INTEGER 16;}\par
{\f1     T = A;  A = B;  B = T;}\par
{\f1    END}\par
\par
Appel :\par
{\f1   RES = NOM(10, 3.14);}\par
{\f1   AFFICHE('BONJOUR');}\par
\par
\par
\par
