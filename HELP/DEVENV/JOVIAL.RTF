{\footnote # IDH_JOVIAL_06}
{\footnote $ JOVIAL - Instructions de controle}
{\footnote K JOVIAL controle;IF THEN ELSE;CASE;FOR STEP UNTIL;WHILE;GOTO;EXIT;STOP;RETURN}
\b\fs24 Instructions de controle \b0\fs20\par
\par
6.1 Affectation\par
{\f1   X = 10;}\par
{\f1   PISTES.X(I) = PISTES.X(I) + DX;}\par
\par
6.2 IF/THEN/ELSE\par
{\f1   IF X GR 0 THEN}\par
{\f1    Y = 1;}\par
{\f1   ELSE}\par
{\f1    Y = -1;}\par
\par
Forme bloc :\par
{\f1   IF COND THEN}\par
{\f1    BEGIN}\par
{\f1     "..."}\par
{\f1    END}\par
{\f1   ELSE}\par
{\f1    BEGIN}\par
{\f1     "..."}\par
{\f1    END}\par
\par
6.3 CASE (instruction multibranche)\par
{\f1   CASE MODE OF}\par
{\f1    BEGIN}\par
{\f1     (V'INIT'): INITIALISER();}\par
{\f1     (V'RUN'):  EXECUTER();}\par
{\f1     (V'STOP'): ARRETER();}\par
{\f1     DEFAULT:   ERREUR();}\par
{\f1    END}\par
\par
6.4 FOR (boucle iterative)\par
{\f1   FOR I = 1 STEP 1 UNTIL 100 DO}\par
{\f1    BEGIN}\par
{\f1     SOMME = SOMME + T(I);}\par
{\f1    END}\par
\par
{\f1   FOR I = 0, I+2 WHILE I LS 100 DO ...}\par
\par
6.5 WHILE\par
{\f1   WHILE COND DO}\par
{\f1    BEGIN}\par
{\f1     "..."}\par
{\f1    END}\par
\par
6.6 GOTO / Label\par
{\f1   ETIQUETTE.}\par
{\f1    X = X + 1;}\par
{\f1    IF X LS 10 THEN GOTO ETIQUETTE;}\par
\par
6.7 EXIT et STOP\par
{\f1   EXIT;    " sortie de boucle "}\par
{\f1   STOP;    " arret du programme "}\par
\par
6.8 RETURN\par
{\f1   RETURN;}\par
{\f1   RETURN VALEUR;   " dans une fonction "}\par
\par
\par
\par
