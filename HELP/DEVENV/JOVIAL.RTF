{\footnote # IDH_JOVIAL_05}
{\footnote $ JOVIAL - Operateurs}
{\footnote K JOVIAL operateurs;arithmetique;relationnel;EQ NQ LS LQ GR GQ;logique;AND OR NOT XOR;bit-a-bit;BAND BOR BXOR;SHL SHR;precedence}
\b\fs24 Operateurs \b0\fs20\par
\par
Arithmetiques : + - * / MOD ABS\par
Relationnels  : EQ NQ LS LQ GR GQ   (ou == != < <= > >=)\par
Logiques      : AND OR NOT XOR EQV\par
Bit-a-bit     : BAND BOR BNOT BXOR\par
Decalage      : SHL n, SHR n, SHRA n (arithmetique)\par
Affectation   : =\par
\par
Precedence (du plus prioritaire au moins) :\par
{\f1   1. NOT BNOT unaire}\par
{\f1   2. * / MOD BAND}\par
{\f1   3. + - BOR BXOR}\par
{\f1   4. SHL SHR}\par
{\f1   5. EQ NQ LS LQ GR GQ}\par
{\f1   6. AND}\par
{\f1   7. OR XOR EQV}\par
\par
\par
\par
