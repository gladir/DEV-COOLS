{\footnote # IDH_JOVIAL_14}
{\footnote $ JOVIAL - Exemples de programmes}
{\footnote K JOVIAL exemples;Hello;somme tableau;factorielle;registre materiel;machine etats;STATUS CASE}
\b\fs24 Exemples de programmes \b0\fs20\par
\par
14.1 Hello World\par
\par
{\f1   PROGRAM HELLO;}\par
{\f1    START}\par
{\f1     OUTPUT 'BONJOUR LE MONDE';}\par
{\f1    TERM}\par
{\f1   END}\par
\par
14.2 Somme d'un tableau\par
\par
{\f1   PROGRAM SOMTAB;}\par
{\f1    ITEM I       INTEGER 16 U;}\par
{\f1    ITEM SOMME   INTEGER 32 S;}\par
{\f1    TABLE T (10) DENSE;}\par
{\f1     BEGIN}\par
{\f1      ITEM V INTEGER 16 S;}\par
{\f1     END}\par
{\f1    START}\par
{\f1     FOR I = 1 STEP 1 UNTIL 10 DO}\par
{\f1      BEGIN}\par
{\f1       T.V(I) = I * I;}\par
{\f1      END}\par
{\f1     SOMME = 0;}\par
{\f1     FOR I = 1 STEP 1 UNTIL 10 DO}\par
{\f1      BEGIN}\par
{\f1       SOMME = SOMME + T.V(I);}\par
{\f1      END}\par
{\f1     OUTPUT 'SOMME = ', SOMME;}\par
{\f1    TERM}\par
{\f1   END}\par
\par
14.3 Factorielle recursive\par
\par
{\f1   PROC FACT (N : INTEGER 16 U) RETURNS (INTEGER 32 U);}\par
{\f1    BEGIN}\par
{\f1     IF N LQ 1 THEN}\par
{\f1      RETURN 1;}\par
{\f1     ELSE}\par
{\f1      RETURN N * FACT(N-1);}\par
{\f1    END}\par
\par
14.4 Lecture d'un registre materiel\par
\par
{\f1   PROGRAM LIRE_ADC;}\par
{\f1    ITEM ADC_REG  INTEGER 16 U LOC V'FFE000'H;}\par
{\f1    ITEM VALEUR   INTEGER 16 U;}\par
{\f1    START}\par
{\f1     VALEUR = ADC_REG;}\par
{\f1     OUTPUT 'CAPTEUR = ', VALEUR;}\par
{\f1    TERM}\par
{\f1   END}\par
\par
14.5 Machine a etats avec STATUS et CASE\par
\par
{\f1   PROGRAM CONTROLEUR;}\par
{\f1    ITEM ETAT  STATUS (V'INIT', V'ARME', V'TIRE', V'STOP');}\par
{\f1    START}\par
{\f1     ETAT = V'INIT';}\par
{\f1     WHILE ETAT NQ V'STOP' DO}\par
{\f1      BEGIN}\par
{\f1       CASE ETAT OF}\par
{\f1        BEGIN}\par
{\f1         (V'INIT'): ETAT = V'ARME';}\par
{\f1         (V'ARME'): ETAT = V'TIRE';}\par
{\f1         (V'TIRE'): ETAT = V'STOP';}\par
{\f1        END}\par
{\f1      END}\par
{\f1    TERM}\par
{\f1   END}\par
\par
