{\footnote # IDH_ADA_13}
{\footnote $ Ada - BIBLIOTHEQUE STANDARD ET CONTENEURS (ADA 2005+)}
{\footnote K Ada bibliotheque standard;conteneurs;Ada.Containers}
\b\fs24 BIBLIOTHEQUE STANDARD ET CONTENEURS (ADA 2005+) \b0\fs20\par
\par
13.1 Conteneurs generiques (Ada.Containers)\par
\par
{\f1   Ada 2005 introduit une bibliotheque de conteneurs :}\par
\par
{\f1     Ada.Containers.Vectors}\par
{\f1       Tableau dynamique a acces indexe.}\par
\par
{\f1     Ada.Containers.Doubly_Linked_Lists}\par
{\f1       Liste doublement chainee.}\par
\par
{\f1     Ada.Containers.Hashed_Maps}\par
{\f1       Table de hachage (dictionnaire).}\par
\par
{\f1     Ada.Containers.Ordered_Maps}\par
{\f1       Arbre de recherche (dictionnaire ordonne).}\par
\par
{\f1     Ada.Containers.Hashed_Sets}\par
{\f1       Ensemble avec hachage.}\par
\par
{\f1     Ada.Containers.Ordered_Sets}\par
{\f1       Ensemble ordonne.}\par
\par
{\f1   Exemple d'utilisation :}\par
\par
{\f1     with Ada.Containers.Vectors;}\par
\par
{\f1     package Entiers is new Ada.Containers.Vectors}\par
{\f1       (Index_Type   => Natural,}\par
{\f1        Element_Type => Integer);}\par
\par
{\f1     V : Entiers.Vector;}\par
\par
{\f1     V.Append (42);}\par
{\f1     V.Append (17);}\par
{\f1     for E of V loop}\par
{\f1       Put_Line (Integer'Image (E));}\par
{\f1     end loop;}\par
\par
13.2 Chaines de caracteres\par
\par
{\f1     Ada.Strings.Fixed        Chaines de taille fixe}\par
{\f1     Ada.Strings.Bounded      Chaines de taille bornee}\par
{\f1     Ada.Strings.Unbounded    Chaines de taille illimitee}\par
{\f1     Ada.Strings.Maps         Tables de correspondance}\par
{\f1     Ada.Strings.Maps.Constants  Tables predefinies}\par
\par
{\f1   Exemple :}\par
{\f1     with Ada.Strings.Unbounded;}\par
{\f1     use Ada.Strings.Unbounded;}\par
\par
{\f1     S : Unbounded_String := To_Unbounded_String ("Hello");}\par
{\f1     S := S & " World";}\par
{\f1     Put_Line (To_String (S));}\par
\par
13.3 Entrees/Sorties\par
\par
{\f1     Ada.Text_IO               E/S texte}\par
{\f1     Ada.Text_IO.Integer_IO    E/S d'entiers}\par
{\f1     Ada.Text_IO.Float_IO      E/S de flottants}\par
{\f1     Ada.Text_IO.Enumeration_IO  E/S d'enumeres}\par
{\f1     Ada.Sequential_IO         E/S sequentielles}\par
{\f1     Ada.Direct_IO             E/S a acces direct}\par
{\f1     Ada.Streams.Stream_IO     E/S par flux (Ada 95+)}\par
\par
{\f1   Exemple (console) :}\par
{\f1     with Ada.Text_IO; use Ada.Text_IO;}\par
\par
{\f1     Put ("Entrez un nombre : ");}\par
{\f1     Get_Line (Ligne);}\par
{\f1     Put_Line ("Vous avez entre : " & Ligne);}\par
\par
13.3.1 Ada.Text_IO - Operations sur fichiers\par
\par
{\f1   Le paquetage Ada.Text_IO definit un type File_Type pour}\par
{\f1   les operations sur fichiers texte. Les modes disponibles sont}\par
{\f1   In_File (lecture), Out_File (ecriture) et Append_File (ajout).}\par
\par
{\f1   Types et constantes :}\par
{\f1     type File_Type is limited private;}\par
{\f1     type File_Mode is (In_File, Out_File, Append_File);}\par
\par
{\f1   Operations principales :}\par
\par
{\f1     procedure Create (File : in out File_Type;}\par
{\f1                       Mode : in File_Mode := Out_File;}\par
{\f1                       Name : in String := "");}\par
{\f1     -- Cree un nouveau fichier et l'ouvre dans le mode specifie.}\par
\par
{\f1     procedure Open (File : in out File_Type;}\par
{\f1                     Mode : in File_Mode;}\par
{\f1                     Name : in String);}\par
{\f1     -- Ouvre un fichier existant dans le mode specifie.}\par
\par
{\f1     procedure Close (File : in out File_Type);}\par
{\f1     -- Ferme le fichier.}\par
\par
{\f1     procedure Put (File : in File_Type; Item : in String);}\par
{\f1     -- Ecrit une chaine dans le fichier.}\par
\par
{\f1     procedure Put_Line (File : in File_Type; Item : in String);}\par
{\f1     -- Ecrit une chaine suivie d'un saut de ligne dans le fichier.}\par
\par
{\f1     procedure Get_Line (File : in File_Type;}\par
{\f1                         Item : out String;}\par
{\f1                         Last : out Natural);}\par
{\f1     -- Lit une ligne du fichier dans Item, Last = longueur lue.}\par
\par
{\f1     procedure New_Line (File : in File_Type;}\par
{\f1                         Spacing : in Positive_Count := 1);}\par
{\f1     -- Ecrit des sauts de ligne dans le fichier.}\par
\par
{\f1   Exemple (fichier) :}\par
{\f1     with Ada.Text_IO; use Ada.Text_IO;}\par
\par
{\f1     procedure Ecrire_Fichier is}\par
{\f1        F : File_Type;}\par
{\f1     begin}\par
{\f1        Create (F, Out_File, "resultat.txt");}\par
{\f1        Put_Line (F, "Premiere ligne");}\par
{\f1        Put_Line (F, "Deuxieme ligne");}\par
{\f1        Close (F);}\par
{\f1     end Ecrire_Fichier;}\par
\par
{\f1     procedure Lire_Fichier is}\par
{\f1        F    : File_Type;}\par
{\f1        Buf  : String (1 .. 255);}\par
{\f1        Last : Natural;}\par
{\f1     begin}\par
{\f1        Open (F, In_File, "resultat.txt");}\par
{\f1        while not End_Of_File (F) loop}\par
{\f1           Get_Line (F, Buf, Last);}\par
{\f1           Put_Line (Buf (1 .. Last));}\par
{\f1        end loop;}\par
{\f1        Close (F);}\par
{\f1     end Lire_Fichier;}\par
\par
\par
\par
