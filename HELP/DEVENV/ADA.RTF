{\footnote # IDH_ADA_06}
{\footnote $ Ada - INSTRUCTIONS}
{\footnote K Ada instructions;if;case;loop;for;while;exit;return}
\b\fs24 INSTRUCTIONS \b0\fs20\par
\par
6.1 Affectation\par
\par
{\f1   Syntaxe :}\par
{\f1     <variable> := <expression> ;}\par
\par
{\f1   Exemples :}\par
{\f1     X := 42;}\par
{\f1     Tab(I) := Tab(I) + 1;}\par
{\f1     P.X := 3.14;}\par
\par
6.2 Instruction conditionnelle (if)\par
\par
{\f1   Syntaxe :}\par
{\f1     if <condition> then}\par
{\f1       <instructions>}\par
{\f1     [elsif <condition> then}\par
{\f1       <instructions>]*}\par
{\f1     [else}\par
{\f1       <instructions>]}\par
{\f1     end if;}\par
\par
{\f1   Exemples :}\par
{\f1     if X > 0 then}\par
{\f1       Put_Line ("Positif");}\par
{\f1     elsif X = 0 then}\par
{\f1       Put_Line ("Zero");}\par
{\f1     else}\par
{\f1       Put_Line ("Negatif");}\par
{\f1     end if;}\par
\par
{\f1   Notes :}\par
{\f1     - Le mot-cle est ELSIF (et non ELSEIF ni ELSE IF)}\par
{\f1     - L'instruction se termine toujours par END IF}\par
{\f1     - Pas d'ambiguite du dangling else}\par
\par
6.3 Instruction de selection (case)\par
\par
{\f1   Syntaxe :}\par
{\f1     case <expression> is}\par
{\f1       when <choix> => <instructions>}\par
{\f1       [when <choix> => <instructions>]*}\par
{\f1       [when others  => <instructions>]}\par
{\f1     end case;}\par
\par
{\f1   Exemples :}\par
{\f1     case Commande is}\par
{\f1       when 'A' | 'a'  => Ajouter;}\par
{\f1       when 'S' | 's'  => Supprimer;}\par
{\f1       when 'Q' | 'q'  => Quitter;}\par
{\f1       when others      => Put_Line ("Invalide");}\par
{\f1     end case;}\par
\par
{\f1     case Jour is}\par
{\f1       when Lundi .. Vendredi =>}\par
{\f1         Travailler;}\par
{\f1       when Samedi | Dimanche =>}\par
{\f1         Se_Reposer;}\par
{\f1     end case;}\par
\par
{\f1   Notes :}\par
{\f1     - Tous les cas possibles doivent etre couverts}\par
{\f1     - Le compilateur verifie l'exhaustivite des choix}\par
{\f1     - OTHERS couvre les cas restants}\par
\par
6.4 Boucle simple (loop)\par
\par
{\f1   Syntaxe :}\par
{\f1     [<nom> :] loop}\par
{\f1       <instructions>}\par
{\f1       exit [<nom>] [when <condition>] ;}\par
{\f1     end loop [<nom>] ;}\par
\par
{\f1   Exemples :}\par
{\f1     loop}\par
{\f1       Get (C);}\par
{\f1       exit when C = 'Q';}\par
{\f1       Traiter (C);}\par
{\f1     end loop;}\par
\par
6.5 Boucle while\par
\par
{\f1   Syntaxe :}\par
{\f1     [<nom> :] while <condition> loop}\par
{\f1       <instructions>}\par
{\f1     end loop [<nom>] ;}\par
\par
{\f1   Exemples :}\par
{\f1     while N > 0 loop}\par
{\f1       S := S + N;}\par
{\f1       N := N - 1;}\par
{\f1     end loop;}\par
\par
6.6 Boucle for\par
\par
{\f1   Syntaxe :}\par
{\f1     [<nom> :] for <var> in [reverse] <intervalle> loop}\par
{\f1       <instructions>}\par
{\f1     end loop [<nom>] ;}\par
\par
{\f1   Exemples :}\par
{\f1     for I in 1 .. 10 loop}\par
{\f1       Put (Integer'Image (I));}\par
{\f1     end loop;}\par
\par
{\f1     for J in reverse 1 .. 10 loop}\par
{\f1       Tab(J) := 0;}\par
{\f1     end loop;}\par
\par
{\f1     for C in Character range 'A' .. 'Z' loop}\par
{\f1       Put (C);}\par
{\f1     end loop;}\par
\par
{\f1     for D in Jour loop   -- parcourt toutes les valeurs}\par
{\f1       Put_Line (Jour'Image (D));}\par
{\f1     end loop;}\par
\par
{\f1   Ada 2012 ajoute les iterateurs generalises :}\par
{\f1     for E of Tab loop       -- iteration sur les elements}\par
{\f1       E := E * 2;}\par
{\f1     end loop;}\par
\par
{\f1     for C of Ma_Liste loop  -- sur un conteneur}\par
{\f1       Put_Line (C);}\par
{\f1     end loop;}\par
\par
{\f1   Ada 2022 ajoute les filtres d'iterateurs :}\par
{\f1     for I in 1 .. 100 when I mod 2 = 0 loop}\par
{\f1       Put (Integer'Image (I));   -- nombres pairs}\par
{\f1     end loop;}\par
\par
6.7 Instruction de bloc (declare)\par
\par
{\f1   Syntaxe :}\par
{\f1     [<nom> :] declare}\par
{\f1       <declarations>}\par
{\f1     begin}\par
{\f1       <instructions>}\par
{\f1     end [<nom>] ;}\par
\par
{\f1   Exemples :}\par
{\f1     declare}\par
{\f1       Temp : Integer;}\par
{\f1     begin}\par
{\f1       Temp := A;}\par
{\f1       A := B;}\par
{\f1       B := Temp;}\par
{\f1     end;}\par
\par
6.8 Instruction nulle\par
\par
{\f1     null;}\par
\par
{\f1   L'instruction nulle ne fait rien. Elle est utile comme}\par
{\f1   corps vide ou dans les branches d'un case :}\par
\par
{\f1     when others => null;}\par
\par
6.9 Instruction goto\par
\par
{\f1     goto <etiquette>;}\par
\par
{\f1   L'etiquette est declaree entre doubles chevrons :}\par
{\f1     <<Recommencer>>}\par
\par
{\f1   L'utilisation du goto est deconseillee en Ada, les}\par
{\f1   structures de controle etant suffisamment expressives.}\par
\par
6.10 Instruction return\par
\par
{\f1     return;               -- dans une procedure}\par
{\f1     return <expression>;  -- dans une fonction}\par
\par
{\f1   Ada 2005 ajoute les retours etendus :}\par
{\f1     return R : Type_Resultat do}\par
{\f1       R.Champ := Valeur;}\par
{\f1     end return;}\par
\par
6.11 Instruction raise\par
\par
{\f1     raise Constraint_Error;}\par
{\f1     raise Mon_Exception;}\par
{\f1     raise Mon_Exception with "message d'erreur";  -- Ada 2005}\par
\par
{\f1   L'instruction raise sans argument releve l'exception}\par
{\f1   courante dans un gestionnaire d'exceptions.}\par
\par
6.12 Instruction delay\par
\par
{\f1     delay 1.5;            -- attente relative (secondes)}\par
{\f1     delay until Heure;    -- attente absolue (Ada 95)}\par
\par
\par
\par
