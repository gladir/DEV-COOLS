{\footnote # IDH_ADA_16}
{\footnote $ Ada - DIFFERENCES ENTRE LES VERSIONS}
{\footnote K Ada versions;Ada 83;Ada 95;Ada 2005;Ada 2012;Ada 2022}
\b\fs24 DIFFERENCES ENTRE LES VERSIONS \b0\fs20\par
\par
16.1 Ada 83 (version initiale)\par
\par
{\f1   Le langage original fournit :}\par
{\f1     - Typage fort avec sous-types et contraintes}\par
{\f1     - Paquetages pour la modularite et l'encapsulation}\par
{\f1     - Generiques pour la programmation generique}\par
{\f1     - Taches pour la programmation concurrente}\par
{\f1     - Gestion structuree des exceptions}\par
{\f1     - Compilation separee avec controle de coherence}\par
{\f1     - Representation bas niveau (clauses de representation)}\par
{\f1     - Pragmas pour les directives au compilateur}\par
\par
16.2 Ajouts d'Ada 95\par
\par
{\f1   Principaux ajouts par rapport a Ada 83 :}\par
{\f1     - Types etiquetes (tagged) et heritage}\par
{\f1     - Polymorphisme dynamique (dispatch)}\par
{\f1     - Types abstraits}\par
{\f1     - Paquetages enfants (hierarchie)}\par
{\f1     - Types proteges (concurrence securisee)}\par
{\f1     - Types modulaires (entiers non signes)}\par
{\f1     - Types d'acces a des sous-programmes}\par
{\f1     - Annexes specialisees (temps reel, distribue,}\par
{\f1       systemes d'information, securite, numerique)}\par
{\f1     - ALIASED et acces general}\par
{\f1     - Instruction REQUEUE}\par
\par
16.3 Ajouts d'Ada 2005\par
\par
{\f1   Principaux ajouts par rapport a Ada 95 :}\par
{\f1     - Interfaces multiples}\par
{\f1     - Notation prefixee (Obj.Methode)}\par
{\f1     - Types d'acces anonymes ameliores}\par
{\f1     - Mot-cle OVERRIDING / NOT OVERRIDING}\par
{\f1     - Conteneurs standards (Ada.Containers)}\par
{\f1     - Retours etendus (extended return)}\par
{\f1     - raise avec message}\par
{\f1     - Paquetage Ada.Directories (systeme de fichiers)}\par
{\f1     - Ameliorations du temps reel (EDF, minuteries)}\par
\par
16.4 Ajouts d'Ada 2012\par
\par
{\f1   Principaux ajouts par rapport a Ada 2005 :}\par
{\f1     - Preconditions (Pre) et postconditions (Post)}\par
{\f1     - Invariants de type (Type_Invariant)}\par
{\f1     - Predicats de sous-type (Static_Predicate,}\par
{\f1       Dynamic_Predicate)}\par
{\f1     - Expressions conditionnelles (if et case)}\par
{\f1     - Expressions quantifiees (for all, for some)}\par
{\f1     - Fonctions d'expression}\par
{\f1     - Iterateurs generalises (for ... of)}\par
{\f1     - Valeurs par defaut des composants de tableaux}\par
{\f1     - Aspect Default_Component_Value}\par
{\f1     - Multiprocesseurs (System.Multiprocessors)}\par
\par
16.5 Ajouts d'Ada 2022\par
\par
{\f1   Principaux ajouts par rapport a Ada 2012 :}\par
{\f1     - Parallelisme leger (parallel loops/blocks)}\par
{\f1     - Agregats delta (with delta)}\par
{\f1     - Operateur de reduction}\par
{\f1     - Filtres d'iterateurs (when dans les boucles for)}\par
{\f1     - Declare expressions}\par
{\f1     - Image personnalisee (Put_Image)}\par
{\f1     - Agregats de conteneurs (notation [])}\par
{\f1     - Renommage d'objets declares}\par
{\f1     - Ameliorations de la gestion des acces}\par
{\f1     - Ameliorations des contrats (Global, Nonblocking)}\par
\par
\par
\par
