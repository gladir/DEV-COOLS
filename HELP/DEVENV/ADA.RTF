{\footnote # IDH_ADA_04}
{\footnote $ Ada - DECLARATIONS}
{\footnote K Ada declarations;type;subtype;variable;constant}
\b\fs24 DECLARATIONS \b0\fs20\par
\par
4.1 Declaration de variables\par
\par
{\f1   Syntaxe :}\par
{\f1     <nom> [, <nom>]* : <type> [:= <expression>] ;}\par
\par
{\f1   Exemples :}\par
{\f1     X : Integer;}\par
{\f1     A, B, C : Float := 0.0;}\par
{\f1     Nom : String (1 .. 20);}\par
{\f1     Trouve : Boolean := False;}\par
\par
4.2 Declaration de constantes\par
\par
{\f1   Syntaxe :}\par
{\f1     <nom> : constant [<type>] := <expression> ;}\par
\par
{\f1   Exemples :}\par
{\f1     Pi : constant Float := 3.14159_26535;}\par
{\f1     Max : constant := 1000;  -- constante nommee universelle}\par
{\f1     Taille : constant Positive := 256;}\par
\par
4.3 Declaration de types\par
\par
{\f1   Syntaxe :}\par
{\f1     type <nom> is <definition_de_type> ;}\par
\par
{\f1   Exemples :}\par
{\f1     type Mois is range 1 .. 12;}\par
{\f1     type Direction is (Nord, Sud, Est, Ouest);}\par
{\f1     type Grille is array (1 .. 8, 1 .. 8) of Integer;}\par
\par
4.4 Declaration de sous-types\par
\par
{\f1   Syntaxe :}\par
{\f1     subtype <nom> is <type> [range <debut> .. <fin>] ;}\par
\par
{\f1   Exemples :}\par
{\f1     subtype Naturel is Integer range 0 .. Integer'Last;}\par
{\f1     subtype Indice is Integer range 1 .. 10;}\par
\par
4.5 Declaration de renommage\par
\par
{\f1   Ada permet de renommer des entites pour la lisibilite :}\par
\par
{\f1     Longueur : Float renames Vecteur.X;}\par
{\f1     procedure Ecrire (S : String) renames Ada.Text_IO.Put_Line;}\par
{\f1     package TIO renames Ada.Text_IO;}\par
\par
4.6 Declaration de nombre\par
\par
{\f1   Les nombres nommes sont des constantes universelles :}\par
\par
{\f1     Bits_Par_Octet : constant := 8;}\par
{\f1     Taille_Page    : constant := 4 * 1024;}\par
\par
{\f1   Ils n'ont pas de type specifique et sont remplaces}\par
{\f1   a la compilation.}\par
\par
4.7 Attributs\par
\par
{\f1   Les attributs fournissent des informations sur les types}\par
{\f1   et les objets. Syntaxe : <nom>'<attribut>}\par
\par
{\f1   Attributs courants :}\par
{\f1     T'First       Premiere valeur du type T}\par
{\f1     T'Last        Derniere valeur du type T}\par
{\f1     T'Range       Equivalent a T'First .. T'Last}\par
{\f1     T'Size        Taille en bits du type T}\par
{\f1     T'Length      Nombre d'elements (pour les tableaux)}\par
{\f1     T'Image(V)    Representation en chaine de la valeur V}\par
{\f1     T'Value(S)    Valeur du type T a partir de la chaine S}\par
{\f1     T'Succ(V)     Successeur de V dans le type T}\par
{\f1     T'Pred(V)     Predecesseur de V dans le type T}\par
{\f1     T'Pos(V)      Position ordinale de V}\par
{\f1     T'Val(N)      Valeur a la position N}\par
{\f1     T'Min(A, B)   Minimum de A et B}\par
{\f1     T'Max(A, B)   Maximum de A et B}\par
\par
\par
\par
