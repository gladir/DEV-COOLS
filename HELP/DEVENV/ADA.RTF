{\footnote # IDH_ADA_07}
{\footnote $ Ada - SOUS-PROGRAMMES (PROCEDURES ET FONCTIONS)}
{\footnote K Ada procedures;fonctions;sous-programmes}
\b\fs24 SOUS-PROGRAMMES (PROCEDURES ET FONCTIONS) \b0\fs20\par
\par
7.1 Procedures\par
\par
{\f1   Syntaxe :}\par
{\f1     procedure <nom> [(<parametres>)] is}\par
{\f1       [<declarations>]}\par
{\f1     begin}\par
{\f1       <instructions>}\par
{\f1     end <nom>;}\par
\par
{\f1   Exemples :}\par
{\f1     procedure Saluer is}\par
{\f1     begin}\par
{\f1       Put_Line ("Bonjour !");}\par
{\f1     end Saluer;}\par
\par
{\f1     procedure Echanger (A, B : in out Integer) is}\par
{\f1       Temp : Integer := A;}\par
{\f1     begin}\par
{\f1       A := B;}\par
{\f1       B := Temp;}\par
{\f1     end Echanger;}\par
\par
7.2 Fonctions\par
\par
{\f1   Syntaxe :}\par
{\f1     function <nom> [(<parametres>)] return <type> is}\par
{\f1       [<declarations>]}\par
{\f1     begin}\par
{\f1       <instructions>}\par
{\f1       return <expression>;}\par
{\f1     end <nom>;}\par
\par
{\f1   Exemples :}\par
{\f1     function Carre (N : Integer) return Integer is}\par
{\f1     begin}\par
{\f1       return N * N;}\par
{\f1     end Carre;}\par
\par
{\f1     function Max (A, B : Integer) return Integer is}\par
{\f1     begin}\par
{\f1       return (if A > B then A else B);  -- Ada 2012}\par
{\f1     end Max;}\par
\par
{\f1   Ada 2012 ajoute les fonctions d'expression :}\par
{\f1     function Carre (N : Integer) return Integer is (N * N);}\par
\par
7.3 Modes de passage des parametres\par
\par
{\f1   Ada definit trois modes de passage (quatre a partir}\par
{\f1   d'Ada 2012) :}\par
\par
{\f1     IN        Lecture seule (defaut). Le parametre formel}\par
{\f1               est une constante initialisee par l'argument.}\par
\par
{\f1     OUT       Ecriture. Le parametre formel est une variable}\par
{\f1               non initialisee, utilisee pour retourner une}\par
{\f1               valeur a l'appelant.}\par
\par
{\f1     IN OUT    Lecture et ecriture. Le parametre formel est}\par
{\f1               une variable initialisee par l'argument et}\par
{\f1               dont la valeur finale est retournee.}\par
\par
{\f1     ACCESS    (Ada 95+) Passage par pointeur explicite.}\par
\par
{\f1   Exemples :}\par
{\f1     procedure Lire (Valeur : out Integer);}\par
{\f1     procedure Incrementer (N : in out Integer);}\par
{\f1     procedure Afficher (Msg : in String);}\par
{\f1     procedure Traiter (P : access Noeud);}\par
\par
{\f1   Notes :}\par
{\f1     - Ada choisit le mecanisme (copie ou reference) selon}\par
{\f1       le type et la taille des parametres}\par
{\f1     - Les types etiquetes et les taches sont toujours passes}\par
{\f1       par reference}\par
{\f1     - Les scalaires sont passes par copie}\par
\par
7.4 Parametres par defaut\par
\par
{\f1     procedure Ouvrir (Nom  : String;}\par
{\f1                       Mode : Mode_Fichier := Lecture);}\par
\par
{\f1   Les parametres avec valeur par defaut peuvent etre}\par
{\f1   omis lors de l'appel.}\par
\par
7.5 Appel avec notation nommee\par
\par
{\f1     Ouvrir (Mode => Ecriture, Nom => "sortie.txt");}\par
\par
{\f1   La notation nommee permet de specifier les arguments}\par
{\f1   dans un ordre quelconque.}\par
\par
7.6 Surcharge (overloading)\par
\par
{\f1   Ada permet la surcharge des sous-programmes : plusieurs}\par
{\f1   sous-programmes peuvent avoir le meme nom si leurs}\par
{\f1   profils (types des parametres et/ou type de retour)}\par
{\f1   different :}\par
\par
{\f1     function "+" (A, B : Vecteur) return Vecteur;}\par
{\f1     function "+" (A : Vecteur; S : Float) return Vecteur;}\par
\par
{\f1   La surcharge s'applique aussi aux operateurs.}\par
\par
7.7 Sous-programmes separes\par
\par
{\f1   Un sous-programme peut etre compile separement :}\par
\par
{\f1     procedure Corps_Principal is separate;}\par
\par
{\f1   Le corps est dans un fichier separe :}\par
\par
{\f1     separate (Paquetage_Parent)}\par
{\f1     procedure Corps_Principal is}\par
{\f1     begin}\par
{\f1       ...}\par
{\f1     end Corps_Principal;}\par
\par
\par
\par
