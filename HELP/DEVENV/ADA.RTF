{\footnote # IDH_ADA_12}
{\footnote $ Ada - PROGRAMMATION ORIENTEE OBJET (ADA 95+)}
{\footnote K Ada objet;tagged;classwide;heritage}
\b\fs24 PROGRAMMATION ORIENTEE OBJET (ADA 95+) \b0\fs20\par
\par
{\f1   Ada 95 introduit la programmation orientee objet avec}\par
{\f1   les types etiquetes (tagged types).}\par
\par
12.1 Types etiquetes (tagged types)\par
\par
{\f1     type Forme is tagged record}\par
{\f1       X : Float;}\par
{\f1       Y : Float;}\par
{\f1     end record;}\par
\par
{\f1     function Aire (F : Forme) return Float;}\par
\par
12.2 Derivation et heritage\par
\par
{\f1     type Cercle is new Forme with record}\par
{\f1       Rayon : Float;}\par
{\f1     end record;}\par
\par
{\f1     overriding}\par
{\f1     function Aire (C : Cercle) return Float;}\par
\par
{\f1     type Rectangle is new Forme with record}\par
{\f1       Largeur : Float;}\par
{\f1       Hauteur : Float;}\par
{\f1     end record;}\par
\par
{\f1     overriding}\par
{\f1     function Aire (R : Rectangle) return Float;}\par
\par
12.3 Polymorphisme (dispatch)\par
\par
{\f1   Le type de classe (class-wide type) permet le}\par
{\f1   polymorphisme dynamique :}\par
\par
{\f1     procedure Afficher_Aire (F : Forme'Class) is}\par
{\f1     begin}\par
{\f1       Put_Line ("Aire = " & Float'Image (Aire (F)));}\par
{\f1     end Afficher_Aire;}\par
\par
{\f1   L'appel Afficher_Aire effectue un dispatch dynamique}\par
{\f1   sur la primitive Aire en fonction du type reel de F.}\par
\par
12.4 Types abstraits\par
\par
{\f1     type Vehicule is abstract tagged record}\par
{\f1       Vitesse : Float;}\par
{\f1     end record;}\par
\par
{\f1     function Description (V : Vehicule) return String}\par
{\f1       is abstract;}\par
\par
{\f1   Un type abstrait ne peut pas etre instancie directement.}\par
{\f1   Les sous-programmes abstraits doivent etre surdefinis}\par
{\f1   dans les types derives.}\par
\par
12.5 Interfaces (Ada 2005+)\par
\par
{\f1     type Imprimable is interface;}\par
{\f1     procedure Imprimer (Obj : Imprimable) is abstract;}\par
\par
{\f1     type Serialisable is interface;}\par
{\f1     procedure Serialiser (Obj : Serialisable) is abstract;}\par
\par
{\f1     type Document is new Forme}\par
{\f1       and Imprimable}\par
{\f1       and Serialisable with record}\par
{\f1       Titre : String (1 .. 80);}\par
{\f1     end record;}\par
\par
{\f1   Les interfaces permettent l'heritage multiple de}\par
{\f1   specifications (pas d'heritage multiple d'implementation).}\par
\par
12.6 Notation prefixee (Ada 2005+)\par
\par
{\f1   Ada 2005 permet la notation objet.methode :}\par
\par
{\f1     Obj.Methode (Args);}\par
{\f1     -- equivalent a : Methode (Obj, Args);}\par
\par
12.7 Mot-cle overriding (Ada 2005+)\par
\par
{\f1     overriding}\par
{\f1     procedure Dessiner (C : Cercle);}\par
\par
{\f1     not overriding}\par
{\f1     procedure Tourner (C : in out Cercle; Angle : Float);}\par
\par
{\f1   Le compilateur verifie que la declaration est coherente}\par
{\f1   avec l'intention du programmeur.}\par
\par
\par
\par
