{\footnote # IDH_ADA_03}
{\footnote $ Ada - TYPES DE DONNEES}
{\footnote K Ada types;Integer;Float;Boolean;record;array;access}
\b\fs24 TYPES DE DONNEES \b0\fs20\par
\par
{\f1   Ada possede un systeme de types riche et fortement type.}\par
{\f1   Tout objet a un type et les conversions implicites sont}\par
{\f1   tres limitees.}\par
\par
3.1 Types scalaires\par
\par
{\f1   a) Types entiers :}\par
\par
{\f1     type Index is range 1 .. 100;}\par
{\f1     type Compteur is range 0 .. 999_999;}\par
\par
{\f1     Types predefinis :}\par
{\f1       Integer       Entier signe (au moins 16 bits)}\par
{\f1       Natural       Sous-type de Integer (>= 0)}\par
{\f1       Positive      Sous-type de Integer (>= 1)}\par
{\f1       Long_Integer  Entier signe etendu (optionnel)}\par
\par
{\f1   b) Types modulaires (non signes, Ada 95+) :}\par
\par
{\f1     type Octet is mod 256;       -- 0 .. 255}\par
{\f1     type Mot is mod 2**16;       -- 0 .. 65535}\par
\par
{\f1     L'arithmetique modulaire boucle automatiquement}\par
{\f1     (wrap-around) et ne leve pas d'exception de debordement.}\par
\par
{\f1   c) Types a virgule flottante :}\par
\par
{\f1     type Temperature is digits 6;}\par
{\f1     type Haute_Precision is digits 15 range -1.0 .. 1.0;}\par
\par
{\f1     Types predefinis :}\par
{\f1       Float         Flottant simple precision}\par
{\f1       Long_Float    Flottant double precision (optionnel)}\par
\par
{\f1   d) Types a virgule fixe :}\par
\par
{\f1     type Volt is delta 0.01 range -100.0 .. 100.0;}\par
{\f1     type Duree is delta 0.001 digits 9}\par
{\f1       range 0.0 .. 86_400.0;   -- virgule fixe decimale}\par
\par
{\f1   e) Types enumeres :}\par
\par
{\f1     type Couleur is (Rouge, Vert, Bleu);}\par
{\f1     type Jour is (Lundi, Mardi, Mercredi, Jeudi,}\par
{\f1                   Vendredi, Samedi, Dimanche);}\par
\par
{\f1     Types predefinis :}\par
{\f1       Boolean       (False, True)}\par
{\f1       Character     (256 valeurs Latin-1)}\par
{\f1       Wide_Character (65536 valeurs, Ada 95+)}\par
\par
{\f1   f) Type caractere :}\par
\par
{\f1     Le type Character est un type enumere predefini}\par
{\f1     correspondant au jeu Latin-1. Les litteraux caracteres}\par
{\f1     sont entre apostrophes : 'A', '0', ' '.}\par
\par
3.2 Types composites\par
\par
{\f1   a) Types tableau (array) :}\par
\par
{\f1     -- Tableau contraint}\par
{\f1     type Vecteur is array (1 .. 3) of Float;}\par
{\f1     type Matrice is array (1 .. 3, 1 .. 3) of Float;}\par
{\f1     type Table is array (Jour) of Natural;}\par
\par
{\f1     -- Tableau non contraint}\par
{\f1     type Chaine is array (Positive range <>) of Character;}\par
\par
{\f1     Types predefinis :}\par
{\f1       String        array (Positive range <>) of Character}\par
\par
{\f1   b) Types enregistrement (record) :}\par
\par
{\f1     type Point is record}\par
{\f1       X : Float;}\par
{\f1       Y : Float;}\par
{\f1     end record;}\par
\par
{\f1     type Personne is record}\par
{\f1       Nom    : String (1 .. 50);}\par
{\f1       Age    : Natural;}\par
{\f1       Actif  : Boolean := True;  -- valeur par defaut}\par
{\f1     end record;}\par
\par
{\f1   c) Enregistrements a discriminant :}\par
\par
{\f1     type Tampon (Taille : Positive) is record}\par
{\f1       Contenu : String (1 .. Taille);}\par
{\f1       Dernier : Natural := 0;}\par
{\f1     end record;}\par
\par
{\f1   d) Enregistrements a variante (discriminated) :}\par
\par
{\f1     type Figure (Forme : Type_Forme) is record}\par
{\f1       case Forme is}\par
{\f1         when Cercle =>}\par
{\f1           Rayon : Float;}\par
{\f1         when Rectangle =>}\par
{\f1           Largeur : Float;}\par
{\f1           Hauteur : Float;}\par
{\f1         when Triangle =>}\par
{\f1           Base   : Float;}\par
{\f1           Cote_A : Float;}\par
{\f1           Cote_B : Float;}\par
{\f1       end case;}\par
{\f1     end record;}\par
\par
3.3 Types d'acces (pointeurs)\par
\par
{\f1   type Ptr_Entier is access Integer;}\par
{\f1   type Ptr_Noeud is access Noeud;}\par
\par
{\f1   P : Ptr_Entier := new Integer'(42);}\par
\par
{\f1   Ada 95 ajoute les niveaux d'accessibilite et les}\par
{\f1   types d'acces a des sous-programmes :}\par
\par
{\f1     type Ptr_Fonction is access function (X : Integer)}\par
{\f1       return Integer;}\par
\par
{\f1   Ada 2005 ajoute les types d'acces anonymes :}\par
\par
{\f1     procedure Traiter (P : access Integer);}\par
{\f1     type Noeud is record}\par
{\f1       Valeur  : Integer;}\par
{\f1       Suivant : access Noeud;  -- acces anonyme}\par
{\f1     end record;}\par
\par
3.4 Types prives et limites\par
\par
{\f1   Les types prives cachent leur implementation :}\par
\par
{\f1     package Pile is}\par
{\f1       type Pile_T is private;}\par
{\f1       procedure Empiler (S : in out Pile_T; V : Integer);}\par
{\f1       function  Depiler (S : in out Pile_T) return Integer;}\par
{\f1     private}\par
{\f1       type Pile_T is record}\par
{\f1         Donnees : array (1 .. 100) of Integer;}\par
{\f1         Sommet  : Natural := 0;}\par
{\f1       end record;}\par
{\f1     end Pile;}\par
\par
{\f1   Les types limites (limited) interdisent l'affectation}\par
{\f1   et la comparaison d'egalite :}\par
\par
{\f1     type Fichier is limited private;}\par
\par
3.5 Sous-types et contraintes\par
\par
{\f1   Un sous-type restreint les valeurs d'un type existant :}\par
\par
{\f1     subtype Jour_Ouvrable is Jour range Lundi .. Vendredi;}\par
{\f1     subtype Petit_Entier is Integer range -128 .. 127;}\par
{\f1     subtype Indice is Positive range 1 .. 100;}\par
\par
{\f1   La violation d'une contrainte leve l'exception}\par
{\f1   Constraint_Error a l'execution.}\par
\par
\par
\par
