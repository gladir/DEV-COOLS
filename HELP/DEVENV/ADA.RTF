{\footnote # IDH_ADA_14}
{\footnote $ Ada - CONTRATS ET ASPECTS (ADA 2012+)}
{\footnote K Ada contrats;aspects;Pre;Post}
\b\fs24 CONTRATS ET ASPECTS (ADA 2012+) \b0\fs20\par
\par
{\f1   Ada 2012 introduit la programmation par contrat,}\par
{\f1   permettant de specifier formellement le comportement}\par
{\f1   attendu des sous-programmes et des types.}\par
\par
14.1 Preconditions et postconditions\par
\par
{\f1   Syntaxe :}\par
{\f1     function F (X : T) return T}\par
{\f1       with Pre  => <condition_prealable>,}\par
{\f1            Post => <condition_posterieure>;}\par
\par
{\f1   Exemples :}\par
{\f1     function Racine_Carree (X : Float) return Float}\par
{\f1       with Pre  => X >= 0.0,}\par
{\f1            Post => Racine_Carree'Result >= 0.0}\par
{\f1                    and then abs (Racine_Carree'Result ** 2}\par
{\f1                                  - X) < 0.001;}\par
\par
{\f1     procedure Empiler (S : in out Pile; V : Integer)}\par
{\f1       with Pre  => not Est_Pleine (S),}\par
{\f1            Post => Sommet (S) = V}\par
{\f1                    and Taille (S) = Taille (S)'Old + 1;}\par
\par
14.2 Invariants de type\par
\par
{\f1     type Compteur is private}\par
{\f1       with Type_Invariant => Verifier (Compteur);}\par
\par
{\f1     function Verifier (C : Compteur) return Boolean;}\par
\par
{\f1   L'invariant est verifie apres chaque operation publique}\par
{\f1   qui modifie un objet du type.}\par
\par
14.3 Predicats de sous-type\par
\par
{\f1   Predicats statiques (verifies a la compilation) :}\par
{\f1     subtype Pair is Integer}\par
{\f1       with Static_Predicate => Pair mod 2 = 0;}\par
\par
{\f1   Predicats dynamiques (verifies a l'execution) :}\par
{\f1     subtype Valide is String}\par
{\f1       with Dynamic_Predicate =>}\par
{\f1         Valide'Length > 0}\par
{\f1         and Valide (Valide'First) /= ' ';}\par
\par
14.4 Valeurs par defaut initiales\par
\par
{\f1     type Tableau is array (1 .. 10) of Integer}\par
{\f1       with Default_Component_Value => 0;}\par
\par
{\f1     type Enreg is record}\par
{\f1       X : Integer;}\par
{\f1     end record}\par
{\f1       with Default_Value => (X => 0);  -- Ada 2022}\par
\par
14.5 Aspects de representation\par
\par
{\f1   Les aspects permettent de controler la representation}\par
{\f1   en memoire :}\par
\par
{\f1     type Registre is record}\par
{\f1       Actif  : Boolean;}\par
{\f1       Code   : Integer range 0 .. 15;}\par
{\f1       Donnee : Integer range 0 .. 255;}\par
{\f1     end record}\par
{\f1       with Size => 16;}\par
\par
{\f1     for Registre use record}\par
{\f1       Actif  at 0 range 0 .. 0;}\par
{\f1       Code   at 0 range 1 .. 4;}\par
{\f1       Donnee at 0 range 5 .. 12;}\par
{\f1     end record;}\par
\par
\par
\par
