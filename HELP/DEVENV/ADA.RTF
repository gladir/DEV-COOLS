{\footnote # IDH_ADA_08}
{\footnote $ Ada - PAQUETAGES (PACKAGES)}
{\footnote K Ada paquetages;packages;with;use}
\b\fs24 PAQUETAGES (PACKAGES) \b0\fs20\par
\par
{\f1   Les paquetages sont le mecanisme de modularite d'Ada.}\par
{\f1   Ils encapsulent des types, des variables, des constantes}\par
{\f1   et des sous-programmes.}\par
\par
8.1 Specification de paquetage\par
\par
{\f1   Syntaxe :}\par
{\f1     package <nom> is}\par
{\f1       <declarations publiques>}\par
{\f1     [private}\par
{\f1       <declarations privees>]}\par
{\f1     end <nom>;}\par
\par
{\f1   Exemples :}\par
{\f1     package Mathematiques is}\par
{\f1       Pi : constant Float := 3.14159_26535;}\par
{\f1       function Sinus (X : Float) return Float;}\par
{\f1       function Cosinus (X : Float) return Float;}\par
{\f1     end Mathematiques;}\par
\par
8.2 Corps de paquetage\par
\par
{\f1   Syntaxe :}\par
{\f1     package body <nom> is}\par
{\f1       <declarations et corps>}\par
{\f1     [begin}\par
{\f1       <instructions d'initialisation>]}\par
{\f1     end <nom>;}\par
\par
{\f1   Exemples :}\par
{\f1     package body Mathematiques is}\par
{\f1       function Sinus (X : Float) return Float is}\par
{\f1       begin}\par
{\f1         ...}\par
{\f1       end Sinus;}\par
\par
{\f1       function Cosinus (X : Float) return Float is}\par
{\f1       begin}\par
{\f1         ...}\par
{\f1       end Cosinus;}\par
{\f1     end Mathematiques;}\par
\par
8.3 Clause with et use\par
\par
{\f1   La clause WITH rend un paquetage visible.}\par
{\f1   La clause USE rend ses declarations directement}\par
{\f1   accessibles sans prefixe.}\par
\par
{\f1     with Ada.Text_IO;}\par
{\f1     with Ada.Integer_Text_IO; use Ada.Integer_Text_IO;}\par
\par
{\f1     procedure Demo is}\par
{\f1     begin}\par
{\f1       Ada.Text_IO.Put_Line ("Avec prefixe");}\par
{\f1       Put (42);  -- sans prefixe grace a USE}\par
{\f1     end Demo;}\par
\par
8.4 Paquetages enfants (child packages, Ada 95+)\par
\par
{\f1   Ada 95 permet d'etendre les paquetages avec des enfants :}\par
\par
{\f1     package Mathematiques.Trigonometrie is}\par
{\f1       function Tangente (X : Float) return Float;}\par
{\f1     end Mathematiques.Trigonometrie;}\par
\par
{\f1   Les paquetages enfants ont acces a la partie privee}\par
{\f1   de leur parent si declares comme enfant prive :}\par
\par
{\f1     private package Mathematiques.Interne is}\par
{\f1       ...}\par
{\f1     end Mathematiques.Interne;}\par
\par
8.5 Paquetages predefinis\par
\par
{\f1   Ada fournit une hierarchie de paquetages standards :}\par
\par
{\f1     Ada.Text_IO           Entrees/sorties texte}\par
{\f1     Ada.Integer_Text_IO   E/S d'entiers}\par
{\f1     Ada.Float_Text_IO     E/S de flottants}\par
{\f1     Ada.Strings           Manipulation de chaines}\par
{\f1     Ada.Strings.Fixed     Chaines de taille fixe}\par
{\f1     Ada.Strings.Unbounded Chaines de taille variable}\par
{\f1     Ada.Numerics          Constantes mathematiques}\par
{\f1     Ada.Numerics.Elementary_Functions  Sin, Cos, Sqrt...}\par
{\f1     Ada.Calendar          Date et heure}\par
{\f1     Ada.Exceptions        Manipulation des exceptions}\par
{\f1     Ada.Containers        Conteneurs (Ada 2005+)}\par
{\f1     Ada.Command_Line      Arguments de la ligne de commande}\par
\par
\par
\par
