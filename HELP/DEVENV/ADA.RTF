{\footnote # IDH_ADA_11}
{\footnote $ Ada - TACHES ET CONCURRENCE (TASKING)}
{\footnote K Ada taches;tasking;rendezvous;protected}
\b\fs24 TACHES ET CONCURRENCE (TASKING) \b0\fs20\par
\par
{\f1   Ada integre la concurrence directement dans le langage}\par
{\f1   depuis Ada 83. Les taches sont des unites d'execution}\par
{\f1   concurrentes.}\par
\par
11.1 Declaration de tache\par
\par
{\f1   Syntaxe :}\par
{\f1     task <nom> is}\par
{\f1       [entry <nom_entree> [(<parametres>)];]*}\par
{\f1     end <nom>;}\par
\par
{\f1     task body <nom> is}\par
{\f1       [<declarations>]}\par
{\f1     begin}\par
{\f1       <instructions>}\par
{\f1     end <nom>;}\par
\par
{\f1   Exemples :}\par
{\f1     task Producteur;}\par
\par
{\f1     task body Producteur is}\par
{\f1     begin}\par
{\f1       for I in 1 .. 10 loop}\par
{\f1         Tampon.Deposer (I);}\par
{\f1       end loop;}\par
{\f1     end Producteur;}\par
\par
11.2 Entrees et rendez-vous\par
\par
{\f1   Les taches communiquent par rendez-vous via des entrees :}\par
\par
{\f1     task Serveur is}\par
{\f1       entry Requete (Donnee : in Integer;}\par
{\f1                      Reponse : out Integer);}\par
{\f1     end Serveur;}\par
\par
{\f1     task body Serveur is}\par
{\f1     begin}\par
{\f1       loop}\par
{\f1         accept Requete (Donnee : in Integer;}\par
{\f1                         Reponse : out Integer) do}\par
{\f1           Reponse := Traiter (Donnee);}\par
{\f1         end Requete;}\par
{\f1       end loop;}\par
{\f1     end Serveur;}\par
\par
{\f1   Appel depuis une autre tache :}\par
{\f1     Serveur.Requete (42, R);}\par
\par
11.3 Instruction select\par
\par
{\f1   Le select permet d'attendre plusieurs entrees :}\par
\par
{\f1     select}\par
{\f1       accept Lire (V : out Integer) do}\par
{\f1         V := Valeur;}\par
{\f1       end Lire;}\par
{\f1     or}\par
{\f1       accept Ecrire (V : in Integer) do}\par
{\f1         Valeur := V;}\par
{\f1       end Ecrire;}\par
{\f1     or}\par
{\f1       delay 5.0;}\par
{\f1       Put_Line ("Timeout");}\par
{\f1     or}\par
{\f1       terminate;}\par
{\f1     end select;}\par
\par
11.4 Types proteges (Ada 95+)\par
\par
{\f1   Les types proteges fournissent un acces concurrent}\par
{\f1   securise aux donnees partagees :}\par
\par
{\f1     protected type Compteur is}\par
{\f1       procedure Incrementer;}\par
{\f1       function  Valeur return Integer;}\par
{\f1       entry     Attendre_Zero;}\par
{\f1     private}\par
{\f1       N : Integer := 0;}\par
{\f1     end Compteur;}\par
\par
{\f1     protected body Compteur is}\par
{\f1       procedure Incrementer is}\par
{\f1       begin}\par
{\f1         N := N + 1;}\par
{\f1       end Incrementer;}\par
\par
{\f1       function Valeur return Integer is}\par
{\f1       begin}\par
{\f1         return N;}\par
{\f1       end Valeur;}\par
\par
{\f1       entry Attendre_Zero when N = 0 is}\par
{\f1       begin}\par
{\f1         null;}\par
{\f1       end Attendre_Zero;}\par
{\f1     end Compteur;}\par
\par
{\f1   Notes :}\par
{\f1     - Les fonctions protegees permettent un acces}\par
{\f1       concurrent en lecture}\par
{\f1     - Les procedures protegees garantissent un acces}\par
{\f1       exclusif en ecriture}\par
{\f1     - Les entrees protegees ont une barriere booleenne}\par
{\f1       qui doit etre vraie pour que l'appel soit accepte}\par
\par
11.5 Instruction requeue (Ada 95+)\par
\par
{\f1     entry Traiter (D : Integer) when Pret is}\par
{\f1     begin}\par
{\f1       if Besoin_Attente then}\par
{\f1         requeue File_Attente;}\par
{\f1       end if;}\par
{\f1     end Traiter;}\par
\par
\par
\par
