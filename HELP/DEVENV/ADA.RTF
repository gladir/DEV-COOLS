{\footnote # IDH_ADA_09}
{\footnote $ Ada - GENERIQUES (GENERICS)}
{\footnote K Ada generiques;generics;template}
\b\fs24 GENERIQUES (GENERICS) \b0\fs20\par
\par
{\f1   Les generiques permettent d'ecrire du code parametrable}\par
{\f1   par des types et des sous-programmes.}\par
\par
9.1 Paquetages generiques\par
\par
{\f1   Syntaxe :}\par
{\f1     generic}\par
{\f1       <parametres generiques>}\par
{\f1     package <nom> is}\par
{\f1       ...}\par
{\f1     end <nom>;}\par
\par
{\f1   Exemples :}\par
{\f1     generic}\par
{\f1       type Element is private;}\par
{\f1       type Indice is (<>);}\par
{\f1     package Pile_Generique is}\par
{\f1       type Pile is private;}\par
{\f1       procedure Empiler (S : in out Pile; V : Element);}\par
{\f1       function  Depiler (S : in out Pile) return Element;}\par
{\f1       function  Est_Vide (S : Pile) return Boolean;}\par
{\f1     private}\par
{\f1       type Tableau is array (Indice) of Element;}\par
{\f1       type Pile is record}\par
{\f1         Donnees : Tableau;}\par
{\f1         Sommet  : Natural := 0;}\par
{\f1       end record;}\par
{\f1     end Pile_Generique;}\par
\par
9.2 Sous-programmes generiques\par
\par
{\f1     generic}\par
{\f1       type T is private;}\par
{\f1       with function "<" (A, B : T) return Boolean is <>;}\par
{\f1     procedure Tri_Generique (Tab : in out Tableau_T);}\par
\par
9.3 Instanciation\par
\par
{\f1     package Pile_Entiers is new Pile_Generique}\par
{\f1       (Element => Integer, Indice => Positive);}\par
\par
{\f1     procedure Trier_Entiers is new Tri_Generique}\par
{\f1       (T => Integer);}\par
\par
9.4 Parametres generiques formels\par
\par
{\f1   Types generiques formels :}\par
{\f1     type T is private;           -- tout type non limite}\par
{\f1     type T is limited private;   -- tout type}\par
{\f1     type T is (<>);              -- type discret}\par
{\f1     type T is range <>;          -- type entier}\par
{\f1     type T is digits <>;         -- type flottant}\par
{\f1     type T is delta <>;          -- type a virgule fixe}\par
{\f1     type T is mod <>;            -- type modulaire (Ada 95)}\par
{\f1     type T is tagged private;    -- type etiquete (Ada 95)}\par
{\f1     type T is new Parent with private; -- derive (Ada 95)}\par
{\f1     type T is access S;          -- type d'acces}\par
\par
{\f1   Sous-programmes generiques formels :}\par
{\f1     with function F (X : T) return T;}\par
{\f1     with procedure P (X : in out T);}\par
{\f1     with function "+" (A, B : T) return T is <>;}\par
\par
{\f1   Paquetages generiques formels (Ada 95+) :}\par
{\f1     with package P is new Q (<>);}\par
\par
\par
\par
