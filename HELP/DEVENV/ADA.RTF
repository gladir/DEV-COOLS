{\footnote # IDH_ADA_10}
{\footnote $ Ada - GESTION DES EXCEPTIONS}
{\footnote K Ada exceptions;raise;exception handler}
\b\fs24 GESTION DES EXCEPTIONS \b0\fs20\par
\par
{\f1   Les exceptions sont le mecanisme de gestion des erreurs}\par
{\f1   en Ada. Elles sont declarees, levees et gerees.}\par
\par
10.1 Declaration d'exceptions\par
\par
{\f1     Mon_Exception : exception;}\par
{\f1     Erreur_Donnees : exception;}\par
\par
{\f1   Exceptions predefinies :}\par
{\f1     Constraint_Error    Violation de contrainte (debordement,}\par
{\f1                         indice hors bornes, division par zero)}\par
{\f1     Program_Error       Erreur de programmation (fin de}\par
{\f1                         fonction sans return, elaboration}\par
{\f1                         circulaire)}\par
{\f1     Storage_Error       Memoire insuffisante}\par
{\f1     Tasking_Error       Erreur de tache}\par
\par
10.2 Lever une exception\par
\par
{\f1     raise Mon_Exception;}\par
{\f1     raise Constraint_Error;}\par
{\f1     raise Erreur_Donnees with "Valeur invalide";  -- Ada 2005}\par
\par
10.3 Gerer les exceptions\par
\par
{\f1   Syntaxe :}\par
{\f1     begin}\par
{\f1       <instructions>}\par
{\f1     exception}\par
{\f1       when <nom_exception> =>}\par
{\f1         <instructions de traitement>}\par
{\f1       when others =>}\par
{\f1         <traitement par defaut>}\par
{\f1     end;}\par
\par
{\f1   Exemples :}\par
{\f1     begin}\par
{\f1       Resultat := A / B;}\par
{\f1     exception}\par
{\f1       when Constraint_Error =>}\par
{\f1         Put_Line ("Division par zero !");}\par
{\f1         Resultat := 0;}\par
{\f1       when others =>}\par
{\f1         Put_Line ("Erreur inattendue");}\par
{\f1         raise;  -- relever l'exception}\par
{\f1     end;}\par
\par
10.4 Informations sur les exceptions (Ada 95+)\par
\par
{\f1   Le paquetage Ada.Exceptions fournit des informations :}\par
\par
{\f1     when E : others =>}\par
{\f1       Put_Line (Ada.Exceptions.Exception_Name (E));}\par
{\f1       Put_Line (Ada.Exceptions.Exception_Message (E));}\par
\par
\par
\par
