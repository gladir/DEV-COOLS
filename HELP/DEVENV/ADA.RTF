{\footnote # IDH_ADA_15}
{\footnote $ Ada - NOUVEAUTES ADA 2022}
{\footnote K Ada 2022;nouveautes}
\b\fs24 NOUVEAUTES ADA 2022 \b0\fs20\par
\par
{\f1   Ada 2022 (ISO/IEC 8652:2023) apporte des ameliorations}\par
{\f1   significatives a la productivite et a l'expressivite.}\par
\par
15.1 Parallelisme leger\par
\par
{\f1   Boucles paralleles :}\par
{\f1     parallel}\par
{\f1     for I in 1 .. N loop}\par
{\f1       Tab(I) := Calculer (I);}\par
{\f1     end loop;}\par
\par
{\f1   Blocs paralleles :}\par
{\f1     parallel do}\par
{\f1       Tache_A;}\par
{\f1     and}\par
{\f1       Tache_B;}\par
{\f1     and}\par
{\f1       Tache_C;}\par
{\f1     end do;}\par
\par
15.2 Agregats delta\par
\par
{\f1   Modification partielle d'un agregat :}\par
{\f1     P2 := (P1 with delta X => 3.0);}\par
\par
{\f1   Pour les tableaux :}\par
{\f1     T2 := (T1 with delta 1 => 42, 5 => 99);}\par
\par
15.3 Operateur de reduction\par
\par
{\f1   Syntaxe :}\par
{\f1     (for I in 1 .. N => <combinaison>)}\par
\par
{\f1   Exemples :}\par
{\f1     Somme := [for I in 1 .. N => "+" (Tab(I), 0)];}\par
{\f1     -- ou avec la notation de reduction :}\par
{\f1     Somme := (for I in Tab'Range => <0, @> + Tab(I));}\par
\par
15.4 Filtres d'iterateurs\par
\par
{\f1     for I in 1 .. 100 when I mod 3 = 0 loop}\par
{\f1       Put (Integer'Image (I));  -- multiples de 3}\par
{\f1     end loop;}\par
\par
{\f1     Pairs := [for E of Tab when E mod 2 = 0 => E];}\par
\par
15.5 Declare expressions\par
\par
{\f1     X := (declare}\par
{\f1             T : constant Float := Calculer;}\par
{\f1           begin}\par
{\f1             T * T + 2.0 * T + 1.0);}\par
\par
15.6 Image personnalisee\par
\par
{\f1     type Direction is (Nord, Sud, Est, Ouest)}\par
{\f1       with Put_Image => Afficher_Direction;}\par
\par
{\f1     procedure Afficher_Direction}\par
{\f1       (Buffer : in out Ada.Strings.Text_Buffers.Root_Buffer_Type'Class;}\par
{\f1        D      : Direction);}\par
\par
15.7 Agregats de conteneurs\par
\par
{\f1     V : Vector := [1, 2, 3, 4, 5];}\par
{\f1     M : Map := [1 => "un", 2 => "deux", 3 => "trois"];}\par
\par
15.8 Renommage d'objets declares\par
\par
{\f1     Obj : T renames Expr;  -- expression quelconque}\par
\par
\par
\par
