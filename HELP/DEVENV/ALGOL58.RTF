\page

{\footnote # IDH_ALGOL58_12}
{\footnote $ Algol 58 - ENTREES / SORTIES}
{\footnote K Algol 58 entrees sorties;read;write;input;output}
\b\fs24 ENTREES / SORTIES \b0\fs20\par
\par
\par
\b 12.1 Ecriture \b0\par
\par
{\f1     write("Hello") ;}\par
{\f1     write(x) ;}\par
{\f1     write("x=", x, " y=", y) ;}\par
{\f1     writeln(x) ;}\par
{\f1     writeln() ;}\par
\par
write affiche un ou plusieurs arguments sans retour a la ligne.\par
writeln affiche avec retour a la ligne (CR+LF).\par
\par
Les arguments peuvent etre :\par
{\f1   - Chaines de caracteres entre guillemets doubles}\par
{\f1   - Expressions entieres (converties en texte)}\par
{\f1   - Expressions booleennes (affichees comme 0 ou 1)}\par
\par
\par
\b 12.2 Lecture \b0\par
\par
{\f1     read(x) ;}\par
{\f1     readln(x) ;}\par
\par
read lit un entier depuis l'entree standard.\par
readln lit un entier et consomme le retour a la ligne.\par
\par
Implementation DOS : INT 21h, AH=0Ah pour la saisie,\par
conversion par _A58RT_STRTONUM.\par
\par
\par
