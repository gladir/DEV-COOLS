{\footnote # IDH_ALGOL58_03}
{\footnote $ Algol 58 - MOTS-CLES}
{\footnote K Algol 58 mots-cles;keywords;reserved}
\b\fs24 MOTS-CLES \b0\fs20\par
\par
Mots-cles du langage :\par
\par
{\f1   Controle     : begin end if then else for do step until while}\par
{\f1   Branchement  : go to goto}\par
{\f1   Declarations : procedure value integer real boolean array}\par
{\f1                  switch own string label}\par
{\f1   Booleens     : true false}\par
{\f1   Operateurs   : and or not imp eqv div mod}\par
{\f1   Commentaires : comment}\par
{\f1   Intrinseques : abs sign sqrt sin cos arctan ln exp entier}\par
{\f1                  max min}\par
{\f1   Entrees/sort.: write writeln read readln}\par
\par
\par
