{\footnote # IDH_ALGOL58_21}
{\footnote $ Algol 58 - EXEMPLE COMPLET}
{\footnote K Algol 58 exemple complet;programme}
\b\fs24 EXEMPLE COMPLET \b0\fs20\par
\par
{\f1     begin}\par
{\f1       comment Programme de demonstration Algol 58 ;}\par
{\f1       integer i, somme, n ;}\par
{\f1       integer array tab[1:5] ;}\par
\par
{\f1       comment Initialisation ;}\par
{\f1       n := 5 ;}\par
{\f1       for i := 1 step 1 until n do}\par
{\f1         tab[i] := i * i ;}\par
\par
{\f1       comment Calcul de la somme des carres ;}\par
{\f1       somme := 0 ;}\par
{\f1       for i := 1 step 1 until n do}\par
{\f1         somme := somme + tab[i] ;}\par
\par
{\f1       write("Somme des carres de 1 a ") ;}\par
{\f1       write(n) ;}\par
{\f1       write(" = ") ;}\par
{\f1       writeln(somme) ;}\par
\par
{\f1       comment Factorielle avec procedure ;}\par
{\f1       integer procedure fact(k) ; value k ; integer k ;}\par
{\f1       begin}\par
{\f1         if k <= 1 then}\par
{\f1           fact := 1}\par
{\f1         else}\par
{\f1           fact := k * fact(k - 1)}\par
{\f1       end ;}\par
\par
{\f1       write("5! = ") ;}\par
{\f1       writeln(fact(5)) ;}\par
\par
{\f1       comment Expressions booleennes ;}\par
{\f1       if somme > 50 and n = 5 then}\par
{\f1         writeln("Resultat verifie")}\par
{\f1       else}\par
{\f1         writeln("Erreur")}\par
{\f1     end}\par
\par
\par
