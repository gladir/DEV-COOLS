{\footnote # IDH_CPP_18}
{\footnote $ C++ - PREPROCESSEUR}
{\footnote K C++ preprocesseur;include;define;ifdef;pragma;__cplusplus;__FILE__;__LINE__}
\b\fs24 PREPROCESSEUR \b0\fs20\par
\par
Identique a C, avec les directives :\par
\par
{\f1   #include <fichier>      inclusion systeme}\par
{\f1   #include "fichier"      inclusion utilisateur}\par
{\f1   #define NOM valeur      macro objet}\par
{\f1   #define MAC(x) ...      macro fonction}\par
{\f1   #undef NOM              annulation}\par
{\f1   #if / #ifdef / #ifndef  compilation conditionnelle}\par
{\f1   #else / #elif / #endif}\par
{\f1   #error msg              erreur de compilation}\par
{\f1   #pragma directive       directive d'implementation}\par
{\f1   #line N "fichier"       indication de ligne}\par
\par
Macros predefinies :\par
\par
{\f1   __FILE__       fichier source}\par
{\f1   __LINE__       numero de ligne}\par
{\f1   __DATE__       date de compilation}\par
{\f1   __TIME__       heure de compilation}\par
{\f1   __cplusplus    version C++ (199711L, 201103L, 201402L,}\par
{\f1                  201703L, 202002L, 202302L)}\par
{\f1   __func__       nom de fonction (C++11)}\par
\par
\par
\par
