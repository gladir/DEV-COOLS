{\footnote # IDH_CPP_04}
{\footnote $ C++ - TYPES DE DONNEES}
{\footnote K C++ types donnees;bool;char;wchar_t;short;int;long;long long;float;double;void;enum;enum class;typedef;using;const;volatile;mutable;constexpr}
\b\fs24 TYPES DE DONNEES \b0\fs20\par
\par
\par
\b 4.1 Types fondamentaux \b0\par
\par
{\f1   Type            Description                Taille typique}\par
{\f1   ----            -----------                --------------}\par
{\f1   bool            booleen (true/false)       1}\par
{\f1   char            caractere                  1}\par
{\f1   signed char     caractere signe            1}\par
{\f1   unsigned char   caractere non-signe        1}\par
{\f1   wchar_t         caractere large            2 ou 4}\par
{\f1   short           entier court               2}\par
{\f1   int             entier                     2 ou 4}\par
{\f1   long            entier long                4}\par
{\f1   long long       entier tres long (C++11)   8}\par
{\f1   float           flottant simple            4}\par
{\f1   double          flottant double            8}\par
{\f1   long double     flottant etendu            8/10/12/16}\par
{\f1   void            absence de type            -}\par
\par
Modificateurs : signed, unsigned, short, long.\par
\par
\par
\b 4.2 Types composes \b0\par
\par
{\f1   - Pointeur  T*}\par
{\f1   - Reference T&         (lvalue)}\par
{\f1   - Reference T&&        (rvalue, C++11)}\par
{\f1   - Tableau   T[N]}\par
{\f1   - Fonction  T(args)}\par
{\f1   - Membre    T C::*}\par
{\f1   - Tableau de longueur variable : NON (extension GCC)}\par
\par
\par
\b 4.3 Types definis par l'utilisateur \b0\par
\par
{\f1   - struct  (membres publics par defaut)}\par
{\f1   - class   (membres prives par defaut)}\par
{\f1   - union}\par
{\f1   - enum    (enum classique)}\par
{\f1   - enum class (C++11, fortement type)}\par
{\f1   - typedef et using (alias de type, using C++11)}\par
\par
Exemple :\par
\par
{\f1   enum Couleur \{ ROUGE, VERT, BLEU \};}\par
{\f1   enum class Direction \{ NORD, SUD, EST, OUEST \}; // C++11}\par
\par
{\f1   typedef unsigned long size_t;}\par
{\f1   using size_t = unsigned long;                   // C++11}\par
\par
\par
\b 4.4 Qualificatifs cv \b0\par
\par
{\f1   const     valeur non modifiable}\par
{\f1   volatile  acces non optimisable}\par
{\f1   mutable   modifiable meme dans un objet const}\par
{\f1   constexpr constante d'expression (C++11)}\par
\par
Exemples :\par
\par
{\f1   const int N = 100;}\par
{\f1   volatile int *port;}\par
{\f1   class C \{ mutable int cache; \};}\par
\par
\par
\par
