{\footnote # IDH_CPP_16}
{\footnote $ C++ - EXCEPTIONS}
{\footnote K C++ exceptions;try;catch;throw;noexcept;std::exception;hierarchie}
\b\fs24 EXCEPTIONS \b0\fs20\par
\par
\par
\b 16.1 Levee et capture \b0\par
\par
{\f1   try \{}\par
{\f1       if (x < 0)}\par
{\f1           throw std::invalid_argument("x negatif");}\par
{\f1       // ...}\par
{\f1   \}}\par
{\f1   catch (const std::invalid_argument& e) \{}\par
{\f1       std::cerr << e.what() << std::endl;}\par
{\f1   \}}\par
{\f1   catch (const std::exception& e) \{}\par
{\f1       std::cerr << "Erreur: " << e.what();}\par
{\f1   \}}\par
{\f1   catch (...) \{}\par
{\f1       std::cerr << "Erreur inconnue";}\par
{\f1   \}}\par
\par
\par
\b 16.2 Hierarchie standard \b0\par
\par
{\f1   std::exception}\par
{\f1    |-- std::logic_error}\par
{\f1    |    |-- std::invalid_argument}\par
{\f1    |    |-- std::out_of_range}\par
{\f1    |    |-- std::length_error}\par
{\f1    |    +-- std::domain_error}\par
{\f1    |-- std::runtime_error}\par
{\f1    |    |-- std::range_error}\par
{\f1    |    |-- std::overflow_error}\par
{\f1    |    +-- std::underflow_error}\par
{\f1    |-- std::bad_alloc}\par
{\f1    |-- std::bad_cast}\par
{\f1    |-- std::bad_typeid}\par
{\f1    +-- std::bad_exception}\par
\par
\par
\b 16.3 Specifications d'exception \b0\par
\par
C++98/03 (depreciees C++11) :\par
\par
{\f1   void f() throw();              // ne leve rien}\par
{\f1   void f() throw(std::exception);}\par
\par
C++11 :\par
\par
{\f1   void f() noexcept;             // ne leve pas}\par
{\f1   void f() noexcept(false);      // peut lever}\par
\par
\par
\b 16.4 Re-levee \b0\par
\par
{\f1   catch (...) \{}\par
{\f1       // nettoyage}\par
{\f1       throw;       // re-leve l'exception courante}\par
{\f1   \}}\par
\par
\par
\b 16.5 RAII et exceptions \b0\par
\par
Les destructeurs sont appeles lors du deroulement de la pile.\par
Utiliser des objets RAII (smart pointers, lock_guard) pour\par
liberer proprement les ressources sur exception.\par
\par
\par
\par
