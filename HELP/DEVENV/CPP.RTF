{\footnote # IDH_CPP_22}
{\footnote $ C++ - COMPILATEUR DU PROJET (CPP86.PAS)}
{\footnote K C++ compilateurs projet;CPP86.PAS}
\b\fs24 COMPILATEUR DU PROJET (CPP86.PAS) \b0\fs20\par
\par
CPP86.PAS - Compilateur C++ vers assembleur 8086\par
\par
{\f1   Cible             : MS-DOS, assembleur MASM .MODEL SMALL}\par
{\f1   Modele memoire    : SMALL (code 64KO, donnees 64KO)}\par
{\f1   Sous-ensemble     : C++98 partiel}\par
{\f1   Sortie            : fichier .ASM, assemblable avec MASM}\par
\par
{\f1   Fonctionnalites supportees :}\par
{\f1     - Types fondamentaux : char, short, int, long, float,}\par
{\f1       double (au niveau lexical), void, bool}\par
{\f1     - Pointeurs, references}\par
{\f1     - struct, class, union, enum}\par
{\f1     - Fonctions, surcharge, parametres par defaut}\par
{\f1     - Operateurs, surcharge d'operateurs basique}\par
{\f1     - Classes : constructeurs, destructeurs, methodes}\par
{\f1     - Heritage simple, fonctions virtuelles}\par
{\f1     - Templates simples (instanciation a la demande)}\par
{\f1     - namespace, using}\par
{\f1     - Preprocesseur #include / #define / #if}\par
{\f1     - Compilation conditionnelle}\par
\par
{\f1   Limitations :}\par
{\f1     - Pas de RTTI (typeid, dynamic_cast)}\par
{\f1     - Pas de gestion d'exceptions completes}\par
{\f1     - STL minimale (string, vector simples)}\par
{\f1     - Pas de templates variadiques}\par
{\f1     - Pas de C++11+ (lambdas, auto, ...)}\par
\par
{\f1   Invocation :}\par
{\f1     CPP86 <source.cpp> [sortie.asm] [-v] [-d] [-w]}\par
{\f1       -v : mode verbeux}\par
{\f1       -d : debug}\par
{\f1       -w : affiche les avertissements}\par
\par
\par
\par
