{\footnote # IDH_CPP_14}
{\footnote $ C++ - TEMPLATES (GENERICITE)}
{\footnote K C++ templates;genericite;template typename;classe template;fonction template;specialisation;variadique}
\b\fs24 TEMPLATES (GENERICITE) \b0\fs20\par
\par
\par
\b 14.1 Templates de fonctions \b0\par
\par
{\f1   template <typename T>}\par
{\f1   T max(T a, T b) \{}\par
{\f1       return (a > b) ? a : b;}\par
{\f1   \}}\par
\par
{\f1   int n = max(3, 7);          // T deduit = int}\par
{\f1   double d = max(3.5, 2.1);   // T deduit = double}\par
{\f1   int m = max<int>(3, 7);     // T explicite}\par
\par
\par
\b 14.2 Templates de classes \b0\par
\par
{\f1   template <typename T>}\par
{\f1   class Pile \{}\par
{\f1       T *data;}\par
{\f1       int n;}\par
{\f1   public:}\par
{\f1       Pile();}\par
{\f1       void push(const T& v);}\par
{\f1       T pop();}\par
{\f1   \};}\par
\par
{\f1   template <typename T>}\par
{\f1   void Pile<T>::push(const T& v) \{ /* ... */ \}}\par
\par
{\f1   Pile<int> pi;}\par
{\f1   Pile<std::string> ps;}\par
\par
\par
\b 14.3 Parametres non-type \b0\par
\par
{\f1   template <typename T, int N>}\par
{\f1   class TableauFixe \{}\par
{\f1       T data[N];}\par
{\f1   \};}\par
{\f1   TableauFixe<int, 100> t;}\par
\par
\par
\b 14.4 Specialisations \b0\par
\par
{\f1   template <typename T>}\par
{\f1   class Tampon \{ /* generique */ \};}\par
\par
{\f1   template <>}\par
{\f1   class Tampon<bool> \{ /* specialisation pour bool */ \};}\par
\par
\par
\b 14.5 Parametres variadiques (C++11) \b0\par
\par
{\f1   template <typename... Args>}\par
{\f1   void print(Args... args) \{}\par
{\f1       // ...}\par
{\f1   \}}\par
\par
\par
\par
