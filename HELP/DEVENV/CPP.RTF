{\footnote # IDH_CPP_09}
{\footnote $ C++ - TABLEAUX}
{\footnote K C++ tableaux;array;vector;multidimensionnel;std::array;std::vector}
\b\fs24 TABLEAUX \b0\fs20\par
\par
\par
\b 9.1 Declaration \b0\par
\par
{\f1   type nom[taille];}\par
{\f1   int t[10];}\par
{\f1   int m[3][4];}\par
\par
\par
\b 9.2 Initialisation \b0\par
\par
{\f1   int t[5] = \{1, 2, 3, 4, 5\};}\par
{\f1   int v[] = \{10, 20, 30\};}\par
{\f1   int m[2][3] = \{\{1,2,3\}, \{4,5,6\}\};}\par
{\f1   int z[100] = \{0\};      // tous a 0}\par
\par
\par
\b 9.3 std::array (C++11) \b0\par
\par
Conteneur a taille fixe sans degradation en pointeur :\par
\par
{\f1   #include <array>}\par
{\f1   std::array<int, 5> t = \{1, 2, 3, 4, 5\};}\par
{\f1   for (int x : t) std::cout << x;}\par
\par
\par
\b 9.4 std::vector \b0\par
\par
Tableau dynamique a taille variable :\par
\par
{\f1   #include <vector>}\par
{\f1   std::vector<int> v;}\par
{\f1   v.push_back(42);}\par
{\f1   v.resize(100);}\par
{\f1   for (size_t i = 0; i < v.size(); ++i)}\par
{\f1       std::cout << v[i];}\par
\par
\par
\par
