{\footnote # IDH_CPP_10}
{\footnote $ C++ - POINTEURS ET REFERENCES}
{\footnote K C++ pointeurs;references;rvalue reference;unique_ptr;shared_ptr;weak_ptr;new;delete;placement new}
\b\fs24 POINTEURS ET REFERENCES \b0\fs20\par
\par
\par
\b 10.1 Pointeurs \b0\par
\par
Identiques a C :\par
\par
{\f1   int *p;}\par
{\f1   int x = 10;}\par
{\f1   p = &x;}\par
{\f1   *p = 20;}\par
\par
\par
\b 10.2 References \b0\par
\par
Alias d'une variable existante, initialise obligatoirement :\par
\par
{\f1   int x = 10;}\par
{\f1   int &r = x;        // r est un alias de x}\par
{\f1   r = 20;            // x vaut maintenant 20}\par
\par
Differences avec les pointeurs :\par
\par
{\f1   - Doit etre initialisee a la declaration}\par
{\f1   - Ne peut etre reaffectee a un autre objet}\par
{\f1   - Ne peut etre nulle}\par
{\f1   - Pas de syntaxe de dereferencement (utilisation directe)}\par
\par
\par
\b 10.3 References constantes \b0\par
\par
{\f1   const int &r = x;       // lecture seule}\par
{\f1   void f(const std::string &s);   // passage efficace}\par
\par
\par
\b 10.4 References rvalue (C++11) \b0\par
\par
{\f1   int &&rr = 42;}\par
{\f1   void g(std::string &&s);     // semantique de mouvement}\par
\par
\par
\b 10.5 Pointeurs intelligents (C++11) \b0\par
\par
{\f1   std::unique_ptr<T>   propriete exclusive}\par
{\f1   std::shared_ptr<T>   propriete partagee (comptage)}\par
{\f1   std::weak_ptr<T>     reference faible}\par
\par
{\f1   #include <memory>}\par
{\f1   std::unique_ptr<int> p(new int(42));}\par
{\f1   std::shared_ptr<Foo> sp = std::make_shared<Foo>();}\par
\par
\par
\b 10.6 new / delete \b0\par
\par
{\f1   T *p = new T;            // un objet}\par
{\f1   T *t = new T[N];         // tableau de N objets}\par
{\f1   delete p;}\par
{\f1   delete[] t;}\par
\par
{\f1   // Placement new}\par
{\f1   void *mem = ::operator new(sizeof(T));}\par
{\f1   T *q = new (mem) T(args);}\par
{\f1   q->~T();}\par
{\f1   ::operator delete(mem);}\par
\par
\par
\par
