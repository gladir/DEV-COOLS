{\footnote # IDH_CPP_13}
{\footnote $ C++ - SURCHARGE D'OPERATEURS}
{\footnote K C++ surcharge operateurs;operator+;operator=;operator++;operator<<;friend;foncteur}
\b\fs24 SURCHARGE D'OPERATEURS \b0\fs20\par
\par
Operateurs courants surchargeables :\par
\par
{\f1   +  -  *  /  %  ^  &  |  ~  !  =  <  >}\par
{\f1   += -= *= /= %= ^= &= |= <<  >>  <<= >>=  ==  !=}\par
{\f1   <= >= && || ++ -- ,  ->*  ->  ()  []  new delete}\par
\par
Exemple complet :\par
\par
{\f1   class Complex \{}\par
{\f1       double re, im;}\par
{\f1   public:}\par
{\f1       Complex(double r=0, double i=0): re(r), im(i) \{\}}\par
{\f1       Complex operator+(const Complex& c) const \{}\par
{\f1           return Complex(re+c.re, im+c.im);}\par
{\f1       \}}\par
{\f1       Complex& operator+=(const Complex& c) \{}\par
{\f1           re += c.re; im += c.im; return *this;}\par
{\f1       \}}\par
{\f1       bool operator==(const Complex& c) const \{}\par
{\f1           return re == c.re && im == c.im;}\par
{\f1       \}}\par
{\f1       friend std::ostream& operator<<(}\par
{\f1           std::ostream& os, const Complex& c);}\par
{\f1   \};}\par
\par
{\f1   std::ostream& operator<<(std::ostream& os, const Complex& c)\{}\par
{\f1       return os << c.re << "+" << c.im << "i";}\par
{\f1   \}}\par
\par
Operateurs speciaux :\par
\par
{\f1   - operator= (affectation) : retourne *this}\par
{\f1   - operator++/-- : version prefixe et postfixe distinguees}\par
{\f1   - operator() : foncteur (objet appelable)}\par
{\f1   - operator-> : retourne pointeur ou objet avec operator->}\par
{\f1   - operator[] : indexation}\par
{\f1   - operator T() : conversion vers T}\par
\par
\par
\par
