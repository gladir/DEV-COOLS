{\footnote # IDH_CPP_07}
{\footnote $ C++ - STRUCTURES DE CONTROLE}
{\footnote K C++ structures controle;if;else;switch;case;while;do;for;range-for;break;continue;return;goto;try;catch;throw}
\b\fs24 STRUCTURES DE CONTROLE \b0\fs20\par
\par
\par
\b 7.1 Selection \b0\par
\par
{\f1   if (expression) instruction}\par
{\f1   if (expression) instruction else instruction}\par
{\f1   if (init; condition) ...    // C++17}\par
{\f1   if constexpr (expr) ...     // C++17}\par
\par
{\f1   switch (expression) \{}\par
{\f1       case constante: instructions; break;}\par
{\f1       case constante: instructions; break;}\par
{\f1       ...}\par
{\f1       default: instructions;}\par
{\f1   \}}\par
\par
\par
\b 7.2 Iteration \b0\par
\par
{\f1   while (expression) instruction}\par
{\f1   do instruction while (expression);}\par
{\f1   for (init; condition; iteration) instruction}\par
{\f1   for (declaration : range) instruction      // C++11}\par
\par
Exemple range-for :\par
\par
{\f1   int t[] = \{1, 2, 3, 4, 5\};}\par
{\f1   for (int x : t) std::cout << x;}\par
\par
\par
\b 7.3 Saut \b0\par
\par
{\f1   break;}\par
{\f1   continue;}\par
{\f1   return [expression];}\par
{\f1   goto etiquette;}\par
\par
\par
\b 7.4 Instructions composees \b0\par
\par
{\f1   \{ instructions \}      // bloc, definit une portee}\par
\par
\par
\b 7.5 Gestion d'exceptions \b0\par
\par
{\f1   try \{}\par
{\f1       // code susceptible de lever une exception}\par
{\f1   \} catch (Type1 e) \{}\par
{\f1       // gestion specifique}\par
{\f1   \} catch (Type2& e) \{}\par
{\f1       // gestion par reference}\par
{\f1   \} catch (...) \{}\par
{\f1       // gestion generique}\par
{\f1   \}}\par
\par
{\f1   throw expression;   // levee}\par
{\f1   throw;              // re-levee dans un catch}\par
\par
\par
\par
