{\footnote # IDH_CPP_11}
{\footnote $ C++ - CLASSES ET OBJETS}
{\footnote K C++ classes;objets;struct;class;public;private;protected;constructeur;destructeur;RAII;this;static;mutable}
\b\fs24 CLASSES ET OBJETS \b0\fs20\par
\par
\par
\b 11.1 Declaration de classe \b0\par
\par
{\f1   class Point \{}\par
{\f1   private:}\par
{\f1       int x, y;}\par
{\f1   public:}\par
{\f1       Point();                    // constructeur par defaut}\par
{\f1       Point(int x, int y);        // constructeur parametre}\par
{\f1       Point(const Point& p);      // constructeur de copie}\par
{\f1       ~Point();                   // destructeur}\par
{\f1       void deplacer(int dx, int dy);}\par
{\f1       int getX() const;           // methode const}\par
{\f1       int getY() const;}\par
{\f1   \};}\par
\par
\par
\b 11.2 Specificateurs d'acces \b0\par
\par
{\f1   public      accessible depuis l'exterieur}\par
{\f1   private     accessible uniquement par la classe (defaut)}\par
{\f1   protected   accessible par la classe et ses derivees}\par
\par
\par
\b 11.3 struct vs class \b0\par
\par
Identiques sauf :\par
{\f1   - struct : membres publics par defaut}\par
{\f1   - class  : membres prives par defaut}\par
\par
\par
\b 11.4 Constructeurs \b0\par
\par
{\f1   Point::Point() : x(0), y(0) \{ \}                  // defaut}\par
{\f1   Point::Point(int x, int y) : x(x), y(y) \{ \}      // parametre}\par
{\f1   Point::Point(const Point& p) : x(p.x), y(p.y) \{\} // copie}\par
\par
C++11 : delegation et = default / = delete :\par
\par
{\f1   Point() : Point(0, 0) \{ \}       // delegation}\par
{\f1   Point() = default;}\par
{\f1   Point(const Point&) = delete;   // copie interdite}\par
\par
\par
\b 11.5 Destructeur \b0\par
\par
{\f1   ~Point() \{ /* liberation des ressources */ \}}\par
\par
Appele automatiquement lors de la destruction de l'objet\par
(sortie de bloc, delete, fin de programme).\par
\par
\par
\b 11.6 RAII (Resource Acquisition Is Initialization) \b0\par
\par
Idiome fondamental : associer la duree de vie d'une ressource\par
a celle d'un objet. Acquisition dans le constructeur,\par
liberation dans le destructeur.\par
\par
{\f1   class Fichier \{}\par
{\f1       FILE *f;}\par
{\f1   public:}\par
{\f1       Fichier(const char *nom) \{ f = fopen(nom, "r"); \}}\par
{\f1       ~Fichier() \{ if (f) fclose(f); \}}\par
{\f1   \};}\par
\par
\par
\b 11.7 Membres statiques \b0\par
\par
{\f1   class Compteur \{}\par
{\f1   public:}\par
{\f1       static int total;}\par
{\f1       static int nouveau();}\par
{\f1   \};}\par
{\f1   int Compteur::total = 0;}\par
{\f1   int Compteur::nouveau() \{ return ++total; \}}\par
\par
\par
\b 11.8 Membres const et mutable \b0\par
\par
Methode const : ne modifie pas l'objet.\par
\par
{\f1   int getX() const \{ return x; \}}\par
\par
Membre mutable : modifiable depuis methode const.\par
\par
{\f1   mutable int cache;}\par
\par
\par
\b 11.9 this \b0\par
\par
Pointeur implicite vers l'objet courant dans les methodes\par
non-statiques.\par
\par
{\f1   Point& Point::operator=(const Point& p) \{}\par
{\f1       if (this != &p) \{}\par
{\f1           x = p.x; y = p.y;}\par
{\f1       \}}\par
{\f1       return *this;}\par
{\f1   \}}\par
\par
\par
\par
