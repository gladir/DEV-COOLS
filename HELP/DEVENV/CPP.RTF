{\footnote # IDH_CPP_20}
{\footnote $ C++ - EVOLUTIONS DU LANGAGE}
{\footnote K C++ evolutions;C++98;C++03;C++11;C++14;C++17;C++20;C++23;auto;lambda;concepts;modules;coroutines}
\b\fs24 EVOLUTIONS DU LANGAGE \b0\fs20\par
\par
\par
\b 20.1 C++98 / C++03 \b0\par
\par
Base : classes, templates, STL, exceptions, RTTI, namespaces.\par
\par
\par
\b 20.2 C++11 \b0\par
\par
{\f1   - auto (deduction), decltype}\par
{\f1   - Range-for, nullptr}\par
{\f1   - Lambdas}\par
{\f1   - Move semantics, rvalue references (&&)}\par
{\f1   - Initialisation uniforme \{\}, listes d'initialisation}\par
{\f1   - constexpr}\par
{\f1   - enum class}\par
{\f1   - Smart pointers (unique_ptr, shared_ptr)}\par
{\f1   - std::thread, std::mutex, std::atomic}\par
{\f1   - Templates variadiques}\par
{\f1   - override, final, = default, = delete}\par
{\f1   - static_assert}\par
{\f1   - noexcept}\par
{\f1   - Litteraux definis par l'utilisateur}\par
\par
\par
\b 20.3 C++14 \b0\par
\par
{\f1   - Lambdas generiques (auto en parametres)}\par
{\f1   - Deduction du type de retour pour fonctions ordinaires}\par
{\f1   - constexpr etendu}\par
{\f1   - Separateurs numeriques (1'000'000)}\par
{\f1   - std::make_unique}\par
\par
\par
\b 20.4 C++17 \b0\par
\par
{\f1   - if constexpr, if (init; cond)}\par
{\f1   - structured bindings : auto [a, b] = paire;}\par
{\f1   - std::optional, std::variant, std::any}\par
{\f1   - std::filesystem}\par
{\f1   - Inline variables}\par
{\f1   - Templates a parametres deduits}\par
\par
\par
\b 20.5 C++20 \b0\par
\par
{\f1   - Concepts (contraintes sur templates)}\par
{\f1   - Modules}\par
{\f1   - Coroutines}\par
{\f1   - Operateur three-way <=>}\par
{\f1   - Ranges}\par
{\f1   - constinit, consteval}\par
\par
\par
\b 20.6 C++23 \b0\par
\par
{\f1   - std::expected}\par
{\f1   - std::print}\par
{\f1   - Deducing this}\par
{\f1   - Extension de constexpr}\par
\par
\par
\par
