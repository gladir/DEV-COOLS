{\footnote # IDH_CPP_17}
{\footnote $ C++ - BIBLIOTHEQUE STANDARD STL}
{\footnote K C++ STL;bibliotheque standard;vector;list;map;set;deque;string;algorithm;iterator;foncteur;flux;iostream}
\b\fs24 BIBLIOTHEQUE STANDARD STL \b0\fs20\par
\par
\par
\b 17.1 Conteneurs \b0\par
\par
{\f1   <vector>       std::vector<T>          tableau dynamique}\par
{\f1   <deque>        std::deque<T>           file double}\par
{\f1   <list>         std::list<T>            liste chainee}\par
{\f1   <forward_list> std::forward_list<T>    liste simple (C++11)}\par
{\f1   <array>        std::array<T,N>         tableau fixe (C++11)}\par
{\f1   <set>          std::set<T>             ensemble trie}\par
{\f1   <multiset>     std::multiset<T>        ensemble trie multi}\par
{\f1   <map>          std::map<K,V>           dictionnaire trie}\par
{\f1   <multimap>     std::multimap<K,V>      dico trie multi}\par
{\f1   <unordered_set> std::unordered_set<T>  ensemble hash (C++11)}\par
{\f1   <unordered_map> std::unordered_map     dico hash (C++11)}\par
{\f1   <stack>        std::stack<T>           pile}\par
{\f1   <queue>        std::queue<T>           file}\par
{\f1   <queue>        std::priority_queue<T>  file de priorite}\par
\par
\par
\b 17.2 Iterateurs \b0\par
\par
Categories : input, output, forward, bidirectional,\par
random-access (et contiguous en C++17).\par
\par
{\f1   std::vector<int>::iterator it;}\par
{\f1   for (it = v.begin(); it != v.end(); ++it)}\par
{\f1       std::cout << *it;}\par
\par
{\f1   // Range-for (C++11) equivalent}\par
{\f1   for (auto& x : v) std::cout << x;}\par
\par
\par
\b 17.3 Algorithmes \b0\par
\par
En-tete <algorithm> : sort, find, copy, transform, accumulate,\par
for_each, count, min, max, remove, replace, reverse, unique,\par
binary_search, etc.\par
\par
{\f1   std::sort(v.begin(), v.end());}\par
{\f1   auto it = std::find(v.begin(), v.end(), 42);}\par
{\f1   int s = std::accumulate(v.begin(), v.end(), 0);}\par
\par
\par
\b 17.4 Foncteurs \b0\par
\par
En-tete <functional> : less, greater, plus, multiplies,\par
function, bind, etc.\par
\par
{\f1   std::sort(v.begin(), v.end(), std::greater<int>());}\par
\par
\par
\b 17.5 Chaines \b0\par
\par
En-tete <string> : std::string, std::wstring.\par
\par
{\f1   std::string s = "Hello";}\par
{\f1   s += ", World!";}\par
{\f1   s.length();}\par
{\f1   s.substr(0, 5);}\par
{\f1   s.find("World");}\par
{\f1   s.replace(0, 5, "Bye");}\par
\par
\par
\b 17.6 Flux \b0\par
\par
En-tete <iostream>, <fstream>, <sstream>.\par
\par
{\f1   std::cin >> n;}\par
{\f1   std::cout << "x = " << x << std::endl;}\par
{\f1   std::ifstream f("data.txt");}\par
{\f1   std::ofstream o("out.txt");}\par
{\f1   std::stringstream ss;}\par
{\f1   ss << "val=" << 42;}\par
\par
\par
\b 17.7 Utilitaires (C++11+) \b0\par
\par
{\f1   <memory>       smart pointers}\par
{\f1   <utility>      pair, move, forward, swap}\par
{\f1   <tuple>        tuple}\par
{\f1   <chrono>       horodatage et durees}\par
{\f1   <thread>       threads}\par
{\f1   <mutex>        verrous}\par
{\f1   <atomic>       operations atomiques}\par
{\f1   <regex>        expressions regulieres}\par
{\f1   <random>       generateurs pseudo-aleatoires}\par
{\f1   <filesystem>   systeme de fichiers (C++17)}\par
{\f1   <optional>     valeur optionnelle (C++17)}\par
{\f1   <variant>      union typee (C++17)}\par
{\f1   <any>          conteneur de type (C++17)}\par
\par
\par
\par
