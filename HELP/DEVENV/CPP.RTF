{\footnote # IDH_CPP_23}
{\footnote $ C++ - EXEMPLES}
{\footnote K C++ exemples;Hello World;Fibonacci;classe Point;template Pile;polymorphisme}
\b\fs24 EXEMPLES \b0\fs20\par
\par
\par
\b 23.1 Hello, World! \b0\par
\par
{\f1   #include <iostream>}\par
{\f1   int main() \{}\par
{\f1       std::cout << "Hello, World!" << std::endl;}\par
{\f1       return 0;}\par
{\f1   \}}\par
\par
\par
\b 23.2 Fibonacci recursif \b0\par
\par
{\f1   #include <iostream>}\par
\par
{\f1   unsigned long fibonacci(unsigned int n) \{}\par
{\f1       if (n < 2) return n;}\par
{\f1       return fibonacci(n - 1) + fibonacci(n - 2);}\par
{\f1   \}}\par
\par
{\f1   int main() \{}\par
{\f1       for (unsigned int i = 0; i < 10; ++i)}\par
{\f1           std::cout << fibonacci(i) << " ";}\par
{\f1       std::cout << std::endl;}\par
{\f1       return 0;}\par
{\f1   \}}\par
\par
\par
\b 23.3 Classe Point avec surcharge \b0\par
\par
{\f1   #include <iostream>}\par
\par
{\f1   class Point \{}\par
{\f1       double x, y;}\par
{\f1   public:}\par
{\f1       Point(double x = 0, double y = 0) : x(x), y(y) \{ \}}\par
{\f1       Point operator+(const Point& p) const \{}\par
{\f1           return Point(x + p.x, y + p.y);}\par
{\f1       \}}\par
{\f1       friend std::ostream& operator<<(}\par
{\f1           std::ostream& os, const Point& p) \{}\par
{\f1           return os << "(" << p.x << ", " << p.y << ")";}\par
{\f1       \}}\par
{\f1   \};}\par
\par
{\f1   int main() \{}\par
{\f1       Point a(1, 2), b(3, 4);}\par
{\f1       Point c = a + b;}\par
{\f1       std::cout << a << " + " << b << " = " << c << std::endl;}\par
{\f1       return 0;}\par
{\f1   \}}\par
\par
\par
\b 23.4 Template de pile \b0\par
\par
{\f1   template <typename T>}\par
{\f1   class Pile \{}\par
{\f1       T data[100];}\par
{\f1       int n;}\par
{\f1   public:}\par
{\f1       Pile() : n(0) \{ \}}\par
{\f1       void push(const T& v) \{ data[n++] = v; \}}\par
{\f1       T pop() \{ return data[--n]; \}}\par
{\f1       bool vide() const \{ return n == 0; \}}\par
{\f1   \};}\par
\par
{\f1   int main() \{}\par
{\f1       Pile<int> p;}\par
{\f1       p.push(1); p.push(2); p.push(3);}\par
{\f1       while (!p.vide())}\par
{\f1           std::cout << p.pop() << " ";}\par
{\f1       return 0;}\par
{\f1   \}}\par
\par
\par
\b 23.5 Heritage et polymorphisme \b0\par
\par
{\f1   #include <iostream>}\par
\par
{\f1   class Forme \{}\par
{\f1   public:}\par
{\f1       virtual double aire() const = 0;}\par
{\f1       virtual ~Forme() \{ \}}\par
{\f1   \};}\par
\par
{\f1   class Cercle : public Forme \{}\par
{\f1       double r;}\par
{\f1   public:}\par
{\f1       Cercle(double r) : r(r) \{ \}}\par
{\f1       double aire() const \{ return 3.14159 * r * r; \}}\par
{\f1   \};}\par
\par
{\f1   class Rectangle : public Forme \{}\par
{\f1       double l, h;}\par
{\f1   public:}\par
{\f1       Rectangle(double l, double h) : l(l), h(h) \{ \}}\par
{\f1       double aire() const \{ return l * h; \}}\par
{\f1   \};}\par
\par
{\f1   int main() \{}\par
{\f1       Forme *formes[2] = \{}\par
{\f1           new Cercle(5),}\par
{\f1           new Rectangle(3, 4)}\par
{\f1       \};}\par
{\f1       for (int i = 0; i < 2; ++i) \{}\par
{\f1           std::cout << formes[i]->aire() << std::endl;}\par
{\f1           delete formes[i];}\par
{\f1       \}}\par
{\f1       return 0;}\par
{\f1   \}}\par
\par
\par
\par
