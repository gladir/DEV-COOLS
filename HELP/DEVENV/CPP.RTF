{\footnote # IDH_CPP_15}
{\footnote $ C++ - ESPACES DE NOMS (NAMESPACES)}
{\footnote K C++ namespaces;namespace;using;alias;std;anonyme}
\b\fs24 ESPACES DE NOMS (NAMESPACES) \b0\fs20\par
\par
\par
\b 15.1 Declaration \b0\par
\par
{\f1   namespace math \{}\par
{\f1       const double PI = 3.14159;}\par
{\f1       double sqrt(double x);}\par
{\f1   \}}\par
\par
{\f1   double r = math::sqrt(2.0);}\par
\par
\par
\b 15.2 Espace anonyme \b0\par
\par
Equivalent a static en C : portee fichier.\par
\par
{\f1   namespace \{}\par
{\f1       int interne = 0;}\par
{\f1   \}}\par
\par
\par
\b 15.3 Directives using \b0\par
\par
{\f1   using namespace math;        // tout le namespace}\par
{\f1   using math::PI;              // un seul nom}\par
{\f1   using AliasPI = math::PI;    // (C++11 pour alias de type)}\par
\par
Eviter using namespace std; dans les en-tetes.\par
\par
\par
\b 15.4 Alias de namespace \b0\par
\par
{\f1   namespace longue_lib = ma::tres::longue::bibliotheque;}\par
{\f1   longue_lib::fonction();}\par
\par
\par
\b 15.5 Espace std \b0\par
\par
Tout la bibliotheque standard reside dans std::\par
\par
{\f1   std::cout, std::string, std::vector, std::map, ...}\par
\par
\par
\par
