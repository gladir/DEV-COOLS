{\footnote # IDH_TPOVL_12}
{\footnote $ Unite Overlay - EXEMPLES COMPLETS}
{\footnote K Turbo Pascal;Unite Overlay;EXEMPLES COMPLETS}
\b\fs24 EXEMPLES COMPLETS \b0\fs20\par
\par
{\f1   --- Exemple 1 : Initialisation basique ---}\par
\par
{\f1   program OverlayDemo;}\par
{\f1   uses Overlay, MonUnite1, MonUnite2;}\par
{\f1   \{$O MonUnite1\}}\par
{\f1   \{$O MonUnite2\}}\par
{\f1   begin}\par
{\f1     OvrInit('OVERLAYDEMO.OVR');}\par
{\f1     if OvrResult <> ovrOk then}\par
{\f1     begin}\par
{\f1       case OvrResult of}\par
{\f1         ovrNotFound : WriteLn('Fichier .OVR non trouv??');}\par
{\f1         ovrNoMemory : WriteLn('M??moire insuffisante');}\par
{\f1         ovrIOError  : WriteLn('Erreur E/S');}\par
{\f1       else}\par
{\f1         WriteLn('Erreur overlay : ', OvrResult);}\par
{\f1       end;}\par
{\f1       Halt(1);}\par
{\f1     end;}\par
\par
{\f1     \{ Appels normaux aux unit??s overlay \}}\par
{\f1     Procedure1DeMonUnite1;}\par
{\f1     Procedure1DeMonUnite2;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : Avec EMS et tampon ??largi ---}\par
\par
{\f1   program OverlayEMS;}\par
{\f1   uses Overlay, Phase1, Phase2, Phase3;}\par
{\f1   \{$O Phase1\}}\par
{\f1   \{$O Phase2\}}\par
{\f1   \{$O Phase3\}}\par
{\f1   begin}\par
{\f1     OvrInit('OVERLAYEMS.OVR');}\par
{\f1     if OvrResult <> ovrOk then Halt(1);}\par
\par
{\f1     \{ Tenter d'utiliser l'EMS \}}\par
{\f1     OvrInitEMS;}\par
{\f1     if OvrResult = ovrOk then}\par
{\f1       WriteLn('Overlays en EMS : ', OvrEmsPages, ' pages')}\par
{\f1     else}\par
{\f1     begin}\par
{\f1       WriteLn('EMS non disponible, augmentation du tampon...');}\par
{\f1       OvrSetBuf(96 * 1024);  \{ 96 Ko \}}\par
{\f1       OvrSetRetry(32 * 1024); \{ 32 Ko zone de r??essai \}}\par
{\f1     end;}\par
\par
{\f1     \{ Ex??cution du programme \}}\par
{\f1     ExecuterPhase1;}\par
{\f1     ExecuterPhase2;}\par
{\f1     ExecuterPhase3;}\par
\par
{\f1     \{ Statistiques \}}\par
{\f1     WriteLn('Traps : ', OvrTrapCount);}\par
{\f1     WriteLn('Chargements : ', OvrLoadCount);}\par
{\f1     WriteLn('Tampon : ', OvrGetBuf, ' octets');}\par
{\f1     WriteLn('Zone r??essai : ', OvrGetRetry, ' octets');}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Mesure de performance ---}\par
\par
{\f1   program OverlayPerf;}\par
{\f1   uses Overlay, UnitA, UnitB;}\par
{\f1   \{$O UnitA\}}\par
{\f1   \{$O UnitB\}}\par
{\f1   var}\par
{\f1     Ratio : Real;}\par
{\f1   begin}\par
{\f1     OvrInit('OVERLAYPERF.OVR');}\par
{\f1     if OvrResult <> ovrOk then Halt(1);}\par
\par
{\f1     OvrSetBuf(48 * 1024);}\par
\par
{\f1     \{ Phase de travail \}}\par
{\f1     AppelerDiversesFonctions;}\par
\par
{\f1     \{ Analyser les performances \}}\par
{\f1     if OvrTrapCount > 0 then}\par
{\f1     begin}\par
{\f1       Ratio := OvrLoadCount / OvrTrapCount;}\par
{\f1       WriteLn('Traps : ', OvrTrapCount);}\par
{\f1       WriteLn('Chargements : ', OvrLoadCount);}\par
{\f1       WriteLn('Ratio charge/trap : ', Ratio:5:2);}\par
{\f1       if Ratio > 0.5 then}\par
{\f1         WriteLn('ATTENTION : thrashing d??tect??, augmenter le tampon')}\par
{\f1       else}\par
{\f1         WriteLn('Performance correcte');}\par
{\f1     end;}\par
{\f1   end.}\par
\par
