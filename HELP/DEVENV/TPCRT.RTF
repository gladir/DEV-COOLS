{\footnote # IDH_TPCRT_11}
{\footnote $ Unite Crt - EXEMPLES D'UTILISATION}
{\footnote K Turbo Pascal;Unite Crt;EXEMPLES D'UTILISATION}
\b\fs24 EXEMPLES D'UTILISATION \b0\fs20\par
\par
\par
\b 11.1 Programme de base avec CRT \b0\par
\par
{\f1   Program DemoCrt;}\par
{\f1   Uses Crt;}\par
{\f1   Var Ch : Char;}\par
{\f1   Begin}\par
{\f1     ClrScr;}\par
{\f1     TextColor(Yellow);}\par
{\f1     TextBackground(Blue);}\par
{\f1     ClrScr;}\par
{\f1     GotoXY(30, 12);}\par
{\f1     WriteLn('Appuyez sur une touche...');}\par
{\f1     Ch := ReadKey;}\par
{\f1     NormVideo;}\par
{\f1     ClrScr;}\par
{\f1   End.}\par
\par
\par
\b 11.2 Fenetre avec bordure \b0\par
\par
{\f1   Program DemoFenetre;}\par
{\f1   Uses Crt;}\par
{\f1   Var I : Integer;}\par
{\f1   Begin}\par
{\f1     ClrScr;}\par
{\f1     \{ Dessiner la bordure \}}\par
{\f1     TextColor(White);}\par
{\f1     TextBackground(Blue);}\par
{\f1     For I := 10 To 70 Do}\par
{\f1     Begin}\par
{\f1       GotoXY(I, 5);  Write(Chr(196));     \{ ligne horizontale haut \}}\par
{\f1       GotoXY(I, 20); Write(Chr(196));     \{ ligne horizontale bas  \}}\par
{\f1     End;}\par
{\f1     For I := 5 To 20 Do}\par
{\f1     Begin}\par
{\f1       GotoXY(10, I); Write(Chr(179));     \{ ligne verticale gauche \}}\par
{\f1       GotoXY(70, I); Write(Chr(179));     \{ ligne verticale droite \}}\par
{\f1     End;}\par
{\f1     GotoXY(10, 5);  Write(Chr(218));      \{ coin haut gauche       \}}\par
{\f1     GotoXY(70, 5);  Write(Chr(191));      \{ coin haut droit        \}}\par
{\f1     GotoXY(10, 20); Write(Chr(192));      \{ coin bas gauche        \}}\par
{\f1     GotoXY(70, 20); Write(Chr(217));      \{ coin bas droit         \}}\par
{\f1     \{ Contenu de la fenetre \}}\par
{\f1     Window(11, 6, 69, 19);}\par
{\f1     ClrScr;}\par
{\f1     WriteLn('Contenu de la fenetre');}\par
{\f1     ReadKey;}\par
{\f1     Window(1, 1, 80, 25);}\par
{\f1     NormVideo;}\par
{\f1     ClrScr;}\par
{\f1   End.}\par
\par
\par
\b 11.3 Attente avec animation \b0\par
\par
{\f1   Program DemoAnim;}\par
{\f1   Uses Crt;}\par
{\f1   Const Spinner : Array[1..4] Of Char = ('|', '/', '-', '\\');}\par
{\f1   Var I : Integer;}\par
{\f1   Begin}\par
{\f1     ClrScr;}\par
{\f1     Write('Chargement... ');}\par
{\f1     I := 1;}\par
{\f1     While Not KeyPressed Do}\par
{\f1     Begin}\par
{\f1       Write(Spinner[I], #8);   \{ afficher puis reculer \}}\par
{\f1       Inc(I);}\par
{\f1       If I > 4 Then I := 1;}\par
{\f1       Delay(100);}\par
{\f1     End;}\par
{\f1     ReadKey;  \{ consommer la touche \}}\par
{\f1     WriteLn('Termine !');}\par
{\f1   End.}\par
\par
\par
\b 11.4 Son et melodie \b0\par
\par
{\f1   Program DemoSon;}\par
{\f1   Uses Crt;}\par
{\f1   Begin}\par
{\f1     WriteLn('Bip !');}\par
{\f1     Sound(1000);}\par
{\f1     Delay(200);}\par
{\f1     NoSound;}\par
{\f1     Delay(100);}\par
{\f1     Sound(1500);}\par
{\f1     Delay(200);}\par
{\f1     NoSound;}\par
{\f1     WriteLn('Fin');}\par
{\f1   End.}\par
\par
\par
