{\footnote # IDH_TPCRT_08}
{\footnote $ Unite Crt - PROCEDURE - TEMPORISATION}
{\footnote K Turbo Pascal;Unite Crt;PROCEDURE - TEMPORISATION}
\b\fs24 PROCEDURE - TEMPORISATION \b0\fs20\par
\par
{\f1   Procedure Delay(MS : Word);}\par
{\f1     - Attend MS millisecondes environ}\par
{\f1     - Bloquante : le programme est suspendu pendant la duree}\par
{\f1     - Precision limitee (depend du timer systeme)}\par
{\f1     - En DOS, utilise une boucle calibree sur le timer 8253}\par
{\f1     - En Win32, peut etre emule par Sleep(MS)}\par
{\f1     - MS est un Word : valeur maximale = 65535 ms (~65 secondes)}\par
{\f1     - Exemple :}\par
{\f1         WriteLn('Debut');}\par
{\f1         Delay(2000);        \{ attendre 2 secondes \}}\par
{\f1         WriteLn('Fin');}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPCRT_07}     {\uldb Suivant >>}{\v IDH_TPCRT_09}     {\uldb Sommaire}{\v IDH_TPCRT_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
