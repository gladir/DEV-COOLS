{\footnote # IDH_TPCRT_05}
{\footnote $ Unite Crt - PROCEDURES ET FONCTIONS - ECRAN}
{\footnote K Turbo Pascal;Unite Crt;PROCEDURES ET FONCTIONS - ECRAN}
\b\fs24 PROCEDURES ET FONCTIONS - ECRAN \b0\fs20\par
\par
\par
\b 5.1 Mode texte \b0\par
\par
{\f1   Procedure TextMode(Mode : Integer);}\par
{\f1     - Change le mode texte de l'ecran}\par
{\f1     - Efface l'ecran et reinitialise la fenetre}\par
{\f1     - TextAttr est remis a $07 (LightGray sur Black)}\par
{\f1     - WindMin/WindMax sont remis a plein ecran}\par
{\f1     - LastMode est mis a jour avec le mode precedent}\par
{\f1     - Modes valides : BW40, CO40, BW80, CO80, Mono}\par
{\f1     - Peut etre combine avec Font8x8 :}\par
{\f1         TextMode(CO80 + Font8x8);  \{ 80x50 sur VGA \}}\par
{\f1     - Exemple : TextMode(CO80);}\par
\par
\par
\b 5.2 Fenetre texte \b0\par
\par
{\f1   Procedure Window(X1, Y1, X2, Y2 : Byte);}\par
{\f1     - Definit une fenetre texte (zone de sortie)}\par
{\f1     - X1,Y1 = coin superieur gauche (1,1 = haut gauche ecran)}\par
{\f1     - X2,Y2 = coin inferieur droit}\par
{\f1     - Toutes les coordonnees deviennent relatives a la fenetre}\par
{\f1     - Le curseur est deplace en (1,1) de la fenetre}\par
{\f1     - Le defilement se fait a l'interieur de la fenetre}\par
{\f1     - Exemple :}\par
{\f1         Window(10, 5, 70, 20);  \{ fenetre de 61x16 \}}\par
{\f1         ClrScr;                 \{ efface seulement la fenetre \}}\par
{\f1         WriteLn('Dans la fenetre');}\par
{\f1     - Pour restaurer le plein ecran :}\par
{\f1         Window(1, 1, 80, 25);}\par
\par
\par
\b 5.3 Positionnement du curseur \b0\par
\par
{\f1   Procedure GotoXY(X, Y : Byte);}\par
{\f1     - Deplace le curseur a la position (X, Y)}\par
{\f1     - Coordonnees relatives a la fenetre active}\par
{\f1     - X = colonne (1 = gauche), Y = ligne (1 = haut)}\par
{\f1     - Exemple : GotoXY(1, 1);  \{ coin superieur gauche \}}\par
\par
{\f1   Function WhereX : Byte;}\par
{\f1     - Retourne la colonne courante du curseur (1-based)}\par
{\f1     - Relative a la fenetre active}\par
{\f1     - Exemple : Col := WhereX;}\par
\par
{\f1   Function WhereY : Byte;}\par
{\f1     - Retourne la ligne courante du curseur (1-based)}\par
{\f1     - Relative a la fenetre active}\par
{\f1     - Exemple : Lig := WhereY;}\par
\par
\par
\b 5.4 Effacement \b0\par
\par
{\f1   Procedure ClrScr;}\par
{\f1     - Efface la fenetre texte active}\par
{\f1     - Remplit avec des espaces et l'attribut TextAttr courant}\par
{\f1     - Deplace le curseur en (1, 1) de la fenetre}\par
{\f1     - Si aucune fenetre n'est definie, efface tout l'ecran}\par
{\f1     - Exemple :}\par
{\f1         TextBackground(Blue);}\par
{\f1         ClrScr;  \{ ecran bleu \}}\par
\par
{\f1   Procedure ClrEol;}\par
{\f1     - Efface depuis le curseur jusqu'a la fin de la ligne}\par
{\f1     - Remplit avec des espaces et l'attribut TextAttr courant}\par
{\f1     - Le curseur ne bouge pas}\par
{\f1     - Exemple :}\par
{\f1         GotoXY(10, 5);}\par
{\f1         ClrEol;  \{ efface colonnes 10 a 80 sur la ligne 5 \}}\par
\par
\par
\b 5.5 Insertion et suppression de lignes \b0\par
\par
{\f1   Procedure InsLine;}\par
{\f1     - Insere une ligne vide a la position du curseur}\par
{\f1     - La ligne courante et celles en dessous descendent d'une ligne}\par
{\f1     - La derniere ligne de la fenetre est perdue}\par
{\f1     - La nouvelle ligne est remplie avec TextAttr courant}\par
{\f1     - Le curseur ne bouge pas}\par
{\f1     - Exemple :}\par
{\f1         GotoXY(1, 5);}\par
{\f1         InsLine;  \{ insere une ligne vide en ligne 5 \}}\par
\par
{\f1   Procedure DelLine;}\par
{\f1     - Supprime la ligne a la position du curseur}\par
{\f1     - Les lignes en dessous remontent d'une ligne}\par
{\f1     - La derniere ligne de la fenetre est remplie de blancs}\par
{\f1     - Le curseur ne bouge pas}\par
{\f1     - Exemple :}\par
{\f1         GotoXY(1, 5);}\par
{\f1         DelLine;  \{ supprime la ligne 5 \}}\par
\par
\par
