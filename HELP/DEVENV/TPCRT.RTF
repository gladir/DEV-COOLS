{\footnote # IDH_TPCRT_09}
{\footnote $ Unite Crt - FREQUENCES DES NOTES MUSICALES}
{\footnote K Turbo Pascal;Unite Crt;FREQUENCES DES NOTES MUSICALES}
\b\fs24 FREQUENCES DES NOTES MUSICALES \b0\fs20\par
\par
{\f1   Pour utiliser Sound() avec des notes musicales, voici les}\par
{\f1   frequences standard (La 440 Hz, temperament egal) :}\par
\par
{\f1   Note    | Octave 3 | Octave 4 | Octave 5 | Octave 6}\par
{\f1   --------+----------+----------+----------+---------}\par
{\f1   Do (C)  |   131    |   262    |   523    |  1047}\par
{\f1   Re (D)  |   147    |   294    |   587    |  1175}\par
{\f1   Mi (E)  |   165    |   330    |   659    |  1319}\par
{\f1   Fa (F)  |   175    |   349    |   698    |  1397}\par
{\f1   Sol (G) |   196    |   392    |   784    |  1568}\par
{\f1   La (A)  |   220    |   440    |   880    |  1760}\par
{\f1   Si (B)  |   247    |   494    |   988    |  1976}\par
\par
{\f1   Exemple - gamme de Do majeur :}\par
\par
{\f1     Const Notes : Array[1..8] Of Word =}\par
{\f1       (262, 294, 330, 349, 392, 440, 494, 523);}\par
{\f1     Var I : Integer;}\par
{\f1     Begin}\par
{\f1       For I := 1 To 8 Do}\par
{\f1       Begin}\par
{\f1         Sound(Notes[I]);}\par
{\f1         Delay(200);}\par
{\f1       End;}\par
{\f1       NoSound;}\par
{\f1     End.}\par
\par
\par
