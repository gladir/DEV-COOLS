{\footnote # IDH_TPCRT_02}
{\footnote $ Unite Crt - CONSTANTES - COULEURS}
{\footnote K Turbo Pascal;Unite Crt;CONSTANTES - COULEURS}
\b\fs24 CONSTANTES - COULEURS \b0\fs20\par
\par
{\f1   Les couleurs sont codees sur 4 bits (0-15) pour le premier plan}\par
{\f1   et 3 bits (0-7) pour l'arriere-plan. L'attribut complet est :}\par
\par
{\f1     TextAttr = (Arriere-plan Shl 4) Or Premier_plan Or Blink}\par
\par
\par
\b 2.1 Couleurs de premier plan ET d'arriere-plan (0-7) \b0\par
\par
{\f1   Const}\par
{\f1     Black      = 0;    \{ Noir         \}}\par
{\f1     Blue       = 1;    \{ Bleu         \}}\par
{\f1     Green      = 2;    \{ Vert         \}}\par
{\f1     Cyan       = 3;    \{ Cyan         \}}\par
{\f1     Red        = 4;    \{ Rouge        \}}\par
{\f1     Magenta    = 5;    \{ Magenta      \}}\par
{\f1     Brown      = 6;    \{ Marron       \}}\par
{\f1     LightGray  = 7;    \{ Gris clair   \}}\par
\par
{\f1   Ces 8 couleurs peuvent etre utilisees a la fois pour le premier}\par
{\f1   plan (TextColor) et pour l'arriere-plan (TextBackground).}\par
\par
\par
\b 2.2 Couleurs de premier plan uniquement (8-15) \b0\par
\par
{\f1   Const}\par
{\f1     DarkGray      = 8;    \{ Gris fonce       \}}\par
{\f1     LightBlue     = 9;    \{ Bleu clair       \}}\par
{\f1     LightGreen    = 10;   \{ Vert clair       \}}\par
{\f1     LightCyan     = 11;   \{ Cyan clair       \}}\par
{\f1     LightRed      = 12;   \{ Rouge clair      \}}\par
{\f1     LightMagenta  = 13;   \{ Magenta clair    \}}\par
{\f1     Yellow        = 14;   \{ Jaune            \}}\par
{\f1     White         = 15;   \{ Blanc            \}}\par
\par
{\f1   Ces couleurs ne peuvent etre utilisees que pour le premier plan.}\par
{\f1   L'arriere-plan n'accepte que les valeurs 0-7.}\par
\par
\par
\b 2.3 Attribut de clignotement \b0\par
\par
{\f1   Const}\par
{\f1     Blink = 128;   \{ Clignotement du texte \}}\par
\par
{\f1   Peut etre ajoute a la couleur du premier plan par OR :}\par
{\f1     TextColor(Red + Blink);   \{ texte rouge clignotant \}}\par
\par
{\f1   NOTE : le clignotement ne fonctionne pas sur tous les systemes.}\par
{\f1   En Win32, il est generalement ignore par la console.}\par
\par
\par
\b 2.4 Encodage de l'attribut texte (TextAttr) \b0\par
\par
{\f1     Bit 7     : Clignotement (Blink)}\par
{\f1     Bits 6-4  : Couleur d'arriere-plan (0-7)}\par
{\f1     Bits 3-0  : Couleur de premier plan (0-15)}\par
\par
{\f1     Exemples :}\par
{\f1       $07 = LightGray sur Black      (defaut)}\par
{\f1       $1E = Yellow sur Blue}\par
{\f1       $4F = White sur Red}\par
{\f1       $70 = Black sur LightGray      (video inverse)}\par
{\f1       $8F = White sur Black + Blink}\par
\par
{\f1     Calcul : TextAttr := (Background Shl 4) Or Foreground;}\par
{\f1     Avec clignotement : TextAttr := (Background Shl 4) Or Foreground Or $80;}\par
\par
\par
