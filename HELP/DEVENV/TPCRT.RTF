{\footnote # IDH_TPCRT_03}
{\footnote $ Unite Crt - VARIABLES}
{\footnote K Turbo Pascal;Unite Crt;VARIABLES}
\b\fs24 VARIABLES \b0\fs20\par
\par
{\f1   Var}\par
{\f1     CheckBreak  : Boolean;   \{ Active la detection de Ctrl+Break     \}}\par
{\f1     CheckEOF    : Boolean;   \{ Active la detection de Ctrl+Z (EOF)   \}}\par
{\f1     DirectVideo : Boolean;   \{ Active l'ecriture directe en memoire  \}}\par
{\f1     CheckSnow   : Boolean;   \{ Active le filtre anti-neige CGA       \}}\par
{\f1     LastMode    : Word;      \{ Dernier mode texte utilise             \}}\par
{\f1     TextAttr    : Byte;      \{ Attribut de texte courant              \}}\par
{\f1     WindMin     : Word;      \{ Coin superieur gauche de la fenetre    \}}\par
{\f1     WindMax     : Word;      \{ Coin inferieur droit de la fenetre     \}}\par
\par
\par
\b 3.1 CheckBreak (defaut : True) \b0\par
\par
{\f1   Quand True, une pression sur Ctrl+Break interrompt le programme.}\par
{\f1   Mettre a False pour ignorer Ctrl+Break :}\par
{\f1     CheckBreak := False;}\par
\par
\par
\b 3.2 CheckEOF (defaut : False) \b0\par
\par
{\f1   Quand True, Ctrl+Z est interprete comme fin de fichier (EOF)}\par
{\f1   lors de la lecture depuis la console. Par defaut, Ctrl+Z est}\par
{\f1   traite comme un caractere normal.}\par
\par
\par
\b 3.3 DirectVideo (defaut : True) \b0\par
\par
{\f1   Quand True, Write et WriteLn ecrivent directement dans la memoire}\par
{\f1   video ($B800:0000) au lieu de passer par les appels BIOS. C'est}\par
{\f1   beaucoup plus rapide mais ne fonctionne pas via connexion serie.}\par
{\f1   NOTE : en Win32, cette variable est ignoree (utilise l'API Console).}\par
\par
\par
\b 3.4 CheckSnow (defaut : True sur CGA) \b0\par
\par
{\f1   Quand True, les ecritures en memoire video attendent le retrace}\par
{\f1   vertical pour eviter la "neige" sur les anciennes cartes CGA.}\par
{\f1   Inutile sur EGA, VGA et Win32.}\par
\par
\par
\b 3.5 LastMode \b0\par
\par
{\f1   Contient le mode texte actif au moment de l'initialisation de CRT.}\par
{\f1   Utilise pour restaurer le mode original :}\par
{\f1     TextMode(LastMode);}\par
\par
\par
\b 3.6 TextAttr \b0\par
\par
{\f1   Attribut de couleur utilise par toutes les operations d'ecriture.}\par
{\f1   Modifie par TextColor, TextBackground, LowVideo, HighVideo,}\par
{\f1   NormVideo. Peut aussi etre assigne directement :}\par
{\f1     TextAttr := Yellow + Blue * 16;  \{ jaune sur bleu \}}\par
\par
\par
\b 3.7 WindMin et WindMax \b0\par
\par
{\f1   Definissent la fenetre texte active. Format encode :}\par
{\f1     WindMin := Lo(X1-1) Or (Hi(Y1-1) Shl 8);}\par
{\f1     WindMax := Lo(X2-1) Or (Hi(Y2-1) Shl 8);}\par
\par
{\f1   Modifiees par Window(). Les coordonnees GotoXY et WhereX/WhereY}\par
{\f1   sont relatives a cette fenetre.}\par
\par
{\f1   Extraction des coordonnees :}\par
{\f1     X1 := Lo(WindMin) + 1;   Y1 := Hi(WindMin) + 1;}\par
{\f1     X2 := Lo(WindMax) + 1;   Y2 := Hi(WindMax) + 1;}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPCRT_02}     {\uldb Suivant >>}{\v IDH_TPCRT_04}     {\uldb Sommaire}{\v IDH_TPCRT_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
