{\footnote # IDH_TPCRT_06}
{\footnote $ Unite Crt - PROCEDURES - COULEURS ET ATTRIBUTS}
{\footnote K Turbo Pascal;Unite Crt;PROCEDURES - COULEURS ET ATTRIBUTS}
\b\fs24 PROCEDURES - COULEURS ET ATTRIBUTS \b0\fs20\par
\par
{\f1   Procedure TextColor(Color : Byte);}\par
{\f1     - Change la couleur du premier plan (0-15)}\par
{\f1     - Peut inclure Blink (128) : TextColor(Red + Blink)}\par
{\f1     - Modifie les bits 0-3 et 7 de TextAttr}\par
{\f1     - N'affecte pas le texte deja affiche}\par
{\f1     - Exemple : TextColor(Yellow);}\par
\par
{\f1   Procedure TextBackground(Color : Byte);}\par
{\f1     - Change la couleur d'arriere-plan (0-7)}\par
{\f1     - Modifie les bits 4-6 de TextAttr}\par
{\f1     - N'affecte pas le texte deja affiche}\par
{\f1     - Exemple : TextBackground(Blue);}\par
\par
{\f1   Procedure LowVideo;}\par
{\f1     - Desactive le bit d'intensite du premier plan}\par
{\f1     - Remet les couleurs 8-15 a 0-7 (version sombre)}\par
{\f1     - Equivalent a : TextAttr := TextAttr And $F7;}\par
{\f1     - Exemple :}\par
{\f1         TextColor(White);   \{ couleur 15 \}}\par
{\f1         LowVideo;           \{ devient LightGray (couleur 7) \}}\par
\par
{\f1   Procedure HighVideo;}\par
{\f1     - Active le bit d'intensite du premier plan}\par
{\f1     - Force les couleurs 0-7 vers 8-15 (version claire)}\par
{\f1     - Equivalent a : TextAttr := TextAttr Or $08;}\par
{\f1     - Exemple :}\par
{\f1         TextColor(Red);     \{ couleur 4 \}}\par
{\f1         HighVideo;          \{ devient LightRed (couleur 12) \}}\par
\par
{\f1   Procedure NormVideo;}\par
{\f1     - Restaure l'attribut texte normal (celui du demarrage)}\par
{\f1     - Remet TextAttr a la valeur initiale lors du lancement}\par
{\f1     - Typiquement $07 (LightGray sur Black)}\par
{\f1     - Exemple :}\par
{\f1         TextColor(Yellow);}\par
{\f1         TextBackground(Blue);}\par
{\f1         WriteLn('Colore');}\par
{\f1         NormVideo;}\par
{\f1         WriteLn('Normal');}\par
\par
\par
