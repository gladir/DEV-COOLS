{\footnote # IDH_TPCRT_12}
{\footnote $ Unite Crt - NOTES D'IMPLEMENTATION POUR TPCW32}
{\footnote K Turbo Pascal;Unite Crt;NOTES D'IMPLEMENTATION POUR TPCW32}
\b\fs24 NOTES D'IMPLEMENTATION POUR TPCW32 \b0\fs20\par
\par
\par
\b 12.1 Emulation en Win32 \b0\par
\par
{\f1   En Win32, l'unite CRT n'a pas acces direct a la memoire video.}\par
{\f1   Les fonctions sont emulees via l'API Console Windows :}\par
\par
{\f1   Fonction CRT        | API Win32 correspondante}\par
{\f1   ---------------------+------------------------------------------}\par
{\f1   ClrScr              | FillConsoleOutputCharacterA +}\par
{\f1                       | FillConsoleOutputAttribute +}\par
{\f1                       | SetConsoleCursorPosition}\par
{\f1   ClrEol              | FillConsoleOutputCharacterA +}\par
{\f1                       | FillConsoleOutputAttribute}\par
{\f1   GotoXY              | SetConsoleCursorPosition}\par
{\f1   WhereX / WhereY     | GetConsoleScreenBufferInfo}\par
{\f1   TextColor           | SetConsoleTextAttribute}\par
{\f1   TextBackground      | SetConsoleTextAttribute}\par
{\f1   KeyPressed          | PeekConsoleInputA / GetNumberOfConsoleInputEvents}\par
{\f1   ReadKey             | ReadConsoleInputA}\par
{\f1   Sound               | Beep (kernel32.dll)}\par
{\f1   NoSound             | (rien, Beep est synchrone en Win32)}\par
{\f1   Delay               | Sleep (kernel32.dll)}\par
{\f1   Window              | SetConsoleWindowInfo / ScrollConsoleScreenBuffer}\par
{\f1   InsLine / DelLine   | ScrollConsoleScreenBufferA}\par
{\f1   TextMode            | SetConsoleScreenBufferSize}\par
\par
\par
\b 12.2 Variables en memoire \b0\par
\par
{\f1   Les variables CRT sont stockees dans le segment de donnees :}\par
\par
{\f1     CHECKBREAK  DD 1           ; Boolean (True par defaut)}\par
{\f1     CHECKEOF    DD 0           ; Boolean (False par defaut)}\par
{\f1     DIRECTVIDEO DD 1           ; Boolean (True par defaut)}\par
{\f1     CHECKSNOW   DD 0           ; Boolean (False en Win32)}\par
{\f1     LASTMODE    DD 3           ; Word (CO80 par defaut)}\par
{\f1     TEXTATTR    DD 7           ; Byte ($07 = LightGray/Black)}\par
{\f1     WINDMIN     DD 0           ; Word (0,0 = encode de 1,1)}\par
{\f1     WINDMAX     DD 184Fh       ; Word (79,24 = 80x25)}\par
\par
\par
\b 12.3 Mapping des couleurs CRT vers Console Windows \b0\par
\par
{\f1   Les couleurs CRT (0-15) mappent directement vers les attributs}\par
{\f1   de la console Windows car l'encodage est identique :}\par
\par
{\f1     CRT Color  | Valeur | Win32 Console Attribute}\par
{\f1     -----------+--------+-------------------------}\par
{\f1     Black      |   0    | 0}\par
{\f1     Blue       |   1    | FOREGROUND_BLUE (1)}\par
{\f1     Green      |   2    | FOREGROUND_GREEN (2)}\par
{\f1     Cyan       |   3    | FOREGROUND_GREEN | FOREGROUND_BLUE (3)}\par
{\f1     Red        |   4    | FOREGROUND_RED (4)}\par
{\f1     Magenta    |   5    | FOREGROUND_RED | FOREGROUND_BLUE (5)}\par
{\f1     Brown      |   6    | FOREGROUND_RED | FOREGROUND_GREEN (6)}\par
{\f1     LightGray  |   7    | FOREGROUND_RED | FOREGROUND_GREEN | FOREGROUND_BLUE (7)}\par
{\f1     DarkGray   |   8    | FOREGROUND_INTENSITY (8)}\par
{\f1     LightBlue  |   9    | FOREGROUND_BLUE | FOREGROUND_INTENSITY (9)}\par
{\f1     LightGreen |  10    | FOREGROUND_GREEN | FOREGROUND_INTENSITY (10)}\par
{\f1     LightCyan  |  11    | FOREGROUND_GREEN | FOREGROUND_BLUE | FOREGROUND_INTENSITY}\par
{\f1     LightRed   |  12    | FOREGROUND_RED | FOREGROUND_INTENSITY (12)}\par
{\f1     LightMagenta| 13    | FOREGROUND_RED | FOREGROUND_BLUE | FOREGROUND_INTENSITY}\par
{\f1     Yellow     |  14    | FOREGROUND_RED | FOREGROUND_GREEN | FOREGROUND_INTENSITY}\par
{\f1     White      |  15    | Toutes les composantes + INTENSITY (15)}\par
\par
{\f1   L'arriere-plan utilise les memes bits decales de 4 :}\par
{\f1     BACKGROUND_BLUE = $10, BACKGROUND_GREEN = $20, etc.}\par
\par
\par
