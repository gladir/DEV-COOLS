{\footnote # IDH_TPCRT_07}
{\footnote $ Unite Crt - PROCEDURES - SON}
{\footnote K Turbo Pascal;Unite Crt;PROCEDURES - SON}
\b\fs24 PROCEDURES - SON \b0\fs20\par
\par
{\f1   Procedure Sound(Hz : Word);}\par
{\f1     - Active le haut-parleur interne a la frequence Hz (en Hertz)}\par
{\f1     - Le son continue indefiniment jusqu'a l'appel de NoSound}\par
{\f1     - Sur PC, utilise le timer 8253 canal 2}\par
{\f1     - Exemple : Sound(440);  \{ La 440 Hz \}}\par
\par
{\f1   Procedure NoSound;}\par
{\f1     - Desactive le haut-parleur interne}\par
{\f1     - Doit etre appele apres Sound pour arreter le son}\par
{\f1     - Exemple :}\par
{\f1         Sound(1000);}\par
{\f1         Delay(500);    \{ attendre 500 ms \}}\par
{\f1         NoSound;}\par
\par
{\f1   NOTE : en Win32, Sound peut etre emule par l'API Beep(Hz, Duration)}\par
{\f1   mais le comportement asynchrone (son continu) n'est pas toujours}\par
{\f1   reproduit. La paire Sound/Delay/NoSound est le patron typique.}\par
\par
\par
