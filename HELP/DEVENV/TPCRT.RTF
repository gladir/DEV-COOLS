{\footnote # IDH_TPCRT_13}
{\footnote $ Unite Crt - INTERFACE COMPLETE}
{\footnote K Turbo Pascal;Unite Crt;INTERFACE COMPLETE}
\b\fs24 INTERFACE COMPLETE \b0\fs20\par
\par
{\f1   Unit Crt;}\par
\par
{\f1   \{$D-,I-,S-\}}\par
\par
{\f1   INTERFACE}\par
\par
{\f1   Const}\par
{\f1     \{ Modes CRT \}}\par
{\f1     BW40     = 0;}\par
{\f1     CO40     = 1;}\par
{\f1     BW80     = 2;}\par
{\f1     CO80     = 3;}\par
{\f1     Mono     = 7;}\par
{\f1     Font8x8  = 256;}\par
\par
{\f1     \{ Compatibilite TP 3.0 \}}\par
{\f1     C40 = CO40;}\par
{\f1     C80 = CO80;}\par
\par
{\f1     \{ Couleurs premier plan et arriere-plan \}}\par
{\f1     Black        = 0;}\par
{\f1     Blue         = 1;}\par
{\f1     Green        = 2;}\par
{\f1     Cyan         = 3;}\par
{\f1     Red          = 4;}\par
{\f1     Magenta      = 5;}\par
{\f1     Brown        = 6;}\par
{\f1     LightGray    = 7;}\par
\par
{\f1     \{ Couleurs premier plan uniquement \}}\par
{\f1     DarkGray     = 8;}\par
{\f1     LightBlue    = 9;}\par
{\f1     LightGreen   = 10;}\par
{\f1     LightCyan    = 11;}\par
{\f1     LightRed     = 12;}\par
{\f1     LightMagenta = 13;}\par
{\f1     Yellow       = 14;}\par
{\f1     White        = 15;}\par
\par
{\f1     \{ Clignotement \}}\par
{\f1     Blink = 128;}\par
\par
{\f1   Var}\par
{\f1     CheckBreak  : Boolean;}\par
{\f1     CheckEOF    : Boolean;}\par
{\f1     DirectVideo : Boolean;}\par
{\f1     CheckSnow   : Boolean;}\par
{\f1     LastMode    : Word;}\par
{\f1     TextAttr    : Byte;}\par
{\f1     WindMin     : Word;}\par
{\f1     WindMax     : Word;}\par
\par
{\f1   \{ Clavier \}}\par
{\f1   Procedure AssignCrt(Var F : Text);}\par
{\f1   Function  KeyPressed : Boolean;}\par
{\f1   Function  ReadKey : Char;}\par
\par
{\f1   \{ Mode et fenetre \}}\par
{\f1   Procedure TextMode(Mode : Integer);}\par
{\f1   Procedure Window(X1, Y1, X2, Y2 : Byte);}\par
\par
{\f1   \{ Curseur \}}\par
{\f1   Procedure GotoXY(X, Y : Byte);}\par
{\f1   Function  WhereX : Byte;}\par
{\f1   Function  WhereY : Byte;}\par
\par
{\f1   \{ Effacement \}}\par
{\f1   Procedure ClrScr;}\par
{\f1   Procedure ClrEol;}\par
\par
{\f1   \{ Lignes \}}\par
{\f1   Procedure InsLine;}\par
{\f1   Procedure DelLine;}\par
\par
{\f1   \{ Couleurs et attributs \}}\par
{\f1   Procedure TextColor(Color : Byte);}\par
{\f1   Procedure TextBackground(Color : Byte);}\par
{\f1   Procedure LowVideo;}\par
{\f1   Procedure HighVideo;}\par
{\f1   Procedure NormVideo;}\par
\par
{\f1   \{ Temporisation et son \}}\par
{\f1   Procedure Delay(MS : Word);}\par
{\f1   Procedure Sound(Hz : Word);}\par
{\f1   Procedure NoSound;}\par
\par
{\f1   IMPLEMENTATION}\par
\par
{\f1   FIN DU DOCUMENT}\par

\par
