{\footnote # IDH_TPCRT_04}
{\footnote $ Unite Crt - PROCEDURES ET FONCTIONS - CLAVIER}
{\footnote K Turbo Pascal;Unite Crt;PROCEDURES ET FONCTIONS - CLAVIER}
\b\fs24 PROCEDURES ET FONCTIONS - CLAVIER \b0\fs20\par
\par
\par
\b 4.1 Lecture du clavier \b0\par
\par
{\f1   Function KeyPressed : Boolean;}\par
{\f1     - Retourne True si une touche est disponible dans le tampon}\par
{\f1     - Ne retire PAS la touche du tampon}\par
{\f1     - Utilisee pour tester sans bloquer l'execution}\par
{\f1     - Exemple :}\par
{\f1         While Not KeyPressed Do}\par
{\f1           \{ ... animations ... \};}\par
{\f1         Ch := ReadKey;}\par
\par
{\f1   Function ReadKey : Char;}\par
{\f1     - Attend et retourne un caractere du clavier}\par
{\f1     - Le caractere N'EST PAS affiche a l'ecran (pas d'echo)}\par
{\f1     - Bloquante : attend jusqu'a ce qu'une touche soit pressee}\par
{\f1     - Pour les touches speciales (F1-F12, fleches, etc.) :}\par
{\f1         Premier appel retourne #0 (Chr(0))}\par
{\f1         Deuxieme appel retourne le code etendu (scan code)}\par
{\f1     - Exemple simple :}\par
{\f1         Ch := ReadKey;}\par
{\f1         WriteLn('Vous avez tape : ', Ch);}\par
{\f1     - Exemple touches speciales :}\par
{\f1         Ch := ReadKey;}\par
{\f1         If Ch = #0 Then}\par
{\f1         Begin}\par
{\f1           Ch := ReadKey;  \{ lire le scan code \}}\par
{\f1           Case Ord(Ch) Of}\par
{\f1             59 : WriteLn('F1');}\par
{\f1             60 : WriteLn('F2');}\par
{\f1             72 : WriteLn('Fleche Haut');}\par
{\f1             75 : WriteLn('Fleche Gauche');}\par
{\f1             77 : WriteLn('Fleche Droite');}\par
{\f1             80 : WriteLn('Fleche Bas');}\par
{\f1           End;}\par
{\f1         End;}\par
\par
{\f1   Codes etendus des touches speciales (second octet apres #0) :}\par
\par
{\f1     Touche        | Code  | Touche         | Code}\par
{\f1     --------------+-------+----------------+------}\par
{\f1     F1            |  59   | Shift+F1       |  84}\par
{\f1     F2            |  60   | Shift+F2       |  85}\par
{\f1     F3            |  61   | Shift+F3       |  86}\par
{\f1     F4            |  62   | Shift+F4       |  87}\par
{\f1     F5            |  63   | Shift+F5       |  88}\par
{\f1     F6            |  64   | Shift+F6       |  89}\par
{\f1     F7            |  65   | Shift+F7       |  90}\par
{\f1     F8            |  66   | Shift+F8       |  91}\par
{\f1     F9            |  67   | Shift+F9       |  92}\par
{\f1     F10           |  68   | Shift+F10      |  93}\par
{\f1     Home          |  71   | Ctrl+F1        |  94}\par
{\f1     Fleche Haut   |  72   | Ctrl+F2        |  95}\par
{\f1     Page Up       |  73   | Ctrl+F3        |  96}\par
{\f1     Fleche Gauche |  75   | Ctrl+F4        |  97}\par
{\f1     Fleche Droite |  77   | Ctrl+F5        |  98}\par
{\f1     End           |  79   | Ctrl+F6        |  99}\par
{\f1     Fleche Bas    |  80   | Ctrl+F7        | 100}\par
{\f1     Page Down     |  81   | Ctrl+F8        | 101}\par
{\f1     Insert        |  82   | Ctrl+F9        | 102}\par
{\f1     Delete        |  83   | Ctrl+F10       | 103}\par
{\f1     Alt+F1        | 104   | Ctrl+Home      | 119}\par
{\f1     Alt+F2        | 105   | Ctrl+End       | 117}\par
{\f1     Alt+F3        | 106   | Ctrl+PgUp      | 132}\par
{\f1     Alt+F4        | 107   | Ctrl+PgDn      | 118}\par
{\f1     Alt+F5        | 108   | Ctrl+Gauche    | 115}\par
{\f1     Alt+F6        | 109   | Ctrl+Droite    | 116}\par
{\f1     Alt+F7        | 110   |}\par
{\f1     Alt+F8        | 111   |}\par
{\f1     Alt+F9        | 112   |}\par
{\f1     Alt+F10       | 113   |}\par
\par
\par
\b 4.2 Assignation CRT \b0\par
\par
{\f1   Procedure AssignCrt(Var F : Text);}\par
{\f1     - Associe un fichier texte a la sortie CRT}\par
{\f1     - Apres Rewrite(F), les Write/WriteLn sur F utilisent CRT}\par
{\f1     - Plus rapide que la sortie standard car bypass le DOS}\par
{\f1     - Utile pour rediriger la sortie vers la console CRT}\par
{\f1     - Exemple :}\par
{\f1         Var F : Text;}\par
{\f1         AssignCrt(F);}\par
{\f1         Rewrite(F);}\par
{\f1         WriteLn(F, 'Sortie via CRT');}\par
{\f1         Close(F);}\par
\par
\par
