{\footnote # IDH_OBERON_18}
{\footnote $ Oberon - CONVERTISSEURS DU PROJET}
{\footnote K Oberon convertisseurs;C2OBERON.PAS;ADA2OBER.PAS;PAS2OBER.PAS;OBER2PAS.PAS;OBER2CS.PAS;OBER2ADA.PAS;OBERON2C.PAS}
\b\fs24 CONVERTISSEURS DU PROJET \b0\fs20\par
\par
\par
\b 18.1 C2OBERON.PAS - C vers Oberon \b0\par
\par
Convertit un sous-ensemble de C en Oberon :\par
\par
{\f1   - struct -> RECORD}\par
{\f1   - typedef -> TYPE}\par
{\f1   - if/else -> IF/ELSE}\par
{\f1   - while/for -> WHILE/FOR}\par
{\f1   - * pointer -> POINTER TO}\par
\par
\par
\b 18.2 ADA2OBER.PAS - Ada vers Oberon \b0\par
\par
{\f1   - package -> MODULE}\par
{\f1   - procedure/function -> PROCEDURE}\par
{\f1   - record -> RECORD}\par
{\f1   - if/elsif/else -> IF/ELSIF/ELSE}\par
{\f1   - loop / while -> LOOP/WHILE}\par
\par
\par
\b 18.3 PAS2OBER.PAS - Pascal vers Oberon \b0\par
\par
{\f1   - program/unit -> MODULE}\par
{\f1   - procedure/function -> PROCEDURE}\par
{\f1   - record -> RECORD}\par
{\f1   - var/const -> VAR/CONST}\par
{\f1   - begin/end -> BEGIN/END}\par
{\f1   - := identique}\par
\par
\par
\b 18.4 OBER2PAS.PAS - Oberon vers Pascal \b0\par
\par
Conversion inverse vers Turbo Pascal.\par
\par
\par
\b 18.5 OBER2CS.PAS - Oberon vers C# \b0\par
\par
{\f1   - MODULE -> namespace + class statique}\par
{\f1   - RECORD -> struct/class}\par
{\f1   - extension de type -> heritage de classe}\par
{\f1   - procedure liee au type -> methode}\par
\par
\par
\b 18.6 OBER2ADA.PAS - Oberon vers Ada \b0\par
\par
Conversion inverse vers Ada 95/2012.\par
\par
\par
\b 18.7 OBERON2C.PAS - Oberon vers C \b0\par
\par
Conversion vers C ANSI :\par
\par
{\f1   - MODULE -> .c + .h}\par
{\f1   - RECORD -> struct}\par
{\f1   - procedure liee au type -> vtable}\par
{\f1   - garbage collector via Boehm GC ou simulation}\par
\par
\par
\par
