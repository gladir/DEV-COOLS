{\footnote # IDH_OBERON_06}
{\footnote $ Oberon - OPERATEURS}
{\footnote K Oberon operateurs;arithmetique;DIV;MOD;relationnel;logique;ensemble;IN;IS;precedence}
\b\fs24 OPERATEURS \b0\fs20\par
\par
\par
\b 6.1 Operateurs arithmetiques \b0\par
\par
{\f1   +    addition (unaire/binaire)}\par
{\f1   -    soustraction (unaire/binaire)}\par
{\f1   *    multiplication}\par
{\f1   /    division reelle}\par
{\f1   DIV  division entiere}\par
{\f1   MOD  modulo}\par
\par
\par
\b 6.2 Operateurs relationnels \b0\par
\par
{\f1   =    egal}\par
{\f1   #    different}\par
{\f1   <    inferieur}\par
{\f1   >    superieur}\par
{\f1   <=   inferieur ou egal}\par
{\f1   >=   superieur ou egal}\par
{\f1   IN   appartenance a un ensemble}\par
{\f1   IS   test de type dynamique}\par
\par
\par
\b 6.3 Operateurs logiques \b0\par
\par
{\f1   &    ET logique (court-circuit)}\par
{\f1   OR   OU logique (court-circuit)}\par
{\f1   ~    NON logique}\par
\par
\par
\b 6.4 Operateurs sur ensembles \b0\par
\par
{\f1   +    union}\par
{\f1   -    difference}\par
{\f1   *    intersection}\par
{\f1   /    difference symetrique}\par
{\f1   IN   appartenance}\par
\par
\par
\b 6.5 Affectation \b0\par
\par
{\f1   :=    affectation}\par
\par
\par
\b 6.6 Precedence (decroissante) \b0\par
\par
{\f1   1. ~ (unaire)}\par
{\f1   2. * / DIV MOD &}\par
{\f1   3. + - OR}\par
{\f1   4. = # < <= > >= IN IS}\par
{\f1   5. & (le mot OR a meme niveau que +/-)}\par
\par
\par
\par
