{\footnote # IDH_OBERON_17}
{\footnote $ Oberon - COMPILATEURS DU PROJET}
{\footnote K Oberon compilateurs projet;OBERON86.PAS;OBERCW32.PAS}
\b\fs24 COMPILATEURS DU PROJET \b0\fs20\par
\par
\par
\b 17.1 OBERON86.PAS - Compilateur Oberon vers 8086 \b0\par
\par
{\f1   Cible             : MS-DOS, assembleur MASM .MODEL SMALL}\par
{\f1   Modele memoire    : SMALL (code 64KO, donnees 64KO)}\par
{\f1   Dialecte          : Oberon-07 (sous-ensemble)}\par
{\f1   Sortie            : fichier .ASM, assemblable avec MASM}\par
\par
{\f1   Fonctionnalites :}\par
{\f1     - Modules, IMPORT, export par *}\par
{\f1     - Types BOOLEAN, CHAR, INTEGER, REAL, SET}\par
{\f1     - ARRAY (fixe et ouvert), RECORD, POINTER}\par
{\f1     - Procedures, procedures liees au type}\par
{\f1     - Structures IF, CASE, WHILE, REPEAT, FOR}\par
{\f1     - Garbage collector simple}\par
\par
{\f1   Limitations :}\par
{\f1     - LONGINT 16 bits seulement (cible 8086)}\par
{\f1     - Tableaux dynamiques limites}\par
{\f1     - Module SYSTEM partiel}\par
\par
\par
\b 17.2 OBERCW32.PAS - Compilateur Oberon vers Win32 \b0\par
\par
{\f1   Cible             : Windows 32 bits (PE)}\par
{\f1   Sortie            : fichier .EXE PE32}\par
{\f1   Dialecte          : Oberon-07 complet}\par
\par
{\f1   Fonctionnalites :}\par
{\f1     - Types complets (INTEGER 32-bit, LONGINT 64-bit)}\par
{\f1     - Tableaux dynamiques NEW(p, n)}\par
{\f1     - Garbage collector base sur marquage}\par
{\f1     - Bibliotheque Out, In, Math}\par
\par
\par
\par
