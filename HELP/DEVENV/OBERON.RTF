{\footnote # IDH_OBERON_09}
{\footnote $ Oberon - TABLEAUX}
{\footnote K Oberon tableaux;ARRAY;LEN;tableau ouvert;tableau dynamique;NEW;POINTER TO ARRAY}
\b\fs24 TABLEAUX \b0\fs20\par
\par
\par
\b 9.1 Declaration \b0\par
\par
{\f1   VAR}\par
{\f1     t: ARRAY 100 OF INTEGER;}\par
{\f1     m: ARRAY 10, 20 OF REAL;}\par
{\f1     s: ARRAY 32 OF CHAR;           (* chaine "limitee" *)}\par
\par
\par
\b 9.2 Acces aux elements \b0\par
\par
{\f1   t[0]}\par
{\f1   m[i, j]                      (* notation Oberon *)}\par
{\f1   m[i][j]                      (* equivalent *)}\par
\par
\par
\b 9.3 Tableaux ouverts \b0\par
\par
Parametre de procedure de taille indeterminee :\par
\par
{\f1   PROCEDURE Inverser(VAR v: ARRAY OF INTEGER);}\par
{\f1     VAR i, j, t: INTEGER;}\par
{\f1   BEGIN}\par
{\f1     i := 0; j := LEN(v) - 1;}\par
{\f1     WHILE i < j DO}\par
{\f1       t := v[i]; v[i] := v[j]; v[j] := t;}\par
{\f1       INC(i); DEC(j)}\par
{\f1     END}\par
{\f1   END Inverser;}\par
\par
`LEN(v)` retourne le nombre d'elements.\par
\par
\par
\b 9.4 Tableaux dynamiques (Oberon-07) \b0\par
\par
{\f1   TYPE PVec = POINTER TO ARRAY OF INTEGER;}\par
{\f1   VAR v: PVec;}\par
{\f1   BEGIN}\par
{\f1     NEW(v, 100);          (* tableau de 100 INTEGER *)}\par
{\f1     v[42] := 7}\par
{\f1     (* libere automatiquement *)}\par
{\f1   END}\par
\par
\par
\par
