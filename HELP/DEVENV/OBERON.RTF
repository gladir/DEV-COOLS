{\footnote # IDH_OBERON_19}
{\footnote $ Oberon - EXEMPLES}
{\footnote K Oberon exemples;Hello World;Factorielle;liste chainee;extension type;polymorphisme;tri insertion}
\b\fs24 EXEMPLES \b0\fs20\par
\par
\par
\b 19.1 Hello, World! \b0\par
\par
{\f1   MODULE Hello;}\par
{\f1     IMPORT Out;}\par
{\f1   BEGIN}\par
{\f1     Out.String("Hello, World!"); Out.Ln}\par
{\f1   END Hello.}\par
\par
\par
\b 19.2 Factorielle recursive \b0\par
\par
{\f1   MODULE Fact;}\par
{\f1     IMPORT Out;}\par
\par
{\f1     PROCEDURE Factorielle(n: INTEGER): INTEGER;}\par
{\f1     BEGIN}\par
{\f1       IF n <= 1 THEN RETURN 1}\par
{\f1       ELSE RETURN n * Factorielle(n - 1)}\par
{\f1       END}\par
{\f1     END Factorielle;}\par
\par
{\f1     PROCEDURE Test*;}\par
{\f1       VAR i: INTEGER;}\par
{\f1     BEGIN}\par
{\f1       FOR i := 0 TO 10 DO}\par
{\f1         Out.Int(i, 3); Out.String(" -> ");}\par
{\f1         Out.Int(Factorielle(i), 8); Out.Ln}\par
{\f1       END}\par
{\f1     END Test;}\par
\par
{\f1   END Fact.}\par
\par
\par
\b 19.3 Liste chainee \b0\par
\par
{\f1   MODULE Liste;}\par
{\f1     IMPORT Out;}\par
\par
{\f1     TYPE}\par
{\f1       PNoeud* = POINTER TO Noeud;}\par
{\f1       Noeud* = RECORD val*: INTEGER; suiv*: PNoeud END;}\par
\par
{\f1     PROCEDURE Ajouter*(VAR tete: PNoeud; v: INTEGER);}\par
{\f1       VAR n: PNoeud;}\par
{\f1     BEGIN}\par
{\f1       NEW(n);}\par
{\f1       n.val := v;}\par
{\f1       n.suiv := tete;}\par
{\f1       tete := n}\par
{\f1     END Ajouter;}\par
\par
{\f1     PROCEDURE Afficher*(tete: PNoeud);}\par
{\f1     BEGIN}\par
{\f1       WHILE tete # NIL DO}\par
{\f1         Out.Int(tete.val, 4);}\par
{\f1         tete := tete.suiv}\par
{\f1       END;}\par
{\f1       Out.Ln}\par
{\f1     END Afficher;}\par
\par
{\f1   END Liste.}\par
\par
\par
\b 19.4 Extension de type et polymorphisme \b0\par
\par
{\f1   MODULE Formes;}\par
{\f1     IMPORT Out, Math;}\par
\par
{\f1     TYPE}\par
{\f1       Forme* = RECORD END;}\par
{\f1       PCercle* = POINTER TO Cercle;}\par
{\f1       Cercle* = RECORD (Forme) r*: REAL END;}\par
{\f1       PRectangle* = POINTER TO Rectangle;}\par
{\f1       Rectangle* = RECORD (Forme) l*, h*: REAL END;}\par
\par
{\f1     PROCEDURE (VAR f: Forme) Aire*(): REAL;}\par
{\f1     BEGIN RETURN 0}\par
{\f1     END Aire;}\par
\par
{\f1     PROCEDURE (VAR c: Cercle) Aire*(): REAL;}\par
{\f1     BEGIN RETURN 3.14159 * c.r * c.r}\par
{\f1     END Aire;}\par
\par
{\f1     PROCEDURE (VAR r: Rectangle) Aire*(): REAL;}\par
{\f1     BEGIN RETURN r.l * r.h}\par
{\f1     END Aire;}\par
\par
{\f1   END Formes.}\par
\par
\par
\b 19.5 Tri par insertion \b0\par
\par
{\f1   PROCEDURE Trier(VAR a: ARRAY OF INTEGER);}\par
{\f1     VAR i, j, t: INTEGER;}\par
{\f1   BEGIN}\par
{\f1     FOR i := 1 TO LEN(a) - 1 DO}\par
{\f1       t := a[i]; j := i;}\par
{\f1       WHILE (j > 0) & (a[j-1] > t) DO}\par
{\f1         a[j] := a[j-1]; DEC(j)}\par
{\f1       END;}\par
{\f1       a[j] := t}\par
{\f1     END}\par
{\f1   END Trier;}\par
\par
\par
\par
