{\footnote # IDH_OBERON_13}
{\footnote $ Oberon - PROCEDURES STANDARD}
{\footnote K Oberon procedures standard;INC;DEC;ABS;ODD;LEN;ORD;CHR;NEW;HALT;INCL;EXCL;Out;In}
\b\fs24 PROCEDURES STANDARD \b0\fs20\par
\par
\par
\b 13.1 Procedures sur entiers \b0\par
\par
{\f1   INC(x)         x := x + 1}\par
{\f1   INC(x, n)      x := x + n}\par
{\f1   DEC(x)         x := x - 1}\par
{\f1   DEC(x, n)      x := x - n}\par
{\f1   ABS(x)         valeur absolue}\par
{\f1   ODD(x)         TRUE si x impair}\par
{\f1   ASH(x, n)      decalage arithmetique}\par
{\f1   ENTIER(x)      partie entiere de REAL}\par
\par
\par
\b 13.2 Procedures sur ensembles \b0\par
\par
{\f1   INCL(s, x)     ajoute x a s}\par
{\f1   EXCL(s, x)     retire x de s}\par
\par
\par
\b 13.3 Procedures sur tableaux \b0\par
\par
{\f1   LEN(t)         nombre d'elements}\par
\par
\par
\b 13.4 Procedures de conversion \b0\par
\par
{\f1   ORD(c)         valeur ordinale d'un CHAR/BOOLEAN}\par
{\f1   CHR(n)         caractere de code n}\par
{\f1   SHORT(x)       conversion vers type plus court}\par
{\f1   LONG(x)        conversion vers type plus long}\par
\par
\par
\b 13.5 Procedures d'allocation \b0\par
\par
{\f1   NEW(p)         alloue *p}\par
{\f1   NEW(p, n)      alloue tableau de n elements}\par
\par
\par
\b 13.6 Procedures d'I/O (module Out) \b0\par
\par
{\f1   Out.Char(c)        ecrit un caractere}\par
{\f1   Out.String(s)      ecrit une chaine}\par
{\f1   Out.Int(n, w)      ecrit entier sur w colonnes}\par
{\f1   Out.Real(x, w)     ecrit reel sur w colonnes}\par
{\f1   Out.Ln             saut de ligne}\par
\par
{\f1   In.Open            initialise l'entree}\par
{\f1   In.Char(c)         lit un caractere}\par
{\f1   In.Int(n)          lit un entier}\par
{\f1   In.String(s)       lit une chaine}\par
\par
\par
\par
