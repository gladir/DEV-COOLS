{\footnote # IDH_TPGRAPH_26}
{\footnote $ Unite Graph (BGI) - EXEMPLES COMPLETS}
{\footnote K Turbo Pascal;Unite Graph (BGI);EXEMPLES COMPLETS}
\b\fs24 EXEMPLES COMPLETS \b0\fs20\par
\par
{\f1   --- Exemple 1 : Programme graphique minimal ---}\par
\par
{\f1   program GraphDemo;}\par
{\f1   uses Graph;}\par
{\f1   var}\par
{\f1     Gd, Gm : Integer;}\par
{\f1   begin}\par
{\f1     Gd := Detect;}\par
{\f1     InitGraph(Gd, Gm, '');}\par
{\f1     if GraphResult <> grOk then}\par
{\f1     begin}\par
{\f1       WriteLn('Erreur : ', GraphErrorMsg(GraphResult));}\par
{\f1       Halt(1);}\par
{\f1     end;}\par
\par
{\f1     SetColor(Yellow);}\par
{\f1     Rectangle(10, 10, GetMaxX - 10, GetMaxY - 10);}\par
{\f1     Circle(GetMaxX div 2, GetMaxY div 2, 100);}\par
{\f1     OutTextXY(10, GetMaxY - 30, 'Appuyez sur Entree...');}\par
{\f1     ReadLn;}\par
{\f1     CloseGraph;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : Barres color??es avec remplissage ---}\par
\par
{\f1   program BarChart;}\par
{\f1   uses Graph;}\par
{\f1   var}\par
{\f1     Gd, Gm, I : Integer;}\par
{\f1   begin}\par
{\f1     Gd := Detect;}\par
{\f1     InitGraph(Gd, Gm, '');}\par
{\f1     if GraphResult <> grOk then Halt(1);}\par
\par
{\f1     for I := 0 to 10 do}\par
{\f1     begin}\par
{\f1       SetFillStyle(I, White);}\par
{\f1       Bar(I * 50 + 10, 50, I * 50 + 50, 300);}\par
{\f1       Rectangle(I * 50 + 10, 50, I * 50 + 50, 300);}\par
{\f1     end;}\par
\par
{\f1     ReadLn;}\par
{\f1     CloseGraph;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Animation par double buffering ---}\par
\par
{\f1   program Animation;}\par
{\f1   uses Graph, Crt;}\par
{\f1   var}\par
{\f1     Gd, Gm, X, Page : Integer;}\par
{\f1   begin}\par
{\f1     Gd := VGA; Gm := VGALo;  \{ 4 pages disponibles \}}\par
{\f1     InitGraph(Gd, Gm, '');}\par
{\f1     if GraphResult <> grOk then Halt(1);}\par
\par
{\f1     X := 0;}\par
{\f1     Page := 0;}\par
{\f1     while not KeyPressed do}\par
{\f1     begin}\par
{\f1       SetActivePage(1 - Page);}\par
{\f1       ClearDevice;}\par
{\f1       SetColor(LightCyan);}\par
{\f1       Circle(X, 100, 30);}\par
{\f1       SetVisualPage(1 - Page);}\par
{\f1       Page := 1 - Page;}\par
{\f1       X := (X + 2) mod GetMaxX;}\par
{\f1       Delay(20);}\par
{\f1     end;}\par
\par
{\f1     CloseGraph;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 4 : Camembert (PieSlice) ---}\par
\par
{\f1   program PieChart;}\par
{\f1   uses Graph;}\par
{\f1   var}\par
{\f1     Gd, Gm : Integer;}\par
{\f1   begin}\par
{\f1     Gd := Detect;}\par
{\f1     InitGraph(Gd, Gm, '');}\par
{\f1     if GraphResult <> grOk then Halt(1);}\par
\par
{\f1     SetFillStyle(SolidFill, Red);}\par
{\f1     PieSlice(320, 240, 0, 120, 100);}\par
\par
{\f1     SetFillStyle(SolidFill, Green);}\par
{\f1     PieSlice(320, 240, 120, 240, 100);}\par
\par
{\f1     SetFillStyle(SolidFill, Blue);}\par
{\f1     PieSlice(320, 240, 240, 360, 100);}\par
\par
{\f1     ReadLn;}\par
{\f1     CloseGraph;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 5 : Capture et affichage d'image ---}\par
\par
{\f1   program ImageDemo;}\par
{\f1   uses Graph;}\par
{\f1   var}\par
{\f1     Gd, Gm : Integer;}\par
{\f1     P       : Pointer;}\par
{\f1     Size    : Word;}\par
{\f1   begin}\par
{\f1     Gd := Detect;}\par
{\f1     InitGraph(Gd, Gm, '');}\par
{\f1     if GraphResult <> grOk then Halt(1);}\par
\par
{\f1     \{ Dessiner un objet \}}\par
{\f1     SetColor(Yellow);}\par
{\f1     SetFillStyle(SolidFill, Red);}\par
{\f1     FillEllipse(50, 50, 30, 20);}\par
\par
{\f1     \{ Capturer \}}\par
{\f1     Size := ImageSize(20, 30, 80, 70);}\par
{\f1     GetMem(P, Size);}\par
{\f1     GetImage(20, 30, 80, 70, P^);}\par
\par
{\f1     \{ Dupliquer \}}\par
{\f1     PutImage(200, 100, P^, CopyPut);}\par
{\f1     PutImage(300, 200, P^, XORPut);}\par
