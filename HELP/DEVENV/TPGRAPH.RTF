\b\fs24 REMPLISSAGE \b0\fs20\par
\par
{\f1   procedure GetFillSettings(var FillInfo : FillSettingsType);}\par
{\f1   Retourne le motif et la couleur de remplissage pr??d??fini courant.}\par
\par
{\f1   procedure GetFillPattern(var FillPattern : FillPatternType);}\par
{\f1   Retourne le motif de remplissage utilisateur courant (8 octets).}\par
\par
{\f1   procedure SetFillStyle(Pattern : Word; Color : Word);}\par
{\f1   D??finit le motif de remplissage pr??d??fini et sa couleur.}\par
\par
{\f1   Param??tres :}\par
{\f1     Pattern   EmptyFill..CloseDotFill (0..11)}\par
{\f1     Color     Couleur de remplissage (0..GetMaxColor)}\par
\par
