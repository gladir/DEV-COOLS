{\f1       P[2] := $55;  \{ 01010101 \}}\par
{\f1       P[3] := $AA;}\par
{\f1       P[4] := $55;}\par
{\f1       P[5] := $AA;}\par
{\f1       P[6] := $55;}\par
{\f1       P[7] := $AA;}\par
{\f1       P[8] := $55;}\par
{\f1       SetFillPattern(P, White);}\par
{\f1     end;}\par
\par
