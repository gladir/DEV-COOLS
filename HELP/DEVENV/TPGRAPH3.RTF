\b\fs24 CAPTURE ET RESTITUTION D'IMAGES \b0\fs20\par
\par
{\f1   procedure GetPic(var Buffer; X1, Y1, X2, Y2 : Integer);}\par
{\f1   Capture une zone rectangulaire de l'??cran dans un tampon m??moire.}\par
\par
{\f1   Param??tres :}\par
{\f1     Buffer     Tampon destination (non typ??)}\par
{\f1     X1, Y1     Coin sup??rieur gauche de la zone}\par
{\f1     X2, Y2     Coin inf??rieur droit de la zone}\par
\par
{\f1   La taille du tampon n??cessaire d??pend de la zone et du mode :}\par
{\f1     Mode 320??200 : ((X2-X1+1) * (Y2-Y1+1) + 3) div 4 + 6 octets}\par
{\f1     Mode 640??200 : ((X2-X1+1) * (Y2-Y1+1) + 7) div 8 + 6 octets}\par
{\f1   (approximation ; pr??voir un tampon large)}\par
\par
{\f1   procedure PutPic(var Buffer; X, Y : Integer);}\par
{\f1   Affiche une image pr??c??demment captur??e par GetPic.}\par
\par
{\f1   Param??tres :}\par
{\f1     Buffer  Tampon contenant l'image (rempli par GetPic)}\par
{\f1     X, Y    Position d'affichage (coin sup??rieur gauche)}\par
\par
{\f1   Exemple :}\par
{\f1     var}\par
{\f1       Buf : array[0..2047] of Byte;}\par
{\f1     begin}\par
{\f1       Circle(50, 50, 20, 1);}\par
{\f1       GetPic(Buf, 30, 30, 70, 70);  \{ capturer le cercle \}}\par
{\f1       PutPic(Buf, 200, 100);         \{ afficher ailleurs \}}\par
{\f1     end;}\par
\par
\par
