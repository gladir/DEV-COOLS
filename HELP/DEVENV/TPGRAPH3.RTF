{\footnote # IDH_TPGR3_16}
{\footnote $ Unite Graph3 (TP 3) - EXEMPLES COMPLETS}
{\footnote K Turbo Pascal;Unite Graph3 (TP 3);EXEMPLES COMPLETS}
\b\fs24 EXEMPLES COMPLETS \b0\fs20\par
\par
{\f1   --- Exemple 1 : Dessin de base en mode CGA ---}\par
\par
{\f1   program DessinCGA;}\par
{\f1   uses Graph3;}\par
{\f1   begin}\par
{\f1     GraphColorMode;        \{ 320??200, 4 couleurs \}}\par
{\f1     Palette(1);            \{ cyan, magenta, blanc \}}\par
{\f1     GraphBackground(0);    \{ fond noir \}}\par
\par
{\f1     Draw(10, 10, 310, 190, 1);   \{ diagonale cyan \}}\par
{\f1     Circle(160, 100, 80, 2);     \{ cercle magenta \}}\par
{\f1     Plot(160, 100, 3);           \{ pixel central blanc \}}\par
\par
{\f1     FillShape(160, 50, 3, 2);    \{ remplir haut du cercle \}}\par
\par
{\f1     ReadLn;}\par
{\f1     TextMode(C80);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : Carr?? en turtle graphics ---}\par
\par
{\f1   program CarreTurtle;}\par
{\f1   uses Graph3;}\par
{\f1   var}\par
{\f1     I : Integer;}\par
{\f1   begin}\par
{\f1     GraphColorMode;}\par
{\f1     HideTurtle;}\par
{\f1     SetPenColor(1);}\par
\par
{\f1     for I := 1 to 4 do}\par
{\f1     begin}\par
{\f1       Forwd(60);}\par
{\f1       TurnRight(90);}\par
{\f1     end;}\par
\par
{\f1     ReadLn;}\par
{\f1     TextMode(C80);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Spirale avec la tortue ---}\par
\par
{\f1   program Spirale;}\par
{\f1   uses Graph3;}\par
{\f1   var}\par
{\f1     I : Integer;}\par
{\f1   begin}\par
{\f1     GraphColorMode;}\par
{\f1     HideTurtle;}\par
{\f1     SetPenColor(2);}\par
{\f1     TurtleDelay(10);}\par
\par
{\f1     for I := 1 to 100 do}\par
{\f1     begin}\par
{\f1       Forwd(I);}\par
{\f1       TurnRight(91);}\par
{\f1     end;}\par
\par
{\f1     ReadLn;}\par
{\f1     TextMode(C80);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 4 : ??toile ?? 5 branches ---}\par
\par
{\f1   program Etoile;}\par
{\f1   uses Graph3;}\par
{\f1   var}\par
{\f1     I : Integer;}\par
{\f1   begin}\par
{\f1     GraphColorMode;}\par
{\f1     HideTurtle;}\par
{\f1     SetPenColor(3);}\par
\par
{\f1     for I := 1 to 5 do}\par
{\f1     begin}\par
{\f1       Forwd(80);}\par
{\f1       TurnRight(144);}\par
{\f1     end;}\par
\par
{\f1     ReadLn;}\par
{\f1     TextMode(C80);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 5 : Capture et restitution d'image ---}\par
\par
{\f1   program CaptureImage;}\par
{\f1   uses Graph3;}\par
{\f1   var}\par
{\f1     Buf : array[0..4095] of Byte;}\par
{\f1   begin}\par
{\f1     GraphColorMode;}\par
\par
{\f1     Circle(50, 50, 30, 1);}\par
{\f1     FillShape(50, 50, 2, 1);}\par
\par
{\f1     GetPic(Buf, 20, 20, 80, 80);    \{ capturer la zone \}}\par
{\f1     PutPic(Buf, 150, 80);           \{ copier ailleurs \}}\par
{\f1     PutPic(Buf, 230, 120);          \{ et encore ailleurs \}}\par
\par
{\f1     ReadLn;}\par
{\f1     TextMode(C80);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 6 : Flocon de Koch (r??cursif) ---}\par
\par
{\f1   program Flocon;}\par
{\f1   uses Graph3;}\par
\par
{\f1     procedure Koch(Longueur, Profondeur : Integer);}\par
{\f1     begin}\par
{\f1       if Profondeur = 0 then}\par
{\f1         Forwd(Longueur)}\par
{\f1       else}\par
{\f1       begin}\par
{\f1         Koch(Longueur div 3, Profondeur - 1);}\par
{\f1         TurnLeft(60);}\par
{\f1         Koch(Longueur div 3, Profondeur - 1);}\par
{\f1         TurnRight(120);}\par
{\f1         Koch(Longueur div 3, Profondeur - 1);}\par
{\f1         TurnLeft(60);}\par
{\f1         Koch(Longueur div 3, Profondeur - 1);}\par
{\f1       end;}\par
{\f1     end;}\par
\par
{\f1   var}\par
{\f1     I : Integer;}\par
{\f1   begin}\par
{\f1     HiRes;}\par
{\f1     HideTurtle;}\par
{\f1     PenUp;}\par
{\f1     SetPosition(100, 50);}\par
{\f1     PenDown;}\par
{\f1     SetHeading(East);}\par
\par
{\f1     for I := 1 to 3 do}\par
{\f1     begin}\par
{\f1       Koch(240, 3);}\par
{\f1       TurnRight(120);}\par
{\f1     end;}\par
\par
{\f1     ReadLn;}\par
{\f1     TextMode(C80);}\par
{\f1   end.}\par
\par
\par
