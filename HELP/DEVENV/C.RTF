\b\fs24 CHAINES DE CARACTERES \b0\fs20\par
\par
Une chaine est un tableau de char termine par un octet nul '\\0'.\par
\par
{\f1   char s[] = "Bonjour";   /* \{ 'B','o','n','j','o','u','r','\\0' \} */}\par
\par
\par
\b 13.1 Fonctions principales (<string.h>) \b0\par
\par
{\f1   size_t strlen(const char *s);}\par
{\f1   char  *strcpy(char *dst, const char *src);}\par
{\f1   char  *strncpy(char *dst, const char *src, size_t n);}\par
{\f1   char  *strcat(char *dst, const char *src);}\par
{\f1   int    strcmp(const char *a, const char *b);}\par
{\f1   int    strncmp(const char *a, const char *b, size_t n);}\par
{\f1   char  *strchr(const char *s, int c);}\par
{\f1   char  *strstr(const char *s, const char *sub);}\par
\par
\par
\b 13.2 Fonctions memoire \b0\par
\par
{\f1   void  *memcpy (void *dst, const void *src, size_t n);}\par
{\f1   void  *memmove(void *dst, const void *src, size_t n);}\par
{\f1   void  *memset (void *p, int c, size_t n);}\par
{\f1   int    memcmp (const void *a, const void *b, size_t n);}\par
\par
\par
\b 13.3 Conversions (<stdlib.h>) \b0\par
\par
{\f1   int    atoi (const char *s);}\par
{\f1   long   atol (const char *s);}\par
{\f1   double atof (const char *s);}\par
{\f1   long   strtol(const char *s, char **endptr, int base);}\par
\par
\par
\par
