\par
log10\par
{\f1   Description : Logarithme decimal (base 10).}\par
{\f1   Syntaxe     : double log10(double x);}\par
{\f1   Parametres  : x - reel strictement positif.}\par
{\f1   Retour      : log10(x).}\par
{\f1   Exemple     : log10(1000.0)  /* 3.0 */}\par
\par
modf\par
