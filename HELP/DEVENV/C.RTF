\b 25.7 <stdarg.h> \b0\par
\par
va_start\par
{\f1   Description : Initialise une liste d'arguments variables.}\par
{\f1   Syntaxe     : void va_start(va_list ap, last_named);}\par
{\f1   Parametres  : ap         - liste a initialiser.}\par
{\f1                 last_named - dernier parametre nomme.}\par
{\f1   Retour      : aucun.}\par
\par
va_arg\par
{\f1   Description : Recupere l'argument suivant et avance le}\par
{\f1                 pointeur de liste.}\par
{\f1   Syntaxe     : type va_arg(va_list ap, type);}\par
{\f1   Parametres  : ap   - liste. type - type attendu.}\par
{\f1   Retour      : valeur du type demande.}\par
\par
va_end\par
{\f1   Description : Termine l'utilisation d'une liste d'arguments.}\par
{\f1   Syntaxe     : void va_end(va_list ap);}\par
{\f1   Parametres  : ap - liste a fermer.}\par
{\f1   Retour      : aucun.}\par
\par
Exemple complet (somme d'un nombre variable d'entiers) :\par
\par
{\f1   int sum(int n, ...) \{}\par
{\f1       va_list ap; int s = 0, i;}\par
{\f1       va_start(ap, n);}\par
{\f1       for (i = 0; i < n; i++) s += va_arg(ap, int);}\par
{\f1       va_end(ap);}\par
{\f1       return s;}\par
{\f1   \}}\par
\par
