{\f1   Retour      : <0, 0 ou >0.}\par
{\f1   Exemple     : strcoll("etre", "evidence");}\par
\par
strcpy\par
{\f1   Description : Copie src dans dst (avec '\\0').}\par
{\f1   Syntaxe     : char *strcpy(char *dst, const char *src);}\par
{\f1   Parametres  : dst, src.}\par
{\f1   Retour      : dst.}\par
{\f1   Exemple     : strcpy(buf, "Bonjour");}\par
\par
strcspn\par
{\f1   Description : Longueur du prefixe ne contenant AUCUN des}\par
{\f1                 caracteres de reject.}\par
{\f1   Syntaxe     : size_t strcspn(const char *s, const char *reject);}\par
{\f1   Parametres  : s, reject.}\par
{\f1   Retour      : longueur du prefixe.}\par
{\f1   Exemple     : size_t n = strcspn(s, " \\t\\n");}\par
\par
strerror\par
{\f1   Description : Message d'erreur correspondant a un code errno.}\par
{\f1   Syntaxe     : char *strerror(int errnum);}\par
{\f1   Parametres  : errnum - valeur de errno.}\par
{\f1   Retour      : pointeur sur chaine statique.}\par
{\f1   Exemple     : printf("%s\\n", strerror(errno));}\par
\par
strlen\par
{\f1   Description : Longueur d'une chaine (sans le '\\0').}\par
{\f1   Syntaxe     : size_t strlen(const char *s);}\par
{\f1   Parametres  : s - chaine.}\par
{\f1   Retour      : nombre d'octets avant '\\0'.}\par
{\f1   Exemple     : size_t l = strlen("hello");  /* 5 */}\par
\par
strncat\par
{\f1   Description : Concatene au plus n caracteres de src a dst.}\par
{\f1   Syntaxe     : char *strncat(char *dst, const char *src, size_t n);}\par
{\f1   Parametres  : dst, src, n.}\par
{\f1   Retour      : dst (toujours termine par '\\0').}\par
{\f1   Exemple     : strncat(buf, src, 10);}\par
\par
strncmp\par
{\f1   Description : Compare au plus n caracteres.}\par
{\f1   Syntaxe     : int strncmp(const char *a, const char *b, size_t n);}\par
{\f1   Parametres  : a, b, n.}\par
{\f1   Retour      : <0, 0 ou >0.}\par
{\f1   Exemple     : if (strncmp(s, "http://", 7) == 0) ...}\par
\par
strncpy\par
{\f1   Description : Copie au plus n caracteres. Si src plus court,}\par
{\f1                 complete avec '\\0'. PAS toujours termine.}\par
{\f1   Syntaxe     : char *strncpy(char *dst, const char *src, size_t n);}\par
{\f1   Parametres  : dst, src, n.}\par
{\f1   Retour      : dst.}\par
{\f1   Exemple     :}\par
{\f1                 strncpy(buf, src, sizeof buf);}\par
{\f1                 buf[sizeof buf - 1] = '\\0';}\par
\par
strpbrk\par
{\f1   Description : Premiere position contenant un caractere de set.}\par
{\f1   Syntaxe     : char *strpbrk(const char *s, const char *set);}\par
{\f1   Parametres  : s, set.}\par
{\f1   Retour      : pointeur ou NULL.}\par
{\f1   Exemple     : char *p = strpbrk(s, ",;");}\par
\par
strrchr\par
{\f1   Description : Derniere occurrence de c dans s.}\par
{\f1   Syntaxe     : char *strrchr(const char *s, int c);}\par
{\f1   Parametres  : s, c.}\par
{\f1   Retour      : pointeur ou NULL.}\par
{\f1   Exemple     : char *ext = strrchr(name, '.');}\par
\par
strspn\par
{\f1   Description : Longueur du prefixe ne contenant QUE les}\par
{\f1                 caracteres de accept.}\par
{\f1   Syntaxe     : size_t strspn(const char *s, const char *accept);}\par
{\f1   Parametres  : s, accept.}\par
{\f1   Retour      : longueur du prefixe.}\par
{\f1   Exemple     : size_t n = strspn(s, "0123456789");}\par
\par
strstr\par
{\f1   Description : Recherche d'une sous-chaine.}\par
{\f1   Syntaxe     : char *strstr(const char *s, const char *sub);}\par
{\f1   Parametres  : s - chaine. sub - sous-chaine.}\par
{\f1   Retour      : pointeur ou NULL.}\par
{\f1   Exemple     : if (strstr(s, "error")) ...}\par
\par
strtok\par
{\f1   Description : Decoupe une chaine en jetons selon des}\par
{\f1                 delimiteurs (modifie la chaine source !).}\par
{\f1   Syntaxe     : char *strtok(char *s, const char *delim);}\par
{\f1   Parametres  : s - chaine (NULL pour iterer). delim - liste.}\par
{\f1   Retour      : pointeur sur jeton suivant ou NULL.}\par
{\f1   Exemple     :}\par
{\f1                 for (p = strtok(s, " ,"); p; p = strtok(NULL, " ,"))}\par
{\f1                     puts(p);}\par
\par
strxfrm\par
{\f1   Description : Transforme s selon la locale pour que strcmp}\par
{\f1                 donne le meme resultat que strcoll.}\par
{\f1   Syntaxe     : size_t strxfrm(char *dst, const char *src, size_t n);}\par
{\f1   Parametres  : dst, src, n.}\par
{\f1   Retour      : longueur necessaire (sans '\\0').}\par
\par
\par
\b 25.11 <time.h> \b0\par
\par
asctime\par
{\f1   Description : Convertit une struct tm en chaine lisible.}\par
{\f1   Syntaxe     : char *asctime(const struct tm *tm);}\par
{\f1   Parametres  : tm - date eclatee.}\par
{\f1   Retour      : chaine "Sun Apr 14 12:34:56 2026\\n".}\par
{\f1   Exemple     : printf("%s", asctime(localtime(&t)));}\par
\par
clock\par
{\f1   Description : Temps CPU consomme depuis le debut du programme.}\par
{\f1   Syntaxe     : clock_t clock(void);}\par
{\f1   Parametres  : aucun.}\par
{\f1   Retour      : clock_t (diviser par CLOCKS_PER_SEC pour}\par
{\f1                 obtenir des secondes).}\par
{\f1   Exemple     :}\par
{\f1                 clock_t t0 = clock();}\par
{\f1                 /* ... */}\par
{\f1                 double s = (clock() - t0) / (double)CLOCKS_PER_SEC;}\par
\par
ctime\par
{\f1   Description : Convertit time_t en chaine lisible (locale).}\par
{\f1   Syntaxe     : char *ctime(const time_t *t);}\par
{\f1   Parametres  : t - pointeur sur l'heure.}\par
{\f1   Retour      : chaine equivalente a asctime(localtime(t)).}\par
{\f1   Exemple     : printf("%s", ctime(&now));}\par
\par
difftime\par
{\f1   Description : Difference entre deux time_t en secondes.}\par
{\f1   Syntaxe     : double difftime(time_t t1, time_t t0);}\par
{\f1   Parametres  : t1, t0.}\par
{\f1   Retour      : t1 - t0 en secondes (double).}\par
{\f1   Exemple     : double d = difftime(t_end, t_start);}\par
\par
gmtime\par
{\f1   Description : Convertit time_t en struct tm UTC.}\par
{\f1   Syntaxe     : struct tm *gmtime(const time_t *t);}\par
{\f1   Parametres  : t.}\par
{\f1   Retour      : pointeur sur struct tm statique.}\par
{\f1   Exemple     : struct tm *u = gmtime(&now);}\par
\par
localtime\par
{\f1   Description : Convertit time_t en struct tm locale.}\par
{\f1   Syntaxe     : struct tm *localtime(const time_t *t);}\par
{\f1   Parametres  : t.}\par
{\f1   Retour      : pointeur sur struct tm statique.}\par
{\f1   Exemple     : struct tm *l = localtime(&now);}\par
\par
mktime\par
{\f1   Description : Convertit struct tm (locale) en time_t et}\par
{\f1                 normalise les champs.}\par
{\f1   Syntaxe     : time_t mktime(struct tm *tm);}\par
{\f1   Parametres  : tm - date eclatee.}\par
{\f1   Retour      : time_t ou -1 si impossible.}\par
{\f1   Exemple     : time_t t = mktime(&tm);}\par
\par
strftime\par
{\f1   Description : Formate une date dans une chaine selon un}\par
{\f1                 modele "%Y-%m-%d %H:%M:%S" etc.}\par
{\f1   Syntaxe     : size_t strftime(char *s, size_t max,}\par
{\f1                                  const char *fmt,}\par
{\f1                                  const struct tm *tm);}\par
{\f1   Parametres  : s - tampon. max - taille. fmt - format.}\par
{\f1                 tm - date.}\par
{\f1   Retour      : longueur ecrite (sans '\\0') ou 0.}\par
{\f1   Exemple     :}\par
{\f1                 char buf[64];}\par
{\f1                 strftime(buf, sizeof buf, "%F %T", localtime(&now));}\par
\par
time\par
{\f1   Description : Retourne l'heure systeme courante (secondes}\par
{\f1                 depuis l'epoque).}\par
{\f1   Syntaxe     : time_t time(time_t *t);}\par
{\f1   Parametres  : t - pointeur de sortie (peut etre NULL).}\par
{\f1   Retour      : time_t ou (time_t)-1 si erreur.}\par
{\f1   Exemple     : time_t now = time(NULL);}\par
\par
\par
\b 25.12 Fonctions C99 et plus recentes \b0\par
\par
snprintf\par
{\f1   Description : sprintf bornant l'ecriture a n octets ('\\0'}\par
{\f1                 inclus). Recommandee a la place de sprintf.}\par
{\f1   Syntaxe     : int snprintf(char *s, size_t n, const char *fmt, ...);}\par
{\f1   Parametres  : s, n, fmt, ...}\par
{\f1   Retour      : nombre de caracteres qui auraient ete ecrits}\par
{\f1                 sans la troncature.}\par
{\f1   Exemple     : snprintf(buf, sizeof buf, "x=%d", n);}\par
\par
vsnprintf\par
{\f1   Description : snprintf prenant une va_list.}\par
{\f1   Syntaxe     : int vsnprintf(char *s, size_t n, const char *fmt,}\par
{\f1                               va_list ap);}\par
{\f1   Parametres  : s, n, fmt, ap.}\par
{\f1   Retour      : nb de caracteres souhaites.}\par
\par
strtoll\par
{\f1   Description : strtol pour long long.}\par
{\f1   Syntaxe     : long long strtoll(const char *s, char **endptr,}\par
{\f1                                    int base);}\par
{\f1   Retour      : valeur long long.}\par
\par
strtoull\par
{\f1   Description : strtoul pour unsigned long long.}\par
{\f1   Syntaxe     : unsigned long long strtoull(const char *s,}\par
{\f1                                              char **endptr, int base);}\par
\par
llabs\par
{\f1   Description : Valeur absolue d'un long long.}\par
{\f1   Syntaxe     : long long llabs(long long n);}\par
\par
lldiv\par
{\f1   Description : Division long long avec quot et reste.}\par
{\f1   Syntaxe     : lldiv_t lldiv(long long num, long long denom);}\par
\par
atoll\par
{\f1   Description : atoi pour long long.}\par
{\f1   Syntaxe     : long long atoll(const char *s);}\par
\par
acosh, asinh, atanh\par
{\f1   Description : Inverses hyperboliques.}\par
{\f1   Syntaxe     : double acosh(double x);}\par
{\f1                 double asinh(double x);}\par
{\f1                 double atanh(double x);}\par
\par
cbrt\par
{\f1   Description : Racine cubique.}\par
{\f1   Syntaxe     : double cbrt(double x);}\par
{\f1   Exemple     : cbrt(27.0)  /* 3.0 */}\par
\par
copysign\par
{\f1   Description : Retourne |x| avec le signe de y.}\par
{\f1   Syntaxe     : double copysign(double x, double y);}\par
\par
erf\par
{\f1   Description : Fonction d'erreur gaussienne.}\par
{\f1   Syntaxe     : double erf(double x);}\par
\par
exp2\par
{\f1   Description : 2^x.}\par
{\f1   Syntaxe     : double exp2(double x);}\par
\par
expm1\par
{\f1   Description : exp(x) - 1, precis pres de 0.}\par
{\f1   Syntaxe     : double expm1(double x);}\par
\par
hypot\par
{\f1   Description : sqrt(x*x + y*y) sans overflow intermediaire.}\par
{\f1   Syntaxe     : double hypot(double x, double y);}\par
{\f1   Exemple     : hypot(3.0, 4.0)  /* 5.0 */}\par
\par
log1p\par
{\f1   Description : log(1+x), precis pres de 0.}\par
{\f1   Syntaxe     : double log1p(double x);}\par
\par
log2\par
{\f1   Description : Logarithme base 2.}\par
{\f1   Syntaxe     : double log2(double x);}\par
\par
nearbyint\par
{\f1   Description : Arrondi a l'entier selon le mode courant (sans}\par
{\f1                 exception "inexact").}\par
{\f1   Syntaxe     : double nearbyint(double x);}\par
\par
remainder\par
{\f1   Description : Reste IEEE 754 (mode "round to nearest even").}\par
{\f1   Syntaxe     : double remainder(double x, double y);}\par
\par
round\par
{\f1   Description : Arrondi a l'entier le plus proche (away from 0).}\par
{\f1   Syntaxe     : double round(double x);}\par
{\f1   Exemple     : round(2.5)  /* 3.0 */}\par
\par
trunc\par
{\f1   Description : Troncature vers zero.}\par
{\f1   Syntaxe     : double trunc(double x);}\par
{\f1   Exemple     : trunc(-2.7)  /* -2.0 */}\par
\par
\par
\b 25.13 Fonctions POSIX courantes \b0\par
\par
open\par
{\f1   Description : Ouvre un descripteur de fichier bas niveau.}\par
{\f1   Syntaxe     : int open(const char *path, int flags, ...);}\par
{\f1   Parametres  : path - chemin. flags - O_RDONLY, O_WRONLY,}\par
{\f1                 O_RDWR, O_CREAT, O_TRUNC, O_APPEND, ...}\par
{\f1                 Mode (3e arg) requis si O_CREAT.}\par
{\f1   Retour      : fd >= 0 ou -1 (errno).}\par
{\f1   Exemple     : int fd = open("data", O_RDONLY);}\par
\par
close\par
{\f1   Description : Ferme un descripteur.}\par
{\f1   Syntaxe     : int close(int fd);}\par
{\f1   Retour      : 0 ou -1.}\par
{\f1   Exemple     : close(fd);}\par
\par
read\par
{\f1   Description : Lit n octets bruts d'un descripteur.}\par
{\f1   Syntaxe     : ssize_t read(int fd, void *buf, size_t n);}\par
{\f1   Retour      : nb d'octets lus, 0 = EOF, -1 = erreur.}\par
{\f1   Exemple     : ssize_t r = read(fd, buf, sizeof buf);}\par
\par
write\par
{\f1   Description : Ecrit n octets bruts vers un descripteur.}\par
{\f1   Syntaxe     : ssize_t write(int fd, const void *buf, size_t n);}\par
{\f1   Retour      : nb d'octets ecrits ou -1.}\par
{\f1   Exemple     : write(STDOUT_FILENO, "hi\\n", 3);}\par
\par
lseek\par
{\f1   Description : Positionne le curseur d'un descripteur.}\par
{\f1   Syntaxe     : off_t lseek(int fd, off_t offset, int whence);}\par
{\f1   Parametres  : whence - SEEK_SET, SEEK_CUR, SEEK_END.}\par
{\f1   Retour      : nouvelle position ou -1.}\par
\par
unlink\par
{\f1   Description : Supprime un fichier (un lien).}\par
{\f1   Syntaxe     : int unlink(const char *path);}\par
{\f1   Retour      : 0 ou -1.}\par
\par
access\par
{\f1   Description : Teste les droits sur un fichier.}\par
{\f1   Syntaxe     : int access(const char *path, int mode);}\par
{\f1   Parametres  : mode - F_OK, R_OK, W_OK, X_OK.}\par
{\f1   Retour      : 0 si autorise, -1 sinon.}\par
\par
stat\par
{\f1   Description : Recupere les attributs d'un fichier.}\par
{\f1   Syntaxe     : int stat(const char *path, struct stat *buf);}\par
{\f1   Retour      : 0 ou -1.}\par
{\f1   Exemple     :}\par
{\f1                 struct stat st;}\par
{\f1                 if (stat("f", &st) == 0)}\par
{\f1                     printf("size=%ld\\n", (long)st.st_size);}\par
\par
fstat\par
{\f1   Description : stat() sur un descripteur ouvert.}\par
{\f1   Syntaxe     : int fstat(int fd, struct stat *buf);}\par
\par
chmod\par
{\f1   Description : Change les permissions d'un fichier.}\par
{\f1   Syntaxe     : int chmod(const char *path, mode_t mode);}\par
{\f1   Retour      : 0 ou -1.}\par
\par
fork\par
{\f1   Description : Cree un processus fils (copie du parent).}\par
{\f1   Syntaxe     : pid_t fork(void);}\par
{\f1   Retour      : 0 dans le fils, pid du fils dans le parent,}\par
{\f1                 -1 si echec.}\par
\par
execv, execl, execvp, ...\par
{\f1   Description : Remplace l'image du processus courant par un}\par
{\f1                 programme.}\par
{\f1   Syntaxe     : int execv(const char *path, char *const argv[]);}\par
{\f1   Retour      : ne revient pas si succes ; -1 si echec.}\par
\par
wait\par
{\f1   Description : Attend la fin d'un processus fils.}\par
{\f1   Syntaxe     : pid_t wait(int *status);}\par
{\f1   Retour      : pid du fils ou -1.}\par
\par
pipe\par
{\f1   Description : Cree une paire de descripteurs (tube).}\par
{\f1   Syntaxe     : int pipe(int fd[2]);}\par
{\f1   Parametres  : fd[0] = lecture, fd[1] = ecriture.}\par
{\f1   Retour      : 0 ou -1.}\par
\par
dup\par
{\f1   Description : Duplique un descripteur (plus petit fd libre).}\par
{\f1   Syntaxe     : int dup(int oldfd);}\par
{\f1   Retour      : nouveau fd ou -1.}\par
\par
dup2\par
{\f1   Description : Duplique vers un descripteur donne (ferme}\par
{\f1                 newfd si necessaire).}\par
{\f1   Syntaxe     : int dup2(int oldfd, int newfd);}\par
{\f1   Retour      : newfd ou -1.}\par
{\f1   Exemple     : dup2(fd, STDOUT_FILENO);  /* rediriger stdout */}\par
\par
\par
