\b\fs24 ENTREES / SORTIES STANDARD \b0\fs20\par
\par
\par
\b 14.1 Flux standard (<stdio.h>) \b0\par
\par
{\f1   stdin    entree standard       (clavier par defaut)}\par
{\f1   stdout   sortie standard       (ecran par defaut)}\par
{\f1   stderr   sortie d'erreur       (ecran, non bufferisee)}\par
\par
\par
\b 14.2 Sortie formatee \b0\par
\par
{\f1   int printf (const char *fmt, ...);}\par
{\f1   int fprintf(FILE *f, const char *fmt, ...);}\par
{\f1   int sprintf(char *buf, const char *fmt, ...);}\par
\par
Specificateurs de format :\par
\par
{\f1   %d  %i      entier decimal signe}\par
{\f1   %u          entier decimal non signe}\par
{\f1   %o  %x  %X  octal / hexa minuscules / hexa majuscules}\par
{\f1   %c          caractere}\par
{\f1   %s          chaine}\par
{\f1   %f  %e  %g  flottant decimal / scientifique / general}\par
{\f1   %p          pointeur}\par
{\f1   %%          litteral %}\par
\par
Modificateurs : largeur, precision, l (long), h (short),\par
ll (long long, C99), drapeaux ('-' '+' ' ' '0' '#').\par
\par
\par
\b 14.3 Entree formatee \b0\par
\par
{\f1   int scanf (const char *fmt, ...);}\par
{\f1   int fscanf(FILE *f, const char *fmt, ...);}\par
{\f1   int sscanf(const char *s, const char *fmt, ...);}\par
\par
\par
\b 14.4 Acces aux fichiers \b0\par
\par
{\f1   FILE  *fopen (const char *path, const char *mode);}\par
{\f1   int    fclose(FILE *f);}\par
{\f1   int    fgetc (FILE *f);}\par
{\f1   int    fputc (int c, FILE *f);}\par
{\f1   char  *fgets (char *s, int n, FILE *f);}\par
{\f1   int    fputs (const char *s, FILE *f);}\par
{\f1   size_t fread (void *p, size_t sz, size_t n, FILE *f);}\par
{\f1   size_t fwrite(const void *p, size_t sz, size_t n, FILE *f);}\par
{\f1   int    fseek (FILE *f, long ofs, int whence);}\par
{\f1   long   ftell (FILE *f);}\par
{\f1   void   rewind(FILE *f);}\par
