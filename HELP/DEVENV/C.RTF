{\f1                 double m = frexp(8.0, &e);  /* m=0.5, e=4 */}\par
\par
ldexp\par
{\f1   Description : Calcule x * 2^exp.}\par
{\f1   Syntaxe     : double ldexp(double x, int exp);}\par
{\f1   Parametres  : x - mantisse. exp - exposant.}\par
