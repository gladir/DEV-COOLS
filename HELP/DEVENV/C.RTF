{\footnote # IDH_C_23}
{\footnote $ C - EXEMPLE COMPLET}
{\footnote K C exemple complet;Fibonacci;programme exemple}
\b\fs24 EXEMPLE COMPLET \b0\fs20\par
\par
Programme calculant la suite de Fibonacci :\par
\par
{\f1   #include <stdio.h>}\par
{\f1   #include <stdlib.h>}\par
\par
{\f1   long fib(int n)}\par
{\f1   \{}\par
{\f1       if (n < 2) return n;}\par
{\f1       return fib(n - 1) + fib(n - 2);}\par
{\f1   \}}\par
\par
{\f1   int main(int argc, char *argv[])}\par
{\f1   \{}\par
{\f1       int n = (argc > 1) ? atoi(argv[1]) : 10;}\par
{\f1       int i;}\par
\par
{\f1       printf("Suite de Fibonacci jusqu'a F(%d) :\\n", n);}\par
{\f1       for (i = 0; i <= n; i++)}\par
{\f1           printf("  F(%2d) = %ld\\n", i, fib(i));}\par
\par
{\f1       return 0;}\par
{\f1   \}}\par
\par
Compilation et execution sous DOS (CC8086) :\par
\par
{\f1   CC8086 fib.c}\par
{\f1   MASM   fib.asm}\par
{\f1   LINK   fib.obj}\par
{\f1   fib 15}\par
\par
\par
