{\footnote # IDH_C_25}
{\footnote $ C - DEFINITIONS DETAILLEES DES FONCTIONS}
{\footnote K C definitions fonctions;documentation fonctions;reference fonctions}
\b\fs24 DEFINITIONS DETAILLEES DES FONCTIONS \b0\fs20\par
\par
Chaque fonction est presentee dans le format :\par
\par
{\f1   Description : role general.}\par
{\f1   Syntaxe     : prototype ANSI.}\par
{\f1   Parametres  : signification de chaque argument.}\par
{\f1   Retour      : valeur retournee et conditions d'erreur.}\par
{\f1   Exemple     : usage minimal.}\par
\par
\par
\b 25.1 <assert.h> \b0\par
\par
assert\par
{\f1   Description : Verifie une expression en mode debug. Si elle}\par
{\f1                 est fausse, affiche un message diagnostique sur}\par
{\f1                 stderr puis appelle abort(). Desactive si NDEBUG}\par
{\f1                 est defini.}\par
{\f1   Syntaxe     : void assert(int expression);}\par
{\f1   Parametres  : expression - condition booleenne a verifier.}\par
{\f1   Retour      : aucun (macro).}\par
{\f1   Exemple     :}\par
{\f1                 assert(p != NULL);}\par
{\f1                 assert(n > 0 && n < 100);}\par
\par
\par
\b 25.2 <ctype.h> \b0\par
\par
isalnum\par
{\f1   Description : Teste si le caractere est alphanumerique.}\par
{\f1   Syntaxe     : int isalnum(int c);}\par
{\f1   Parametres  : c - caractere a tester (unsigned char ou EOF).}\par
{\f1   Retour      : non zero si vrai, 0 sinon.}\par
{\f1   Exemple     : if (isalnum(c)) putchar(c);}\par
\par
isalpha\par
{\f1   Description : Teste si le caractere est une lettre.}\par
{\f1   Syntaxe     : int isalpha(int c);}\par
{\f1   Parametres  : c - caractere a tester.}\par
{\f1   Retour      : non zero si lettre, 0 sinon.}\par
{\f1   Exemple     : while (isalpha(*s)) s++;}\par
\par
iscntrl\par
{\f1   Description : Teste si le caractere est un caractere de}\par
{\f1                 controle (codes 0..31 et 127 en ASCII).}\par
{\f1   Syntaxe     : int iscntrl(int c);}\par
{\f1   Parametres  : c - caractere a tester.}\par
{\f1   Retour      : non zero si controle, 0 sinon.}\par
