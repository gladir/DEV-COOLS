\page

{\footnote # IDH_C_11}
{\footnote $ C - STRUCTURES, UNIONS, ENUMERATIONS}
{\footnote K C structures;union;enum;enumeration;typedef;champs de bits}
\b\fs24 STRUCTURES, UNIONS, ENUMERATIONS \b0\fs20\par
\par
\par
\b 11.1 Structures \b0\par
\par
{\f1   struct point \{}\par
{\f1       int x;}\par
{\f1       int y;}\par
{\f1   \};}\par
\par
{\f1   struct point p1 = \{10, 20\};}\par
{\f1   struct point p2 = \{ .x = 5, .y = 7 \};   /* designators C99 */}\par
\par
{\f1   p1.x = 30;}\par
{\f1   printf("%d %d\\n", p1.x, p1.y);}\par
\par
Avec typedef :\par
\par
{\f1   typedef struct \{}\par
{\f1       double r;}\par
{\f1       double i;}\par
{\f1   \} complex;}\par
\par
{\f1   complex c = \{1.0, -2.0\};}\par
\par
\par
\b 11.2 Pointeurs sur structure \b0\par
\par
{\f1   struct point *pp = &p1;}\par
{\f1   pp->x = 100;          /* equivalent a (*pp).x = 100 */}\par
\par
\par
\b 11.3 Unions \b0\par
\par
Une union reserve un emplacement assez grand pour le plus gros\par
de ses champs ; tous ses champs partagent le meme stockage.\par
\par
{\f1   union variant \{}\par
{\f1       int    i;}\par
{\f1       float  f;}\par
{\f1       char   s[16];}\par
{\f1   \};}\par
\par
\par
\b 11.4 Enumerations \b0\par
\par
{\f1   enum couleur \{ ROUGE, VERT, BLEU \};          /* 0, 1, 2     */}\par
{\f1   enum signal  \{ OK = 0, ERR = -1, WARN = 1 \};}\par
\par
Les valeurs sont des constantes entieres.\par
\par
\par
\b 11.5 Champs de bits \b0\par
\par
{\f1   struct flags \{}\par
{\f1       unsigned actif      : 1;}\par
{\f1       unsigned mode       : 3;}\par
{\f1       unsigned reserve    : 4;}\par
{\f1   \};}\par
\par
\par
\par
