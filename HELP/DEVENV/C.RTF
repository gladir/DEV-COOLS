{\footnote # IDH_C_17}
{\footnote $ C - PORTEE, DUREE DE VIE ET LIAISON}
{\footnote K C portee;duree de vie;liaison;linkage;static;extern}
\b\fs24 PORTEE, DUREE DE VIE ET LIAISON \b0\fs20\par
\par
\par
\b 17.1 Portees \b0\par
\par
{\f1   - Portee de bloc        : variable locale a un bloc \{ ... \}}\par
{\f1   - Portee de fonction    : etiquettes goto}\par
{\f1   - Portee de prototype   : parametres d'une declaration}\par
{\f1   - Portee de fichier     : declarations hors fonction}\par
\par
\par
\b 17.2 Durees de vie \b0\par
\par
{\f1   - Automatique : creee a l'entree du bloc, detruite a la}\par
{\f1                   sortie (variables locales standard).}\par
{\f1   - Statique    : duree de vie = programme (globales et}\par
{\f1                   locales static).}\par
{\f1   - Allouee     : controlee par malloc/free.}\par
\par
\par
\b 17.3 Liaisons (linkage) \b0\par
\par
{\f1   - Externe  : visible depuis d'autres unites de traduction}\par
{\f1                (fonctions par defaut, globales sans static).}\par
{\f1   - Interne  : visible uniquement dans l'unite (declaration}\par
{\f1                static au niveau fichier).}\par
{\f1   - Sans liaison : locale a une fonction.}\par
\par
\par
\par
