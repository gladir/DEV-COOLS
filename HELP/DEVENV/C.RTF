\b 25.4 <math.h> \b0\par
\par
Toutes les fonctions <math.h> de C89 prennent et retournent un\par
double. En cas d'erreur de domaine, errno=EDOM et le resultat\par
est implementation-defined. En cas d'erreur de plage, errno=\par
ERANGE et le resultat est HUGE_VAL ou 0.\par
\par
acos\par
{\f1   Description : Arc cosinus (radians) de x dans [-1, 1].}\par
{\f1   Syntaxe     : double acos(double x);}\par
{\f1   Parametres  : x - valeur dans [-1, 1].}\par
{\f1   Retour      : angle dans [0, PI] en radians.}\par
{\f1   Exemple     : double a = acos(0.5);   /* PI/3 */}\par
\par
asin\par
{\f1   Description : Arc sinus (radians) de x dans [-1, 1].}\par
{\f1   Syntaxe     : double asin(double x);}\par
{\f1   Parametres  : x - valeur dans [-1, 1].}\par
{\f1   Retour      : angle dans [-PI/2, PI/2].}\par
{\f1   Exemple     : double a = asin(1.0);   /* PI/2 */}\par
\par
atan\par
{\f1   Description : Arc tangente de x.}\par
{\f1   Syntaxe     : double atan(double x);}\par
{\f1   Parametres  : x - valeur reelle.}\par
{\f1   Retour      : angle dans (-PI/2, PI/2).}\par
{\f1   Exemple     : double a = atan(1.0);   /* PI/4 */}\par
\par
atan2\par
{\f1   Description : Arc tangente de y/x sur les 4 quadrants.}\par
{\f1   Syntaxe     : double atan2(double y, double x);}\par
{\f1   Parametres  : y, x - coordonnees.}\par
{\f1   Retour      : angle dans (-PI, PI].}\par
{\f1   Exemple     : double a = atan2(1.0, 1.0);  /* PI/4 */}\par
\par
ceil\par
{\f1   Description : Plafond : plus petit entier >= x.}\par
{\f1   Syntaxe     : double ceil(double x);}\par
{\f1   Parametres  : x - valeur reelle.}\par
{\f1   Retour      : ceil(x).}\par
{\f1   Exemple     : ceil(3.2)   /* 4.0 */}\par
\par
cos\par
{\f1   Description : Cosinus de x exprime en radians.}\par
{\f1   Syntaxe     : double cos(double x);}\par
{\f1   Parametres  : x - angle en radians.}\par
{\f1   Retour      : valeur dans [-1, 1].}\par
{\f1   Exemple     : double c = cos(0.0);   /* 1.0 */}\par
\par
cosh\par
{\f1   Description : Cosinus hyperbolique de x.}\par
{\f1   Syntaxe     : double cosh(double x);}\par
{\f1   Parametres  : x - valeur reelle.}\par
{\f1   Retour      : (e^x + e^-x)/2.}\par
{\f1   Exemple     : cosh(0.0)   /* 1.0 */}\par
\par
exp\par
{\f1   Description : Exponentielle e^x.}\par
{\f1   Syntaxe     : double exp(double x);}\par
{\f1   Parametres  : x - exposant.}\par
{\f1   Retour      : e^x.}\par
{\f1   Exemple     : exp(1.0)   /* ~2.71828 */}\par
\par
fabs\par
{\f1   Description : Valeur absolue d'un flottant.}\par
{\f1   Syntaxe     : double fabs(double x);}\par
{\f1   Parametres  : x - valeur reelle.}\par
{\f1   Retour      : |x|.}\par
{\f1   Exemple     : fabs(-3.5)  /* 3.5 */}\par
\par
floor\par
{\f1   Description : Plancher : plus grand entier <= x.}\par
{\f1   Syntaxe     : double floor(double x);}\par
{\f1   Parametres  : x - valeur reelle.}\par
{\f1   Retour      : floor(x).}\par
{\f1   Exemple     : floor(3.7)  /* 3.0 */}\par
\par
fmod\par
{\f1   Description : Reste flottant de x/y de meme signe que x.}\par
{\f1   Syntaxe     : double fmod(double x, double y);}\par
{\f1   Parametres  : x - numerateur. y - denominateur.}\par
{\f1   Retour      : x - n*y avec n entier ; 0 si y=0 (erreur).}\par
{\f1   Exemple     : fmod(5.3, 2.0)  /* 1.3 */}\par
\par
frexp\par
{\f1   Description : Decompose x en mantisse f et exposant 2^e :}\par
{\f1                 x = f * 2^e avec 0.5 <= |f| < 1.}\par
{\f1   Syntaxe     : double frexp(double x, int *exp);}\par
{\f1   Parametres  : x   - valeur. exp - sortie de l'exposant.}\par
{\f1   Retour      : mantisse normalisee.}\par
{\f1   Exemple     :}\par
