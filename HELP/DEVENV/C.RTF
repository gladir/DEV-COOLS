{\footnote # IDH_C_12}
{\footnote $ C - PREPROCESSEUR}
{\footnote K C preprocesseur;define;include;ifdef;macros;__FILE__;__LINE__}
\b\fs24 PREPROCESSEUR \b0\fs20\par
\par
Le preprocesseur traite le source AVANT la compilation. Toutes\par
les directives commencent par # en colonne 1 (ou apres des\par
espaces).\par
\par
\par
\b 12.1 Inclusion de fichiers \b0\par
\par
{\f1   #include <stdio.h>      /* en-tete systeme */}\par
{\f1   #include "monfich.h"    /* en-tete local   */}\par
\par
\par
\b 12.2 Macros \b0\par
\par
Sans parametre :\par
\par
{\f1   #define PI       3.14159265}\par
{\f1   #define BUFSIZE  1024}\par
\par
Avec parametres :\par
\par
{\f1   #define MAX(a,b)   ((a) > (b) ? (a) : (b))}\par
{\f1   #define CARRE(x)   ((x) * (x))}\par
\par
\par
\b 12.3 Compilation conditionnelle \b0\par
\par
{\f1   #ifdef  SYMBOLE      ... #endif}\par
{\f1   #ifndef SYMBOLE      ... #endif}\par
{\f1   #if    expression    ... #elif ...  #else ...  #endif}\par
{\f1   #undef SYMBOLE}\par
\par
\par
\b 12.4 Operateurs # et ## \b0\par
\par
{\f1   #x       transforme x en chaine ("nom")}\par
{\f1   a##b     concatene les jetons a et b (collage)}\par
\par
\par
\b 12.5 Macros predefinies \b0\par
\par
{\f1   __FILE__         nom du fichier source courant}\par
{\f1   __LINE__         numero de ligne courant}\par
{\f1   __DATE__         date de compilation     ("Apr 14 2026")}\par
{\f1   __TIME__         heure de compilation    ("12:34:56")}\par
{\f1   __STDC__         vaut 1 en mode ANSI strict}\par
{\f1   __func__         (C99) nom de la fonction courante}\par
\par
\par
\par
