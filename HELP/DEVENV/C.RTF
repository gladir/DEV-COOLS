{\footnote # IDH_C_06}
{\footnote $ C - OPERATEURS ET EXPRESSIONS}
{\footnote K C operateurs;expressions;arithmetique;relationnel;logique;bit a bit;precedence;sizeof}
\b\fs24 OPERATEURS ET EXPRESSIONS \b0\fs20\par
\par
\par
\b 6.1 Operateurs arithmetiques \b0\par
\par
{\f1   +    addition          a + b}\par
{\f1   -    soustraction      a - b   (ou unaire -a)}\par
{\f1   *    multiplication    a * b}\par
{\f1   /    division          a / b   (entiere si operandes entiers)}\par
{\f1   %    modulo            a % b   (entier seulement)}\par
{\f1   ++   incrementation    ++i  i++}\par
{\f1   --   decrementation    --i  i--}\par
\par
\par
\b 6.2 Operateurs relationnels et logiques \b0\par
\par
{\f1   ==  !=                 egalite, difference}\par
{\f1   <   >   <=   >=        comparaisons}\par
{\f1   &&  ||  !              ET / OU / NON logiques (court-circuit)}\par
\par
Les operandes "true" valent != 0. Les operateurs renvoient 0 ou 1.\par
\par
\par
\b 6.3 Operateurs bit a bit \b0\par
\par
{\f1   &   ET binaire           a & b}\par
{\f1   |   OU binaire           a | b}\par
{\f1   ^   OU exclusif binaire  a ^ b}\par
{\f1   ~   complement a 1       ~a}\par
{\f1   <<  decalage gauche      a << n}\par
{\f1   >>  decalage droite      a >> n  (arith. si signe)}\par
\par
\par
\b 6.4 Operateurs d'affectation \b0\par
\par
{\f1   =                  affectation simple}\par
{\f1   +=  -=  *=  /=  %=}\par
{\f1   &=  |=  ^=  <<=  >>=}\par
\par
{\f1   Exemple : a += 5;  /* equivalent a a = a + 5 */}\par
\par
\par
\b 6.5 Operateurs particuliers \b0\par
\par
{\f1   ?:           conditionnel ternaire}\par
{\f1                cond ? expr_si_vrai : expr_si_faux}\par
{\f1   ,            sequence d'expressions}\par
{\f1   sizeof       taille en octets    sizeof(int)  sizeof x}\par
{\f1   &  *         adresse / dereferencement}\par
{\f1   .   ->       acces membre struct (valeur / pointeur)}\par
{\f1   []           indexation tableau}\par
{\f1   ()           appel de fonction}\par
\par
\par
\b 6.6 Precedence des operateurs (la plus haute en premier) \b0\par
\par
{\f1    1.  ()  []  ->  .                           gauche-droite}\par
{\f1    2.  !  ~  ++  --  +(unaire)  -(unaire)}\par
{\f1        (cast)  *  &  sizeof                    droite-gauche}\par
{\f1    3.  *  /  %                                 gauche-droite}\par
{\f1    4.  +  -                                    gauche-droite}\par
{\f1    5.  <<  >>                                  gauche-droite}\par
{\f1    6.  <  <=  >  >=                            gauche-droite}\par
{\f1    7.  ==  !=                                  gauche-droite}\par
{\f1    8.  &                                       gauche-droite}\par
{\f1    9.  ^                                       gauche-droite}\par
{\f1   10.  |                                       gauche-droite}\par
{\f1   11.  &&                                      gauche-droite}\par
{\f1   12.  ||                                      gauche-droite}\par
{\f1   13.  ?:                                      droite-gauche}\par
{\f1   14.  =  +=  -=  *=  /=  %=  &=  ...          droite-gauche}\par
{\f1   15.  ,                                       gauche-droite}\par
\par
\par
\par
