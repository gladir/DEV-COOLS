{\f1   Retour      : partie fractionnaire de meme signe que x.}\par
{\f1   Exemple     :}\par
{\f1                 double i, f = modf(3.75, &i);  /* i=3.0 f=0.75 */}\par
\par
pow\par
{\f1   Description : Puissance x^y.}\par
{\f1   Syntaxe     : double pow(double x, double y);}\par
{\f1   Parametres  : x - base. y - exposant.}\par
{\f1   Retour      : x^y. Erreur si x<0 et y non entier.}\par
{\f1   Exemple     : pow(2.0, 10.0)  /* 1024.0 */}\par
\par
sin\par
{\f1   Description : Sinus de x en radians.}\par
{\f1   Syntaxe     : double sin(double x);}\par
{\f1   Parametres  : x - angle en radians.}\par
{\f1   Retour      : valeur dans [-1, 1].}\par
