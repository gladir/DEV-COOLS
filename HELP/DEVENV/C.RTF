\par
tan\par
{\f1   Description : Tangente de x en radians.}\par
{\f1   Syntaxe     : double tan(double x);}\par
{\f1   Parametres  : x - angle en radians.}\par
{\f1   Retour      : tan(x).}\par
{\f1   Exemple     : tan(0.0)  /* 0.0 */}\par
\par
tanh\par
{\f1   Description : Tangente hyperbolique de x.}\par
{\f1   Syntaxe     : double tanh(double x);}\par
{\f1   Parametres  : x - valeur reelle.}\par
{\f1   Retour      : tanh(x) dans (-1, 1).}\par
{\f1   Exemple     : tanh(0.0)  /* 0.0 */}\par
