\b 25.5 <setjmp.h> \b0\par
\par
setjmp\par
{\f1   Description : Sauvegarde l'environnement d'execution (pile,}\par
{\f1                 registres) pour un saut non local ulterieur.}\par
{\f1   Syntaxe     : int setjmp(jmp_buf env);}\par
{\f1   Parametres  : env - tampon de sauvegarde.}\par
{\f1   Retour      : 0 au premier appel ; non zero si revenu par}\par
{\f1                 longjmp.}\par
{\f1   Exemple     :}\par
{\f1                 jmp_buf buf;}\par
{\f1                 if (setjmp(buf) == 0) \{}\par
{\f1                     /* code normal */}\par
{\f1                     longjmp(buf, 1);}\par
{\f1                 \} else \{}\par
{\f1                     /* gestion d'erreur */}\par
{\f1                 \}}\par
\par
longjmp\par
{\f1   Description : Saut non local au point d'un setjmp precedent.}\par
{\f1   Syntaxe     : void longjmp(jmp_buf env, int val);}\par
{\f1   Parametres  : env - environnement sauvegarde par setjmp.}\par
{\f1                 val - valeur retournee par setjmp (>=1).}\par
{\f1   Retour      : ne revient pas.}\par
{\f1   Exemple     : longjmp(buf, 1);}\par
\par
