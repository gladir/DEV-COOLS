{\f1   ssize_t write(int fd, const void *buf, size_t n);}\par
{\f1   off_t lseek(int fd, off_t ofs, int whence);}\par
\par
Descripteurs predefinis :\par
\par
{\f1   0    STDIN_FILENO}\par
{\f1   1    STDOUT_FILENO}\par
{\f1   2    STDERR_FILENO}\par
\par
\par
\par
