{\footnote # IDH_MODULA2_04}
{\footnote $ Modula-2 - TYPES DE DONNEES}
{\footnote K Modula-2 types donnees;BOOLEAN;CHAR;INTEGER;CARDINAL;LONGINT;LONGREAL;BITSET;ARRAY;RECORD;variantes;POINTER;SET;types procedure;tableaux ouverts}
\b\fs24 TYPES DE DONNEES \b0\fs20\par
\par
\par
\b 4.1 Types simples standard \b0\par
\par
{\f1   Type        Description              Taille typique}\par
{\f1   ----        -----------              --------------}\par
{\f1   BOOLEAN     TRUE / FALSE             1}\par
{\f1   CHAR        caractere                1}\par
{\f1   INTEGER     entier signe             2 ou 4}\par
{\f1   CARDINAL    entier NON SIGNE         2 ou 4}\par
{\f1   LONGINT     entier signe long        4 ou 8}\par
{\f1   LONGCARD    entier non signe long    4 ou 8}\par
{\f1   REAL        flottant simple          4}\par
{\f1   LONGREAL    flottant double          8}\par
{\f1   BITSET      ensemble de bits 0..N-1  2 ou 4}\par
\par
\par
\b 4.2 Types enumeres \b0\par
\par
{\f1   TYPE Couleur = (Rouge, Vert, Bleu, Jaune);}\par
{\f1   TYPE Jour = (Lundi, Mardi, Mercredi, Jeudi,}\par
{\f1                Vendredi, Samedi, Dimanche);}\par
\par
Operations : ORD, VAL, INC, DEC.\par
\par
\par
\b 4.3 Sous-intervalles \b0\par
\par
{\f1   TYPE Note = [0..20];}\par
{\f1   TYPE Lettre = ['A'..'Z'];}\par
{\f1   TYPE Travail = [Lundi..Vendredi];}\par
\par
\par
\b 4.4 Tableaux : ARRAY \b0\par
\par
{\f1   TYPE Vecteur = ARRAY [0..99] OF REAL;}\par
{\f1   TYPE Matrice = ARRAY [1..10], [1..10] OF REAL;}\par
{\f1   TYPE String = ARRAY [0..255] OF CHAR;}\par
\par
\par
\b 4.5 Enregistrements : RECORD \b0\par
\par
{\f1   TYPE Date = RECORD}\par
{\f1     annee: CARDINAL;}\par
{\f1     mois: [1..12];}\par
{\f1     jour: [1..31]}\par
{\f1   END;}\par
\par
Avec variantes (union discriminee) :\par
\par
{\f1   TYPE Forme = RECORD}\par
{\f1     CASE genre: (cercle, rectangle) OF}\par
{\f1       cercle: rayon: REAL}\par
{\f1       |}\par
{\f1       rectangle: largeur, hauteur: REAL}\par
{\f1     END}\par
{\f1   END;}\par
\par
\par
\b 4.6 Ensembles : SET \b0\par
\par
{\f1   TYPE Ensemble = SET OF [0..31];}\par
{\f1   TYPE Petits = SET OF Couleur;}\par
\par
Le type predefini BITSET = SET OF [0..15] (ou 31).\par
\par
\par
\b 4.7 Pointeurs : POINTER TO \b0\par
\par
{\f1   TYPE PNoeud = POINTER TO Noeud;}\par
{\f1   TYPE Noeud = RECORD}\par
{\f1     val: INTEGER;}\par
{\f1     suiv: PNoeud}\par
{\f1   END;}\par
\par
Allocation/liberation explicite via ALLOCATE/DEALLOCATE\par
(module Storage).\par
\par
\par
\b 4.8 Types procedure \b0\par
\par
{\f1   TYPE Callback = PROCEDURE(CARDINAL): BOOLEAN;}\par
{\f1   VAR f: Callback;}\par
\par
Une variable f peut contenir une procedure de signature\par
compatible.\par
\par
\par
\b 4.9 Tableaux ouverts (parametres) \b0\par
\par
{\f1   PROCEDURE Somme(VAR v: ARRAY OF INTEGER): INTEGER;}\par
\par
Le nombre d'elements s'obtient via HIGH(v) (dernier indice).\par
\par
\par
\par
