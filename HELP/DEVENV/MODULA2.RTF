{\footnote # IDH_MODULA2_16}
{\footnote $ Modula-2 - CONVERTISSEURS DU PROJET}
{\footnote K Modula-2 convertisseurs;ADA2MOD2.PAS;PAS2MOD2.PAS;Ada vers Modula-2;Pascal vers Modula-2}
\b\fs24 CONVERTISSEURS DU PROJET \b0\fs20\par
\par
\par
\b 16.1 ADA2MOD2.PAS - Ada vers Modula-2 \b0\par
\par
Convertit Ada (sous-ensemble) vers Modula-2 :\par
\par
{\f1   - package -> DEFINITION MODULE}\par
{\f1   - package body -> IMPLEMENTATION MODULE}\par
{\f1   - procedure/function -> PROCEDURE}\par
{\f1   - record -> RECORD}\par
{\f1   - if/elsif/else -> IF/ELSIF/ELSE}\par
\par
\par
\b 16.2 PAS2MOD2.PAS - Pascal vers Modula-2 \b0\par
\par
Convertit Turbo Pascal (sous-ensemble) vers Modula-2 :\par
\par
{\f1   - unit -> DEFINITION + IMPLEMENTATION MODULE}\par
{\f1   - program -> MODULE}\par
{\f1   - var/const/type -> VAR/CONST/TYPE}\par
{\f1   - begin/end -> BEGIN/END}\par
{\f1   - := identique}\par
{\f1   - writeln -> WriteString + WriteLn}\par
\par
\par
\par
