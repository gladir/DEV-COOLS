{\footnote # IDH_MODULA2_07}
{\footnote $ Modula-2 - STRUCTURES DE CONTROLE}
{\footnote K Modula-2 structures controle;IF;ELSIF;CASE;WHILE;REPEAT;FOR;BY;LOOP;EXIT;WITH;RETURN}
\b\fs24 STRUCTURES DE CONTROLE \b0\fs20\par
\par
\par
\b 7.1 Selection : IF \b0\par
\par
{\f1   IF condition THEN}\par
{\f1     instructions}\par
{\f1   ELSIF condition2 THEN}\par
{\f1     instructions}\par
{\f1   ELSE}\par
{\f1     instructions}\par
{\f1   END}\par
\par
\par
\b 7.2 Selection : CASE \b0\par
\par
{\f1   CASE expression OF}\par
{\f1     val1: instructions |}\par
{\f1     val2, val3: instructions |}\par
{\f1     a..b: instructions}\par
{\f1   ELSE}\par
{\f1     instructions}\par
{\f1   END}\par
\par
\par
\b 7.3 Iteration : WHILE \b0\par
\par
{\f1   WHILE condition DO}\par
{\f1     instructions}\par
{\f1   END}\par
\par
\par
\b 7.4 Iteration : REPEAT \b0\par
\par
{\f1   REPEAT}\par
{\f1     instructions}\par
{\f1   UNTIL condition}\par
\par
\par
\b 7.5 Iteration : FOR \b0\par
\par
{\f1   FOR i := init TO fin DO}\par
{\f1     instructions}\par
{\f1   END}\par
\par
{\f1   FOR i := init TO fin BY pas DO}\par
{\f1     instructions}\par
{\f1   END}\par
\par
\par
\b 7.6 Boucle infinie : LOOP / EXIT \b0\par
\par
{\f1   LOOP}\par
{\f1     instructions;}\par
{\f1     IF condition THEN EXIT END;}\par
{\f1     autres instructions}\par
{\f1   END}\par
\par
EXIT sort de la boucle LOOP la plus interne.\par
\par
\par
\b 7.7 WITH \b0\par
\par
Acces simplifie aux champs d'un RECORD :\par
\par
{\f1   WITH personne DO}\par
{\f1     nom := "Jean";}\par
{\f1     age := 42}\par
{\f1   END}\par
\par
\par
\b 7.8 RETURN \b0\par
\par
{\f1   RETURN              (* dans procedure sans valeur *)}\par
{\f1   RETURN expression   (* dans fonction *)}\par
\par
\par
\par
