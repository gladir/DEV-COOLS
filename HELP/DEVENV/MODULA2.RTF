{\footnote # IDH_MODULA2_15}
{\footnote $ Modula-2 - COMPILATEUR DU PROJET (MODII86.PAS)}
{\footnote K Modula-2 compilateur projet;MODII86.PAS;MS-DOS;assembleur 8086;MASM;modele SMALL}
\b\fs24 COMPILATEUR DU PROJET (MODII86.PAS) \b0\fs20\par
\par
MODII86.PAS - Compilateur Modula-2 vers assembleur 8086\par
\par
{\f1   Cible             : MS-DOS, assembleur MASM .MODEL SMALL}\par
{\f1   Modele memoire    : SMALL (code 64KO, donnees 64KO)}\par
{\f1   Dialecte          : Modula-2 PIM-4 (sous-ensemble)}\par
{\f1   Sortie            : fichier .ASM, assemblable avec MASM}\par
\par
{\f1   Fonctionnalites :}\par
{\f1     - Modules DEFINITION et IMPLEMENTATION}\par
{\f1     - Types BOOLEAN, CHAR, INTEGER, CARDINAL, REAL}\par
{\f1     - ARRAY (fixe et ouvert), RECORD, POINTER, SET}\par
{\f1     - Procedures et fonctions}\par
{\f1     - Structures IF, CASE, WHILE, REPEAT, FOR, LOOP/EXIT}\par
{\f1     - WITH, sous-intervalles, enumerations}\par
{\f1     - Importation FROM ... IMPORT, IMPORT ...}\par
{\f1     - Coroutines basiques (NEWPROCESS, TRANSFER)}\par
{\f1     - InOut, Storage, SYSTEM partiels}\par
\par
{\f1   Limitations :}\par
{\f1     - LONGINT/LONGREAL non supportes (32-bit non standard)}\par
{\f1     - Pas de generiques (extension ISO)}\par
{\f1     - Pas d'exceptions (extension ISO)}\par
{\f1     - Modules locaux non supportes}\par
\par
\par
\par
