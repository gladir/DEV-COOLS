{\footnote # IDH_MODULA2_17}
{\footnote $ Modula-2 - EXEMPLES}
{\footnote K Modula-2 exemples;Hello World;Factorielle;liste chainee;module pile;DEFINITION;IMPLEMENTATION}
\b\fs24 EXEMPLES \b0\fs20\par
\par
\par
\b 17.1 Hello, World! \b0\par
\par
{\f1   MODULE Hello;}\par
{\f1     FROM InOut IMPORT WriteString, WriteLn;}\par
{\f1   BEGIN}\par
{\f1     WriteString("Hello, World!"); WriteLn}\par
{\f1   END Hello.}\par
\par
\par
\b 17.2 Factorielle recursive \b0\par
\par
{\f1   MODULE Fact;}\par
{\f1     FROM InOut IMPORT WriteString, WriteCard, WriteLn;}\par
\par
{\f1     PROCEDURE Factorielle(n: CARDINAL): CARDINAL;}\par
{\f1     BEGIN}\par
{\f1       IF n <= 1 THEN RETURN 1}\par
{\f1       ELSE RETURN n * Factorielle(n - 1)}\par
{\f1       END}\par
{\f1     END Factorielle;}\par
\par
{\f1     VAR i: CARDINAL;}\par
{\f1   BEGIN}\par
{\f1     FOR i := 0 TO 10 DO}\par
{\f1       WriteCard(i, 3); WriteString(" -> ");}\par
{\f1       WriteCard(Factorielle(i), 8); WriteLn}\par
{\f1     END}\par
{\f1   END Fact.}\par
\par
\par
\b 17.3 Liste chainee \b0\par
\par
{\f1   MODULE Liste;}\par
{\f1     FROM Storage IMPORT ALLOCATE;}\par
{\f1     FROM InOut IMPORT WriteInt, WriteLn;}\par
\par
{\f1     TYPE}\par
{\f1       PNoeud = POINTER TO Noeud;}\par
{\f1       Noeud = RECORD}\par
{\f1         val: INTEGER;}\par
{\f1         suiv: PNoeud}\par
{\f1       END;}\par
\par
{\f1     VAR tete: PNoeud;}\par
\par
{\f1     PROCEDURE Ajouter(v: INTEGER);}\par
{\f1       VAR n: PNoeud;}\par
{\f1     BEGIN}\par
{\f1       NEW(n);}\par
{\f1       n^.val := v;}\par
{\f1       n^.suiv := tete;}\par
{\f1       tete := n}\par
{\f1     END Ajouter;}\par
\par
{\f1     PROCEDURE Afficher;}\par
{\f1       VAR p: PNoeud;}\par
{\f1     BEGIN}\par
{\f1       p := tete;}\par
{\f1       WHILE p # NIL DO}\par
{\f1         WriteInt(p^.val, 4);}\par
{\f1         p := p^.suiv}\par
{\f1       END;}\par
{\f1       WriteLn}\par
{\f1     END Afficher;}\par
\par
{\f1   BEGIN}\par
{\f1     tete := NIL;}\par
{\f1     Ajouter(1); Ajouter(2); Ajouter(3);}\par
{\f1     Afficher}\par
{\f1   END Liste.}\par
\par
\par
\b 17.4 Module de pile \b0\par
\par
{\f1   DEFINITION MODULE Pile;}\par
{\f1     EXPORT QUALIFIED Push, Pop, Empty;}\par
\par
{\f1     PROCEDURE Push(x: INTEGER);}\par
{\f1     PROCEDURE Pop(): INTEGER;}\par
{\f1     PROCEDURE Empty(): BOOLEAN;}\par
{\f1   END Pile.}\par
\par
{\f1   IMPLEMENTATION MODULE Pile;}\par
{\f1     VAR}\par
{\f1       data: ARRAY [0..99] OF INTEGER;}\par
{\f1       sp: CARDINAL;}\par
\par
{\f1     PROCEDURE Push(x: INTEGER);}\par
{\f1     BEGIN}\par
{\f1       data[sp] := x; INC(sp)}\par
{\f1     END Push;}\par
\par
{\f1     PROCEDURE Pop(): INTEGER;}\par
{\f1     BEGIN}\par
{\f1       DEC(sp); RETURN data[sp]}\par
{\f1     END Pop;}\par
\par
{\f1     PROCEDURE Empty(): BOOLEAN;}\par
{\f1     BEGIN}\par
{\f1       RETURN sp = 0}\par
{\f1     END Empty;}\par
\par
{\f1   BEGIN}\par
{\f1     sp := 0}\par
{\f1   END Pile.}\par
\par
\par
\par
