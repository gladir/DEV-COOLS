{\footnote # IDH_MODULA2_12}
{\footnote $ Modula-2 - PROCEDURES STANDARD}
{\footnote K Modula-2 procedures standard;ABS;CAP;CHR;ORD;ODD;INC;DEC;INCL;EXCL;HIGH;SIZE;NEW;DISPOSE;FLOAT;TRUNC;ROUND;HALT;ADR;TSIZE}
\b\fs24 PROCEDURES STANDARD \b0\fs20\par
\par
\par
\b 12.1 Procedures sur entiers \b0\par
\par
{\f1   ABS(x)        valeur absolue}\par
{\f1   CAP(c)        majuscule d'un CHAR}\par
{\f1   CHR(n)        caractere de code n}\par
{\f1   ORD(x)        valeur ordinale}\par
{\f1   ODD(x)        TRUE si impair}\par
{\f1   INC(x)        x := x + 1}\par
{\f1   INC(x, n)     x := x + n}\par
{\f1   DEC(x)        x := x - 1}\par
{\f1   DEC(x, n)     x := x - n}\par
\par
\par
\b 12.2 Procedures sur ensembles \b0\par
\par
{\f1   INCL(s, x)    ajoute x a s}\par
{\f1   EXCL(s, x)    retire x de s}\par
\par
\par
\b 12.3 Procedures sur tableaux \b0\par
\par
{\f1   HIGH(v)       dernier indice}\par
{\f1   SIZE(v)       taille en octets}\par
\par
\par
\b 12.4 Allocation \b0\par
\par
{\f1   NEW(p)        delegue a ALLOCATE}\par
{\f1   DISPOSE(p)    delegue a DEALLOCATE}\par
\par
\par
\b 12.5 Conversion \b0\par
\par
{\f1   CHR(n)        CARDINAL -> CHAR}\par
{\f1   ORD(x)        type -> CARDINAL}\par
{\f1   FLOAT(x)      INTEGER/CARDINAL -> REAL}\par
{\f1   TRUNC(x)      REAL -> CARDINAL (troncature)}\par
{\f1   ROUND(x)      REAL -> CARDINAL (arrondi)}\par
\par
\par
\b 12.6 Procedures HALT et fin \b0\par
\par
{\f1   HALT          termine le programme}\par
\par
\par
\b 12.7 Procedures du module SYSTEM \b0\par
\par
{\f1   ADR(x)        adresse de x}\par
{\f1   SIZE(T)       taille du type T}\par
{\f1   TSIZE(T)      taille du type T (variant size)}\par
{\f1   WORD          type "mot machine"}\par
{\f1   ADDRESS       type adresse}\par
\par
\par
\par
