{\footnote # IDH_MODULA2_18}
{\footnote $ Modula-2 - INFLUENCE}
{\footnote K Modula-2 influence;Oberon;Modula-3;Ada;Component Pascal;comparaison Pascal}
\b\fs24 INFLUENCE \b0\fs20\par
\par
Modula-2 a influence directement :\par
\par
{\f1   - Oberon (Wirth, 1988) - successeur direct}\par
{\f1   - Modula-3 (DEC SRC, 1988) - avec POO, exceptions, threads}\par
{\f1   - Ada (DoD, 1983) - emprunte certaines idees modulaires}\par
{\f1   - Component Pascal (Oberon Microsystems, 1997)}\par
\par
Comparaison Modula-2 / Pascal :\par
\par
{\f1   Aspect             Pascal              Modula-2}\par
{\f1   ------             ------              --------}\par
{\f1   Modularite         programme unique    modules separes}\par
{\f1   Sensibilite casse  non                 oui (mots-cles MAJ)}\par
{\f1   CARDINAL           non                 oui (entier unsigned)}\par
{\f1   Tableaux ouverts   non                 oui}\par
{\f1   Procedure type     non                 oui}\par
{\f1   Coroutines         non                 oui}\par
{\f1   Importation        uses (TP)           FROM/IMPORT}\par
{\f1   Hex/octal          $FF / non           0FFH / 377B}\par
{\f1   Caractere          'A', #65            'A', 41C}\par
{\f1   Different          <>                  # (ou <>)}\par
{\f1   Boucle infinie     non                 LOOP/EXIT}\par
\par
\par
\par
