{\footnote # IDH_MODULA2_05}
{\footnote $ Modula-2 - DECLARATIONS}
{\footnote K Modula-2 declarations;CONST;TYPE;VAR;ordre declarations}
\b\fs24 DECLARATIONS \b0\fs20\par
\par
Ordre obligatoire dans un module ou une procedure :\par
\par
{\f1   CONST      declarations de constantes}\par
{\f1   TYPE       declarations de types}\par
{\f1   VAR        declarations de variables}\par
{\f1   PROCEDURE  declarations de procedures}\par
{\f1   MODULE     modules locaux (rares)}\par
\par
\par
\b 5.1 Constantes : CONST \b0\par
\par
{\f1   CONST}\par
{\f1     PI = 3.14159;}\par
{\f1     MAX = 1000;}\par
{\f1     LF = 12C;            (* caractere de code octal 12 *)}\par
{\f1     BORNE = MAX - 1;}\par
\par
\par
\b 5.2 Types : TYPE \b0\par
\par
{\f1   TYPE}\par
{\f1     Compteur = CARDINAL;}\par
{\f1     Nom = ARRAY [0..31] OF CHAR;}\par
{\f1     PListe = POINTER TO Noeud;}\par
{\f1     Noeud = RECORD}\par
{\f1       val: INTEGER;}\par
{\f1       suiv: PListe}\par
{\f1     END;}\par
\par
\par
\b 5.3 Variables : VAR \b0\par
\par
{\f1   VAR}\par
{\f1     x, y: INTEGER;}\par
{\f1     nom: Nom;}\par
{\f1     tete: PListe;}\par
\par
\par
\par
