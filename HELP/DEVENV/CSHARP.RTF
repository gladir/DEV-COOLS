{\footnote # IDH_CSHARP_10}
{\footnote $ C# - Delegates, evenements et lambdas}
{\footnote K C# delegates evenements lambdas;delegate;Func Action Predicate;event;EventHandler;lambda expression}
\b\fs24 Delegates, evenements et lambdas \b0\fs20\par
\par
Delegate :\par
{\f1   public delegate int Operation(int a, int b);}\par
{\f1   Operation add = (a, b) => a + b;}\par
{\f1   int r = add(2, 3);}\par
\par
Func<>, Action<>, Predicate<> :\par
{\f1   Func<int, int, int> mul = (a, b) => a * b;}\par
{\f1   Action<string> log = s => Console.WriteLine(s);}\par
{\f1   Predicate<int> pair = n => n % 2 == 0;}\par
\par
Lambdas :\par
{\f1   x => x * 2}\par
{\f1   (x, y) => x + y}\par
{\f1   (int x) => \{ return x * 2; \}}\par
{\f1   static (x, y) => x + y       // C# 9+ static lambda}\par
\par
Evenements :\par
{\f1   public class Bouton \{}\par
{\f1     public event EventHandler? Clic;}\par
{\f1     protected virtual void OnClic() => Clic?.Invoke(this, EventArgs.Empty);}\par
{\f1   \}}\par
{\f1   bouton.Clic += (s, e) => Console.WriteLine("clique");}\par
\par
\par
