{\footnote # IDH_CSHARP_14}
{\footnote $ C# - Gestion de la memoire et bas niveau}
{\footnote K C# memoire bas niveau;Garbage Collector;IDisposable;unsafe;pointeurs;stackalloc;Span Memory;ref in out}
\b\fs24 Gestion de la memoire et bas niveau \b0\fs20\par
\par
Garbage Collector : generationnel (Gen 0/1/2, LOH), pas de delete explicite.\par
IDisposable + using pour ressources non managees.\par
\par
Mode unsafe (pointeurs) :\par
{\f1   unsafe void Inverser(int* p, int n) \{}\par
{\f1     for (int i = 0, j = n - 1; i < j; i++, j--) \{}\par
{\f1       (p[i], p[j]) = (p[j], p[i]);}\par
{\f1     \}}\par
{\f1   \}}\par
\par
stackalloc :\par
{\f1   Span<int> buf = stackalloc int[256];}\par
\par
Span<T> et Memory<T> (C# 7.2+) : acces zero-copy a des tableaux/chaines.\par
{\f1   ReadOnlySpan<char> s = "Bonjour".AsSpan();}\par
{\f1   ReadOnlySpan<char> deb = s[..3];   // "Bon"}\par
\par
ref / in / out :\par
{\f1   void Echange(ref int a, ref int b) \{ (a, b) = (b, a); \}}\par
{\f1   int Calculer(in BigStruct s) \{ ... \}      // C# 7.2+ ref readonly}\par
{\f1   bool TryParse(string s, out int r) \{ ... \}}\par
\par
\par
