{\footnote # IDH_CSHARP_06}
{\footnote $ C# - Instructions de controle}
{\footnote K C# controle;if else;switch;switch expression;pattern matching;while do for foreach;break continue return goto;try catch finally;using;lock;checked unchecked;yield}
\b\fs24 Instructions de controle \b0\fs20\par
\par
if/else :\par
{\f1   if (x > 0) \{ ... \} else if (x == 0) \{ ... \} else \{ ... \}}\par
\par
switch (instruction) :\par
{\f1   switch (jour) \{}\par
{\f1     case "Lun":}\par
{\f1     case "Mar": Console.WriteLine("Semaine"); break;}\par
{\f1     case "Sam":}\par
{\f1     case "Dim": Console.WriteLine("WE"); break;}\par
{\f1     default: throw new ArgumentException(); }\par
{\f1   \}}\par
\par
switch expression (C# 8+) :\par
{\f1   string nom = code switch \{}\par
{\f1     1 => "Un", 2 => "Deux", _ => "Autre"}\par
{\f1   \};}\par
\par
Pattern matching (C# 7+, etendu en 8/9/10/11) :\par
{\f1   if (obj is string s && s.Length > 0) \{ ... \}}\par
{\f1   if (p is \{ Age: > 18, Nom: not null \}) \{ ... \}}\par
{\f1   var msg = shape switch \{}\par
{\f1     Circle \{ Radius: > 0 \} c => $"Cercle r=\{c.Radius\}",}\par
{\f1     Square s when s.Side > 0 => $"Carre \{s.Side\}",}\par
{\f1     _ => "Inconnu"}\par
{\f1   \};}\par
\par
while / do-while :\par
{\f1   while (cond) \{ ... \}}\par
{\f1   do \{ ... \} while (cond);}\par
\par
for :\par
{\f1   for (int i = 0; i < n; i++) \{ ... \}}\par
\par
foreach :\par
{\f1   foreach (var item in collection) \{ ... \}}\par
\par
break / continue / return / goto :\par
{\f1   for (...) \{ if (cond) break; if (cond2) continue; \}}\par
{\f1   goto label; label: ...}\par
\par
throw / try / catch / finally :\par
{\f1   try \{}\par
{\f1     ...}\par
{\f1   \} catch (FileNotFoundException ex) \{}\par
{\f1     ...}\par
{\f1   \} catch (Exception ex) when (ex.Message.Length > 0) \{}\par
{\f1     ...}\par
{\f1   \} finally \{}\par
{\f1     ...}\par
{\f1   \}}\par
\par
using (gestion deterministe IDisposable) :\par
{\f1   using (var f = File.OpenRead("a.txt")) \{ ... \}}\par
{\f1   using var f = File.OpenRead("a.txt");  // C# 8+ using declaration}\par
\par
lock :\par
{\f1   lock (objetVerrou) \{ /* section critique */ \}}\par
\par
checked / unchecked :\par
{\f1   int r = checked(a * b);          // leve OverflowException}\par
{\f1   int r = unchecked(a * b);        // wrap silencieux}\par
\par
yield (iterators, C# 2+) :\par
{\f1   IEnumerable<int> Pairs(int n) \{}\par
{\f1     for (int i = 0; i < n; i += 2) yield return i;}\par
{\f1   \}}\par
\par
\par
\par
