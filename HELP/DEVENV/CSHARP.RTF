{\footnote # IDH_CSHARP_02}
{\footnote $ C# - Structure d'un programme C#}
{\footnote K C# structure programme;namespace;Main;using;top-level statements;file-scoped namespace;global using}
\b\fs24 Structure d'un programme C# \b0\fs20\par
\par
Programme classique :\par
\par
{\f1   using System;}\par
\par
{\f1   namespace MonProgramme}\par
{\f1   \{}\par
{\f1       class Program}\par
{\f1       \{}\par
{\f1           static void Main(string[] args)}\par
{\f1           \{}\par
{\f1               Console.WriteLine("Bonjour le monde");}\par
{\f1           \}}\par
{\f1       \}}\par
{\f1   \}}\par
\par
Top-level statements (C# 9+) :\par
\par
{\f1   using System;}\par
{\f1   Console.WriteLine("Bonjour le monde");}\par
\par
File-scoped namespace (C# 10+) :\par
\par
{\f1   namespace MonProgramme;}\par
\par
{\f1   class Program \{ ... \}}\par
\par
Global using (C# 10+) :\par
\par
{\f1   global using System;}\par
{\f1   global using System.Collections.Generic;}\par
\par
\par
\par
