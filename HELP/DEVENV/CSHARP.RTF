{\footnote # IDH_CSHARP_17}
{\footnote $ C# - Exemples de programmes}
{\footnote K C# exemples;Hello;factorielle;fichier;LINQ;async parallele;records pattern matching}
\b\fs24 Exemples de programmes \b0\fs20\par
\par
17.1 Hello World\par
\par
{\f1   using System;}\par
{\f1   Console.WriteLine("Bonjour le monde");}\par
\par
17.2 Factorielle recursive\par
\par
{\f1   static long Fact(int n) => n <= 1 ? 1 : n * Fact(n - 1);}\par
{\f1   Console.WriteLine(Fact(10));   // 3628800}\par
\par
17.3 Lecture/ecriture de fichier\par
\par
{\f1   using System.IO;}\par
{\f1   var lignes = File.ReadAllLines("entree.txt");}\par
{\f1   File.WriteAllLines("sortie.txt", lignes.Reverse());}\par
\par
17.4 LINQ : top 3 mots les plus frequents\par
\par
{\f1   var freq = File.ReadAllText("texte.txt")}\par
{\f1     .Split(new[] \{ ' ', '\\n', '\\r' \}, StringSplitOptions.RemoveEmptyEntries)}\par
{\f1     .GroupBy(w => w.ToLower())}\par
{\f1     .OrderByDescending(g => g.Count())}\par
{\f1     .Take(3)}\par
{\f1     .Select(g => $"\{g.Key\} : \{g.Count()\}");}\par
{\f1   foreach (var s in freq) Console.WriteLine(s);}\par
\par
17.5 Async : telechargements paralleles\par
\par
{\f1   using System.Net.Http;}\par
{\f1   static async Task Main() \{}\par
{\f1     var urls = new[] \{ "https://a.org", "https://b.org" \};}\par
{\f1     using var client = new HttpClient();}\par
{\f1     var taches = urls.Select(u => client.GetStringAsync(u));}\par
{\f1     var res = await Task.WhenAll(taches);}\par
{\f1     foreach (var s in res) Console.WriteLine(s.Length);}\par
{\f1   \}}\par
\par
17.6 Record et pattern matching\par
\par
{\f1   public record Forme;}\par
{\f1   public record Cercle(double Rayon) : Forme;}\par
{\f1   public record Rectangle(double L, double H) : Forme;}\par
\par
{\f1   static double Aire(Forme f) => f switch \{}\par
{\f1     Cercle c => Math.PI * c.Rayon * c.Rayon,}\par
{\f1     Rectangle r => r.L * r.H,}\par
{\f1     _ => 0}\par
{\f1   \};}\par
\par
\par
\par
