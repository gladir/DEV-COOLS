{\footnote # IDH_TPPRT_06}
{\footnote $ Unite Printer - EXEMPLES}
{\footnote K Turbo Pascal;Unite Printer;EXEMPLES}
\b\fs24 EXEMPLES \b0\fs20\par
\par
{\f1   --- Exemple 1 : Impression simple ---}\par
\par
{\f1   program ImprimerTexte;}\par
{\f1   uses Printer;}\par
{\f1   begin}\par
{\f1     WriteLn(Lst, 'Bonjour depuis Turbo Pascal !');}\par
{\f1     WriteLn(Lst, '============================');}\par
{\f1     WriteLn(Lst);}\par
{\f1     WriteLn(Lst, 'Date : ', Date);}\par
{\f1     Write(Lst, #12);  \{ ??jecter la page \}}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : Impression d'un tableau ---}\par
\par
{\f1   program ImprimerTableau;}\par
{\f1   uses Printer;}\par
{\f1   var}\par
{\f1     I : Integer;}\par
{\f1   begin}\par
{\f1     WriteLn(Lst, '  N    N??     N??');}\par
{\f1     WriteLn(Lst, '---  -----  ------');}\par
{\f1     for I := 1 to 20 do}\par
{\f1       WriteLn(Lst, I:3, I*I:7, I*I*I:8);}\par
{\f1     Write(Lst, #12);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Impression d'un fichier texte ---}\par
\par
{\f1   program ImprimerFichier;}\par
{\f1   uses Printer;}\par
{\f1   var}\par
{\f1     F    : Text;}\par
{\f1     Line : String;}\par
{\f1     Page : Integer;}\par
{\f1     Num  : Integer;}\par
{\f1   begin}\par
{\f1     Assign(F, ParamStr(1));}\par
{\f1     \{$I-\}}\par
{\f1     Reset(F);}\par
{\f1     \{$I+\}}\par
{\f1     if IOResult <> 0 then}\par
{\f1     begin}\par
{\f1       WriteLn('Fichier non trouv?? : ', ParamStr(1));}\par
{\f1       Halt(1);}\par
{\f1     end;}\par
\par
{\f1     Page := 1;}\par
{\f1     Num := 0;}\par
{\f1     WriteLn(Lst, 'Fichier : ', ParamStr(1),}\par
{\f1             '  Page ', Page);}\par
{\f1     WriteLn(Lst, '----------------------------------------');}\par
\par
{\f1     while not Eof(F) do}\par
{\f1     begin}\par
{\f1       ReadLn(F, Line);}\par
{\f1       Inc(Num);}\par
{\f1       WriteLn(Lst, Num:4, ' | ', Line);}\par
{\f1       if Num mod 60 = 0 then}\par
{\f1       begin}\par
{\f1         Write(Lst, #12);  \{ saut de page \}}\par
{\f1         Inc(Page);}\par
{\f1         WriteLn(Lst, 'Fichier : ', ParamStr(1),}\par
{\f1                 '  Page ', Page);}\par
{\f1         WriteLn(Lst, '-------------------------------');}\par
{\f1       end;}\par
{\f1     end;}\par
\par
{\f1     Write(Lst, #12);  \{ ??jecter derni??re page \}}\par
{\f1     Close(F);}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 4 : Gestion d'erreur d'impression ---}\par
\par
{\f1   program SafePrint;}\par
{\f1   uses Printer;}\par
\par
{\f1     function PrinterReady : Boolean;}\par
{\f1     begin}\par
{\f1       \{$I-\}}\par
{\f1       Write(Lst, '');}\par
{\f1       PrinterReady := (IOResult = 0);}\par
{\f1       \{$I+\}}\par
{\f1     end;}\par
\par
{\f1   begin}\par
{\f1     if not PrinterReady then}\par
{\f1     begin}\par
{\f1       WriteLn('Imprimante non pr??te !');}\par
{\f1       WriteLn('V??rifiez la connexion et l''alimentation.');}\par
{\f1       Halt(1);}\par
{\f1     end;}\par
\par
{\f1     WriteLn(Lst, 'Impression r??ussie.');}\par
{\f1     Write(Lst, #12);}\par
{\f1   end.}\par
\par
\par
