{\footnote # IDH_TPPRT_05}
{\footnote $ Unite Printer - CARACT??RES DE CONTR??LE COURANTS}
{\footnote K Turbo Pascal;Unite Printer;CARACT??RES DE CONTR??LE COURANTS}
\b\fs24 CARACT??RES DE CONTR??LE COURANTS \b0\fs20\par
\par
{\f1   Les codes de contr??le suivants sont fr??quemment envoy??s ??}\par
{\f1   l'imprimante via Lst :}\par
\par
{\f1   Code   Valeur   Description}\par
{\f1   ----   ------   ------------------------------------------}\par
{\f1   BEL      #7     Signal sonore (certaines imprimantes)}\par
{\f1   BS       #8     Retour arri??re (backspace)}\par
{\f1   HT       #9     Tabulation horizontale}\par
{\f1   LF      #10     Saut de ligne (line feed)}\par
{\f1   FF      #12     Saut de page (form feed)}\par
{\f1   CR      #13     Retour chariot (carriage return)}\par
{\f1   ESC     #27     D??but de s??quence d'??chappement}\par
\par
{\f1   Les s??quences d'??chappement (ESC + commande) d??pendent du}\par
{\f1   mod??le d'imprimante. Exemples courants (Epson/compatible) :}\par
\par
{\f1     Write(Lst, #27, 'E');          \{ gras activ?? \}}\par
{\f1     Write(Lst, #27, 'F');          \{ gras d??sactiv?? \}}\par
{\f1     Write(Lst, #27, '0');          \{ interligne 1/8 pouce \}}\par
{\f1     Write(Lst, #27, '2');          \{ interligne 1/6 pouce \}}\par
{\f1     Write(Lst, #27, #15);         \{ mode condens?? \}}\par
\par
\par
