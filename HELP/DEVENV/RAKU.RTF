{\footnote # IDH_RAKU_05}
{\footnote $ Raku - Operateurs}
{\footnote K Raku operateurs;arithmetiques;comparaison;logiques;binaires;chaines;tableau}
\b\fs24 Operateurs \b0\fs20\par
\par
\par
\b 5.1 Operateurs arithmetiques \b0\par
\par
{\f1   +     Addition            (ADD AX, BX)}\par
{\f1   -     Soustraction        (SUB AX, BX)}\par
{\f1   *     Multiplication      (IMUL BX)}\par
{\f1   /     Division            (CWD / IDIV BX, quotient AX)}\par
{\f1   div   Division entiere    (IDIV, quotient AX)}\par
{\f1   mod   Modulo              (IDIV, reste DX)}\par
{\f1   %%    Test de divisibilite (DX == 0 apres IDIV)}\par
\par
\par
\b 5.2 Operateurs de chaine \b0\par
\par
{\f1   ~     Concatenation   (CALL _RKRT_CONCAT)}\par
{\f1   x     Repetition      (CALL _RKRT_REPEAT)}\par
\par
\par
\b 5.3 Operateurs de comparaison numerique \b0\par
\par
{\f1   ==    Egalite             (CMP + JE)}\par
{\f1   !=    Inegalite           (CMP + JNE)}\par
{\f1   <     Inferieur strict    (CMP + JL)}\par
{\f1   <=    Inferieur ou egal   (CMP + JLE)}\par
{\f1   >     Superieur strict    (CMP + JG)}\par
{\f1   >=    Superieur ou egal   (CMP + JGE)}\par
{\f1   <=>   Comparaison tri     (resultat -1, 0 ou 1)}\par
\par
\par
\b 5.4 Operateurs de comparaison de chaine \b0\par
\par
{\f1   eq    Egalite de chaine     (CALL _RKRT_STRCMP + JE)}\par
{\f1   ne    Inegalite de chaine   (CALL _RKRT_STRCMP + JNE)}\par
{\f1   lt    Inferieur lexical     (CALL _RKRT_STRCMP + JL)}\par
{\f1   le    Inf. ou egal lexical  (CALL _RKRT_STRCMP + JLE)}\par
{\f1   gt    Superieur lexical     (CALL _RKRT_STRCMP + JG)}\par
{\f1   ge    Sup. ou egal lexical  (CALL _RKRT_STRCMP + JGE)}\par
{\f1   leg   Comparaison lexicale  (resultat -1, 0 ou 1)}\par
{\f1   cmp   Comparaison generique (alias de leg)}\par
\par
\par
\b 5.5 Operateurs logiques \b0\par
\par
{\f1   &&    ET logique (court-circuit : JZ vers false)}\par
{\f1   ||    OU logique (court-circuit : JNZ vers true)}\par
{\f1   !     Negation logique (prefixe)}\par
{\f1   //    Defini-ou (short-circuit si defini)}\par
{\f1   and   ET basse precedence}\par
{\f1   or    OU basse precedence}\par
{\f1   not   Negation basse precedence}\par
\par
\par
\b 5.6 Operateurs d affectation \b0\par
\par
{\f1   =     Affectation simple}\par
{\f1   :=    Binding (aliasing)}\par
{\f1   +=    Addition-affectation}\par
{\f1   -=    Soustraction-affectation}\par
{\f1   *=    Multiplication-affectation}\par
{\f1   /=    Division-affectation}\par
{\f1   ~=    Concatenation-affectation}\par
{\f1   x=    Repetition-affectation}\par
\par
\par
\b 5.7 Operateurs unaires \b0\par
\par
{\f1   +$x   Contexte numerique}\par
{\f1   -$x   Negation (NEG AX)}\par
{\f1   !$x   Negation logique (NOT, booleen)}\par
{\f1   ?$x   Contexte booleen}\par
{\f1   ~$x   Contexte chaine}\par
{\f1   so $x Equivalent de ?$x}\par
\par
\par
\b 5.8 Increment / Decrement \b0\par
\par
{\f1   ++$x   Pre-increment}\par
{\f1   $x++   Post-increment}\par
{\f1   --$x   Pre-decrement}\par
{\f1   $x--   Post-decrement}\par
\par
\par
\b 5.9 Operateurs d intervalle \b0\par
\par
{\f1   ..     Intervalle inclusif (1..10)}\par
{\f1   ..^    Exclusif a droite (1..^10 = 1 a 9)}\par
{\f1   ^..    Exclusif a gauche (1^..10 = 2 a 10)}\par
{\f1   ^..^   Exclusif des deux cotes}\par
\par
\par
\b 5.10 Operateur ternaire \b0\par
\par
{\f1   $cond ?? $vrai !! $faux}\par
Equivalent du ternaire C, avec court-circuit.\par
\par
\par
\b 5.11 Smart match \b0\par
\par
{\f1   $x ~~ $pattern}\par
Correspondance intelligente : le comportement depend\par
du type de l operande droit (valeur, type, regex...).\par
\par
\par
\b 5.12 Jonctions \b0\par
\par
{\f1   $x | $y    any-junction (au moins un vrai)}\par
{\f1   $x & $y    all-junction (tous vrais)}\par
{\f1   $x ^ $y    one-junction (exactement un vrai)}\par
\par
\par
\b 5.13 Precedence des operateurs \b0\par
\par
Du plus fort au plus faible :\par
{\f1   1.  Postfixe  : ++ -- .methode}\par
{\f1   2.  Prefixe   : ! + - ~ ? so not}\par
{\f1   3.  Mult/Div  : * / div mod %%}\par
{\f1   4.  Add/Sous  : + - ~ (binaire)}\par
{\f1   5.  Repetition: x}\par
{\f1   6.  Intervalle: .. ..^ ^.. ^..^}\par
{\f1   7.  Compar.   : == != < <= > >= eq ne lt le gt ge}\par
{\f1   8.  ET/DefOr  : && // ~~}\par
{\f1   9.  OU        : ||}\par
{\f1   10. Ternaire  : ?? !!}\par
{\f1   11. Affect.   : = := += -= etc.}\par
{\f1   12. Basse     : and or not}\par
\par
\par
\par
