\page

{\footnote # IDH_ALGOL60_12}
{\footnote $ Algol 60 - DIFFERENCES AVEC ALGOL 58}
{\footnote K Algol 60 differences Algol 58;evolution}
\b\fs24 DIFFERENCES AVEC ALGOL 58 \b0\fs20\par
\par
{\f1   Algol 60 a apporte des ameliorations significatives par}\par
{\f1   rapport a Algol 58 (IAL) :}\par
\par
{\f1     - Structure de blocs (BEGIN/END) avec portee lexicale}\par
{\f1     - Types de donnees explicites (INTEGER, REAL, BOOLEAN)}\par
{\f1     - Appel par nom comme mecanisme par defaut}\par
{\f1     - Mot-cle VALUE pour specifier le passage par valeur}\par
{\f1     - Variables OWN (persistance entre appels)}\par
{\f1     - Boucle FOR generalisee (STEP/UNTIL, WHILE, listes)}\par
{\f1     - Expressions conditionnelles (IF/THEN/ELSE comme valeur)}\par
{\f1     - Recursivite pleinement supportee}\par
{\f1     - Grammaire formelle en BNF}\par
\par
\par
\par
