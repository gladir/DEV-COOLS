\page

{\footnote # IDH_ALGOL60_13}
{\footnote $ Algol 60 - LIMITATIONS CONNUES}
{\footnote K Algol 60 limitations;compilateur}
\b\fs24 LIMITATIONS CONNUES \b0\fs20\par
\par
{\f1   Le langage Algol 60 standard presente les limitations}\par
{\f1   suivantes :}\par
\par
{\f1     - Pas de types utilisateur (pas de structures/records)}\par
{\f1     - Pas de systeme de modules ou d'importation}\par
{\f1     - Pas d'entrees/sorties standardisees}\par
{\f1     - Pas de gestion d'erreurs ou d'exceptions}\par
{\f1     - Pas de pointeurs ou d'allocation dynamique explicite}\par
{\f1     - Pas de types enumeres}\par
{\f1     - Pas de gestion de fichiers}\par
{\f1     - Les chaines ne sont pas un type de premiere classe}\par
{\f1     - L'appel par nom peut etre couteux en performance}\par
\par
{\f1   Limitations specifiques a cette implementation :}\par
{\f1     - Les reels sont tronques vers des entiers 16 bits}\par
{\f1     - Les entiers sont limites a 16 bits signes}\par
{\f1     - Pas de virgule flottante materielle (8086 sans 8087)}\par
{\f1     - Les tableaux multidimensionnels sont linearises}\par
{\f1       en row-major order}\par
\par
\par
\par
