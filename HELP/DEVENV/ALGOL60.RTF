{\footnote # IDH_ALGOL60_09}
{\footnote $ Algol 60 - BLOCS ET PORTEE}
{\footnote K Algol 60 blocs;portee;scope;begin;end}
\b\fs24 BLOCS ET PORTEE \b0\fs20\par
\par
9.1 Structure de bloc\par
\par
{\f1   Un programme Algol 60 est un bloc. Chaque bloc est delimite}\par
{\f1   par BEGIN et END et peut contenir des declarations suivies}\par
{\f1   d'instructions.}\par
\par
{\f1     BEGIN}\par
{\f1       INTEGER x;    comment declaration ;}\par
{\f1       x := 10;      comment instruction ;}\par
{\f1       BEGIN}\par
{\f1         INTEGER y;   comment declaration locale ;}\par
{\f1         y := x + 1}\par
{\f1       END}\par
{\f1     END}\par
\par
9.2 Portee lexicale\par
\par
{\f1   Les declarations sont locales au bloc englobant. La}\par
{\f1   recherche d'un identificateur remonte les blocs englobants}\par
{\f1   (portee lexicale statique, static scoping).}\par
\par
{\f1   Un identificateur local masque un identificateur de meme}\par
{\f1   nom dans un bloc englobant (shadowing).}\par
\par
9.3 Duree de vie\par
\par
{\f1   Variables locales : creees a l'entree du bloc, detruites}\par
{\f1   a la sortie. Allouees sur la pile.}\par
\par
{\f1   Variables OWN : duree de vie du programme entier. Allouees}\par
{\f1   dans le segment de donnees statiques.}\par
\par
\par
\par
