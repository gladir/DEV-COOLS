{\footnote # IDH_ALGOL60_05}
{\footnote $ Algol 60 - EXPRESSIONS}
{\footnote K Algol 60 expressions;arithmetiques;booleennes;conditionnelles}
\b\fs24 EXPRESSIONS \b0\fs20\par
\par
5.1 Expressions arithmetiques\par
\par
{\f1   Operateurs arithmetiques :}\par
{\f1     +     Addition}\par
{\f1     -     Soustraction (binaire) ou negation (unaire)}\par
{\f1     *     Multiplication}\par
{\f1     /     Division (reelle)}\par
{\f1     div   Division entiere (quotient tronque)}\par
{\f1     ^     Puissance (ou ** comme notation alternative)}\par
\par
{\f1   Precedence (du plus fort au plus faible) :}\par
{\f1     1. Unaire +, -}\par
{\f1     2. ^ (puissance, associativite a droite)}\par
{\f1     3. *, /, div}\par
{\f1     4. +, - (binaire)}\par
\par
{\f1   Exemples :}\par
{\f1     a + b * c         ->  a + (b * c)}\par
{\f1     2 ^ 3 ^ 2         ->  2 ^ (3 ^ 2) = 512  (associativite droite)}\par
{\f1     17 - 5 * 2         ->  17 - (5 * 2) = 7}\par
{\f1     10 div 3           ->  3}\par
\par
5.2 Expressions relationnelles\par
\par
{\f1   Operateurs de comparaison :}\par
{\f1     <     Inferieur}\par
{\f1     <=    Inferieur ou egal}\par
{\f1     =     Egal}\par
{\f1     >=    Superieur ou egal}\par
{\f1     >     Superieur}\par
{\f1     !=    Different (ou <> dans certaines notations)}\par
\par
{\f1   Le resultat est de type BOOLEAN (TRUE ou FALSE).}\par
\par
5.3 Expressions booleennes\par
\par
{\f1   Operateurs logiques :}\par
{\f1     NOT    Negation logique (ou ~)}\par
{\f1     AND    Conjonction logique (ou /\\)}\par
{\f1     OR     Disjonction logique (ou \\/)}\par
{\f1     IMPL   Implication logique (a IMPL b = NOT a OR b)}\par
{\f1     EQUIV  Equivalence logique (a EQUIV b = (a AND b) OR (NOT a AND NOT b))}\par
\par
{\f1   Precedence (du plus fort au plus faible) :}\par
{\f1     1. NOT}\par
{\f1     2. AND}\par
{\f1     3. OR}\par
{\f1     4. IMPL}\par
{\f1     5. EQUIV}\par
\par
{\f1   Evaluation en court-circuit :}\par
{\f1     - AND : si le premier operande est FALSE, le second}\par
{\f1       n'est pas evalue}\par
{\f1     - OR : si le premier operande est TRUE, le second}\par
{\f1       n'est pas evalue}\par
\par
5.4 Expression conditionnelle\par
\par
{\f1   Syntaxe :}\par
{\f1     IF <condition> THEN <expression1> ELSE <expression2>}\par
\par
{\f1   Retourne expression1 si la condition est vraie,}\par
{\f1   expression2 sinon. Peut etre de type INTEGER, REAL ou BOOLEAN.}\par
\par
{\f1   Exemples :}\par
{\f1     m := IF x > y THEN x ELSE y;}\par
{\f1     signe := IF n > 0 THEN 1 ELSE IF n < 0 THEN -1 ELSE 0;}\par
\par
{\f1   Note : contrairement a l'instruction IF, l'expression}\par
{\f1   conditionnelle DOIT avoir une clause ELSE.}\par
\par
5.5 Expressions designationnelles\par
\par
{\f1   Une expression designationnelle est une expression dont la}\par
{\f1   valeur est une etiquette (LABEL). Elle peut etre :}\par
\par
{\f1     - Un nom d'etiquette : L1}\par
{\f1     - Un element de switch : choix[i]}\par
{\f1     - Une expression conditionnelle d'etiquettes :}\par
{\f1       IF b THEN L1 ELSE L2}\par
\par
{\f1   Utilisee avec GOTO pour les sauts conditionels :}\par
{\f1     GOTO IF b THEN L1 ELSE L2;}\par
{\f1     GOTO choix[n];}\par
\par
\par
\par
