{\footnote # IDH_ALGOL60_06}
{\footnote $ Algol 60 - INSTRUCTIONS}
{\footnote K Algol 60 instructions;assignment;goto;if;for;while;step;until}
\b\fs24 INSTRUCTIONS \b0\fs20\par
\par
6.1 Affectation\par
\par
{\f1   Syntaxe :}\par
{\f1     <variable> := <expression>}\par
\par
{\f1   Exemples :}\par
{\f1     x := 42;}\par
{\f1     a[i] := b[j] + 1;}\par
\par
{\f1   Affectation multiple :}\par
{\f1     a := b := c := 0;}\par
{\f1     (evalue l'expression une fois, affecte de droite a gauche)}\par
\par
6.2 Instruction conditionnelle (IF/THEN/ELSE)\par
\par
{\f1   Syntaxe :}\par
{\f1     IF <condition> THEN <instruction>}\par
{\f1     IF <condition> THEN <instruction> ELSE <instruction>}\par
\par
{\f1   Exemples :}\par
{\f1     IF x < 0 THEN x := -x;}\par
{\f1     IF x > y THEN}\par
{\f1       outstring(1, `plus grand`)}\par
{\f1     ELSE}\par
{\f1       outstring(1, `plus petit`);}\par
\par
{\f1   Ambiguite du "dangling else" : la clause ELSE se lie au}\par
{\f1   IF le plus proche non encore ferme.}\par
\par
6.3 Boucle FOR\par
\par
{\f1   La boucle FOR en Algol 60 est tres generalisee. Le corps}\par
{\f1   de la boucle est execute pour chaque element de la liste.}\par
\par
{\f1   Forme STEP/UNTIL :}\par
{\f1     FOR <var> := <debut> STEP <pas> UNTIL <fin> DO <instruction>}\par
\par
{\f1   Forme WHILE :}\par
{\f1     FOR <var> := <expression> WHILE <condition> DO <instruction>}\par
\par
{\f1   Forme par liste :}\par
{\f1     FOR <var> := <elem1>, <elem2>, ... DO <instruction>}\par
\par
{\f1   Forme mixte :}\par
{\f1     FOR <var> := <elem1>, <debut> STEP <pas> UNTIL <fin>,}\par
{\f1                  <expr> WHILE <cond> DO <instruction>}\par
\par
{\f1   Exemples :}\par
{\f1     FOR i := 1 STEP 1 UNTIL 10 DO outinteger(1, i);}\par
{\f1     FOR i := 10 STEP -1 UNTIL 1 DO outinteger(1, i);}\par
{\f1     FOR i := 2, 4, 6, 8 DO outinteger(1, i);}\par
{\f1     FOR i := i WHILE i <= 100 DO i := i * 2;}\par
\par
6.4 GOTO et etiquettes\par
\par
{\f1   Syntaxe :}\par
{\f1     GOTO <etiquette>}\par
{\f1     GO TO <etiquette>    (synonyme en deux mots)}\par
{\f1     GOTO <expression designationnelle>}\par
\par
{\f1   Exemples :}\par
{\f1     GOTO fin;}\par
{\f1     GO TO debut;}\par
{\f1     GOTO choix[n];}\par
{\f1     GOTO IF b THEN L1 ELSE L2;}\par
\par
{\f1   Restrictions : un GOTO ne peut pas sauter a l'interieur}\par
{\f1   d'un bloc depuis l'exterieur. On ne peut sauter que vers}\par
{\f1   un bloc englobant ou au meme niveau.}\par
\par
6.5 Instruction composee et bloc\par
\par
{\f1   Instruction composee :}\par
{\f1     BEGIN <instruction>; <instruction>; ... END}\par
\par
{\f1   Bloc :}\par
{\f1     BEGIN <declarations>; <instructions> END}\par
\par
{\f1   Les declarations doivent preceder les instructions dans}\par
{\f1   un bloc. Le point-virgule separe les instructions (il}\par
{\f1   n'est pas un terminateur mais un separateur).}\par
\par
6.6 Instruction vide\par
\par
{\f1   Le point-virgule seul constitue une instruction vide,}\par
{\f1   utile comme cible d'etiquette :}\par
{\f1     fin: ;}\par
\par
6.7 Appel de procedure\par
\par
{\f1   Syntaxe :}\par
{\f1     <nom>(<argument1>, <argument2>, ...)}\par
{\f1     <nom>                    (sans arguments)}\par
\par
{\f1   Exemples :}\par
{\f1     afficher(42);}\par
{\f1     compteur;}\par
{\f1     outinteger(1, x + y);}\par
\par
\par
\par
