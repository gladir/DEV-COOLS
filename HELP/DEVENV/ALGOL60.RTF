\page

{\footnote # IDH_ALGOL60_11}
{\footnote $ Algol 60 - STRUCTURE D'UN PROGRAMME}
{\footnote K Algol 60 structure programme;main;source}
\b\fs24 STRUCTURE D'UN PROGRAMME \b0\fs20\par
\par
{\f1   Un programme Algol 60 est un bloc principal termine par}\par
{\f1   un point :}\par
\par
{\f1     comment Mon programme Algol 60 ;}\par
{\f1     BEGIN}\par
{\f1       <declarations> ;}\par
{\f1       <instructions>}\par
{\f1     END.}\par
\par
{\f1   Notes :}\par
{\f1     - Le point final (.) marque la fin du programme}\par
{\f1     - Le point-virgule (;) est un separateur d'instructions,}\par
{\f1       pas un terminateur}\par
{\f1     - Les declarations precedent les instructions dans}\par
{\f1       chaque bloc}\par
{\f1     - Un commentaire d'en-tete peut preceder le BEGIN}\par
\par
{\f1   Exemple complet :}\par
\par
{\f1     comment Programme de demonstration Algol 60 ;}\par
{\f1     BEGIN}\par
{\f1       INTEGER x, y;}\par
{\f1       INTEGER PROCEDURE carre(n); INTEGER n;}\par
{\f1         carre := n * n;}\par
\par
{\f1       x := 5;}\par
{\f1       y := carre(x);}\par
{\f1       outstring(1, `carre de 5 = `);}\par
{\f1       outinteger(1, y)}\par
{\f1     END.}\par
\par
\par
\par
