\page

{\footnote # IDH_ALGOL60_10}
{\footnote $ Algol 60 - ENTREES / SORTIES}
{\footnote K Algol 60 entrees sorties;read;write;input;output}
\b\fs24 ENTREES / SORTIES \b0\fs20\par
\par
{\f1   Le Revised Report d'Algol 60 ne definit pas de mecanisme}\par
{\f1   standard d'entrees/sorties. Chaque implementation fournit}\par
{\f1   ses propres intrinsics.}\par
\par
{\f1   Les intrinsics fournis par cette implementation sont :}\par
\par
{\f1     outinteger(canal, n)     Ecrire l'entier n sur le canal}\par
{\f1     outreal(canal, x)        Ecrire le reel x sur le canal}\par
{\f1     outstring(canal, s)      Ecrire la chaine s sur le canal}\par
{\f1     outboolean(canal, b)     Ecrire TRUE ou FALSE sur le canal}\par
{\f1     ininteger(canal)         Lire un entier depuis le canal}\par
{\f1     inreal(canal)            Lire un reel depuis le canal}\par
{\f1     inchar(canal)            Lire un caractere depuis le canal}\par
{\f1     print(args)              Raccourci pour outstring sur canal 1}\par
\par
{\f1   Canaux :}\par
{\f1     1 = sortie standard (STDOUT)}\par
{\f1     2 = sortie d'erreur (STDERR)}\par
\par
{\f1   Fonctions mathematiques intrinseques :}\par
{\f1     abs(n)      Valeur absolue}\par
{\f1     sign(n)     Signe (-1, 0, ou 1)}\par
{\f1     entier(x)   Partie entiere (floor)}\par
\par
\par
\par
