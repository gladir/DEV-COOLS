{\footnote # IDH_MODULA3_18}
{\footnote $ Modula-3 - CONVERTISSEURS DU PROJET}
{\footnote K Modula-3 convertisseurs;ADA2MOD3.PAS;PAS2MOD3.PAS;Ada vers Modula-3;Pascal vers Modula-3}
\b\fs24 CONVERTISSEURS DU PROJET \b0\fs20\par
\par
\par
\b 18.1 ADA2MOD3.PAS - Ada vers Modula-3 \b0\par
\par
Convertit Ada (sous-ensemble) vers Modula-3 :\par
\par
{\f1   - package spec -> INTERFACE}\par
{\f1   - package body -> MODULE}\par
{\f1   - tagged record -> OBJECT}\par
{\f1   - exception/raise -> EXCEPTION/RAISE}\par
{\f1   - access type -> REF}\par
{\f1   - generic package -> GENERIC INTERFACE/MODULE}\par
\par
\par
\b 18.2 PAS2MOD3.PAS - Pascal vers Modula-3 \b0\par
\par
Convertit Turbo Pascal (sous-ensemble) vers Modula-3 :\par
\par
{\f1   - unit -> INTERFACE + MODULE}\par
{\f1   - program -> MODULE EXPORTS Main}\par
{\f1   - object/class -> OBJECT}\par
{\f1   - try/except -> TRY/EXCEPT}\par
{\f1   - try/finally -> TRY/FINALLY}\par
{\f1   - string -> TEXT}\par
{\f1   - writeln -> IO.Put avec \\n}\par
\par
\par
\par
