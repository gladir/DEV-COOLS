{\footnote # IDH_MODULA3_02}
{\footnote $ Modula-3 - STRUCTURE D'UN PROGRAMME}
{\footnote K Modula-3 structure programme;MODULE;INTERFACE;EXPORTS Main;IMPORT;BEGIN;END}
\b\fs24 STRUCTURE D'UN PROGRAMME \b0\fs20\par
\par
Un programme Modula-3 se compose d'au moins un MODULE\par
principal et de zero ou plusieurs paires INTERFACE/MODULE de\par
bibliotheque. Le point d'entree est le module marque\par
EXPORTS Main.\par
\par
\par
\b 2.1 Module principal \b0\par
\par
{\f1   MODULE Hello EXPORTS Main;}\par
{\f1   IMPORT IO;}\par
{\f1   BEGIN}\par
{\f1     IO.Put("Hello, World!\\n")}\par
{\f1   END Hello.}\par
\par
\par
\b 2.2 INTERFACE \b0\par
\par
L'interface decrit la specification visible publiquement :\par
\par
{\f1   INTERFACE Pile;}\par
\par
{\f1   TYPE T <: REFANY;}\par
\par
{\f1   PROCEDURE New(): T;}\par
{\f1   PROCEDURE Push(s: T; x: INTEGER);}\par
{\f1   PROCEDURE Pop(s: T): INTEGER;}\par
{\f1   PROCEDURE Empty(s: T): BOOLEAN;}\par
\par
{\f1   END Pile.}\par
\par
\par
\b 2.3 MODULE \b0\par
\par
Le module implemente une ou plusieurs interfaces :\par
\par
{\f1   MODULE Pile;}\par
\par
{\f1   REVEAL T = BRANDED OBJECT}\par
{\f1     data: REF ARRAY OF INTEGER;}\par
{\f1     sp: INTEGER;}\par
{\f1   END;}\par
\par
{\f1   PROCEDURE New(): T =}\par
{\f1     VAR s := NEW(T);}\par
{\f1     BEGIN}\par
{\f1       s.data := NEW(REF ARRAY OF INTEGER, 100);}\par
{\f1       s.sp := 0;}\par
{\f1       RETURN s}\par
{\f1     END New;}\par
\par
{\f1   PROCEDURE Push(s: T; x: INTEGER) =}\par
{\f1     BEGIN}\par
{\f1       s.data[s.sp] := x;}\par
{\f1       INC(s.sp)}\par
{\f1     END Push;}\par
\par
{\f1   PROCEDURE Pop(s: T): INTEGER =}\par
{\f1     BEGIN}\par
{\f1       DEC(s.sp);}\par
{\f1       RETURN s.data[s.sp]}\par
{\f1     END Pop;}\par
\par
{\f1   PROCEDURE Empty(s: T): BOOLEAN =}\par
{\f1     BEGIN}\par
{\f1       RETURN s.sp = 0}\par
{\f1     END Empty;}\par
\par
{\f1   BEGIN}\par
{\f1   END Pile.}\par
\par
\par
\par
