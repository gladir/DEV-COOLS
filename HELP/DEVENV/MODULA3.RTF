{\footnote # IDH_MODULA3_14}
{\footnote $ Modula-3 - PROCEDURES STANDARD}
{\footnote K Modula-3 procedures standard;ABS;MAX;MIN;INC;DEC;ORD;VAL;FLOAT;TRUNC;ROUND;CEILING;FLOOR;NUMBER;FIRST;LAST;NEW;DISPOSE;ISTYPE;NARROW;TYPECODE;BITSIZE;BYTESIZE}
\b\fs24 PROCEDURES STANDARD \b0\fs20\par
\par
\par
\b 14.1 Sur entiers \b0\par
\par
{\f1   ABS(x)        valeur absolue}\par
{\f1   MAX(x, y)     maximum}\par
{\f1   MIN(x, y)     minimum}\par
{\f1   INC(x)        x := x + 1}\par
{\f1   INC(x, n)     x := x + n}\par
{\f1   DEC(x)        x := x - 1}\par
{\f1   DEC(x, n)     x := x - n}\par
{\f1   ORD(x)        valeur ordinale}\par
{\f1   VAL(n, T)     n-ieme valeur du type T}\par
\par
\par
\b 14.2 Sur flottants \b0\par
\par
{\f1   FLOAT(x, T)   conversion vers REAL/LONGREAL/EXTENDED}\par
{\f1   TRUNC(x)      troncature vers INTEGER}\par
{\f1   ROUND(x)      arrondi vers INTEGER}\par
{\f1   CEILING(x)    plafond}\par
{\f1   FLOOR(x)      plancher}\par
\par
\par
\b 14.3 Sur tableaux \b0\par
\par
{\f1   NUMBER(t)     nombre d'elements}\par
{\f1   FIRST(t)      premier indice/valeur}\par
{\f1   LAST(t)       dernier indice/valeur}\par
{\f1   SUBARRAY(t, s, n)  sous-tableau}\par
\par
\par
\b 14.4 Sur references et objets \b0\par
\par
{\f1   NEW(T, ...)   allocation}\par
{\f1   DISPOSE(p)    liberation (UNTRACED uniquement)}\par
{\f1   ISTYPE(r, T)  test de type}\par
{\f1   NARROW(r, T)  conversion verifiee}\par
{\f1   TYPECODE(r)   code numerique du type}\par
{\f1   ADR(x)        adresse (UNSAFE)}\par
{\f1   ADRSIZE(x)    taille adresse}\par
\par
\par
\b 14.5 Sur ensembles \b0\par
\par
{\f1   INCL(s, x)    ajoute x a s}\par
{\f1   EXCL(s, x)    retire x de s}\par
\par
\par
\b 14.6 Cast (UNSAFE) \b0\par
\par
{\f1   LOOPHOLE(x, T)    transmutation sans verification}\par
{\f1   BITSIZE(x)        taille en bits}\par
{\f1   BYTESIZE(x)       taille en octets}\par
\par
\par
\par
