{\footnote # IDH_MODULA3_17}
{\footnote $ Modula-3 - COMPILATEUR DU PROJET (MODIII86.PAS)}
{\footnote K Modula-3 compilateur projet;MODIII86.PAS;MS-DOS;assembleur 8086;MASM;modele LARGE}
\b\fs24 COMPILATEUR DU PROJET (MODIII86.PAS) \b0\fs20\par
\par
MODIII86.PAS - Compilateur Modula-3 vers assembleur 8086\par
\par
{\f1   Cible             : MS-DOS, assembleur MASM .MODEL LARGE}\par
{\f1   Modele memoire    : LARGE (segments multiples 64KO)}\par
{\f1   Dialecte          : Modula-3 SRC (sous-ensemble)}\par
{\f1   Sortie            : fichier .ASM, assemblable avec MASM}\par
\par
{\f1   Fonctionnalites :}\par
{\f1     - INTERFACE et MODULE}\par
{\f1     - Types INTEGER, CARDINAL, BOOLEAN, CHAR, REAL, TEXT}\par
{\f1     - ARRAY (fixe et ouvert), RECORD, REF, SET, OBJECT}\par
{\f1     - Procedures avec VALUE/VAR/READONLY}\par
{\f1     - Structures IF, CASE, WHILE, REPEAT, FOR, LOOP/EXIT}\par
{\f1     - WITH, TYPECASE}\par
{\f1     - Exceptions : RAISE, TRY/EXCEPT/FINALLY}\par
{\f1     - Sous-typage par OBJECT/OVERRIDES}\par
{\f1     - RAISES \{\} pour verification statique}\par
{\f1     - IMPORT FROM, EXPORTS Main}\par
{\f1     - GC simplifie (compteur de references)}\par
\par
{\f1   Limitations :}\par
{\f1     - Threads et MUTEX/LOCK non supportes}\par
{\f1     - Generiques (GENERIC) non supportes}\par
{\f1     - UNSAFE limite au module SYSTEM}\par
{\f1     - Pas de Network Objects, pas de Pickle}\par
{\f1     - LONGREAL et EXTENDED non supportes}\par
{\f1     - TEXT limite a 255 caracteres}\par
\par
\par
\par
