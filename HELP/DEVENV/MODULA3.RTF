{\footnote # IDH_MODULA3_19}
{\footnote $ Modula-3 - EXEMPLES}
{\footnote K Modula-3 exemples;Hello World;Factorielle;heritage objets;exception finally;thread simple}
\b\fs24 EXEMPLES \b0\fs20\par
\par
\par
\b 19.1 Hello, World! \b0\par
\par
{\f1   MODULE Hello EXPORTS Main;}\par
{\f1   IMPORT IO;}\par
{\f1   BEGIN}\par
{\f1     IO.Put("Hello, World!\\n")}\par
{\f1   END Hello.}\par
\par
\par
\b 19.2 Factorielle recursive \b0\par
\par
{\f1   MODULE Fact EXPORTS Main;}\par
{\f1   IMPORT IO, Fmt;}\par
\par
{\f1   PROCEDURE Factorielle(n: CARDINAL): CARDINAL =}\par
{\f1     BEGIN}\par
{\f1       IF n <= 1 THEN RETURN 1}\par
{\f1       ELSE RETURN n * Factorielle(n - 1)}\par
{\f1       END}\par
{\f1     END Factorielle;}\par
\par
{\f1   BEGIN}\par
{\f1     FOR i := 0 TO 10 DO}\par
{\f1       IO.Put(Fmt.Int(i) & " -> " &}\par
{\f1              Fmt.Int(Factorielle(i)) & "\\n")}\par
{\f1     END}\par
{\f1   END Fact.}\par
\par
\par
\b 19.3 Hierarchie d'objets \b0\par
\par
{\f1   MODULE Animaux EXPORTS Main;}\par
{\f1   IMPORT IO;}\par
\par
{\f1   TYPE}\par
{\f1     Animal = OBJECT}\par
{\f1       nom: TEXT;}\par
{\f1     METHODS}\par
{\f1       crier(): TEXT;}\par
{\f1     END;}\par
\par
{\f1     Chien = Animal OBJECT}\par
{\f1     OVERRIDES}\par
{\f1       crier := ChienCri;}\par
{\f1     END;}\par
\par
{\f1     Chat = Animal OBJECT}\par
{\f1     OVERRIDES}\par
{\f1       crier := ChatCri;}\par
{\f1     END;}\par
\par
{\f1   PROCEDURE ChienCri(self: Chien): TEXT =}\par
{\f1     BEGIN RETURN "Wouf!" END ChienCri;}\par
\par
{\f1   PROCEDURE ChatCri(self: Chat): TEXT =}\par
{\f1     BEGIN RETURN "Miaou!" END ChatCri;}\par
\par
{\f1   VAR a: Animal;}\par
{\f1   BEGIN}\par
{\f1     a := NEW(Chien, nom := "Rex");}\par
{\f1     IO.Put(a.nom & " dit " & a.crier() & "\\n");}\par
{\f1     a := NEW(Chat, nom := "Felix");}\par
{\f1     IO.Put(a.nom & " dit " & a.crier() & "\\n")}\par
{\f1   END Animaux.}\par
\par
\par
\b 19.4 Exception et finally \b0\par
\par
{\f1   MODULE Fichier EXPORTS Main;}\par
{\f1   IMPORT IO;}\par
\par
{\f1   EXCEPTION}\par
{\f1     Erreur(TEXT);}\par
\par
{\f1   PROCEDURE Lire(nom: TEXT) RAISES \{Erreur\} =}\par
{\f1     BEGIN}\par
{\f1       IF Text.Equal(nom, "") THEN}\par
{\f1         RAISE Erreur("Nom vide")}\par
{\f1       END}\par
{\f1     END Lire;}\par
\par
{\f1   BEGIN}\par
{\f1     TRY}\par
{\f1       TRY}\par
{\f1         Lire("")}\par
{\f1       EXCEPT}\par
{\f1       | Erreur(msg) => IO.Put("Erreur: " & msg & "\\n")}\par
{\f1       END}\par
{\f1     FINALLY}\par
{\f1       IO.Put("Termine.\\n")}\par
{\f1     END}\par
{\f1   END Fichier.}\par
\par
\par
\b 19.5 Thread simple \b0\par
\par
{\f1   MODULE Concurrent EXPORTS Main;}\par
{\f1   IMPORT IO, Thread;}\par
\par
{\f1   TYPE Tache = Thread.Closure OBJECT}\par
{\f1     id: INTEGER;}\par
{\f1   OVERRIDES}\par
{\f1     apply := Faire;}\par
{\f1   END;}\par
\par
{\f1   PROCEDURE Faire(self: Tache): REFANY =}\par
{\f1     BEGIN}\par
{\f1       IO.Put("Tache " & Fmt.Int(self.id) & "\\n");}\par
{\f1       RETURN NIL}\par
{\f1     END Faire;}\par
\par
{\f1   VAR t1, t2: Thread.T;}\par
{\f1   BEGIN}\par
{\f1     t1 := Thread.Fork(NEW(Tache, id := 1));}\par
{\f1     t2 := Thread.Fork(NEW(Tache, id := 2));}\par
{\f1     EVAL Thread.Join(t1);}\par
{\f1     EVAL Thread.Join(t2)}\par
{\f1   END Concurrent.}\par
\par
\par
