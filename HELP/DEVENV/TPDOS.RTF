{\footnote # IDH_TPDOS_11}
{\footnote $ Unite Dos - PROCEDURES - CONTROLE SYSTEME}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES - CONTROLE SYSTEME}
\b\fs24 PROCEDURES - CONTROLE SYSTEME \b0\fs20\par
\par
{\f1   Procedure GetCBreak(Var Break : Boolean);}\par
{\f1     - Retourne l'etat du Ctrl+Break DOS}\par
{\f1     - True = le DOS verifie Ctrl+C/Break a chaque appel systeme}\par
{\f1     - False = verification uniquement lors des E/S console}\par
{\f1     - Exemple :}\par
{\f1         GetCBreak(B);}\par
{\f1         WriteLn('Ctrl+Break = ', B);}\par
\par
{\f1   Procedure SetCBreak(Break : Boolean);}\par
{\f1     - Active ou desactive la verification etendue Ctrl+Break}\par
{\f1     - Exemple : SetCBreak(False);  \{ ignorer Ctrl+Break \}}\par
\par
{\f1   Procedure GetVerify(Var Verify : Boolean);}\par
{\f1     - Retourne l'etat de la verification d'ecriture disque}\par
{\f1     - True = le DOS relit chaque secteur ecrit pour verification}\par
{\f1     - False = pas de relecture (plus rapide mais moins sur)}\par
\par
{\f1   Procedure SetVerify(Verify : Boolean);}\par
{\f1     - Active ou desactive la verification d'ecriture disque}\par
{\f1     - Exemple : SetVerify(True);  \{ activer la verification \}}\par
\par
{\f1   NOTE : en Win32, GetCBreak/SetCBreak et GetVerify/SetVerify}\par
{\f1   n'ont plus de sens. Elles peuvent etre implementees comme}\par
{\f1   des stubs (ne rien faire / retourner une valeur par defaut).}\par
\par
\par
