{\footnote # IDH_TPDOS_20}
{\footnote $ Unite Dos - EXEMPLES D'UTILISATION}
{\footnote K Turbo Pascal;Unite Dos;EXEMPLES D'UTILISATION}
\b\fs24 EXEMPLES D'UTILISATION \b0\fs20\par
\par
\par
\b 20.1 Lister les fichiers d'un repertoire \b0\par
\par
{\f1   Program ListDir;}\par
{\f1   Uses Dos;}\par
{\f1   Var}\par
{\f1     SR : SearchRec;}\par
{\f1     DT : DateTime;}\par
{\f1   Begin}\par
{\f1     FindFirst('*.*', AnyFile, SR);}\par
{\f1     While DosError = 0 Do}\par
{\f1     Begin}\par
{\f1       UnpackTime(SR.Time, DT);}\par
{\f1       Write(SR.Name:14);}\par
{\f1       If (SR.Attr And Directory) <> 0 Then}\par
{\f1         Write('<REP>':10)}\par
{\f1       Else}\par
{\f1         Write(SR.Size:10);}\par
{\f1       WriteLn('  ', DT.Day:2, '/', DT.Month:2, '/', DT.Year);}\par
{\f1       FindNext(SR);}\par
{\f1     End;}\par
{\f1   End.}\par
\par
\par
\b 20.2 Obtenir la date et l'heure \b0\par
\par
{\f1   Program DateHeure;}\par
{\f1   Uses Dos;}\par
{\f1   Const Jours : Array[0..6] Of String[9] =}\par
{\f1     ('Dimanche','Lundi','Mardi','Mercredi',}\par
{\f1      'Jeudi','Vendredi','Samedi');}\par
{\f1   Var Y, M, D, DOW, H, Mi, S, S100 : Word;}\par
{\f1   Begin}\par
{\f1     GetDate(Y, M, D, DOW);}\par
{\f1     GetTime(H, Mi, S, S100);}\par
{\f1     WriteLn(Jours[DOW], ' ', D, '/', M, '/', Y);}\par
{\f1     WriteLn(H, ':', Mi, ':', S, '.', S100);}\par
{\f1   End.}\par
\par
\par
\b 20.3 Decomposer un chemin de fichier \b0\par
\par
{\f1   Program DecomposeChemin;}\par
{\f1   Uses Dos;}\par
{\f1   Var}\par
{\f1     Dir  : DirStr;}\par
{\f1     Name : NameStr;}\par
{\f1     Ext  : ExtStr;}\par
{\f1     Full : PathStr;}\par
{\f1   Begin}\par
{\f1     Full := FExpand(ParamStr(1));}\par
{\f1     FSplit(Full, Dir, Name, Ext);}\par
{\f1     WriteLn('Chemin complet : ', Full);}\par
{\f1     WriteLn('Repertoire     : ', Dir);}\par
{\f1     WriteLn('Nom            : ', Name);}\par
{\f1     WriteLn('Extension      : ', Ext);}\par
{\f1   End.}\par
\par
\par
\b 20.4 Executer un programme externe \b0\par
\par
{\f1   Program LancerProg;}\par
{\f1   Uses Dos;}\par
{\f1   Begin}\par
{\f1     SwapVectors;}\par
{\f1     Exec(GetEnv('COMSPEC'), '/C DIR *.PAS /W');}\par
{\f1     SwapVectors;}\par
{\f1     If DosError <> 0 Then}\par
{\f1       WriteLn('Erreur : ', DosError)}\par
{\f1     Else}\par
{\f1       WriteLn('Code retour : ', Lo(DosExitCode));}\par
{\f1   End.}\par
\par
\par
\b 20.5 Afficher les variables d'environnement \b0\par
\par
{\f1   Program AfficherEnv;}\par
{\f1   Uses Dos;}\par
{\f1   Var I : Integer;}\par
{\f1   Begin}\par
{\f1     WriteLn('Nombre de variables : ', EnvCount);}\par
{\f1     WriteLn;}\par
{\f1     For I := 1 To EnvCount Do}\par
{\f1       WriteLn(EnvStr(I));}\par
{\f1     WriteLn;}\par
{\f1     WriteLn('PATH = ', GetEnv('PATH'));}\par
{\f1   End.}\par
\par
\par
