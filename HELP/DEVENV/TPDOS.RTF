{\footnote # IDH_TPDOS_13}
{\footnote $ Unite Dos - PROCEDURES - ATTRIBUTS ET HORODATAGE DE FICHIERS}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES - ATTRIBUTS ET HORODATAGE DE FICHIERS}
\b\fs24 PROCEDURES - ATTRIBUTS ET HORODATAGE DE FICHIERS \b0\fs20\par
\par
\par
\b 13.1 Attributs de fichier \b0\par
\par
{\f1   Procedure GetFAttr(Var F; Var Attr : Word);}\par
{\f1     - Retourne les attributs du fichier associe a F}\par
{\f1     - F doit avoir ete associe par Assign (pas necessairement ouvert)}\par
{\f1     - Attr recoit la combinaison des attributs (ReadOnly, Hidden, etc.)}\par
{\f1     - Met a jour DosError en cas d'erreur}\par
{\f1     - Exemple :}\par
{\f1         Assign(F, 'TEST.PAS');}\par
{\f1         GetFAttr(F, A);}\par
{\f1         If DosError = 0 Then}\par
{\f1         Begin}\par
{\f1           If (A And ReadOnly) <> 0 Then WriteLn('Lecture seule');}\par
{\f1           If (A And Hidden) <> 0 Then WriteLn('Cache');}\par
{\f1           If (A And Directory) <> 0 Then WriteLn('Repertoire');}\par
{\f1         End;}\par
\par
{\f1   Procedure SetFAttr(Var F; Attr : Word);}\par
{\f1     - Modifie les attributs du fichier associe a F}\par
{\f1     - F doit etre ferme}\par
{\f1     - Met a jour DosError en cas d'erreur}\par
{\f1     - Exemple :}\par
{\f1         Assign(F, 'TEST.PAS');}\par
{\f1         SetFAttr(F, ReadOnly + Archive);}\par
\par
{\f1   API Win32 correspondantes :}\par
{\f1     GetFAttr -> GetFileAttributesA}\par
{\f1     SetFAttr -> SetFileAttributesA}\par
\par
\par
\b 13.2 Horodatage de fichier \b0\par
\par
{\f1   Procedure GetFTime(Var F; Var Time : LongInt);}\par
{\f1     - Retourne la date/heure de derniere modification du fichier F}\par
{\f1     - F doit etre OUVERT (apres Reset ou Rewrite)}\par
{\f1     - Time est au format compacte DOS (voir PackTime/UnpackTime)}\par
{\f1     - Met a jour DosError en cas d'erreur}\par
{\f1     - Exemple :}\par
{\f1         Assign(F, 'TEST.PAS');}\par
{\f1         Reset(F);}\par
{\f1         GetFTime(F, T);}\par
{\f1         UnpackTime(T, DT);}\par
{\f1         WriteLn('Date : ', DT.Day, '/', DT.Month, '/', DT.Year);}\par
{\f1         Close(F);}\par
\par
{\f1   Procedure SetFTime(Var F; Time : LongInt);}\par
{\f1     - Modifie la date/heure de derniere modification du fichier F}\par
{\f1     - F doit etre OUVERT}\par
{\f1     - Time est au format compacte DOS}\par
{\f1     - Exemple :}\par
{\f1         PackTime(DT, T);}\par
{\f1         SetFTime(F, T);}\par
\par
\par
