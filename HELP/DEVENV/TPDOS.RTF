{\footnote # IDH_TPDOS_21}
{\footnote $ Unite Dos - NOTES D'IMPLEMENTATION POUR TPCW32}
{\footnote K Turbo Pascal;Unite Dos;NOTES D'IMPLEMENTATION POUR TPCW32}
\b\fs24 NOTES D'IMPLEMENTATION POUR TPCW32 \b0\fs20\par
\par
\par
\b 21.1 Emulation en Win32 \b0\par
\par
{\f1   Fonction DOS             | API Win32 correspondante}\par
{\f1   -------------------------+----------------------------------------}\par
{\f1   DosVersion               | GetVersion / GetVersionExA}\par
{\f1   GetDate / SetDate        | GetLocalTime / SetLocalTime}\par
{\f1   GetTime / SetTime        | GetLocalTime / SetLocalTime}\par
{\f1   DiskFree / DiskSize      | GetDiskFreeSpaceA}\par
{\f1   GetFAttr                 | GetFileAttributesA}\par
{\f1   SetFAttr                 | SetFileAttributesA}\par
{\f1   FindFirst                | FindFirstFileA}\par
{\f1   FindNext                 | FindNextFileA}\par
{\f1   (fin de recherche)       | FindClose}\par
{\f1   FExpand                  | GetFullPathNameA}\par
{\f1   GetEnv                   | GetEnvironmentVariableA}\par
{\f1   Exec                     | CreateProcessA + WaitForSingleObject}\par
{\f1   DosExitCode              | GetExitCodeProcess}\par
{\f1   Intr / MsDos             | (non supportees, stubs)}\par
{\f1   GetIntVec / SetIntVec    | (non supportees, stubs)}\par
{\f1   SwapVectors              | (stub, pas necessaire)}\par
{\f1   Keep                     | (non supportee)}\par
{\f1   GetCBreak / SetCBreak    | (stubs)}\par
{\f1   GetVerify / SetVerify    | (stubs)}\par
\par
\par
\b 21.2 Structure SearchRec en Win32 \b0\par
\par
{\f1   En Win32, FindFirstFileA retourne un handle et remplit une}\par
{\f1   structure WIN32_FIND_DATAA. L'implementation doit :}\par
{\f1   1. Stocker le handle FindFirstFile dans le champ Fill}\par
{\f1   2. Convertir WIN32_FIND_DATAA vers SearchRec :}\par
{\f1      - Attr = dwFileAttributes (masque avec $3F)}\par
{\f1      - Size = nFileSizeLow}\par
{\f1      - Time = conversion FileTime -> DOS packed time}\par
{\f1      - Name = cFileName (tronque a 12 caracteres si > 8.3)}\par
\par
\par
\b 21.3 Conversion DateTime en Win32 \b0\par
\par
{\f1   Win32 utilise SYSTEMTIME (Year, Month, Day, Hour, Minute,}\par
{\f1   Second, Milliseconds) et FILETIME (64 bits depuis 1601).}\par
{\f1   La conversion entre le format DOS compact et SYSTEMTIME est :}\par
\par
{\f1     DOS -> SYSTEMTIME :}\par
{\f1       Appeler UnpackTime puis remplir SYSTEMTIME.}\par
\par
{\f1     SYSTEMTIME -> DOS :}\par
{\f1       Remplir DateTime depuis SYSTEMTIME puis appeler PackTime.}\par
\par
\par
