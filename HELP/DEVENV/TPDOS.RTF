{\footnote # IDH_TPDOS_22}
{\footnote $ Unite Dos - INTERFACE COMPLETE}
{\footnote K Turbo Pascal;Unite Dos;INTERFACE COMPLETE}
\b\fs24 INTERFACE COMPLETE \b0\fs20\par
\par
{\f1   Unit Dos;}\par
\par
{\f1   \{$D-,I-,S-,O+\}}\par
\par
{\f1   INTERFACE}\par
\par
{\f1   Const}\par
{\f1     \{ Drapeaux du processeur \}}\par
{\f1     FCarry     = $0001;}\par
{\f1     FParity    = $0004;}\par
{\f1     FAuxiliary = $0010;}\par
{\f1     FZero      = $0040;}\par
{\f1     FSign      = $0080;}\par
{\f1     FOverflow  = $0800;}\par
\par
{\f1     \{ Modes de fichier \}}\par
{\f1     fmClosed = $D7B0;}\par
{\f1     fmInput  = $D7B1;}\par
{\f1     fmOutput = $D7B2;}\par
{\f1     fmInOut  = $D7B3;}\par
\par
{\f1     \{ Attributs de fichier \}}\par
{\f1     ReadOnly  = $01;}\par
{\f1     Hidden    = $02;}\par
{\f1     SysFile   = $04;}\par
{\f1     VolumeID  = $08;}\par
{\f1     Directory = $10;}\par
{\f1     Archive   = $20;}\par
{\f1     AnyFile   = $3F;}\par
\par
{\f1   Type}\par
{\f1     ComStr  = String[127];}\par
{\f1     PathStr = String[79];}\par
{\f1     DirStr  = String[67];}\par
{\f1     NameStr = String[8];}\par
{\f1     ExtStr  = String[4];}\par
\par
{\f1     Registers = record}\par
{\f1       case Integer of}\par
{\f1         0: (AX, BX, CX, DX, BP, SI, DI, DS, ES, Flags : Word);}\par
{\f1         1: (AL, AH, BL, BH, CL, CH, DL, DH : Byte);}\par
{\f1     end;}\par
\par
{\f1     FileRec = record}\par
{\f1       Handle   : Word;}\par
{\f1       Mode     : Word;}\par
{\f1       RecSize  : Word;}\par
{\f1       Private  : Array[1..26] Of Byte;}\par
{\f1       UserData : Array[1..16] Of Byte;}\par
{\f1       Name     : Array[0..79] Of Char;}\par
{\f1     end;}\par
\par
{\f1     TextBuf = Array[0..127] Of Char;}\par
\par
{\f1     TextRec = record}\par
{\f1       Handle    : Word;}\par
{\f1       Mode      : Word;}\par
{\f1       BufSize   : Word;}\par
{\f1       Private   : Word;}\par
{\f1       BufPos    : Word;}\par
{\f1       BufEnd    : Word;}\par
{\f1       BufPtr    : ^TextBuf;}\par
{\f1       OpenFunc  : Pointer;}\par
{\f1       InOutFunc : Pointer;}\par
{\f1       FlushFunc : Pointer;}\par
{\f1       CloseFunc : Pointer;}\par
{\f1       UserData  : Array[1..16] Of Byte;}\par
{\f1       Name      : Array[0..79] Of Char;}\par
{\f1       Buffer    : TextBuf;}\par
{\f1     end;}\par
\par
{\f1     SearchRec = record}\par
{\f1       Fill : Array[1..21] Of Byte;}\par
{\f1       Attr : Byte;}\par
{\f1       Time : LongInt;}\par
{\f1       Size : LongInt;}\par
{\f1       Name : String[12];}\par
{\f1     end;}\par
\par
{\f1     DateTime = record}\par
{\f1       Year, Month, Day, Hour, Min, Sec : Word;}\par
{\f1     end;}\par
\par
{\f1   Var}\par
{\f1     DosError : Integer;}\par
\par
{\f1   \{ Version et interruptions \}}\par
{\f1   Function  DosVersion : Word;}\par
{\f1   Procedure Intr(IntNo : Byte; Var Regs : Registers);}\par
{\f1   Procedure MsDos(Var Regs : Registers);}\par
\par
{\f1   \{ Date et heure \}}\par
{\f1   Procedure GetDate(Var Year, Month, Day, DayOfWeek : Word);}\par
{\f1   Procedure SetDate(Year, Month, Day : Word);}\par
{\f1   Procedure GetTime(Var Hour, Minute, Second, Sec100 : Word);}\par
{\f1   Procedure SetTime(Hour, Minute, Second, Sec100 : Word);}\par
\par
{\f1   \{ Controle systeme \}}\par
{\f1   Procedure GetCBreak(Var Break : Boolean);}\par
{\f1   Procedure SetCBreak(Break : Boolean);}\par
{\f1   Procedure GetVerify(Var Verify : Boolean);}\par
{\f1   Procedure SetVerify(Verify : Boolean);}\par
\par
{\f1   \{ Espace disque \}}\par
{\f1   Function  DiskFree(Drive : Byte) : LongInt;}\par
{\f1   Function  DiskSize(Drive : Byte) : LongInt;}\par
\par
{\f1   \{ Attributs et horodatage \}}\par
{\f1   Procedure GetFAttr(Var F; Var Attr : Word);}\par
{\f1   Procedure SetFAttr(Var F; Attr : Word);}\par
{\f1   Procedure GetFTime(Var F; Var Time : LongInt);}\par
{\f1   Procedure SetFTime(Var F; Time : LongInt);}\par
\par
{\f1   \{ Recherche de fichiers \}}\par
{\f1   Procedure FindFirst(Path : PathStr; Attr : Word; Var F : SearchRec);}\par
{\f1   Procedure FindNext(Var F : SearchRec);}\par
\par
{\f1   \{ Conversion date/heure \}}\par
{\f1   Procedure UnpackTime(P : LongInt; Var T : DateTime);}\par
{\f1   Procedure PackTime(Var T : DateTime; Var P : LongInt);}\par
\par
{\f1   \{ Vecteurs d'interruption \}}\par
{\f1   Procedure GetIntVec(IntNo : Byte; Var Vector : Pointer);}\par
{\f1   Procedure SetIntVec(IntNo : Byte; Vector : Pointer);}\par
{\f1   Procedure SwapVectors;}\par
\par
{\f1   \{ Chemins et fichiers \}}\par
{\f1   Function  FSearch(Path : PathStr; DirList : String) : PathStr;}\par
{\f1   Function  FExpand(Path : PathStr) : PathStr;}\par
{\f1   Procedure FSplit(Path : PathStr; Var Dir : DirStr;}\par
{\f1                    Var Name : NameStr; Var Ext : ExtStr);}\par
\par
{\f1   \{ Environnement \}}\par
{\f1   Function  EnvCount : Integer;}\par
{\f1   Function  EnvStr(Index : Integer) : String;}\par
{\f1   Function  GetEnv(EnvVar : String) : String;}\par
\par
{\f1   \{ Execution de programmes \}}\par
{\f1   Procedure Exec(Path : PathStr; ComLine : ComStr);}\par
{\f1   Function  DosExitCode : Word;}\par
{\f1   Procedure Keep(ExitCode : Word);}\par
\par
{\f1   IMPLEMENTATION}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_21}     {\uldb Suivant >>}{\v IDH_TPDOS_23}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPDOS_23}
{\footnote $ Unite Dos - RESUME PAR CATEGORIE}
{\footnote K Turbo Pascal;Unite Dos;RESUME PAR CATEGORIE}
\b\fs24 RESUME PAR CATEGORIE \b0\fs20\par
\par
{\f1   CATEGORIE              | ELEMENTS}\par
{\f1   -----------------------+-------------------------------------------}\par
{\f1   Drapeaux processeur    | FCarry, FParity, FAuxiliary, FZero,}\par
{\f1                          | FSign, FOverflow}\par
{\f1   Modes fichier          | fmClosed, fmInput, fmOutput, fmInOut}\par
{\f1   Attributs fichier      | ReadOnly, Hidden, SysFile, VolumeID,}\par
{\f1                          | Directory, Archive, AnyFile}\par
{\f1   Types chaines          | ComStr, PathStr, DirStr, NameStr, ExtStr}\par
{\f1   Types enregistrements  | Registers, FileRec, TextRec, TextBuf,}\par
{\f1                          | SearchRec, DateTime}\par
{\f1   Variable               | DosError}\par
{\f1   Version DOS            | DosVersion}\par
{\f1   Interruptions          | Intr, MsDos}\par
{\f1   Date et heure          | GetDate, SetDate, GetTime, SetTime}\par
{\f1   Controle systeme       | GetCBreak, SetCBreak, GetVerify, SetVerify}\par
{\f1   Espace disque          | DiskFree, DiskSize}\par
{\f1   Attributs fichier      | GetFAttr, SetFAttr}\par
{\f1   Horodatage fichier     | GetFTime, SetFTime}\par
{\f1   Recherche fichiers     | FindFirst, FindNext}\par
{\f1   Conversion date        | UnpackTime, PackTime}\par
{\f1   Vecteurs interruption  | GetIntVec, SetIntVec, SwapVectors}\par
{\f1   Chemins                | FSearch, FExpand, FSplit}\par
{\f1   Environnement          | EnvCount, EnvStr, GetEnv}\par
{\f1   Execution programmes   | Exec, DosExitCode, Keep}\par
\par
{\f1   FIN DU DOCUMENT}\par

\par
