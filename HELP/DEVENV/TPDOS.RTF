{\footnote # IDH_TPDOS_15}
{\footnote $ Unite Dos - PROCEDURES - CONVERSION DATE/HEURE}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES - CONVERSION DATE/HEURE}
\b\fs24 PROCEDURES - CONVERSION DATE/HEURE \b0\fs20\par
\par
{\f1   Procedure UnpackTime(P : LongInt; Var T : DateTime);}\par
{\f1     - Convertit un horodatage compacte DOS en champs lisibles}\par
{\f1     - P : horodatage au format compacte (de GetFTime ou SearchRec.Time)}\par
{\f1     - T : enregistrement DateTime avec Year, Month, Day, Hour, Min, Sec}\par
{\f1     - Exemple :}\par
{\f1         UnpackTime(SR.Time, DT);}\par
{\f1         WriteLn(DT.Year, '-', DT.Month, '-', DT.Day, ' ',}\par
{\f1                 DT.Hour, ':', DT.Min, ':', DT.Sec);}\par
\par
{\f1   Procedure PackTime(Var T : DateTime; Var P : LongInt);}\par
{\f1     - Convertit des champs DateTime en horodatage compacte DOS}\par
{\f1     - T : enregistrement avec les champs a compacter}\par
{\f1     - P : recoit l'horodatage compacte}\par
{\f1     - Exemple :}\par
{\f1         DT.Year := 2026; DT.Month := 3; DT.Day := 13;}\par
{\f1         DT.Hour := 14; DT.Min := 30; DT.Sec := 0;}\par
{\f1         PackTime(DT, T);}\par
\par
{\f1   Formule de conversion :}\par
{\f1     Pack :}\par
{\f1       P := (Sec Shr 1) Or (Min Shl 5) Or (Hour Shl 11) Or}\par
{\f1            (Day Shl 16) Or (Month Shl 21) Or ((Year - 1980) Shl 25);}\par
\par
{\f1     Unpack :}\par
{\f1       Sec   := (P And $1F) * 2;}\par
{\f1       Min   := (P Shr 5) And $3F;}\par
{\f1       Hour  := (P Shr 11) And $1F;}\par
{\f1       Day   := (P Shr 16) And $1F;}\par
{\f1       Month := (P Shr 21) And $0F;}\par
{\f1       Year  := (P Shr 25) And $7F + 1980;}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_14}     {\uldb Suivant >>}{\v IDH_TPDOS_16}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPDOS_16}
{\footnote $ Unite Dos - PROCEDURES - VECTEURS D'INTERRUPTION}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES - VECTEURS D'INTERRUPTION}
\b\fs24 PROCEDURES - VECTEURS D'INTERRUPTION \b0\fs20\par
\par
{\f1   Procedure GetIntVec(IntNo : Byte; Var Vector : Pointer);}\par
{\f1     - Retourne l'adresse du vecteur d'interruption IntNo}\par
{\f1     - IntNo : numero d'interruption (0..255)}\par
{\f1     - Vector : recoit l'adresse du handler}\par
{\f1     - Exemple :}\par
{\f1         GetIntVec($1C, OldTimer);  \{ sauver le timer user tick \}}\par
\par
{\f1   Procedure SetIntVec(IntNo : Byte; Vector : Pointer);}\par
{\f1     - Installe un nouveau vecteur d'interruption}\par
{\f1     - IntNo : numero d'interruption (0..255)}\par
{\f1     - Vector : adresse du nouveau handler}\par
{\f1     - ATTENTION : le handler doit etre declare avec la directive Far}\par
{\f1       et doit etre une procedure d'interruption}\par
{\f1     - Exemple :}\par
{\f1         SetIntVec($1C, @MyTimerHandler);}\par
\par
{\f1   Procedure SwapVectors;}\par
{\f1     - Echange les vecteurs d'interruption sauvegardes par le runtime}\par
{\f1       avec les vecteurs courants}\par
{\f1     - Doit etre appelee AVANT et APRES Exec pour que le programme}\par
{\f1       execute puisse fonctionner correctement}\par
{\f1     - Exemple :}\par
{\f1         SwapVectors;}\par
{\f1         Exec('COMMAND.COM', '/C DIR');}\par
{\f1         SwapVectors;}\par
\par
{\f1   NOTE : en Win32, les vecteurs d'interruption ne sont pas accessibles.}\par
{\f1   Ces procedures sont des stubs (ne font rien) ou provoquent une erreur.}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_15}     {\uldb Suivant >>}{\v IDH_TPDOS_17}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPDOS_17}
{\footnote $ Unite Dos - PROCEDURES ET FONCTIONS - CHEMINS ET FICHIERS}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES ET FONCTIONS - CHEMINS ET FICHIERS}
\b\fs24 PROCEDURES ET FONCTIONS - CHEMINS ET FICHIERS \b0\fs20\par
\par
{\f1   Function FSearch(Path : PathStr; DirList : String) : PathStr;}\par
{\f1     - Recherche un fichier dans une liste de repertoires}\par
{\f1     - Path : nom du fichier a chercher}\par
{\f1     - DirList : liste de repertoires separes par ';'}\par
{\f1     - Retourne le chemin complet si trouve, '' (vide) sinon}\par
{\f1     - Cherche d'abord dans le repertoire courant}\par
{\f1     - Exemple :}\par
{\f1         S := FSearch('TPC.EXE', GetEnv('PATH'));}\par
{\f1         If S <> '' Then}\par
{\f1           WriteLn('Trouve : ', S)}\par
{\f1         Else}\par
{\f1           WriteLn('Non trouve');}\par
\par
{\f1   Function FExpand(Path : PathStr) : PathStr;}\par
{\f1     - Developpe un chemin relatif en chemin absolu complet}\par
{\f1     - Ajoute l'unite et le repertoire courants si necessaire}\par
{\f1     - Convertit en majuscules (convention DOS)}\par
{\f1     - Resout les '.' et '..'}\par
{\f1     - Exemple :}\par
{\f1         WriteLn(FExpand('TEST.PAS'));}\par
{\f1         \{ -> 'C:\\TP\\PROJETS\\TEST.PAS' \}}\par
\par
{\f1   Procedure FSplit(Path : PathStr; Var Dir : DirStr;}\par
{\f1                    Var Name : NameStr; Var Ext : ExtStr);}\par
{\f1     - Decompose un chemin en ses composantes}\par
{\f1     - Dir  : unite + repertoire (avec '\\' final)}\par
{\f1     - Name : nom du fichier (sans extension)}\par
{\f1     - Ext  : extension (avec le '.')}\par
{\f1     - Exemple :}\par
{\f1         FSplit('C:\\TP\\BIN\\TPC.EXE', Dir, Name, Ext);}\par
{\f1         \{ Dir = 'C:\\TP\\BIN\\', Name = 'TPC', Ext = '.EXE' \}}\par
{\f1     - Si une composante est absente, la chaine est vide :}\par
{\f1         FSplit('TEST', Dir, Name, Ext);}\par
{\f1         \{ Dir = '', Name = 'TEST', Ext = '' \}}\par
\par
{\f1   API Win32 correspondante :}\par
{\f1     FExpand -> GetFullPathNameA}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_16}     {\uldb Suivant >>}{\v IDH_TPDOS_18}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPDOS_18}
{\footnote $ Unite Dos - PROCEDURES ET FONCTIONS - ENVIRONNEMENT}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES ET FONCTIONS - ENVIRONNEMENT}
\b\fs24 PROCEDURES ET FONCTIONS - ENVIRONNEMENT \b0\fs20\par
\par
{\f1   Function EnvCount : Integer;}\par
{\f1     - Retourne le nombre de variables d'environnement}\par
{\f1     - Exemple :}\par
{\f1         WriteLn('Variables : ', EnvCount);}\par
\par
{\f1   Function EnvStr(Index : Integer) : String;}\par
{\f1     - Retourne la N-ieme variable d'environnement (1-based)}\par
{\f1     - Format : 'NOM=VALEUR'}\par
{\f1     - Exemple :}\par
{\f1         For I := 1 To EnvCount Do}\par
{\f1           WriteLn(EnvStr(I));}\par
{\f1         \{ Affiche toutes les variables d'environnement \}}\par
\par
{\f1   Function GetEnv(EnvVar : String) : String;}\par
{\f1     - Retourne la valeur d'une variable d'environnement}\par
{\f1     - EnvVar : nom de la variable (insensible a la casse)}\par
{\f1     - Retourne '' si la variable n'existe pas}\par
{\f1     - Exemple :}\par
{\f1         WriteLn('PATH = ', GetEnv('PATH'));}\par
{\f1         WriteLn('HOME = ', GetEnv('HOME'));}\par
\par
{\f1   API Win32 correspondante :}\par
{\f1     GetEnv -> GetEnvironmentVariableA}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_17}     {\uldb Suivant >>}{\v IDH_TPDOS_19}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
