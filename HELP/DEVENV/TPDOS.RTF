{\footnote # IDH_TPDOS_07}
{\footnote $ Unite Dos - VARIABLE DOSERROR}
{\footnote K Turbo Pascal;Unite Dos;VARIABLE DOSERROR}
\b\fs24 VARIABLE DOSERROR \b0\fs20\par
\par
{\f1   Var}\par
{\f1     DosError : Integer;}\par
\par
{\f1   Contient le code d'erreur de la derniere operation de l'unite DOS.}\par
{\f1   Mis a jour par FindFirst, FindNext, Exec et d'autres procedures.}\par
\par
{\f1   Codes d'erreur DOS courants :}\par
{\f1     0   = Pas d'erreur}\par
{\f1     2   = Fichier non trouve}\par
{\f1     3   = Chemin non trouve}\par
{\f1     5   = Acces refuse}\par
{\f1     6   = Handle invalide}\par
{\f1     8   = Memoire insuffisante}\par
{\f1     10  = Environnement invalide}\par
{\f1     11  = Format invalide}\par
{\f1     18  = Plus de fichiers (FindNext epuise)}\par
\par
{\f1   Exemple :}\par
{\f1     FindFirst('*.PAS', AnyFile, SR);}\par
{\f1     If DosError <> 0 Then}\par
{\f1       WriteLn('Aucun fichier .PAS trouve');}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_06}     {\uldb Suivant >>}{\v IDH_TPDOS_08}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPDOS_08}
{\footnote $ Unite Dos - PROCEDURES ET FONCTIONS - VERSION DOS}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES ET FONCTIONS - VERSION DOS}
\b\fs24 PROCEDURES ET FONCTIONS - VERSION DOS \b0\fs20\par
\par
{\f1   Function DosVersion : Word;}\par
{\f1     - Retourne le numero de version du DOS}\par
{\f1     - Lo(DosVersion) = numero majeur}\par
{\f1     - Hi(DosVersion) = numero mineur}\par
{\f1     - Exemple :}\par
{\f1         V := DosVersion;}\par
{\f1         WriteLn('DOS ', Lo(V), '.', Hi(V));}\par
{\f1         \{ DOS 6.22 -> Lo=6, Hi=22 \}}\par
\par
{\f1   NOTE : en Win32, retourne generalement la version de}\par
{\f1   compatibilite DOS du sous-systeme Windows.}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_07}     {\uldb Suivant >>}{\v IDH_TPDOS_09}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPDOS_09}
{\footnote $ Unite Dos - PROCEDURES - INTERRUPTIONS DOS}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES - INTERRUPTIONS DOS}
\b\fs24 PROCEDURES - INTERRUPTIONS DOS \b0\fs20\par
\par
{\f1   Procedure Intr(IntNo : Byte; Var Regs : Registers);}\par
{\f1     - Execute l'interruption logicielle IntNo}\par
{\f1     - Les registres sont charges depuis Regs avant l'appel}\par
{\f1     - Les registres sont sauvegardes dans Regs apres l'appel}\par
{\f1     - Permet d'appeler n'importe quel service BIOS ou DOS}\par
{\f1     - Exemple (INT 10h, service 0 = changer mode video) :}\par
{\f1         Regs.AH := $00;}\par
{\f1         Regs.AL := $13;     \{ mode 320x200x256 \}}\par
{\f1         Intr($10, Regs);}\par
\par
{\f1   Procedure MsDos(Var Regs : Registers);}\par
{\f1     - Equivalent a Intr($21, Regs)}\par
{\f1     - Appelle directement l'interruption DOS (INT 21h)}\par
{\f1     - Plus lisible que Intr($21, Regs)}\par
{\f1     - Exemple (obtenir version DOS) :}\par
{\f1         Regs.AH := $30;}\par
{\f1         MsDos(Regs);}\par
{\f1         WriteLn('Version = ', Regs.AL, '.', Regs.AH);}\par
\par
{\f1   NOTE : en Win32, ces procedures ne sont plus fonctionnelles.}\par
{\f1   Les interruptions DOS ne sont pas disponibles en mode protege}\par
{\f1   Win32. Elles doivent etre remplacees par les API Windows.}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPDOS_08}     {\uldb Suivant >>}{\v IDH_TPDOS_10}     {\uldb Sommaire}{\v IDH_TPDOS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPDOS_10}
{\footnote $ Unite Dos - PROCEDURES - DATE ET HEURE}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES - DATE ET HEURE}
\b\fs24 PROCEDURES - DATE ET HEURE \b0\fs20\par
\par
{\f1   Procedure GetDate(Var Year, Month, Day, DayOfWeek : Word);}\par
{\f1     - Retourne la date systeme courante}\par
{\f1     - Year  : annee (1980..2099)}\par
{\f1     - Month : mois (1..12)}\par
{\f1     - Day   : jour du mois (1..31)}\par
{\f1     - DayOfWeek : jour de la semaine (0=Dimanche, 1=Lundi, ..., 6=Samedi)}\par
{\f1     - Exemple :}\par
{\f1         GetDate(Y, M, D, DOW);}\par
{\f1         WriteLn('Date : ', D, '/', M, '/', Y);}\par
\par
{\f1   Procedure SetDate(Year, Month, Day : Word);}\par
{\f1     - Modifie la date systeme}\par
{\f1     - Requiert les privileges administrateur sur certains systemes}\par
{\f1     - Exemple : SetDate(2026, 3, 13);}\par
\par
{\f1   Procedure GetTime(Var Hour, Minute, Second, Sec100 : Word);}\par
{\f1     - Retourne l'heure systeme courante}\par
{\f1     - Hour   : heure (0..23)}\par
{\f1     - Minute : minute (0..59)}\par
{\f1     - Second : seconde (0..59)}\par
{\f1     - Sec100 : centiemes de seconde (0..99)}\par
{\f1     - Exemple :}\par
{\f1         GetTime(H, Mi, S, S100);}\par
{\f1         WriteLn('Heure : ', H, ':', Mi, ':', S);}\par
\par
{\f1   Procedure SetTime(Hour, Minute, Second, Sec100 : Word);}\par
{\f1     - Modifie l'heure systeme}\par
{\f1     - Requiert les privileges administrateur sur certains systemes}\par
{\f1     - Exemple : SetTime(14, 30, 0, 0);}\par
\par
{\f1   API Win32 correspondantes :}\par
{\f1     GetDate -> GetLocalTime (structure SYSTEMTIME)}\par
{\f1     SetDate -> SetLocalTime}\par
{\f1     GetTime -> GetLocalTime}\par
{\f1     SetTime -> SetLocalTime}\par
\par
\par
