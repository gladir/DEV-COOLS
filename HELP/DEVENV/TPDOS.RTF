{\footnote # IDH_TPDOS_12}
{\footnote $ Unite Dos - PROCEDURES ET FONCTIONS - ESPACE DISQUE}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES ET FONCTIONS - ESPACE DISQUE}
\b\fs24 PROCEDURES ET FONCTIONS - ESPACE DISQUE \b0\fs20\par
\par
{\f1   Function DiskFree(Drive : Byte) : LongInt;}\par
{\f1     - Retourne l'espace libre en octets sur le lecteur Drive}\par
{\f1     - Drive : 0 = lecteur courant, 1 = A:, 2 = B:, 3 = C:, etc.}\par
{\f1     - Retourne -1 si le lecteur est invalide}\par
{\f1     - Exemple :}\par
{\f1         Free := DiskFree(3);     \{ espace libre sur C: \}}\par
{\f1         WriteLn('Libre : ', Free, ' octets');}\par
{\f1     - NOTE : limite a 2 Go (LongInt = 32 bits signe)}\par
\par
{\f1   Function DiskSize(Drive : Byte) : LongInt;}\par
{\f1     - Retourne la capacite totale en octets du lecteur Drive}\par
{\f1     - Meme convention que DiskFree pour Drive}\par
{\f1     - Retourne -1 si le lecteur est invalide}\par
{\f1     - Exemple :}\par
{\f1         Total := DiskSize(3);    \{ taille totale de C: \}}\par
{\f1         WriteLn('Total : ', Total, ' octets');}\par
\par
{\f1   API Win32 correspondante :}\par
{\f1     GetDiskFreeSpaceA(root, sectPerClust, bytesPerSect,}\par
{\f1                       freeClust, totalClust)}\par
\par
\par
