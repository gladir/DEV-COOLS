{\footnote # IDH_TPDOS_19}
{\footnote $ Unite Dos - PROCEDURES ET FONCTIONS - EXECUTION DE PROGRAMMES}
{\footnote K Turbo Pascal;Unite Dos;PROCEDURES ET FONCTIONS - EXECUTION DE PROGRAMMES}
\b\fs24 PROCEDURES ET FONCTIONS - EXECUTION DE PROGRAMMES \b0\fs20\par
\par
{\f1   Procedure Exec(Path : PathStr; ComLine : ComStr);}\par
{\f1     - Execute un programme externe}\par
{\f1     - Path : chemin du programme a executer (.EXE ou .COM)}\par
{\f1     - ComLine : ligne de commande a passer au programme}\par
{\f1     - Bloquant : attend la fin du programme}\par
{\f1     - Met a jour DosError : 0 = succes, autre = erreur}\par
{\f1     - DosExitCode retourne le code de sortie apres Exec}\par
{\f1     - IMPORTANT : appeler SwapVectors avant et apres Exec}\par
{\f1     - Exemple :}\par
{\f1         SwapVectors;}\par
{\f1         Exec(GetEnv('COMSPEC'), '/C DIR *.PAS');}\par
{\f1         SwapVectors;}\par
{\f1         If DosError <> 0 Then}\par
{\f1           WriteLn('Erreur exec : ', DosError)}\par
{\f1         Else}\par
{\f1           WriteLn('Code retour : ', Lo(DosExitCode));}\par
\par
{\f1   Function DosExitCode : Word;}\par
{\f1     - Retourne le code de sortie du dernier programme execute par Exec}\par
{\f1     - Lo(DosExitCode) : code de sortie du programme (Halt(N))}\par
{\f1     - Hi(DosExitCode) : methode de terminaison :}\par
{\f1         0 = terminaison normale}\par
{\f1         1 = termine par Ctrl+C}\par
{\f1         2 = termine par erreur critique}\par
{\f1         3 = termine par programme resident (TSR)}\par
{\f1     - Exemple :}\par
{\f1         If Lo(DosExitCode) = 0 Then}\par
{\f1           WriteLn('Programme termine normalement');}\par
\par
{\f1   Procedure Keep(ExitCode : Word);}\par
{\f1     - Termine le programme et le rend resident en memoire (TSR)}\par
{\f1     - ExitCode : code de sortie}\par
{\f1     - Le programme reste en memoire apres sa terminaison}\par
{\f1     - Utilise pour les pilotes residentiels et les utilitaires TSR}\par
{\f1     - Equivalent a l'interruption DOS INT 21h, fonction 31h}\par
{\f1     - Exemple :}\par
{\f1         Keep(0);  \{ rester en memoire avec code de sortie 0 \}}\par
\par
{\f1   NOTE : Keep n'a pas de sens en Win32. Exec est emule par}\par
{\f1   CreateProcessA + WaitForSingleObject + GetExitCodeProcess.}\par
\par
{\f1   API Win32 correspondantes :}\par
{\f1     Exec         -> CreateProcessA + WaitForSingleObject}\par
{\f1     DosExitCode  -> GetExitCodeProcess}\par
\par
\par
