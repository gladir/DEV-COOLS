{\footnote # IDH_TPDOS_01}
{\footnote $ Unite Dos - CONSTANTES - DRAPEAUX DU PROCESSEUR}
{\footnote K Turbo Pascal;Unite Dos;CONSTANTES - DRAPEAUX DU PROCESSEUR}
\b\fs24 CONSTANTES - DRAPEAUX DU PROCESSEUR \b0\fs20\par
\par
{\f1   Ces constantes representent les bits du registre FLAGS du processeur}\par
{\f1   x86. Elles sont utilisees avec le champ Flags de l'enregistrement}\par
{\f1   Registers lors d'appels a Intr ou MsDos.}\par
\par
{\f1   Const}\par
{\f1     FCarry     = $0001;   \{ Bit 0  : drapeau de retenue (Carry)      \}}\par
{\f1     FParity    = $0004;   \{ Bit 2  : drapeau de parite                \}}\par
{\f1     FAuxiliary = $0010;   \{ Bit 4  : drapeau de retenue auxiliaire    \}}\par
{\f1     FZero      = $0040;   \{ Bit 6  : drapeau zero                     \}}\par
{\f1     FSign      = $0080;   \{ Bit 7  : drapeau de signe                 \}}\par
{\f1     FOverflow  = $0800;   \{ Bit 11 : drapeau de depassement           \}}\par
\par
{\f1   Utilisation typique :}\par
{\f1     MsDos(Regs);}\par
{\f1     If (Regs.Flags And FCarry) <> 0 Then}\par
{\f1       WriteLn('Erreur DOS');}\par
\par
\par
