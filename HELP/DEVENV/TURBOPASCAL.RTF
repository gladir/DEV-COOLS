{\footnote # IDH_TP_03}
{\footnote $ Turbo Pascal - Environnement de developpement integre (IDE)}
{\footnote K Turbo Pascal;Turbo Pascal;Environnement de developpement integre (IDE)}
\b\fs24 Environnement de developpement integre (IDE) \b0\fs20\par
\par
\par
\b 3.1 Composants \b0\par
\par
{\f1   L IDE Turbo Pascal regroupe :}\par
\par
{\f1     - Editeur plein ecran inspire de WordStar (touches Ctrl-K).}\par
{\f1     - Compilateur en memoire ou sur disque.}\par
{\f1     - Debugueur integre (TP 5.0+) avec points d arret, pas a pas,}\par
{\f1       surveillance de variables.}\par
{\f1     - Aide en ligne contextuelle (F1) tres complete.}\par
{\f1     - Gestionnaire de fichiers .PAS, .TPU (unite compilee), .EXE.}\par
\par
\par
\b 3.2 Touches principales \b0\par
\par
{\f1     F2     : sauver}\par
{\f1     F3     : ouvrir}\par
{\f1     F5     : agrandir / restaurer fenetre}\par
{\f1     F6     : fenetre suivante}\par
{\f1     F7     : pas a pas avec entree dans procedure}\par
{\f1     F8     : pas a pas sans entrer dans procedure}\par
{\f1     F9     : compiler vers EXE}\par
{\f1     F10    : menu principal}\par
{\f1     Ctrl-F2 : reinitialiser le programme}\par
{\f1     Ctrl-F7 : ajouter une expression a surveiller}\par
{\f1     Ctrl-F9 : compiler et executer}\par
\par
\par
\b 3.3 Menus typiques \b0\par
\par
{\f1     File   : New, Open, Save, Print, Exit}\par
{\f1     Edit   : Cut, Copy, Paste, Find, Replace}\par
{\f1     Search : recherche dans le source}\par
{\f1     Run    : Run, Reset, Step Over, Trace Into, Go to Cursor}\par
{\f1     Compile : Compile, Make, Build, Target}\par
{\f1     Debug  : Breakpoints, Watches, Call Stack, Evaluate}\par
{\f1     Tools  : utilitaires externes}\par
{\f1     Options : repertoires, parametres de compilation}\par
{\f1     Window : gestion des fenetres}\par
{\f1     Help   : aide en ligne}\par
\par
\par
