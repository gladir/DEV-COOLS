{\footnote # IDH_TP_08}
{\footnote $ Turbo Pascal - Pointeurs}
{\footnote K Turbo Pascal;Turbo Pascal;Pointeurs}
\b\fs24 Pointeurs \b0\fs20\par
\par
\par
\b 8.1 Declaration \b0\par
\par
{\f1     Type}\par
{\f1       PInt = ^Integer;}\par
{\f1       PNode = ^TNode;}\par
{\f1       TNode = Record}\par
{\f1         Valeur : Integer;}\par
{\f1         Suiv   : PNode;}\par
{\f1       End;}\par
\par
{\f1     Var P : PInt;}\par
\par
{\f1   Note : on peut declarer un pointeur vers un type non encore defini,}\par
{\f1   a condition que ce type soit defini dans la meme section Type}\par
{\f1   (forward declaration de type).}\par
\par
\par
\b 8.2 Allocation et liberation \b0\par
\par
{\f1     New(P);        \{ alloue sizeof(Integer^) \}}\par
{\f1     P^ := 42;}\par
{\f1     WriteLn(P^);}\par
{\f1     Dispose(P);}\par
\par
{\f1   Pour les blocs typees plus complexes :}\par
\par
{\f1     GetMem(P, 1024);     \{ alloue 1024 octets sur le tas \}}\par
{\f1     FreeMem(P, 1024);}\par
\par
\par
\b 8.3 Pointeur generique \b0\par
\par
{\f1     Var}\par
{\f1       P : Pointer;          \{ sans type \}}\par
\par
{\f1     P := Addr(MaVar);}\par
\par
{\f1   Pour utiliser le contenu, on doit caster :}\par
\par
{\f1     Integer(P^);}\par
\par
\par
\b 8.4 Adresses et indirection \b0\par
\par
{\f1     @X        \{ ou Addr(X), adresse de X \}}\par
{\f1     P^        \{ dereferencement \}}\par
\par
\par
