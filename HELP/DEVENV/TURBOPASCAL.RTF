{\footnote # IDH_TP_28}
{\footnote $ Turbo Pascal - Memoire et modeles}
{\footnote K Turbo Pascal;Turbo Pascal;Memoire et modeles}
\b\fs24 Memoire et modeles \b0\fs20\par
\par
\par
\b 28.1 Modele memoire DOS \b0\par
\par
{\f1   Turbo Pascal cible le mode reel 8086 avec un seul modele :}\par
\par
{\f1     - 1 segment de code (CS, 64 ko max par unite)}\par
{\f1     - 1 segment de donnees (DS, 64 ko)}\par
{\f1     - 1 segment de pile (SS, taille fixee par $M)}\par
{\f1     - Tas (heap) entre la fin de DS et la fin de la memoire}\par
\par
{\f1   Les pointeurs sont Far par defaut (4 octets) sauf optimisation.}\par
\par
\par
\b 28.2 Pointeurs Near et Far \b0\par
\par
{\f1     Type}\par
{\f1       PNear = ^Integer;       \{ 2 octets, segment courant \}}\par
{\f1       PFar  = ^Integer;       \{ 4 octets, seg:off \}}\par
\par
{\f1   TP genere du code Far pour les unites par defaut.}\par
\par
\par
\b 28.3 Tas (Heap) \b0\par
\par
{\f1     HeapOrg    debut du tas}\par
{\f1     HeapPtr    sommet courant}\par
{\f1     HeapEnd    fin reservee}\par
{\f1     FreePtr    liste libre (libere par Dispose)}\par
\par
{\f1   Allocation par New, GetMem, liberation par Dispose, FreeMem.}\par
\par
{\f1   Mark / Release : marqueur historique du sommet, pour liberer en}\par
{\f1   bloc (deconseille avec FreePtr).}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_27}     {\uldb Suivant >>}{\v IDH_TP_29}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_29}
{\footnote $ Turbo Pascal - Gestion des interruptions}
{\footnote K Turbo Pascal;Turbo Pascal;Gestion des interruptions}
\b\fs24 Gestion des interruptions \b0\fs20\par
\par
\par
\b 29.1 Procedure d interruption \b0\par
\par
{\f1     Procedure GestionnaireTimer; Interrupt;}\par
{\f1     Begin}\par
{\f1       Inc(Compteur);}\par
{\f1     End;}\par
\par
{\f1   Le mot-cle Interrupt empile correctement les registres a l entree}\par
{\f1   et IRET a la sortie.}\par
\par
\par
\b 29.2 Installation \b0\par
\par
{\f1     Var Ancien : Procedure;}\par
\par
{\f1     Begin}\par
{\f1       GetIntVec($1C, @Ancien);}\par
{\f1       SetIntVec($1C, Addr(GestionnaireTimer));}\par
{\f1       ...}\par
{\f1       \{ restaurer avant Halt \}}\par
{\f1       SetIntVec($1C, @Ancien);}\par
{\f1     End.}\par
\par
\par
\b 29.3 INT 21h appel direct \b0\par
\par
{\f1     Var R : Registers;}\par
{\f1     R.AH := $02;}\par
{\f1     R.DL := Ord('A');}\par
{\f1     Intr($21, R);}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_28}     {\uldb Suivant >>}{\v IDH_TP_30}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_30}
{\footnote $ Turbo Pascal - Compatibilite Free Pascal mode -Mtp}
{\footnote K Turbo Pascal;Turbo Pascal;Compatibilite Free Pascal mode -Mtp}
\b\fs24 Compatibilite Free Pascal mode -Mtp \b0\fs20\par
\par
{\f1   Free Pascal (FPC) propose un mode de compatibilite Turbo Pascal}\par
{\f1   active par l option -Mtp ou la directive \{$MODE TP\}.}\par
\par
{\f1   Particularites du mode -Mtp :}\par
\par
{\f1     - Integer reste 16 bits (comme en TP).}\par
{\f1     - String par defaut = String[255].}\par
{\f1     - Pas de tableaux dynamiques ni d Ansistring (sauf via TP unit).}\par
{\f1     - Constantes hex $9000..$FFFF sont des Integer signes -> negatives.}\par
{\f1     - Procedure Inherited fonctionne comme TP.}\par
{\f1     - Objects (Object) supportes (en plus de class).}\par
{\f1     - Unites .tpu remplacees par .ppu (incompatibilite binaire).}\par
{\f1     - Code 32 bits (DPMI / Win32 / Linux 32 / Linux 64), pas reel 16}\par
{\f1       bits.}\par
\par
{\f1   Pieges connus avec -Mtp :}\par
\par
{\f1     - Constantes hex et comparaisons LongInt :}\par
{\f1         If LongVar > $9000 Then ...  \{ faux : $9000 = -28672 \}}\par
{\f1       Solution : utiliser decimal ou LongInt($9000) avec precaution.}\par
\par
{\f1     - Multiplication tronquee a 16 bits si la variable cible est}\par
{\f1       Integer :}\par
{\f1         Disp : Integer;}\par
{\f1         Disp := LongInt(A) * B;     \{ tronque ! \}}\par
\par
{\f1     - Records non packed alignent Pointer sur 4 octets.}\par
\par
{\f1     - Function dans une condition = appel recursif :}\par
{\f1         If MaFonc Then ...    \{ invoque MaFonc recursivement \}}\par
{\f1       Solution : utiliser une variable locale ou Result.}\par
\par
{\f1   Voir le fichier user memory fpc-mtp-pitfalls.md pour les details.}\par
\par
\par
\b 30.1 Compilation \b0\par
\par
{\f1     fpc -Mtp programme.pas}\par
\par
{\f1   Ou avec directive en tete de fichier :}\par
\par
{\f1     \{$MODE TP\}}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_29}     {\uldb Suivant >>}{\v IDH_TP_31}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_31}
{\footnote $ Turbo Pascal - Exemples complets}
{\footnote K Turbo Pascal;Turbo Pascal;Exemples complets}
\b\fs24 Exemples complets \b0\fs20\par
\par
\par
\b 31.1 Hello World \b0\par
\par
{\f1     Program Hello;}\par
{\f1     Begin}\par
{\f1       WriteLn('Hello, World!');}\par
{\f1     End.}\par
\par
\par
\b 31.2 Factorielle recursive \b0\par
\par
{\f1     Program Factorielle;}\par
{\f1     Function Fact(N : Integer) : LongInt;}\par
{\f1     Begin}\par
{\f1       If N <= 1 Then Fact := 1}\par
{\f1       Else Fact := N * Fact(N - 1);}\par
{\f1     End;}\par
\par
{\f1     Var I : Integer;}\par
{\f1     Begin}\par
{\f1       For I := 1 To 10 Do}\par
{\f1         WriteLn(I:2, '! = ', Fact(I));}\par
{\f1     End.}\par
\par
\par
\b 31.3 Tri a bulles \b0\par
\par
{\f1     Program TriBulles;}\par
{\f1     Const N = 10;}\par
{\f1     Var T : Array[1..N] Of Integer;}\par
{\f1         I, J, Tmp : Integer;}\par
{\f1     Begin}\par
{\f1       For I := 1 To N Do T[I] := Random(100);}\par
{\f1       For I := 1 To N - 1 Do}\par
{\f1         For J := 1 To N - I Do}\par
{\f1           If T[J] > T[J + 1] Then Begin}\par
{\f1             Tmp      := T[J];}\par
{\f1             T[J]     := T[J + 1];}\par
{\f1             T[J + 1] := Tmp;}\par
{\f1           End;}\par
{\f1       For I := 1 To N Do Write(T[I]:4);}\par
{\f1       WriteLn;}\par
{\f1     End.}\par
\par
\par
\b 31.4 Lecture / ecriture de fichier texte \b0\par
\par
{\f1     Program FicTxt;}\par
{\f1     Var F : Text;}\par
{\f1         S : String;}\par
{\f1     Begin}\par
{\f1       Assign(F, 'data.txt');}\par
{\f1       Rewrite(F);}\par
{\f1       WriteLn(F, 'Ligne 1');}\par
{\f1       WriteLn(F, 'Ligne 2');}\par
{\f1       Close(F);}\par
\par
{\f1       Assign(F, 'data.txt');}\par
{\f1       Reset(F);}\par
{\f1       While Not Eof(F) Do Begin}\par
{\f1         ReadLn(F, S);}\par
{\f1         WriteLn(S);}\par
{\f1       End;}\par
{\f1       Close(F);}\par
{\f1     End.}\par
\par
\par
\b 31.5 Unite simple \b0\par
\par
{\f1     Unit Math;}\par
{\f1     Interface}\par
{\f1       Function Carre(N : Integer) : LongInt;}\par
{\f1       Function Cube(N : Integer) : LongInt;}\par
{\f1     Implementation}\par
{\f1       Function Carre(N : Integer) : LongInt;}\par
{\f1       Begin}\par
{\f1         Carre := LongInt(N) * N;}\par
{\f1       End;}\par
{\f1       Function Cube(N : Integer) : LongInt;}\par
{\f1       Begin}\par
{\f1         Cube := Carre(N) * N;}\par
{\f1       End;}\par
{\f1     End.}\par
\par
{\f1     Program TestMath;}\par
{\f1     Uses Math;}\par
{\f1     Begin}\par
{\f1       WriteLn(Carre(7));     \{ 49 \}}\par
{\f1       WriteLn(Cube(5));      \{ 125 \}}\par
{\f1     End.}\par
\par
\par
\b 31.6 Objet et heritage \b0\par
\par
{\f1     Program TestObj;}\par
{\f1     Type}\par
{\f1       TForme = Object}\par
{\f1         Constructor Init;}\par
{\f1         Procedure Dessine; Virtual;}\par
{\f1         Function Aire : Real; Virtual;}\par
{\f1         Destructor Done; Virtual;}\par
{\f1       End;}\par
\par
{\f1       TCercle = Object(TForme)}\par
{\f1         R : Real;}\par
{\f1         Constructor Init(R0 : Real);}\par
{\f1         Procedure Dessine; Virtual;}\par
{\f1         Function Aire : Real; Virtual;}\par
{\f1       End;}\par
\par
{\f1     Constructor TForme.Init;}\par
{\f1     Begin}\par
{\f1     End;}\par
\par
{\f1     Procedure TForme.Dessine;}\par
{\f1     Begin}\par
{\f1       WriteLn('forme generique');}\par
{\f1     End;}\par
\par
{\f1     Function TForme.Aire : Real;}\par
{\f1     Begin}\par
{\f1       Aire := 0;}\par
{\f1     End;}\par
\par
{\f1     Destructor TForme.Done;}\par
{\f1     Begin}\par
{\f1     End;}\par
\par
{\f1     Constructor TCercle.Init(R0 : Real);}\par
{\f1     Begin}\par
{\f1       Inherited Init;}\par
{\f1       R := R0;}\par
{\f1     End;}\par
\par
{\f1     Procedure TCercle.Dessine;}\par
{\f1     Begin}\par
{\f1       WriteLn('cercle de rayon ', R:0:2);}\par
{\f1     End;}\par
\par
{\f1     Function TCercle.Aire : Real;}\par
{\f1     Begin}\par
{\f1       Aire := Pi * R * R;}\par
{\f1     End;}\par
\par
{\f1     Var F : TForme;}\par
{\f1         C : TCercle;}\par
{\f1     Begin}\par
{\f1       F.Init;  F.Dessine;}\par
{\f1       C.Init(2.5); C.Dessine;}\par
{\f1       WriteLn('aire : ', C.Aire:0:2);}\par
{\f1       F.Done; C.Done;}\par
{\f1     End.}\par
\par
