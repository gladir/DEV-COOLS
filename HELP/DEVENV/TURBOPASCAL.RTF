{\footnote # IDH_TP_13}
{\footnote $ Turbo Pascal - Chaines de caracteres}
{\footnote K Turbo Pascal;Turbo Pascal;Chaines de caracteres}
\b\fs24 Chaines de caracteres \b0\fs20\par
\par
\par
\b 13.1 Type String \b0\par
\par
{\f1   Le type String represente une chaine de caracteres de longueur}\par
{\f1   variable jusqu a 255 octets. La longueur courante est stockee dans}\par
{\f1   l octet 0 :}\par
\par
{\f1     Var S : String;       \{ = String[255] \}}\par
{\f1     Var S2 : String[40];  \{ longueur max 40 \}}\par
\par
{\f1   Acces :}\par
{\f1     S := 'Bonjour';}\par
{\f1     WriteLn(Length(S));   \{ 7 \}}\par
{\f1     WriteLn(S[1]);        \{ 'B' \}}\par
{\f1     WriteLn(Ord(S[0]));   \{ 7 = longueur \}}\par
\par
\par
\b 13.2 Operations \b0\par
\par
{\f1     Length(s)         longueur courante}\par
{\f1     Concat(s1, s2)    concatenation (ou +)}\par
{\f1     Copy(s, i, n)     sous-chaine}\par
{\f1     Pos(sub, s)       position (0 si absent)}\par
{\f1     Delete(s, i, n)   suppression dans s}\par
{\f1     Insert(sub, s, i) insertion dans s}\par
{\f1     UpCase(c)         majuscule (caractere uniquement)}\par
{\f1     Str(v, s)         variable -> chaine}\par
{\f1     Val(s, v, code)   chaine -> variable}\par
\par
\par
\b 13.3 Concatenation \b0\par
\par
{\f1     S := 'Hello, ' + 'World!' + #10;}\par
\par
\par
\b 13.4 Comparaison \b0\par
\par
{\f1   Les chaines se comparent caractere par caractere :}\par
\par
{\f1     If S1 = S2 Then ...}\par
{\f1     If S1 < S2 Then ...     \{ ordre lexicographique \}}\par
\par
\par
\b 13.5 PChar (TP 7.0+) \b0\par
\par
{\f1   Chaine ASCIIZ a la mode C (sans byte de longueur, terminee par #0) :}\par
\par
{\f1     Var P : PChar;}\par
{\f1     P := 'Hello';     \{ litteral converti \}}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_12}     {\uldb Suivant >>}{\v IDH_TP_14}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_14}
{\footnote $ Turbo Pascal - Tableaux}
{\footnote K Turbo Pascal;Turbo Pascal;Tableaux}
\b\fs24 Tableaux \b0\fs20\par
\par
\par
\b 14.1 Declaration \b0\par
\par
{\f1     Var T : Array[1..10] Of Integer;}\par
{\f1     Var M : Array[0..9, 0..9] Of Real;}\par
\par
{\f1     Type}\par
{\f1       TVecteur = Array[1..N] Of Real;}\par
{\f1       TMatrice = Array[1..N, 1..N] Of Real;}\par
\par
{\f1   Les bornes peuvent etre tout type ordinal :}\par
\par
{\f1     Var Notes : Array['A'..'E'] Of Integer;}\par
{\f1     Var Heures : Array[TJour] Of Integer;}\par
\par
\par
\b 14.2 Acces \b0\par
\par
{\f1     T[1] := 42;}\par
{\f1     M[3, 4] := 0.5;}\par
\par
{\f1   Avec \{$R+\}, les acces hors borne provoquent une erreur d execution.}\par
\par
\par
\b 14.3 Tableaux ouverts (TP 7.0+) \b0\par
\par
{\f1   Pour passer un tableau de taille variable a une procedure :}\par
\par
{\f1     Procedure Imprime(Const T : Array Of Integer);}\par
{\f1     Var I : Integer;}\par
{\f1     Begin}\par
{\f1       For I := Low(T) To High(T) Do WriteLn(T[I]);}\par
{\f1     End;}\par
\par
\par
\b 14.4 Tableaux dynamiques \b0\par
\par
{\f1   Turbo Pascal classique ne propose pas de tableaux dynamiques (ajoutes}\par
{\f1   en Delphi 4 et Free Pascal mode Delphi). En TP, on utilise des}\par
{\f1   pointeurs et GetMem :}\par
\par
{\f1     Type}\par
{\f1       PArray = ^TArray;}\par
{\f1       TArray = Array[0..MAXINT div sizeof(Integer) - 1] Of Integer;}\par
\par
{\f1     Var P : PArray;}\par
{\f1     GetMem(P, N * SizeOf(Integer));}\par
{\f1     P^[I] := ...;}\par
{\f1     FreeMem(P, N * SizeOf(Integer));}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_13}     {\uldb Suivant >>}{\v IDH_TP_15}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_15}
{\footnote $ Turbo Pascal - Records (et records variants)}
{\footnote K Turbo Pascal;Turbo Pascal;Records (et records variants)}
\b\fs24 Records (et records variants) \b0\fs20\par
\par
\par
\b 15.1 Record simple \b0\par
\par
{\f1     Type}\par
{\f1       TPoint = Record}\par
{\f1         X, Y : Integer;}\par
{\f1       End;}\par
\par
{\f1     Var P : TPoint;}\par
{\f1     P.X := 10;}\par
{\f1     P.Y := 20;}\par
\par
\par
\b 15.2 Record imbrique \b0\par
\par
{\f1     Type}\par
{\f1       TAdresse = Record}\par
{\f1         Rue   : String[60];}\par
{\f1         Ville : String[40];}\par
{\f1       End;}\par
\par
{\f1       TPersonne = Record}\par
{\f1         Nom     : String[40];}\par
{\f1         Age     : Byte;}\par
{\f1         Adresse : TAdresse;}\par
{\f1       End;}\par
\par
{\f1     Var P : TPersonne;}\par
{\f1     P.Adresse.Ville := 'Quebec';}\par
\par
\par
\b 15.3 Record variant \b0\par
\par
{\f1   Plusieurs interpretations memoire d un meme espace (comme union en C) :}\par
\par
{\f1     Type}\par
{\f1       TForme = Record}\par
{\f1         Couleur : Word;}\par
{\f1         Case Sorte : (Cercle, Rectangle, Triangle) Of}\par
{\f1           Cercle    : (Rayon : Integer);}\par
{\f1           Rectangle : (Largeur, Hauteur : Integer);}\par
{\f1           Triangle  : (A, B, C : Integer);}\par
{\f1       End;}\par
\par
{\f1   La balise (Sorte) est optionnelle. Si elle est presente, c est un}\par
{\f1   champ accessible.}\par
\par
\par
\b 15.4 Acces par With \b0\par
\par
{\f1     With P Do Begin}\par
{\f1       Nom := 'Alice';}\par
{\f1       Age := 30;}\par
{\f1     End;}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_14}     {\uldb Suivant >>}{\v IDH_TP_16}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_16}
{\footnote $ Turbo Pascal - Ensembles (Set)}
{\footnote K Turbo Pascal;Turbo Pascal;Ensembles (Set)}
\b\fs24 Ensembles (Set) \b0\fs20\par
\par
\par
\b 16.1 Declaration \b0\par
\par
{\f1     Type}\par
{\f1       TSetJour = Set Of TJour;}\par
{\f1       TSetByte = Set Of Byte;}\par
{\f1       TSetChar = Set Of Char;}\par
\par
{\f1     Var Ouvrables : TSetJour;}\par
\par
{\f1   Le type de base doit etre ordinal et compter au plus 256 valeurs.}\par
\par
\par
\b 16.2 Operations \b0\par
\par
{\f1     Ouvrables := [Lundi, Mardi, Mercredi, Jeudi, Vendredi];}\par
{\f1     If Jour In Ouvrables Then ...}\par
{\f1     Ouvrables := Ouvrables + [Samedi];     \{ union \}}\par
{\f1     Ouvrables := Ouvrables - [Vendredi];   \{ difference \}}\par
{\f1     Ouvrables := Ouvrables * [Lundi..Vendredi];  \{ intersection \}}\par
\par
\par
\b 16.3 Comparaison \b0\par
\par
{\f1     A = B       egalite}\par
{\f1     A <= B      inclusion (A est sous-ensemble de B)}\par
{\f1     A >= B      A est sur-ensemble de B}\par
{\f1     X In A      appartenance}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_15}     {\uldb Suivant >>}{\v IDH_TP_17}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_17}
{\footnote $ Turbo Pascal - Fichiers}
{\footnote K Turbo Pascal;Turbo Pascal;Fichiers}
\b\fs24 Fichiers \b0\fs20\par
\par
\par
\b 17.1 Types de fichiers \b0\par
\par
{\f1     Var}\par
{\f1       F  : File;             \{ fichier non type (octets bruts) \}}\par
{\f1       T  : Text;             \{ fichier texte ASCII \}}\par
{\f1       FI : File Of Integer;  \{ fichier typee \}}\par
\par
\par
\b 17.2 Operations communes \b0\par
\par
{\f1     Assign(F, 'data.txt');     associe nom physique au handle}\par
{\f1     Reset(F);                  ouvre en lecture}\par
{\f1     Rewrite(F);                ouvre en ecriture (cree/tronque)}\par
{\f1     Append(T);                 ouvre Text en ajout}\par
{\f1     Read(F, v); Write(F, v);   lecture / ecriture}\par
{\f1     ReadLn(T, s); WriteLn(T, s);   pour les fichiers texte}\par
{\f1     Close(F);                  ferme}\par
{\f1     Eof(F)                     fin de fichier}\par
{\f1     SeekEof(T)                 fin en sautant les espaces}\par
{\f1     Rename(F, 'new.txt');      renomme}\par
{\f1     Erase(F);                  efface}\par
\par
\par
\b 17.3 Fichiers typees (acces aleatoire) \b0\par
\par
{\f1     Var FI : File Of Integer;}\par
{\f1     Assign(FI, 'donnees.dat');}\par
{\f1     Rewrite(FI);}\par
{\f1     For I := 1 To 100 Do Write(FI, I * 10);}\par
{\f1     Close(FI);}\par
\par
{\f1     Reset(FI);}\par
{\f1     Seek(FI, 50);    \{ positionne sur le 51e enregistrement \}}\par
{\f1     Read(FI, V);}\par
{\f1     Close(FI);}\par
\par
\par
\b 17.4 Fichiers non types \b0\par
\par
{\f1     Reset(F, 512);    \{ taille bloc 512 octets \}}\par
{\f1     BlockRead(F, Buffer, NumBlocks, NumRead);}\par
{\f1     BlockWrite(F, Buffer, NumBlocks, NumWritten);}\par
\par
\par
\b 17.5 Verification des E/S \b0\par
\par
{\f1   Avec \{$I+\} (defaut), les erreurs declenchent une exception d execution.}\par
{\f1   Avec \{$I-\}, on lit le code via IOResult :}\par
\par
{\f1     \{$I-\}}\par
{\f1     Reset(F);}\par
{\f1     \{$I+\}}\par
{\f1     If IOResult <> 0 Then ...}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_16}     {\uldb Suivant >>}{\v IDH_TP_18}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_18}
{\footnote $ Turbo Pascal - Unites (Units)}
{\footnote K Turbo Pascal;Turbo Pascal;Unites (Units)}
\b\fs24 Unites (Units) \b0\fs20\par
\par
{\f1   Les unites permettent la compilation separee, introduites en TP 4.0.}\par
{\f1   Une unite est compilee en fichier .TPU et reutilisable.}\par
\par
\par
\b 18.1 Structure d une unite \b0\par
\par
{\f1     Unit MaUnite;}\par
\par
{\f1     Interface}\par
{\f1       \{ declarations visibles depuis l exterieur \}}\par
{\f1       Const PI = 3.14159;}\par
{\f1       Type TVecteur = Record X, Y : Real End;}\par
{\f1       Procedure Salut(N : String);}\par
{\f1       Function Carre(N : Integer) : LongInt;}\par
\par
{\f1     Implementation}\par
{\f1       \{ code \}}\par
{\f1       Procedure Salut(N : String);}\par
{\f1       Begin}\par
{\f1         WriteLn('Bonjour ', N);}\par
{\f1       End;}\par
{\f1       Function Carre(N : Integer) : LongInt;}\par
{\f1       Begin}\par
{\f1         Carre := LongInt(N) * N;}\par
{\f1       End;}\par
\par
{\f1     Begin}\par
{\f1       \{ code d initialisation (optionnel) \}}\par
{\f1     End.}\par
\par
\par
\b 18.2 Utilisation \b0\par
\par
{\f1     Program TestUnit;}\par
{\f1     Uses MaUnite;}\par
{\f1     Begin}\par
{\f1       Salut('Alice');}\par
{\f1       WriteLn(Carre(7));}\par
{\f1     End.}\par
\par
\par
\b 18.3 Unites standard de TP \b0\par
\par
{\f1     System    : automatiquement Used dans tout programme}\par
{\f1     Crt       : ecran texte, clavier, son}\par
{\f1     Dos       : appels DOS, environnement, dates}\par
{\f1     Graph     : graphismes BGI (CGA, EGA, VGA)}\par
{\f1     Printer   : sortie imprimante (Lst : Text)}\par
{\f1     Strings   : manipulation de PChar}\par
{\f1     Overlay   : gestion des overlays}\par
