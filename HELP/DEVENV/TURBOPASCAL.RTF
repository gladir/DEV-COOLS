{\footnote # IDH_TP_06}
{\footnote $ Turbo Pascal - Types de donnees scalaires}
{\footnote K Turbo Pascal;Turbo Pascal;Types de donnees scalaires}
\b\fs24 Types de donnees scalaires \b0\fs20\par
\par
\par
\b 6.1 Types entiers \b0\par
\par
{\f1     Type        Taille   Plage}\par
{\f1     --------    ------   ----------------------------}\par
{\f1     ShortInt    1 octet   -128..127}\par
{\f1     Byte        1 octet   0..255}\par
{\f1     Integer     2 octets  -32768..32767}\par
{\f1     Word        2 octets  0..65535}\par
{\f1     LongInt     4 octets  -2147483648..2147483647}\par
{\f1     Comp        8 octets  -2E63..2E63 (avec coprocesseur)}\par
\par
{\f1   Sous Free Pascal -Mtp, Integer reste 16 bits par defaut comme en TP.}\par
\par
\par
\b 6.2 Types reels \b0\par
\par
{\f1     Type        Taille   Plage approximative}\par
{\f1     --------    ------   ----------------------------}\par
{\f1     Real        6 octets  2.9E-39..1.7E38, 11-12 chiffres}\par
{\f1     Single      4 octets  IEEE 754 simple precision}\par
{\f1     Double      8 octets  IEEE 754 double precision}\par
{\f1     Extended    10 octets  IEEE 754 etendue (80387)}\par
{\f1     Comp        8 octets  entier 64 bits (manipule par FPU)}\par
\par
{\f1   Real est le seul type reel disponible sans coprocesseur 8087 ; les}\par
{\f1   autres requierent \{$N+\}.}\par
\par
\par
\b 6.3 Type Char \b0\par
\par
{\f1   Caractere ASCII 8 bits :}\par
\par
{\f1     Var C : Char;}\par
{\f1     C := 'A';}\par
{\f1     C := #65;     \{ equivalent \}}\par
{\f1     WriteLn(Ord(C), ' ', C);    \{ 65 A \}}\par
\par
\par
\b 6.4 Type Boolean \b0\par
\par
{\f1   Valeurs True (1) et False (0) representees sur 1 octet :}\par
\par
{\f1     Var B : Boolean;}\par
{\f1     B := True;}\par
{\f1     If B Then ...}\par
\par
\par
\b 6.5 Type enumere \b0\par
\par
{\f1     Type}\par
{\f1       TJour = (Lundi, Mardi, Mercredi, Jeudi, Vendredi, Samedi, Dimanche);}\par
\par
{\f1     Var J : TJour;}\par
{\f1     J := Mardi;}\par
{\f1     WriteLn(Ord(J));     \{ 1 \}}\par
\par
{\f1   Les valeurs sont representees par 0, 1, 2... sur 1 ou 2 octets selon}\par
{\f1   le nombre de valeurs.}\par
\par
\par
\b 6.6 Sous-intervalles \b0\par
\par
{\f1   On peut definir un sous-intervalle d un type ordinal :}\par
\par
{\f1     Type}\par
{\f1       TDigit = 0..9;}\par
{\f1       TLettreMaj = 'A'..'Z';}\par
{\f1       TSemaine = Lundi..Vendredi;}\par
\par
{\f1   Avec \{$R+\}, les acces hors borne declenchent une erreur d execution.}\par
\par
\par
