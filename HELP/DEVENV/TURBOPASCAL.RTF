{\footnote # IDH_TP_09}
{\footnote $ Turbo Pascal - Declarations const, var, type}
{\footnote K Turbo Pascal;Turbo Pascal;Declarations const, var, type}
\b\fs24 Declarations const, var, type \b0\fs20\par
\par
\par
\b 9.1 Constantes \b0\par
\par
{\f1     Const}\par
{\f1       MAX     = 100;}\par
{\f1       PI      = 3.14159265;}\par
{\f1       TITRE   = 'Mon Programme';}\par
{\f1       ESPACES = '   ';}\par
\par
{\f1   Constantes typees (initialisation au demarrage, variables modifiables}\par
{\f1   selon $J) :}\par
\par
{\f1     Const}\par
{\f1       Buffer : Array[1..5] Of Integer = (10, 20, 30, 40, 50);}\par
{\f1       Origine : TPoint = (X: 0; Y: 0);}\par
{\f1       Compteur : Integer = 0;   \{ modifiable \}}\par
\par
\par
\b 9.2 Variables \b0\par
\par
{\f1     Var}\par
{\f1       I, J   : Integer;}\par
{\f1       Nom    : String[40];}\par
{\f1       Actif  : Boolean;}\par
{\f1       T      : Array[1..10] Of Real;}\par
\par
\par
\b 9.3 Variables absolues \b0\par
\par
{\f1   Variable a une adresse memoire fixe :}\par
\par
{\f1     Var Crayon : Byte Absolute $0040:$0017;}\par
\par
\par
\b 9.4 Types \b0\par
\par
{\f1     Type}\par
{\f1       TPoint = Record X, Y : Integer; End;}\par
{\f1       TTab   = Array[1..100] Of Integer;}\par
{\f1       PNode  = ^TNode;}\par
{\f1       TNode  = Record V : Integer; Suiv : PNode; End;}\par
\par
\par
