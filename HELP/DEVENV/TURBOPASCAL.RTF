{\footnote # IDH_TP_05}
{\footnote $ Turbo Pascal - Lexique et conventions}
{\footnote K Turbo Pascal;Turbo Pascal;Lexique et conventions}
\b\fs24 Lexique et conventions \b0\fs20\par
\par
\par
\b 5.1 Identificateurs \b0\par
\par
{\f1   Un identificateur commence par une lettre ou un caractere souligne,}\par
{\f1   suit avec lettres, chiffres ou soulignes. Sensible a la casse : NON}\par
{\f1   (Pascal est insensible a la casse).}\par
\par
{\f1     nom    Nom    NOM        \{ tous identiques \}}\par
\par
{\f1   Longueur significative : 63 caracteres en TP 7.0.}\par
\par
\par
\b 5.2 Mots reserves \b0\par
\par
{\f1   Les mots reserves ne peuvent pas etre utilises comme identificateurs :}\par
\par
{\f1     absolute       and            array         asm           begin}\par
{\f1     case           const          constructor   destructor    div}\par
{\f1     do             downto         else          end           file}\par
{\f1     for            function       goto          if            implementation}\par
{\f1     in             inherited      inline        interface     interrupt}\par
{\f1     label          mod            nil           not           object}\par
{\f1     of             or             packed        procedure     program}\par
{\f1     record         repeat         set           shl           shr}\par
{\f1     string         then           to            type          unit}\par
{\f1     until          uses           var           virtual       while}\par
{\f1     with           xor}\par
\par
\par
\b 5.3 Directives standard (mots reconnus mais redefinissables) \b0\par
\par
{\f1     abstract       assembler      cdecl         exit          export}\par
{\f1     external       far            forward       near          near}\par
{\f1     private        protected      public        published     register}\par
\par
\par
\b 5.4 Commentaires \b0\par
\par
{\f1   Trois formes equivalentes :}\par
\par
{\f1     \{ commentaire avec accolades \}}\par
{\f1     (* commentaire avec parentheses-etoiles *)}\par
\par
{\f1   Les commentaires // jusqu en fin de ligne ne font pas partie de}\par
{\f1   Turbo Pascal classique mais sont reconnus par Free Pascal -Mtp.}\par
\par
{\f1   Les commentaires sont non imbricables si on melange \{ \} et (* *) avec}\par
{\f1   les memes delimiteurs, mais on peut imbriquer \{ (* *) \} et (* \{ \} *).}\par
\par
\par
\b 5.5 Litteraux \b0\par
\par
{\f1   Entiers :}\par
{\f1     42        \{ decimal \}}\par
{\f1     -100}\par
{\f1     $1A       \{ hexadecimal \}}\par
{\f1     $FFFF}\par
\par
{\f1   Reels :}\par
{\f1     3.14}\par
{\f1     -1.5E-10}\par
{\f1     2.5e+3}\par
\par
{\f1   Caracteres :}\par
{\f1     'A'}\par
{\f1     ''''           \{ apostrophe \}}\par
{\f1     #65            \{ caractere de code 65 = 'A' \}}\par
{\f1     #$0D           \{ code 13 = CR \}}\par
{\f1     ^M             \{ code Ctrl-M = 13 \}}\par
\par
{\f1   Chaines :}\par
{\f1     'Bonjour'}\par
{\f1     'L''ami'       \{ apostrophe doublee \}}\par
{\f1     'Pre'#9'Post'  \{ concatenation avec #9 = TAB \}}\par
\par
{\f1   Booleens :}\par
{\f1     True   False}\par
\par
{\f1   Pointeur nul :}\par
{\f1     nil}\par
\par
\par
