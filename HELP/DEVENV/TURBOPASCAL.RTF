{\footnote # IDH_TP_19}
{\footnote $ Turbo Pascal - Objets (Pascal Objet, TP 5.5+)}
{\footnote K Turbo Pascal;Turbo Pascal;Objets (Pascal Objet, TP 5.5+)}
\b\fs24 Objets (Pascal Objet, TP 5.5+) \b0\fs20\par
\par
\par
\b 19.1 Declaration d un objet \b0\par
\par
{\f1     Type}\par
{\f1       TAnimal = Object}\par
{\f1         Nom : String[20];}\par
{\f1         Constructor Init(N : String);}\par
{\f1         Procedure Parle; Virtual;}\par
{\f1         Destructor Done; Virtual;}\par
{\f1       End;}\par
\par
{\f1       TChien = Object(TAnimal)}\par
{\f1         Procedure Parle; Virtual;}\par
{\f1       End;}\par
\par
\par
\b 19.2 Implementation \b0\par
\par
{\f1     Constructor TAnimal.Init(N : String);}\par
{\f1     Begin}\par
{\f1       Nom := N;}\par
{\f1     End;}\par
\par
{\f1     Procedure TAnimal.Parle;}\par
{\f1     Begin}\par
{\f1       WriteLn(Nom, ' fait un bruit');}\par
{\f1     End;}\par
\par
{\f1     Destructor TAnimal.Done;}\par
{\f1     Begin}\par
{\f1     End;}\par
\par
{\f1     Procedure TChien.Parle;}\par
{\f1     Begin}\par
{\f1       WriteLn(Nom, ' : Ouaf !');}\par
{\f1     End;}\par
\par
\par
\b 19.3 Utilisation \b0\par
\par
{\f1     Var}\par
{\f1       A : TAnimal;}\par
{\f1       C : TChien;}\par
\par
{\f1     Begin}\par
{\f1       A.Init('Beta');}\par
{\f1       A.Parle;          \{ Beta fait un bruit \}}\par
{\f1       C.Init('Rex');}\par
{\f1       C.Parle;          \{ Rex : Ouaf ! \}}\par
{\f1       A.Done; C.Done;}\par
{\f1     End.}\par
\par
\par
\b 19.4 Pointeurs sur objets \b0\par
\par
{\f1     Type PAnimal = ^TAnimal;}\par
\par
{\f1     Var P : PAnimal;}\par
{\f1     New(P, Init('Polly'));}\par
{\f1     P^.Parle;}\par
{\f1     Dispose(P, Done);}\par
\par
\par
\b 19.5 Methodes virtuelles \b0\par
\par
{\f1   Marquees Virtual, elles utilisent une VMT (Virtual Method Table)}\par
{\f1   pour le polymorphisme dynamique. Un objet doit avoir au moins un}\par
{\f1   constructeur pour initialiser sa VMT.}\par
\par
\par
\b 19.6 Heritage \b0\par
\par
{\f1   Heritage simple (un seul ancetre). Mot-cle Inherited pour appeler}\par
{\f1   la methode de l ancetre :}\par
\par
{\f1     Procedure TChien.Parle;}\par
{\f1     Begin}\par
{\f1       Inherited Parle;}\par
{\f1       WriteLn(Nom, ' : Ouaf !');}\par
{\f1     End;}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_18}     {\uldb Suivant >>}{\v IDH_TP_20}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_20}
{\footnote $ Turbo Pascal - Directives de compilation}
{\footnote K Turbo Pascal;Turbo Pascal;Directives de compilation}
\b\fs24 Directives de compilation \b0\fs20\par
\par
{\f1   Les directives sont des commentaires speciaux $... :}\par
\par
{\f1     \{$R+\}    verifie les bornes (Range checking)}\par
{\f1     \{$R-\}    desactive (par defaut)}\par
{\f1     \{$I+\}    verifie les E/S (par defaut)}\par
{\f1     \{$I-\}    laisse IOResult}\par
{\f1     \{$Q+\}    verifie le depassement entier (Overflow)}\par
{\f1     \{$Q-\}    desactive (defaut)}\par
{\f1     \{$S+\}    verifie la pile (Stack checking)}\par
{\f1     \{$S-\}    desactive}\par
{\f1     \{$N+\}    utilise le coprocesseur 8087/80387 pour les reels}\par
{\f1     \{$E+\}    emule le 8087 logiciellement}\par
{\f1     \{$B+\}    evalue completement les expressions booleennes}\par
{\f1     \{$B-\}    court-circuit (defaut)}\par
{\f1     \{$F+\}    procedures Far par defaut}\par
{\f1     \{$X+\}    syntaxe etendue (resultat de fonction ignorable)}\par
{\f1     \{$V+\}    verification stricte des Var-parametres String}\par
{\f1     \{$M ss,hp,hpmax\}  taille pile, tas min, tas max}\par
{\f1     \{$I fichier\}  inclusion d un fichier}\par
{\f1     \{$DEFINE sym\} \{$UNDEF sym\}}\par
{\f1     \{$IFDEF sym\} \{$ELSE\} \{$ENDIF\}}\par
{\f1     \{$IFNDEF sym\} \{$ENDIF\}}\par
{\f1     \{$L file.obj\}  lie un fichier OBJ}\par
{\f1     \{$O+\}    overlays autorises}\par
{\f1     \{$A+\}    aligne les variables sur des mots}\par
\par
\par
