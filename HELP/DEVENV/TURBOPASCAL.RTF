{\footnote # IDH_TP_10}
{\footnote $ Turbo Pascal - Operateurs et expressions}
{\footnote K Turbo Pascal;Turbo Pascal;Operateurs et expressions}
\b\fs24 Operateurs et expressions \b0\fs20\par
\par
\par
\b 10.1 Operateurs arithmetiques \b0\par
\par
{\f1     +    addition}\par
{\f1     -    soustraction}\par
{\f1     *    multiplication}\par
{\f1     /    division reelle (resultat reel)}\par
{\f1     div  division entiere}\par
{\f1     mod  reste de division entiere}\par
\par
\par
\b 10.2 Operateurs relationnels \b0\par
\par
{\f1     =    egal}\par
{\f1     <>   different}\par
{\f1     <    inferieur}\par
{\f1     <=   inferieur ou egal}\par
{\f1     >    superieur}\par
{\f1     >=   superieur ou egal}\par
{\f1     in   appartenance a un ensemble}\par
\par
\par
\b 10.3 Operateurs logiques et bit-a-bit \b0\par
\par
{\f1   Selon que les operandes sont Boolean ou entier :}\par
\par
{\f1     and  ET}\par
{\f1     or   OU}\par
{\f1     xor  OU exclusif}\par
{\f1     not  NON}\par
{\f1     shl  decalage gauche (entiers)}\par
{\f1     shr  decalage droite (entiers)}\par
\par
\par
\b 10.4 Operateur de chaine \b0\par
\par
{\f1     +    concatenation (String + String)}\par
\par
\par
\b 10.5 Precedence \b0\par
\par
{\f1   De la plus haute a la plus basse :}\par
\par
{\f1     1. @, Not}\par
{\f1     2. *, /, div, mod, and, shl, shr}\par
{\f1     3. +, -, or, xor}\par
{\f1     4. =, <>, <, <=, >, >=, in}\par
\par
{\f1   Utiliser des parentheses pour les expressions logiques mixtes.}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_09}     {\uldb Suivant >>}{\v IDH_TP_11}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_11}
{\footnote $ Turbo Pascal - Instructions}
{\footnote K Turbo Pascal;Turbo Pascal;Instructions}
\b\fs24 Instructions \b0\fs20\par
\par
\par
\b 11.1 Affectation \b0\par
\par
{\f1     X := 42;}\par
{\f1     Nom := 'Bob';}\par
\par
\par
\b 11.2 If / Then / Else \b0\par
\par
{\f1     If X > 0 Then}\par
{\f1       WriteLn('positif')}\par
{\f1     Else If X < 0 Then}\par
{\f1       WriteLn('negatif')}\par
{\f1     Else}\par
{\f1       WriteLn('nul');}\par
\par
{\f1   Attention : pas de ";" avant Else.}\par
\par
\par
\b 11.3 Case \b0\par
\par
{\f1     Case J Of}\par
{\f1       Lundi..Vendredi : WriteLn('semaine');}\par
{\f1       Samedi, Dimanche : WriteLn('weekend');}\par
{\f1     Else}\par
{\f1       WriteLn('inconnu');}\par
{\f1     End;}\par
\par
\par
\b 11.4 For \b0\par
\par
{\f1     For I := 1 To 10 Do}\par
{\f1       WriteLn(I);}\par
\par
{\f1     For I := 10 DownTo 1 Do}\par
{\f1       WriteLn(I);}\par
\par
{\f1     For I := 1 To N Do Begin}\par
{\f1       ...}\par
{\f1     End;}\par
\par
\par
\b 11.5 While \b0\par
\par
{\f1     While X > 0 Do Begin}\par
{\f1       X := X - 1;}\par
{\f1     End;}\par
\par
\par
\b 11.6 Repeat / Until \b0\par
\par
{\f1     Repeat}\par
{\f1       X := X + 1;}\par
{\f1     Until X >= 10;}\par
\par
\par
\b 11.7 With \b0\par
\par
{\f1     With Personne Do Begin}\par
{\f1       Nom    := 'Alice';}\par
{\f1       Age    := 30;}\par
{\f1     End;}\par
\par
\par
\b 11.8 Goto et Label \b0\par
\par
{\f1     Label 100;}\par
\par
{\f1     Begin}\par
{\f1       ...}\par
{\f1       Goto 100;}\par
{\f1       ...}\par
{\f1     100:}\par
{\f1       WriteLn('cible');}\par
{\f1     End.}\par
\par
{\f1   Decommande : utiliser Exit, Break (TP6+), Continue (TP6+) a la place.}\par
\par
\par
\b 11.9 Exit, Break, Continue, Halt \b0\par
\par
{\f1     Exit       : sort de la procedure / fonction courante.}\par
{\f1     Break      : sort de la boucle courante (TP 6+).}\par
{\f1     Continue   : passe a l iteration suivante (TP 6+).}\par
{\f1     Halt(code) : termine le programme.}\par
\par
\par
{\uldb << Precedent}{\v IDH_TP_10}     {\uldb Suivant >>}{\v IDH_TP_12}     {\uldb Sommaire}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TP_12}
{\footnote $ Turbo Pascal - Procedures et fonctions}
{\footnote K Turbo Pascal;Turbo Pascal;Procedures et fonctions}
\b\fs24 Procedures et fonctions \b0\fs20\par
\par
\par
\b 12.1 Procedure \b0\par
\par
{\f1     Procedure Salut(Nom : String);}\par
{\f1     Begin}\par
{\f1       WriteLn('Bonjour ', Nom);}\par
{\f1     End;}\par
\par
\par
\b 12.2 Fonction \b0\par
\par
{\f1     Function Carre(N : Integer) : LongInt;}\par
{\f1     Begin}\par
{\f1       Carre := LongInt(N) * N;}\par
{\f1     End;}\par
\par
{\f1   Le nom de la fonction sert de variable de retour. Free Pascal -Mtp}\par
{\f1   accepte aussi Result comme synonyme.}\par
\par
\par
\b 12.3 Parametres \b0\par
\par
{\f1   Par valeur (defaut) :}\par
\par
{\f1     Procedure P1(X : Integer);}\par
\par
{\f1   Par reference (Var) :}\par
\par
{\f1     Procedure Echange(Var A, B : Integer);}\par
{\f1     Var T : Integer;}\par
{\f1     Begin}\par
{\f1       T := A; A := B; B := T;}\par
{\f1     End;}\par
\par
{\f1   Tableau ouvert (TP 7+) :}\par
\par
{\f1     Procedure AfficheTab(Const T : Array Of Integer);}\par
{\f1     Var I : Integer;}\par
{\f1     Begin}\par
{\f1       For I := Low(T) To High(T) Do WriteLn(T[I]);}\par
{\f1     End;}\par
\par
\par
\b 12.4 Forward \b0\par
\par
{\f1   Pour des routines mutuellement recursives :}\par
\par
{\f1     Function Pair(N : Integer) : Boolean; Forward;}\par
\par
{\f1     Function Impair(N : Integer) : Boolean;}\par
{\f1     Begin}\par
{\f1       If N = 0 Then Impair := False}\par
{\f1       Else Impair := Pair(N - 1);}\par
{\f1     End;}\par
\par
{\f1     Function Pair(N : Integer) : Boolean;}\par
{\f1     Begin}\par
{\f1       If N = 0 Then Pair := True}\par
{\f1       Else Pair := Impair(N - 1);}\par
{\f1     End;}\par
\par
\par
\b 12.5 Procedures imbriquees \b0\par
\par
{\f1   Une procedure peut etre declaree localement a une autre :}\par
\par
{\f1     Procedure Externe;}\par
{\f1     Var X : Integer;}\par
\par
{\f1        Procedure Interne;}\par
{\f1        Begin}\par
{\f1          X := X + 1;}\par
{\f1        End;}\par
\par
{\f1     Begin}\par
{\f1       X := 0;}\par
{\f1       Interne;}\par
{\f1       WriteLn(X);}\par
{\f1     End;}\par
\par
\par
\b 12.6 Procedures externes et inline \b0\par
\par
{\f1     Procedure DOS_INT(N : Byte); External;}\par
{\f1     Procedure NOP; Inline($90);}\par
\par
\par
\b 12.7 Recursivite \b0\par
\par
{\f1   Toutes les procedures et fonctions peuvent etre recursives :}\par
\par
{\f1     Function Fact(N : Integer) : LongInt;}\par
{\f1     Begin}\par
{\f1       If N <= 1 Then Fact := 1}\par
{\f1       Else Fact := N * Fact(N - 1);}\par
{\f1     End;}\par
\par
\par
