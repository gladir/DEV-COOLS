{\footnote # IDH_TP_04}
{\footnote $ Turbo Pascal - Structure d un programme}
{\footnote K Turbo Pascal;Turbo Pascal;Structure d un programme}
\b\fs24 Structure d un programme \b0\fs20\par
\par
\par
\b 4.1 Programme principal \b0\par
\par
{\f1     Program HelloWorld;}\par
\par
{\f1     Uses Crt;}\par
\par
{\f1     Const}\par
{\f1       MAX = 100;}\par
\par
{\f1     Type}\par
{\f1       TArr = Array[1..MAX] Of Integer;}\par
\par
{\f1     Var}\par
{\f1       I : Integer;}\par
{\f1       T : TArr;}\par
\par
{\f1     Procedure Init;}\par
{\f1     Var J : Integer;}\par
{\f1     Begin}\par
{\f1       For J := 1 To MAX Do T[J] := 0;}\par
{\f1     End;}\par
\par
{\f1     Begin}\par
{\f1       ClrScr;}\par
{\f1       Init;}\par
{\f1       WriteLn('Bonjour, monde !');}\par
{\f1       ReadKey;}\par
{\f1     End.}\par
\par
\par
\b 4.2 Ordre canonique d un programme Pascal \b0\par
\par
{\f1     Program <nom>;}\par
{\f1     Uses <unites>;}\par
{\f1     Const ...}\par
{\f1     Type ...}\par
{\f1     Var ...}\par
{\f1     Procedure / Function ...}\par
{\f1     Begin}\par
{\f1       <instructions>}\par
{\f1     End.}\par
\par
{\f1   Sous Turbo Pascal, les sections const, type, var et procedure /}\par
{\f1   function peuvent etre repetees dans n importe quel ordre (extension}\par
{\f1   par rapport au Pascal standard).}\par
\par
\par
\b 4.3 Point final \b0\par
\par
{\f1   Le programme se termine par "End." (un point) et non "End;" (un}\par
{\f1   point-virgule). Les blocs internes (procedures, fonctions, begin}\par
{\f1   imbriques) finissent par "End;".}\par
\par
\par
