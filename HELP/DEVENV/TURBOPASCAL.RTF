{\footnote # IDH_TP_32}
{\footnote $ Turbo Pascal - Differences avec Standard Pascal (ISO 7185)}
{\footnote K Turbo Pascal;Turbo Pascal;Differences avec Standard Pascal (ISO 7185)}
\b\fs24 Differences avec Standard Pascal (ISO 7185) \b0\fs20\par
\par
{\f1     Aspect              Standard Pascal    Turbo Pascal}\par
{\f1     -----------------   ----------------   --------------------------}\par
{\f1     Casse               insensible         insensible}\par
{\f1     Strings             tableau de char    type String dedie [n]}\par
{\f1     Chaines litterales  packed array       String automatique}\par
{\f1     Modulo entier       mod                mod (+ div)}\par
{\f1     Hexadecimal         non                $1A (TP)}\par
{\f1     Pointeurs           ^T                 ^T (+ Pointer, Far/Near)}\par
{\f1     Set                 limite             Set Of Byte ou Char etc.}\par
{\f1     Unites              non                Unit / Interface / Implementation}\par
{\f1     Assembleur inline   non                Asm ... End;}\par
{\f1     Includes            non                \{$I file\}}\par
{\f1     Conditionnel        non                \{$IFDEF ...\}}\par
{\f1     Operateurs bit      non                and/or/xor sur entiers}\par
{\f1     Objets              non                Object (TP 5.5+)}\par
{\f1     Procedures imbriquees  oui             oui}\par
{\f1     Sections multiples  non                oui (const/type/var n importe ou)}\par
{\f1     Forward             oui                oui}\par
{\f1     Tableaux ouverts    non                oui (TP 7+)}\par
{\f1     Result              non                oui (FPC -Mtp)}\par
{\f1     Halt/Exit/Break     non                oui}\par
{\f1     Goto                limite              illimite}\par
{\f1     IOResult            non                oui (avec \{$I-\})}\par
\par
\par
