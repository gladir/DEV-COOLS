{\footnote # IDH_TPSYS_05}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - CHAINES}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - CHAINES}
\b\fs24 PROCEDURES ET FONCTIONS - CHAINES \b0\fs20\par
\par
{\f1   Ces fonctions operent sur les types String (Pascal ShortString).}\par
{\f1   Voir DOC\\TURBOPASCAL_STRING.txt pour les details complets.}\par
\par
\par
\b 5.1 Fonctions de chaines \b0\par
\par
{\f1   Function Length(ch : String) : Integer;}\par
{\f1     - Retourne la longueur de la chaine (valeur de ch[0])}\par
{\f1     - Exemple : Length('TEST') = 4}\par
\par
{\f1   Function Copy(S : String; Index, Count : Integer) : String;}\par
{\f1     - Retourne une sous-chaine de Count caracteres a partir de Index}\par
{\f1     - Index est 1-based (S[1] = premier caractere)}\par
{\f1     - Exemple : Copy('ABCDEF', 2, 3) = 'BCD'}\par
\par
{\f1   Function Pos(search, source : String) : Integer;}\par
{\f1     - Retourne la position de search dans source (1-based)}\par
{\f1     - Retourne 0 si non trouve}\par
{\f1     - Exemple : Pos('CD', 'ABCDEF') = 3}\par
\par
{\f1   Function Concat(ch1, ch2, ... : String) : String;}\par
{\f1     - Concatene plusieurs chaines}\par
{\f1     - Equivalent a ch1 + ch2 + ...}\par
{\f1     - Tronque a 255 caracteres si necessaire}\par
{\f1     - Exemple : Concat('AB', 'CD') = 'ABCD'}\par
\par
{\f1   Function UpCase(ch : Char) : Char;}\par
{\f1     - Convertit un caractere minuscule a-z en majuscule A-Z}\par
{\f1     - Les autres caracteres ne sont pas modifies}\par
{\f1     - Ne gere PAS les caracteres accentues}\par
{\f1     - Exemple : UpCase('a') = 'A'}\par
\par
\par
\b 5.2 Procedures de chaines \b0\par
\par
{\f1   Procedure Delete(Var S : String; Pos, nbre : Integer);}\par
{\f1     - Supprime nbre caracteres de S a partir de Pos}\par
{\f1     - Modifie S en place}\par
{\f1     - Exemple : S := 'ABCDEF'; Delete(S, 2, 3); \{ S = 'AEF' \}}\par
\par
{\f1   Procedure Insert(ch1 : String; Var ch2 : String; pos : Integer);}\par
{\f1     - Insere ch1 dans ch2 a la position pos}\par
{\f1     - Modifie ch2 en place}\par
{\f1     - Exemple : S := 'AEF'; Insert('BCD', S, 2); \{ S = 'ABCDEF' \}}\par
\par
{\f1   Procedure Str(nbre : <type>; Var ch : String);}\par
{\f1   Procedure Str(nbre : <type>:largeur; Var ch : String);}\par
{\f1   Procedure Str(nbre : <type>:largeur:decimales; Var ch : String);}\par
{\f1     - Convertit un nombre en chaine}\par
{\f1     - Supporte Integer, LongInt, Real avec formatage optionnel}\par
{\f1     - Exemple : Str(42, S);       \{ S = '42'     \}}\par
{\f1     - Exemple : Str(3.14:6:2, S); \{ S = '  3.14' \}}\par
\par
{\f1   Procedure Val(ch : String; Var nbre; Var err : Integer);}\par
{\f1     - Convertit une chaine en nombre (Integer, LongInt ou Real)}\par
{\f1     - err = 0 si la conversion reussit}\par
{\f1     - err = position du premier caractere invalide sinon}\par
{\f1     - Exemple : Val('42', N, Err);  \{ N = 42, Err = 0 \}}\par
{\f1     - Exemple : Val('3X', N, Err);  \{ N = ?, Err = 2  \}}\par
\par
\par
