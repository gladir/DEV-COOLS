{\footnote # IDH_TPSYS_10}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - REPERTOIRES}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - REPERTOIRES}
\b\fs24 PROCEDURES ET FONCTIONS - REPERTOIRES \b0\fs20\par
\par
{\f1   Procedure ChDir(rep : String);}\par
{\f1     - Change le repertoire courant}\par
{\f1     - Exemple : ChDir('C:\\PROJETS');}\par
\par
{\f1   Procedure MkDir(reper : String);}\par
{\f1     - Cree un nouveau repertoire}\par
{\f1     - Exemple : MkDir('C:\\PROJETS\\NOUVEAU');}\par
\par
{\f1   Procedure RmDir(reper : String);}\par
{\f1     - Supprime un repertoire (doit etre vide)}\par
{\f1     - Exemple : RmDir('C:\\PROJETS\\ANCIEN');}\par
\par
{\f1   Procedure GetDir(unite : Word; Var reper : String);}\par
{\f1     - Retourne le repertoire courant d'un lecteur}\par
{\f1     - unite = 0 pour le lecteur courant, 1=A, 2=B, 3=C, etc.}\par
{\f1     - Exemple : GetDir(0, S);  \{ S = 'C:\\PROJETS' \}}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPSYS_09}     {\uldb Suivant >>}{\v IDH_TPSYS_11}     {\uldb Sommaire}{\v IDH_TPSYS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
