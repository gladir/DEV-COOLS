{\footnote # IDH_TPSYS_04}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - E/S FICHIER}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - E/S FICHIER}
\b\fs24 PROCEDURES ET FONCTIONS - E/S FICHIER \b0\fs20\par
\par
{\f1   Les procedures d'E/S fichier sont le coeur de la gestion des fichiers}\par
{\f1   en Turbo Pascal. Elles s'appliquent aux types Text, File et File of T.}\par
\par
\par
\b 4.1 Assignation et ouverture \b0\par
\par
{\f1   Procedure Assign(Var fich : File; nomfich : String);}\par
{\f1     - Associe une variable fichier a un nom de fichier sur disque}\par
{\f1     - Doit etre appelee AVANT Reset, Rewrite ou Append}\par
{\f1     - Exemple : Assign(F, 'DONNEES.TXT');}\par
\par
{\f1   Procedure Reset(Var fich : File);}\par
{\f1     - Ouvre un fichier existant}\par
{\f1     - Pour Text : ouvre en lecture seule}\par
{\f1     - Pour File : ouvre en lecture/ecriture (selon FileMode)}\par
{\f1     - Pour File of T : ouvre en lecture/ecriture}\par
{\f1     - Le pointeur de fichier est positionne au debut}\par
{\f1     - Erreur si le fichier n'existe pas}\par
{\f1     - Exemple : Reset(F);}\par
\par
{\f1   Procedure Rewrite(Var fich : File);}\par
{\f1     - Cree un nouveau fichier (ou ecrase un existant)}\par
{\f1     - Pour Text : ouvre en ecriture seule}\par
{\f1     - Pour File : cree avec taille de bloc = 128 octets par defaut}\par
{\f1     - Le fichier est vide apres l'appel}\par
{\f1     - Exemple : Rewrite(F);}\par
\par
{\f1   Procedure Append(Var fich : Text);}\par
{\f1     - Ouvre un fichier texte EXISTANT en mode ajout}\par
{\f1     - Le pointeur se positionne a la fin du fichier}\par
{\f1     - Les ecritures s'ajoutent apres le contenu existant}\par
{\f1     - Ne fonctionne qu'avec le type Text}\par
{\f1     - Exemple : Append(F);}\par
\par
\par
\b 4.2 Lecture \b0\par
\par
{\f1   Procedure Read(var1, var2, ...);}\par
{\f1   Procedure Read(Var fich : Text; var1, var2, ...);}\par
{\f1     - Lit des valeurs depuis un fichier texte (ou stdin)}\par
{\f1     - Les types supportes : Integer, LongInt, Real, Char, String}\par
{\f1     - Pour Integer/Real : saute les espaces, lit un nombre}\par
{\f1     - Pour Char : lit un seul caractere}\par
{\f1     - Pour String : lit jusqu'a CR/LF (sans le consommer)}\par
{\f1     - Sans argument fich, lit depuis Input (stdin)}\par
{\f1     - Exemple : Read(F, Nom, Age);}\par
\par
{\f1   Procedure ReadLn(var1, var2, ...);}\par
{\f1   Procedure ReadLn(Var fich : Text; var1, var2, ...);}\par
{\f1     - Comme Read, mais consomme aussi le reste de la ligne (CR/LF)}\par
{\f1     - ReadLn sans arguments avance d'une ligne}\par
{\f1     - Ne fonctionne qu'avec Text (pas File of T)}\par
{\f1     - Exemple : ReadLn(F, S);}\par
\par
{\f1   Procedure BlockRead(Var fich : File; Var buf; count : Word;}\par
{\f1                        Var result : Word);}\par
{\f1     - Lit count enregistrements dans buf}\par
{\f1     - result recoit le nombre d'enregistrements effectivement lus}\par
{\f1     - Pour fichiers non types (File) avec taille de bloc}\par
{\f1     - Exemple : BlockRead(F, Buffer, SizeOf(Buffer), BytesRead);}\par
\par
\par
\b 4.3 Ecriture \b0\par
\par
{\f1   Procedure Write(var1, var2, ...);}\par
{\f1   Procedure Write(Var fich : Text; var1, var2, ...);}\par
{\f1     - Ecrit des valeurs dans un fichier texte (ou stdout)}\par
{\f1     - Supporte le formatage : Write(N:8) ou Write(R:10:2)}\par
{\f1     - Types supportes : Integer, LongInt, Real, Char, String, Boolean}\par
{\f1     - Sans argument fich, ecrit dans Output (stdout)}\par
{\f1     - Exemple : Write(F, 'Nom = ', Nom);}\par
\par
{\f1   Procedure WriteLn(var1, var2, ...);}\par
{\f1   Procedure WriteLn(Var fich : Text; var1, var2, ...);}\par
{\f1     - Comme Write, mais ajoute CR+LF a la fin}\par
{\f1     - WriteLn sans arguments ecrit une ligne vide}\par
{\f1     - Ne fonctionne qu'avec Text (pas File of T)}\par
{\f1     - Exemple : WriteLn(F, 'Total = ', Total:10:2);}\par
\par
{\f1   Procedure BlockWrite(Var fich : File; Var buf; count : Word;}\par
{\f1                         Var result : Word);}\par
{\f1     - Ecrit count enregistrements depuis buf}\par
{\f1     - result recoit le nombre d'enregistrements effectivement ecrits}\par
{\f1     - Pour fichiers non types (File) avec taille de bloc}\par
{\f1     - Exemple : BlockWrite(F, Buffer, BytesRead, BytesWritten);}\par
\par
\par
\b 4.4 Fermeture et controle \b0\par
\par
{\f1   Procedure Close(Var fich : File);}\par
{\f1     - Ferme un fichier ouvert}\par
{\f1     - Vide le tampon d'ecriture avant de fermer}\par
{\f1     - Doit etre appelee apres toute utilisation}\par
{\f1     - Exemple : Close(F);}\par
\par
{\f1   Procedure Flush(Var fich : Text);}\par
{\f1     - Vide le tampon d'ecriture d'un fichier texte}\par
{\f1     - Les donnees en tampon sont ecrites sur disque}\par
{\f1     - Ne fonctionne qu'avec Text}\par
{\f1     - Exemple : Flush(F);}\par
\par
\par
\b 4.5 Tests d'etat \b0\par
\par
{\f1   Function Eof(Var fich : File) : Boolean;}\par
{\f1   Function Eof : Boolean;}\par
{\f1     - Retourne True si la fin du fichier est atteinte}\par
{\f1     - Sans argument : teste Eof(Input) = stdin}\par
{\f1     - Pour Text : True quand aucun caractere ne peut etre lu}\par
{\f1     - Pour File : True quand FilePos = FileSize}\par
{\f1     - Exemple : While Not Eof(F) Do ReadLn(F, S);}\par
\par
{\f1   Function Eoln(Var fich : Text) : Boolean;}\par
{\f1   Function Eoln : Boolean;}\par
{\f1     - Retourne True si le caractere courant est CR ou LF}\par
{\f1     - Ne fonctionne qu'avec Text}\par
{\f1     - Sans argument : teste Eoln(Input)}\par
{\f1     - Exemple : While Not Eoln(F) Do Read(F, Ch);}\par
\par
{\f1   Function SeekEof(Var fich : Text) : Boolean;}\par
{\f1     - Comme Eof mais saute les espaces, tabulations et lignes vides}\par
{\f1     - Utile pour lire des nombres separes par des blancs}\par
{\f1     - Ne fonctionne qu'avec Text}\par
{\f1     - Exemple : While Not SeekEof(F) Do Read(F, N);}\par
\par
{\f1   Function SeekEoln(Var fich : Text) : Boolean;}\par
{\f1     - Comme Eoln mais saute les espaces et tabulations}\par
{\f1     - Ne fonctionne qu'avec Text}\par
\par
{\f1   Function IoResult : Word;}\par
{\f1     - Retourne le code d'erreur de la derniere operation I/O}\par
{\f1     - Remet InOutRes a 0 apres l'appel}\par
{\f1     - Requiert la directive \{$I-\} pour ne pas generer d'erreur runtime}\par
{\f1     - 0 = succes, autre = code d'erreur (voir section 1.4)}\par
{\f1     - Exemple :}\par
{\f1         \{$I-\}}\par
{\f1         Reset(F);}\par
{\f1         If IoResult <> 0 Then WriteLn('Erreur ouverture');}\par
{\f1         \{$I+\}}\par
\par
\par
\b 4.6 Positionnement \b0\par
\par
{\f1   Procedure Seek(Var fich : File; Pos : LongInt);}\par
{\f1     - Positionne le pointeur de fichier a l'enregistrement Pos}\par
{\f1     - Pos = 0 pour le debut du fichier}\par
{\f1     - Ne fonctionne PAS avec Text}\par
{\f1     - Exemple : Seek(F, 0);  \{ retour au debut \}}\par
\par
{\f1   Function FilePos(Var fich : File) : LongInt;}\par
{\f1     - Retourne la position courante dans le fichier}\par
{\f1     - Pour File : en nombre d'enregistrements}\par
{\f1     - Ne fonctionne PAS avec Text}\par
{\f1     - Exemple : Pos := FilePos(F);}\par
\par
{\f1   Function FileSize(Var fich : File) : LongInt;}\par
{\f1     - Retourne la taille du fichier en nombre d'enregistrements}\par
{\f1     - Pour File of T : nombre d'enregistrements de type T}\par
{\f1     - Pour File : nombre de blocs de 128 octets (par defaut)}\par
{\f1     - Ne fonctionne PAS avec Text}\par
{\f1     - Exemple : N := FileSize(F);}\par
\par
{\f1   Procedure Truncate(Var fich : File);}\par
{\f1     - Tronque le fichier a la position courante}\par
{\f1     - Tout ce qui suit la position courante est supprime}\par
{\f1     - Ne fonctionne PAS avec Text}\par
{\f1     - Exemple : Seek(F, 10); Truncate(F);}\par
\par
\par
\b 4.7 Gestion fichier \b0\par
\par
{\f1   Procedure Rename(Var fich : File; nouveaunom : String);}\par
{\f1     - Renomme un fichier (doit etre ferme)}\par
{\f1     - Exemple : Close(F); Rename(F, 'NOUVEAU.TXT');}\par
\par
{\f1   Procedure Erase(Var fich : File);}\par
{\f1     - Supprime un fichier du disque (doit etre ferme)}\par
{\f1     - Exemple : Close(F); Erase(F);}\par
\par
\par
\b 4.8 Tampon texte \b0\par
\par
{\f1   Procedure SetTextBuf(Var fich : Text; Var buffer; Taille : Word);}\par
{\f1   Procedure SetTextBuf(Var fich : Text; Var buffer);}\par
{\f1     - Assigne un tampon personnalise a un fichier texte}\par
{\f1     - Doit etre appele ENTRE Assign et Reset/Rewrite}\par
{\f1     - Si Taille est omise, utilise SizeOf(buffer)}\par
{\f1     - Ameliore les performances pour les gros fichiers}\par
{\f1     - Exemple :}\par
{\f1         Var Buf : Array[0..4095] Of Char;}\par
{\f1         Assign(F, 'GROS.TXT');}\par
{\f1         SetTextBuf(F, Buf);}\par
{\f1         Reset(F);}\par
\par
\par
