{\footnote # IDH_TPSYS_09}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - REGISTRES ET SEGMENTS}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - REGISTRES ET SEGMENTS}
\b\fs24 PROCEDURES ET FONCTIONS - REGISTRES ET SEGMENTS \b0\fs20\par
\par
{\f1   Function CSeg : Word;}\par
{\f1     - Retourne le segment de code courant (CS)}\par
{\f1     - Specifique au mode reel 16 bits}\par
\par
{\f1   Function DSeg : Word;}\par
{\f1     - Retourne le segment de donnees courant (DS)}\par
{\f1     - Specifique au mode reel 16 bits}\par
\par
{\f1   Function SSeg : Word;}\par
{\f1     - Retourne le segment de pile courant (SS)}\par
{\f1     - Specifique au mode reel 16 bits}\par
\par
{\f1   Function SPtr : Word;}\par
{\f1     - Retourne le pointeur de pile courant (SP)}\par
{\f1     - Specifique au mode reel 16 bits}\par
\par
{\f1   NOTE : en Win32 (mode protege 32 bits a plat), CSeg, DSeg, SSeg}\par
{\f1   et SPtr ne sont plus significatifs. Les segments sont tous = 0}\par
{\f1   ou ont des selecteurs systeme.}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPSYS_08}     {\uldb Suivant >>}{\v IDH_TPSYS_10}     {\uldb Sommaire}{\v IDH_TPSYS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
