{\footnote # IDH_TPSYS_14}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - PARAMETRES DU PROGRAMME}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - PARAMETRES DU PROGRAMME}
\b\fs24 PROCEDURES ET FONCTIONS - PARAMETRES DU PROGRAMME \b0\fs20\par
\par
{\f1   Function ParamCount : Word;}\par
{\f1     - Retourne le nombre de parametres de la ligne de commande}\par
{\f1     - Le nom du programme n'est PAS compte}\par
{\f1     - Exemple : If ParamCount = 0 Then WriteLn('Usage: ...');}\par
\par
{\f1   Function ParamStr(N : Word) : String;}\par
{\f1     - Retourne le N-ieme parametre de la ligne de commande}\par
{\f1     - ParamStr(0) = nom et chemin du programme}\par
{\f1     - ParamStr(1) = premier parametre, etc.}\par
{\f1     - NOTE : ParamStr n'est PAS dans l'interface System standard,}\par
{\f1       mais est une procedure intrinseque du runtime.}\par
\par
