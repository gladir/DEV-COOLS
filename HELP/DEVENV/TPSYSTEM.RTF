\page

{\footnote # IDH_TPSYS_08}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - MEMOIRE ET POINTEURS}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - MEMOIRE ET POINTEURS}
\b\fs24 PROCEDURES ET FONCTIONS - MEMOIRE ET POINTEURS \b0\fs20\par
\par
\par
\b 8.1 Allocation dynamique \b0\par
\par
{\f1   Procedure New(Var p : Pointer);}\par
{\f1   Procedure New(Var p : Pointer; Init : Constructor);}\par
{\f1     - Alloue un bloc de memoire sur le tas de taille SizeOf(p^)}\par
{\f1     - p recoit l'adresse du bloc alloue}\par
{\f1     - La forme avec constructeur est pour les objets}\par
{\f1     - Exemple : New(P);    \{ alloue SizeOf(P^) octets \}}\par
\par
{\f1   Procedure Dispose(Var p : Pointer);}\par
{\f1   Procedure Dispose(Var p : Pointer; Destructor);}\par
{\f1     - Libere la memoire allouee par New}\par
{\f1     - La forme avec destructeur est pour les objets}\par
{\f1     - p devient invalide apres l'appel}\par
{\f1     - Exemple : Dispose(P);}\par
\par
{\f1   Procedure GetMem(Var p : Pointer; t : Word);}\par
{\f1     - Alloue t octets sur le tas}\par
{\f1     - Plus flexible que New (taille variable)}\par
{\f1     - Exemple : GetMem(P, 100);  \{ alloue 100 octets \}}\par
\par
{\f1   Procedure FreeMem(Var p : Pointer; t : Word);}\par
{\f1     - Libere t octets precedemment alloues par GetMem}\par
{\f1     - t DOIT etre identique a la taille passee a GetMem}\par
{\f1     - Exemple : FreeMem(P, 100);}\par
\par
{\f1   Procedure Mark(Var p : Pointer);}\par
{\f1     - Enregistre l'etat courant du tas dans p}\par
{\f1     - Utilise avec Release (methode ancienne)}\par
{\f1     - Deconseille : utiliser New/Dispose ou GetMem/FreeMem}\par
\par
{\f1   Procedure Release(Var p : Pointer);}\par
{\f1     - Libere toute la memoire du tas depuis la position Mark}\par
{\f1     - Toutes les allocations apres Mark sont perdues}\par
{\f1     - Deconseille : utiliser New/Dispose ou GetMem/FreeMem}\par
\par
\par
\b 8.2 Information memoire \b0\par
\par
{\f1   Function MaxAvail : LongInt;}\par
{\f1     - Retourne la taille du plus grand bloc contigu libre sur le tas}\par
{\f1     - En octets}\par
{\f1     - Exemple : If MaxAvail > 1000 Then GetMem(P, 1000);}\par
\par
{\f1   Function MemAvail : LongInt;}\par
{\f1     - Retourne la memoire totale libre sur le tas (tous blocs)}\par
{\f1     - En octets}\par
{\f1     - MemAvail >= MaxAvail}\par
\par
\par
\b 8.3 Fonctions de pointeur \b0\par
\par
{\f1   Function Addr(x) : Pointer;}\par
{\f1     - Retourne l'adresse de x (equivalent a @x)}\par
{\f1     - Exemple : P := Addr(MaVariable);}\par
\par
{\f1   Function Assigned(Var P) : Boolean;}\par
{\f1     - Retourne True si P n'est pas nil}\par
{\f1     - Equivalent a P <> nil mais plus lisible}\par
{\f1     - Disponible a partir de TP 7.0}\par
{\f1     - Exemple : If Assigned(P) Then P^.DoSomething;}\par
\par
{\f1   Function Ptr(seg, ofs : Word) : Pointer;}\par
{\f1     - Construit un pointeur a partir d'un segment et d'un offset}\par
{\f1     - Specifique au mode reel 16 bits}\par
{\f1     - Exemple : P := Ptr($B800, 0);  \{ debut de la memoire video \}}\par
\par
{\f1   Function Ofs(ident) : Word;}\par
{\f1     - Retourne l'offset d'un identifiant dans son segment}\par
{\f1     - Specifique au mode reel 16 bits}\par
{\f1     - Exemple : WriteLn(Ofs(MaVar));}\par
\par
{\f1   Function Seg(ident) : Word;     \{ Note : non dans l'interface ci-dessus \}}\par
{\f1     - Retourne le segment d'un identifiant}\par
{\f1     - Specifique au mode reel 16 bits}\par
\par
\par
\b 8.4 Operations sur la memoire \b0\par
\par
{\f1   Procedure Move(Const orig; Var dest; nbre : Word);}\par
{\f1     - Copie nbre octets de orig vers dest}\par
{\f1     - Les zones peuvent se chevaucher (copie dans le bon sens)}\par
{\f1     - Plus rapide que boucle manuelle (utilise REP MOVSB/MOVSD)}\par
{\f1     - Exemple : Move(Source, Dest, SizeOf(Source));}\par
\par
{\f1   Procedure FillChar(Var tampon; nbre : Word; val : Byte);}\par
{\f1   Procedure FillChar(Var tampon; nbre : Word; val : Char);}\par
{\f1     - Remplit nbre octets de tampon avec la valeur val}\par
{\f1     - Utilise pour initialiser des buffers a zero}\par
{\f1     - Exemple : FillChar(Buffer, SizeOf(Buffer), 0);}\par
{\f1     - Exemple : FillChar(S, SizeOf(S), ' ');}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPSYS_07}     {\uldb Suivant >>}{\v IDH_TPSYS_09}     {\uldb Sommaire}{\v IDH_TPSYS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
