{\footnote # IDH_TPSYS_03}
{\footnote $ Unite System - TYPES PREDEFINIS}
{\footnote K Turbo Pascal;Unite System;TYPES PREDEFINIS}
\b\fs24 TYPES PREDEFINIS \b0\fs20\par
\par
{\f1   Le langage Turbo Pascal definit les types suivants dans System :}\par
\par
{\f1   Types ordinaux :}\par
{\f1     Integer   = -32768..32767        (16 bits signe)}\par
{\f1     Word      = 0..65535             (16 bits non signe)}\par
{\f1     Byte      = 0..255               (8 bits non signe)}\par
{\f1     ShortInt  = -128..127            (8 bits signe)}\par
{\f1     LongInt   = -2147483648..2147483647  (32 bits signe)}\par
{\f1     Boolean   = False..True          (8 bits, 0 ou 1)}\par
{\f1     Char      = #0..#255             (8 bits, un caractere)}\par
\par
{\f1   Types reels :}\par
{\f1     Real      = 6 octets (format specifique Turbo Pascal)}\par
{\f1     Single    = 4 octets IEEE 754 (requiert coprocesseur)}\par
{\f1     Double    = 8 octets IEEE 754 (requiert coprocesseur)}\par
{\f1     Extended  = 10 octets IEEE 754 (requiert coprocesseur)}\par
{\f1     Comp      = 8 octets entier 64 bits (requiert coprocesseur)}\par
\par
{\f1   Types chaines :}\par
{\f1     String    = ShortString, String[255] par defaut}\par
{\f1     String[N] = chaine de N caracteres max (N = 1..255)}\par
{\f1     PChar     = ^Char (pointeur vers chaine ASCIIZ,}\par
{\f1                         disponible a partir de TP 7.0)}\par
\par
{\f1   Types pointeurs :}\par
{\f1     Pointer   = pointeur generique non type (Seg:Ofs en real mode)}\par
\par
{\f1   Types fichiers :}\par
{\f1     Text      = fichier texte (TextRec, 256 octets en real mode)}\par
{\f1     File      = fichier non type (FileRec)}\par
{\f1     File of T = fichier type (enregistrements de type T)}\par
\par
{\f1   Constantes speciales :}\par
{\f1     True      = Boolean(1)}\par
{\f1     False     = Boolean(0)}\par
{\f1     Nil       = pointeur nul}\par
{\f1     MaxInt    = 32767        \{ valeur maximale d'un Integer \}}\par
{\f1     MaxLongInt = 2147483647  \{ valeur maximale d'un LongInt (TP7) \}}\par
\par
\par
