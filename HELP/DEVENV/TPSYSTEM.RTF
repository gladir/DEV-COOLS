{\footnote # IDH_TPSYS_06}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - ARITHMETIQUE}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - ARITHMETIQUE}
\b\fs24 PROCEDURES ET FONCTIONS - ARITHMETIQUE \b0\fs20\par
\par
\par
\b 6.1 Fonctions entieres \b0\par
\par
{\f1   Function Abs(n : Integer) : Integer;}\par
{\f1   Function Abs(n : Real) : Real;}\par
{\f1     - Retourne la valeur absolue de n}\par
{\f1     - Exemple : Abs(-5) = 5}\par
\par
{\f1   Function Sqr(x : Integer) : Integer;}\par
{\f1   Function Sqr(x : Real) : Real;}\par
{\f1     - Retourne le carre de x (x * x)}\par
{\f1     - Exemple : Sqr(3) = 9}\par
\par
{\f1   Function Odd(i : LongInt) : Boolean;}\par
{\f1     - Retourne True si i est impair}\par
{\f1     - Equivalent a (i And 1) = 1}\par
{\f1     - Exemple : Odd(3) = True, Odd(4) = False}\par
\par
\par
\b 6.2 Fonctions reelles \b0\par
\par
{\f1   Function Sqrt(r : Real) : Real;}\par
{\f1     - Retourne la racine carree de r}\par
{\f1     - r doit etre >= 0}\par
{\f1     - Exemple : Sqrt(9.0) = 3.0}\par
\par
{\f1   Function Sin(r : Real) : Real;}\par
{\f1     - Retourne le sinus de r (r en radians)}\par
\par
{\f1   Function Cos(r : Real) : Real;}\par
{\f1     - Retourne le cosinus de r (r en radians)}\par
\par
{\f1   Function ArcTan(r : Real) : Real;}\par
{\f1     - Retourne l'arc tangente de r (en radians)}\par
\par
{\f1   Function Exp(r : Real) : Real;}\par
{\f1     - Retourne e^r (exponentielle)}\par
\par
{\f1   Function Ln(r : Real) : Real;}\par
{\f1     - Retourne le logarithme neperien de r}\par
{\f1     - r doit etre > 0}\par
\par
{\f1   Function Frac(r : Real) : Real;}\par
{\f1     - Retourne la partie fractionnaire de r}\par
{\f1     - Exemple : Frac(3.14) = 0.14}\par
\par
{\f1   Function Int(r : Real) : Real;}\par
{\f1     - Retourne la partie entiere de r (comme Real)}\par
{\f1     - Exemple : Int(3.14) = 3.0}\par
\par
\par
\b 6.3 Fonctions de conversion \b0\par
\par
{\f1   Function Round(n : Real) : LongInt;}\par
{\f1     - Arrondit un reel a l'entier le plus proche}\par
{\f1     - Exemple : Round(3.6) = 4, Round(3.4) = 3}\par
\par
{\f1   Function Trunc(r : Real) : LongInt;}\par
{\f1     - Tronque un reel (supprime la partie decimale)}\par
{\f1     - Exemple : Trunc(3.9) = 3, Trunc(-3.9) = -3}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPSYS_05}     {\uldb Suivant >>}{\v IDH_TPSYS_07}     {\uldb Sommaire}{\v IDH_TPSYS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPSYS_07}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - ORDINAUX}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - ORDINAUX}
\b\fs24 PROCEDURES ET FONCTIONS - ORDINAUX \b0\fs20\par
\par
{\f1   Function Ord(s) : LongInt;}\par
{\f1     - Retourne la valeur ordinale de s}\par
{\f1     - Pour Char : code ASCII (Ord('A') = 65)}\par
{\f1     - Pour Boolean : Ord(False) = 0, Ord(True) = 1}\par
{\f1     - Pour enumeration : indice dans le type}\par
{\f1     - Exemple : Ord(S[0]) = longueur de la chaine S}\par
\par
{\f1   Function Chr(i : Byte) : Char;}\par
{\f1     - Retourne le caractere de code ASCII i}\par
{\f1     - Inverse de Ord pour les Char}\par
{\f1     - Exemple : Chr(65) = 'A', Chr(13) = CR}\par
\par
{\f1   Function Pred(s) : <meme type>;}\par
{\f1     - Retourne le predecesseur de s}\par
{\f1     - Pour Integer : Pred(N) = N - 1}\par
{\f1     - Pour Char : Pred('B') = 'A'}\par
{\f1     - Pour enumeration : element precedent}\par
{\f1     - Erreur si s est le premier element du type}\par
\par
{\f1   Function Succ(s) : <meme type>;}\par
{\f1     - Retourne le successeur de s}\par
{\f1     - Pour Integer : Succ(N) = N + 1}\par
{\f1     - Pour Char : Succ('A') = 'B'}\par
{\f1     - Erreur si s est le dernier element du type}\par
\par
{\f1   Procedure Inc(Var s);}\par
{\f1   Procedure Inc(Var s; n : LongInt);}\par
{\f1     - Incremente s de 1 (ou de n)}\par
{\f1     - Plus efficace que s := s + 1 (genere INC en assembleur)}\par
{\f1     - Fonctionne avec tous les types ordinaux et pointeurs}\par
{\f1     - Exemple : Inc(I);      \{ I := I + 1 \}}\par
{\f1     - Exemple : Inc(I, 5);   \{ I := I + 5 \}}\par
\par
{\f1   Procedure Dec(Var s);}\par
{\f1   Procedure Dec(Var s; n : LongInt);}\par
{\f1     - Decremente s de 1 (ou de n)}\par
{\f1     - Plus efficace que s := s - 1 (genere DEC en assembleur)}\par
{\f1     - Exemple : Dec(I);      \{ I := I - 1 \}}\par
{\f1     - Exemple : Dec(I, 5);   \{ I := I - 5 \}}\par
\par
{\f1   Function Hi(i : Word) : Byte;}\par
{\f1     - Retourne l'octet de poids fort de i}\par
{\f1     - Equivalent a (i Shr 8) And $FF}\par
{\f1     - Exemple : Hi($1234) = $12}\par
\par
{\f1   Function Lo(i : Word) : Byte;}\par
{\f1     - Retourne l'octet de poids faible de i}\par
{\f1     - Equivalent a i And $FF}\par
{\f1     - Exemple : Lo($1234) = $34}\par
\par
{\f1   Function Swap(i : Word) : Word;}\par
{\f1     - Echange les octets haut et bas de i}\par
{\f1     - Exemple : Swap($1234) = $3412}\par
\par
\par
