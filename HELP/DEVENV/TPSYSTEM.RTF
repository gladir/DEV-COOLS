{\footnote # IDH_TPSYS_11}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - ENSEMBLES}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - ENSEMBLES}
\b\fs24 PROCEDURES ET FONCTIONS - ENSEMBLES \b0\fs20\par
\par
{\f1   Procedure Include(Var S : Set of T; I : T);}\par
{\f1     - Ajoute l'element I a l'ensemble S}\par
{\f1     - Plus efficace que S := S + [I]}\par
{\f1     - Disponible a partir de TP 7.0}\par
{\f1     - Exemple : Include(MonSet, 'A');}\par
\par
{\f1   Procedure Exclude(Var S : Set of T; I : T);}\par
{\f1     - Retire l'element I de l'ensemble S}\par
{\f1     - Plus efficace que S := S - [I]}\par
{\f1     - Disponible a partir de TP 7.0}\par
{\f1     - Exemple : Exclude(MonSet, 'A');}\par
\par
\par
{\uldb << Precedent}{\v IDH_TPSYS_10}     {\uldb Suivant >>}{\v IDH_TPSYS_12}     {\uldb Sommaire}{\v IDH_TPSYS_01}     {\uldb Turbo Pascal}{\v IDH_TP_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_TPSYS_12}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - CONTROLE DU PROGRAMME}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - CONTROLE DU PROGRAMME}
\b\fs24 PROCEDURES ET FONCTIONS - CONTROLE DU PROGRAMME \b0\fs20\par
\par
{\f1   Procedure Halt;}\par
{\f1   Procedure Halt(nbre : Word);}\par
{\f1     - Termine le programme immediatement}\par
{\f1     - nbre = code de sortie (0 par defaut = pas d'erreur)}\par
{\f1     - Les procedures ExitProc sont executees}\par
{\f1     - Les fichiers ne sont PAS fermes automatiquement}\par
{\f1     - Exemple : Halt(1);  \{ sortie avec erreur \}}\par
\par
{\f1   Procedure RunError(nbre : Word);}\par
{\f1     - Genere une erreur d'execution avec le code nbre}\par
{\f1     - Affiche le message d'erreur et termine le programme}\par
{\f1     - Codes courants :}\par
{\f1         1   = invalide function number}\par
{\f1         2   = file not found}\par
{\f1         3   = path not found}\par
{\f1         4   = too many open files}\par
{\f1         5   = file access denied}\par
{\f1         6   = invalid file handle}\par
{\f1         12  = invalid file access code}\par
{\f1         15  = invalid drive number}\par
{\f1         16  = cannot remove current directory}\par
{\f1         17  = cannot rename across drives}\par
{\f1         100 = disk read error}\par
{\f1         101 = disk write error}\par
{\f1         102 = file not assigned}\par
{\f1         103 = file not open}\par
{\f1         104 = file not open for input}\par
{\f1         105 = file not open for output}\par
{\f1         106 = invalid numeric format}\par
{\f1         150 = disk is write-protected}\par
{\f1         151 = bad drive request struct length}\par
{\f1         152 = drive not ready}\par
{\f1         154 = CRC error in data}\par
{\f1         156 = disk seek error}\par
{\f1         157 = unknown media type}\par
{\f1         158 = sector not found}\par
{\f1         159 = printer out of paper}\par
{\f1         160 = device write fault}\par
{\f1         161 = device read fault}\par
{\f1         162 = hardware failure}\par
{\f1         200 = division by zero}\par
{\f1         201 = range check error}\par
{\f1         202 = stack overflow error}\par
{\f1         203 = heap overflow error}\par
{\f1         204 = invalid pointer operation}\par
{\f1         205 = floating-point overflow}\par
{\f1         206 = floating-point underflow}\par
{\f1         207 = invalid floating-point operation}\par
\par
\par
