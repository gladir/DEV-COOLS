{\footnote # IDH_TPSYS_13}
{\footnote $ Unite System - PROCEDURES ET FONCTIONS - ALEATOIRE}
{\footnote K Turbo Pascal;Unite System;PROCEDURES ET FONCTIONS - ALEATOIRE}
\b\fs24 PROCEDURES ET FONCTIONS - ALEATOIRE \b0\fs20\par
\par
{\f1   Function Random(max : Word) : Word;}\par
{\f1   Function Random : Real;}\par
{\f1     - Retourne un nombre pseudo-aleatoire}\par
{\f1     - Random(N) retourne un Word dans [0..N-1]}\par
{\f1     - Random (sans argument) retourne un Real dans [0.0..1.0[}\par
{\f1     - Utilise RandSeed comme graine}\par
{\f1     - Exemple : D := Random(6) + 1;  \{ de 1en : 1..6 \}}\par
\par
{\f1   Procedure Randomize;}\par
{\f1     - Initialise RandSeed a partir de l'horloge systeme}\par
{\f1     - Doit etre appele une seule fois, au debut du programme}\par
{\f1     - Sans appel a Randomize, RandSeed = 0 et la sequence}\par
{\f1       pseudo-aleatoire est toujours la meme}\par
{\f1     - Exemple :}\par
{\f1         Randomize;}\par
{\f1         WriteLn(Random(100));}\par
\par
