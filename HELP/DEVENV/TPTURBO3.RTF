{\footnote # IDH_TPT3_09}
{\footnote $ Compatibilite TP3 - EXEMPLES}
{\footnote K Turbo Pascal;Compatibilite TP3;EXEMPLES}
\b\fs24 EXEMPLES \b0\fs20\par
\par
{\f1   --- Exemple 1 : Programme typique TP3 migr?? ---}\par
\par
{\f1   program OldProgram;}\par
{\f1   uses Turbo3;}\par
{\f1   var}\par
{\f1     Ch   : Char;}\par
{\f1     F    : file of Integer;}\par
{\f1     Size : Real;}\par
{\f1   begin}\par
{\f1     CBreak := False;}\par
\par
{\f1     Write('Appuyez sur une touche : ');}\par
{\f1     Read(Kbd, Ch);}\par
{\f1     WriteLn;}\par
{\f1     WriteLn('Touche : ', Ch);}\par
\par
{\f1     WriteLn('M??moire libre : ', MemAvail, ' (unit??s TP3)');}\par
{\f1     WriteLn('Plus grand bloc : ', MaxAvail, ' (unit??s TP3)');}\par
\par
{\f1     Assign(F, 'DATA.DAT');}\par
{\f1     \{$I-\}}\par
{\f1     Reset(F);}\par
{\f1     if IOresult = 0 then}\par
{\f1     begin}\par
{\f1       Size := LongFileSize(F);}\par
{\f1       WriteLn('Taille fichier : ', Size:0:0, ' enregistrements');}\par
{\f1       Close(F);}\par
{\f1     end}\par
{\f1     else}\par
{\f1       WriteLn('Fichier non trouv??');}\par
{\f1     \{$I+\}}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : Utilisation des attributs vid??o ---}\par
\par
{\f1   program VideoDemo;}\par
{\f1   uses Turbo3;}\par
{\f1   begin}\par
{\f1     NormVideo;}\par
{\f1     WriteLn('Texte normal');}\par
\par
{\f1     HighVideo;}\par
{\f1     WriteLn('Texte haute intensit??');}\par
\par
{\f1     LowVideo;}\par
{\f1     WriteLn('Texte basse intensit??');}\par
\par
{\f1     NormVideo;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Navigation dans un gros fichier ---}\par
\par
{\f1   program BigFileNav;}\par
{\f1   uses Turbo3;}\par
{\f1   var}\par
{\f1     F   : file of Byte;}\par
{\f1     B   : Byte;}\par
{\f1     Pos : Real;}\par
{\f1   begin}\par
{\f1     Assign(F, 'BIGFILE.BIN');}\par
{\f1     \{$I-\}}\par
{\f1     Reset(F);}\par
{\f1     \{$I+\}}\par
{\f1     if IOresult <> 0 then}\par
{\f1     begin}\par
{\f1       WriteLn('Erreur ouverture');}\par
{\f1       Halt(1);}\par
{\f1     end;}\par
\par
{\f1     WriteLn('Taille : ', LongFileSize(F):0:0, ' octets');}\par
\par
{\f1     \{ Aller au milieu du fichier \}}\par
{\f1     Pos := LongFileSize(F) / 2;}\par
{\f1     LongSeek(F, Pos);}\par
{\f1     WriteLn('Position : ', LongFilePos(F):0:0);}\par
\par
{\f1     Read(F, B);}\par
{\f1     WriteLn('Octet lu : ', B);}\par
\par
{\f1     Close(F);}\par
{\f1   end.}\par
\par
\par
