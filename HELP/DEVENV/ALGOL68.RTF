{\footnote # IDH_ALGOL68_15}
{\footnote $ Algol 68 - TABLEAUX ET TRANCHES (ROW)}
{\footnote K Algol 68 tableaux;ROW;tranches;indexation;bornes}
\b\fs24 TABLEAUX ET TRANCHES (ROW) \b0\fs20\par
\par
{\f1   15.1 Declaration de tableau}\par
{\f1        [1:10] INT a          CO tableau de 10 entiers CO}\par
{\f1        [1:5] INT b := (10, 20, 30, 40, 50)}\par
\par
{\f1        Les bornes sont flexibles (pas seulement 0 ou 1).}\par
\par
{\f1   15.2 Descripteur de tableau}\par
{\f1        Chaque tableau possede un descripteur :}\par
{\f1        (lwb, upb, taille_elem, ptr_data)}\par
\par
{\f1   15.3 Acces par index}\par
{\f1        a[3]      CO troisieme element CO}\par
\par
{\f1        Verification de bornes a l execution : erreur si hors limites.}\par
\par
{\f1   15.4 Tranche (trimming)}\par
{\f1        a[2:4]    CO sous-tableau a[2], a[3], a[4] CO}\par
\par
{\f1        Memes donnees, bornes modifiees.}\par
\par
{\f1   15.5 Bornes LWB et UPB}\par
{\f1        LWB a     CO borne inferieure CO}\par
{\f1        UPB a     CO borne superieure CO}\par
\par
{\f1   15.6 STRING comme tableau}\par
{\f1        STRING est equivalent a un tableau flexible de CHAR : [1:n] CHAR}\par
\par
{\f1        STRING msg = "Algol 68";}\par
{\f1        STRING sub = msg[1:5];        CO tranche CO}\par
{\f1        STRING s3 = s1 + s2;          CO concatenation CO}\par
\par
{\f1   15.7 Constructeur de rangee}\par
{\f1        (1, 2, 3) en contexte de rowing.}\par
\par
\par
\par
