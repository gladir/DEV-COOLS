{\footnote # IDH_ALGOL68_17}
{\footnote $ Algol 68 - DEFINITIONS D OPERATEURS (OP ET PRIO)}
{\footnote K Algol 68 operateurs definis;OP;PRIO;surcharge}
\b\fs24 DEFINITIONS D OPERATEURS (OP ET PRIO) \b0\fs20\par
\par
{\f1   17.1 Operateur dyadique}\par
{\f1        OP ADDX = (INT a, INT b) INT : a + b + 1;}\par
{\f1        INT r := 10 ADDX 20;   CO r = 31 CO}\par
\par
{\f1   17.2 Operateur monadique}\par
{\f1        OP DBL = (INT x) INT : x + x;}\par
{\f1        INT r := DBL 7;        CO r = 14 CO}\par
\par
{\f1   17.3 Declaration de priorite}\par
{\f1        PRIO MYMUL = 5;}\par
{\f1        OP MYMUL = (INT a, INT b) INT : a * b;}\par
\par
{\f1        Les priorites vont de 1 (faible) a 9 (fort).}\par
\par
{\f1   17.4 Surcharge d operateurs}\par
{\f1        Un meme symbole peut etre defini pour differents modes}\par
{\f1        d operandes. La resolution se fait par le mode des operandes.}\par
\par
{\f1   17.5 Operateurs d affectation}\par
{\f1        OP +:= = (REF INT a, INT b) REF INT : ...}\par
\par
\par
\par
