{\footnote # IDH_ALGOL68_12}
{\footnote $ Algol 68 - CLAUSES REPETITIVES (BOUCLES)}
{\footnote K Algol 68 boucles;FOR;FROM;TO;BY;WHILE;DO;OD}
\b\fs24 CLAUSES REPETITIVES (BOUCLES) \b0\fs20\par
\par
Forme generale :\par
\par
{\f1   FOR ident FROM debut TO fin BY pas WHILE condition DO}\par
{\f1     unites}\par
{\f1   OD}\par
\par
Tous les mots-cles sauf DO et OD sont optionnels.\par
\par
{\f1   12.1 FOR ident}\par
{\f1        Variable de boucle locale, de mode INT, non modifiable dans}\par
{\f1        le corps. Si absent, pas de variable de boucle.}\par
\par
{\f1   12.2 FROM debut}\par
{\f1        Valeur initiale (defaut 1).}\par
\par
{\f1   12.3 TO fin}\par
{\f1        Borne superieure. Si absent, la boucle est potentiellement}\par
{\f1        infinie (sauf WHILE).}\par
\par
{\f1   12.4 BY pas}\par
{\f1        Increment a chaque iteration (defaut 1). Peut etre negatif.}\par
\par
{\f1   12.5 WHILE condition}\par
{\f1        Condition testee avant chaque iteration. Permet des boucles}\par
{\f1        WHILE pures : WHILE cond DO ... OD}\par
\par
{\f1   Exemples :}\par
\par
{\f1     CO Boucle FOR classique CO}\par
{\f1     FOR i FROM 1 TO 10 DO}\par
{\f1       print((i, newline))}\par
{\f1     OD}\par
\par
{\f1     CO Boucle avec pas CO}\par
{\f1     FOR k FROM 1 TO 10 BY 2 DO}\par
{\f1       print((k, " "))}\par
{\f1     OD}\par
\par
{\f1     CO Boucle WHILE pure CO}\par
{\f1     INT n := 100;}\par
{\f1     WHILE n > 1 DO}\par
{\f1       n := n OVER 2}\par
{\f1     OD}\par
\par
{\f1     CO Boucle FOR avec WHILE CO}\par
{\f1     INT total := 0;}\par
{\f1     FOR n FROM 1 TO 100 WHILE total < 50 DO}\par
{\f1       total +:= n}\par
{\f1     OD}\par
\par
{\f1     CO Boucle infinie CO}\par
{\f1     DO ... OD}\par
\par
\par
\par
