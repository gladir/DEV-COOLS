{\footnote # IDH_ALGOL68_18}
{\footnote $ Algol 68 - MODES UNIS (UNION) ET CLAUSES DE CONFORMITE}
{\footnote K Algol 68 unions;UNION;CASE conformite}
\b\fs24 MODES UNIS (UNION) ET CLAUSES DE CONFORMITE \b0\fs20\par
\par
{\f1   18.1 Declaration de mode UNION}\par
{\f1        MODE NOMBRE = UNION(INT, REAL);}\par
\par
{\f1        Un mode uni peut contenir une valeur de l un des modes}\par
{\f1        alternatifs.}\par
\par
{\f1   18.2 Representation interne}\par
{\f1        Discriminant (mot de 16 bits) + donnees (taille = max des}\par
{\f1        alternatives).}\par
\par
{\f1   18.3 Unification (coercition)}\par
{\f1        INT -> UNION(INT, REAL) : stocker la valeur avec son}\par
{\f1        discriminant.}\par
\par
{\f1   18.4 Clause de conformite}\par
{\f1        CASE expr IN}\par
{\f1          (INT i) : utiliser i,}\par
{\f1          (REAL r) : utiliser r}\par
{\f1        OUT}\par
{\f1          traitement par defaut}\par
{\f1        ESAC}\par
\par
{\f1        Chaque alternative lie un identificateur local au contenu}\par
{\f1        extrait de l union.}\par
\par
{\f1   18.5 EMPTY}\par
{\f1        Union vide (aucune alternative selectionnee).}\par
\par
\par
\par
