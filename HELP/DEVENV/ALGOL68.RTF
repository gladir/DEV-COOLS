{\footnote # IDH_ALGOL68_09}
{\footnote $ Algol 68 - EXPRESSIONS ET FORMULES}
{\footnote K Algol 68 expressions;formules;unitaires}
\b\fs24 EXPRESSIONS ET FORMULES \b0\fs20\par
\par
{\f1   9.1 Expressions primaires}\par
{\f1       - Denotation (litteral)}\par
{\f1       - Identificateur (recherche dans la table des symboles)}\par
{\f1       - Clause fermee : (expr) ou BEGIN expr END}\par
{\f1       - Appel de procedure : nom(args)}\par
{\f1       - Selection de champ : champ OF structure}\par
{\f1       - Indexation de tableau : tableau[indice]}\par
{\f1       - Tranche de tableau : tableau[lo:up]}\par
{\f1       - SKIP (valeur indefinie) et NIL (reference nulle)}\par
\par
{\f1   9.2 Formules}\par
{\f1       Les formules sont des expressions composees d operateurs et}\par
{\f1       d operandes, analysees par descente de Pratt avec priorites 1 a 9.}\par
\par
{\f1       Exemples :}\par
{\f1         a + b * c          CO priorite : * avant + CO}\par
{\f1         ABS x + SIGN y     CO unaires avant binaires CO}\par
{\f1         x = 5 AND y > 0    CO comparaison puis logique CO}\par
\par
{\f1   9.3 Affectation}\par
{\f1       destination := source}\par
{\f1       La destination doit etre de mode REF M.}\par
\par
{\f1       Affectation inversee : source =: destination}\par
\par
{\f1   9.4 Test d identite}\par
{\f1       expr1 IS expr2      (meme reference)}\par
{\f1       expr1 ISNT expr2    (references differentes)}\par
{\f1       expr IS NIL          (test de reference nulle)}\par
\par
\par
\par
