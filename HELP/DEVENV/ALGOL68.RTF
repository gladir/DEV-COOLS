{\footnote # IDH_ALGOL68_08}
{\footnote $ Algol 68 - DECLARATIONS D IDENTITE ET DE VARIABLE}
{\footnote K Algol 68 declarations identite;variable;LOC;HEAP}
\b\fs24 DECLARATIONS D IDENTITE ET DE VARIABLE \b0\fs20\par
\par
{\f1   8.1 Declaration d identite (constante)}\par
{\f1       MODE nom = valeur;}\par
\par
{\f1       Exemples :}\par
{\f1         INT answer = 42;}\par
{\f1         STRING greeting = "Hello";}\par
{\f1         BOOL flag = TRUE;}\par
\par
{\f1   8.2 Declaration de variable}\par
{\f1       MODE nom := valeur;}\par
\par
{\f1       La forme abregee ?? INT x := 42 ?? cree implicitement un}\par
{\f1       REF INT local initialise a 42.}\par
\par
{\f1       Forme longue : REF INT x = LOC INT := 42;}\par
\par
{\f1   8.3 Allocation locale (LOC)}\par
{\f1       LOC MODE : allocation sur la pile dans le cadre courant.}\par
{\f1       Adresse relative a BP : [BP - offset]}\par
\par
{\f1   8.4 Allocation dynamique (HEAP)}\par
{\f1       HEAP MODE : allocation sur le tas.}\par
{\f1       Appel a la routine runtime _A68RT_ALLOC.}\par
\par
{\f1   8.5 Declarations multiples}\par
{\f1       INT a = 1, b = 2, c = 3;}\par
\par
{\f1   8.6 Declaration REF explicite}\par
{\f1       REF INT p = x;}\par
{\f1       p est un alias (meme adresse) vers la variable x.}\par
\par
\par
\par
