{\footnote # IDH_ALGOL68_10}
{\footnote $ Algol 68 - CLAUSES FERMEES ET CLAUSES SERIE}
{\footnote K Algol 68 clauses fermees;serie;BEGIN;END}
\b\fs24 CLAUSES FERMEES ET CLAUSES SERIE \b0\fs20\par
\par
{\f1   10.1 Clause fermee (closed clause)}\par
{\f1        BEGIN suite_d_unites END}\par
{\f1        ( suite_d_unites )}\par
\par
{\f1        Ouvre une nouvelle portee lexicale. La valeur de la clause}\par
{\f1        est la valeur de la derniere unite.}\par
\par
{\f1        Exemple :}\par
{\f1          INT r := BEGIN INT x := 5; x + 1 END   CO r = 6 CO}\par
\par
{\f1   10.2 Clause serie (serial clause)}\par
{\f1        Suite d unites separees par des points-virgules.}\par
{\f1        La valeur est celle de la derniere unite.}\par
\par
{\f1        Exemple :}\par
{\f1          INT a := 1; INT b := 2; a + b   CO valeur = 3 CO}\par
\par
{\f1   10.3 Labels (etiquettes)}\par
{\f1        etiquette: unite}\par
{\f1        GO TO etiquette  ou  GOTO etiquette}\par
\par
{\f1        Exemple :}\par
{\f1          boucle: x +:= 1;}\par
{\f1          IF x < 10 THEN GOTO boucle FI}\par
\par
\par
\par
