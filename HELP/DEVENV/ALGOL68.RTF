{\footnote # IDH_ALGOL68_22}
{\footnote $ Algol 68 - RUNTIME MINIMAL}
{\footnote K Algol 68 runtime;minimal;bibliotheque}
\b\fs24 RUNTIME MINIMAL \b0\fs20\par
\par
Le compilateur AL68C86 genere des appels a un ensemble de routines\par
runtime assembleur 8086, emises dans le segment de code.\par
\par
{\f1   Routine               Description}\par
{\f1   --------------------  ------------------------------------------}\par
{\f1   _A68RT_PRINT          Ecriture bloc sur handle (INT 21h AH=40h)}\par
{\f1   _A68RT_PRINTLN        Ecriture chaine + CR+LF sur stdout}\par
{\f1   _A68RT_STRLEN         Longueur d une chaine ASCIIZ -> AX}\par
{\f1   _A68RT_PRINTINT       Entier signe -> ASCII + ecriture stdout}\par
{\f1   _A68RT_PRINTBOOL      Ecrire TRUE ou FALSE}\par
{\f1   _A68RT_READINT        Lecture chaine + conversion -> AX}\par
{\f1   _A68RT_READCHAR       Lecture d un caractere (INT 21h AH=01h)}\par
{\f1   _A68RT_READLINE       Lecture d une ligne stdin}\par
{\f1   _A68RT_NUMTOSTR       Entier -> chaine ASCII (itoa)}\par
{\f1   _A68RT_STRTONUM       Chaine ASCII -> entier (atoi)}\par
{\f1   _A68RT_CONCAT         Concatenation de deux STRING -> AX=ptr}\par
{\f1   _A68RT_STRCMP          Comparaison de chaines -> drapeaux ZF/CF}\par
{\f1   _A68RT_STRTRIM        Tranche de chaine -> AX=ptr}\par
{\f1   _A68RT_ALLOC          Allocation sur le tas -> AX=ptr}\par
{\f1   _A68RT_POWER          Exponentiation entiere -> AX}\par
{\f1   _A68RT_ABS            Valeur absolue -> AX}\par
{\f1   _A68RT_ODD            Test de parite -> AX=0|1}\par
{\f1   _A68RT_SIGN           Signe -> AX=-1|0|1}\par
{\f1   _A68RT_CHKIDX         Verification de bornes de tableau}\par
{\f1   _A68RT_CHKNIL         Verification de reference nulle}\par
{\f1   _A68RT_PANIC          Message d erreur + terminaison (exit 1)}\par
\par
{\f1   Donnees runtime :}\par
{\f1     _A68_HEAP      : tas statique de 4096 octets}\par
{\f1     _A68_HEAPTOP   : pointeur sommet du tas}\par
{\f1     _A68_CRLF      : constante CR+LF (13, 10, 0)}\par
{\f1     _A68_STRBUF    : tampon de travail pour les chaines}\par
{\f1     _A68_STRPOOL   : pool de chaines dynamiques}\par
\par
\par
\par
