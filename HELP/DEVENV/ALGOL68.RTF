{\footnote # IDH_ALGOL68_24}
{\footnote $ Algol 68 - GRAMMAIRE BNF}
{\footnote K Algol 68 grammaire BNF;syntaxe;Van Wijngaarden}
\b\fs24 GRAMMAIRE BNF \b0\fs20\par
\par
{\f1   <programme>    ::= <clause-fermee>}\par
\par
{\f1   <clause-fermee>}\par
{\f1                  ::= BEGIN <clause-serie> END}\par
{\f1                    | '(' <clause-serie> ')'}\par
\par
{\f1   <clause-serie> ::= \{ <declaration> ';' \} <unite>}\par
{\f1                       \{ ';' <unite> \}}\par
\par
{\f1   <declaration>  ::= <decl-identite>}\par
{\f1                    | <decl-variable>}\par
{\f1                    | <decl-mode>}\par
{\f1                    | <decl-proc>}\par
{\f1                    | <decl-op>}\par
{\f1                    | <decl-prio>}\par
{\f1                    | <label>}\par
\par
{\f1   <decl-identite>}\par
{\f1                  ::= <mode> <ident> '=' <unite>}\par
{\f1                       \{ ',' <ident> '=' <unite> \}}\par
\par
{\f1   <decl-variable>}\par
{\f1                  ::= <mode> <ident> ':=' <unite>}\par
{\f1                       \{ ',' <ident> ':=' <unite> \}}\par
{\f1                    | REF <mode> <ident> '=' LOC <mode> ':=' <unite>}\par
{\f1                    | HEAP <mode> <ident>}\par
\par
{\f1   <decl-mode>    ::= MODE <ident> '=' <mode-ind>}\par
\par
{\f1   <decl-proc>    ::= PROC <ident> '=' '(' <params> ')' <mode> ':'}\par
{\f1                         <unite>}\par
\par
{\f1   <decl-op>      ::= OP <op-symbole> '=' '(' <params> ')' <mode> ':'}\par
{\f1                         <unite>}\par
\par
{\f1   <decl-prio>    ::= PRIO <op-symbole> '=' <entier>}\par
\par
{\f1   <label>        ::= <ident> ':'}\par
\par
{\f1   <mode-ind>     ::= INT | REAL | BOOL | CHAR | BITS | BYTES}\par
{\f1                    | COMPL | STRING | VOID}\par
{\f1                    | STRUCT '(' <champs> ')'}\par
{\f1                    | UNION '(' <modes-liste> ')'}\par
{\f1                    | REF <mode-ind>}\par
{\f1                    | PROC '(' <modes-liste> ')' <mode-ind>}\par
{\f1                    | '[' <unite> ':' <unite> ']' <mode-ind>}\par
{\f1                    | <ident>}\par
\par
{\f1   <champs>       ::= <mode-ind> <ident>}\par
{\f1                       \{ ',' <mode-ind> <ident> \}}\par
\par
{\f1   <modes-liste>  ::= <mode-ind> \{ ',' <mode-ind> \}}\par
\par
{\f1   <params>       ::= <mode-ind> <ident>}\par
{\f1                       \{ ',' <mode-ind> <ident> \}}\par
{\f1                    |  CO vide CO}\par
\par
{\f1   <unite>        ::= <formule>}\par
{\f1                    | <affectation>}\par
{\f1                    | <clause-fermee>}\par
{\f1                    | <clause-cond>}\par
{\f1                    | <clause-cas>}\par
{\f1                    | <clause-boucle>}\par
{\f1                    | <clause-collat>}\par
{\f1                    | SKIP | NIL | EMPTY}\par
{\f1                    | GO TO <ident> | GOTO <ident>}\par
\par
{\f1   <affectation>  ::= <destination> ':=' <unite>}\par
{\f1                    | <unite> '=:' <destination>}\par
\par
{\f1   <destination>  ::= <ident>}\par
{\f1                    | <selection>}\par
{\f1                    | <indexation>}\par
\par
{\f1   <formule>      ::= <monadique> <operande>}\par
{\f1                    | <operande> <dyadique> <operande>}\par
{\f1                    | <operande>}\par
\par
{\f1   <operande>     ::= <primaire> \{ <dyadique> <primaire> \}}\par
\par
{\f1   <primaire>     ::= <denotation>}\par
{\f1                    | <ident>}\par
{\f1                    | <ident> '(' <args> ')'}\par
{\f1                    | <champ> OF <primaire>}\par
{\f1                    | <primaire> '[' <indice> ']'}\par
{\f1                    | <primaire> '[' <unite> ':' <unite> ']'}\par
{\f1                    | '(' <unite> ')'}\par
\par
{\f1   <args>         ::= <unite> \{ ',' <unite> \}}\par
\par
{\f1   <indice>       ::= <unite>}\par
\par
{\f1   <selection>    ::= <ident> OF <primaire>}\par
\par
{\f1   <indexation>   ::= <primaire> '[' <indice> ']'}\par
\par
{\f1   <clause-cond>  ::= IF <unite> THEN <clause-serie>}\par
{\f1                       \{ ELIF <unite> THEN <clause-serie> \}}\par
{\f1                       [ ELSE <clause-serie> ] FI}\par
{\f1                    | '(' <unite> '|' <unite> '|' <unite> ')'}\par
\par
{\f1   <clause-cas>   ::= CASE <unite> IN <unite> \{ ',' <unite> \}}\par
{\f1                       [ OUT <clause-serie> ] ESAC}\par
{\f1                    | '(' <unite> '|' <unite> \{ ',' <unite> \}}\par
{\f1                       [ '|' <unite> ] ')'}\par
\par
{\f1   <clause-conform>}\par
{\f1                  ::= CASE <unite> IN}\par
{\f1                       '(' <mode-ind> <ident> ')' ':' <unite>}\par
{\f1                       \{ ',' '(' <mode-ind> <ident> ')' ':' <unite> \}}\par
{\f1                       [ OUT <clause-serie> ] ESAC}\par
\par
{\f1   <clause-boucle>}\par
{\f1                  ::= [ FOR <ident> ]}\par
{\f1                      [ FROM <unite> ]}\par
{\f1                      [ TO <unite> | DOWNTO <unite> ]}\par
{\f1                      [ BY <unite> ]}\par
{\f1                      [ WHILE <unite> ]}\par
{\f1                      DO <clause-serie> OD}\par
\par
{\f1   <clause-collat>}\par
{\f1                  ::= '(' <unite> ',' <unite> \{ ',' <unite> \} ')'}\par
{\f1                    | PAR '(' <unite> \{ ',' <unite> \} ')'}\par
\par
{\f1   <monadique>    ::= NOT | ABS | ARG | BIN | CONJ | IM | LENG}\par
{\f1                    | LEVEL | ODD | RE | REPR | ROUND | SHORTEN}\par
{\f1                    | SIGN | '-' | <op-symbole>}\par
\par
{\f1   <dyadique>     ::= '+' | '-' | '*' | '/' | OVER | MOD | '**'}\par
{\f1                    | '=' | '/=' | '<' | '<=' | '>' | '>='}\par
{\f1                    | AND | OR | SHL | SHR | ELEM | UP | DOWN}\par
{\f1                    | '+*' | I | <op-symbole>}\par
\par
{\f1   <denotation>   ::= <entier> | <reel> | <chaine> | <caractere>}\par
{\f1                    | TRUE | FALSE}\par
\par
{\f1   <entier>       ::= chiffre \{ chiffre \}}\par
{\f1                    | <base> 'r' <chiffres-base>}\par
\par
{\f1   <reel>         ::= chiffre \{ chiffre \} '.' chiffre \{ chiffre \}}\par
{\f1                       [ ('e' | 'E') ['+' | '-'] chiffre \{ chiffre \} ]}\par
\par
{\f1   <chaine>       ::= '"' \{ caractere | '""' \} '"'}\par
\par
{\f1   <caractere>    ::= '"' un_caractere '"'}\par
\par
{\f1   <ident>        ::= lettre \{ lettre | chiffre | '_' \}}\par
\par
{\f1   <op-symbole>   ::= lettre_majuscule \{ lettre_majuscule \}}\par
\par
\par
FIN DU DOCUMENT\par

\par
