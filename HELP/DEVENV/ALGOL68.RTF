{\footnote # IDH_ALGOL68_19}
{\footnote $ Algol 68 - CLAUSES COLLATERALES ET PARALLELES}
{\footnote K Algol 68 collaterales;paralleles;PAR}
\b\fs24 CLAUSES COLLATERALES ET PARALLELES \b0\fs20\par
\par
{\f1   19.1 Clause collaterale}\par
{\f1        (unite1, unite2, unite3)}\par
\par
{\f1        Les unites sont evaluees dans un ordre indefini.}\par
{\f1        En pratique, evaluation de gauche a droite.}\par
{\f1        Utilisee pour les constructeurs de rangees et structures.}\par
\par
{\f1   19.2 Clause parallele}\par
{\f1        PAR(unite1, unite2, unite3)}\par
{\f1        PAR BEGIN tache1, tache2 END}\par
\par
{\f1        Non supportee sur DOS 8086 mono-tache.}\par
{\f1        Avertissement emis : evaluation sequentielle.}\par
\par
\par
\par
