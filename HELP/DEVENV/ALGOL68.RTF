{\footnote # IDH_ALGOL68_03}
{\footnote $ Algol 68 - CONVENTIONS LEXICALES}
{\footnote K Algol 68 lexical;identificateurs;litteraux;casse}
\b\fs24 CONVENTIONS LEXICALES \b0\fs20\par
\par
{\f1   3.1 Identificateurs}\par
{\f1       Commencent par une lettre, suivis de lettres, chiffres ou}\par
{\f1       underscores. Sensibles a la casse.}\par
\par
{\f1       Exemples : x, somme, mon_tableau, i2}\par
\par
{\f1   3.2 Mots gras (bold words)}\par
{\f1       Ecrits en majuscules : BEGIN, END, IF, THEN, ELSE, etc.}\par
{\f1       Ils ne sont pas des identificateurs et ne peuvent pas etre}\par
{\f1       redefinis par le programmeur.}\par
\par
{\f1   3.3 Symboles speciaux}\par
\par
{\f1       Symbole   Signification}\par
{\f1       --------  -------------------------------------------}\par
{\f1       :=        Affectation (becomes)}\par
{\f1       =:        Affectation inversee (assignation inversee)}\par
{\f1       ;         Separateur d unites (go-on symbol)}\par
{\f1       ,         Separateur de liste}\par
{\f1       (         Parenthese ouvrante}\par
{\f1       )         Parenthese fermante}\par
{\f1       [         Crochet ouvrant (sous-indice)}\par
{\f1       ]         Crochet fermant}\par
{\f1       :         Separateur de bornes ou label}\par
{\f1       +*        Operateur imaginaire (I pour COMPL)}\par
{\f1       +:=       Plus et assignation (plusab)}\par
{\f1       -:=       Moins et assignation (minusab)}\par
{\f1       *:=       Fois et assignation (timesab)}\par
{\f1       /:=       Divise et assignation (divab)}\par
\par
{\f1   3.4 Denotations numeriques}\par
{\f1       Entiers : 0, 42, 65535}\par
{\f1       Entiers en base : 2r1010, 8r77, 16rFF (radix r digits)}\par
{\f1       Reels : 3.14, 1.5e-3, .5e2}\par
\par
\par
\par
