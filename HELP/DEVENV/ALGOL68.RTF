\par
{\f1   Cas                       CASE, IN, OUT, ESAC}\par
\par
{\f1   Boucles                   FOR, FROM, TO, DOWNTO, BY,}\par
{\f1                             WHILE, DO, OD}\par
\par
{\f1   Procedures                PROC}\par
\par
{\f1   Operateurs                OP, PRIO}\par
\par
{\f1   Modes (types)             MODE, STRUCT, UNION, REF,}\par
{\f1                             LOC, HEAP}\par
\par
{\f1   Modes primitifs           INT, REAL, BOOL, CHAR, BITS,}\par
{\f1                             BYTES, COMPL, STRING, VOID}\par
\par
{\f1   Constantes speciales      TRUE, FALSE, NIL, SKIP, EMPTY}\par
\par
{\f1   Operateurs standard       AND, OR, NOT, OF, AT, IS, ISNT,}\par
{\f1                             ABS, ARG, BIN, CONJ, IM, LENG,}\par
{\f1                             LEVEL, ODD, RE, REPR, ROUND,}\par
{\f1                             SHORTEN, SIGN, OVER, MOD,}\par
{\f1                             SHL, SHR, ELEM, UP, DOWN,}\par
{\f1                             LWB, UPB}\par
\par
{\f1   Saut                      GO TO, GOTO}\par
\par
{\f1   Parallele                 PAR}\par
\par
{\f1   Commentaires              CO, COMMENT}\par
\par
{\f1   Pragmats                  PR, PRAGMAT}\par
\par
\par
\par
