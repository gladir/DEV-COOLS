{\footnote # IDH_ALGOL68_16}
{\footnote $ Algol 68 - PROCEDURES (PROC)}
{\footnote K Algol 68 procedures;PROC;parametres;retour}
\b\fs24 PROCEDURES (PROC) \b0\fs20\par
\par
{\f1   16.1 Declaration de procedure}\par
{\f1        PROC nom = (params) MODE : corps;}\par
\par
{\f1        Exemples :}\par
{\f1          PROC double = (INT x) INT : x + x;}\par
{\f1          PROC add = (INT a, INT b) INT : a + b;}\par
{\f1          PROC greet = () VOID : print(("Bonjour", newline));}\par
\par
{\f1   16.2 Procedure VOID}\par
{\f1        Procedure sans valeur de retour :}\par
{\f1        PROC noop = () VOID : SKIP;}\par
\par
{\f1   16.3 Parametres}\par
{\f1        Par valeur : copie sur la pile.}\par
{\f1        Par reference (REF) : passage d adresse.}\par
\par
{\f1   16.4 Valeur de retour}\par
{\f1        Le resultat d une procedure est la valeur de la derniere}\par
{\f1        expression de son corps (dans AX).}\par
\par
{\f1   16.5 Recursion}\par
{\f1        Supportee naturellement via la pile.}\par
\par
{\f1        PROC factorial = (INT n) INT :}\par
{\f1          IF n = 0 THEN 1 ELSE n * factorial(n - 1) FI;}\par
\par
{\f1        PROC fib = (INT n) INT :}\par
{\f1          IF n <= 1 THEN n ELSE fib(n - 1) + fib(n - 2) FI;}\par
\par
{\f1   16.6 Procedures comme valeurs de premier ordre}\par
{\f1        PROC(INT)INT f = ma_proc;}\par
{\f1        Variables de type PROC : pointeur de code.}\par
{\f1        Appel indirect possible.}\par
\par
{\f1   16.7 Convention d appel}\par
{\f1        cdecl 16 bits : arguments empiles de gauche a droite.}\par
{\f1        Prologue : PUSH BP / MOV BP,SP / SUB SP, taille_locales}\par
{\f1        Epilogue : MOV SP,BP / POP BP / RET}\par
\par
\par
\par
