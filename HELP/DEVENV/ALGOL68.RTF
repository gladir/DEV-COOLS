{\footnote # IDH_ALGOL68_21}
{\footnote $ Algol 68 - SYMBOLES ET PORTEES}
{\footnote K Algol 68 symboles;portee;scope;identification}
\b\fs24 SYMBOLES ET PORTEES \b0\fs20\par
\par
{\f1   21.1 Portees lexicales (scopes)}\par
{\f1        Chaque clause fermee (BEGIN...END ou (...)) ouvre une}\par
{\f1        nouvelle portee. Les declarations dans une portee ne sont}\par
{\f1        pas visibles a l exterieur.}\par
\par
{\f1        BEGIN}\par
{\f1          INT x := 5;      CO x visible ici CO}\par
{\f1          BEGIN}\par
{\f1            INT y := x + 1; CO x et y visibles ici CO}\par
{\f1          END;}\par
{\f1          CO y n est plus visible ici CO}\par
{\f1        END}\par
\par
{\f1   21.2 Table des symboles}\par
{\f1        Chaque symbole possede : nom, nom decore (mangled), genre,}\par
{\f1        mode, offset, niveau de portee, attributs (param, heap, loc).}\par
\par
{\f1        Genres de symboles :}\par
{\f1          SK_IDENT   Identite (constante)}\par
{\f1          SK_VAR     Variable (REF)}\par
{\f1          SK_PROC    Procedure}\par
{\f1          SK_OP      Operateur}\par
{\f1          SK_MODE    Type (mode)}\par
{\f1          SK_LABEL   Etiquette}\par
{\f1          SK_PRIO    Priorite d operateur}\par
\par
{\f1   21.3 Symboles predefinis (61 symboles standard)}\par
\par
{\f1        Categorie          Symboles}\par
{\f1        -----------------  ------------------------------------------}\par
{\f1        E/S                print, read, newline, newpage, space,}\par
{\f1                           backspace}\par
{\f1        Transput           put, get, open, close, associate, create,}\par
{\f1                           establish}\par
{\f1        Operateurs         abs, odd, sign, entier, round, repr,}\par
{\f1                           leng, shorten, bin, elem, level, re,}\par
{\f1                           im, conj, arg}\par
{\f1        Math               sqrt, exp, ln, sin, cos, tan, arcsin,}\par
{\f1                           arccos, arctan}\par
{\f1        Chaines            whole, fixed, float, char in string,}\par
{\f1                           string in string}\par
{\f1        Constantes         max int, max real, small real, pi,}\par
{\f1                           blank, flip, flop}\par
{\f1        Fichiers           stand in, stand out, stand error,}\par
{\f1                           stand back}\par
{\f1        Divers             random, next random, stop}\par
\par
\par
\par
