{\footnote # IDH_ALGOL68_14}
{\footnote $ Algol 68 - REFERENCES ET AFFECTATIONS (REF)}
{\footnote K Algol 68 references;affectations;REF;pointeurs}
\b\fs24 REFERENCES ET AFFECTATIONS (REF) \b0\fs20\par
\par
{\f1   14.1 REF MODE}\par
{\f1        Reference (pointeur) vers un objet de mode MODE.}\par
{\f1        Toute variable est implicitement un REF.}\par
\par
{\f1   14.2 Affectation}\par
{\f1        x := 42          CO affectation standard CO}\par
{\f1        99 =: z          CO affectation inversee CO}\par
\par
{\f1   14.3 LOC (allocation locale)}\par
{\f1        LOC INT : allocation sur la pile dans le cadre courant.}\par
\par
{\f1   14.4 HEAP (allocation dynamique)}\par
{\f1        HEAP INT : allocation sur le tas via _A68RT_ALLOC.}\par
\par
{\f1   14.5 REF REF MODE}\par
{\f1        Double indirection (reference vers reference).}\par
\par
{\f1   14.6 NIL}\par
{\f1        Reference nulle, compatible avec tout REF M.}\par
\par
{\f1   14.7 Test d identite}\par
{\f1        a IS b       CO meme reference (meme adresse) CO}\par
{\f1        a ISNT b     CO references differentes CO}\par
{\f1        p IS NIL     CO test de reference nulle CO}\par
{\f1        p ISNT NIL}\par
\par
\par
\par
