{\footnote # IDH_ALGOL68_11}
{\footnote $ Algol 68 - CLAUSES CONDITIONNELLES (IF ET CASE)}
{\footnote K Algol 68 conditionnelles;IF;CASE;THEN;ELSE;FI;ESAC}
\b\fs24 CLAUSES CONDITIONNELLES (IF ET CASE) \b0\fs20\par
\par
{\f1   11.1 Clause IF}\par
\par
{\f1        IF condition THEN}\par
{\f1          unites_vrai}\par
{\f1        ELIF condition THEN}\par
{\f1          unites_elif}\par
{\f1        ELSE}\par
{\f1          unites_faux}\par
{\f1        FI}\par
\par
{\f1        Forme abregee : (condition | val_vrai | val_faux)}\par
\par
{\f1        Exemple :}\par
{\f1          IF note >= 90 THEN}\par
{\f1            print(("Excellent", newline))}\par
{\f1          ELIF note >= 70 THEN}\par
{\f1            print(("Bien", newline))}\par
{\f1          ELSE}\par
{\f1            print(("Echec", newline))}\par
{\f1          FI}\par
\par
{\f1        La clause IF peut etre utilisee comme expression :}\par
{\f1          INT x = IF cond THEN 1 ELSE 2 FI}\par
\par
{\f1   11.2 Clause CASE}\par
\par
{\f1        CASE expression IN}\par
{\f1          unite1,}\par
{\f1          unite2,}\par
{\f1          unite3}\par
{\f1        OUT}\par
{\f1          unite_defaut}\par
{\f1        ESAC}\par
\par
{\f1        Forme abregee : (expr | val1, val2, ... | defaut)}\par
\par
{\f1        L expression doit etre de mode INT.}\par
{\f1        La selection est 1-basee : 1 -> unite1, 2 -> unite2, etc.}\par
{\f1        La clause OUT est executee si aucune valeur ne correspond.}\par
\par
{\f1        Exemple :}\par
{\f1          CASE jour IN}\par
{\f1            print(("Lundi", newline)),}\par
{\f1            print(("Mardi", newline)),}\par
{\f1            print(("Mercredi", newline))}\par
{\f1          OUT}\par
{\f1            print(("Autre jour", newline))}\par
{\f1          ESAC}\par
\par
\par
\par
