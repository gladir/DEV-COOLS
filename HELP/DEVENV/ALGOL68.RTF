{\footnote # IDH_ALGOL68_20}
{\footnote $ Algol 68 - TRANSPUT (ENTREES/SORTIES)}
{\footnote K Algol 68 transput;entrees;sorties;read;print;put;get}
\b\fs24 TRANSPUT (ENTREES/SORTIES) \b0\fs20\par
\par
{\f1   20.1 print}\par
{\f1        print((args))}\par
{\f1        Ecriture sur stdout. Accepte une liste heterogene.}\par
\par
{\f1        Exemples :}\par
{\f1          print(("Hello, World!", newline));}\par
{\f1          print(("x = ", x, newline));}\par
{\f1          print((msg, ": ", val, " ", flag, newline));}\par
\par
{\f1        Types supportes dans print :}\par
{\f1          INT    -> conversion decimale}\par
{\f1          CHAR   -> caractere unique}\par
{\f1          STRING -> chaine de caracteres}\par
{\f1          BOOL   -> "TRUE" ou "FALSE"}\par
\par
{\f1   20.2 read}\par
{\f1        read((args))}\par
{\f1        Lecture depuis stdin.}\par
\par
{\f1        Exemples :}\par
{\f1          read((x));}\par
{\f1          read((x, y));}\par
\par
{\f1   20.3 Procedures standard de transput}\par
\par
{\f1        Procedure    Description}\par
{\f1        -----------  -----------------------------------------}\par
{\f1        print        Ecriture formatee sur stdout}\par
{\f1        read         Lecture depuis stdin}\par
{\f1        newline      Ecrire un saut de ligne (CR+LF)}\par
{\f1        newpage      Ecrire un saut de page (FF)}\par
{\f1        space        Ecrire un espace}\par
{\f1        whole        Formater un entier avec largeur}\par
{\f1        fixed        Formater un reel avec decimales}\par
\par
{\f1   20.4 Fichiers}\par
{\f1        open, close, get, put (interface simplifiee).}\par
\par
{\f1   20.5 Fichiers standard}\par
{\f1        stand in    : entree standard (stdin)}\par
{\f1        stand out   : sortie standard (stdout)}\par
{\f1        stand error : sortie d erreur (stderr)}\par
{\f1        stand back  : fichier arriere}\par
\par
\par
\par
