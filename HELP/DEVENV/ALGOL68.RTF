{\footnote # IDH_ALGOL68_13}
{\footnote $ Algol 68 - STRUCTURES (STRUCT)}
{\footnote K Algol 68 structures;STRUCT;champs}
\b\fs24 STRUCTURES (STRUCT) \b0\fs20\par
\par
{\f1   13.1 Declaration de mode structure}\par
{\f1        MODE POINT = STRUCT(INT x, INT y);}\par
{\f1        MODE VEC3 = STRUCT(INT a, INT b, INT c);}\par
\par
{\f1        La taille d une structure est la somme des tailles de ses champs.}\par
\par
{\f1   13.2 Constructeur de structure}\par
{\f1        POINT p := POINT(3, 7);}\par
{\f1        VEC3 v := VEC3(10, 20, 30);}\par
\par
{\f1   13.3 Selection de champ (OF)}\par
{\f1        INT px := x OF p;}\par
{\f1        INT vc := c OF v;}\par
\par
{\f1        L operateur OF accede a un champ par un offset fixe depuis}\par
{\f1        le debut de la structure.}\par
\par
{\f1   13.4 Structures imbriquees}\par
{\f1        MODE RECT = STRUCT(POINT tl, POINT br);}\par
{\f1        Acces chaine : x OF tl OF rect}\par
\par
{\f1   13.5 Affectation de structure}\par
{\f1        Copie champ par champ ou par bloc (REP MOVSW).}\par
\par
\par
\par
{\uldb << Precedent}{\v IDH_ALGOL68_12}     {\uldb Suivant >>}{\v IDH_ALGOL68_14}     {\uldb Table des matieres}{\v IDH_ALGOL68_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
