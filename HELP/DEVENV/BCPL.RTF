{\footnote # IDH_BCPL_15}
{\footnote $ BCPL - COMPILATEUR DU PROJET (BCPL86.PAS)}
{\footnote K BCPL compilateurs projet;BCPL86.PAS}
\b\fs24 COMPILATEUR DU PROJET (BCPL86.PAS) \b0\fs20\par
\par
BCPL86.PAS - Compilateur BCPL vers assembleur 8086\par
\par
{\f1   Cible             : MS-DOS, assembleur MASM .MODEL SMALL}\par
{\f1   Modele memoire    : SMALL (code 64KO, donnees 64KO)}\par
{\f1   Taille de mot     : 16 bits}\par
{\f1   Sortie            : fichier .ASM, assemblable avec MASM}\par
\par
{\f1   Fonctionnalites supportees :}\par
{\f1     - Declarations LET, MANIFEST, GLOBAL, STATIC, EXTERNAL}\par
{\f1     - Vecteurs VEC, TABLE}\par
{\f1     - Operateurs arithmetiques, logiques, relationnels}\par
{\f1     - Operateurs ! (subscript), LV / @ (lvalue)}\par
{\f1     - Structures de controle IF/TEST/UNLESS, WHILE/UNTIL/FOR,}\par
{\f1       REPEAT, SWITCHON, BREAK, LOOP}\par
{\f1     - Fonctions et procedures (LET ... = / LET ... BE)}\par
{\f1     - Mutual recursion (AND)}\par
{\f1     - VALOF / RESULTIS}\par
{\f1     - Blocs $( ... $) et \{ ... \}}\par
{\f1     - Sections (SECTION, GET, EXTERNAL)}\par
{\f1     - Sorties WRITES, WRITEN, WRITEF (sous-ensemble)}\par
\par
{\f1   Limitations :}\par
{\f1     - Pas de OCODE / INTCODE intermediaire (compilation}\par
{\f1       directe vers 8086)}\par
{\f1     - Chaines : longueur dans le mot 0, caracteres dans}\par
{\f1       mots suivants (1 caractere par mot)}\par
{\f1     - Pas de chaines compactees (operateur %)}\par
{\f1     - Pas d'allocation dynamique GETVEC / FREEVEC (utilisez}\par
{\f1       les vecteurs locaux ou STATIC)}\par
\par
\par
\par
