{\footnote # IDH_BCPL_14}
{\footnote $ BCPL - EXEMPLES}
{\footnote K BCPL exemples;Hello World;Factorielle;Fibonacci;tri insertion;recherche chaine}
\b\fs24 EXEMPLES \b0\fs20\par
\par
\par
\b 14.1 Hello, World! \b0\par
\par
{\f1   GET "LIBHDR"}\par
\par
{\f1   LET START() BE}\par
{\f1     WRITES("Hello, World!*N")}\par
\par
\par
\b 14.2 Factorielle recursive \b0\par
\par
{\f1   GET "LIBHDR"}\par
\par
{\f1   LET FACT(N) = N < 2 -> 1, N * FACT(N - 1)}\par
\par
{\f1   LET START() BE}\par
{\f1   $(}\par
{\f1     LET I = 0}\par
{\f1     FOR I = 0 TO 10 DO}\par
{\f1       WRITEF("FACT(%N) = %N*N", I, FACT(I))}\par
{\f1   $)}\par
\par
\par
\b 14.3 Fibonacci iteratif \b0\par
\par
{\f1   GET "LIBHDR"}\par
\par
{\f1   LET FIB(N) = VALOF}\par
{\f1   $(}\par
{\f1     LET A, B = 0, 1}\par
{\f1     LET I = 0}\par
{\f1     FOR I = 1 TO N DO}\par
{\f1     $(}\par
{\f1       LET T = A + B}\par
{\f1       A := B}\par
{\f1       B := T}\par
{\f1     $)}\par
{\f1     RESULTIS A}\par
{\f1   $)}\par
\par
{\f1   LET START() BE}\par
{\f1   $(}\par
{\f1     LET I = 0}\par
{\f1     FOR I = 0 TO 10 DO}\par
{\f1       WRITEF("FIB(%N) = %N*N", I, FIB(I))}\par
{\f1   $)}\par
\par
\par
\b 14.4 Tri par insertion d'un vecteur \b0\par
\par
{\f1   LET TRI(V, N) BE}\par
{\f1   $(}\par
{\f1     LET I = 0}\par
{\f1     FOR I = 1 TO N - 1 DO}\par
{\f1     $(}\par
{\f1       LET J = I}\par
{\f1       WHILE J > 0 & V!(J-1) > V!J DO}\par
{\f1       $(}\par
{\f1         LET T = V!J}\par
{\f1         V!J     := V!(J-1)}\par
{\f1         V!(J-1) := T}\par
{\f1         J := J - 1}\par
{\f1       $)}\par
{\f1     $)}\par
{\f1   $)}\par
\par
\par
\b 14.5 Recherche dans une chaine \b0\par
\par
{\f1   LET CHERCHER(S, C) = VALOF}\par
{\f1   $(}\par
{\f1     LET I = 0}\par
{\f1     FOR I = 1 TO S!0 DO}\par
{\f1       IF S!I = C THEN RESULTIS I}\par
{\f1     RESULTIS 0}\par
{\f1   $)}\par
\par
\par
\par
