{\footnote # IDH_BCPL_16}
{\footnote $ BCPL - CONVERTISSEURS DU PROJET}
{\footnote K BCPL convertisseurs;ASC2BCPL.PAS;ADA2BCPL.PAS;PAS2BCPL.PAS;transpileur}
\b\fs24 CONVERTISSEURS DU PROJET \b0\fs20\par
\par
\par
\b 16.1 ASC2BCPL.PAS - Texte ASCII vers BCPL \b0\par
\par
Convertit un fichier texte en chaine BCPL initialisee :\par
\par
{\f1   LET MESSAGE = TABLE 'B', 'C', 'P', 'L', '*N', 0}\par
\par
\par
\b 16.2 ADA2BCPL.PAS - Ada vers BCPL \b0\par
\par
Transpileur Ada (sous-ensemble) vers BCPL.\par
\par
{\f1   - procedure -> LET ... BE}\par
{\f1   - function  -> LET ... =}\par
{\f1   - if/elsif/else -> TEST / ELSE}\par
{\f1   - loop / while  -> WHILE / UNTIL / FOR}\par
\par
\par
\b 16.3 PAS2BCPL.PAS - Pascal vers BCPL \b0\par
\par
Transpileur Pascal (sous-ensemble) vers BCPL.\par
\par
{\f1   - procedure -> LET ... BE}\par
{\f1   - function  -> LET ... =}\par
{\f1   - var       -> LET}\par
{\f1   - const     -> MANIFEST}\par
{\f1   - begin/end -> $(  $)}\par
{\f1   - := -> := (identique)}\par
{\f1   - read/write -> READN / WRITES / WRITEN}\par
\par
\par
\par
