{\footnote # IDH_BCPL_11}
{\footnote $ BCPL - ENTREES / SORTIES}
{\footnote K BCPL entrees sorties;WRITES;WRITEN;WRITEF;WRCH;RDCH;READN;FINDINPUT;FINDOUTPUT}
\b\fs24 ENTREES / SORTIES \b0\fs20\par
\par
\par
\b 11.1 Sorties \b0\par
\par
{\f1   WRITES(S)             ecrit une chaine}\par
{\f1   WRITEN(N)             ecrit un entier}\par
{\f1   WRITEF(FMT, ARGS...)  ecriture formatee}\par
{\f1   WRCH(C)               ecrit un caractere}\par
{\f1   NEWLINE()             saut de ligne}\par
\par
Specificateurs WRITEF :\par
\par
{\f1   %N    entier}\par
{\f1   %S    chaine}\par
{\f1   %C    caractere}\par
{\f1   %X    hexadecimal}\par
{\f1   %O    octal}\par
{\f1   %B    binaire}\par
{\f1   %P    pad / espacement}\par
\par
\par
\b 11.2 Entrees \b0\par
\par
{\f1   RDCH()                lit un caractere}\par
{\f1   READN()               lit un entier}\par
{\f1   READSTREAM(S)         lit une chaine}\par
\par
\par
\b 11.3 Fichiers \b0\par
\par
{\f1   FINDINPUT(NOM)        ouvre en lecture}\par
{\f1   FINDOUTPUT(NOM)       ouvre en ecriture}\par
{\f1   SELECTINPUT(FLUX)     selectionne flux de lecture}\par
{\f1   SELECTOUTPUT(FLUX)    selectionne flux d'ecriture}\par
{\f1   ENDREAD()             ferme le flux d'entree}\par
{\f1   ENDWRITE()            ferme le flux de sortie}\par
\par
\par
\par
