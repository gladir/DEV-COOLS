{\f1     TextRec                        TTextRec}\par
{\f1     TextBuf                        TTextBuf (+ PTextBuf)}\par
{\f1     SearchRec                      TSearchRec}\par
{\f1     DateTime                       TDateTime}\par
\par
{\f1   Param??tres String ??? PChar :}\par
{\f1     FindFirst(Path: String;...)    FindFirst(Path: PChar;...)}\par
{\f1     FSearch(Name: String): String  FileSearch(Dest,Name,List: PChar)}\par
