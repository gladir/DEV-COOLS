{\f1     GetCurDir, SetCurDir           ??? gestion de r??pertoire courant}\par
{\f1     CreateDir, RemoveDir           ??? cr??ation/suppression r??pertoire}\par
{\f1     GetArgCount, GetArgStr         ??? acc??s ligne de commande}\par
{\f1     GetEnvVar                      ??? acc??s environnement (PChar)}\par
\par
