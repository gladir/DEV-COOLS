{\footnote # IDH_TPWIN_23}
{\footnote $ Unite WinDos - EXEMPLES COMPLETS}
{\footnote K Turbo Pascal;Unite WinDos;EXEMPLES COMPLETS}
\b\fs24 EXEMPLES COMPLETS \b0\fs20\par
\par
{\f1   --- Exemple 1 : Lister les fichiers d'un r??pertoire ---}\par
\par
{\f1   program ListFiles;}\par
{\f1   uses WinDos, Strings;}\par
{\f1   var}\par
{\f1     SR   : TSearchRec;}\par
{\f1     DT   : TDateTime;}\par
{\f1     Path : array[0..fsPathName] of Char;}\par
{\f1   begin}\par
{\f1     StrPCopy(Path, '*.*');}\par
{\f1     FindFirst(Path, faAnyFile, SR);}\par
{\f1     while DosError = 0 do}\par
{\f1     begin}\par
{\f1       UnpackTime(SR.Time, DT);}\par
{\f1       Write(StrPas(SR.Name):13);}\par
{\f1       Write(SR.Size:10);}\par
{\f1       Write('  ', DT.Year, '-');}\par
{\f1       if DT.Month < 10 then Write('0');}\par
{\f1       Write(DT.Month, '-');}\par
{\f1       if DT.Day < 10 then Write('0');}\par
{\f1       WriteLn(DT.Day);}\par
{\f1       FindNext(SR);}\par
{\f1     end;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : D??composer un chemin de fichier ---}\par
\par
{\f1   program SplitPath;}\par
{\f1   uses WinDos, Strings;}\par
{\f1   var}\par
{\f1     Dir   : array[0..fsDirectory] of Char;}\par
{\f1     Name  : array[0..fsFileName] of Char;}\par
{\f1     Ext   : array[0..fsExtension] of Char;}\par
{\f1     Path  : array[0..fsPathName] of Char;}\par
{\f1     Flags : Word;}\par
{\f1   begin}\par
{\f1     StrPCopy(Path, 'C:\\TP\\BIN\\TURBO.EXE');}\par
{\f1     Flags := FileSplit(Path, Dir, Name, Ext);}\par
{\f1     WriteLn('R??pertoire : ', StrPas(Dir));}\par
{\f1     WriteLn('Nom        : ', StrPas(Name));}\par
{\f1     WriteLn('Extension  : ', StrPas(Ext));}\par
{\f1     WriteLn('Flags      : $', HexStr(Flags, 4));}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Rechercher un fichier dans le PATH ---}\par
\par
{\f1   program SearchFile;}\par
{\f1   uses WinDos, Strings;}\par
{\f1   var}\par
{\f1     Dest : array[0..fsPathName] of Char;}\par
{\f1     P    : PChar;}\par
{\f1   begin}\par
{\f1     P := GetEnvVar('PATH');}\par
{\f1     if P <> nil then}\par
{\f1     begin}\par
{\f1       FileSearch(Dest, 'TURBO.EXE', P);}\par
{\f1       if Dest[0] <> #0 then}\par
{\f1         WriteLn('Trouv?? : ', StrPas(Dest))}\par
{\f1       else}\par
{\f1         WriteLn('TURBO.EXE non trouv?? dans le PATH');}\par
{\f1     end}\par
{\f1     else}\par
{\f1       WriteLn('Variable PATH non d??finie');}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 4 : Afficher les arguments de la ligne de commande ---}\par
\par
{\f1   program ShowArgs;}\par
{\f1   uses WinDos, Strings;}\par
{\f1   var}\par
{\f1     Buf : array[0..127] of Char;}\par
{\f1     I   : Integer;}\par
{\f1   begin}\par
{\f1     WriteLn('Nombre d''arguments : ', GetArgCount);}\par
{\f1     WriteLn('Programme : ', StrPas(GetArgStr(Buf, 0, 127)));}\par
{\f1     for I := 1 to GetArgCount do}\par
{\f1       WriteLn('  Arg[', I, '] = ', StrPas(GetArgStr(Buf, I, 127)));}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 5 : Modifier les attributs d'un fichier ---}\par
\par
{\f1   program ChangeAttr;}\par
{\f1   uses WinDos, Strings;}\par
{\f1   var}\par
{\f1     F    : file;}\par
{\f1     Attr : Word;}\par
{\f1     Path : array[0..fsPathName] of Char;}\par
{\f1   begin}\par
{\f1     StrPCopy(Path, 'TEST.DAT');}\par
{\f1     Assign(F, Path);}\par
{\f1     GetFAttr(F, Attr);}\par
{\f1     if DosError = 0 then}\par
{\f1     begin}\par
{\f1       WriteLn('Attributs actuels : $', HexStr(Attr, 4));}\par
{\f1       \{ Ajouter lecture seule \}}\par
{\f1       SetFAttr(F, Attr or faReadOnly);}\par
{\f1       if DosError = 0 then}\par
{\f1         WriteLn('Lecture seule activ??e')}\par
{\f1       else}\par
{\f1         WriteLn('Erreur SetFAttr : ', DosError);}\par
{\f1     end}\par
{\f1     else}\par
{\f1       WriteLn('Erreur GetFAttr : ', DosError);}\par
{\f1   end.}\par
\par
\par
