{\footnote # IDH_TPWIN_15}
{\footnote $ Unite WinDos - FORMAT EMPAQUETAGE DATE/HEURE}
{\footnote K Turbo Pascal;Unite WinDos;FORMAT EMPAQUETAGE DATE/HEURE}
\b\fs24 FORMAT EMPAQUETAGE DATE/HEURE \b0\fs20\par
\par
{\f1   Le format date/heure empquet?? DOS (Longint, 32 bits) se d??compose}\par
{\f1   comme suit :}\par
\par
{\f1     Bits 0..4   : Secondes div 2     (0..29 ??? 0..58 secondes)}\par
{\f1     Bits 5..10  : Minutes             (0..59)}\par
{\f1     Bits 11..15 : Heures              (0..23)}\par
{\f1     Bits 16..20 : Jour                (1..31)}\par
{\f1     Bits 21..24 : Mois                (1..12)}\par
{\f1     Bits 25..31 : Ann??e - 1980        (0..119 ??? 1980..2099)}\par
\par
{\f1   procedure UnpackTime(P : Longint; var T : TDateTime);}\par
{\f1   Convertit une date/heure empaquet??e en enregistrement TDateTime.}\par
\par
{\f1   Param??tres :}\par
{\f1     P  Valeur empaquet??e (de GetFTime, FindFirst ou FindNext)}\par
{\f1     T  [sortie] Enregistrement d??compos??}\par
\par
{\f1   Formules de d??compression :}\par
{\f1     T.Sec   := (P and $1F) * 2;}\par
{\f1     T.Min   := (P shr 5) and $3F;}\par
{\f1     T.Hour  := (P shr 11) and $1F;}\par
{\f1     T.Day   := (P shr 16) and $1F;}\par
{\f1     T.Month := (P shr 21) and $0F;}\par
{\f1     T.Year  := (P shr 25) and $7F + 1980;}\par
\par
{\f1   procedure PackTime(var T : TDateTime; var P : Longint);}\par
{\f1   Convertit un enregistrement TDateTime en date/heure empaquet??e.}\par
\par
{\f1   Param??tres :}\par
{\f1     T  Enregistrement source}\par
{\f1     P  [sortie] Valeur empaquet??e (pour SetFTime)}\par
\par
{\f1   Formule de compression :}\par
{\f1     P := (T.Sec div 2)}\par
{\f1       or (T.Min shl 5)}\par
{\f1       or (T.Hour shl 11)}\par
{\f1       or (T.Day shl 16)}\par
{\f1       or (T.Month shl 21)}\par
{\f1       or ((T.Year - 1980) shl 25);}\par
\par
{\f1   Exemple :}\par
{\f1     var}\par
{\f1       DT : TDateTime;}\par
{\f1       T  : Longint;}\par
{\f1     begin}\par
{\f1       DT.Year := 1995; DT.Month := 6; DT.Day := 15;}\par
{\f1       DT.Hour := 14; DT.Min := 30; DT.Sec := 0;}\par
{\f1       PackTime(DT, T);}\par
{\f1       SetFTime(F, T);}\par
{\f1     end;}\par
\par
\par
