{\footnote # IDH_SQL_12}
{\footnote $ SQL - FONCTIONS D AGREGATION}
{\footnote K SQL agregation;COUNT SUM AVG MIN MAX;STDEV VAR;GROUP BY;HAVING;ROLLUP CUBE GROUPING SETS;DISTINCT}
\b\fs24 FONCTIONS D AGREGATION \b0\fs20\par
\par
Les fonctions d agregation operent sur un ensemble de lignes\par
et retournent une valeur unique.\par
\par
{\f1     COUNT(*)                  nombre de lignes}\par
{\f1     COUNT(expression)         nombre de valeurs non NULL}\par
{\f1     COUNT(DISTINCT expr)      nombre de valeurs distinctes}\par
{\f1     SUM(expression)           somme}\par
{\f1     AVG(expression)           moyenne}\par
{\f1     MIN(expression)           minimum}\par
{\f1     MAX(expression)           maximum}\par
{\f1     STDEV(expression)         ecart-type (echantillon)}\par
{\f1     STDEVP(expression)        ecart-type (population)}\par
{\f1     VAR(expression)           variance (echantillon)}\par
{\f1     VARP(expression)          variance (population)}\par
{\f1     STRING_AGG(expr, sep)     concatenation de chaines}\par
{\f1       [WITHIN GROUP (ORDER BY ...)]}\par
{\f1     GROUPING(colonne)         0 si non aggrege, 1 si total}\par
{\f1     GROUPING_ID(col1, col2)   bitmask des colonnes agregees}\par
{\f1     CHECKSUM_AGG(expr)        checksum agregee}\par
{\f1     COUNT_BIG(*)              comme COUNT mais retourne BIGINT}\par
{\f1     APPROX_COUNT_DISTINCT(expr)  estimation de COUNT DISTINCT}\par
\par
{\f1     Les agregats ignorent les valeurs NULL (sauf COUNT(*)).}\par
\par
{\f1     GROUP BY avec ROLLUP, CUBE et GROUPING SETS :}\par
\par
{\f1     -- ROLLUP : sous-totaux hierarchiques}\par
{\f1     SELECT dept, poste, SUM(salaire)}\par
{\f1     FROM Employes}\par
{\f1     GROUP BY ROLLUP (dept, poste)}\par
\par
{\f1     -- CUBE : toutes les combinaisons de sous-totaux}\par
{\f1     SELECT dept, poste, SUM(salaire)}\par
{\f1     FROM Employes}\par
{\f1     GROUP BY CUBE (dept, poste)}\par
\par
{\f1     -- GROUPING SETS : combinaisons explicites}\par
{\f1     SELECT dept, poste, SUM(salaire)}\par
{\f1     FROM Employes}\par
{\f1     GROUP BY GROUPING SETS ((dept, poste), (dept), ())}\par
\par
\par
