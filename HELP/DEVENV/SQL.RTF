{\footnote # IDH_SQL_08}
{\footnote $ SQL - INSTRUCTIONS DCL (DATA CONTROL LANGUAGE)}
{\footnote K SQL DCL;GRANT;REVOKE;DENY;permissions;roles}
\b\fs24 INSTRUCTIONS DCL (DATA CONTROL LANGUAGE) \b0\fs20\par
\par
8.1 GRANT\par
\par
{\f1     GRANT permission ON objet TO principal}\par
{\f1     GRANT permission TO role}\par
\par
{\f1     Permissions :}\par
{\f1       SELECT, INSERT, UPDATE, DELETE, EXECUTE,}\par
{\f1       ALTER, CONTROL, VIEW DEFINITION, REFERENCES,}\par
{\f1       TAKE OWNERSHIP}\par
\par
{\f1     Exemples :}\par
{\f1       GRANT SELECT ON dbo.Employes TO UtilisateurRH}\par
{\f1       GRANT EXECUTE ON dbo.sp_GetEmployes TO AppRole}\par
{\f1       GRANT SELECT, INSERT ON SCHEMA::dbo TO DeveloppeurRole}\par
\par
8.2 REVOKE\par
\par
{\f1     REVOKE permission ON objet FROM principal}\par
\par
{\f1     Exemple :}\par
{\f1       REVOKE SELECT ON dbo.Employes FROM UtilisateurRH}\par
\par
8.3 DENY\par
\par
{\f1     DENY permission ON objet TO principal}\par
\par
{\f1     Exemple :}\par
{\f1       DENY DELETE ON dbo.Employes TO StagiaireRole}\par
\par
{\f1     DENY a priorite sur GRANT : si un utilisateur a GRANT}\par
{\f1     et DENY sur la meme permission, DENY l emporte.}\par
\par
8.4 Gestion des utilisateurs et roles\par
\par
{\f1     CREATE LOGIN nom WITH PASSWORD = 'mot_de_passe'}\par
{\f1     CREATE USER nom FOR LOGIN nom_login}\par
{\f1     ALTER ROLE nom_role ADD MEMBER nom_utilisateur}\par
{\f1     ALTER ROLE nom_role DROP MEMBER nom_utilisateur}\par
{\f1     ALTER LOGIN nom WITH PASSWORD = 'nouveau'}\par
{\f1     DROP LOGIN nom}\par
{\f1     DROP USER nom}\par
\par
\par
