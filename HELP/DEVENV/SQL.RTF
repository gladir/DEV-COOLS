{\footnote # IDH_SQL_19}
{\footnote $ SQL - DECLENCHEURS (TRIGGERS)}
{\footnote K SQL triggers declencheurs;CREATE TRIGGER;AFTER INSTEAD OF;INSERTED DELETED;DDL trigger;LOGON trigger}
\b\fs24 DECLENCHEURS (TRIGGERS) \b0\fs20\par
\par
19.1 Triggers DML\par
\par
{\f1      CREATE TRIGGER nom ON table}\par
{\f1      AFTER | INSTEAD OF [INSERT] [,] [UPDATE] [,] [DELETE]}\par
{\f1      AS}\par
{\f1      BEGIN}\par
{\f1        -- Tables virtuelles disponibles :}\par
{\f1        -- INSERTED : lignes inserees ou nouvelles valeurs}\par
{\f1        -- DELETED  : lignes supprimees ou anciennes valeurs}\par
{\f1      END}\par
\par
{\f1      Exemple (audit) :}\par
{\f1        CREATE TRIGGER trg_Audit ON Employes}\par
{\f1        AFTER INSERT, UPDATE, DELETE}\par
{\f1        AS}\par
{\f1        BEGIN}\par
{\f1          INSERT INTO AuditLog (action, date_modif, details)}\par
{\f1          SELECT}\par
{\f1            CASE}\par
{\f1              WHEN EXISTS(SELECT 1 FROM INSERTED) AND}\par
{\f1                   EXISTS(SELECT 1 FROM DELETED) THEN 'UPDATE'}\par
{\f1              WHEN EXISTS(SELECT 1 FROM INSERTED) THEN 'INSERT'}\par
{\f1              ELSE 'DELETE'}\par
{\f1            END,}\par
{\f1            GETDATE(),}\par
{\f1            (SELECT COUNT(*) FROM INSERTED)}\par
{\f1        END}\par
\par
19.2 Triggers DDL\par
\par
{\f1      CREATE TRIGGER nom ON DATABASE}\par
{\f1      FOR CREATE_TABLE, ALTER_TABLE, DROP_TABLE}\par
{\f1      AS}\par
{\f1      BEGIN}\par
{\f1        -- EVENTDATA() retourne un XML decrivant l evenement}\par
{\f1      END}\par
\par
19.3 INSTEAD OF triggers\par
\par
{\f1      Les triggers INSTEAD OF remplacent l action originale :}\par
\par
{\f1      CREATE TRIGGER trg_VueInsert ON ma_vue}\par
{\f1      INSTEAD OF INSERT}\par
{\f1      AS}\par
{\f1      BEGIN}\par
{\f1        INSERT INTO table_base}\par
{\f1        SELECT col1, col2 FROM INSERTED}\par
{\f1      END}\par
\par
\par
{\uldb << Precedent}{\v IDH_SQL_18}     {\uldb Suivant >>}{\v IDH_SQL_20}     {\uldb Table des matieres}{\v IDH_SQL_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_SQL_20}
{\footnote $ SQL - GESTION DES ERREURS}
{\footnote K SQL gestion erreurs;TRY CATCH;THROW;RAISERROR;ERROR_NUMBER ERROR_MESSAGE ERROR_LINE;@@ERROR}
\b\fs24 GESTION DES ERREURS \b0\fs20\par
\par
20.1 TRY ... CATCH\par
\par
{\f1      BEGIN TRY}\par
{\f1        -- instructions susceptibles de lever une erreur}\par
{\f1      END TRY}\par
{\f1      BEGIN CATCH}\par
{\f1        -- gestion de l erreur}\par
{\f1        SELECT}\par
{\f1          ERROR_NUMBER() AS numero,}\par
{\f1          ERROR_SEVERITY() AS severite,}\par
{\f1          ERROR_STATE() AS etat,}\par
{\f1          ERROR_PROCEDURE() AS procedure_name,}\par
{\f1          ERROR_LINE() AS ligne,}\par
{\f1          ERROR_MESSAGE() AS message}\par
{\f1      END CATCH}\par
\par
{\f1      Exemple complet :}\par
{\f1        BEGIN TRY}\par
{\f1          BEGIN TRAN}\par
{\f1            UPDATE Comptes SET solde -= 100 WHERE id = @source}\par
{\f1            UPDATE Comptes SET solde += 100 WHERE id = @dest}\par
{\f1          COMMIT TRAN}\par
{\f1        END TRY}\par
{\f1        BEGIN CATCH}\par
{\f1          IF @@TRANCOUNT > 0}\par
{\f1            ROLLBACK TRAN}\par
{\f1          THROW}\par
{\f1        END CATCH}\par
\par
20.2 THROW\par
\par
{\f1      THROW [numero, message, state]}\par
\par
{\f1      Sans parametres, releve l erreur courante (dans CATCH).}\par
{\f1      Avec parametres, leve une nouvelle erreur :}\par
{\f1        THROW 50001, 'Erreur personnalisee', 1}\par
\par
{\f1      Le numero doit etre >= 50000 pour les erreurs utilisateur.}\par
\par
20.3 RAISERROR\par
\par
{\f1      RAISERROR (message, severity, state [, arguments])}\par
\par
{\f1      Severites :}\par
{\f1        0-10  : messages informatifs}\par
{\f1        11-16 : erreurs utilisateur (attrapees par TRY/CATCH)}\par
{\f1        17-19 : erreurs de ressources}\par
{\f1        20-25 : erreurs fatales (connexion terminee)}\par
\par
{\f1      Exemples :}\par
{\f1        RAISERROR('Erreur : %s', 16, 1, @detail)}\par
{\f1        RAISERROR(50001, 16, 1)  -- par numero de message}\par
\par
20.4 @@ERROR\par
\par
{\f1      Retourne le code d erreur de la derniere instruction.}\par
{\f1      0 = pas d erreur. Valeur reintialisee apres chaque}\par
{\f1      instruction.}\par
\par
\par
