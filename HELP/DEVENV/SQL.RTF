{\footnote # IDH_SQL_02}
{\footnote $ SQL - CONVENTIONS LEXICALES}
{\footnote K SQL lexical;commentaires;identificateurs;mots reserves;litteraux;chaines;dates;NULL}
\b\fs24 CONVENTIONS LEXICALES \b0\fs20\par
\par
2.1 Commentaires\par
\par
{\f1     -- commentaire sur une ligne (jusqu a la fin de ligne)}\par
{\f1     /* commentaire sur}\par
{\f1        plusieurs lignes */}\par
\par
{\f1     Les commentaires bloc peuvent etre imbriques :}\par
{\f1     /* niveau 1 /* niveau 2 */ fin niveau 1 */}\par
\par
2.2 Identificateurs\par
\par
{\f1     Les identificateurs nomment les objets de la base :}\par
{\f1     tables, colonnes, variables, procedures, fonctions, etc.}\par
\par
{\f1     Identificateurs reguliers :}\par
{\f1       Commencent par une lettre (a-z, A-Z) ou un underscore (_),}\par
{\f1       at (@) pour les variables, dieise (#) pour les objets}\par
{\f1       temporaires, double dieise (##) pour les objets temporaires}\par
{\f1       globaux.}\par
{\f1       Suivis de lettres, chiffres, underscores, @ ou #.}\par
{\f1       Longueur maximale : 128 caracteres.}\par
{\f1       Non sensibles a la casse (selon la collation par defaut).}\par
\par
{\f1     Identificateurs delimites :}\par
{\f1       [nom avec espaces]    -- crochets (specifique T-SQL)}\par
{\f1       "nom avec espaces"    -- guillemets doubles (SQL standard)}\par
\par
{\f1     Exemples :}\par
{\f1       NomTable     _compte     @variable     #temp}\par
{\f1       ##global     [Nom Colonne]     "Schema"."Table"}\par
\par
2.3 Variables\par
\par
{\f1     Les variables locales commencent par @ :}\par
{\f1       @nom_variable}\par
\par
{\f1     Les variables systeme commencent par @@ :}\par
{\f1       @@ROWCOUNT  @@ERROR  @@IDENTITY  @@VERSION}\par
\par
{\f1     Les parametres de procedures stockees commencent par @ :}\par
{\f1       @param1  @param2}\par
\par
2.4 Litteraux numeriques\par
\par
{\f1     Entiers          : 42, -17, 0}\par
{\f1     Decimaux         : 3.14, -0.5, 123.456}\par
{\f1     Scientifiques    : 1.5E3, 2.7E-4}\par
{\f1     Hexadecimaux     : 0x1A2B, 0xFF}\par
{\f1     Monetaires       : $12.50, -$99.99}\par
\par
2.5 Litteraux chaines\par
\par
{\f1     Chaines ANSI :}\par
{\f1       'texte simple'}\par
{\f1       'l''apostrophe est doublee'}\par
{\f1       ''                          -- chaine vide}\par
\par
{\f1     Chaines Unicode :}\par
{\f1       N'texte unicode'}\par
{\f1       N'l''apostrophe est doublee'}\par
\par
{\f1     Chaines binaires :}\par
{\f1       0x48656C6C6F                -- octets hexadecimaux}\par
\par
2.6 Mots-cles reserves\par
\par
{\f1     T-SQL comporte un grand nombre de mots-cles reserves.}\par
{\f1     Les principaux sont :}\par
\par
{\f1     -- DML}\par
{\f1     SELECT  INSERT  UPDATE  DELETE  MERGE  TRUNCATE}\par
{\f1     BULK INSERT}\par
\par
{\f1     -- Clauses SELECT}\par
{\f1     FROM  WHERE  GROUP BY  HAVING  ORDER BY}\par
{\f1     TOP  DISTINCT  ALL  AS  INTO}\par
\par
{\f1     -- Jointures}\par
{\f1     JOIN  INNER  LEFT  RIGHT  FULL  OUTER  CROSS}\par
{\f1     ON  APPLY}\par
\par
{\f1     -- Operateurs ensemblistes}\par
{\f1     UNION  INTERSECT  EXCEPT}\par
\par
{\f1     -- Predicats}\par
{\f1     AND  OR  NOT  IN  EXISTS  BETWEEN  LIKE}\par
{\f1     IS  NULL  SOME  ANY  ALL}\par
\par
{\f1     -- Expressions}\par
{\f1     CASE  WHEN  THEN  ELSE  END}\par
{\f1     CAST  CONVERT  TRY_CAST  TRY_CONVERT}\par
{\f1     COLLATE  COALESCE  NULLIF  IIF  CHOOSE}\par
\par
{\f1     -- DDL}\par
{\f1     CREATE  ALTER  DROP  TABLE  VIEW  INDEX}\par
{\f1     PROCEDURE  FUNCTION  TRIGGER  DATABASE}\par
{\f1     SCHEMA  SEQUENCE  TYPE  SYNONYM}\par
{\f1     CONSTRAINT  PRIMARY KEY  FOREIGN KEY}\par
{\f1     REFERENCES  UNIQUE  CHECK  DEFAULT}\par
{\f1     IDENTITY  CLUSTERED  NONCLUSTERED}\par
{\f1     COLUMNSTORE  IF EXISTS}\par
\par
{\f1     -- Controle de flux}\par
{\f1     BEGIN  END  IF  ELSE  WHILE  BREAK  CONTINUE}\par
{\f1     GOTO  RETURN  WAITFOR  THROW  TRY  CATCH}\par
{\f1     RAISERROR  PRINT}\par
\par
{\f1     -- Transactions}\par
{\f1     BEGIN TRAN  COMMIT  ROLLBACK  SAVE  TRANSACTION}\par
\par
{\f1     -- DCL}\par
{\f1     GRANT  REVOKE  DENY}\par
\par
{\f1     -- Divers}\par
{\f1     DECLARE  SET  USE  GO  EXEC  EXECUTE}\par
{\f1     WITH  OVER  PARTITION BY  ROWS  RANGE}\par
{\f1     PIVOT  UNPIVOT  OFFSET  FETCH  NEXT  ONLY}\par
{\f1     PERCENT  TIES  OUTPUT  INSERTED  DELETED}\par
{\f1     FOR  XML  JSON  PATH  RAW  AUTO}\par
\par
2.7 Sensibilite a la casse\par
\par
{\f1     Par defaut, T-SQL n est pas sensible a la casse pour les}\par
{\f1     mots-cles et les identificateurs. Cependant, la}\par
{\f1     sensibilite depend de la collation de la base :}\par
\par
{\f1     SQL_Latin1_General_CP1_CI_AS : insensible a la casse (CI)}\par
{\f1     SQL_Latin1_General_CP1_CS_AS : sensible a la casse (CS)}\par
\par
{\f1     Les litteraux chaines respectent toujours la collation.}\par
\par
2.8 Separateur de batch\par
\par
{\f1     GO}\par
{\f1       Separateur de batch (lots d instructions). Ce n est pas}\par
{\f1       un mot-cle T-SQL mais une commande reconnue par les}\par
{\f1       outils client (sqlcmd, SSMS). Chaque batch est compile}\par
{\f1       et execute independamment.}\par
\par
{\f1     Le point-virgule (;) est le terminateur d instruction}\par
{\f1     recommande :}\par
{\f1       SELECT 1;}\par
{\f1       SELECT 2;}\par
\par
\par
