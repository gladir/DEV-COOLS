{\footnote # IDH_SQL_09}
{\footnote $ SQL - INSTRUCTIONS DE CONTROLE DE FLUX (T-SQL)}
{\footnote K SQL controle flux T-SQL;DECLARE;SET;IF ELSE;WHILE;BREAK CONTINUE;BEGIN END;GOTO;RETURN;WAITFOR;PRINT;variables locales}
\b\fs24 INSTRUCTIONS DE CONTROLE DE FLUX (T-SQL) \b0\fs20\par
\par
9.1 DECLARE (declaration de variables)\par
\par
{\f1     DECLARE @variable type [= valeur_initiale]}\par
{\f1     DECLARE @v1 INT, @v2 VARCHAR(50), @v3 DATE}\par
\par
{\f1     -- Variable table}\par
{\f1     DECLARE @table TABLE (}\par
{\f1       id INT,}\par
{\f1       nom NVARCHAR(100),}\par
{\f1       valeur DECIMAL(10,2)}\par
{\f1     )}\par
\par
9.2 SET et SELECT (affectation)\par
\par
{\f1     SET @variable = expression}\par
{\f1     SELECT @variable = expression}\par
\par
{\f1     -- Affectation depuis une requete}\par
{\f1     SELECT @nom = nom, @age = age}\par
{\f1     FROM Employes}\par
{\f1     WHERE id = @id}\par
\par
{\f1     Difference entre SET et SELECT :}\par
{\f1     - SET affecte une seule variable a la fois}\par
{\f1     - SELECT peut affecter plusieurs variables}\par
{\f1     - SET leve une erreur si la sous-requete retourne}\par
{\f1       plus d une ligne ; SELECT prend la derniere valeur}\par
\par
9.3 IF ... ELSE\par
\par
{\f1     IF condition}\par
{\f1       instruction_ou_bloc}\par
{\f1     [ELSE}\par
{\f1       instruction_ou_bloc]}\par
\par
{\f1     Exemples :}\par
{\f1       IF @age >= 18}\par
{\f1         PRINT 'Majeur'}\par
{\f1       ELSE}\par
{\f1         PRINT 'Mineur'}\par
\par
{\f1       IF EXISTS (SELECT 1 FROM Employes WHERE id = @id)}\par
{\f1       BEGIN}\par
{\f1         UPDATE Employes SET actif = 1 WHERE id = @id}\par
{\f1         PRINT 'Employe active'}\par
{\f1       END}\par
{\f1       ELSE}\par
{\f1       BEGIN}\par
{\f1         PRINT 'Employe non trouve'}\par
{\f1       END}\par
\par
9.4 BEGIN ... END (blocs)\par
\par
{\f1     BEGIN}\par
{\f1       instruction1}\par
{\f1       instruction2}\par
{\f1       ...}\par
{\f1     END}\par
\par
{\f1     Les blocs sont necessaires quand IF, ELSE, WHILE}\par
{\f1     contiennent plus d une instruction.}\par
\par
9.5 WHILE\par
\par
{\f1     WHILE condition}\par
{\f1     BEGIN}\par
{\f1       instructions}\par
{\f1       [BREAK]}\par
{\f1       [CONTINUE]}\par
{\f1     END}\par
\par
{\f1     Exemple :}\par
{\f1       DECLARE @i INT = 1}\par
{\f1       WHILE @i <= 10}\par
{\f1       BEGIN}\par
{\f1         PRINT @i}\par
{\f1         SET @i += 1}\par
{\f1       END}\par
\par
9.6 BREAK et CONTINUE\par
\par
{\f1     BREAK     : sort de la boucle WHILE englobante}\par
{\f1     CONTINUE  : passe a l iteration suivante}\par
\par
9.7 GOTO et labels\par
\par
{\f1     GOTO label_name}\par
{\f1     label_name:}\par
\par
{\f1     Exemple :}\par
{\f1       IF @erreur = 1 GOTO Nettoyage}\par
{\f1       -- traitement normal}\par
{\f1       Nettoyage:}\par
{\f1       PRINT 'Nettoyage en cours'}\par
\par
9.8 RETURN\par
\par
{\f1     RETURN [valeur_entiere]}\par
\par
{\f1     Termine l execution du batch, de la procedure ou de la}\par
{\f1     fonction. Pour les procedures, la valeur de retour est}\par
{\f1     un entier (0 = succes par convention).}\par
\par
9.9 WAITFOR\par
\par
{\f1     WAITFOR DELAY 'hh:mm:ss'     -- pause de duree fixe}\par
{\f1     WAITFOR TIME 'hh:mm:ss'      -- attente jusqu a une heure}\par
\par
{\f1     Exemples :}\par
{\f1       WAITFOR DELAY '00:00:05'    -- pause de 5 secondes}\par
{\f1       WAITFOR TIME '23:00:00'     -- attend 23 heures}\par
\par
9.10 PRINT\par
\par
{\f1      PRINT expression}\par
\par
{\f1      Affiche un message texte au client.}\par
{\f1      Exemples :}\par
{\f1        PRINT 'Traitement termine'}\par
{\f1        PRINT 'Nombre de lignes : ' + CAST(@count AS VARCHAR)}\par
\par
9.11 EXEC / EXECUTE\par
\par
{\f1      EXEC nom_procedure @param1, @param2}\par
{\f1      EXEC nom_procedure @param1 = valeur1, @param2 = valeur2}\par
{\f1      EXEC @ret = nom_procedure @param1}\par
\par
{\f1      -- SQL dynamique}\par
{\f1      EXEC('SELECT * FROM ' + @nom_table)}\par
{\f1      EXEC sp_executesql N'SELECT * FROM table WHERE id = @p',}\par
{\f1                         N'@p INT', @p = 42}\par
\par
9.12 USE et GO\par
\par
{\f1      USE nom_base    -- change la base de donnees courante}\par
{\f1      GO              -- separateur de batch}\par
\par
\par
