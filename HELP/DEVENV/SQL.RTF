{\footnote # IDH_SQL_18}
{\footnote $ SQL - PROCEDURES STOCKEES ET FONCTIONS UTILISATEUR}
{\footnote K SQL procedures stockees fonctions;CREATE PROCEDURE;EXECUTE EXEC;parametres OUTPUT;CREATE FUNCTION;scalar function;table-valued function;RETURNS}
\b\fs24 PROCEDURES STOCKEES ET FONCTIONS UTILISATEUR \b0\fs20\par
\par
18.1 Procedures stockees\par
\par
{\f1      Creation :}\par
{\f1        CREATE [OR ALTER] PROCEDURE nom}\par
{\f1          @p1 type [= defaut] [OUTPUT],}\par
{\f1          @p2 type [= defaut]}\par
{\f1        AS}\par
{\f1        BEGIN}\par
{\f1          -- corps}\par
{\f1        END}\par
\par
{\f1      Appel :}\par
{\f1        EXEC nom @param1, @param2}\par
{\f1        EXEC nom @p1 = valeur1, @p2 = valeur2}\par
{\f1        DECLARE @ret INT}\par
{\f1        EXEC @ret = nom @param1}\par
\par
{\f1      Procedures systeme courantes :}\par
{\f1        sp_help 'nom_objet'           info sur un objet}\par
{\f1        sp_helptext 'nom_procedure'   texte source}\par
{\f1        sp_columns 'nom_table'        colonnes d une table}\par
{\f1        sp_tables                     liste des tables}\par
{\f1        sp_who                        sessions actives}\par
{\f1        sp_executesql @sql, @params   SQL dynamique}\par
\par
18.2 Fonctions scalaires\par
\par
{\f1      CREATE FUNCTION fn_Nom (@p1 type, @p2 type)}\par
{\f1      RETURNS type_retour}\par
{\f1      AS}\par
{\f1      BEGIN}\par
{\f1        DECLARE @r type_retour}\par
{\f1        SET @r = ...}\par
{\f1        RETURN @r}\par
{\f1      END}\par
\par
{\f1      Appel : SELECT dbo.fn_Nom(val1, val2)}\par
\par
18.3 Fonctions table en ligne (Inline TVF)\par
\par
{\f1      CREATE FUNCTION fn_Nom (@p1 type)}\par
{\f1      RETURNS TABLE}\par
{\f1      AS}\par
{\f1      RETURN (}\par
{\f1        SELECT col1, col2 FROM table WHERE col = @p1}\par
{\f1      )}\par
\par
{\f1      Appel : SELECT * FROM dbo.fn_Nom(valeur)}\par
\par
18.4 Fonctions table multi-instructions (MSTVF)\par
\par
{\f1      CREATE FUNCTION fn_Nom (@p1 type)}\par
{\f1      RETURNS @result TABLE (col1 type, col2 type)}\par
{\f1      AS}\par
{\f1      BEGIN}\par
{\f1        INSERT INTO @result SELECT ... FROM ...}\par
{\f1        RETURN}\par
{\f1      END}\par
\par
\par
