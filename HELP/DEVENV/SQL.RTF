{\footnote # IDH_SQL_03}
{\footnote $ SQL - TYPES DE DONNEES}
{\footnote K SQL types donnees;INT BIGINT SMALLINT TINYINT;DECIMAL NUMERIC FLOAT REAL;CHAR VARCHAR NVARCHAR;DATE DATETIME DATETIME2;BIT;UNIQUEIDENTIFIER;XML}
\b\fs24 TYPES DE DONNEES \b0\fs20\par
\par
3.1 Types numeriques exacts\par
\par
{\f1     Type              Taille   Plage / Description}\par
{\f1     ----------------  -------  --------------------------------}\par
{\f1     BIT               1 bit    0 ou 1}\par
{\f1     TINYINT           1 octet  0 a 255}\par
{\f1     SMALLINT          2 octets -32768 a 32767}\par
{\f1     INT               4 octets -2^31 a 2^31-1}\par
{\f1     BIGINT            8 octets -2^63 a 2^63-1}\par
{\f1     DECIMAL(p,s)      5-17 oct Precision p (1-38), echelle s}\par
{\f1     NUMERIC(p,s)      5-17 oct Synonyme de DECIMAL}\par
{\f1     SMALLMONEY        4 octets -214748.3648 a 214748.3647}\par
{\f1     MONEY             8 octets -922337203685477.5808 a}\par
{\f1                                 922337203685477.5807}\par
\par
3.2 Types numeriques approches\par
\par
{\f1     Type              Taille   Description}\par
{\f1     ----------------  -------  --------------------------------}\par
{\f1     REAL              4 octets IEEE 754 simple precision}\par
{\f1     FLOAT [(n)]       4 ou 8   n=1-24: 4 oct, n=25-53: 8 oct}\par
{\f1                       octets   IEEE 754 double par defaut}\par
\par
3.3 Types chaines de caracteres\par
\par
{\f1     Type              Taille     Description}\par
{\f1     ----------------  ---------  ----------------------------}\par
{\f1     CHAR(n)           n octets   Chaine fixe (1-8000)}\par
{\f1     VARCHAR(n)        variable   Chaine variable (1-8000)}\par
{\f1     VARCHAR(MAX)      variable   Jusqu a 2^31-1 octets}\par
{\f1     TEXT              variable   Obsolete, remplace par}\par
{\f1                                  VARCHAR(MAX)}\par
\par
{\f1     Les types CHAR/VARCHAR utilisent la page de code de la}\par
{\f1     collation de la colonne (ex: Latin1, CP1252).}\par
\par
3.4 Types chaines Unicode\par
\par
{\f1     Type              Taille     Description}\par
{\f1     ----------------  ---------  ----------------------------}\par
{\f1     NCHAR(n)          2*n oct.   Unicode fixe (1-4000)}\par
{\f1     NVARCHAR(n)       variable   Unicode variable (1-4000)}\par
{\f1     NVARCHAR(MAX)     variable   Jusqu a 2^31-1 octets}\par
{\f1     NTEXT             variable   Obsolete, remplace par}\par
{\f1                                  NVARCHAR(MAX)}\par
\par
{\f1     Encodage : UTF-16 Little-Endian.}\par
\par
3.5 Types date et heure\par
\par
{\f1     Type              Taille   Description}\par
{\f1     ----------------  -------  --------------------------------}\par
{\f1     DATE              3 octets 0001-01-01 a 9999-12-31}\par
{\f1     TIME(p)           3-5 oct. 00:00:00.0000000 a}\par
{\f1                                23:59:59.9999999 (precision p)}\par
{\f1     DATETIME          8 octets 1753-01-01 a 9999-12-31}\par
{\f1                                Precision : 3.33 ms}\par
{\f1     DATETIME2(p)      6-8 oct. 0001-01-01 a 9999-12-31}\par
{\f1                                Precision : 100 ns (p=7)}\par
{\f1     SMALLDATETIME     4 octets 1900-01-01 a 2079-06-06}\par
{\f1                                Precision : 1 minute}\par
{\f1     DATETIMEOFFSET(p) 8-10 oct DATETIME2 + fuseau horaire}\par
{\f1                                (-14:00 a +14:00)}\par
\par
{\f1     Formats de litteraux :}\par
{\f1       '2026-03-21'                  -- DATE (ISO 8601)}\par
{\f1       '14:30:00'                    -- TIME}\par
{\f1       '2026-03-21 14:30:00'         -- DATETIME}\par
{\f1       '2026-03-21T14:30:00.123'     -- DATETIME2}\par
{\f1       '2026-03-21 14:30:00 +02:00'  -- DATETIMEOFFSET}\par
\par
3.6 Types binaires\par
\par
{\f1     Type              Taille     Description}\par
{\f1     ----------------  ---------  ----------------------------}\par
{\f1     BINARY(n)         n octets   Binaire fixe (1-8000)}\par
{\f1     VARBINARY(n)      variable   Binaire variable (1-8000)}\par
{\f1     VARBINARY(MAX)    variable   Jusqu a 2^31-1 octets}\par
{\f1     IMAGE             variable   Obsolete, remplace par}\par
{\f1                                  VARBINARY(MAX)}\par
{\f1     TIMESTAMP         8 octets   Synonyme de ROWVERSION}\par
{\f1     ROWVERSION        8 octets   Valeur auto-incrementee}\par
\par
3.7 Types speciaux\par
\par
{\f1     Type               Taille    Description}\par
{\f1     -----------------  --------  ----------------------------}\par
{\f1     UNIQUEIDENTIFIER   16 octets GUID (ex: '6F9619FF-...')}\par
{\f1     SQL_VARIANT        variable  Peut stocker la plupart des}\par
{\f1                                  types de base}\par
{\f1     XML                variable  Document ou fragment XML}\par
{\f1     HIERARCHYID        variable  Position dans une hierarchie}\par
{\f1     GEOGRAPHY          variable  Donnees geospatiales}\par
{\f1     GEOMETRY           variable  Donnees geometriques planes}\par
{\f1     TABLE              variable  Variable de type table}\par
{\f1     CURSOR             -         Pointeur de curseur}\par
\par
3.8 Conversion de types\par
\par
{\f1     Conversion implicite :}\par
{\f1       T-SQL convertit automatiquement certains types dans les}\par
{\f1       expressions mixtes selon les regles de precedence :}\par
{\f1         sql_variant > datetimeoffset > datetime2 > datetime >}\par
{\f1         smalldatetime > date > time > float > real > decimal >}\par
{\f1         money > smallmoney > bigint > int > smallint > tinyint >}\par
{\f1         bit > nvarchar > nchar > varchar > char > varbinary >}\par
{\f1         binary > uniqueidentifier}\par
\par
{\f1     Conversion explicite :}\par
{\f1       CAST(expression AS type)}\par
{\f1       CONVERT(type, expression [, style])}\par
{\f1       TRY_CAST(expression AS type)      -- retourne NULL si echec}\par
{\f1       TRY_CONVERT(type, expression)     -- retourne NULL si echec}\par
\par
{\f1     Exemples :}\par
{\f1       CAST(42 AS VARCHAR(10))           -- '42'}\par
{\f1       CAST('2026-03-21' AS DATE)        -- conversion de date}\par
{\f1       CONVERT(VARCHAR, GETDATE(), 120)  -- format ISO}\par
{\f1       TRY_CAST('abc' AS INT)            -- retourne NULL}\par
\par
\par
