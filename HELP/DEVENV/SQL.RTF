{\footnote # IDH_SQL_06}
{\footnote $ SQL - INSTRUCTIONS DML (DATA MANIPULATION LANGUAGE)}
{\footnote K SQL DML;SELECT;INSERT;UPDATE;DELETE;MERGE;OUTPUT;TOP;ORDER BY;OFFSET FETCH}
\b\fs24 INSTRUCTIONS DML (DATA MANIPULATION LANGUAGE) \b0\fs20\par
\par
6.1 SELECT\par
\par
{\f1     Syntaxe complete :}\par
\par
{\f1     [WITH cte AS (requete)]}\par
{\f1     SELECT [ALL | DISTINCT]}\par
{\f1            [TOP (n) [PERCENT] [WITH TIES]]}\par
{\f1            liste_colonnes | *}\par
{\f1     [INTO nouvelle_table]}\par
{\f1     FROM source_table [AS alias]}\par
{\f1          [WITH (hint_table)]}\par
{\f1     [jointures]}\par
{\f1     [WHERE condition]}\par
{\f1     [GROUP BY colonnes [WITH ROLLUP | CUBE]}\par
{\f1              | GROUPING SETS ((cols), ...)]}\par
{\f1     [HAVING condition]}\par
{\f1     [ORDER BY colonnes [ASC | DESC]}\par
{\f1               [OFFSET n ROWS [FETCH NEXT m ROWS ONLY]]]}\par
{\f1     [FOR XML PATH('element') | RAW | AUTO | EXPLICIT]}\par
{\f1     [FOR JSON PATH | AUTO]}\par
{\f1     [OPTION (query_hints)]}\par
\par
{\f1     Exemples :}\par
\par
{\f1     -- Requete simple}\par
{\f1     SELECT nom, prenom, age FROM Employes WHERE age > 30}\par
\par
{\f1     -- Avec alias}\par
{\f1     SELECT e.nom AS NomEmploye, d.nom AS NomDepartement}\par
{\f1     FROM Employes e}\par
{\f1     INNER JOIN Departements d ON e.dept_id = d.id}\par
\par
{\f1     -- Top 10 avec tri}\par
{\f1     SELECT TOP 10 nom, salaire}\par
{\f1     FROM Employes}\par
{\f1     ORDER BY salaire DESC}\par
\par
{\f1     -- Pagination (SQL Server 2012+)}\par
{\f1     SELECT nom, prenom}\par
{\f1     FROM Employes}\par
{\f1     ORDER BY nom}\par
{\f1     OFFSET 20 ROWS FETCH NEXT 10 ROWS ONLY}\par
\par
{\f1     -- CTE (Common Table Expression)}\par
{\f1     WITH VentesParRegion AS (}\par
{\f1       SELECT region, SUM(montant) AS total}\par
{\f1       FROM Ventes}\par
{\f1       GROUP BY region}\par
{\f1     )}\par
{\f1     SELECT * FROM VentesParRegion WHERE total > 10000}\par
\par
{\f1     -- CTE recursive}\par
{\f1     WITH Hierarchie AS (}\par
{\f1       SELECT id, nom, manager_id, 0 AS niveau}\par
{\f1       FROM Employes WHERE manager_id IS NULL}\par
{\f1       UNION ALL}\par
{\f1       SELECT e.id, e.nom, e.manager_id, h.niveau + 1}\par
{\f1       FROM Employes e}\par
{\f1       INNER JOIN Hierarchie h ON e.manager_id = h.id}\par
{\f1     )}\par
{\f1     SELECT * FROM Hierarchie}\par
\par
{\f1     -- SELECT INTO (creation de table)}\par
{\f1     SELECT * INTO #TempEmployes FROM Employes WHERE actif = 1}\par
\par
6.2 INSERT\par
\par
{\f1     -- Insertion de valeurs explicites}\par
{\f1     INSERT INTO table (col1, col2, col3)}\par
{\f1     VALUES (val1, val2, val3)}\par
\par
{\f1     -- Insertion de plusieurs lignes (SQL Server 2008+)}\par
{\f1     INSERT INTO table (col1, col2)}\par
{\f1     VALUES (1, 'a'), (2, 'b'), (3, 'c')}\par
\par
{\f1     -- Insertion par requete}\par
{\f1     INSERT INTO table (col1, col2)}\par
{\f1     SELECT colA, colB FROM autre_table WHERE condition}\par
\par
{\f1     -- Insertion avec valeurs par defaut}\par
{\f1     INSERT INTO table DEFAULT VALUES}\par
\par
{\f1     -- Insertion avec OUTPUT}\par
{\f1     INSERT INTO table (col1, col2)}\par
{\f1     OUTPUT INSERTED.id, INSERTED.col1}\par
{\f1     VALUES (val1, val2)}\par
\par
{\f1     -- Insertion par execution de procedure}\par
{\f1     INSERT INTO table}\par
{\f1     EXEC nom_procedure @param1, @param2}\par
\par
6.3 UPDATE\par
\par
{\f1     -- Mise a jour simple}\par
{\f1     UPDATE table}\par
{\f1     SET col1 = val1, col2 = val2}\par
{\f1     WHERE condition}\par
\par
{\f1     -- Mise a jour avec FROM (jointure, specifique T-SQL)}\par
{\f1     UPDATE t}\par
{\f1     SET t.col1 = s.valeur}\par
{\f1     FROM table_cible t}\par
{\f1     INNER JOIN table_source s ON t.id = s.id}\par
{\f1     WHERE s.status = 'actif'}\par
\par
{\f1     -- Mise a jour avec TOP}\par
{\f1     UPDATE TOP (100) table}\par
{\f1     SET traite = 1}\par
{\f1     WHERE traite = 0}\par
\par
{\f1     -- Mise a jour avec OUTPUT}\par
{\f1     UPDATE table}\par
{\f1     SET status = 'archive'}\par
{\f1     OUTPUT DELETED.id, DELETED.status, INSERTED.status}\par
{\f1     WHERE date_creation < '2020-01-01'}\par
\par
{\f1     -- Affectation composee}\par
{\f1     UPDATE table SET compteur += 1 WHERE id = @id}\par
\par
6.4 DELETE\par
\par
{\f1     -- Suppression simple}\par
{\f1     DELETE FROM table WHERE condition}\par
\par
{\f1     -- Suppression avec TOP}\par
{\f1     DELETE TOP (1000) FROM table WHERE archive = 1}\par
\par
{\f1     -- Suppression avec FROM (jointure, specifique T-SQL)}\par
{\f1     DELETE t}\par
{\f1     FROM table_cible t}\par
{\f1     INNER JOIN table_ref r ON t.ref_id = r.id}\par
{\f1     WHERE r.expire = 1}\par
\par
{\f1     -- Suppression avec OUTPUT}\par
{\f1     DELETE FROM table}\par
{\f1     OUTPUT DELETED.*}\par
{\f1     WHERE id = @id}\par
\par
6.5 TRUNCATE TABLE\par
\par
{\f1     TRUNCATE TABLE nom_table}\par
\par
{\f1     Supprime toutes les lignes de la table sans journaliser}\par
{\f1     chaque suppression individuelle. Plus rapide que DELETE}\par
{\f1     sans WHERE. Reinitialise les colonnes IDENTITY.}\par
\par
6.6 MERGE\par
\par
{\f1     MERGE INTO table_cible AS cible}\par
{\f1     USING table_source AS source}\par
{\f1     ON cible.id = source.id}\par
{\f1     WHEN MATCHED THEN}\par
{\f1       UPDATE SET cible.col1 = source.col1}\par
{\f1     WHEN NOT MATCHED [BY TARGET] THEN}\par
{\f1       INSERT (col1, col2) VALUES (source.col1, source.col2)}\par
{\f1     WHEN NOT MATCHED BY SOURCE THEN}\par
{\f1       DELETE}\par
{\f1     OUTPUT $action, INSERTED.*, DELETED.*;}\par
\par
{\f1     L instruction MERGE permet de combiner INSERT, UPDATE et}\par
{\f1     DELETE en une seule instruction basee sur une condition}\par
{\f1     de correspondance.}\par
\par
6.7 BULK INSERT\par
\par
{\f1     BULK INSERT table}\par
{\f1     FROM 'chemin\\fichier.csv'}\par
{\f1     WITH (}\par
{\f1       FIELDTERMINATOR = ',',}\par
{\f1       ROWTERMINATOR = '\\n',}\par
{\f1       FIRSTROW = 2,}\par
{\f1       CODEPAGE = '65001',}\par
{\f1       TABLOCK}\par
{\f1     )}\par
\par
\par
