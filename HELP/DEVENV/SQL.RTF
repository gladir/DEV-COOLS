{\footnote # IDH_SQL_07}
{\footnote $ SQL - INSTRUCTIONS DDL (DATA DEFINITION LANGUAGE)}
{\footnote K SQL DDL;CREATE TABLE;ALTER TABLE;DROP;TRUNCATE;CREATE INDEX;CREATE VIEW;CREATE SCHEMA;contraintes PRIMARY KEY FOREIGN KEY CHECK UNIQUE DEFAULT}
\b\fs24 INSTRUCTIONS DDL (DATA DEFINITION LANGUAGE) \b0\fs20\par
\par
7.1 CREATE TABLE\par
\par
{\f1     CREATE TABLE nom_schema.nom_table (}\par
{\f1       col1 type [IDENTITY(seed, increment)]}\par
{\f1                 [NOT NULL | NULL]}\par
{\f1                 [PRIMARY KEY [CLUSTERED | NONCLUSTERED]]}\par
{\f1                 [UNIQUE]}\par
{\f1                 [DEFAULT valeur]}\par
{\f1                 [CHECK (condition)]}\par
{\f1                 [REFERENCES table_ref(col_ref)]}\par
{\f1                 [COLLATE collation],}\par
{\f1       col2 type ...,}\par
{\f1       ...}\par
{\f1       [CONSTRAINT nom_pk PRIMARY KEY [CLUSTERED] (col1, ...)],}\par
{\f1       [CONSTRAINT nom_uq UNIQUE [NONCLUSTERED] (col1, ...)],}\par
{\f1       [CONSTRAINT nom_fk FOREIGN KEY (col1)}\par
{\f1                   REFERENCES table_ref(col_ref)}\par
{\f1                   [ON DELETE CASCADE | SET NULL | NO ACTION]}\par
{\f1                   [ON UPDATE CASCADE | SET NULL | NO ACTION]],}\par
{\f1       [CONSTRAINT nom_ck CHECK (condition)],}\par
{\f1       [CONSTRAINT nom_df DEFAULT valeur FOR col1]}\par
{\f1     )}\par
\par
{\f1     Exemples :}\par
\par
{\f1     CREATE TABLE Employes (}\par
{\f1       id INT IDENTITY(1,1) NOT NULL PRIMARY KEY,}\par
{\f1       nom NVARCHAR(100) NOT NULL,}\par
{\f1       prenom NVARCHAR(100) NOT NULL,}\par
{\f1       email VARCHAR(255) UNIQUE,}\par
{\f1       date_embauche DATE DEFAULT GETDATE(),}\par
{\f1       salaire DECIMAL(10,2) CHECK (salaire > 0),}\par
{\f1       dept_id INT REFERENCES Departements(id)}\par
{\f1     )}\par
\par
{\f1     -- Table temporaire locale}\par
{\f1     CREATE TABLE #TempTable (id INT, valeur VARCHAR(100))}\par
\par
{\f1     -- Table temporaire globale}\par
{\f1     CREATE TABLE ##GlobalTemp (id INT, valeur VARCHAR(100))}\par
\par
7.2 ALTER TABLE\par
\par
{\f1     ALTER TABLE table ADD colonne type [contraintes]}\par
{\f1     ALTER TABLE table ALTER COLUMN col nouveau_type [NULL|NOT NULL]}\par
{\f1     ALTER TABLE table DROP COLUMN colonne}\par
{\f1     ALTER TABLE table ADD CONSTRAINT nom_contrainte ...}\par
{\f1     ALTER TABLE table DROP CONSTRAINT nom_contrainte}\par
{\f1     ALTER TABLE table ENABLE TRIGGER nom_trigger}\par
{\f1     ALTER TABLE table DISABLE TRIGGER nom_trigger}\par
\par
{\f1     Exemples :}\par
\par
{\f1     ALTER TABLE Employes ADD telephone VARCHAR(20) NULL}\par
{\f1     ALTER TABLE Employes ALTER COLUMN nom NVARCHAR(200) NOT NULL}\par
{\f1     ALTER TABLE Employes DROP COLUMN telephone}\par
\par
7.3 DROP TABLE\par
\par
{\f1     DROP TABLE [IF EXISTS] nom_table}\par
\par
7.4 CREATE INDEX\par
\par
{\f1     CREATE [UNIQUE] [CLUSTERED | NONCLUSTERED] INDEX nom_index}\par
{\f1     ON table (col1 [ASC|DESC], col2 [ASC|DESC], ...)}\par
{\f1     [INCLUDE (col3, col4, ...)]}\par
{\f1     [WHERE condition_filtre]}\par
{\f1     [WITH (}\par
{\f1       FILLFACTOR = n,}\par
{\f1       PAD_INDEX = ON | OFF,}\par
{\f1       ONLINE = ON | OFF,}\par
{\f1       SORT_IN_TEMPDB = ON | OFF}\par
{\f1     )]}\par
\par
{\f1     Exemples :}\par
\par
{\f1     CREATE INDEX IX_Emp_Nom ON Employes (nom)}\par
{\f1     CREATE UNIQUE INDEX UX_Emp_Email ON Employes (email)}\par
{\f1       WHERE email IS NOT NULL}\par
{\f1     CREATE INDEX IX_Emp_Dept_Salaire ON Employes (dept_id, salaire DESC)}\par
{\f1       INCLUDE (nom, prenom)}\par
\par
{\f1     -- Index columnstore (SQL Server 2012+)}\par
{\f1     CREATE CLUSTERED COLUMNSTORE INDEX CCI_Ventes ON Ventes}\par
{\f1     CREATE NONCLUSTERED COLUMNSTORE INDEX NCCI_Ventes}\par
{\f1       ON Ventes (date_vente, montant, region)}\par
\par
7.5 ALTER INDEX\par
\par
{\f1     ALTER INDEX nom_index ON table REBUILD}\par
{\f1     ALTER INDEX nom_index ON table REORGANIZE}\par
{\f1     ALTER INDEX nom_index ON table DISABLE}\par
{\f1     ALTER INDEX ALL ON table REBUILD}\par
\par
7.6 DROP INDEX\par
\par
{\f1     DROP INDEX [IF EXISTS] nom_index ON table}\par
\par
7.7 CREATE VIEW\par
\par
{\f1     CREATE [OR ALTER] VIEW nom_vue}\par
{\f1     [WITH SCHEMABINDING]}\par
{\f1     AS}\par
{\f1       SELECT ...}\par
{\f1     [WITH CHECK OPTION]}\par
\par
{\f1     Exemple :}\par
\par
{\f1     CREATE VIEW vw_EmployesActifs}\par
{\f1     WITH SCHEMABINDING}\par
{\f1     AS}\par
{\f1       SELECT id, nom, prenom, dept_id}\par
{\f1       FROM dbo.Employes}\par
{\f1       WHERE actif = 1}\par
\par
7.8 CREATE PROCEDURE\par
\par
{\f1     CREATE [OR ALTER] PROCEDURE nom_procedure}\par
{\f1       @param1 type [= valeur_defaut] [OUTPUT],}\par
{\f1       @param2 type [= valeur_defaut]}\par
{\f1     AS}\par
{\f1     BEGIN}\par
{\f1       -- corps de la procedure}\par
{\f1     END}\par
\par
{\f1     Exemple :}\par
\par
{\f1     CREATE PROCEDURE sp_GetEmployes}\par
{\f1       @dept_id INT,}\par
{\f1       @count INT OUTPUT}\par
{\f1     AS}\par
{\f1     BEGIN}\par
{\f1       SELECT * FROM Employes WHERE dept_id = @dept_id}\par
{\f1       SET @count = @@ROWCOUNT}\par
{\f1     END}\par
\par
7.9 CREATE FUNCTION\par
\par
{\f1     -- Fonction scalaire}\par
{\f1     CREATE [OR ALTER] FUNCTION nom_fonction (}\par
{\f1       @param1 type,}\par
{\f1       @param2 type}\par
{\f1     )}\par
{\f1     RETURNS type_retour}\par
{\f1     AS}\par
{\f1     BEGIN}\par
{\f1       DECLARE @resultat type_retour}\par
{\f1       -- calculs}\par
{\f1       RETURN @resultat}\par
{\f1     END}\par
\par
{\f1     -- Fonction table en ligne}\par
{\f1     CREATE FUNCTION fn_GetEmployes (@dept_id INT)}\par
{\f1     RETURNS TABLE}\par
{\f1     AS}\par
{\f1     RETURN (}\par
{\f1       SELECT * FROM Employes WHERE dept_id = @dept_id}\par
{\f1     )}\par
\par
{\f1     -- Fonction table multi-instructions}\par
{\f1     CREATE FUNCTION fn_Hierarchie (@id INT)}\par
{\f1     RETURNS @result TABLE (id INT, nom NVARCHAR(100), niveau INT)}\par
{\f1     AS}\par
{\f1     BEGIN}\par
{\f1       -- logique d insertion dans @result}\par
{\f1       RETURN}\par
{\f1     END}\par
\par
7.10 CREATE TRIGGER\par
\par
{\f1      CREATE [OR ALTER] TRIGGER nom_trigger}\par
{\f1      ON table}\par
{\f1      FOR | AFTER | INSTEAD OF [INSERT] [,] [UPDATE] [,] [DELETE]}\par
{\f1      AS}\par
{\f1      BEGIN}\par
{\f1        -- corps du trigger}\par
{\f1        -- Tables virtuelles : INSERTED, DELETED}\par
{\f1      END}\par
\par
{\f1      Exemple :}\par
\par
{\f1      CREATE TRIGGER trg_AuditEmployes}\par
{\f1      ON Employes}\par
{\f1      AFTER UPDATE}\par
{\f1      AS}\par
{\f1      BEGIN}\par
{\f1        INSERT INTO AuditLog (table_name, action, date_modif)}\par
{\f1        SELECT 'Employes', 'UPDATE', GETDATE()}\par
{\f1        FROM INSERTED}\par
{\f1      END}\par
\par
7.11 Autres objets DDL\par
\par
{\f1      CREATE SCHEMA nom_schema}\par
{\f1      CREATE SEQUENCE nom_sequence}\par
{\f1        AS type START WITH n INCREMENT BY n}\par
{\f1        [MINVALUE n] [MAXVALUE n] [CYCLE | NO CYCLE]}\par
{\f1      CREATE TYPE nom_type FROM type_base [NOT NULL]}\par
{\f1      CREATE TYPE nom_type AS TABLE (col type, ...)}\par
{\f1      CREATE SYNONYM nom FOR objet_cible}\par
{\f1      CREATE DATABASE nom_base}\par
\par
{\f1      DROP VIEW [IF EXISTS] nom_vue}\par
{\f1      DROP PROCEDURE [IF EXISTS] nom_procedure}\par
{\f1      DROP FUNCTION [IF EXISTS] nom_fonction}\par
{\f1      DROP TRIGGER [IF EXISTS] nom_trigger}\par
{\f1      DROP SCHEMA nom_schema}\par
{\f1      DROP SEQUENCE nom_sequence}\par
{\f1      DROP TYPE nom_type}\par
\par
\par
