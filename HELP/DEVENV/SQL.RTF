{\footnote # IDH_SQL_04}
{\footnote $ SQL - EXPRESSIONS}
{\footnote K SQL expressions;CASE;COALESCE NULLIF;ISNULL;CAST CONVERT;TRY_CAST}
\b\fs24 EXPRESSIONS \b0\fs20\par
\par
4.1 Expressions scalaires\par
\par
{\f1     Une expression scalaire produit une valeur unique :}\par
\par
{\f1     42                          -- litteraux}\par
{\f1     'texte'}\par
{\f1     @variable                   -- variable locale}\par
{\f1     @@ROWCOUNT                  -- variable systeme}\par
{\f1     nom_colonne                 -- reference de colonne}\par
{\f1     table.colonne               -- reference qualifiee}\par
{\f1     schema.table.colonne        -- reference completement qualifiee}\par
{\f1     (expression)                -- parentheses}\par
{\f1     fonction(args)              -- appel de fonction}\par
{\f1     (SELECT expr FROM ...)      -- sous-requete scalaire}\par
\par
4.2 Expression CASE\par
\par
{\f1     Forme simple :}\par
{\f1       CASE expression}\par
{\f1         WHEN valeur1 THEN resultat1}\par
{\f1         WHEN valeur2 THEN resultat2}\par
{\f1         ...}\par
{\f1         ELSE resultat_defaut}\par
{\f1       END}\par
\par
{\f1     Forme recherchee :}\par
{\f1       CASE}\par
{\f1         WHEN condition1 THEN resultat1}\par
{\f1         WHEN condition2 THEN resultat2}\par
{\f1         ...}\par
{\f1         ELSE resultat_defaut}\par
{\f1       END}\par
\par
{\f1     Exemples :}\par
{\f1       CASE status WHEN 'A' THEN 'Actif' ELSE 'Inactif' END}\par
{\f1       CASE WHEN age >= 18 THEN 'Majeur' ELSE 'Mineur' END}\par
\par
4.3 Expression COALESCE et NULLIF\par
\par
{\f1     COALESCE(expr1, expr2, ..., exprN)}\par
{\f1       Retourne la premiere expression non NULL.}\par
{\f1       Equivalent a CASE WHEN expr1 IS NOT NULL THEN expr1}\par
{\f1                         WHEN expr2 IS NOT NULL THEN expr2}\par
{\f1                         ... END}\par
\par
{\f1     NULLIF(expr1, expr2)}\par
{\f1       Retourne NULL si expr1 = expr2, sinon retourne expr1.}\par
\par
4.4 Expression IIF et CHOOSE\par
\par
{\f1     IIF(condition, valeur_vrai, valeur_faux)}\par
{\f1       Equivalent a CASE WHEN condition THEN valeur_vrai}\par
{\f1                         ELSE valeur_faux END}\par
\par
{\f1     CHOOSE(index, val1, val2, ..., valN)}\par
{\f1       Retourne la valeur a la position index (base 1).}\par
\par
\par
