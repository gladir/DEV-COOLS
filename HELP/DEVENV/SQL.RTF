{\footnote # IDH_SQL_22}
{\footnote $ SQL - VARIABLES ET FONCTIONS SYSTEME}
{\footnote K SQL exemples}
\b\fs24 VARIABLES ET FONCTIONS SYSTEME \b0\fs20\par
\par
22.1 Variables systeme (@@)\par
\par
{\f1      @@ROWCOUNT        nombre de lignes affectees par la}\par
{\f1                        derniere instruction}\par
{\f1      @@ERROR           code d erreur de la derniere instruction}\par
{\f1      @@IDENTITY        derniere valeur IDENTITY inseree}\par
{\f1      @@TRANCOUNT       niveau d imbrication des transactions}\par
{\f1      @@FETCH_STATUS    statut du dernier FETCH de curseur}\par
{\f1      @@SPID            ID de la session courante}\par
{\f1      @@VERSION         version de SQL Server}\par
{\f1      @@SERVERNAME      nom du serveur}\par
{\f1      @@DBTS            derniere valeur timestamp}\par
{\f1      @@LANGUAGE        langue courante}\par
{\f1      @@NESTLEVEL       niveau d imbrication des procedures}\par
{\f1      @@MAX_CONNECTIONS nombre max de connexions}\par
{\f1      @@LOCK_TIMEOUT    delai d attente de verrou}\par
{\f1      @@DATEFIRST       premier jour de la semaine (1-7)}\par
{\f1      @@OPTIONS         options SET actives (bitmask)}\par
{\f1      @@TEXTSIZE        taille max des donnees TEXT retournees}\par
{\f1      @@CURSOR_ROWS     nombre de lignes du dernier curseur}\par
{\f1      @@PROCID          Object ID de la procedure courante}\par
\par
22.2 SCOPE_IDENTITY et IDENT_CURRENT\par
\par
{\f1      SCOPE_IDENTITY()}\par
{\f1        Derniere valeur IDENTITY dans la portee courante.}\par
{\f1        Plus fiable que @@IDENTITY (non affecte par les triggers).}\par
\par
{\f1      IDENT_CURRENT('nom_table')}\par
{\f1        Derniere valeur IDENTITY de la table specifiee,}\par
{\f1        toutes sessions confondues.}\par
\par
\par
