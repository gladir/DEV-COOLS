\page

{\footnote # IDH_SQL_17}
{\footnote $ SQL - CURSEURS}
{\footnote K SQL curseurs;DECLARE CURSOR;OPEN;FETCH;CLOSE;DEALLOCATE;STATIC DYNAMIC SCROLL FORWARD_ONLY}
\b\fs24 CURSEURS \b0\fs20\par
\par
Les curseurs permettent le traitement ligne par ligne des\par
resultats d une requete.\par
\par
{\f1     DECLARE nom_curseur CURSOR}\par
{\f1       [LOCAL | GLOBAL]}\par
{\f1       [FORWARD_ONLY | SCROLL]}\par
{\f1       [STATIC | KEYSET | DYNAMIC | FAST_FORWARD]}\par
{\f1       [READ_ONLY | SCROLL_LOCKS | OPTIMISTIC]}\par
{\f1     FOR requete_select}\par
{\f1     [FOR UPDATE [OF colonnes]]}\par
\par
{\f1     OPEN nom_curseur}\par
{\f1     FETCH NEXT FROM nom_curseur INTO @var1, @var2, ...}\par
{\f1     CLOSE nom_curseur}\par
{\f1     DEALLOCATE nom_curseur}\par
\par
{\f1     @@FETCH_STATUS : 0 = succes, -1 = fin, -2 = ligne absente}\par
\par
{\f1     Exemple :}\par
{\f1       DECLARE @nom NVARCHAR(100), @salaire DECIMAL(10,2)}\par
{\f1       DECLARE cur_emp CURSOR FAST_FORWARD FOR}\par
{\f1         SELECT nom, salaire FROM Employes WHERE dept_id = 1}\par
{\f1       OPEN cur_emp}\par
{\f1       FETCH NEXT FROM cur_emp INTO @nom, @salaire}\par
{\f1       WHILE @@FETCH_STATUS = 0}\par
{\f1       BEGIN}\par
{\f1         PRINT @nom + ' : ' + CAST(@salaire AS VARCHAR)}\par
{\f1         FETCH NEXT FROM cur_emp INTO @nom, @salaire}\par
{\f1       END}\par
{\f1       CLOSE cur_emp}\par
{\f1       DEALLOCATE cur_emp}\par
\par
{\f1     Note : les curseurs sont generalement deconseilles au}\par
{\f1     profit des operations ensemblistes plus performantes.}\par
\par
\par
