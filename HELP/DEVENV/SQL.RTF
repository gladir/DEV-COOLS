{\footnote # IDH_SQL_10}
{\footnote $ SQL - TRANSACTIONS}
{\footnote K SQL transactions;BEGIN TRANSACTION;COMMIT;ROLLBACK;SAVE TRANSACTION;niveaux isolation;READ COMMITTED;SERIALIZABLE;SNAPSHOT;XACT_ABORT}
\b\fs24 TRANSACTIONS \b0\fs20\par
\par
10.1 Transactions explicites\par
\par
{\f1      BEGIN TRANSACTION [nom_transaction]}\par
{\f1      BEGIN TRAN [nom_transaction]}\par
\par
{\f1      COMMIT [TRANSACTION] [nom_transaction]}\par
{\f1      COMMIT [TRAN] [nom_transaction]}\par
\par
{\f1      ROLLBACK [TRANSACTION] [nom_transaction | nom_savepoint]}\par
{\f1      ROLLBACK [TRAN] [nom_transaction | nom_savepoint]}\par
\par
{\f1      SAVE TRANSACTION nom_savepoint}\par
{\f1      SAVE TRAN nom_savepoint}\par
\par
{\f1      Exemple :}\par
{\f1        BEGIN TRAN}\par
{\f1          UPDATE Comptes SET solde -= 100 WHERE id = @source}\par
{\f1          UPDATE Comptes SET solde += 100 WHERE id = @dest}\par
{\f1          IF @@ERROR <> 0}\par
{\f1            ROLLBACK TRAN}\par
{\f1          ELSE}\par
{\f1            COMMIT TRAN}\par
\par
10.2 Niveaux d isolation\par
\par
{\f1      SET TRANSACTION ISOLATION LEVEL niveau}\par
\par
{\f1      Niveaux disponibles :}\par
{\f1        READ UNCOMMITTED  : lectures sales possibles (dirty reads)}\par
{\f1        READ COMMITTED    : defaut, pas de lectures sales}\par
{\f1        REPEATABLE READ   : pas de lectures non repetables}\par
{\f1        SERIALIZABLE      : isolation maximale}\par
{\f1        SNAPSHOT          : versionnement de lignes}\par
\par
{\f1      Hints de table equivalents :}\par
{\f1        WITH (NOLOCK)     -- READ UNCOMMITTED}\par
{\f1        WITH (HOLDLOCK)   -- SERIALIZABLE}\par
{\f1        WITH (READPAST)   -- saute les lignes verrouillees}\par
\par
10.3 @@TRANCOUNT\par
\par
{\f1      @@TRANCOUNT retourne le niveau d imbrication des}\par
{\f1      transactions. COMMIT decremente @@TRANCOUNT ; la}\par
{\f1      transaction n est reellement validee que quand}\par
{\f1      @@TRANCOUNT atteint 0.}\par
\par
\par
