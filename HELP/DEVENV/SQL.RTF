{\footnote # IDH_SQL_21}
{\footnote $ SQL - FORMATS DE SORTIE (FOR XML / FOR JSON)}
{\footnote K SQL XML JSON;FOR XML;PATH RAW AUTO EXPLICIT;FOR JSON;PATH AUTO;OPENJSON;OPENXML}
\b\fs24 FORMATS DE SORTIE (FOR XML / FOR JSON) \b0\fs20\par
\par
21.1 FOR XML\par
\par
{\f1      SELECT colonnes FROM table FOR XML PATH('element')}\par
{\f1      SELECT colonnes FROM table FOR XML RAW('row')}\par
{\f1      SELECT colonnes FROM table FOR XML AUTO}\par
{\f1      SELECT colonnes FROM table FOR XML EXPLICIT}\par
\par
{\f1      Options :}\par
{\f1        , ROOT('racine')         element racine}\par
{\f1        , ELEMENTS               colonnes comme elements}\par
{\f1        , TYPE                   retourne un type XML}\par
\par
{\f1      Exemple :}\par
{\f1        SELECT id AS '@id', nom, prenom}\par
{\f1        FROM Employes}\par
{\f1        FOR XML PATH('employe'), ROOT('employes'), TYPE}\par
\par
{\f1        Resultat :}\par
{\f1        <employes>}\par
{\f1          <employe id="1">}\par
{\f1            <nom>Dupont</nom>}\par
{\f1            <prenom>Jean</prenom>}\par
{\f1          </employe>}\par
{\f1        </employes>}\par
\par
21.2 FOR JSON\par
\par
{\f1      SELECT colonnes FROM table FOR JSON PATH}\par
{\f1      SELECT colonnes FROM table FOR JSON AUTO}\par
\par
{\f1      Options :}\par
{\f1        , ROOT('racine')         element racine}\par
{\f1        , INCLUDE_NULL_VALUES    inclure les NULLs}\par
{\f1        , WITHOUT_ARRAY_WRAPPER  pas de crochets [ ]}\par
\par
{\f1      Exemple :}\par
{\f1        SELECT id, nom, prenom}\par
{\f1        FROM Employes}\par
{\f1        FOR JSON PATH, ROOT('employes')}\par
\par
{\f1        Resultat :}\par
{\f1        \{"employes":[}\par
{\f1          \{"id":1,"nom":"Dupont","prenom":"Jean"\},}\par
{\f1          \{"id":2,"nom":"Martin","prenom":"Marie"\}}\par
{\f1        ]\}}\par
\par
\par
