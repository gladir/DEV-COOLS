{\footnote # IDH_SQL_14}
{\footnote $ SQL - SOUS-REQUETES ET EXPRESSIONS DE TABLE}
{\footnote K SQL sous-requetes CTE;subquery;EXISTS;IN ANY ALL;WITH;CTE;recursive CTE;table derivee}
\b\fs24 SOUS-REQUETES ET EXPRESSIONS DE TABLE \b0\fs20\par
\par
14.1 Sous-requetes scalaires\par
\par
{\f1      Une sous-requete scalaire retourne une seule valeur :}\par
\par
{\f1      SELECT nom,}\par
{\f1             (SELECT COUNT(*) FROM Commandes c}\par
{\f1              WHERE c.client_id = cl.id) AS nb_commandes}\par
{\f1      FROM Clients cl}\par
\par
14.2 Sous-requetes de table\par
\par
{\f1      Sous-requete dans la clause FROM :}\par
\par
{\f1      SELECT * FROM (}\par
{\f1        SELECT nom, salaire,}\par
{\f1               ROW_NUMBER() OVER (ORDER BY salaire DESC) AS rn}\par
{\f1        FROM Employes}\par
{\f1      ) sub}\par
{\f1      WHERE sub.rn <= 10}\par
\par
14.3 Sous-requetes correlees\par
\par
{\f1      Sous-requete qui reference la requete externe :}\par
\par
{\f1      SELECT * FROM Employes e}\par
{\f1      WHERE salaire > (}\par
{\f1        SELECT AVG(salaire) FROM Employes}\par
{\f1        WHERE dept_id = e.dept_id}\par
{\f1      )}\par
\par
14.4 CTE (Common Table Expressions)\par
\par
{\f1      WITH nom_cte [(colonnes)] AS (}\par
{\f1        requete_definition}\par
{\f1      )}\par
{\f1      SELECT ... FROM nom_cte}\par
\par
{\f1      -- CTE multiple}\par
{\f1      WITH cte1 AS (...),}\par
{\f1           cte2 AS (...)}\par
{\f1      SELECT ... FROM cte1 JOIN cte2}\par
\par
{\f1      -- CTE recursive}\par
{\f1      WITH cte_recursive AS (}\par
{\f1        -- membre ancre}\par
{\f1        SELECT id, nom, 0 AS niveau FROM Employes}\par
{\f1        WHERE manager_id IS NULL}\par
{\f1        UNION ALL}\par
{\f1        -- membre recursif}\par
{\f1        SELECT e.id, e.nom, r.niveau + 1}\par
{\f1        FROM Employes e}\par
{\f1        INNER JOIN cte_recursive r ON e.manager_id = r.id}\par
{\f1      )}\par
{\f1      SELECT * FROM cte_recursive}\par
{\f1      OPTION (MAXRECURSION 100)}\par
\par
14.5 PIVOT et UNPIVOT\par
\par
{\f1      -- PIVOT : lignes vers colonnes}\par
{\f1      SELECT *}\par
{\f1      FROM (}\par
{\f1        SELECT departement, trimestre, montant}\par
{\f1        FROM Ventes}\par
{\f1      ) src}\par
{\f1      PIVOT (}\par
{\f1        SUM(montant) FOR trimestre IN ([Q1], [Q2], [Q3], [Q4])}\par
{\f1      ) pvt}\par
\par
{\f1      -- UNPIVOT : colonnes vers lignes}\par
{\f1      SELECT departement, trimestre, montant}\par
{\f1      FROM Ventes_Pivot}\par
{\f1      UNPIVOT (}\par
{\f1        montant FOR trimestre IN ([Q1], [Q2], [Q3], [Q4])}\par
{\f1      ) unpvt}\par
\par
14.6 APPLY\par
\par
{\f1      CROSS APPLY : jointure laterale (lignes de gauche uniquement}\par
{\f1      si la fonction retourne des lignes)}\par
\par
{\f1      OUTER APPLY : jointure laterale (toutes les lignes de gauche,}\par
{\f1      NULLs si la fonction ne retourne rien)}\par
\par
{\f1      Exemples :}\par
{\f1        SELECT e.nom, a.adresse}\par
{\f1        FROM Employes e}\par
{\f1        CROSS APPLY fn_GetAdresses(e.id) a}\par
\par
{\f1        SELECT e.nom, top3.montant}\par
{\f1        FROM Employes e}\par
{\f1        OUTER APPLY (}\par
{\f1          SELECT TOP 3 montant FROM Ventes v}\par
{\f1          WHERE v.employe_id = e.id}\par
{\f1          ORDER BY montant DESC}\par
{\f1        ) top3}\par
\par
\par
{\uldb << Precedent}{\v IDH_SQL_13}     {\uldb Suivant >>}{\v IDH_SQL_15}     {\uldb Table des matieres}{\v IDH_SQL_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_SQL_15}
{\footnote $ SQL - JOINTURES}
{\footnote K SQL jointures;INNER JOIN;LEFT OUTER JOIN;RIGHT OUTER JOIN;FULL OUTER JOIN;CROSS JOIN;CROSS APPLY;OUTER APPLY;self-join}
\b\fs24 JOINTURES \b0\fs20\par
\par
15.1 INNER JOIN\par
\par
{\f1      Retourne les lignes qui ont une correspondance dans les}\par
{\f1      deux tables :}\par
\par
{\f1      SELECT e.nom, d.nom_departement}\par
{\f1      FROM Employes e}\par
{\f1      INNER JOIN Departements d ON e.dept_id = d.id}\par
\par
15.2 LEFT [OUTER] JOIN\par
\par
{\f1      Retourne toutes les lignes de la table de gauche et les}\par
{\f1      correspondances de la table de droite (NULL si pas de}\par
{\f1      correspondance) :}\par
\par
{\f1      SELECT e.nom, d.nom_departement}\par
{\f1      FROM Employes e}\par
{\f1      LEFT JOIN Departements d ON e.dept_id = d.id}\par
\par
15.3 RIGHT [OUTER] JOIN\par
\par
{\f1      Retourne toutes les lignes de la table de droite :}\par
\par
{\f1      SELECT e.nom, d.nom_departement}\par
{\f1      FROM Employes e}\par
{\f1      RIGHT JOIN Departements d ON e.dept_id = d.id}\par
\par
15.4 FULL [OUTER] JOIN\par
\par
{\f1      Retourne toutes les lignes des deux tables :}\par
\par
{\f1      SELECT e.nom, d.nom_departement}\par
{\f1      FROM Employes e}\par
{\f1      FULL OUTER JOIN Departements d ON e.dept_id = d.id}\par
\par
15.5 CROSS JOIN\par
\par
{\f1      Produit cartesien (chaque ligne combinee avec chaque}\par
{\f1      ligne de l autre table) :}\par
\par
{\f1      SELECT a.lettre, b.chiffre}\par
{\f1      FROM Lettres a CROSS JOIN Chiffres b}\par
\par
15.6 Self join\par
\par
{\f1      Jointure d une table avec elle-meme :}\par
\par
{\f1      SELECT e.nom AS employe, m.nom AS manager}\par
{\f1      FROM Employes e}\par
{\f1      LEFT JOIN Employes m ON e.manager_id = m.id}\par
\par
15.7 Jointures multiples\par
\par
{\f1      SELECT e.nom, d.nom_dept, p.nom_poste}\par
{\f1      FROM Employes e}\par
{\f1      INNER JOIN Departements d ON e.dept_id = d.id}\par
{\f1      INNER JOIN Postes p ON e.poste_id = p.id}\par
{\f1      WHERE d.actif = 1}\par
\par
\par
{\uldb << Precedent}{\v IDH_SQL_14}     {\uldb Suivant >>}{\v IDH_SQL_16}     {\uldb Table des matieres}{\v IDH_SQL_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_SQL_16}
{\footnote $ SQL - OPERATEURS ENSEMBLISTES}
{\footnote K SQL ensemblistes;UNION;UNION ALL;INTERSECT;EXCEPT}
\b\fs24 OPERATEURS ENSEMBLISTES \b0\fs20\par
\par
16.1 UNION\par
\par
{\f1      Combine les resultats de deux requetes en eliminant}\par
{\f1      les doublons :}\par
\par
{\f1      SELECT nom FROM Clients}\par
{\f1      UNION}\par
{\f1      SELECT nom FROM Fournisseurs}\par
\par
16.2 UNION ALL\par
\par
{\f1      Combine les resultats sans eliminer les doublons :}\par
\par
{\f1      SELECT nom FROM Clients}\par
{\f1      UNION ALL}\par
{\f1      SELECT nom FROM Fournisseurs}\par
\par
16.3 INTERSECT\par
\par
{\f1      Retourne les lignes communes aux deux requetes :}\par
\par
{\f1      SELECT nom FROM Clients}\par
{\f1      INTERSECT}\par
{\f1      SELECT nom FROM Fournisseurs}\par
\par
16.4 EXCEPT\par
\par
{\f1      Retourne les lignes de la premiere requete qui ne}\par
{\f1      sont pas dans la seconde :}\par
\par
{\f1      SELECT nom FROM Clients}\par
{\f1      EXCEPT}\par
{\f1      SELECT nom FROM Fournisseurs}\par
\par
{\f1      Regles communes :}\par
{\f1      - Les requetes doivent avoir le meme nombre de colonnes}\par
{\f1      - Les types doivent etre compatibles}\par
{\f1      - L ORDER BY s applique au resultat final}\par
\par
\par
