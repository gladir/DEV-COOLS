{\footnote # IDH_SQL_05}
{\footnote $ SQL - OPERATEURS}
{\footnote K SQL operateurs;arithmetiques;comparaison;LIKE BETWEEN IN IS NULL;logiques AND OR NOT;concatenation +;bit-a-bit}
\b\fs24 OPERATEURS \b0\fs20\par
\par
5.1 Operateurs arithmetiques\par
\par
{\f1     +   addition}\par
{\f1     -   soustraction ou negation unaire}\par
{\f1     *   multiplication}\par
{\f1     /   division (entiere si les deux operandes sont entiers)}\par
{\f1     %   modulo (reste de la division)}\par
\par
{\f1     Exemples :}\par
{\f1       10 + 3       -- 13}\par
{\f1       10 / 3       -- 3 (division entiere)}\par
{\f1       10.0 / 3     -- 3.333... (division decimale)}\par
{\f1       10 % 3       -- 1}\par
\par
5.2 Operateurs de comparaison\par
\par
{\f1     =    egalite}\par
{\f1     <>   difference (SQL standard)}\par
{\f1     !=   difference (non standard, accepte par T-SQL)}\par
{\f1     <    inferieur strict}\par
{\f1     >    superieur strict}\par
{\f1     <=   inferieur ou egal}\par
{\f1     >=   superieur ou egal}\par
{\f1     !<   non inferieur (equivalent a >=, specifique T-SQL)}\par
{\f1     !>   non superieur (equivalent a <=, specifique T-SQL)}\par
\par
5.3 Operateurs logiques\par
\par
{\f1     AND       ET logique}\par
{\f1     OR        OU logique}\par
{\f1     NOT       negation logique}\par
\par
{\f1     Logique tri-valuee SQL (TRUE, FALSE, UNKNOWN) :}\par
{\f1       TRUE AND UNKNOWN  = UNKNOWN}\par
{\f1       FALSE AND UNKNOWN = FALSE}\par
{\f1       TRUE OR UNKNOWN   = TRUE}\par
{\f1       FALSE OR UNKNOWN  = UNKNOWN}\par
{\f1       NOT UNKNOWN       = UNKNOWN}\par
\par
{\f1     Les valeurs NULL produisent UNKNOWN dans les comparaisons :}\par
{\f1       NULL = NULL       -- UNKNOWN (pas TRUE)}\par
{\f1       NULL <> 1         -- UNKNOWN (pas TRUE)}\par
{\f1       NULL IS NULL      -- TRUE}\par
\par
5.4 Operateurs de chaine\par
\par
{\f1     +   concatenation de chaines}\par
{\f1       'Hello' + ' ' + 'World'  -- 'Hello World'}\par
{\f1       NULL + 'texte'           -- NULL (propagation de NULL)}\par
\par
{\f1     CONCAT(str1, str2, ...)}\par
{\f1       Concatenation avec gestion des NULLs :}\par
{\f1       CONCAT(NULL, 'texte')    -- 'texte'}\par
\par
5.5 Operateurs d affectation\par
\par
{\f1     =    affectation simple}\par
{\f1     +=   addition et affectation}\par
{\f1     -=   soustraction et affectation}\par
{\f1     *=   multiplication et affectation}\par
{\f1     /=   division et affectation}\par
{\f1     %=   modulo et affectation}\par
{\f1     &=   ET bit a bit et affectation}\par
{\f1     |=   OU bit a bit et affectation}\par
{\f1     ^=   OU exclusif bit a bit et affectation}\par
\par
{\f1     Exemples :}\par
{\f1       SET @x = 10}\par
{\f1       SET @x += 5    -- @x vaut 15}\par
\par
5.6 Operateurs bit a bit\par
\par
{\f1     &    ET bit a bit}\par
{\f1     |    OU bit a bit}\par
{\f1     ^    OU exclusif bit a bit}\par
{\f1     ~    complement bit a bit (unaire)}\par
\par
5.7 Predicats speciaux\par
\par
{\f1     expr IS NULL                -- teste si l expression est NULL}\par
{\f1     expr IS NOT NULL            -- teste si l expression n est pas NULL}\par
{\f1     expr BETWEEN a AND b        -- equivalent a expr >= a AND expr <= b}\par
{\f1     expr NOT BETWEEN a AND b}\par
{\f1     expr IN (val1, val2, ...)   -- teste l appartenance a une liste}\par
{\f1     expr NOT IN (val1, ...)}\par
{\f1     expr IN (SELECT ...)        -- teste l appartenance a un sous-ensemble}\par
{\f1     EXISTS (SELECT ...)         -- teste si la sous-requete retourne}\par
{\f1                                    au moins une ligne}\par
{\f1     NOT EXISTS (SELECT ...)}\par
{\f1     expr LIKE motif [ESCAPE car]}\par
{\f1       Caracteres jokers du LIKE :}\par
{\f1         %    : zero ou plusieurs caracteres}\par
{\f1         _    : exactement un caractere}\par
{\f1         [abc]  : un caractere parmi a, b ou c}\par
{\f1         [a-z]  : un caractere dans la plage a-z}\par
{\f1         [^abc] : un caractere qui n est ni a, ni b, ni c}\par
\par
{\f1       Exemples :}\par
{\f1         nom LIKE 'Mart%'         -- commence par 'Mart'}\par
{\f1         nom LIKE '_a%'           -- deuxieme caractere 'a'}\par
{\f1         nom LIKE '[A-C]%'        -- commence par A, B ou C}\par
{\f1         nom LIKE '%[_]%' ESCAPE '\\' -- contient un underscore}\par
\par
{\f1     expr ALL (SELECT ...)       -- TRUE si la condition est vraie}\par
{\f1                                    pour toutes les valeurs}\par
{\f1     expr ANY (SELECT ...)       -- TRUE si la condition est vraie}\par
{\f1     expr SOME (SELECT ...)         pour au moins une valeur}\par
\par
5.8 Precedence des operateurs (du plus fort au plus faible)\par
\par
{\f1      1. ~ (complement bit a bit)}\par
{\f1      2. * / %}\par
{\f1      3. + - (arithmetiques)}\par
{\f1      4. = <> < > <= >= != !< !>}\par
{\f1      5. ^ (XOR bit a bit)}\par
{\f1      6. & (ET bit a bit)}\par
{\f1      7. | (OU bit a bit)}\par
{\f1      8. NOT}\par
{\f1      9. AND}\par
{\f1     10. ALL ANY BETWEEN IN LIKE OR SOME}\par
{\f1     11. = (affectation)}\par
\par
\par
