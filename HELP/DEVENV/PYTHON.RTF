{\footnote # IDH_PYTHON_12}
{\footnote $ Python - Chaines de caracteres}
{\footnote K Python chaines;str methodes;split join replace;f-string formatage;str.format;encode decode;regex re;expressions regulieres}
\b\fs24 Chaines de caracteres \b0\fs20\par
\par
Operations courantes :\par
\par
{\f1   s = "Bonjour le Monde"}\par
{\f1   len(s)                  # 16}\par
{\f1   s.upper(); s.lower(); s.title()}\par
{\f1   s.strip(); s.lstrip(); s.rstrip()}\par
{\f1   s.split(); s.split(",")}\par
{\f1   ",".join(["a", "b", "c"])}\par
{\f1   s.replace("le", "au")}\par
{\f1   s.startswith("Bon"); s.endswith("e")}\par
{\f1   s.find("le"); s.index("le")}\par
{\f1   s.count("o")}\par
{\f1   s[::-1]                 # inversion}\par
\par
Formatage :\par
\par
{\f1   # f-strings (3.6+, recommande)}\par
{\f1   print(f"\{nom\} a \{age\} ans")}\par
{\f1   print(f"\{x:.3f\}")}\par
{\f1   print(f"\{x:>10\}")            # alignement}\par
{\f1   print(f"\{x:_\}")              # separateur de milliers}\par
{\f1   print(f"\{var=\}")             # debug : var=valeur (3.8+)}\par
\par
{\f1   # str.format()}\par
{\f1   "\{0\} \{1\}".format(a, b)}\par
{\f1   "\{nom\}".format(nom="Alice")}\par
\par
{\f1   # %-formatting (style C, legacy)}\par
{\f1   "%d %s" % (10, "abc")}\par
\par
Encodage/decodage :\par
\par
{\f1   s.encode("utf-8")          # str -> bytes}\par
{\f1   b.decode("utf-8")          # bytes -> str}\par
\par
Expressions regulieres (re) :\par
\par
{\f1   import re}\par
{\f1   m = re.match(r"(\\d+)-(\\d+)", "10-20")}\par
{\f1   if m: print(m.group(1), m.group(2))}\par
{\f1   re.findall(r"\\d+", "a 10 b 20 c 30")    # ['10', '20', '30']}\par
{\f1   re.sub(r"\\s+", " ", texte)}\par
\par
\par
