{\footnote # IDH_PYTHON_08}
{\footnote $ Python - Classes et orientation objet}
{\footnote K Python classes objets;__init__;dunders;self;heritage;super;MRO;C3 linearization;property;dataclass;PEP 557;abc;abstractmethod}
\b\fs24 Classes et orientation objet \b0\fs20\par
\par
{\f1   class Personne:}\par
{\f1       """Une personne avec nom et age."""}\par
\par
{\f1       especes = "Homo sapiens"            # attribut de classe}\par
\par
{\f1       def __init__(self, nom: str, age: int):}\par
{\f1           self.nom = nom}\par
{\f1           self.age = age}\par
\par
{\f1       def saluer(self) -> str:}\par
{\f1           return f"Bonjour, je suis \{self.nom\}"}\par
\par
{\f1       def __repr__(self) -> str:}\par
{\f1           return f"Personne(\{self.nom!r\}, \{self.age\})"}\par
\par
{\f1       def __eq__(self, other) -> bool:}\par
{\f1           return isinstance(other, Personne) and \\}\par
{\f1                  (self.nom, self.age) == (other.nom, other.age)}\par
\par
Methodes speciales (dunders) :\par
{\f1   __init__   __del__   __repr__  __str__  __format__}\par
{\f1   __eq__     __ne__    __lt__    __le__   __gt__    __ge__}\par
{\f1   __hash__   __bool__  __len__   __getitem__   __setitem__   __delitem__}\par
{\f1   __iter__   __next__  __contains__}\par
{\f1   __add__    __sub__   __mul__   __truediv__   __floordiv__  __mod__  __pow__}\par
{\f1   __radd__   __iadd__  ...}\par
{\f1   __call__   __enter__ __exit__}\par
{\f1   __getattr__ __setattr__ __delattr__ __getattribute__}\par
\par
Heritage :\par
\par
{\f1   class Etudiant(Personne):}\par
{\f1       def __init__(self, nom, age, ecole):}\par
{\f1           super().__init__(nom, age)}\par
{\f1           self.ecole = ecole}\par
\par
Heritage multiple et MRO (Method Resolution Order, C3 linearization) :\par
\par
{\f1   class A: pass}\par
{\f1   class B(A): pass}\par
{\f1   class C(A): pass}\par
{\f1   class D(B, C): pass        # MRO : D -> B -> C -> A -> object}\par
\par
Proprietes :\par
\par
{\f1   class Compte:}\par
{\f1       def __init__(self):}\par
{\f1           self._solde = 0}\par
{\f1       @property}\par
{\f1       def solde(self):}\par
{\f1           return self._solde}\par
{\f1       @solde.setter}\par
{\f1       def solde(self, v):}\par
{\f1           if v < 0: raise ValueError}\par
{\f1           self._solde = v}\par
\par
@dataclass (PEP 557, 3.7+) :\par
\par
{\f1   from dataclasses import dataclass, field}\par
\par
{\f1   @dataclass(frozen=True, slots=True)}\par
{\f1   class Point:}\par
{\f1       x: float}\par
{\f1       y: float}\par
{\f1       tags: list[str] = field(default_factory=list)}\par
\par
Classes abstraites (abc) :\par
\par
{\f1   from abc import ABC, abstractmethod}\par
\par
{\f1   class Forme(ABC):}\par
{\f1       @abstractmethod}\par
{\f1       def aire(self) -> float: ...}\par
\par
\par
\par
