\b\fs24 Collections et iterateurs \b0\fs20\par
\par
10.1 Listes\par
\par
{\f1   liste = [1, 2, 3]}\par
{\f1   liste.append(4)}\par
{\f1   liste.extend([5, 6])}\par
{\f1   liste.insert(0, 0)}\par
{\f1   liste.pop()                     # dernier}\par
{\f1   liste.pop(0)                    # premier}\par
{\f1   liste.remove(3)}\par
{\f1   liste.sort(); liste.reverse()}\par
{\f1   copie = liste[:]}\par
{\f1   inverse = liste[::-1]}\par
{\f1   sub = liste[1:4]}\par
\par
10.2 Tuples\par
\par
{\f1   t = (1, 2, 3)}\par
{\f1   t = 1, 2, 3                     # parentheses optionnelles}\par
{\f1   x, y, z = t}\par
{\f1   named = (1,)                    # tuple a un element}\par
\par
10.3 Dictionnaires\par
\par
{\f1   d = \{"a": 1, "b": 2\}}\par
{\f1   d["c"] = 3}\par
{\f1   d.get("x", 0)                   # avec valeur par defaut}\par
{\f1   d.setdefault("y", []).append(1)}\par
{\f1   for k, v in d.items(): ...}\par
{\f1   d2 = d | \{"d": 4\}               # merge (3.9+)}\par
\par
10.4 Sets\par
\par
{\f1   s = \{1, 2, 3\}}\par
{\f1   s.add(4)}\par
{\f1   s.discard(2)}\par
{\f1   union = s | \{5, 6\}}\par
{\f1   inter = s & \{3, 4\}}\par
{\f1   diff = s - \{1, 2\}}\par
\par
10.5 Comprehensions\par
\par
{\f1   carres = [x*x for x in range(10)]}\par
{\f1   pairs = \{x for x in range(10) if x % 2 == 0\}}\par
{\f1   d = \{x: x*x for x in range(10)\}}\par
{\f1   generateur = (x*x for x in range(10))      # lazy}\par
\par
10.6 collections (bibliotheque standard)\par
\par
{\f1   from collections import (}\par
{\f1       defaultdict, Counter, OrderedDict, deque, namedtuple, ChainMap}\par
{\f1   )}\par
{\f1   c = Counter("abracadabra")           # \{'a': 5, 'b': 2, 'r': 2, ...\}}\par
