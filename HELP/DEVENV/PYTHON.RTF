{\footnote # IDH_PYTHON_04}
{\footnote $ Python - Types de donnees}
{\footnote K Python types donnees;int float complex bool;str bytes bytearray;list tuple range;dict set frozenset;None Ellipsis;type hints;PEP 484 526 585 695;variables;unpacking}
\b\fs24 Types de donnees \b0\fs20\par
\par
4.1 Types numeriques\par
\par
{\f1   int      entier de taille arbitraire (precision illimitee)}\par
{\f1   float    flottant double precision IEEE 754}\par
{\f1   complex  nombre complexe (z.real, z.imag)}\par
{\f1   bool     sous-classe d'int (True == 1, False == 0)}\par
\par
4.2 Sequences\par
\par
{\f1   str       chaine immuable Unicode}\par
{\f1   bytes     sequence immuable d'octets}\par
{\f1   bytearray sequence mutable d'octets}\par
{\f1   list      [1, 2, 3] - mutable, ordonnee}\par
{\f1   tuple     (1, 2, 3) - immuable, ordonnee}\par
{\f1   range     range(0, 10, 2) - immuable, generatrice}\par
\par
4.3 Collections\par
\par
{\f1   set            \{1, 2, 3\} - ensemble mutable, non ordonne}\par
{\f1   frozenset      ensemble immuable}\par
{\f1   dict           \{"a": 1, "b": 2\} - dictionnaire (ordre d'insertion 3.7+)}\par
\par
4.4 Autres\par
\par
{\f1   None           singleton (type NoneType)}\par
{\f1   Ellipsis       ... (utilise pour slices, type hints)}\par
{\f1   NotImplemented retourne par __eq__ etc. quand non applicable}\par
\par
4.5 Type hints (PEP 484, 526, 585, 604, 695)\par
\par
{\f1   age: int = 30}\par
{\f1   noms: list[str] = []}\par
{\f1   table: dict[str, int] = \{\}}\par
{\f1   resultat: int | None = None              # Python 3.10+}\par
{\f1   def f(x: int, y: float = 1.0) -> str: ...}\par
\par
{\f1   # PEP 695 (Python 3.12+) : syntaxe native pour generics}\par
{\f1   type Vector = list[float]}\par
{\f1   def somme[T: (int, float)](xs: list[T]) -> T: ...}\par
\par
4.6 Variables et affectation\par
\par
{\f1   x = 10}\par
{\f1   a, b = 1, 2                              # tuple unpacking}\par
{\f1   a, b = b, a                              # echange}\par
{\f1   first, *rest = [1, 2, 3, 4]              # rest = [2, 3, 4]}\par
{\f1   d = \{"x": 1, "y": 2\}}\par
{\f1   x, y = d.values()}\par
\par
\par
\par
