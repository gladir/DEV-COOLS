{\footnote # IDH_TPSTRS_06}
{\footnote $ Unite Strings (PChar) - RECHERCHE}
{\footnote K Turbo Pascal;Unite Strings (PChar);RECHERCHE}
\b\fs24 RECHERCHE \b0\fs20\par
\par
{\f1   function StrScan(Str : PChar; Chr : Char) : PChar;}\par
{\f1   Recherche la PREMI??RE occurrence d'un caract??re dans une cha??ne.}\par
\par
{\f1   Param??tres :}\par
{\f1     Str  Cha??ne source (ASCIIZ)}\par
{\f1     Chr  Caract??re ?? rechercher}\par
{\f1   Retour :}\par
{\f1     Pointeur vers la premi??re occurrence de Chr dans Str,}\par
{\f1     ou nil si Chr n'est pas trouv??.}\par
\par
{\f1   NOTE : le terminateur nul (#0) est consid??r?? comme faisant}\par
{\f1   partie de la cha??ne. StrScan(Str, #0) retourne donc toujours}\par
{\f1   un pointeur vers le terminateur (??quivalent ?? StrEnd).}\par
\par
{\f1   ??quivalent C : strchr()}\par
\par
{\f1   Exemple :}\par
{\f1     var P : PChar;}\par
{\f1     begin}\par
{\f1       P := StrScan('Hello, World!', ',');}\par
{\f1       if P <> nil then}\par
{\f1         WriteLn(StrPas(P));  \{ ??? ', World!' \}}\par
{\f1     end;}\par
\par
{\f1   function StrRScan(Str : PChar; Chr : Char) : PChar;}\par
{\f1   Recherche la DERNI??RE occurrence d'un caract??re dans une cha??ne.}\par
\par
{\f1   Param??tres :}\par
{\f1     Str  Cha??ne source (ASCIIZ)}\par
{\f1     Chr  Caract??re ?? rechercher}\par
{\f1   Retour :}\par
{\f1     Pointeur vers la derni??re occurrence de Chr dans Str,}\par
{\f1     ou nil si Chr n'est pas trouv??.}\par
\par
{\f1   Le terminateur nul est consid??r?? comme faisant partie de la}\par
{\f1   cha??ne (m??me comportement que StrScan).}\par
\par
{\f1   ??quivalent C : strrchr()}\par
\par
{\f1   Exemple :}\par
{\f1     var P : PChar;}\par
{\f1     begin}\par
{\f1       P := StrRScan('C:\\TP\\BIN\\TURBO.EXE', '\\');}\par
{\f1       if P <> nil then}\par
{\f1         WriteLn(StrPas(P));  \{ ??? '\\TURBO.EXE' \}}\par
{\f1     end;}\par
\par
{\f1   Impl??mentation : parcourt la cha??ne vers l'avant pour trouver}\par
{\f1   le #0, puis recule avec STD et REPNE SCASB.}\par
\par
{\f1   function StrPos(Str1, Str2 : PChar) : PChar;}\par
{\f1   Recherche la premi??re occurrence d'une sous-cha??ne dans une}\par
{\f1   cha??ne.}\par
\par
{\f1   Param??tres :}\par
{\f1     Str1  Cha??ne dans laquelle chercher (ASCIIZ)}\par
{\f1     Str2  Sous-cha??ne ?? rechercher (ASCIIZ)}\par
{\f1   Retour :}\par
{\f1     Pointeur vers la premi??re occurrence de Str2 dans Str1,}\par
{\f1     ou nil si Str2 n'est pas trouv??.}\par
\par
{\f1   Si Str2 est une cha??ne vide, retourne nil.}\par
\par
{\f1   ??quivalent C : strstr()}\par
\par
{\f1   Exemple :}\par
{\f1     var P : PChar;}\par
{\f1     begin}\par
{\f1       P := StrPos('Turbo Pascal 7.0', 'Pascal');}\par
{\f1       if P <> nil then}\par
{\f1         WriteLn(StrPas(P));  \{ ??? 'Pascal 7.0' \}}\par
{\f1     end;}\par
\par
\par
