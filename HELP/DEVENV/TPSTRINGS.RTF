{\footnote # IDH_TPSTRS_08}
{\footnote $ Unite Strings (PChar) - CONVERSION String ??? PChar}
{\footnote K Turbo Pascal;Unite Strings (PChar);CONVERSION String ??? PChar}
\b\fs24 CONVERSION String ??? PChar \b0\fs20\par
\par
{\f1   function StrPas(Str : PChar) : String;}\par
{\f1   Convertit une cha??ne PChar (ASCIIZ) en cha??ne Pascal (String).}\par
\par
{\f1   Param??tres :}\par
{\f1     Str  Cha??ne source (ASCIIZ)}\par
{\f1   Retour :}\par
{\f1     Cha??ne Pascal correspondante}\par
\par
{\f1   Si Str contient plus de 255 caract??res, seuls les 255 premiers}\par
{\f1   sont copi??s (limite du type String).}\par
\par
{\f1   C'est la fonction de conversion PChar ??? String.}\par
\par
{\f1   Exemple :}\par
{\f1     var}\par
{\f1       P : PChar;}\par
{\f1       S : String;}\par
{\f1     begin}\par
{\f1       P := 'Bonjour';}\par
{\f1       S := StrPas(P);}\par
{\f1       WriteLn(S);        \{ ??? Bonjour \}}\par
{\f1       WriteLn(Length(S)); \{ ??? 7 \}}\par
{\f1     end;}\par
\par
{\f1   function StrPCopy(Dest : PChar; Source : String) : PChar;}\par
{\f1   (Document??e en section 3 ??? Copie et d??placement)}\par
\par
{\f1   C'est la fonction de conversion String ??? PChar.}\par
\par
{\f1   R??sum?? : copie une cha??ne Pascal dans un tampon PChar en}\par
