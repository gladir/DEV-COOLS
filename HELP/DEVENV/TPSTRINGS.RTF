{\footnote # IDH_TPSTRS_05}
{\footnote $ Unite Strings (PChar) - COMPARAISON}
{\footnote K Turbo Pascal;Unite Strings (PChar);COMPARAISON}
\b\fs24 COMPARAISON \b0\fs20\par
\par
{\f1   function StrComp(Str1, Str2 : PChar) : Integer;}\par
{\f1   Compare Str1 et Str2 (sensible ?? la casse).}\par
\par
{\f1   Param??tres :}\par
{\f1     Str1, Str2  Cha??nes ?? comparer (ASCIIZ)}\par
{\f1   Retour :}\par
{\f1     < 0  si Str1 < Str2  (ordre lexicographique ASCII)}\par
{\f1       0  si Str1 = Str2}\par
{\f1     > 0  si Str1 > Str2}\par
\par
{\f1   La comparaison est bas??e sur les valeurs ASCII des caract??res.}\par
{\f1   Les majuscules (65..90) sont INF??RIEURES aux minuscules (97..122).}\par
\par
{\f1   ??quivalent C : strcmp()}\par
\par
{\f1   Exemple :}\par
{\f1     if StrComp(P1, P2) = 0 then}\par
{\f1       WriteLn('Cha??nes identiques');}\par
\par
{\f1   function StrIComp(Str1, Str2 : PChar) : Integer;}\par
{\f1   Compare Str1 et Str2 sans tenir compte de la casse.}\par
\par
{\f1   Param??tres :}\par
{\f1     Str1, Str2  Cha??nes ?? comparer (ASCIIZ)}\par
{\f1   Retour :}\par
{\f1     M??me convention que StrComp}\par
\par
{\f1   Les lettres 'a'..'z' sont converties en 'A'..'Z' avant}\par
{\f1   comparaison. Seuls les caract??res ASCII standard sont}\par
{\f1   convertis (pas les caract??res accentu??s).}\par
\par
{\f1   ??quivalent C : stricmp() / strcasecmp()}\par
\par
{\f1   Exemple :}\par
{\f1     if StrIComp('Hello', 'HELLO') = 0 then}\par
{\f1       WriteLn('Identiques');  \{ ??? Identiques \}}\par
\par
{\f1   function StrLComp(Str1, Str2 : PChar; MaxLen : Word) : Integer;}\par
{\f1   Compare au maximum MaxLen caract??res de Str1 et Str2}\par
{\f1   (sensible ?? la casse).}\par
\par
{\f1   Param??tres :}\par
{\f1     Str1, Str2  Cha??nes ?? comparer}\par
{\f1     MaxLen      Nombre maximal de caract??res ?? comparer}\par
{\f1   Retour :}\par
{\f1     M??me convention que StrComp}\par
\par
{\f1   Utile pour comparer des pr??fixes de cha??nes.}\par
\par
{\f1   ??quivalent C : strncmp()}\par
\par
{\f1   Exemple :}\par
{\f1     if StrLComp('Turbo Pascal', 'Turbo C', 5) = 0 then}\par
{\f1       WriteLn('M??me pr??fixe');  \{ ??? M??me pr??fixe (les 5 premiers) \}}\par
\par
{\f1   function StrLIComp(Str1, Str2 : PChar; MaxLen : Word) : Integer;}\par
{\f1   Compare au maximum MaxLen caract??res de Str1 et Str2, sans}\par
{\f1   tenir compte de la casse.}\par
\par
{\f1   Param??tres :}\par
{\f1     Str1, Str2  Cha??nes ?? comparer}\par
{\f1     MaxLen      Nombre maximal de caract??res ?? comparer}\par
{\f1   Retour :}\par
{\f1     M??me convention que StrComp}\par
\par
{\f1   Combinaison de StrLComp et StrIComp.}\par
\par
{\f1   ??quivalent C : strnicmp() / strncasecmp()}\par
\par
\par
