{\footnote # IDH_TPSTRS_09}
{\footnote $ Unite Strings (PChar) - ALLOCATION DYNAMIQUE}
{\footnote K Turbo Pascal;Unite Strings (PChar);ALLOCATION DYNAMIQUE}
\b\fs24 ALLOCATION DYNAMIQUE \b0\fs20\par
\par
{\f1   function StrNew(Str : PChar) : PChar;}\par
{\f1   Alloue une copie de Str sur le tas (heap) et retourne un}\par
{\f1   pointeur vers la copie.}\par
\par
{\f1   Param??tres :}\par
{\f1     Str  Cha??ne source (ASCIIZ), ou nil}\par
{\f1   Retour :}\par
{\f1     Pointeur vers la copie allou??e, ou nil}\par
\par
{\f1   Cas particuliers :}\par
{\f1     - Si Str = nil ??? retourne nil (pas d'allocation)}\par
{\f1     - Si Str^ = #0 (cha??ne vide) ??? retourne nil (pas d'allocation)}\par
\par
{\f1   La m??moire allou??e fait StrLen(Str) + 1 octets (pour le #0).}\par
{\f1   L'allocation est effectu??e via GetMem.}\par
\par
{\f1   Pour lib??rer la m??moire, utiliser StrDispose (pas FreeMem}\par
{\f1   directement, bien que fonctionnellement ??quivalent).}\par
\par
{\f1   ??quivalent C : strdup()}\par
\par
{\f1   Exemple :}\par
{\f1     var P, Q : PChar;}\par
{\f1     begin}\par
{\f1       P := 'Original';}\par
{\f1       Q := StrNew(P);       \{ Q pointe vers une copie sur le tas \}}\par
{\f1       WriteLn(StrPas(Q));   \{ ??? 'Original' \}}\par
{\f1       StrDispose(Q);        \{ lib??rer la m??moire \}}\par
{\f1     end;}\par
\par
{\f1   Impl??mentation :}\par
{\f1     function StrNew(Str: PChar): PChar;}\par
{\f1     var L: Word; P: PChar;}\par
{\f1     begin}\par
{\f1       StrNew := nil;}\par
{\f1       if (Str <> nil) and (Str^ <> #0) then}\par
{\f1       begin}\par
{\f1         L := StrLen(Str) + 1;}\par
{\f1         GetMem(P, L);}\par
{\f1         if P <> nil then StrNew := StrMove(P, Str, L);}\par
{\f1       end;}\par
{\f1     end;}\par
\par
{\f1   procedure StrDispose(Str : PChar);}\par
{\f1   Lib??re une cha??ne pr??c??demment allou??e par StrNew.}\par
\par
{\f1   Param??tres :}\par
{\f1     Str  Pointeur retourn?? par StrNew, ou nil}\par
\par
{\f1   Si Str = nil, StrDispose ne fait rien (appel s??r).}\par
\par
{\f1   La taille lib??r??e est calcul??e automatiquement comme}\par
{\f1   StrLen(Str) + 1 (via FreeMem).}\par
\par
{\f1   IMPORTANT : ne pas appeler StrDispose sur une cha??ne qui n'a}\par
{\f1   pas ??t?? allou??e par StrNew (ou GetMem avec la m??me taille).}\par
\par
{\f1   Impl??mentation :}\par
{\f1     procedure StrDispose(Str: PChar);}\par
{\f1     begin}\par
{\f1       if Str <> nil then FreeMem(Str, StrLen(Str) + 1);}\par
{\f1     end;}\par
\par
\par
