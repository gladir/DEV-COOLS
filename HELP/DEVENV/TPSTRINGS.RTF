{\footnote # IDH_TPSTRS_11}
{\footnote $ Unite Strings (PChar) - EXEMPLES COMPLETS}
{\footnote K Turbo Pascal;Unite Strings (PChar);EXEMPLES COMPLETS}
\b\fs24 EXEMPLES COMPLETS \b0\fs20\par
\par
{\f1   --- Exemple 1 : Manipulation de base ---}\par
\par
{\f1   program StringsDemo;}\par
{\f1   uses Strings;}\par
{\f1   var}\par
{\f1     Buf : array[0..255] of Char;}\par
{\f1     P   : PChar;}\par
{\f1   begin}\par
{\f1     StrCopy(Buf, 'Turbo');}\par
{\f1     StrCat(Buf, ' ');}\par
{\f1     StrCat(Buf, 'Pascal');}\par
{\f1     WriteLn(StrPas(Buf));       \{ ??? 'Turbo Pascal' \}}\par
{\f1     WriteLn('Longueur : ', StrLen(Buf)); \{ ??? 12 \}}\par
\par
{\f1     P := StrScan(Buf, ' ');}\par
{\f1     if P <> nil then}\par
{\f1       WriteLn('Apr??s espace : ', StrPas(P)); \{ ??? ' Pascal' \}}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 2 : Concat??nation efficace avec StrECopy ---}\par
\par
{\f1   program EfficientConcat;}\par
{\f1   uses Strings;}\par
{\f1   var}\par
{\f1     Buf : array[0..255] of Char;}\par
{\f1     P   : PChar;}\par
{\f1   begin}\par
{\f1     P := StrECopy(Buf, 'Fichier : ');}\par
{\f1     P := StrECopy(P, 'C:\\TP\\BIN\\');}\par
{\f1     StrCopy(P, 'TURBO.EXE');}\par
{\f1     WriteLn(StrPas(Buf));}\par
{\f1     \{ ??? 'Fichier : C:\\TP\\BIN\\TURBO.EXE' \}}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 3 : Comparaison insensible ?? la casse ---}\par
\par
{\f1   program CaseCompare;}\par
{\f1   uses Strings;}\par
{\f1   var}\par
{\f1     A, B : array[0..79] of Char;}\par
{\f1   begin}\par
{\f1     StrCopy(A, 'Hello World');}\par
{\f1     StrCopy(B, 'HELLO WORLD');}\par
\par
{\f1     if StrComp(A, B) <> 0 then}\par
{\f1       WriteLn('StrComp : diff??rentes');}\par
\par
{\f1     if StrIComp(A, B) = 0 then}\par
{\f1       WriteLn('StrIComp : identiques');}\par
\par
{\f1     if StrLIComp(A, B, 5) = 0 then}\par
{\f1       WriteLn('5 premiers car. identiques (insensible casse)');}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 4 : Allocation dynamique ---}\par
\par
{\f1   program DynamicStrings;}\par
{\f1   uses Strings;}\par
{\f1   var}\par
{\f1     Original : PChar;}\par
{\f1     Copie    : PChar;}\par
{\f1   begin}\par
{\f1     Original := 'Cha??ne originale';}\par
\par
{\f1     Copie := StrNew(Original);}\par
{\f1     if Copie <> nil then}\par
{\f1     begin}\par
{\f1       WriteLn(StrPas(Copie));}\par
{\f1       WriteLn('Taille en m??moire : ', StrLen(Copie) + 1, ' octets');}\par
{\f1       StrUpper(Copie);}\par
{\f1       WriteLn(StrPas(Copie));  \{ ??? 'CHA??NE ORIGINALE' \}}\par
{\f1       StrDispose(Copie);}\par
{\f1     end;}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 5 : Conversion String ??? PChar ---}\par
\par
{\f1   program ConvertDemo;}\par
{\f1   uses Strings;}\par
{\f1   var}\par
{\f1     PascalStr : String;}\par
{\f1     Buf       : array[0..255] of Char;}\par
{\f1   begin}\par
{\f1     \{ String ??? PChar \}}\par
{\f1     PascalStr := 'Bonjour le monde';}\par
{\f1     StrPCopy(Buf, PascalStr);}\par
{\f1     WriteLn('PChar : ', StrPas(Buf));}\par
{\f1     WriteLn('Longueur : ', StrLen(Buf));}\par
\par
{\f1     \{ PChar ??? String \}}\par
{\f1     StrCopy(Buf, 'Au revoir');}\par
{\f1     PascalStr := StrPas(Buf);}\par
{\f1     WriteLn('String : ', PascalStr);}\par
{\f1     WriteLn('Length : ', Length(PascalStr));}\par
{\f1   end.}\par
\par
{\f1   --- Exemple 6 : Extraction de nom de fichier ---}\par
\par
{\f1   program ExtractFileName;}\par
{\f1   uses Strings;}\par
{\f1   var}\par
{\f1     Path : PChar;}\par
{\f1     P    : PChar;}\par
{\f1   begin}\par
{\f1     Path := 'C:\\TP\\BIN\\TURBO.EXE';}\par
\par
{\f1     \{ Trouver le dernier '\\' \}}\par
{\f1     P := StrRScan(Path, '\\');}\par
{\f1     if P <> nil then}\par
{\f1     begin}\par
{\f1       Inc(P);  \{ avancer apr??s le '\\' \}}\par
{\f1       WriteLn('Nom fichier : ', StrPas(P));  \{ ??? TURBO.EXE \}}\par
{\f1     end;}\par
\par
{\f1     \{ Trouver 'BIN' dans le chemin \}}\par
{\f1     P := StrPos(Path, 'BIN');}\par
{\f1     if P <> nil then}\par
{\f1       WriteLn('Trouv?? ?? partir de : ', StrPas(P));}\par
{\f1       \{ ??? BIN\\TURBO.EXE \}}\par
{\f1   end.}\par
\par
