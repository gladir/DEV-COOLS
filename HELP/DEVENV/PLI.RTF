{\footnote # IDH_PLI_16}
{\footnote $ PL/I - Le compilateur PLI86.PAS}
{\footnote K PLI86.PAS;compilateur PL/I 8086;sortie MASM TASM;projet DEV-COOLS;modeles memoire SMALL COMPACT;pipeline assemblage liens}
\b\fs24 Le compilateur PLI86.PAS \b0\fs20\par
\par
\par
\b 16.1 Vue d ensemble \b0\par
\par
{\f1   PLI86.PAS est un compilateur PL/I cible 8086/8088 ecrit en Turbo Pascal}\par
{\f1   et Free Pascal, integre au projet DEV-COOLS. Il produit du code source}\par
{\f1   assembleur compatible MASM/TASM, assemblable par les outils du projet}\par
{\f1   (ASM86.PAS, MASM.PAS).}\par
\par
{\f1   Caracteristiques :}\par
\par
{\f1     - Sous-ensemble pratique de PL/I oriente PC 16 bits}\par
{\f1     - Sortie texte assembleur 8086 (segments .CODE, .DATA, .BSS)}\par
{\f1     - Modeles memoire SMALL et COMPACT}\par
{\f1     - Liaison avec LIB.PAS et LINK.PAS pour produire un .COM ou .EXE}\par
\par
\par
\b 16.2 Types supportes \b0\par
\par
{\f1   PLI86.PAS reconnait les types suivants (codes internes) :}\par
\par
{\f1     FIXED       : FIXED BINARY(15)  - entier 16 bits}\par
{\f1     FIXED(31)   : FIXED BINARY(31)  - entier 32 bits}\par
{\f1     FLOAT       : FLOAT BINARY      - flottant (stub a etoffer)}\par
{\f1     CHAR(n)     : chaine fixe       - tableau de n octets}\par
{\f1     CHAR(n) VARYING : chaine variable - prefixe de longueur 16 bits}\par
{\f1     BIT(n)      : champ de bits}\par
{\f1     LABEL       : etiquette PL/I}\par
{\f1     POINTER     : pointeur 16 bits (NEAR) ou 32 bits (FAR)}\par
{\f1     ENTRY       : pointeur de procedure}\par
\par
\par
\b 16.3 Classes de stockage \b0\par
\par
{\f1     AUTOMATIC   : pile, frame BP (defaut)}\par
{\f1     STATIC      : segment .DATA}\par
{\f1     EXTERNAL    : import depuis autre unite}\par
{\f1     BASED       : acces via pointeur}\par
\par
\par
\b 16.4 Mots-cles reconnus \b0\par
\par
{\f1   Le tableau interne KW_PROCEDURE..KW_END couvre les constructions}\par
{\f1   essentielles : PROCEDURE, END, BEGIN, CALL, RETURN, IF, THEN, ELSE,}\par
{\f1   DO, WHILE, UNTIL, TO, BY, LEAVE, ITERATE, GOTO, DECLARE, DCL, PUT,}\par
{\f1   GET, LIST, OPTIONS, MAIN, FIXED, FLOAT, BINARY, DECIMAL, CHAR,}\par
{\f1   CHARACTER, BIT, VARYING, POINTER, PTR, STATIC, AUTOMATIC, EXTERNAL,}\par
{\f1   BASED, INITIAL, ALLOCATE, FREE, NULL, ADDR.}\par
\par
\par
\b 16.5 Sortie assembleur \b0\par
\par
{\f1   Le compilateur produit une sortie de la forme :}\par
\par
{\f1     .MODEL SMALL}\par
{\f1     .STACK 1024}\par
{\f1     .DATA}\par
{\f1     _MSG    DB    'BONJOUR$'}\par
{\f1     _X      DW    0}\par
{\f1     .CODE}\par
{\f1     _MAIN:  MOV   AX, OFFSET _MSG}\par
{\f1             CALL  _PRINT}\par
{\f1             MOV   AH, 4Ch}\par
{\f1             INT   21h}\par
{\f1     _PRINT: ...}\par
\par
\par
\b 16.6 Pipeline de compilation \b0\par
\par
{\f1   Le pipeline typique avec PLI86.PAS :}\par
\par
{\f1     1. PLI86.PAS         : compile .PLI -> .ASM}\par
{\f1     2. ASM86.PAS / MASM  : assemble .ASM -> .OBJ}\par
{\f1     3. LINK.PAS          : edite les liens .OBJ -> .EXE ou .COM}\par
\par
\par
\b 16.7 Utilisation \b0\par
\par
{\f1   Compilation du compilateur :}\par
\par
{\f1     fpc -Mtp PLI86.PAS}\par
\par
{\f1   Compilation d un programme PL/I :}\par
\par
{\f1     PLI86 MONPRG.PLI}\par
{\f1     ASM86 MONPRG.ASM}\par
{\f1     LINK  MONPRG.OBJ}\par
\par
\par
