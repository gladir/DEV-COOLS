{\footnote # IDH_PLI_14}
{\footnote $ PL/I - Conditions et gestion des exceptions}
{\footnote K PL/I exceptions;ON-units;OVERFLOW UNDERFLOW ZERODIVIDE SIZE STRINGSIZE SUBSCRIPTRANGE CONVERSION ENDFILE ERROR FINISH;SIGNAL;REVERT}
\b\fs24 Conditions et gestion des exceptions \b0\fs20\par
\par
\par
\b 14.1 ON-units \b0\par
\par
{\f1   PL/I propose un mecanisme d exceptions appele "ON-units". Une instruction}\par
{\f1   ON definit ce qui doit etre execute quand une condition donnee se}\par
{\f1   produit :}\par
\par
{\f1     ON OVERFLOW BEGIN;}\par
{\f1        PUT LIST('Depassement de capacite !');}\par
{\f1        STOP;}\par
{\f1     END;}\par
\par
{\f1     ON ZERODIVIDE}\par
{\f1        PUT LIST('Division par zero !');}\par
\par
{\f1     ON ENDFILE(F)}\par
{\f1        FIN_LECTURE = '1'B;}\par
\par
\par
\b 14.2 Conditions standard \b0\par
\par
{\f1     OVERFLOW         : depassement de capacite arithmetique}\par
{\f1     UNDERFLOW        : sous-depassement flottant}\par
{\f1     ZERODIVIDE       : division par zero}\par
{\f1     SIZE             : perte de chiffres significatifs}\par
{\f1     STRINGSIZE       : depassement de chaine}\par
{\f1     SUBSCRIPTRANGE   : indice hors borne}\par
{\f1     CONVERSION       : erreur de conversion de donnees}\par
{\f1     ENDFILE(F)       : fin de fichier F}\par
{\f1     UNDEFINEDFILE(F) : fichier non defini}\par
{\f1     ERROR            : erreur generique}\par
{\f1     FINISH           : avant la fin du programme}\par
\par
{\f1   Activation/desactivation prefixees aux instructions ou blocs :}\par
\par
{\f1     (NOSUBSCRIPTRANGE):}\par
{\f1     MAIN: PROCEDURE OPTIONS(MAIN);}\par
{\f1        ...}\par
{\f1     END MAIN;}\par
\par
{\f1     (SIZE, OVERFLOW):}\par
{\f1     DO I = 1 TO 100;}\par
{\f1        X = X * 2;}\par
{\f1     END;}\par
\par
\par
\b 14.3 SIGNAL \b0\par
\par
{\f1   Declenche manuellement une condition :}\par
\par
{\f1     SIGNAL CONDITION(MON_ERREUR);}\par
{\f1     SIGNAL OVERFLOW;}\par
\par
\par
\b 14.4 REVERT \b0\par
\par
{\f1   Restaure le ON-unit precedent :}\par
\par
{\f1     ON ERROR BEGIN; ... END;}\par
{\f1     ...}\par
{\f1     REVERT ERROR;       /* retourne au gestionnaire precedent */}\par
\par
\par
