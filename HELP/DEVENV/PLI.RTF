{\footnote # IDH_PLI_05}
{\footnote $ PL/I - Types de donnees}
{\footnote K PL/I types donnees;FIXED BINARY;FIXED DECIMAL;FLOAT BINARY;FLOAT DECIMAL;CHARACTER VARYING;BIT;PICTURE;POINTER OFFSET;LABEL;ENTRY}
\b\fs24 Types de donnees \b0\fs20\par
\par
\par
\b 5.1 Types numeriques \b0\par
\par
{\f1   PL/I distingue plusieurs types numeriques par leur "base" (BINARY ou}\par
{\f1   DECIMAL), leur "echelle" (FIXED ou FLOAT) et leur "precision" :}\par
\par
{\f1     FIXED BINARY(p,q)      : entier ou virgule fixe binaire}\par
{\f1                              p = nombre total de bits, q = bits fractionnaires}\par
{\f1                              Exemples :}\par
{\f1                                FIXED BINARY(15,0)   /* short, -32768..32767 */}\par
{\f1                                FIXED BINARY(31,0)   /* int, +/- 2^31 */}\par
{\f1                                FIXED BINARY(63,0)   /* long, +/- 2^63 */}\par
\par
{\f1     FIXED DECIMAL(p,q)     : virgule fixe decimale (BCD packed)}\par
{\f1                              Exemple :}\par
{\f1                                FIXED DECIMAL(7,2)   /* 99999.99 */}\par
\par
{\f1     FLOAT BINARY(p)        : virgule flottante binaire}\par
{\f1                              p = bits de precision}\par
{\f1                                FLOAT BINARY(21)     /* simple precision IEEE */}\par
{\f1                                FLOAT BINARY(53)     /* double precision IEEE */}\par
\par
{\f1     FLOAT DECIMAL(p)       : virgule flottante decimale}\par
{\f1                                FLOAT DECIMAL(6)     /* simple precision */}\par
{\f1                                FLOAT DECIMAL(15)    /* double precision */}\par
\par
{\f1   Defauts si non specifies :}\par
\par
{\f1     DECLARE X FIXED;                    /* FIXED DECIMAL(5,0) */}\par
{\f1     DECLARE Y FLOAT;                    /* FLOAT DECIMAL(6)   */}\par
{\f1     DECLARE Z FIXED BINARY;             /* FIXED BINARY(15,0) */}\par
{\f1     DECLARE W FLOAT BINARY;             /* FLOAT BINARY(21)   */}\par
\par
\par
\b 5.2 Type CHARACTER \b0\par
\par
{\f1   Chaine de caracteres de longueur fixe ou variable :}\par
\par
{\f1     DECLARE NOM       CHARACTER(20);              /* longueur fixe 20 */}\par
{\f1     DECLARE MESSAGE   CHARACTER(80) VARYING;      /* longueur variable, max 80 */}\par
{\f1     DECLARE INITIALE  CHARACTER(1);}\par
\par
{\f1   Les chaines fixes sont remplies d espaces (blank-padded). Les chaines}\par
{\f1   VARYING stockent leur longueur courante en prefixe (mot 16 ou 32 bits).}\par
\par
\par
\b 5.3 Type BIT \b0\par
\par
{\f1   Chaine de bits compactee :}\par
\par
{\f1     DECLARE DRAPEAU      BIT(1);                  /* equivalent booleen */}\par
{\f1     DECLARE MASQUE       BIT(8);                  /* 8 bits packs */}\par
{\f1     DECLARE FLAGS        BIT(16) VARYING;}\par
\par
{\f1   Les constantes booleennes sont '1'B (vrai) et '0'B (faux).}\par
\par
\par
\b 5.4 Type PICTURE \b0\par
\par
{\f1   Specification de format pour entree/sortie editees (comme COBOL) :}\par
\par
{\f1     DECLARE PRIX     PICTURE '$$$,$$9.99';        /* 9999.99 -> $9,999.99 */}\par
{\f1     DECLARE CODE     PICTURE '9999';              /* exactement 4 chiffres */}\par
{\f1     DECLARE TEL      PICTURE 'A99-9999';          /* lettre + 6 chiffres */}\par
\par
{\f1   Caracteres de specification :}\par
{\f1     9  : chiffre obligatoire}\par
{\f1     Z  : chiffre, zero a gauche supprime}\par
{\f1     *  : chiffre, zero a gauche remplace par *}\par
{\f1     .  : point decimal}\par
{\f1     ,  : separateur de milliers}\par
{\f1     $  : symbole monetaire flottant}\par
{\f1     A  : lettre alphabetique}\par
{\f1     X  : caractere quelconque}\par
{\f1     B  : espace}\par
{\f1     -  : signe negatif (flottant ou positionnel)}\par
{\f1     +  : signe positif (flottant ou positionnel)}\par
{\f1     CR : credit (suffixe pour valeur negative)}\par
{\f1     DB : debit (suffixe pour valeur negative)}\par
\par
\par
\b 5.5 Type POINTER et OFFSET \b0\par
\par
{\f1     DECLARE PTR1 POINTER;}\par
{\f1     DECLARE OFF1 OFFSET(AREA1);}\par
{\f1     DECLARE AREA1 AREA(1024);}\par
\par
{\f1   Un POINTER est une adresse memoire 16/32/64 bits selon l implementation.}\par
{\f1   Un OFFSET est un decalage dans une zone AREA, permettant des structures}\par
{\f1   relocatables.}\par
\par
\par
\b 5.6 Type LABEL \b0\par
\par
{\f1   Variable contenant l adresse d une etiquette :}\par
\par
{\f1     DECLARE L LABEL;}\par
{\f1     L = ETIQ1;}\par
{\f1     GOTO L;}\par
{\f1     ...}\par
{\f1     ETIQ1: PUT LIST('Saute ici');}\par
\par
\par
\b 5.7 Type ENTRY \b0\par
\par
{\f1   Pointeur de procedure :}\par
\par
{\f1     DECLARE FUNC ENTRY(FIXED BINARY) RETURNS(FIXED BINARY);}\par
{\f1     FUNC = MA_PROC;}\par
{\f1     X = FUNC(42);}\par
\par
\par
