{\footnote # IDH_PLI_17}
{\footnote $ PL/I - Exemples complets}
{\footnote K PL/I exemples;Hello World;factorielle recursive;tri a bulles;lecture fichier;liste chainee}
\b\fs24 Exemples complets \b0\fs20\par
\par
\par
\b 17.1 Hello, World! \b0\par
\par
{\f1     HELLO: PROCEDURE OPTIONS(MAIN);}\par
{\f1        PUT LIST('Hello, World!');}\par
{\f1     END HELLO;}\par
\par
\par
\b 17.2 Factorielle recursive \b0\par
\par
{\f1     FACTORIELLE: PROCEDURE OPTIONS(MAIN);}\par
\par
{\f1        FACT: PROCEDURE(N) RECURSIVE RETURNS(FIXED BINARY(31));}\par
{\f1           DECLARE N FIXED BINARY(31);}\par
{\f1           IF N <= 1 THEN RETURN(1);}\par
{\f1           RETURN(N * FACT(N-1));}\par
{\f1        END FACT;}\par
\par
{\f1        DECLARE I FIXED BINARY(31);}\par
{\f1        DO I = 1 TO 10;}\par
{\f1           PUT SKIP LIST(I, FACT(I));}\par
{\f1        END;}\par
\par
{\f1     END FACTORIELLE;}\par
\par
\par
\b 17.3 Tri a bulles \b0\par
\par
{\f1     TRI: PROCEDURE OPTIONS(MAIN);}\par
{\f1        DECLARE T(10) FIXED BINARY(31)}\par
{\f1           INITIAL(5, 2, 8, 1, 9, 3, 7, 4, 6, 0);}\par
{\f1        DECLARE (I, J, TMP) FIXED BINARY(31);}\par
\par
{\f1        DO I = 1 TO 9;}\par
{\f1           DO J = 1 TO 10 - I;}\par
{\f1              IF T(J) > T(J+1) THEN DO;}\par
{\f1                 TMP    = T(J);}\par
{\f1                 T(J)   = T(J+1);}\par
{\f1                 T(J+1) = TMP;}\par
{\f1              END;}\par
{\f1           END;}\par
{\f1        END;}\par
\par
{\f1        DO I = 1 TO 10;}\par
{\f1           PUT LIST(T(I));}\par
{\f1        END;}\par
{\f1     END TRI;}\par
\par
\par
\b 17.4 Lecture de fichier \b0\par
\par
{\f1     LIRE: PROCEDURE OPTIONS(MAIN);}\par
{\f1        DECLARE F FILE INPUT STREAM;}\par
{\f1        DECLARE LIGNE CHARACTER(80) VARYING;}\par
{\f1        DECLARE FIN BIT(1) INITIAL('0'B);}\par
\par
{\f1        ON ENDFILE(F) FIN = '1'B;}\par
\par
{\f1        OPEN FILE(F) TITLE('DONNEES.TXT');}\par
{\f1        DO WHILE(^FIN);}\par
{\f1           GET FILE(F) EDIT(LIGNE)(A(80));}\par
{\f1           IF ^FIN THEN PUT SKIP LIST(LIGNE);}\par
{\f1        END;}\par
{\f1        CLOSE FILE(F);}\par
{\f1     END LIRE;}\par
\par
\par
\b 17.5 Liste chainee \b0\par
\par
{\f1     LISTE: PROCEDURE OPTIONS(MAIN);}\par
{\f1        DECLARE 1 NOEUD BASED(P),}\par
{\f1                  2 VALEUR FIXED BINARY(31),}\par
{\f1                  2 SUIV POINTER;}\par
\par
{\f1        DECLARE (TETE, P, Q) POINTER;}\par
{\f1        DECLARE I FIXED BINARY(31);}\par
\par
{\f1        TETE = NULL();}\par
{\f1        DO I = 1 TO 5;}\par
{\f1           ALLOCATE NOEUD SET(P);}\par
{\f1           P -> VALEUR = I * 10;}\par
{\f1           P -> SUIV   = TETE;}\par
{\f1           TETE = P;}\par
{\f1        END;}\par
\par
{\f1        Q = TETE;}\par
{\f1        DO WHILE(Q ^= NULL());}\par
{\f1           PUT SKIP LIST(Q -> VALEUR);}\par
{\f1           Q = Q -> SUIV;}\par
{\f1        END;}\par
{\f1     END LISTE;}\par
\par
\par
