{\footnote # IDH_PLI_18}
{\footnote $ PL/I - Differences avec C, COBOL et Fortran}
{\footnote K PL/I differences;PL/I vs C;PL/I vs COBOL;PL/I vs Fortran;comparaison langages}
\b\fs24 Differences avec C, COBOL et Fortran \b0\fs20\par
\par
\par
\b 18.1 PL/I vs C \b0\par
\par
{\f1     Aspect              PL/I                  C}\par
{\f1     ------------------  --------------------  ----------------------}\par
{\f1     Casse               insensible            sensible}\par
{\f1     Type defaut         FIXED DECIMAL(5,0)    int}\par
{\f1     Chaines             type natif            tableau de char + '\\0'}\par
{\f1     Tableaux            descripteur           pointeur}\par
{\f1     Exceptions          ON-units integres     setjmp/longjmp}\par
{\f1     Conversions         implicites largement  limitees, explicites}\par
{\f1     Allocation          ALLOCATE/FREE         malloc/free}\par
{\f1     Pointeurs           type POINTER          type *}\par
{\f1     Indices defaut      1                     0}\par
{\f1     Operateur affect    =                     =}\par
{\f1     Comparaison egal    =                     ==}\par
\par
\par
\b 18.2 PL/I vs COBOL \b0\par
\par
{\f1     Aspect              PL/I                  COBOL}\par
{\f1     ------------------  --------------------  ----------------------}\par
{\f1     Domaine             generaliste           gestion}\par
{\f1     Structure           blocs imbriques       divisions (4)}\par
{\f1     Declarations        DECLARE flexible      PICTURE clause}\par
{\f1     Boucles             DO unifie             PERFORM}\par
{\f1     Conditions          ON-units              imperative + check}\par
{\f1     Recursion           OUI                   non (avant 2002)}\par
{\f1     Format I/O          PUT EDIT / picture    PIC clause}\par
{\f1     Verbosite           moyenne               tres elevee}\par
\par
\par
\b 18.3 PL/I vs Fortran \b0\par
\par
{\f1     Aspect              PL/I                  Fortran (77)}\par
{\f1     ------------------  --------------------  ----------------------}\par
{\f1     Domaine             generaliste           scientifique}\par
{\f1     Recursion           OUI (RECURSIVE)       NON (avant Fortran 90)}\par
{\f1     Pointeurs           OUI                   NON (avant Fortran 90)}\par
{\f1     Chaines             types natifs          tableaux de char}\par
{\f1     Structures          DECLARE niveaux       TYPE (Fortran 90+)}\par
{\f1     Allocation dyn      OUI                   NON (avant Fortran 90)}\par
{\f1     Format I/O          plus riche            FORMAT statement}\par
{\f1     Bloc                BEGIN/END             pas de bloc local}\par
\par
\par
