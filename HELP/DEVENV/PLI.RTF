\page

{\footnote # IDH_PLI_10}
{\footnote $ PL/I - Procedures et fonctions}
{\footnote K PL/I procedures fonctions;PROCEDURE RETURNS;passage parametres reference valeur;RECURSIVE;OPTIONS MAIN REENTRANT BYVALUE LINKAGE}
\b\fs24 Procedures et fonctions \b0\fs20\par
\par
\par
\b 10.1 Procedure simple \b0\par
\par
{\f1     AFFICHE: PROCEDURE(MSG);}\par
{\f1        DECLARE MSG CHARACTER(*);}\par
{\f1        PUT LIST(MSG);}\par
{\f1     END AFFICHE;}\par
\par
{\f1   L attribut CHARACTER(*) indique que la longueur sera celle de l argument}\par
{\f1   passe au moment de l appel.}\par
\par
\par
\b 10.2 Fonction (avec RETURNS) \b0\par
\par
{\f1     CARRE: PROCEDURE(X) RETURNS(FIXED BINARY(31));}\par
{\f1        DECLARE X FIXED BINARY(31);}\par
{\f1        RETURN(X * X);}\par
{\f1     END CARRE;}\par
\par
{\f1     Y = CARRE(7);     /* Y = 49 */}\par
\par
\par
\b 10.3 Passage de parametres \b0\par
\par
{\f1   Par defaut, les arguments sont passes par REFERENCE (alias). Pour passer}\par
{\f1   par valeur, on encadre l argument de parentheses, ce qui force la}\par
{\f1   creation d une copie :}\par
\par
{\f1     CALL MAJ(X);       /* par reference - peut modifier X */}\par
{\f1     CALL MAJ((X));     /* par valeur - X protegee */}\par
\par
\par
\b 10.4 RECURSIVE \b0\par
\par
{\f1   Procedures recursives explicitement marquees :}\par
\par
{\f1     FACT: PROCEDURE(N) RECURSIVE RETURNS(FIXED BINARY(31));}\par
{\f1        DECLARE N FIXED BINARY(31);}\par
{\f1        IF N <= 1 THEN RETURN(1);}\par
{\f1        RETURN(N * FACT(N-1));}\par
{\f1     END FACT;}\par
\par
{\f1   Sans RECURSIVE, les variables locales sont STATIC et l appel recursif}\par
{\f1   est non sur.}\par
\par
\par
\b 10.5 OPTIONS \b0\par
\par
{\f1   Modificateurs sur la procedure :}\par
\par
{\f1     OPTIONS(MAIN)       : procedure principale}\par
{\f1     OPTIONS(RECURSIVE)  : autorise la recursion}\par
{\f1     OPTIONS(REENTRANT)  : code reentrant (multitache)}\par
{\f1     OPTIONS(BYVALUE)    : passage par valeur par defaut}\par
{\f1     OPTIONS(LINKAGE(...))  : convention d appel (OPTLINK, STDCALL, etc.)}\par
\par
\par
