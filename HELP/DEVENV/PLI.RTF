{\footnote # IDH_PLI_11}
{\footnote $ PL/I - Entrees/sorties}
{\footnote K PL/I entrees sorties;PUT GET LIST EDIT DATA;format A F E B P X SKIP PAGE COL;FILE INPUT OUTPUT;STREAM RECORD;OPEN CLOSE READ WRITE}
\b\fs24 Entrees/sorties \b0\fs20\par
\par
\par
\b 11.1 PUT et GET \b0\par
\par
{\f1   Les instructions de base sont PUT (sortie) et GET (entree). Trois}\par
{\f1   modes :}\par
\par
{\f1   Mode LIST (libre, separateurs automatiques) :}\par
\par
{\f1     PUT LIST('X =', X, 'Y =', Y);}\par
{\f1     GET LIST(A, B, C);}\par
\par
{\f1   Mode EDIT (format precis) :}\par
\par
{\f1     PUT EDIT(NOM, AGE)(A(20), F(3));}\par
{\f1     GET EDIT(NOM, AGE)(A(20), F(3));}\par
\par
{\f1   Mode DATA (nom=valeur) :}\par
\par
{\f1     PUT DATA(X, Y, Z);          /* affiche X= ... Y= ... Z= ... ; */}\par
{\f1     GET DATA;                   /* lit ces affectations */}\par
\par
\par
\b 11.2 Format codes \b0\par
\par
{\f1     A(n)    : alphanumerique de largeur n}\par
{\f1     F(w,d)  : numerique de largeur w avec d decimales}\par
{\f1     E(w,d)  : flottant exponentiel}\par
{\f1     B(n)    : chaine de bits}\par
{\f1     P'...'  : picture}\par
{\f1     X(n)    : n espaces}\par
{\f1     SKIP    : saut de ligne}\par
{\f1     PAGE    : saut de page}\par
{\f1     COL(n)  : positionne en colonne n}\par
{\f1     R(label): repete le format defini a label}\par
\par
\par
\b 11.3 Fichiers \b0\par
\par
{\f1     DECLARE F FILE INPUT RECORD;}\par
\par
{\f1     OPEN FILE(F) TITLE('DONNEES.TXT');}\par
{\f1     READ FILE(F) INTO(BUFFER);}\par
{\f1     CLOSE FILE(F);}\par
\par
{\f1   Attributs de FILE :}\par
\par
{\f1     INPUT / OUTPUT / UPDATE}\par
{\f1     STREAM / RECORD}\par
{\f1     SEQUENTIAL / DIRECT / KEYED}\par
{\f1     PRINT}\par
{\f1     ENVIRONMENT(...)}\par
\par
\par
{\uldb << Precedent}{\v IDH_PLI_10}     {\uldb Suivant >>}{\v IDH_PLI_12}     {\uldb Table des matieres}{\v IDH_PLI_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_PLI_12}
{\footnote $ PL/I - Pointeurs et structures}
{\footnote K PL/I pointeurs structures;POINTER NULL;ADDR;BASED;ALLOCATE SET;structures auto-referentielles;liste chainee}
\b\fs24 Pointeurs et structures \b0\fs20\par
\par
\par
\b 12.1 Pointeurs \b0\par
\par
{\f1     DECLARE P POINTER;}\par
{\f1     DECLARE X FIXED BINARY(31) BASED(P);}\par
\par
{\f1     ALLOCATE X;}\par
{\f1     X = 42;            /* equivaut a P -> X = 42 */}\par
{\f1     FREE X;}\par
{\f1     P = NULL();        /* pointeur nul */}\par
\par
\par
\b 12.2 ADDR \b0\par
\par
{\f1   Fonction integree retournant l adresse d une variable :}\par
\par
{\f1     DECLARE I FIXED BINARY(31);}\par
{\f1     DECLARE P POINTER;}\par
{\f1     P = ADDR(I);}\par
\par
\par
\b 12.3 Structures auto-referentielles \b0\par
\par
{\f1   Liste chainee :}\par
\par
{\f1     DECLARE 1 NOEUD BASED(P),}\par
{\f1               2 VALEUR  FIXED BINARY(31),}\par
{\f1               2 SUIVANT POINTER;}\par
\par
{\f1     DECLARE TETE POINTER INITIAL(NULL());}\par
{\f1     DECLARE P    POINTER;}\par
\par
{\f1     ALLOCATE NOEUD SET(P);}\par
{\f1     P -> VALEUR = 42;}\par
{\f1     P -> SUIVANT = TETE;}\par
{\f1     TETE = P;}\par
\par
\par
{\uldb << Precedent}{\v IDH_PLI_11}     {\uldb Suivant >>}{\v IDH_PLI_13}     {\uldb Table des matieres}{\v IDH_PLI_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_PLI_13}
{\footnote $ PL/I - Tableaux}
{\footnote K PL/I tableaux;dimensions;indices;sections de tableaux;expressions tableau;matrice;tableaux structures}
\b\fs24 Tableaux \b0\fs20\par
\par
\par
\b 13.1 Declaration \b0\par
\par
{\f1     DECLARE T(10)        FIXED BINARY(31);       /* T(1) a T(10) */}\par
{\f1     DECLARE U(0:9)       FIXED BINARY(31);       /* U(0) a U(9)  */}\par
{\f1     DECLARE M(5,5)       FLOAT BINARY(21);       /* matrice 5x5  */}\par
{\f1     DECLARE V(-10:10)    FIXED BINARY(31);       /* indices negatifs */}\par
\par
{\f1   Les indices par defaut commencent a 1.}\par
\par
\par
\b 13.2 Expressions sur tableaux \b0\par
\par
{\f1     DECLARE A(100), B(100), C(100) FIXED BINARY(31);}\par
\par
{\f1     A = B;           /* copie element par element */}\par
{\f1     C = A + B;       /* somme element par element */}\par
{\f1     A = 0;           /* tous les elements a 0 */}\par
\par
\par
\b 13.3 Sections de tableaux \b0\par
\par
{\f1     A(*) = 0;             /* tous les elements */}\par
{\f1     A(5:10) = B(1:6);     /* sous-section */}\par
{\f1     M(*, 3) = 1;          /* colonne 3 */}\par
{\f1     M(2, *) = 0;          /* ligne 2 */}\par
\par
\par
\b 13.4 Tableaux de structures \b0\par
\par
{\f1     DECLARE 1 EMPLOYES(100),}\par
{\f1               2 NOM CHARACTER(40) VARYING,}\par
{\f1               2 SALAIRE FIXED DECIMAL(9,2);}\par
\par
{\f1     EMPLOYES(1).NOM = 'DUPONT';}\par
{\f1     EMPLOYES(1).SALAIRE = 35000.00;}\par
\par
\par
