{\footnote # IDH_PLI_08}
{\footnote $ PL/I - Operateurs et expressions}
{\footnote K PL/I operateurs;arithmetiques;puissance **;comparaison =;^= != ~=;logiques & | ^;concatenation ||;precedence;conversions implicites}
\b\fs24 Operateurs et expressions \b0\fs20\par
\par
\par
\b 8.1 Operateurs arithmetiques \b0\par
\par
{\f1     +     addition}\par
{\f1     -     soustraction}\par
{\f1     *     multiplication}\par
{\f1     /     division}\par
{\f1     **    puissance (exponentiation)}\par
{\f1     -     negation unaire}\par
{\f1     +     identite unaire}\par
\par
\par
\b 8.2 Operateurs de comparaison \b0\par
\par
{\f1     =     egal a}\par
{\f1     ^=    different (peut aussi s ecrire !=, ~= ou ??=)}\par
{\f1     <     inferieur a}\par
{\f1     <=    inferieur ou egal}\par
{\f1     >     superieur a}\par
{\f1     >=    superieur ou egal}\par
\par
{\f1   Les operateurs de comparaison renvoient une chaine BIT(1) : '1'B (vrai)}\par
{\f1   ou '0'B (faux).}\par
\par
\par
\b 8.3 Operateurs logiques \b0\par
\par
{\f1     &     ET logique (AND)}\par
{\f1     |     OU logique (OR)}\par
{\f1     ^     NON logique (NOT) - peut aussi s ecrire ~ ou ??}\par
\par
{\f1   Operandes : chaines BIT. Les operateurs s appliquent bit a bit, ce qui}\par
{\f1   donne aussi un ET/OU bit-a-bit pour les masques.}\par
\par
\par
\b 8.4 Operateur de concatenation \b0\par
\par
{\f1     ||    concatenation de chaines (CHARACTER ou BIT)}\par
\par
{\f1   Exemple :}\par
{\f1     NOM_COMPLET = PRENOM || ' ' || NOM;}\par
\par
\par
\b 8.5 Precedence des operateurs \b0\par
\par
{\f1   De la plus haute a la plus basse :}\par
\par
{\f1     1.  **               (puissance, droite a gauche)}\par
{\f1     2.  unaires + -  ^   (signe, NOT)}\par
{\f1     3.  *  /             (multiplication, division)}\par
{\f1     4.  +  -             (addition, soustraction)}\par
{\f1     5.  ||               (concatenation)}\par
{\f1     6.  <  <=  =  ^=  >=  >    (comparaisons)}\par
{\f1     7.  &                (AND)}\par
{\f1     8.  |                (OR)}\par
\par
\par
\b 8.6 Conversions implicites \b0\par
\par
{\f1   PL/I convertit automatiquement les operandes selon des regles precises.}\par
{\f1   Exemples :}\par
\par
{\f1     DECLARE I FIXED BINARY(15), F FLOAT BINARY(21), C CHARACTER(10);}\par
\par
{\f1     F = I;          /* FIXED -> FLOAT */}\par
{\f1     I = '123';      /* CHAR  -> FIXED (parse) */}\par
{\f1     C = I;          /* FIXED -> CHAR  (format) */}\par
{\f1     C = '12' + 5;   /* CHAR converti en FIXED, addition, retour CHAR */}\par
\par
{\f1   Cette conversion est tres puissante mais source de bugs subtils si}\par
{\f1   l on ne maitrise pas les regles.}\par
\par
\par
