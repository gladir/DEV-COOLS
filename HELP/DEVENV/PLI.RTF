{\footnote # IDH_PLI_09}
{\footnote $ PL/I - Instructions de controle}
{\footnote K PL/I controle flux;affectation multiple;IF THEN ELSE;DO TO BY WHILE UNTIL FOREVER;LEAVE ITERATE;SELECT WHEN OTHERWISE;GOTO;CALL RETURN}
\b\fs24 Instructions de controle \b0\fs20\par
\par
\par
\b 9.1 Affectation \b0\par
\par
{\f1     X = 42;}\par
{\f1     A, B, C = 0;            /* affectation multiple */}\par
{\f1     TAB(*) = 0;             /* tous les elements */}\par
{\f1     NOM = 'BONJOUR';}\par
\par
\par
\b 9.2 IF / THEN / ELSE \b0\par
\par
{\f1     IF X > 0 THEN}\par
{\f1        PUT LIST('positif');}\par
{\f1     ELSE IF X < 0 THEN}\par
{\f1        PUT LIST('negatif');}\par
{\f1     ELSE}\par
{\f1        PUT LIST('nul');}\par
\par
{\f1   Bloc multi-instructions :}\par
\par
{\f1     IF X > 0 THEN DO;}\par
{\f1        Y = X * 2;}\par
{\f1        PUT LIST(Y);}\par
{\f1     END;}\par
\par
\par
\b 9.3 DO \b0\par
\par
{\f1   Boucle generale, plusieurs formes :}\par
\par
{\f1   Boucle compteur :}\par
{\f1     DO I = 1 TO 10;}\par
{\f1        PUT LIST(I);}\par
{\f1     END;}\par
\par
{\f1   Avec pas :}\par
{\f1     DO I = 0 TO 100 BY 5;}\par
{\f1        PUT LIST(I);}\par
{\f1     END;}\par
\par
{\f1   Liste de valeurs :}\par
{\f1     DO J = 2, 4, 7, 11;}\par
{\f1        PUT LIST(J);}\par
{\f1     END;}\par
\par
{\f1   WHILE :}\par
{\f1     DO WHILE(X > 0);}\par
{\f1        X = X - 1;}\par
{\f1     END;}\par
\par
{\f1   UNTIL :}\par
{\f1     DO UNTIL(X = 0);}\par
{\f1        X = X - 1;}\par
{\f1     END;}\par
\par
{\f1   Combinaison :}\par
{\f1     DO I = 1 TO 100 WHILE(TROUVE = '0'B);}\par
{\f1        /* boucle iterative avec condition de sortie */}\par
{\f1     END;}\par
\par
{\f1   Repetition indefinie :}\par
{\f1     DO FOREVER;}\par
{\f1        /* equivaut a DO WHILE('1'B) */}\par
{\f1        IF FIN THEN LEAVE;}\par
{\f1     END;}\par
\par
\par
\b 9.4 LEAVE et ITERATE \b0\par
\par
{\f1   LEAVE : sort de la boucle (equiv. C break).}\par
{\f1   ITERATE : passe a l iteration suivante (equiv. C continue).}\par
\par
{\f1     DO I = 1 TO 100;}\par
{\f1        IF I = 50 THEN LEAVE;}\par
{\f1        IF MOD(I,2) = 0 THEN ITERATE;}\par
{\f1        PUT LIST(I);}\par
{\f1     END;}\par
\par
\par
\b 9.5 SELECT (multi-branchement) \b0\par
\par
{\f1   Comme switch/case mais plus puissant :}\par
\par
{\f1     SELECT(N);}\par
{\f1        WHEN(0)       PUT LIST('zero');}\par
{\f1        WHEN(1,2,3)   PUT LIST('petit');}\par
{\f1        WHEN(4 TO 9)  PUT LIST('moyen');}\par
{\f1        OTHERWISE     PUT LIST('grand');}\par
{\f1     END;}\par
\par
{\f1   Version sans expression (suite de conditions) :}\par
\par
{\f1     SELECT;}\par
{\f1        WHEN(X > 0)   PUT LIST('positif');}\par
{\f1        WHEN(X < 0)   PUT LIST('negatif');}\par
{\f1        OTHERWISE     PUT LIST('nul');}\par
{\f1     END;}\par
\par
\par
\b 9.6 GOTO \b0\par
\par
{\f1     GOTO ETIQ1;}\par
{\f1     ...}\par
{\f1     ETIQ1: PUT LIST('arrivee');}\par
\par
{\f1   GOTO peut sortir d un bloc imbrique, declenchant le deroulement de la}\par
{\f1   pile (unwind).}\par
\par
\par
\b 9.7 CALL et RETURN \b0\par
\par
{\f1     CALL MA_PROCEDURE(X, Y);}\par
{\f1     Z = MA_FONCTION(X, Y);}\par
\par
{\f1     RETURN;            /* dans procedure sans valeur */}\par
{\f1     RETURN(EXPR);      /* dans fonction */}\par
\par
\par
