{\footnote # IDH_PLI_15}
{\footnote $ PL/I - Preprocesseur}
{\footnote K PL/I preprocesseur;%INCLUDE;%DECLARE;%IF %THEN %ELSE;%DO;%PROCEDURE;macros}
\b\fs24 Preprocesseur \b0\fs20\par
\par
{\f1   PL/I integre un macroprocesseur puissant prefixe par "%".}\par
\par
\par
\b 15.1 Inclusion de fichiers \b0\par
\par
{\f1     %INCLUDE 'CONSTANTES.INC';}\par
{\f1     %INCLUDE STDIO;}\par
\par
\par
\b 15.2 Variables et constantes du preprocesseur \b0\par
\par
{\f1     %DECLARE TAILLE FIXED;}\par
{\f1     %TAILLE = 100;}\par
\par
{\f1     DECLARE T(TAILLE) FIXED BINARY(31);   /* devient T(100) */}\par
\par
\par
\b 15.3 Conditionnelle \b0\par
\par
{\f1     %IF DEBUG = 1 %THEN}\par
{\f1        %DO;}\par
{\f1           PUT LIST('Mode debug');}\par
{\f1        %END;}\par
{\f1     %ELSE}\par
{\f1        %DO;}\par
{\f1           /* version production */}\par
{\f1        %END;}\par
\par
\par
\b 15.4 Iteration et procedures macro \b0\par
\par
{\f1     %DO I = 1 TO 5;}\par
{\f1        PUT LIST('Iteration', I);}\par
{\f1     %END;}\par
\par
{\f1     %PROCEDURE GENERATE_FIELD(NAME, TYPE);}\par
{\f1        DECLARE NAME TYPE;}\par
{\f1     %END GENERATE_FIELD;}\par
\par
\par
