{\footnote # IDH_PLI_06}
{\footnote $ PL/I - Declarations de variables}
{\footnote K PL/I DECLARE DCL;attributs;declarations factorisees;niveaux 1 2 3;INITIAL;LIKE;ALIGNED}
\b\fs24 Declarations de variables \b0\fs20\par
\par
\par
\b 6.1 Syntaxe DECLARE \b0\par
\par
{\f1   L instruction DECLARE (ou DCL) declare une ou plusieurs variables avec}\par
{\f1   leurs attributs :}\par
\par
{\f1     DECLARE I              FIXED BINARY(31);}\par
{\f1     DECLARE NOM            CHARACTER(40) VARYING INITIAL('');}\par
{\f1     DECLARE (X, Y, Z)      FLOAT BINARY(53);}\par
{\f1     DECLARE PRIX           FIXED DECIMAL(7,2) INITIAL(99.95);}\par
{\f1     DECLARE TABLEAU(1:100) FIXED BINARY(31);}\par
\par
{\f1   Les attributs peuvent inclure :}\par
\par
{\f1     - Type        : FIXED, FLOAT, CHARACTER, BIT, POINTER...}\par
{\f1     - Precision   : (p), (p,q)}\par
{\f1     - Base        : BINARY ou DECIMAL}\par
{\f1     - Echelle     : FIXED ou FLOAT}\par
{\f1     - Longueur    : (n) pour CHAR et BIT}\par
{\f1     - VARYING     : longueur variable}\par
{\f1     - Stockage    : AUTOMATIC, STATIC, EXTERNAL, BASED, CONTROLLED}\par
{\f1     - Portee      : INTERNAL ou EXTERNAL}\par
{\f1     - Initialisation : INITIAL(valeur)}\par
{\f1     - Alignement  : ALIGNED ou UNALIGNED}\par
\par
\par
\b 6.2 Declarations factorisees \b0\par
\par
{\f1   Plusieurs variables avec attributs partages :}\par
\par
{\f1     DECLARE 1 PERSONNE,}\par
{\f1               2 NOM       CHARACTER(40) VARYING,}\par
{\f1               2 PRENOM    CHARACTER(40) VARYING,}\par
{\f1               2 AGE       FIXED BINARY(15),}\par
{\f1               2 ADRESSE,}\par
{\f1                 3 RUE     CHARACTER(60) VARYING,}\par
{\f1                 3 VILLE   CHARACTER(40) VARYING,}\par
{\f1                 3 CP      CHARACTER(10);}\par
\par
{\f1   Les niveaux 1, 2, 3 indiquent l imbrication, similaire a COBOL.}\par
\par
\par
\b 6.3 Initialisation \b0\par
\par
{\f1     DECLARE I FIXED BINARY(31) INITIAL(0);}\par
{\f1     DECLARE PI FLOAT DECIMAL(15) INITIAL(3.141592653589793);}\par
{\f1     DECLARE NOM CHARACTER(20) INITIAL('INCONNU');}\par
{\f1     DECLARE T(10) FIXED BINARY(31) INITIAL((10)0);     /* tous a 0 */}\par
{\f1     DECLARE LISTE(5) FIXED BINARY(31) INITIAL(1,2,3,4,5);}\par
\par
\par
\b 6.4 LIKE : copie d attributs \b0\par
\par
{\f1     DECLARE 1 EMPLOYE LIKE PERSONNE,}\par
{\f1               2 SALAIRE FIXED DECIMAL(9,2);}\par
\par
{\f1   EMPLOYE herite de tous les sous-elements de PERSONNE, plus ajoute}\par
{\f1   SALAIRE.}\par
\par
\par
{\uldb << Precedent}{\v IDH_PLI_05}     {\uldb Suivant >>}{\v IDH_PLI_07}     {\uldb Table des matieres}{\v IDH_PLI_01}     {\uldb Retour aux langages}{\v IDH_LANGAGES}\par
\page

{\footnote # IDH_PLI_07}
{\footnote $ PL/I - Classes de stockage}
{\footnote K PL/I classes stockage;AUTOMATIC;STATIC;EXTERNAL;BASED;CONTROLLED;ALLOCATE FREE;pile heap}
\b\fs24 Classes de stockage \b0\fs20\par
\par
{\f1   PL/I propose plusieurs classes de stockage definissant la duree de vie}\par
{\f1   et le mode d allocation d une variable.}\par
\par
\par
\b 7.1 AUTOMATIC (defaut dans une procedure) \b0\par
\par
{\f1   Allouee a l entree de la procedure, liberee a la sortie. Sur la pile.}\par
\par
{\f1     DECLARE I FIXED BINARY(31) AUTOMATIC;}\par
\par
{\f1   C est le comportement par defaut pour les variables locales.}\par
\par
\par
\b 7.2 STATIC \b0\par
\par
{\f1   Allouee une seule fois au demarrage du programme. Conserve sa valeur}\par
{\f1   entre les appels de la procedure.}\par
\par
{\f1     DECLARE COMPTEUR FIXED BINARY(31) STATIC INITIAL(0);}\par
\par
\par
\b 7.3 EXTERNAL \b0\par
\par
{\f1   Variable partagee entre plusieurs unites de compilation. Equivalent du}\par
{\f1   "extern" du C.}\par
\par
{\f1     DECLARE GLOBAL_VAR FIXED BINARY(31) EXTERNAL STATIC;}\par
\par
\par
\b 7.4 BASED \b0\par
\par
{\f1   Variable accessible via un pointeur. N a pas de stockage propre :}\par
\par
{\f1     DECLARE PTR POINTER;}\par
{\f1     DECLARE X FIXED BINARY(31) BASED(PTR);}\par
\par
{\f1     ALLOCATE X;          /* alloue dynamiquement */}\par
{\f1     X = 42;              /* equivaut a PTR -> X = 42 */}\par
{\f1     FREE X;}\par
\par
\par
\b 7.5 CONTROLLED \b0\par
\par
{\f1   Pile dynamique de variables : chaque ALLOCATE empile une nouvelle}\par
{\f1   occurrence, chaque FREE depile.}\par
\par
{\f1     DECLARE STACK_VAR FIXED BINARY(31) CONTROLLED;}\par
\par
{\f1     ALLOCATE STACK_VAR; STACK_VAR = 1;}\par
{\f1     ALLOCATE STACK_VAR; STACK_VAR = 2;}\par
{\f1     PUT LIST(STACK_VAR);     /* 2 */}\par
{\f1     FREE STACK_VAR;}\par
{\f1     PUT LIST(STACK_VAR);     /* 1 */}\par
\par
\par
