{\footnote # IDH_PLI_04}
{\footnote $ PL/I - Lexique et conventions}
{\footnote K PL/I lexique;identificateurs;mots-cles non reserves;constantes numeriques;constantes binaires B;chaines apostrophes;chaines bits}
\b\fs24 Lexique et conventions \b0\fs20\par
\par
\par
\b 4.1 Identificateurs \b0\par
\par
{\f1   Un identificateur PL/I commence par une lettre (A-Z) et peut contenir}\par
{\f1   des lettres, chiffres (0-9) et le caractere "_" (souligne). La longueur}\par
{\f1   maximale depend de l implementation (31 caracteres pour PL/I optimizing,}\par
{\f1   100 pour Enterprise PL/I). PL/I est insensible a la casse : "Compteur"}\par
{\f1   et "COMPTEUR" sont identiques.}\par
\par
{\f1   Exemples valides :}\par
{\f1     I, X, COMPTEUR, NOM_FICHIER, MA_VARIABLE_2}\par
\par
\par
\b 4.2 Mots-cles \b0\par
\par
{\f1   Particularite : PL/I n a pas de mots reserves. Tous les mots-cles}\par
{\f1   (PROCEDURE, END, IF...) peuvent etre utilises comme identificateurs si}\par
{\f1   le contexte permet de les distinguer. En pratique on evite de le faire}\par
{\f1   pour la lisibilite.}\par
\par
{\f1   Mots-cles principaux :}\par
\par
{\f1     PROCEDURE  END        BEGIN      CALL       RETURN     RETURNS}\par
{\f1     DECLARE    DCL        IF         THEN       ELSE       DO}\par
{\f1     WHILE      UNTIL      TO         BY         BY         LEAVE}\par
{\f1     ITERATE    GOTO       GO         SELECT     WHEN       OTHERWISE}\par
{\f1     PUT        GET        LIST       EDIT       SKIP       PAGE}\par
{\f1     OPEN       CLOSE      READ       WRITE      REWRITE    DELETE}\par
{\f1     FIXED      FLOAT      BINARY     DECIMAL    CHARACTER  CHAR}\par
{\f1     BIT        VARYING    PICTURE    PIC        ENTRY      LABEL}\par
{\f1     POINTER    PTR        OFFSET     STATIC     AUTOMATIC  AUTO}\par
{\f1     BASED      CONTROLLED CTL        EXTERNAL   EXT        INTERNAL}\par
{\f1     ALLOCATE   ALLOC      FREE       NULL       ADDR}\par
{\f1     ON         REVERT     SIGNAL     CONDITION  OVERFLOW   ZERODIVIDE}\par
{\f1     ENDFILE    UNDEFINEDFILE         ERROR      FINISH}\par
{\f1     INITIAL    INIT       LIKE       UNION      LIKE       ALIGNED}\par
\par
\par
\b 4.3 Constantes \b0\par
\par
{\f1   Numeriques entieres :}\par
{\f1     123        /* FIXED DECIMAL */}\par
{\f1     -45        /* FIXED DECIMAL signe */}\par
{\f1     +0}\par
{\f1     1234.56    /* FIXED DECIMAL avec partie fractionnaire */}\par
\par
{\f1   Numeriques binaires :}\par
{\f1     101B       /* FIXED BINARY 5 */}\par
{\f1     1110B}\par
{\f1     0B}\par
{\f1     11.01B     /* FIXED BINARY avec fraction */}\par
\par
{\f1   Numeriques en virgule flottante :}\par
{\f1     1.5E10     /* FLOAT DECIMAL */}\par
{\f1     -2.3E-5}\par
{\f1     1.0E0}\par
{\f1     1.0E10B    /* FLOAT BINARY (suffixe B) */}\par
\par
{\f1   Chaines de caracteres :}\par
{\f1     'BONJOUR'                /* CHARACTER(7) */}\par
{\f1     'L''ETOILE'              /* apostrophe double pour echappement */}\par
{\f1     'A'                      /* CHARACTER(1) */}\par
{\f1     (3)'AB'                  /* repetition : 'ABABAB' */}\par
\par
{\f1   Chaines de bits :}\par
{\f1     '1010'B                  /* BIT(4) */}\par
{\f1     '01'B}\par
{\f1     ''B                      /* BIT(0) chaine vide */}\par
{\f1     'F'B4                    /* hexadecimal sur 4 bits : 1111 */}\par
{\f1     'FF'BX                   /* hexadecimal : 11111111 */}\par
\par
\par
