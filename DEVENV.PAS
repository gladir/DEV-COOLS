  TC_NORMAL,            { texte normal                            }
  TC_KEYWORD,           { mot-cle du langage                      }
  TC_STRING,            { chaine de caracteres                    }
  TC_CHAR,              { caractere litteral                      }
  TC_NUMBER,            { nombre (entier, flottant, hex, etc.)    }
