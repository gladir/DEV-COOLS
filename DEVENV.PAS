{ --- Initialisation des options --- }

Procedure InitOptions(Var Opts: TDevEnvOptions);
Begin
 Opts.SolutionFile    := '';
 Opts.SourceFile      := '';
 Opts.Verbose         := False;
 Opts.DebugMode       := False;
 Opts.ThemeName       := 'Default';
 Opts.FontSize        := 8;
 Opts.TabSize         := 4;
 Opts.AutoSave        := False;
 Opts.ShowLineNumbers := True;
 Opts.WordWrap        := False;
 Opts.AutoIndent      := True;
 Opts.ShowWhitespace  := False;
 Opts.EmuMode         := False;
 Opts.EmuTarget       := '';
 Opts.EmuFile         := '';
 Opts.EmuArgs         := '';
 Opts.DiskImg0        := '';
 Opts.DiskImg1        := '';
End;

{ --- Analyse de la ligne de commande --- }

Procedure ParseCommandLine(Var Opts: TDevEnvOptions);
Var
 I, K: Integer;
 Arg, Ext, EmuArg, EmuName, EmuFn, EmuUp: String;
Begin
 For I := 1 To ParamCount Do Begin
  Arg := ParamStr(I);
  If (Arg = '-h') Or (Arg = '--help') Or (Arg = '-?') Or
     (Arg = '/?') Then
   ShowHelp
  Else If (Arg = '-v') Or (Arg = '-V') Then
   Opts.Verbose := True
  Else If (Arg = '-d') Or (Arg = '-D') Then
   Opts.DebugMode := True
  Else If (Length(Arg) >= 5) And
          ((Copy(Arg, 1, 5) = '-emu:') Or (Copy(Arg, 1, 5) = '-EMU:') Or
           (Copy(Arg, 1, 5) = '-Emu:')) Then Begin
   { -emu:XXX,fichier[,arg1[,arg2...]] : split sur les virgules }
   EmuArg := Copy(Arg, 6, Length(Arg) - 5);
   K := Pos(',', EmuArg);
   If K <= 0 Then
    FatalError('Syntaxe -emu attendue : -emu:XXX,fichier (ex: -emu:NES,prog.nes)');
   EmuName := Copy(EmuArg, 1, K - 1);
   EmuFn   := Copy(EmuArg, K + 1, Length(EmuArg) - K);
   { Extraire les arguments supplementaires apres la deuxieme virgule }
   K := Pos(',', EmuFn);
   If K > 0 Then Begin
    Opts.EmuArgs := Copy(EmuFn, K + 1, Length(EmuFn) - K);
    EmuFn := Copy(EmuFn, 1, K - 1);
    { Remplacer les virgules restantes par des espaces dans la cmdline }
    For K := 1 To Length(Opts.EmuArgs) Do
     If Opts.EmuArgs[K] = ',' Then Opts.EmuArgs[K] := ' ';
   End;
   If (EmuName = '') Or (EmuFn = '') Then
    FatalError('Syntaxe -emu invalide : ' + Arg);
   EmuUp := UpCaseStr(EmuName);
   { Mapper le nom court vers le flag TargetCPU attendu par ShowEmulatorPanel }
   If      EmuUp = 'NES'       Then Opts.EmuTarget := '-CNES'
   Else If EmuUp = 'AMIGA'     Then Opts.EmuTarget := '-CAMIGA'
   Else If EmuUp = 'ATARIST'   Then Opts.EmuTarget := '-CATARIST'
   Else If EmuUp = '68000'     Then Opts.EmuTarget := '-C68000'
   Else If EmuUp = 'C64'       Then Opts.EmuTarget := '-CC64'
   Else If EmuUp = 'APPLEII'   Then Opts.EmuTarget := '-CAPPLEII'
   Else If EmuUp = 'ATARI400'  Then Opts.EmuTarget := '-CATARI400'
   Else If EmuUp = 'ATARI800'  Then Opts.EmuTarget := '-CATARI800'
   Else If EmuUp = 'ATARI2600' Then Opts.EmuTarget := '-CATARI2600'
   Else If EmuUp = 'MSX'       Then Opts.EmuTarget := '-CMSX'
   Else If EmuUp = 'TRS80'     Then Opts.EmuTarget := '-CTRS80'
   Else If EmuUp = 'ADAM'      Then Opts.EmuTarget := '-CADAM'
   Else If EmuUp = 'COCO3'     Then Opts.EmuTarget := '-CCOCO3'
   Else If EmuUp = 'DRAGON32'  Then Opts.EmuTarget := '-CDRAGON32'
   Else If EmuUp = 'DRAGON64'  Then Opts.EmuTarget := '-CDRAGON64'
   Else If EmuUp = 'TO7'       Then Opts.EmuTarget := '-CTO7'
   Else If EmuUp = 'TO8'       Then Opts.EmuTarget := '-CTO8'
   Else If EmuUp = 'MO5'       Then Opts.EmuTarget := '-CMO5'
   Else If EmuUp = 'CRAY1'     Then Opts.EmuTarget := '-CCRAY1'
   Else If EmuUp = 'D'         Then Opts.EmuTarget := '-CD'
   Else If EmuUp = 'P'         Then Opts.EmuTarget := '-CP'
   Else If (EmuUp = 'DOS') Or (EmuUp = 'DOS16') Or
           (EmuUp = 'MSDOS') Or (EmuUp = 'PCDOS') Or
           (EmuUp = '8086') Then Opts.EmuTarget := '-CD'
   Else If (EmuUp = 'DOSP') Or (EmuUp = 'DOS286') Or
           (EmuUp = '80286') Then Opts.EmuTarget := '-CP'
   Else If (Length(EmuName) > 0) And (EmuName[1] = '-') Then
    Opts.EmuTarget := EmuName  { deja un flag complet }
   Else
    FatalError('Cible emulateur inconnue : ' + EmuName);
   If Not FileExists(EmuFn) Then
    FatalError('Fichier introuvable: ' + EmuFn);
   Opts.EmuFile := EmuFn;
   Opts.EmuMode := True;
  End
  Else If (Length(Arg) >= 7) And
          ((Copy(Arg, 1, 7) = '/DISK0:') Or (Copy(Arg, 1, 7) = '/disk0:') Or
           (Copy(Arg, 1, 7) = '-DISK0:') Or (Copy(Arg, 1, 7) = '-disk0:') Or
           (Copy(Arg, 1, 7) = '/Disk0:') Or (Copy(Arg, 1, 7) = '-Disk0:')) Then Begin
   EmuFn := Copy(Arg, 8, Length(Arg) - 7);
   If EmuFn = '' Then
    FatalError('Syntaxe /DISK0 attendue : /DISK0:fichier.img');
   If Not FileExists(EmuFn) Then
    FatalError('Image disque introuvable: ' + EmuFn);
   Opts.DiskImg0 := EmuFn;
  End
  Else If (Length(Arg) >= 7) And
          ((Copy(Arg, 1, 7) = '/DISK1:') Or (Copy(Arg, 1, 7) = '/disk1:') Or
           (Copy(Arg, 1, 7) = '-DISK1:') Or (Copy(Arg, 1, 7) = '-disk1:') Or
           (Copy(Arg, 1, 7) = '/Disk1:') Or (Copy(Arg, 1, 7) = '-Disk1:')) Then Begin
   EmuFn := Copy(Arg, 8, Length(Arg) - 7);
   If EmuFn = '' Then
    FatalError('Syntaxe /DISK1 attendue : /DISK1:fichier.img');
   If Not FileExists(EmuFn) Then
    FatalError('Image disque introuvable: ' + EmuFn);
   Opts.DiskImg1 := EmuFn;
  End
  Else If (Length(Arg) > 0) And (Arg[1] = '-') Then
   FatalError('Option inconnue: ' + Arg)
  Else Begin
   { Argument sans tiret : fichier solution ou fichier source }
   If (Opts.SolutionFile = '') And (Opts.SourceFile = '') Then Begin
    Ext := UpCaseStr(ExtractFileExt(Arg));
    If Ext = '.SLN' Then Begin
     If Not FileExists(Arg) Then
      FatalError('Fichier introuvable: ' + Arg);
     Opts.SolutionFile := Arg;
    End Else If (Ext = '.PAS') Or (Ext = '.CS')   Or (Ext = '.VB')   Or
                (Ext = '.C')   Or (Ext = '.CPP')  Or (Ext = '.H')    Or
                (Ext = '.HPP') Or (Ext = '.JAVA') Or (Ext = '.JS')   Or
                (Ext = '.TS')  Or (Ext = '.PY')   Or (Ext = '.RB')   Or
                (Ext = '.PHP') Or (Ext = '.XML')  Or (Ext = '.HTM')  Or
                (Ext = '.HTML')Or (Ext = '.CSS')  Or (Ext = '.SQL')  Or
                (Ext = '.ASM') Or (Ext = '.INC')  Or (Ext = '.TXT')  Or
                (Ext = '.ADB') Or (Ext = '.ADS')  Or (Ext = '.ADA')  Or
                (Ext = '.ABAP')Or (Ext = '.ABP')  Or
                (Ext = '.PSP') Or (Ext = '.AWK')  Then Begin
     If Not FileExists(Arg) Then
      FatalError('Fichier introuvable: ' + Arg);
     Opts.SourceFile := Arg;
    End Else
     FatalError('Format de fichier non reconnu: ' + Arg);
   End Else
    FatalError('Fichier deja specifie: ' + Arg);
  End;
 End;
End;

