{ --- Verifier si un mot est un tag XML connu --- }

Function IsXMLKnownTag(Var HL: TXMLHighlighter;
                        Word: String): Boolean;
Var
 I: Integer;
 LW: String;
Begin
 IsXMLKnownTag := False;
 LW := LowerCaseStr(Word);
 For I := 0 To HL.TagCount - 1 Do
 Begin
  If LW = HL.Tags[I] Then
  Begin
   IsXMLKnownTag := True;
   Exit;
  End;
 End;
End;

{ --- Verifier si un caractere est un delimiteur XML --- }

Function IsXMLDelimiter(Ch: Char): Boolean;
Begin
 IsXMLDelimiter :=
  (Ch = '<') Or (Ch = '>') Or (Ch = '/') Or
  (Ch = '=') Or (Ch = ' ') Or (Ch = #9) Or
  (Ch = '"') Or (Ch = '''');
End;

{ --- Obtenir la classe de jeton XML a une position --- }

Function GetXMLTokenClass(Var HL: TXMLHighlighter;
                          Line: String;
                          Var Pos: Integer): TTokenClass;
Var
 Len: Integer;
 StartPos: Integer;
 TagName: String;
Begin
 Len := Length(Line);
 GetXMLTokenClass := TC_NORMAL;
 If Pos > Len Then
 Begin
  Inc(Pos);
  Exit;
 End;

 { Commentaire XML <!-- ... --> }
 If HL.Base.InBlockComment Then
 Begin
  GetXMLTokenClass := TC_COMMENT;
  While Pos <= Len Do
  Begin
   If (Pos + 2 <= Len) And (Line[Pos] = '-') And
      (Line[Pos + 1] = '-') And (Line[Pos + 2] = '>') Then
   Begin
    Inc(Pos, 3);
    HL.Base.InBlockComment := False;
    Exit;
   End;
   Inc(Pos);
  End;
  Exit;
 End;

 { Debut de commentaire <!-- }
 If (Pos + 3 <= Len) And (Line[Pos] = '<') And
    (Line[Pos + 1] = '!') And (Line[Pos + 2] = '-') And
    (Line[Pos + 3] = '-') Then
 Begin
  GetXMLTokenClass := TC_COMMENT;
  Inc(Pos, 4);
  While Pos <= Len Do
  Begin
   If (Pos + 2 <= Len) And (Line[Pos] = '-') And
      (Line[Pos + 1] = '-') And (Line[Pos + 2] = '>') Then
   Begin
    Inc(Pos, 3);
    Exit;
   End;
   Inc(Pos);
  End;
  HL.Base.InBlockComment := True;
  Exit;
 End;

 { Declaration XML <?...?> }
 If (Pos + 1 <= Len) And (Line[Pos] = '<') And
    (Line[Pos + 1] = '?') Then
 Begin
  GetXMLTokenClass := TC_PREPROCESSOR;
  Inc(Pos, 2);
  While Pos <= Len Do
  Begin
   If (Pos + 1 <= Len) And (Line[Pos] = '?') And
      (Line[Pos + 1] = '>') Then
   Begin
    Inc(Pos, 2);
    Exit;
   End;
   Inc(Pos);
  End;
  Exit;
 End;

 { CDATA <![CDATA[...]]> }
 If (Pos + 8 <= Len) And (Line[Pos] = '<') And
    (Line[Pos + 1] = '!') And (Line[Pos + 2] = '[') And
    (Line[Pos + 3] = 'C') And (Line[Pos + 4] = 'D') And
    (Line[Pos + 5] = 'A') And (Line[Pos + 6] = 'T') And
    (Line[Pos + 7] = 'A') And (Line[Pos + 8] = '[') Then
 Begin
  GetXMLTokenClass := TC_STRING;
  Inc(Pos, 9);
  While Pos <= Len Do
  Begin
   If (Pos + 2 <= Len) And (Line[Pos] = ']') And
      (Line[Pos + 1] = ']') And (Line[Pos + 2] = '>') Then
   Begin
    Inc(Pos, 3);
    Exit;
   End;
   Inc(Pos);
  End;
  Exit;
 End;

 { Tag de fermeture </tag> ou tag d ouverture <tag...> }
 If Line[Pos] = '<' Then
 Begin
  StartPos := Pos;
  Inc(Pos);
  { Tag de fermeture </ }
  If (Pos <= Len) And (Line[Pos] = '/') Then
   Inc(Pos);
  { DOCTYPE <!DOCTYPE...> }
  If (Pos <= Len) And (Line[Pos] = '!') Then
  Begin
   GetXMLTokenClass := TC_PREPROCESSOR;
   While (Pos <= Len) And (Line[Pos] <> '>') Do
    Inc(Pos);
   If Pos <= Len Then
    Inc(Pos);
   Exit;
  End;
  { Lire le nom du tag }
  TagName := '';
  While (Pos <= Len) And Not IsXMLDelimiter(Line[Pos]) Do
  Begin
   TagName := TagName + Line[Pos];
   Inc(Pos);
  End;
  If IsXMLKnownTag(HL, TagName) Then
   GetXMLTokenClass := TC_KEYWORD
  Else
   GetXMLTokenClass := TC_TYPE;
  Exit;
 End;

 { Fermeture de tag > ou /> }
 If (Line[Pos] = '>') Or
    ((Line[Pos] = '/') And (Pos + 1 <= Len) And
     (Line[Pos + 1] = '>')) Then
 Begin
  GetXMLTokenClass := TC_OPERATOR;
  If Line[Pos] = '/' Then
   Inc(Pos, 2)
  Else
   Inc(Pos);
  Exit;
 End;

 { Chaine double-quote "..." }
 If Line[Pos] = '"' Then
 Begin
  GetXMLTokenClass := TC_STRING;
  Inc(Pos);
  While (Pos <= Len) And (Line[Pos] <> '"') Do
   Inc(Pos);
  If Pos <= Len Then
   Inc(Pos);
  Exit;
 End;

 { Chaine single-quote '...' }
 If Line[Pos] = '''' Then
 Begin
  GetXMLTokenClass := TC_STRING;
  Inc(Pos);
  While (Pos <= Len) And (Line[Pos] <> '''') Do
   Inc(Pos);
  If Pos <= Len Then
   Inc(Pos);
  Exit;
 End;

 { Entite &amp; &lt; &gt; etc. }
 If Line[Pos] = '&' Then
 Begin
  GetXMLTokenClass := TC_DIRECTIVE;
  Inc(Pos);
  While (Pos <= Len) And (Line[Pos] <> ';') And
        (Line[Pos] <> ' ') And (Line[Pos] <> '<') Do
   Inc(Pos);
  If (Pos <= Len) And (Line[Pos] = ';') Then
   Inc(Pos);
  Exit;
 End;

 { Operateur = }
 If Line[Pos] = '=' Then
 Begin
  GetXMLTokenClass := TC_OPERATOR;
  Inc(Pos);
  Exit;
 End;

 { Nom d attribut (identifiant avant =) }
 If ((Line[Pos] >= 'A') And (Line[Pos] <= 'Z')) Or
    ((Line[Pos] >= 'a') And (Line[Pos] <= 'z')) Or
    (Line[Pos] = '_') Then
 Begin
  GetXMLTokenClass := TC_ATTRIBUTE;
  While (Pos <= Len) And
        (((Line[Pos] >= 'A') And (Line[Pos] <= 'Z')) Or
         ((Line[Pos] >= 'a') And (Line[Pos] <= 'z')) Or
         ((Line[Pos] >= '0') And (Line[Pos] <= '9')) Or
         (Line[Pos] = '_') Or (Line[Pos] = '-') Or
         (Line[Pos] = ':') Or (Line[Pos] = '.')) Do
   Inc(Pos);
  Exit;
 End;

 { Texte normal }
 GetXMLTokenClass := TC_NORMAL;
 Inc(Pos);
End;

{ --- Colorier une ligne XML entiere --- }

Procedure HighlightXMLLine(Var HL: TXMLHighlighter;
                           Line: String;
                           Var Colors: Array Of Byte);
Var
 Pos, Start, I, Len: Integer;
 TC: TTokenClass;
 Clr: Byte;
Begin
 Len := Length(Line);
 For I := 0 To Len - 1 Do
  Colors[I] := Byte(TokenClassToColor(TC_NORMAL));

 Pos := 1;
 While Pos <= Len Do
 Begin
  Start := Pos;
  TC := GetXMLTokenClass(HL, Line, Pos);
  Clr := Byte(TokenClassToColor(TC));
  For I := Start To Pos - 1 Do
  Begin
   If (I >= 1) And (I <= Len) Then
    Colors[I - 1] := Clr;
  End;
 End;
End;

{ ============================================================
  COLORATION SYNTAXIQUE JSON
  ============================================================ }

{ --- Colorier une ligne JSON ---
  Tokens reconnus :
    - Chaines entre guillemets (avec echappements) -> TC_STRING
    - Nombres (entiers, flottants, exposants)      -> TC_NUMBER
    - Mots-cles true / false / null                -> TC_KEYWORD
    - Commentaires de ligne (extension JSONC)      -> TC_COMMENT
    - Ponctuation et autres caracteres             -> TC_NORMAL  }

Procedure HighlightJSONLine(Line: String; Var Colors: Array Of Byte);
Var
 Pos, Start, I, Len: Integer;
 ClrNorm, ClrStr, ClrNum, ClrKw, ClrCmt: Byte;
 Ch: Char;
 Word: String;
Begin
 Len := Length(Line);
 ClrNorm := Byte(TokenClassToColor(TC_NORMAL));
 ClrStr  := Byte(TokenClassToColor(TC_STRING));
 ClrNum  := Byte(TokenClassToColor(TC_NUMBER));
 ClrKw   := Byte(TokenClassToColor(TC_KEYWORD));
 ClrCmt  := Byte(TokenClassToColor(TC_COMMENT));
 For I := 0 To Len - 1 Do
  Colors[I] := ClrNorm;

 Pos := 1;
 While Pos <= Len Do
 Begin
  Ch := Line[Pos];
  { Commentaire de ligne // ... (JSONC) }
  If (Ch = '/') And (Pos + 1 <= Len) And (Line[Pos + 1] = '/') Then
  Begin
   For I := Pos To Len Do
    Colors[I - 1] := ClrCmt;
   Exit;
  End;
  { Chaine "..." }
  If Ch = '"' Then
  Begin
   Start := Pos;
   Inc(Pos);
   While Pos <= Len Do
   Begin
    If Line[Pos] = '\' Then
    Begin
     Inc(Pos);
     If Pos <= Len Then Inc(Pos);
    End
    Else If Line[Pos] = '"' Then
    Begin
     Inc(Pos);
     Break;
    End
    Else
     Inc(Pos);
   End;
   For I := Start To Pos - 1 Do
    If (I >= 1) And (I <= Len) Then
     Colors[I - 1] := ClrStr;
   Continue;
  End;
  { Nombre : -? digits (.digits)? ([eE][+-]?digits)? }
  If (Ch In ['0'..'9']) Or
     ((Ch = '-') And (Pos + 1 <= Len) And (Line[Pos + 1] In ['0'..'9'])) Then
  Begin
   Start := Pos;
   If Ch = '-' Then Inc(Pos);
   While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   If (Pos <= Len) And (Line[Pos] = '.') Then
   Begin
    Inc(Pos);
    While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   End;
   If (Pos <= Len) And ((Line[Pos] = 'e') Or (Line[Pos] = 'E')) Then
   Begin
    Inc(Pos);
    If (Pos <= Len) And ((Line[Pos] = '+') Or (Line[Pos] = '-')) Then
     Inc(Pos);
    While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   End;
   For I := Start To Pos - 1 Do
    Colors[I - 1] := ClrNum;
   Continue;
  End;
  { Identifiant -> verifier true / false / null }
  If (Ch In ['a'..'z']) Or (Ch In ['A'..'Z']) Then
  Begin
   Start := Pos;
   Word := '';
   While (Pos <= Len) And
         ((Line[Pos] In ['a'..'z']) Or (Line[Pos] In ['A'..'Z'])) Do
   Begin
    Word := Word + Line[Pos];
    Inc(Pos);
   End;
   If (Word = 'true') Or (Word = 'false') Or (Word = 'null') Then
    For I := Start To Pos - 1 Do
     Colors[I - 1] := ClrKw;
   Continue;
  End;
  Inc(Pos);
 End;
End;

{ ============================================================
  COLORATION SYNTAXIQUE YAML / YML
  ============================================================ }

{ --- Colorier une ligne YAML ---
  Tokens reconnus :
    - Commentaires # ...                          -> TC_COMMENT
    - Cle suivie de ':' (debut de ligne ou tiret) -> TC_KEYWORD
    - Chaines '...' et "..."                      -> TC_STRING
    - Nombres (entiers, flottants, exposants)     -> TC_NUMBER
    - Mots-cles true/false/null/yes/no/on/off/~   -> TC_KEYWORD
    - Tiret de liste '- ', ancres &/*, tags !     -> TC_DIRECTIVE
    - Ponctuation et reste                        -> TC_NORMAL  }

Procedure HighlightYAMLLine(Line: String; Var Colors: Array Of Byte);
Var
 Pos, Start, I, Len, KeyEnd, FirstNonBlank: Integer;
 ClrNorm, ClrStr, ClrNum, ClrKw, ClrCmt, ClrDir: Byte;
 Ch, Quote: Char;
 Word: String;
Begin
 Len := Length(Line);
 ClrNorm := Byte(TokenClassToColor(TC_NORMAL));
 ClrStr  := Byte(TokenClassToColor(TC_STRING));
 ClrNum  := Byte(TokenClassToColor(TC_NUMBER));
 ClrKw   := Byte(TokenClassToColor(TC_KEYWORD));
 ClrCmt  := Byte(TokenClassToColor(TC_COMMENT));
 ClrDir  := Byte(TokenClassToColor(TC_DIRECTIVE));
 For I := 0 To Len - 1 Do
  Colors[I] := ClrNorm;

 { Reperer le premier caractere non blanc. }
 FirstNonBlank := 0;
 Pos := 1;
 While (Pos <= Len) And ((Line[Pos] = ' ') Or (Line[Pos] = #9)) Do
  Inc(Pos);
 FirstNonBlank := Pos;

 { Directive YAML en debut de ligne (--- , ... , %YAML ...). }
 If (FirstNonBlank <= Len) And
    (((FirstNonBlank + 2 <= Len) And
      (Line[FirstNonBlank] = '-') And
      (Line[FirstNonBlank + 1] = '-') And
      (Line[FirstNonBlank + 2] = '-')) Or
     ((FirstNonBlank + 2 <= Len) And
      (Line[FirstNonBlank] = '.') And
      (Line[FirstNonBlank + 1] = '.') And
      (Line[FirstNonBlank + 2] = '.')) Or
     (Line[FirstNonBlank] = '%')) Then
 Begin
  For I := FirstNonBlank To Len Do
   Colors[I - 1] := ClrDir;
  Exit;
 End;

 { Tiret de liste '- ' au debut. }
 If (FirstNonBlank <= Len) And (Line[FirstNonBlank] = '-') And
    ((FirstNonBlank = Len) Or (Line[FirstNonBlank + 1] = ' ')) Then
 Begin
  Colors[FirstNonBlank - 1] := ClrDir;
  Pos := FirstNonBlank + 1;
 End
 Else
  Pos := FirstNonBlank;

 { Cle: tout ce qui precede ':' (suivi d'espace/fin) avant un # ou une chaine. }
 Start := Pos;
 KeyEnd := -1;
 I := Pos;
 While I <= Len Do
 Begin
  Ch := Line[I];
  If (Ch = '#') Or (Ch = '"') Or (Ch = '''') Then Break;
  If Ch = ':' Then
  Begin
   If (I = Len) Or (Line[I + 1] = ' ') Or (Line[I + 1] = #9) Then
   Begin
    KeyEnd := I - 1;
    Break;
   End;
  End;
  Inc(I);
 End;
 If (KeyEnd >= Start) Then
 Begin
  For I := Start To KeyEnd Do
   Colors[I - 1] := ClrKw;
  Pos := KeyEnd + 1;
 End;

 { Tokeniser le reste : commentaires, chaines, nombres, mots-cles. }
 While Pos <= Len Do
 Begin
  Ch := Line[Pos];
  { Commentaire #... (precede d'un espace ou debut). }
  If (Ch = '#') And ((Pos = 1) Or (Line[Pos - 1] = ' ') Or
                     (Line[Pos - 1] = #9)) Then
  Begin
   For I := Pos To Len Do
    Colors[I - 1] := ClrCmt;
   Exit;
  End;
  { Chaine entre quotes simples ou doubles. }
  If (Ch = '"') Or (Ch = '''') Then
  Begin
   Quote := Ch;
   Start := Pos;
   Inc(Pos);
   While Pos <= Len Do
   Begin
    If (Quote = '"') And (Line[Pos] = '\') Then
    Begin
     Inc(Pos);
     If Pos <= Len Then Inc(Pos);
    End
    Else If Line[Pos] = Quote Then
    Begin
     Inc(Pos);
     Break;
    End
    Else
     Inc(Pos);
   End;
   For I := Start To Pos - 1 Do
    Colors[I - 1] := ClrStr;
   Continue;
  End;
  { Ancre &name ou alias *name ou tag !name. }
  If ((Ch = '&') Or (Ch = '*') Or (Ch = '!')) And
     (Pos + 1 <= Len) And
     ((Line[Pos + 1] In ['a'..'z']) Or (Line[Pos + 1] In ['A'..'Z']) Or
      (Line[Pos + 1] = '_')) Then
  Begin
   Start := Pos;
   Inc(Pos);
   While (Pos <= Len) And
         ((Line[Pos] In ['a'..'z']) Or (Line[Pos] In ['A'..'Z']) Or
          (Line[Pos] In ['0'..'9']) Or (Line[Pos] = '_') Or
          (Line[Pos] = '-')) Do
    Inc(Pos);
   For I := Start To Pos - 1 Do
    Colors[I - 1] := ClrDir;
   Continue;
  End;
  { Nombre. }
  If (Ch In ['0'..'9']) Or
     ((Ch = '-') And (Pos + 1 <= Len) And (Line[Pos + 1] In ['0'..'9'])) Then
  Begin
   Start := Pos;
   If Ch = '-' Then Inc(Pos);
   While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   If (Pos <= Len) And (Line[Pos] = '.') Then
   Begin
    Inc(Pos);
    While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   End;
   If (Pos <= Len) And ((Line[Pos] = 'e') Or (Line[Pos] = 'E')) Then
   Begin
    Inc(Pos);
    If (Pos <= Len) And ((Line[Pos] = '+') Or (Line[Pos] = '-')) Then
     Inc(Pos);
    While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   End;
   For I := Start To Pos - 1 Do
    Colors[I - 1] := ClrNum;
   Continue;
  End;
  { Mot -> mots-cles YAML. }
  If (Ch In ['a'..'z']) Or (Ch In ['A'..'Z']) Or (Ch = '~') Then
  Begin
   Start := Pos;
   Word := '';
   If Ch = '~' Then
   Begin
    Word := '~';
    Inc(Pos);
   End
   Else
    While (Pos <= Len) And
          ((Line[Pos] In ['a'..'z']) Or (Line[Pos] In ['A'..'Z'])) Do
    Begin
     Word := Word + Line[Pos];
     Inc(Pos);
    End;
   If (LowerCaseStr(Word) = 'true')  Or (LowerCaseStr(Word) = 'false') Or
      (LowerCaseStr(Word) = 'null')  Or (Word = '~') Or
      (LowerCaseStr(Word) = 'yes')   Or (LowerCaseStr(Word) = 'no') Or
      (LowerCaseStr(Word) = 'on')    Or (LowerCaseStr(Word) = 'off') Then
    For I := Start To Pos - 1 Do
     Colors[I - 1] := ClrKw;
   Continue;
  End;
  Inc(Pos);
 End;
End;

{ ============================================================
  COLORATION SYNTAXIQUE SQL
  ============================================================ }

{ Verifier si Word (deja en majuscules) est un mot-cle SQL. }

Function IsSQLKeyword(Word: String): Boolean;
Begin
 IsSQLKeyword :=
  (Word = 'SELECT')   Or (Word = 'FROM')      Or (Word = 'WHERE')   Or
  (Word = 'INSERT')   Or (Word = 'UPDATE')    Or (Word = 'DELETE')  Or
  (Word = 'CREATE')   Or (Word = 'TABLE')     Or (Word = 'DROP')    Or
  (Word = 'ALTER')    Or (Word = 'INDEX')     Or (Word = 'VIEW')    Or
  (Word = 'JOIN')     Or (Word = 'LEFT')      Or (Word = 'RIGHT')   Or
  (Word = 'INNER')    Or (Word = 'OUTER')     Or (Word = 'CROSS')   Or
  (Word = 'FULL')     Or (Word = 'ON')        Or (Word = 'AS')      Or
  (Word = 'AND')      Or (Word = 'OR')        Or (Word = 'NOT')     Or
  (Word = 'NULL')     Or (Word = 'IS')        Or (Word = 'IN')      Or
  (Word = 'LIKE')     Or (Word = 'BETWEEN')   Or (Word = 'EXISTS')  Or
  (Word = 'ORDER')    Or (Word = 'BY')        Or (Word = 'GROUP')   Or
  (Word = 'HAVING')   Or (Word = 'UNION')     Or (Word = 'ALL')     Or
  (Word = 'DISTINCT') Or (Word = 'INTO')      Or (Word = 'VALUES')  Or
  (Word = 'SET')      Or (Word = 'PRIMARY')   Or (Word = 'KEY')     Or
  (Word = 'FOREIGN')  Or (Word = 'REFERENCES')Or (Word = 'CONSTRAINT') Or
  (Word = 'DEFAULT')  Or (Word = 'CHECK')     Or (Word = 'UNIQUE')  Or
  (Word = 'CASE')     Or (Word = 'WHEN')      Or (Word = 'THEN')    Or
  (Word = 'ELSE')     Or (Word = 'END')       Or (Word = 'IF')      Or
  (Word = 'BEGIN')    Or (Word = 'COMMIT')    Or (Word = 'ROLLBACK')Or
  (Word = 'TRANSACTION') Or (Word = 'GRANT')  Or (Word = 'REVOKE')  Or
  (Word = 'TRUE')     Or (Word = 'FALSE')     Or (Word = 'ASC')     Or
  (Word = 'DESC')     Or (Word = 'LIMIT')     Or (Word = 'OFFSET')  Or
  (Word = 'TOP')      Or (Word = 'WITH')      Or (Word = 'RECURSIVE') Or
  (Word = 'EXEC')     Or (Word = 'EXECUTE')   Or (Word = 'PROCEDURE') Or
  (Word = 'FUNCTION') Or (Word = 'TRIGGER')   Or (Word = 'RETURNS') Or
  (Word = 'RETURN')   Or (Word = 'DECLARE')   Or (Word = 'CURSOR')  Or
  (Word = 'FETCH')    Or (Word = 'OPEN')      Or (Word = 'CLOSE')   Or
  (Word = 'WHILE')    Or (Word = 'FOR')       Or (Word = 'LOOP')    Or
  (Word = 'AUTO_INCREMENT') Or (Word = 'IDENTITY') Or (Word = 'TEMP') Or
  (Word = 'TEMPORARY')Or (Word = 'DATABASE')  Or (Word = 'SCHEMA')  Or
  (Word = 'USE')      Or (Word = 'SHOW')      Or (Word = 'DESCRIBE')Or
  (Word = 'TRUNCATE') Or (Word = 'RENAME')    Or (Word = 'ADD')     Or
  (Word = 'COLUMN')   Or (Word = 'MODIFY')    Or (Word = 'CASCADE') Or
  (Word = 'RESTRICT') Or (Word = 'NO')        Or (Word = 'ACTION');
End;

{ Verifier si Word (deja en majuscules) est un type SQL. }

Function IsSQLType(Word: String): Boolean;
Begin
 IsSQLType :=
  (Word = 'INT')      Or (Word = 'INTEGER')  Or (Word = 'SMALLINT') Or
  (Word = 'BIGINT')   Or (Word = 'TINYINT')  Or (Word = 'BIT')      Or
  (Word = 'BOOLEAN')  Or (Word = 'BOOL')     Or (Word = 'VARCHAR')  Or
  (Word = 'CHAR')     Or (Word = 'NVARCHAR') Or (Word = 'NCHAR')    Or
  (Word = 'TEXT')     Or (Word = 'NTEXT')    Or (Word = 'CLOB')     Or
  (Word = 'BLOB')     Or (Word = 'BINARY')   Or (Word = 'VARBINARY')Or
  (Word = 'DATE')     Or (Word = 'TIME')     Or (Word = 'TIMESTAMP')Or
  (Word = 'DATETIME') Or (Word = 'INTERVAL') Or (Word = 'YEAR')     Or
  (Word = 'DECIMAL')  Or (Word = 'NUMERIC')  Or (Word = 'FLOAT')    Or
  (Word = 'REAL')     Or (Word = 'DOUBLE')   Or (Word = 'MONEY')    Or
  (Word = 'SERIAL')   Or (Word = 'UUID')     Or (Word = 'JSON')     Or
  (Word = 'XML');
End;

{ --- Colorier une ligne SQL --- }

Procedure HighlightSQLLine(Line: String; Var Colors: Array Of Byte);
Var
 Pos, Start, I, Len: Integer;
 ClrNorm, ClrStr, ClrNum, ClrKw, ClrCmt, ClrType: Byte;
 Ch: Char;
 Word: String;
Begin
 Len := Length(Line);
 ClrNorm := Byte(TokenClassToColor(TC_NORMAL));
 ClrStr  := Byte(TokenClassToColor(TC_STRING));
 ClrNum  := Byte(TokenClassToColor(TC_NUMBER));
 ClrKw   := Byte(TokenClassToColor(TC_KEYWORD));
 ClrCmt  := Byte(TokenClassToColor(TC_COMMENT));
 ClrType := Byte(TokenClassToColor(TC_DIRECTIVE));
 For I := 0 To Len - 1 Do
  Colors[I] := ClrNorm;

 Pos := 1;
 While Pos <= Len Do
 Begin
  Ch := Line[Pos];
  { Commentaire ligne -- ... }
  If (Ch = '-') And (Pos + 1 <= Len) And (Line[Pos + 1] = '-') Then
  Begin
   For I := Pos To Len Do
    Colors[I - 1] := ClrCmt;
   Exit;
  End;
  { Commentaire bloc /* ... */ (sur la ligne, ferme ou non). }
  If (Ch = '/') And (Pos + 1 <= Len) And (Line[Pos + 1] = '*') Then
  Begin
   Start := Pos;
   Inc(Pos, 2);
   While (Pos + 1 <= Len) And
         Not ((Line[Pos] = '*') And (Line[Pos + 1] = '/')) Do
    Inc(Pos);
   If (Pos + 1 <= Len) And (Line[Pos] = '*') And
      (Line[Pos + 1] = '/') Then
    Inc(Pos, 2)
   Else
    Pos := Len + 1;
   For I := Start To Pos - 1 Do
    If I - 1 < Len Then Colors[I - 1] := ClrCmt;
   Continue;
  End;
  { Chaine 'xxx' (avec '' comme echappement). }
  If Ch = '''' Then
  Begin
   Start := Pos;
   Inc(Pos);
   While Pos <= Len Do
   Begin
    If (Line[Pos] = '''') And (Pos + 1 <= Len) And
       (Line[Pos + 1] = '''') Then
     Inc(Pos, 2)
    Else If Line[Pos] = '''' Then
    Begin
     Inc(Pos);
     Break;
    End
    Else
     Inc(Pos);
   End;
   For I := Start To Pos - 1 Do
    Colors[I - 1] := ClrStr;
   Continue;
  End;
  { Identifiant entre "..." ou `...` ou [...]. }
  If (Ch = '"') Or (Ch = '`') Or (Ch = '[') Then
  Begin
   Start := Pos;
   Inc(Pos);
   While Pos <= Len Do
   Begin
    If (Ch = '[') And (Line[Pos] = ']') Then
    Begin
     Inc(Pos);
     Break;
    End
    Else If (Ch <> '[') And (Line[Pos] = Ch) Then
    Begin
     Inc(Pos);
     Break;
    End
    Else
     Inc(Pos);
   End;
   For I := Start To Pos - 1 Do
    Colors[I - 1] := ClrStr;
   Continue;
  End;
  { Nombre. }
  If (Ch In ['0'..'9']) Then
  Begin
   Start := Pos;
   While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   If (Pos <= Len) And (Line[Pos] = '.') Then
   Begin
    Inc(Pos);
    While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   End;
   If (Pos <= Len) And ((Line[Pos] = 'e') Or (Line[Pos] = 'E')) Then
   Begin
    Inc(Pos);
    If (Pos <= Len) And
       ((Line[Pos] = '+') Or (Line[Pos] = '-')) Then Inc(Pos);
    While (Pos <= Len) And (Line[Pos] In ['0'..'9']) Do Inc(Pos);
   End;
   For I := Start To Pos - 1 Do
    Colors[I - 1] := ClrNum;
   Continue;
  End;
  { Mot -> mot-cle, type ou identifiant. }
  If (Ch In ['a'..'z']) Or (Ch In ['A'..'Z']) Or (Ch = '_') Then
  Begin
   Start := Pos;
   Word := '';
   While (Pos <= Len) And
         ((Line[Pos] In ['a'..'z']) Or (Line[Pos] In ['A'..'Z']) Or
          (Line[Pos] In ['0'..'9']) Or (Line[Pos] = '_')) Do
   Begin
    Word := Word + Line[Pos];
    Inc(Pos);
   End;
   Word := UpCaseStr(Word);
   If IsSQLKeyword(Word) Then
    For I := Start To Pos - 1 Do Colors[I - 1] := ClrKw
   Else If IsSQLType(Word) Then
    For I := Start To Pos - 1 Do Colors[I - 1] := ClrType;
   Continue;
  End;
  Inc(Pos);
 End;
End;

{ ============================================================
  COLORATION SYNTAXIQUE PSP (PASCAL SERVER PAGES)
  ============================================================ }

{ --- Initialiser le moteur de coloration PSP --- }

Procedure InitPSPHighlighter(Var HL: TPSPHighlighter);
Begin
 InitXMLHighlighter(HL.XMLHL);
 InitPascalHighlighter(HL.PasHL);
End;

{ --- Colorier une ligne PSP (hybride HTML + Pascal) --- }

Procedure HighlightPSPLine(Var HL: TPSPHighlighter;
                           Line: String;
                           Var Colors: Array Of Byte);
Var
 Pos, Start, I, Len: Integer;
 TC: TTokenClass;
 Clr: Byte;
 InCode: Boolean;
Begin
 Len := Length(Line);
 For I := 0 To Len - 1 Do
  Colors[I] := Byte(TokenClassToColor(TC_NORMAL));

 Pos := 1;
 InCode := False;
 While Pos <= Len Do
 Begin
  { Detecter debut de bloc Pascal <% }
  If Not InCode And (Pos < Len) And
     (Line[Pos] = '<') And (Line[Pos + 1] = '%') Then
  Begin
   { Colorier <% en gris fonce (directive) }
   Clr := Byte(TokenClassToColor(TC_PREPROCESSOR));
   Colors[Pos - 1] := Clr;
   Colors[Pos] := Clr;
   Inc(Pos, 2);
   InCode := True;
   Continue;
  End;
  { Detecter fin de bloc Pascal %> }
  If InCode And (Pos < Len) And
     (Line[Pos] = '%') And (Line[Pos + 1] = '>') Then
  Begin
   { Colorier %> en gris fonce (directive) }
   Clr := Byte(TokenClassToColor(TC_PREPROCESSOR));
   Colors[Pos - 1] := Clr;
   Colors[Pos] := Clr;
   Inc(Pos, 2);
   InCode := False;
   Continue;
  End;
  { Selon le mode, utiliser le tokenizer Pascal ou XML }
  Start := Pos;
  If InCode Then
   TC := GetPascalTokenClass(HL.PasHL, Line, Pos)
  Else
   TC := GetXMLTokenClass(HL.XMLHL, Line, Pos);
  { Ne pas depasser un delimiteur <% ou %> }
  Clr := Byte(TokenClassToColor(TC));
  For I := Start To Pos - 1 Do
  Begin
   If (I >= 1) And (I <= Len) Then
    Colors[I - 1] := Clr;
  End;
 End;
End;

{ --- Obtenir le nom d un type de jeton XML --- }

Function XMLTokenClassName(TC: TTokenClass): String;
Begin
 XMLTokenClassName := TokenClassName(TC);
End;

{ --- Compter les tags XML connus --- }

Function CountXMLTags(Var HL: TXMLHighlighter): Integer;
Begin
 CountXMLTags := HL.TagCount;
End;

{ --- Verifier si une ligne XML contient un commentaire --- }

Function XMLLineHasComment(Var HL: TXMLHighlighter;
                            Line: String): Boolean;
Var
 Pos: Integer;
 TC: TTokenClass;
 SaveBC, SaveStr: Boolean;
 SaveTop: Integer;
Begin
 SaveBC := HL.Base.InBlockComment;
 SaveStr := HL.Base.InString;
 SaveTop := HL.Base.StateTop;
 XMLLineHasComment := False;
 Pos := 1;
 While Pos <= Length(Line) Do
 Begin
  TC := GetXMLTokenClass(HL, Line, Pos);
  If TC = TC_COMMENT Then
  Begin
   XMLLineHasComment := True;
   Break;
  End;
 End;
 HL.Base.InBlockComment := SaveBC;
 HL.Base.InString := SaveStr;
 HL.Base.StateTop := SaveTop;
End;

{ --- Verifier si une ligne XML contient une chaine --- }

Function XMLLineHasString(Var HL: TXMLHighlighter;
                           Line: String): Boolean;
Var
 Pos: Integer;
 TC: TTokenClass;
 SaveBC, SaveStr: Boolean;
 SaveTop: Integer;
Begin
 SaveBC := HL.Base.InBlockComment;
 SaveStr := HL.Base.InString;
 SaveTop := HL.Base.StateTop;
 XMLLineHasString := False;
 Pos := 1;
 While Pos <= Length(Line) Do
 Begin
  TC := GetXMLTokenClass(HL, Line, Pos);
  If TC = TC_STRING Then
  Begin
   XMLLineHasString := True;
   Break;
  End;
 End;
 HL.Base.InBlockComment := SaveBC;
 HL.Base.InString := SaveStr;
 HL.Base.StateTop := SaveTop;
End;

{ --- Compter les jetons XML dans une ligne --- }

Function CountXMLTokensInLine(Var HL: TXMLHighlighter;
                               Line: String): Integer;
Var
 Pos, Count: Integer;
 TC: TTokenClass;
 SaveBC, SaveStr: Boolean;
 SaveTop: Integer;
Begin
 SaveBC := HL.Base.InBlockComment;
 SaveStr := HL.Base.InString;
 SaveTop := HL.Base.StateTop;
 Count := 0;
 Pos := 1;
 While Pos <= Length(Line) Do
 Begin
  TC := GetXMLTokenClass(HL, Line, Pos);
  Inc(Count);
 End;
 HL.Base.InBlockComment := SaveBC;
 HL.Base.InString := SaveStr;
 HL.Base.StateTop := SaveTop;
 CountXMLTokensInLine := Count;
End;

{ --- Verifier si le surligneur XML est vide --- }

Function IsXMLHighlighterEmpty(Var HL: TXMLHighlighter): Boolean;
Begin
 IsXMLHighlighterEmpty := (HL.TagCount = 0);
End;

