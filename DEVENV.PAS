Function IsVBNetKeyword(Var HL: TVBNetHighlighter;
                        Word: String): Boolean;
Var
 I: Integer;
 LW: String;
Begin
 IsVBNetKeyword := False;
 LW := LowerCaseStr(Word);
 For I := 0 To HL.KeywordCount - 1 Do
 Begin
  If LW = HL.Keywords[I] Then
  Begin
   IsVBNetKeyword := True;
   Exit;
  End;
 End;
End;

