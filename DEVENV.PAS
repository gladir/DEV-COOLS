 Pos, Count: Integer;
 TC: TTokenClass;
 SaveBC, SaveStr: Boolean;
 SaveTop: Integer;
Begin
 SaveBC := HL.Base.InBlockComment;
 SaveStr := HL.Base.InString;
 SaveTop := HL.Base.StateTop;
 Count := 0;
 Pos := 1;
