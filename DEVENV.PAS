{ --- Compter les erreurs dans un onglet --- }

Function CountOutputErrors(Var OP: TOutputPanel;
 Tab: Integer): Integer;
Var
 I, Base, MaxPerTab, Count: Integer;
Begin
 Count := 0;
 If (Tab < 0) Or (Tab >= OUTPUT_TAB_COUNT) Then Begin
  CountOutputErrors := 0;
  Exit;
 End;
 MaxPerTab := MAX_OUTPUT_LINES Div OUTPUT_TAB_COUNT;
 Base := Tab * MaxPerTab;
 For I := 0 To OP.LineCounts[Tab] - 1 Do
  If OP.Lines[Base + I].Kind = OLK_ERROR Then
   Inc(Count);
 CountOutputErrors := Count;
End;

{ --- Compter les avertissements dans un onglet --- }

Function CountOutputWarnings(Var OP: TOutputPanel;
 Tab: Integer): Integer;
Var
 I, Base, MaxPerTab, Count: Integer;
Begin
 Count := 0;
 If (Tab < 0) Or (Tab >= OUTPUT_TAB_COUNT) Then Begin
  CountOutputWarnings := 0;
  Exit;
 End;
 MaxPerTab := MAX_OUTPUT_LINES Div OUTPUT_TAB_COUNT;
 Base := Tab * MaxPerTab;
 For I := 0 To OP.LineCounts[Tab] - 1 Do
  If OP.Lines[Base + I].Kind = OLK_WARNING Then
   Inc(Count);
 CountOutputWarnings := Count;
End;

{ ============================================================
  TERMINAL INTEGRE - SHELL INTERNE
  ============================================================ }

{ --- Ajouter une ligne au buffer du terminal --- }

Procedure TermAddLine(Var TP: TTerminalPanel; S: String);
Var
 Node, Old: PTermLine;
Begin
 If TP.LineCount < MAX_TERM_LINES Then Begin
  TP.Lines[TP.LineCount] := S;
  Inc(TP.LineCount);
 End Else Begin
  { Buffer plein : decaler vers le haut }
  Move(TP.Lines[1], TP.Lines[0],
   (MAX_TERM_LINES - 1) * SizeOf(String));
  TP.Lines[MAX_TERM_LINES - 1] := S;
 End;
 { Ajouter aussi a la liste chainee (historique d affichage) }
 New(Node);
 Node^.S := S;
 Node^.Prev := TP.HistTail;
 Node^.Next := Nil;
 If TP.HistTail <> Nil Then TP.HistTail^.Next := Node
 Else TP.HistHead := Node;
 TP.HistTail := Node;
 Inc(TP.HistCount);
 { Cap maximum : retirer la tete }
 While TP.HistCount > MAX_TERM_HIST_LINES Do Begin
  Old := TP.HistHead;
  If Old = Nil Then Break;
  TP.HistHead := Old^.Next;
  If TP.HistHead <> Nil Then TP.HistHead^.Prev := Nil
  Else TP.HistTail := Nil;
  Dispose(Old);
  Dec(TP.HistCount);
 End;
 { Si l utilisateur a remonte dans l historique, garder son point
   de vue stable en suivant les nouvelles lignes. }
 If TP.ScrollOffset > 0 Then Begin
  Inc(TP.ScrollOffset);
  If TP.ScrollOffset >= TP.HistCount Then
   TP.ScrollOffset := TP.HistCount - 1;
 End;
 TP.NeedRepaint := True;
End;

{ --- Fonctions utilitaires du shell --- }

Function TermStrToUpper(S: String): String;
Var
 I: Integer;
Begin
 For I := 1 To Length(S) Do
  If S[I] In ['a'..'z'] Then
   S[I] := Chr(Ord(S[I]) - 32);
 TermStrToUpper := S;
End;

Function TermTrimL(S: String): String;
Var
 I: Integer;
Begin
 For I := 1 To Length(S) Do Begin
  If S[I] <> ' ' Then Begin
   TermTrimL := Copy(S, I, 255);
   Exit;
  End;
 End;
 TermTrimL := S;
End;

Function TermTrimR(S: String): String;
Var
 I: Integer;
Begin
 I := Length(S);
 While (I > 0) And (S[I] In [#9, ' ']) Do Dec(I);
 S[0] := Chr(I);
 TermTrimR := S;
End;

Function TermTrim(S: String): String;
Begin
 TermTrim := TermTrimL(TermTrimR(S));
End;

Function TermPadRight(S: String; Space: Integer): String;
Var
 I: Integer;
Begin
 If Length(S) < Space Then
  For I := Length(S) + 1 To Space Do
   S := S + ' ';
 TermPadRight := S;
End;

Function TermPadZeroLeft(Value: Integer; Space: Integer): String;
Var
 S: String;
Begin
 Str(Value, S);
 While Length(S) < Space Do S := '0' + S;
 TermPadZeroLeft := S;
End;

Function TermGetCurrentDir: String;
Var
 Dir: String;
Begin
 GetDir(0, Dir);
 TermGetCurrentDir := Dir;
End;

Function TermGetErrorMessage(Code: Word): String;
Begin
 Case Code Of
  0: TermGetErrorMessage := '';
  2: TermGetErrorMessage := 'Fichier introuvable';
  3: TermGetErrorMessage := 'Chemin introuvable';
  4: TermGetErrorMessage := 'Trop de fichiers ouverts';
  5: TermGetErrorMessage := 'Acces refuse';
  6: TermGetErrorMessage := 'Handle de fichier invalide';
  12: TermGetErrorMessage := 'Mode d''acces sur disque invalide';
  15: TermGetErrorMessage := 'Numero de disque invalide';
  16: TermGetErrorMessage := 'Impossible de supprimer le repertoire';
  17: TermGetErrorMessage := 'Impossible de renommer sur plusieurs volumes';
  100: TermGetErrorMessage := 'Erreur de lecture a partir du disque';
  101: TermGetErrorMessage := 'Erreur d''ecriture sur le disque';
  102: TermGetErrorMessage := 'Fichier non attribue';
  103: TermGetErrorMessage := 'Le fichier n''est pas ouvert';
  104: TermGetErrorMessage := 'Le fichier n''est pas ouvert a l''entree';
  105: TermGetErrorMessage := 'Le fichier n''est pas ouvert a la sortie';
  106: TermGetErrorMessage := 'Numero invalide';
  150: TermGetErrorMessage := 'Disque protege en ecriture';
  152: TermGetErrorMessage := 'Disque pas pret';
  Else TermGetErrorMessage := 'Erreur inconnue';
 End;
End;

{ --- Extraction de la commande et des parametres --- }

Procedure TermExtractCommand(CmdStr: String;
 Var CurrCmd, ParamStr: String);
Var
 I: Integer;
Begin
 CmdStr := TermTrim(CmdStr);
 For I := 1 To Length(CmdStr) Do Begin
  If Not (CmdStr[I] In ['A'..'Z', 'a'..'z', '_', '-',
   '0'..'9']) Then Begin
   CurrCmd := TermStrToUpper(Copy(CmdStr, 1, I - 1));
   ParamStr := TermTrimL(Copy(CmdStr, I, 255));
   Exit;
  End;
 End;
 CurrCmd := TermStrToUpper(CmdStr);
 ParamStr := '';
End;

Function TermExtractParam(ParamStr: String;
 Index: Integer): String;
Var
 Count, LocalIndex, L: Integer;
 Temp: String;
Begin
 Temp := '';
 Count := 1;
 LocalIndex := 1;
 L := 0;
 While Count <= Length(ParamStr) Do Begin
  If Not (ParamStr[Count] In [' ', #9]) Then Begin
   If LocalIndex = Index Then Begin
    While (Count <= Length(ParamStr)) And
     (Not (ParamStr[Count] In [' ', #9])) And
     (L < 255) Do Begin
     Temp := Temp + ParamStr[Count];
     Inc(L);
     Inc(Count);
    End;
    TermExtractParam := Temp;
    Exit;
   End;
   While (Count <= Length(ParamStr)) And
    (Not (ParamStr[Count] In [' ', #9])) Do
    Inc(Count);
   Inc(LocalIndex);
  End;
  If Count >= Length(ParamStr) Then Break;
  Inc(Count);
 End;
 TermExtractParam := Temp;
End;

{ --- Ajouter une commande a l historique du terminal --- }

Procedure TermAddHistory(Var TP: TTerminalPanel; S: String);
Var
 I: Integer;
Begin
 If S = '' Then Exit;
 If TP.NumberHistory >= MAX_TERM_HISTORY Then Begin
  For I := 1 To MAX_TERM_HISTORY - 1 Do
   TP.TermHistory[I] := TP.TermHistory[I + 1];
  TP.TermHistory[MAX_TERM_HISTORY] := S;
 End Else Begin
  Inc(TP.NumberHistory);
  TP.TermHistory[TP.NumberHistory] := S;
 End;
 TP.HistoryPos := TP.NumberHistory + 1;
End;

{ --- Copie de fichier interne (definition apres helpers FAT) --- }

{ ============================================================
  ACCES FAT12/16 POUR LE TERMINAL INTEGRE
  ============================================================
  Les images montees via /DISK0 et /DISK1 sont lues directement
  depuis EmuFloppyFile[]. Ces helpers fournissent une couche
  read-only suffisante pour DIR / CD / TYPE / VOL. }

Function Fat_ReadSector(Idx: Byte; LBA: LongInt;
 Var Buf: Array Of Byte): Boolean;
Var
 BR: Word;
Begin
 Fat_ReadSector := False;
 If Not EmuFloppyOpen[Idx] Then Exit;
 If LBA < 0 Then Exit;
 If LBA >= (EmuFloppySize[Idx] Div 512) Then Exit;
 {$I-}
 Seek(EmuFloppyFile[Idx], LBA * 512);
 If IOResult <> 0 Then Exit;
 BR := 0;
 BlockRead(EmuFloppyFile[Idx], Buf, 512, BR);
 {$I+} If IOResult <> 0 Then Exit;
 Fat_ReadSector := (BR = 512);
End;

Function Fat_LE16(Var Buf: Array Of Byte; Off: Integer): Word;
Begin
 Fat_LE16 := Word(Buf[Off]) Or (Word(Buf[Off + 1]) Shl 8);
End;

Function Fat_LE32(Var Buf: Array Of Byte; Off: Integer): LongInt;
Begin
 Fat_LE32 := LongInt(Buf[Off]) +
             LongInt(Buf[Off + 1]) * 256 +
             LongInt(Buf[Off + 2]) * 65536 +
             LongInt(Buf[Off + 3]) * 16777216;
End;

Procedure Fat_TryMount(Idx: Byte);
Var
 Buf: Array[0..511] Of Byte;
 BPS: Word;
 SPC: Byte;
 TS16: Word;
 TS32: LongInt;
 SPF: Word;
 V: TFatVol;
 I: Integer;
 C: Char;
Begin
 FillChar(V, SizeOf(V), 0);
 V.Mounted := False;
 V.CachedFatLBA := -1;
 If Not EmuFloppyOpen[Idx] Then Begin
  FatVol[Idx] := V;
  Exit;
 End;
 If Not Fat_ReadSector(Idx, 0, Buf) Then Begin
  FatVol[Idx] := V;
  Exit;
 End;
 BPS := Fat_LE16(Buf, 11);
 SPC := Buf[13];
 If (BPS <> 512) Or (SPC = 0) Then Begin
  FatVol[Idx] := V;
  Exit;
 End;
 V.BytesPerSector   := BPS;
 V.SectorsPerCluster := SPC;
 V.ReservedSectors  := Fat_LE16(Buf, 14);
 V.NumFATs          := Buf[16];
 V.RootEntries      := Fat_LE16(Buf, 17);
 TS16               := Fat_LE16(Buf, 19);
 TS32               := Fat_LE32(Buf, 32);
 If TS16 <> 0 Then V.TotalSectors := TS16
              Else V.TotalSectors := TS32;
 SPF                := Fat_LE16(Buf, 22);
 V.SectorsPerFAT    := SPF;
 If (V.NumFATs = 0) Or (V.ReservedSectors = 0) Or
    (V.SectorsPerFAT = 0) Or (V.RootEntries = 0) Or
    (V.TotalSectors = 0) Then Begin
  FatVol[Idx] := V;
  Exit;
 End;
 V.FATStart       := V.ReservedSectors;
 V.RootStart      := V.FATStart + LongInt(V.NumFATs) * V.SectorsPerFAT;
 V.RootDirSectors := (LongInt(V.RootEntries) * 32 + 511) Div 512;
 V.DataStart      := V.RootStart + V.RootDirSectors;
 V.ClusterCount   := (V.TotalSectors - (V.ReservedSectors +
                       LongInt(V.NumFATs) * V.SectorsPerFAT +
                       V.RootDirSectors)) Div V.SectorsPerCluster;
 If V.ClusterCount < 4085 Then V.FATType := 12
 Else If V.ClusterCount < 65525 Then V.FATType := 16
 Else Begin
  { FAT32 non supporte pour le moment }
  FatVol[Idx] := V;
  Exit;
 End;
 { Label de volume : champ a offset 43 du BPB (11 octets) }
 V.VolLabel := '';
 For I := 0 To 10 Do Begin
  C := Chr(Buf[43 + I]);
  If C = ' ' Then Continue;
  If (Buf[43 + I] < 32) Or (Buf[43 + I] > 126) Then Begin
   V.VolLabel := '';
   Break;
  End;
  V.VolLabel := V.VolLabel + C;
 End;
 V.Mounted := True;
 FatVol[Idx] := V;
End;

Function Fat_FATByte(Idx: Byte; Offset: LongInt): Byte;
Var
 LBA: LongInt;
 Within: Word;
Begin
 Fat_FATByte := 0;
 LBA := FatVol[Idx].FATStart + (Offset Div 512);
 Within := Word(Offset Mod 512);
 If LBA <> FatVol[Idx].CachedFatLBA Then Begin
  If Not Fat_ReadSector(Idx, LBA, FatVol[Idx].CachedFatBuf) Then Exit;
  FatVol[Idx].CachedFatLBA := LBA;
 End;
 Fat_FATByte := FatVol[Idx].CachedFatBuf[Within];
End;

Function Fat_NextCluster(Idx: Byte; Cl: LongInt): LongInt;
Var
 O: LongInt;
 B1, B2: Byte;
 V: LongInt;
Begin
 If FatVol[Idx].FATType = 12 Then Begin
  O := Cl + (Cl Div 2);
  B1 := Fat_FATByte(Idx, O);
  B2 := Fat_FATByte(Idx, O + 1);
  V := Word(B1) Or (Word(B2) Shl 8);
  If (Cl And 1) <> 0 Then V := V Shr 4
                     Else V := V And $0FFF;
  Fat_NextCluster := V;
 End Else Begin
  O := Cl * 2;
  Fat_NextCluster := Word(Fat_FATByte(Idx, O)) Or
                     (Word(Fat_FATByte(Idx, O + 1)) Shl 8);
 End;
End;

Function Fat_IsEOC(Idx: Byte; Cl: LongInt): Boolean;
Begin
 If FatVol[Idx].FATType = 12 Then Fat_IsEOC := Cl >= $0FF8
 Else Fat_IsEOC := Cl >= $FFF8;
End;

Function Fat_ClusterToLBA(Idx: Byte; Cl: LongInt): LongInt;
Begin
 Fat_ClusterToLBA := FatVol[Idx].DataStart +
   LongInt(Cl - 2) * FatVol[Idx].SectorsPerCluster;
End;

Function Fat_UpStr(S: String): String;
Var I: Integer;
Begin
 For I := 1 To Length(S) Do
  If S[I] In ['a'..'z'] Then S[I] := Chr(Ord(S[I]) - 32);
 Fat_UpStr := S;
End;

{ Decoder un nom 8.3 a partir d une entree de repertoire (32 octets).
  Renvoie '' si entree libre/effacee ou nom long VFAT. }
Function Fat_EntryName(Var Buf: Array Of Byte; Off: Integer): String;
Var
 I: Integer;
 N, E: String;
 B: Byte;
Begin
 Fat_EntryName := '';
 If (Buf[Off] = 0) Or (Buf[Off] = $E5) Then Exit;
 If (Buf[Off + 11] And $0F) = $0F Then Exit;   { LFN }
 N := '';
 For I := 0 To 7 Do Begin
  B := Buf[Off + I];
  If B = 32 Then Continue;
  If (B < 32) Or (B > 126) Then Exit;
  N := N + Chr(B);
 End;
 E := '';
 For I := 8 To 10 Do Begin
  B := Buf[Off + 10 - (10 - I)]; { offsets 8..10 }
  B := Buf[Off + I];
  If B = 32 Then Continue;
  If (B < 32) Or (B > 126) Then Exit;
  E := E + Chr(B);
 End;
 { Premier byte $05 = caractere $E5 reel }
 If Buf[Off] = $05 Then N[1] := Chr($E5);
 If E <> '' Then Fat_EntryName := N + '.' + E
            Else Fat_EntryName := N;
End;

Function Fat_EntryAttr(Var Buf: Array Of Byte; Off: Integer): Byte;
Begin
 Fat_EntryAttr := Buf[Off + 11];
End;

Function Fat_EntryCluster(Var Buf: Array Of Byte; Off: Integer): Word;
Begin
 Fat_EntryCluster := Fat_LE16(Buf, Off + 26);
End;

Function Fat_EntrySize(Var Buf: Array Of Byte; Off: Integer): LongInt;
Begin
 Fat_EntrySize := Fat_LE32(Buf, Off + 28);
End;

{ Decoder l etiquette de volume depuis le repertoire racine si elle
  n a pas ete trouvee dans le BPB. }
Procedure Fat_FindVolLabel(Idx: Byte);
Var
 Buf: Array[0..511] Of Byte;
 S: LongInt;
 I, Cnt, Attr: Integer;
 LBA: LongInt;
 N: String;
 K: Integer;
Begin
 If Not FatVol[Idx].Mounted Then Exit;
 Cnt := 0;
 For S := 0 To FatVol[Idx].RootDirSectors - 1 Do Begin
  LBA := FatVol[Idx].RootStart + S;
  If Not Fat_ReadSector(Idx, LBA, Buf) Then Exit;
  For I := 0 To 15 Do Begin
   If Cnt >= FatVol[Idx].RootEntries Then Exit;
   Inc(Cnt);
   If Buf[I * 32] = 0 Then Exit;
   If Buf[I * 32] = $E5 Then Continue;
   Attr := Buf[I * 32 + 11];
   If (Attr And $0F) = $0F Then Continue;   { LFN }
   If (Attr And $08) <> 0 Then Begin
    { Volume label }
    N := '';
    For K := 0 To 10 Do
     If (Buf[I * 32 + K] >= 32) And (Buf[I * 32 + K] <= 126) Then
      N := N + Chr(Buf[I * 32 + K]);
    While (Length(N) > 0) And (N[Length(N)] = ' ') Do
     N := Copy(N, 1, Length(N) - 1);
    If N <> '' Then FatVol[Idx].VolLabel := N;
    Exit;
   End;
  End;
 End;
End;

{ Decouper un chemin '\AAA\BBB\CCC' en composantes UPPER. Le slash
  '/' est aussi accepte. Renvoie le nombre de composantes (max 16). }
Procedure Fat_SplitPath(P: String; Var N: Integer;
 Var Parts: Array Of String);
Var
 I, Start: Integer;
 Sub: String;
Begin
 N := 0;
 I := 1;
 While I <= Length(P) Do Begin
  If (P[I] = '\') Or (P[I] = '/') Then Inc(I)
  Else Begin
   Start := I;
   While (I <= Length(P)) And (P[I] <> '\') And (P[I] <> '/') Do
    Inc(I);
   Sub := Copy(P, Start, I - Start);
   If N < 16 Then Begin
    Parts[N] := Fat_UpStr(Sub);
    Inc(N);
   End;
  End;
 End;
End;

{ Resoudre Cwd + Rel -> chemin absolu (commencant par '\'). Gere
  '.' et '..'. }
Function Fat_AbsPath(Cwd, Rel: String): String;
Var
 Comb: String;
 NParts: Integer;
 Parts: Array[0..15] Of String;
 OutP: String;
 I: Integer;
 NOut: Integer;
 OutParts: Array[0..15] Of String;
Begin
 If (Rel <> '') And ((Rel[1] = '\') Or (Rel[1] = '/')) Then
  Comb := Rel
 Else Begin
  If Cwd = '' Then Cwd := '\';
  If Cwd[Length(Cwd)] = '\' Then Comb := Cwd + Rel
  Else Comb := Cwd + '\' + Rel;
 End;
 Fat_SplitPath(Comb, NParts, Parts);
 NOut := 0;
 For I := 0 To NParts - 1 Do Begin
  If Parts[I] = '.' Then Continue;
  If Parts[I] = '..' Then Begin
   If NOut > 0 Then Dec(NOut);
   Continue;
  End;
  If NOut < 16 Then Begin
   OutParts[NOut] := Parts[I];
   Inc(NOut);
  End;
 End;
 OutP := '\';
 For I := 0 To NOut - 1 Do Begin
  If I > 0 Then OutP := OutP + '\';
  OutP := OutP + OutParts[I];
 End;
 If (Length(OutP) > 1) And (OutP[Length(OutP)] = '\') Then
  OutP := Copy(OutP, 1, Length(OutP) - 1);
 Fat_AbsPath := OutP;
End;

{ Chercher dans le repertoire de cluster StartCl (ou racine si IsRoot)
  une entree de nom NameUp. Si trouve, renvoie True et remplit
  Attr/Cluster/Size. }
Function Fat_FindInDir(Idx: Byte; IsRoot: Boolean; StartCl: LongInt;
 NameUp: String; Var Attr: Byte; Var Cluster: Word;
 Var Size: LongInt): Boolean;
Var
 Buf: Array[0..511] Of Byte;
 SecInClu, I: Integer;
 EntName: String;
 Cur: LongInt;
 S: LongInt;
 RootCnt: Integer;
 LBA: LongInt;
Begin
 Fat_FindInDir := False;
 If IsRoot Then Begin
  RootCnt := 0;
  For S := 0 To FatVol[Idx].RootDirSectors - 1 Do Begin
   LBA := FatVol[Idx].RootStart + S;
   If Not Fat_ReadSector(Idx, LBA, Buf) Then Exit;
   For I := 0 To 15 Do Begin
    If RootCnt >= FatVol[Idx].RootEntries Then Exit;
    Inc(RootCnt);
    If Buf[I * 32] = 0 Then Exit;
    EntName := Fat_EntryName(Buf, I * 32);
    If EntName = '' Then Continue;
    If (Fat_EntryAttr(Buf, I * 32) And $08) <> 0 Then Continue;
    If Fat_UpStr(EntName) = NameUp Then Begin
     Attr    := Fat_EntryAttr(Buf, I * 32);
     Cluster := Fat_EntryCluster(Buf, I * 32);
     Size    := Fat_EntrySize(Buf, I * 32);
     Fat_FindInDir := True;
     Exit;
    End;
   End;
  End;
 End Else Begin
  Cur := StartCl;
  While (Cur >= 2) And (Not Fat_IsEOC(Idx, Cur)) Do Begin
   For SecInClu := 0 To FatVol[Idx].SectorsPerCluster - 1 Do Begin
    LBA := Fat_ClusterToLBA(Idx, Cur) + SecInClu;
    If Not Fat_ReadSector(Idx, LBA, Buf) Then Exit;
    For I := 0 To 15 Do Begin
     If Buf[I * 32] = 0 Then Exit;
     EntName := Fat_EntryName(Buf, I * 32);
     If EntName = '' Then Continue;
     If (Fat_EntryAttr(Buf, I * 32) And $08) <> 0 Then Continue;
     If Fat_UpStr(EntName) = NameUp Then Begin
      Attr    := Fat_EntryAttr(Buf, I * 32);
      Cluster := Fat_EntryCluster(Buf, I * 32);
      Size    := Fat_EntrySize(Buf, I * 32);
      Fat_FindInDir := True;
      Exit;
     End;
    End;
   End;
   Cur := Fat_NextCluster(Idx, Cur);
  End;
 End;
End;

{ Resoudre AbsPath (commencant par '\') vers un descripteur :
  IsRoot=True si racine, sinon StartCl = cluster de depart. Si le
  chemin n existe pas, renvoie False. SkipLast=True : on resout le
  parent et OutName = nom final restant. }
Function Fat_ResolveDir(Idx: Byte; AbsPath: String;
 Var IsRoot: Boolean; Var StartCl: LongInt): Boolean;
Var
 NParts: Integer;
 Parts: Array[0..15] Of String;
 I: Integer;
 Attr: Byte;
 Cluster: Word;
 Sz: LongInt;
Begin
 Fat_ResolveDir := False;
 IsRoot  := True;
 StartCl := 0;
 If Not FatVol[Idx].Mounted Then Exit;
 Fat_SplitPath(AbsPath, NParts, Parts);
 For I := 0 To NParts - 1 Do Begin
  If Not Fat_FindInDir(Idx, IsRoot, StartCl, Parts[I],
   Attr, Cluster, Sz) Then Exit;
  If (Attr And $10) = 0 Then Exit;  { pas un repertoire }
  IsRoot  := False;
  StartCl := Cluster;
  If StartCl < 2 Then Begin
   { ".." sur sous-rep racine -> retourner racine }
   IsRoot := True;
  End;
 End;
 Fat_ResolveDir := True;
End;

{ Resoudre un chemin de fichier : separe parent + nom feuille, puis
  cherche le nom dans le parent. }
Function Fat_FindPath(Idx: Byte; AbsPath: String;
 Var Attr: Byte; Var Cluster: Word; Var Size: LongInt): Boolean;
Var
 NParts: Integer;
 Parts: Array[0..15] Of String;
 I: Integer;
 ParentPath, Leaf: String;
 IsRoot: Boolean;
 StartCl: LongInt;
Begin
 Fat_FindPath := False;
 If Not FatVol[Idx].Mounted Then Exit;
 Fat_SplitPath(AbsPath, NParts, Parts);
 If NParts = 0 Then Begin
  Attr := $10;
  Cluster := 0;
  Size := 0;
  Fat_FindPath := True;
  Exit;
 End;
 ParentPath := '\';
 For I := 0 To NParts - 2 Do Begin
  If Length(ParentPath) > 1 Then ParentPath := ParentPath + '\';
  ParentPath := ParentPath + Parts[I];
 End;
 Leaf := Parts[NParts - 1];
 If Not Fat_ResolveDir(Idx, ParentPath, IsRoot, StartCl) Then Exit;
 Fat_FindPath := Fat_FindInDir(Idx, IsRoot, StartCl, Leaf,
  Attr, Cluster, Size);
End;

{ Iterer toutes les entrees d un repertoire (root ou cluster chain)
  et accumuler les noms via TermAddLine pour la commande DIR. }
Procedure Fat_ListDir(Idx: Byte; IsRoot: Boolean; StartCl: LongInt;
 Var TP: TTerminalPanel; Style: Byte);
{ Style : 0 = CMD (date taille nom), 1 = PowerShell }
Var
 Buf: Array[0..511] Of Byte;
 SecInClu, I: Integer;
 EntName, Line, S: String;
 Cur: LongInt;
 S2: LongInt;
 RootCnt: Integer;
 LBA: LongInt;
 Attr: Byte;
 Sz: LongInt;
 T, D: Word;
 Hr, Mn, Yr, Mo, Dy: Word;
 TotalFiles, TotalDirs: LongInt;
 TotalSize: LongInt;
 Done: Boolean;
 EntOff: Integer;
Begin
 TotalFiles := 0;
 TotalDirs  := 0;
 TotalSize  := 0;
 Done := False;
 If IsRoot Then Begin
  RootCnt := 0;
  For S2 := 0 To FatVol[Idx].RootDirSectors - 1 Do Begin
   If Done Then Break;
   LBA := FatVol[Idx].RootStart + S2;
   If Not Fat_ReadSector(Idx, LBA, Buf) Then Break;
   For I := 0 To 15 Do Begin
    If RootCnt >= FatVol[Idx].RootEntries Then Begin
     Done := True; Break;
    End;
    Inc(RootCnt);
    EntOff := I * 32;
    If Buf[EntOff] = 0 Then Begin Done := True; Break; End;
    EntName := Fat_EntryName(Buf, EntOff);
    If EntName = '' Then Continue;
    Attr := Fat_EntryAttr(Buf, EntOff);
    If (Attr And $08) <> 0 Then Continue;
    Sz := Fat_EntrySize(Buf, EntOff);
    T := Fat_LE16(Buf, EntOff + 22);
    D := Fat_LE16(Buf, EntOff + 24);
    Yr := ((D Shr 9) And $7F) + 1980;
    Mo := (D Shr 5) And $0F;
    Dy := D And $1F;
    Hr := (T Shr 11) And $1F;
    Mn := (T Shr 5)  And $3F;
    Line := TermPadZeroLeft(Mo, 2) + '/' +
            TermPadZeroLeft(Dy, 2) + '/' +
            TermPadZeroLeft(Yr, 4) + '  ' +
            TermPadZeroLeft(Hr, 2) + ':' +
            TermPadZeroLeft(Mn, 2) + '    ';
    If (Attr And $10) <> 0 Then Begin
     Line := Line + '<DIR>          ' + EntName;
     Inc(TotalDirs);
    End Else Begin
     Str(Sz, S);
     While Length(S) < 14 Do S := ' ' + S;
     Line := Line + S + ' ' + EntName;
     Inc(TotalFiles);
     Inc(TotalSize, Sz);
    End;
    TermAddLine(TP, Line);
   End;
  End;
 End Else Begin
  Cur := StartCl;
  While (Cur >= 2) And (Not Fat_IsEOC(Idx, Cur)) And (Not Done) Do Begin
   For SecInClu := 0 To FatVol[Idx].SectorsPerCluster - 1 Do Begin
    If Done Then Break;
    LBA := Fat_ClusterToLBA(Idx, Cur) + SecInClu;
    If Not Fat_ReadSector(Idx, LBA, Buf) Then Begin
     Done := True; Break;
    End;
    For I := 0 To 15 Do Begin
     EntOff := I * 32;
     If Buf[EntOff] = 0 Then Begin Done := True; Break; End;
     EntName := Fat_EntryName(Buf, EntOff);
     If EntName = '' Then Continue;
     Attr := Fat_EntryAttr(Buf, EntOff);
     If (Attr And $08) <> 0 Then Continue;
     Sz := Fat_EntrySize(Buf, EntOff);
     T := Fat_LE16(Buf, EntOff + 22);
     D := Fat_LE16(Buf, EntOff + 24);
     Yr := ((D Shr 9) And $7F) + 1980;
     Mo := (D Shr 5) And $0F;
     Dy := D And $1F;
     Hr := (T Shr 11) And $1F;
     Mn := (T Shr 5)  And $3F;
     Line := TermPadZeroLeft(Mo, 2) + '/' +
             TermPadZeroLeft(Dy, 2) + '/' +
             TermPadZeroLeft(Yr, 4) + '  ' +
             TermPadZeroLeft(Hr, 2) + ':' +
             TermPadZeroLeft(Mn, 2) + '    ';
     If (Attr And $10) <> 0 Then Begin
      Line := Line + '<DIR>          ' + EntName;
      Inc(TotalDirs);
     End Else Begin
      Str(Sz, S);
      While Length(S) < 14 Do S := ' ' + S;
      Line := Line + S + ' ' + EntName;
      Inc(TotalFiles);
      Inc(TotalSize, Sz);
     End;
     TermAddLine(TP, Line);
    End;
   End;
   If Done Then Break;
   Cur := Fat_NextCluster(Idx, Cur);
  End;
 End;
 If Style = 0 Then Begin
  Str(TotalFiles, S);
  While Length(S) < 16 Do S := ' ' + S;
  Str(TotalSize, Line);
  While Length(Line) < 14 Do Line := ' ' + Line;
  TermAddLine(TP, S + ' File(s)' + Line + ' bytes');
  Str(TotalDirs, S);
  While Length(S) < 16 Do S := ' ' + S;
  TermAddLine(TP, S + ' Dir(s)');
 End;
End;

{ Lire un fichier (cluster chain) et l afficher ligne par ligne sur
  le terminal. Coupe sur CR/LF. Marque les fichiers binaires (octet
  < 32 hors TAB/CR/LF) par un avertissement et arrete. }
Procedure Fat_TypeFile(Idx: Byte; StartCl: LongInt; Size: LongInt;
 Var TP: TTerminalPanel);
Var
 Buf: Array[0..511] Of Byte;
 Cur: LongInt;
 SecInClu, J: Integer;
 LBA: LongInt;
 Remain: LongInt;
 ToRead: Integer;
 B: Byte;
 Line: String;
 IsBin: Boolean;
Begin
 Cur := StartCl;
 Remain := Size;
 Line := '';
 IsBin := False;
 If (StartCl < 2) Or (Size <= 0) Then Exit;
 While (Cur >= 2) And (Not Fat_IsEOC(Idx, Cur)) And
       (Remain > 0) And (Not IsBin) Do Begin
  For SecInClu := 0 To FatVol[Idx].SectorsPerCluster - 1 Do Begin
   If Remain <= 0 Then Break;
   LBA := Fat_ClusterToLBA(Idx, Cur) + SecInClu;
   If Not Fat_ReadSector(Idx, LBA, Buf) Then Begin
    TermAddLine(TP, 'Erreur de lecture sur l image');
    Exit;
   End;
   If Remain > 512 Then ToRead := 512
                   Else ToRead := Integer(Remain);
   For J := 0 To ToRead - 1 Do Begin
    B := Buf[J];
    Case B Of
     10: Begin
      TermAddLine(TP, Line);
      Line := '';
     End;
     13: ;       { ignore CR }
      9: Begin
      Line := Line + '    ';
     End;
     26: Begin   { EOF DOS }
      If Line <> '' Then TermAddLine(TP, Line);
      Exit;
     End;
    Else
     If B < 32 Then Begin
      IsBin := True;
      Break;
     End;
     If Length(Line) >= 250 Then Begin
      TermAddLine(TP, Line);
      Line := '';
     End;
     Line := Line + Chr(B);
    End;
   End;
   Dec(Remain, ToRead);
   If IsBin Then Break;
  End;
  If IsBin Then Break;
  Cur := Fat_NextCluster(Idx, Cur);
 End;
 If Line <> '' Then TermAddLine(TP, Line);
 If IsBin Then
  TermAddLine(TP, '(fichier binaire : affichage interrompu)');
End;

{ Calcul de l espace libre en octets sur le volume. }
Function Fat_FreeBytes(Idx: Byte): LongInt;
Var
 Cl: LongInt;
 V: LongInt;
 Free: LongInt;
 MaxCl: LongInt;
Begin
 Fat_FreeBytes := 0;
 If Not FatVol[Idx].Mounted Then Exit;
 Free := 0;
 MaxCl := FatVol[Idx].ClusterCount + 1;
 For Cl := 2 To MaxCl Do Begin
  V := Fat_NextCluster(Idx, Cl);
  If V = 0 Then Inc(Free);
 End;
 Fat_FreeBytes := Free * LongInt(FatVol[Idx].SectorsPerCluster) * 512;
End;

{ ============================================================
  ECRITURE FAT12/16 (creation de fichier dans une image montee)
  ============================================================ }

Function Fat_WriteSector(Idx: Byte; LBA: LongInt;
 Var Buf: Array Of Byte): Boolean;
Var BW: Word;
Begin
 Fat_WriteSector := False;
 If Not EmuFloppyOpen[Idx] Then Exit;
 If LBA < 0 Then Exit;
 If LBA >= (EmuFloppySize[Idx] Div 512) Then Exit;
 {$I-}
 Seek(EmuFloppyFile[Idx], LBA * 512);
 If IOResult <> 0 Then Exit;
 BW := 0;
 BlockWrite(EmuFloppyFile[Idx], Buf, 512, BW);
 {$I+} If IOResult <> 0 Then Exit;
 { Invalider le cache FAT si on ecrit sur le LBA cache }
 If LBA = FatVol[Idx].CachedFatLBA Then
  FatVol[Idx].CachedFatLBA := -1;
 Fat_WriteSector := (BW = 512);
End;

{ Modifier un octet de la FAT et repercuter sur toutes les copies. }
Function Fat_FATWriteByte(Idx: Byte; Offset: LongInt;
 Val: Byte): Boolean;
Var
 Buf: Array[0..511] Of Byte;
 K: Integer;
 LBA, BaseLBA: LongInt;
 Within: Word;
Begin
 Fat_FATWriteByte := False;
 BaseLBA := FatVol[Idx].FATStart + (Offset Div 512);
 Within  := Word(Offset Mod 512);
 If Not Fat_ReadSector(Idx, BaseLBA, Buf) Then Exit;
 Buf[Within] := Val;
 For K := 0 To FatVol[Idx].NumFATs - 1 Do Begin
  LBA := BaseLBA + LongInt(K) * FatVol[Idx].SectorsPerFAT;
  If Not Fat_WriteSector(Idx, LBA, Buf) Then Exit;
 End;
 Fat_FATWriteByte := True;
End;

{ Ecrire la valeur 12 ou 16 bits dans la FAT pour le cluster Cl. }
Function Fat_SetNextCluster(Idx: Byte; Cl, Val: LongInt): Boolean;
Var
 O: LongInt;
 B1, B2: Byte;
Begin
 Fat_SetNextCluster := False;
 If FatVol[Idx].FATType = 12 Then Begin
  O := Cl + (Cl Div 2);
  B1 := Fat_FATByte(Idx, O);
  B2 := Fat_FATByte(Idx, O + 1);
  If (Cl And 1) = 0 Then Begin
   B1 := Byte(Val And $FF);
   B2 := Byte((B2 And $F0) Or ((Val Shr 8) And $0F));
  End Else Begin
   B1 := Byte((B1 And $0F) Or ((Val Shl 4) And $F0));
   B2 := Byte((Val Shr 4) And $FF);
  End;
  If Not Fat_FATWriteByte(Idx, O, B1) Then Exit;
  If Not Fat_FATWriteByte(Idx, O + 1, B2) Then Exit;
 End Else Begin
  O := Cl * 2;
  If Not Fat_FATWriteByte(Idx, O, Byte(Val And $FF)) Then Exit;
  If Not Fat_FATWriteByte(Idx, O + 1,
   Byte((Val Shr 8) And $FF)) Then Exit;
 End;
 Fat_SetNextCluster := True;
End;

{ Trouver un cluster libre et le marquer EOC. Renvoie 0 si plein. }
Function Fat_AllocCluster(Idx: Byte): LongInt;
Var
 Cl: LongInt;
 EOC: LongInt;
Begin
 Fat_AllocCluster := 0;
 If FatVol[Idx].FATType = 12 Then EOC := $0FFF
                              Else EOC := $FFFF;
 For Cl := 2 To FatVol[Idx].ClusterCount + 1 Do
  If Fat_NextCluster(Idx, Cl) = 0 Then Begin
   If Fat_SetNextCluster(Idx, Cl, EOC) Then
    Fat_AllocCluster := Cl;
   Exit;
  End;
End;

{ Convertir un nom en 11 octets 8.3 (espaces pad). Tronque base a 8 et
  extension a 3 si necessaire. Retourne False si caracteres invalides. }
Function Fat_MakeName11(Name: String;
 Var N11: Array Of Byte): Boolean;
Var
 I, DotPos: Integer;
 Base, Ext: String;
 C: Char;
Begin
 Fat_MakeName11 := False;
 Name := Fat_UpStr(Name);
 If Length(Name) = 0 Then Exit;
 DotPos := 0;
 For I := Length(Name) DownTo 1 Do
  If Name[I] = '.' Then Begin DotPos := I; Break; End;
 If DotPos = 0 Then Begin
  Base := Name; Ext := '';
 End Else Begin
  Base := Copy(Name, 1, DotPos - 1);
  Ext  := Copy(Name, DotPos + 1, Length(Name) - DotPos);
 End;
 If Length(Base) = 0 Then Exit;
 If Length(Base) > 8 Then Base := Copy(Base, 1, 8);
 If Length(Ext)  > 3 Then Ext  := Copy(Ext,  1, 3);
 For I := 0 To 10 Do N11[I] := Ord(' ');
 For I := 1 To Length(Base) Do N11[I - 1] := Ord(Base[I]);
 For I := 1 To Length(Ext)  Do N11[8 + I - 1] := Ord(Ext[I]);
 For I := 0 To 10 Do Begin
  C := Chr(N11[I]);
  If (N11[I] < 32) Or (C = '"') Or (C = '*') Or (C = '+') Or
     (C = ',') Or (C = '/') Or (C = ':') Or (C = ';') Or
     (C = '<') Or (C = '=') Or (C = '>') Or (C = '?') Or
     (C = '[') Or (C = '\') Or (C = ']') Or (C = '|') Then Exit;
 End;
 Fat_MakeName11 := True;
End;

{ Trouver un slot libre dans un repertoire (root ou cluster chain). }
Function Fat_FindFreeSlot(Idx: Byte; IsRoot: Boolean; StartCl: LongInt;
 Var SlotLBA: LongInt; Var SlotIdx: Integer): Boolean;
Var
 Buf: Array[0..511] Of Byte;
 SecInClu, I: Integer;
 Cur: LongInt;
 S: LongInt;
 RootCnt: Integer;
 LBA: LongInt;
 B0: Byte;
Begin
 Fat_FindFreeSlot := False;
 If IsRoot Then Begin
  RootCnt := 0;
  For S := 0 To FatVol[Idx].RootDirSectors - 1 Do Begin
   LBA := FatVol[Idx].RootStart + S;
   If Not Fat_ReadSector(Idx, LBA, Buf) Then Exit;
   For I := 0 To 15 Do Begin
    If RootCnt >= FatVol[Idx].RootEntries Then Exit;
    Inc(RootCnt);
    B0 := Buf[I * 32];
    If (B0 = 0) Or (B0 = $E5) Then Begin
     SlotLBA := LBA;
     SlotIdx := I;
     Fat_FindFreeSlot := True;
     Exit;
    End;
   End;
  End;
 End Else Begin
  Cur := StartCl;
  While (Cur >= 2) And (Not Fat_IsEOC(Idx, Cur)) Do Begin
   For SecInClu := 0 To FatVol[Idx].SectorsPerCluster - 1 Do Begin
    LBA := Fat_ClusterToLBA(Idx, Cur) + SecInClu;
    If Not Fat_ReadSector(Idx, LBA, Buf) Then Exit;
    For I := 0 To 15 Do Begin
     B0 := Buf[I * 32];
     If (B0 = 0) Or (B0 = $E5) Then Begin
      SlotLBA := LBA;
      SlotIdx := I;
      Fat_FindFreeSlot := True;
      Exit;
     End;
    End;
   End;
   Cur := Fat_NextCluster(Idx, Cur);
  End;
 End;
End;

{ Ecrire une entree 32 octets dans le slot indique. }
Function Fat_WriteDirEntry(Idx: Byte; LBA: LongInt; SlotIdx: Integer;
 Var N11: Array Of Byte; Attr: Byte; FirstClu: Word;
 Size: LongInt): Boolean;
Var
 Buf: Array[0..511] Of Byte;
 Off, I: Integer;
Begin
 Fat_WriteDirEntry := False;
 If Not Fat_ReadSector(Idx, LBA, Buf) Then Exit;
 Off := SlotIdx * 32;
 For I := 0 To 10 Do Buf[Off + I] := N11[I];
 Buf[Off + 11] := Attr;
 For I := 12 To 21 Do Buf[Off + I] := 0;
 Buf[Off + 22] := 0; Buf[Off + 23] := 0;   { time }
 Buf[Off + 24] := 0; Buf[Off + 25] := 0;   { date }
 Buf[Off + 26] := Byte(FirstClu And $FF);
 Buf[Off + 27] := Byte((FirstClu Shr 8) And $FF);
 Buf[Off + 28] := Byte(Size And $FF);
 Buf[Off + 29] := Byte((Size Shr 8) And $FF);
 Buf[Off + 30] := Byte((Size Shr 16) And $FF);
 Buf[Off + 31] := Byte((Size Shr 24) And $FF);
 Fat_WriteDirEntry := Fat_WriteSector(Idx, LBA, Buf);
End;

{ Creer un fichier dans le repertoire AbsParent du disque virtuel Idx,
  avec le nom Leaf (8.3), en lisant les donnees depuis SrcPath (hote).
  Retourne False et remplit ErrMsg en cas d echec. }
Function Fat_WriteFileFromHost(Idx: Byte; AbsParent, Leaf: String;
 SrcPath: String; Var ErrMsg: String): Boolean;
Var
 IsRoot: Boolean;
 StartCl: LongInt;
 N11: Array[0..10] Of Byte;
 Attr: Byte;
 ExClu: Word;
 ExSize: LongInt;
 SrcF: File;
 BR: Word;
 ClusterSize: LongInt;
 ClBuf: Array[0..4095] Of Byte;
 FirstClu, PrevClu, NewClu: LongInt;
 SlotLBA: LongInt;
 SlotIdx: Integer;
 TotalSize: LongInt;
 SecInClu: Integer;
 LBA: LongInt;
 SecBuf: Array[0..511] Of Byte;
 J: Integer;
Begin
 Fat_WriteFileFromHost := False;
 ErrMsg := '';
 If Not FatVol[Idx].Mounted Then Begin
  ErrMsg := 'Disque virtuel non monte';
  Exit;
 End;
 ClusterSize := LongInt(FatVol[Idx].SectorsPerCluster) * 512;
 If (ClusterSize <= 0) Or (ClusterSize > 4096) Then Begin
  ErrMsg := 'Taille de cluster non supportee';
  Exit;
 End;
 If Not Fat_MakeName11(Leaf, N11) Then Begin
  ErrMsg := 'Nom de fichier 8.3 invalide : ' + Leaf;
  Exit;
 End;
 If Not Fat_ResolveDir(Idx, AbsParent, IsRoot, StartCl) Then Begin
  ErrMsg := 'Repertoire introuvable : ' + AbsParent;
  Exit;
 End;
 If Fat_FindInDir(Idx, IsRoot, StartCl, Fat_UpStr(Leaf), Attr,
  ExClu, ExSize) Then Begin
  ErrMsg := 'Le fichier existe deja : ' + Leaf;
  Exit;
 End;
 Assign(SrcF, SrcPath);
 {$I-} Reset(SrcF, 1); {$I+}
 If IOResult <> 0 Then Begin
  ErrMsg := 'Source hote introuvable : ' + SrcPath;
  Exit;
 End;
 FirstClu := 0;
 PrevClu := 0;
 TotalSize := 0;
 Repeat
  FillChar(ClBuf, ClusterSize, 0);
  BR := 0;
  {$I-} BlockRead(SrcF, ClBuf, ClusterSize, BR); {$I+}
  If IOResult <> 0 Then Begin
   ErrMsg := 'Erreur de lecture sur l hote';
   Close(SrcF);
   Exit;
  End;
  If BR = 0 Then Break;
  NewClu := Fat_AllocCluster(Idx);
  If NewClu = 0 Then Begin
   ErrMsg := 'Disque virtuel plein';
   Close(SrcF);
   Exit;
  End;
  If FirstClu = 0 Then FirstClu := NewClu
  Else If Not Fat_SetNextCluster(Idx, PrevClu, NewClu) Then Begin
   ErrMsg := 'Erreur d ecriture FAT';
   Close(SrcF);
   Exit;
  End;
  PrevClu := NewClu;
  For SecInClu := 0 To FatVol[Idx].SectorsPerCluster - 1 Do Begin
   LBA := Fat_ClusterToLBA(Idx, NewClu) + SecInClu;
   For J := 0 To 511 Do SecBuf[J] := ClBuf[SecInClu * 512 + J];
   If Not Fat_WriteSector(Idx, LBA, SecBuf) Then Begin
    ErrMsg := 'Erreur d ecriture des donnees';
    Close(SrcF);
    Exit;
   End;
  End;
  Inc(TotalSize, BR);
 Until BR < Word(ClusterSize);
 Close(SrcF);
 If Not Fat_FindFreeSlot(Idx, IsRoot, StartCl, SlotLBA, SlotIdx) Then
 Begin
  ErrMsg := 'Repertoire plein';
  Exit;
 End;
 If Not Fat_WriteDirEntry(Idx, SlotLBA, SlotIdx, N11, $20,
  Word(FirstClu), TotalSize) Then Begin
  ErrMsg := 'Erreur d ecriture de l entree repertoire';
  Exit;
 End;
 Fat_WriteFileFromHost := True;
End;

{ Construire le chemin "X:\..." courant du terminal sur le disque virtuel }
Function Term_VirtFullPath(Var TP: TTerminalPanel): String;
Var
 DL: Char;
Begin
 If TP.VirtDrive = 0 Then DL := 'A'
 Else If TP.VirtDrive = 1 Then DL := 'B'
 Else DL := '?';
 If (TP.VirtCwd = '') Or (TP.VirtCwd = '\') Then
  Term_VirtFullPath := DL + ':\'
 Else
  Term_VirtFullPath := DL + ':' + TP.VirtCwd;
End;

{ Tenter de monter le volume si pas deja fait (lazy). }
Procedure Term_VirtEnsureMounted(Idx: Byte);
Begin
 If EmuFloppyOpen[Idx] And (Not FatVol[Idx].Mounted) Then Begin
  Fat_TryMount(Idx);
  Fat_FindVolLabel(Idx);
 End;
End;

{ Resoudre une cible (eventuellement prefixee A:/B:) en mode virtuel.
  Retourne True si la cible designe une unite FAT montee, et remplit
  Idx + AbsP (chemin absolu sur ce volume). P peut etre vide. }
Function Term_ResolveVirtTarget(Var TP: TTerminalPanel; P: String;
 Var Idx: Byte; Var AbsP: String): Boolean;
Var
 DL: Char;
 Rest: String;
 TIdx: Byte;
 HasColon: Boolean;
Begin
 Term_ResolveVirtTarget := False;
 HasColon := (Length(P) >= 2) And (P[2] = ':');
 If HasColon Then Begin
  DL := UpCase(P[1]);
  Rest := Copy(P, 3, Length(P) - 2);
  If (DL <> 'A') And (DL <> 'B') Then Exit;
  If DL = 'A' Then TIdx := 0 Else TIdx := 1;
  Term_VirtEnsureMounted(TIdx);
  If Not FatVol[TIdx].Mounted Then Exit;
  Idx := TIdx;
  If Rest = '' Then Begin
   { "A:" tout court : si TP est deja sur ce lecteur,
     utiliser le cwd virtuel ; sinon racine. }
   If TP.VirtDrive = Idx Then AbsP := TP.VirtCwd
                          Else AbsP := '\';
  End Else If Rest[1] = '\' Then Begin
   AbsP := Rest;
  End Else Begin
   { "A:foo" : relatif au cwd si meme lecteur, sinon a la racine. }
   If TP.VirtDrive = Idx Then AbsP := Fat_AbsPath(TP.VirtCwd, Rest)
                          Else AbsP := Fat_AbsPath('\', Rest);
  End;
  Term_ResolveVirtTarget := True;
  Exit;
 End;
 If TP.VirtDrive >= 0 Then Begin
  Idx := TP.VirtDrive;
  If P = '' Then AbsP := TP.VirtCwd
            Else AbsP := Fat_AbsPath(TP.VirtCwd, P);
  Term_ResolveVirtTarget := True;
 End;
End;

{ --- Copie de fichier interne (supporte disques virtuels) --- }

Function TermCopyFile(Var TP: TTerminalPanel;
 Source, Target: String): Boolean;
Var
 SourceFile, TargetFile: File;
 RecordsRead: Integer;
 Buffer: Array[1..1000] Of Byte;
 SrcIdx, DstIdx: Byte;
 SrcAbs, DstAbs: String;
 SrcIsVirt, DstIsVirt: Boolean;
 Attr: Byte;
 SrcCluster: Word;
 SrcSize: LongInt;
 Cur: LongInt;
 SecInClu, BaseSlash, I: Integer;
 LBA, Remain: LongInt;
 ToRead: Integer;
 SBuf: Array[0..511] Of Byte;
 TLast: Char;
 ParentAbs, Leaf: String;
 ErrMsg: String;
 DstIsDir: Boolean;
 DummyAttr: Byte;
 DummyClu: Word;
 DummySz: LongInt;
 SrcBase: String;
Begin
 TermCopyFile := False;
 { Si la cible se termine par ':' ou '\\' ou '/', ajouter le nom de
   base de la source pour conserver le nom du fichier. }
 If Length(Target) > 0 Then Begin
  TLast := Target[Length(Target)];
  If (TLast = ':') Or (TLast = '\') Or (TLast = '/') Then Begin
   BaseSlash := 0;
   For I := Length(Source) DownTo 1 Do
    If (Source[I] = '\') Or (Source[I] = '/') Or
       (Source[I] = ':') Then Begin
     BaseSlash := I;
     Break;
    End;
   Target := Target + Copy(Source, BaseSlash + 1,
    Length(Source) - BaseSlash);
  End;
 End;
 { Determiner si source/cible sont sur un disque virtuel }
 SrcIsVirt := Term_ResolveVirtTarget(TP, Source, SrcIdx, SrcAbs);
 DstIsVirt := Term_ResolveVirtTarget(TP, Target, DstIdx, DstAbs);
 { ---- Cible sur disque virtuel : ecriture FAT ---- }
 If DstIsVirt Then Begin
  If SrcIsVirt Then Begin
   TermAddLine(TP,
    'Copie virtuel -> virtuel non supportee pour l instant.');
   Exit;
  End;
  { Si la cible designe un repertoire (racine, '.', '..' ou entree
    FAT avec attr repertoire), ajouter le basename de la source. }
  DstIsDir := (DstAbs = '') Or (DstAbs = '\');
  If Not DstIsDir Then
   If Fat_FindPath(DstIdx, DstAbs, DummyAttr, DummyClu, DummySz) Then
    DstIsDir := (DummyAttr And $10) <> 0;
  If DstIsDir Then Begin
   BaseSlash := 0;
   For I := Length(Source) DownTo 1 Do
    If (Source[I] = '\') Or (Source[I] = '/') Or
       (Source[I] = ':') Then Begin
     BaseSlash := I;
     Break;
    End;
   SrcBase := Copy(Source, BaseSlash + 1,
    Length(Source) - BaseSlash);
   If SrcBase = '' Then Begin
    TermAddLine(TP, 'Nom de fichier cible manquant.');
    Exit;
   End;
   If (DstAbs = '') Or (DstAbs = '\') Then DstAbs := '\' + SrcBase
   Else DstAbs := DstAbs + '\' + SrcBase;
  End;
  { Decouper DstAbs en parent + feuille }
  ParentAbs := '\';
  Leaf := '';
  For I := Length(DstAbs) DownTo 1 Do
   If DstAbs[I] = '\' Then Begin
    If I = 1 Then ParentAbs := '\'
             Else ParentAbs := Copy(DstAbs, 1, I - 1);
    Leaf := Copy(DstAbs, I + 1, Length(DstAbs) - I);
    Break;
   End;
  If Leaf = '' Then Begin
   TermAddLine(TP, 'Nom de fichier cible manquant.');
   Exit;
  End;
  If Fat_WriteFileFromHost(DstIdx, ParentAbs, Leaf, Source,
   ErrMsg) Then Begin
   TermCopyFile := True;
   Exit;
  End;
  TermAddLine(TP, ErrMsg);
  Exit;
 End;
 { ---- Source sur disque virtuel : lecture via FAT ---- }
 If SrcIsVirt Then Begin
  If Not Fat_FindPath(SrcIdx, SrcAbs, Attr, SrcCluster, SrcSize) Then
  Begin
   TermAddLine(TP, 'Fichier source introuvable : ' + Source);
   Exit;
  End;
  If (Attr And $10) <> 0 Then Begin
   TermAddLine(TP, Source + ' est un repertoire.');
   Exit;
  End;
  Assign(TargetFile, Target);
  {$I-} Rewrite(TargetFile, 1); {$I+}
  If IOResult <> 0 Then Begin
   TermAddLine(TP, 'Impossible de creer : ' + Target);
   Exit;
  End;
  Cur := SrcCluster;
  Remain := SrcSize;
  While (Cur >= 2) And (Not Fat_IsEOC(SrcIdx, Cur)) And
        (Remain > 0) Do Begin
   For SecInClu := 0 To FatVol[SrcIdx].SectorsPerCluster - 1 Do Begin
    If Remain <= 0 Then Break;
    LBA := Fat_ClusterToLBA(SrcIdx, Cur) + SecInClu;
    If Not Fat_ReadSector(SrcIdx, LBA, SBuf) Then Begin
     TermAddLine(TP, 'Erreur de lecture sur l image');
     Close(TargetFile);
     Exit;
    End;
    If Remain > 512 Then ToRead := 512
                    Else ToRead := Integer(Remain);
    {$I-} BlockWrite(TargetFile, SBuf, ToRead); {$I+}
    If IOResult <> 0 Then Begin
     TermAddLine(TP, 'Erreur d ecriture : ' + Target);
     Close(TargetFile);
     Exit;
    End;
    Dec(Remain, ToRead);
   End;
   Cur := Fat_NextCluster(SrcIdx, Cur);
  End;
  Close(TargetFile);
  TermCopyFile := True;
  Exit;
 End;
 { Cas hote -> hote }
 Assign(SourceFile, Source);
 {$I-} Reset(SourceFile, 1); {$I+}
 If IOResult <> 0 Then Begin
  TermAddLine(TP, 'Fichier source introuvable : ' + Source);
  Exit;
 End;
 Assign(TargetFile, Target);
 {$I-} Rewrite(TargetFile, 1);
 BlockRead(SourceFile, Buffer, SizeOf(Buffer), RecordsRead);
 While RecordsRead > 0 Do Begin
  BlockWrite(TargetFile, Buffer, RecordsRead);
  BlockRead(SourceFile, Buffer, SizeOf(Buffer), RecordsRead);
 End;
 Close(SourceFile);
 Close(TargetFile);
 {$I+}
 TermCopyFile := True;
End;

