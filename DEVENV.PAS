  TC := GetVBNetTokenClass(HL, Line, Pos);
  Inc(Count);
 End;
 HL.Base.InBlockComment := SaveBC;
 HL.Base.InString := SaveStr;
 HL.Base.StateTop := SaveTop;
 CountVBNetTokensInLine := Count;
End;

