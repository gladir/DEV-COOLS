 Case Kind Of
  OLK_ERROR:   OutputLineColor := 4;   { rouge                  }
  OLK_WARNING: OutputLineColor := 6;   { jaune/marron           }
  OLK_SUCCESS: OutputLineColor := 2;   { vert                   }
 Else
  OutputLineColor := CLR_EDITOR_TEXT;   { noir (info)            }
 End;
End;

