{ --- Ouvrir un fichier solution .sln --- }

Procedure OpenSolutionFile(FileName: String);
Var
 I, J: Integer;
 SolIdx, ProjIdx, RefsIdx: Integer;
 SolDir: String;
 ProjFile: String;
Begin
 { Convertir en chemin absolu pour que ExtractFilePath ne soit pas vide }
 FileName := FExpand(FileName);
 ParseSolutionFile(FileName, CurrentSolution);
 SolutionLoaded := True;
 SolutionModified := False;
 { Chemin du repertoire de la solution }
 SolDir := CurrentSolution.Info.SolutionPath;
 If Length(SolDir) > 0 Then Begin
  If SolDir[Length(SolDir)] <> '\' Then
   SolDir := SolDir + '\';
 End;
 { Peupler l explorateur avec la solution }
 ClearExplorer(SolExplorer);
 SolIdx := AddExplorerNode(SolExplorer,
  CurrentSolution.Info.SolutionName, ENK_SOLUTION, -1);
 If SolIdx >= 0 Then Begin
  SolExplorer.Nodes[SolIdx].Expanded := True;
  SolExplorer.Nodes[SolIdx].HasChildren :=
   CurrentSolution.ProjectCount > 0;
  For I := 0 To CurrentSolution.ProjectCount - 1 Do Begin
   ProjIdx := AddExplorerNode(SolExplorer,
    CurrentSolution.Projects[I].ProjectName,
    ENK_PROJECT, SolIdx);
   If ProjIdx >= 0 Then Begin
    SolExplorer.Nodes[ProjIdx].Expanded := True;
    SolExplorer.Nodes[ProjIdx].HasChildren := True;
    AddExplorerNode(SolExplorer, 'Properties',
     ENK_PROPERTIES, ProjIdx);
    RefsIdx := AddExplorerNode(SolExplorer, 'References',
     ENK_REFERENCES, ProjIdx);
    { Parser le fichier projet pour charger les fichiers }
    If (I = 0) And (SolDir <> '') Then Begin
     ProjFile := SolDir
      + CurrentSolution.Projects[I].ProjectPath;
     ParseProjectFile(ProjFile, CurrentProject);
     { Ajouter les fichiers du projet dans l explorateur }
     For J := 0 To CurrentProject.FileCount - 1 Do Begin
      AddExplorerNode(SolExplorer,
       CurrentProject.Files[J].FileName,
       NodeKindFromExtension(
        CurrentProject.Files[J].FileName),
       ProjIdx);
     End;
     { Ajouter les references du projet }
     If RefsIdx >= 0 Then Begin
      For J := 0 To CurrentProject.RefCount - 1 Do Begin
       AddExplorerNode(SolExplorer,
        CurrentProject.Refs[J].ReferenceName,
        ENK_REFERENCE, RefsIdx);
      End;
      SolExplorer.Nodes[RefsIdx].HasChildren :=
       CurrentProject.RefCount > 0;
     End;
    End;
   End;
  End;
 End;
 If SolExplorer.NodeCount > 0 Then Begin
  SolExplorer.SelectedIdx := 0;
  SolExplorer.Nodes[0].Selected := True;
 End;
 SolExplorer.NeedRepaint := True;
 AddMRUEntry(MRUList, FileName);
 AppendOutput(OutputPanel,
  'Solution ouverte : ' + FileName, Ord(OTK_BUILD));
End;

{ --- Traitement de l ouverture d un dossier --- }

Procedure HandleOpenFolderConfirmed;
Var
 Folder: String;
 SR: SearchRec;
 RootIdx: Integer;
 FolderName: String;
 LastSlash, I: Integer;
Begin
 Folder := FileDlg.CurrentPath;
 If Folder = '' Then Exit;
 { Normaliser le separateur final. }
 If (Folder[Length(Folder)] <> '\') And
    (Folder[Length(Folder)] <> '/') Then
  Folder := Folder + '\';
 { Extraire le nom du dossier (dernier segment). }
 FolderName := Folder;
 If (Length(FolderName) > 0) And
    ((FolderName[Length(FolderName)] = '\') Or
     (FolderName[Length(FolderName)] = '/')) Then
  Dec(FolderName[0]);
 LastSlash := 0;
 For I := 1 To Length(FolderName) Do
  If (FolderName[I] = '\') Or (FolderName[I] = '/') Then
   LastSlash := I;
 If LastSlash > 0 Then
  FolderName := Copy(FolderName, LastSlash + 1,
   Length(FolderName) - LastSlash);
 If FolderName = '' Then FolderName := Folder;
 { Masquer la page de demarrage. }
 If StartPage.Visible Then Begin
  StartPage.Visible := False;
  FullRepaintNeeded := True;
 End;
 { Reinitialiser l explorateur avec un noeud racine 'dossier'. }
 ClearExplorer(SolExplorer);
 SolutionLoaded := False;
 SolutionModified := False;
 RootIdx := AddExplorerNode(SolExplorer, FolderName,
  ENK_FOLDER, -1);
 If RootIdx >= 0 Then Begin
  SolExplorer.Nodes[RootIdx].Expanded := True;
  { Lister sous-dossiers en premier. }
  FindFirst(Folder + '*.*', Directory, SR);
  While DosError = 0 Do Begin
   If ((SR.Attr And Directory) <> 0) And
      (SR.Name <> '.') And (SR.Name <> '..') And
      (SR.Name[1] <> '.') Then
    AddExplorerNode(SolExplorer, SR.Name, ENK_FOLDER, RootIdx);
   Dos.FindNext(SR);
  End;
  FindClose(SR);
  { Lister fichiers. }
  FindFirst(Folder + '*.*', AnyFile, SR);
  While DosError = 0 Do Begin
   If ((SR.Attr And Directory) = 0) And
      (SR.Name <> '.') And (SR.Name <> '..') Then
    AddExplorerNode(SolExplorer, SR.Name,
     NodeKindFromExtension(SR.Name), RootIdx);
   Dos.FindNext(SR);
  End;
  FindClose(SR);
  SolExplorer.Nodes[RootIdx].HasChildren :=
   SolExplorer.NodeCount > 1;
  SolExplorer.SelectedIdx := RootIdx;
  SolExplorer.Nodes[RootIdx].Selected := True;
 End;
 SolExplorer.NeedRepaint := True;
 FullRepaintNeeded := True;
 AppendOutput(OutputPanel,
  'Dossier ouvert : ' + Folder, Ord(OTK_BUILD));
End;

{ --- Traitement de l ouverture d un fichier --- }

Procedure HandleOpenFileConfirmed;
Var
 FN: String;
 Ext: String;
 Idx: Integer;
 I: Integer;
 ProjIdx: Integer;
 RelPath: String;
 ProjDir: String;
 SolDir: String;
Begin
 FN := FileDlg.SelectedFile;
 If FN = '' Then Exit;
 { Sauvegarder l editeur actuel avant d en ouvrir un autre }
 If EditorReady And (WinMgr.ActiveIdx >= 0) And
    (WinMgr.ActiveIdx < WinMgr.WinCount) And
    (Editors[WinMgr.ActiveIdx] <> Nil) Then
  Editors[WinMgr.ActiveIdx]^ := ActiveEditor;
 { Masquer la page de demarrage }
 If StartPage.Visible Then Begin
  StartPage.Visible := False;
  FullRepaintNeeded := True;
 End;
 Ext := UpCaseStr(ExtractFileExt(FN));
 { Fichier solution .sln : ouvrir comme solution }
 If Ext = '.SLN' Then Begin
  OpenSolutionFile(FN);
  FullRepaintNeeded := True;
  Exit;
 End;
 { Fichier source : verifier si deja ouvert }
 Idx := FindEditorByFileName(FN);
 If Idx >= 0 Then Begin
  ActivateWindow(Idx);
  FullRepaintNeeded := True;
  Exit;
 End;
 { Ouvrir dans un nouvel editeur }
 CreateEditorWindow(FN);
 Idx := WinMgr.ActiveIdx;
 { Charger le fichier dans l editeur alloue }
 LoadFile(Editors[Idx]^.Buffer, FN);
 ActiveEditor := Editors[Idx]^;
 Opts.SourceFile := FN;
 EditorReady := True;
 { Ajouter le fichier a l explorateur }
 If (SolExplorer.NodeCount = 0) Or
    (SolExplorer.Nodes[0].Kind <> ENK_SOLUTION) Then Begin
  ClearExplorer(SolExplorer);
  AddExplorerNode(SolExplorer, 'Solution sans nom',
   ENK_SOLUTION, -1);
  SolExplorer.Nodes[0].Expanded := True;
  SolExplorer.Nodes[0].HasChildren := True;
 End;
 { Trouver le premier noeud projet pour y ajouter le fichier }
 ProjIdx := -1;
 For I := 0 To SolExplorer.NodeCount - 1 Do
  If SolExplorer.Nodes[I].Kind = ENK_PROJECT Then Begin
   ProjIdx := I;
   Break;
  End;
 If ProjIdx < 0 Then
  ProjIdx := 0; { Ajouter sous la solution si pas de projet }
 { Calculer le chemin relatif par rapport au repertoire du projet }
 RelPath := ExtractFileName(FN);
 If SolutionLoaded And (CurrentSolution.ProjectCount > 0) Then
 Begin
  SolDir := CurrentSolution.Info.SolutionPath;
  If Length(SolDir) > 0 Then Begin
   If (SolDir[Length(SolDir)] <> '\') And
      (SolDir[Length(SolDir)] <> '/') Then
    SolDir := SolDir + '\';
  End;
  ProjDir := SolDir + ExtractFilePath(
   CurrentSolution.Projects[0].ProjectPath);
  { Normaliser les separateurs pour comparaison }
  For I := 1 To Length(ProjDir) Do
   If ProjDir[I] = '/' Then ProjDir[I] := '\';
  For I := 1 To Length(FN) Do
   If FN[I] = '/' Then FN[I] := '\';
  { Retirer le prefixe du repertoire projet du chemin absolu }
  If Length(ProjDir) > 0 Then Begin
   If UpCaseStr(Copy(FN, 1, Length(ProjDir)))
      = UpCaseStr(ProjDir) Then
    RelPath := Copy(FN, Length(ProjDir) + 1,
     Length(FN) - Length(ProjDir));
  End;
 End;
 AddExplorerNode(SolExplorer,
  RelPath,
  NodeKindFromExtension(FN), ProjIdx);
 SolExplorer.SelectedIdx := SolExplorer.NodeCount - 1;
 SolExplorer.Nodes[SolExplorer.NodeCount - 1].Selected := True;
 SolExplorer.NeedRepaint := True;
 { Ajouter le fichier dans le projet courant }
 If SolutionLoaded Then Begin
  AddFileToProject(CurrentProject, RelPath);
  SolutionModified := True;
  SaveCurrentSolution;
 End;
 AddMRUEntry(MRUList, FN);
 AppendOutput(OutputPanel, 'Fichier ouvert : ' + FN,
  Ord(OTK_BUILD));
End;

Procedure HandleNewSolutionConfirmed;
Var
 SolName: String;
 ProjName: String;
 ProjExt: String;
 ProjType: TProjectType;
 SolIdx, ProjIdx: Integer;
Begin
 SolName := NewProjDlg.SolutionName;
 ProjName := NewProjDlg.ProjectName;
 If SolName = '' Then SolName := 'MaSolution';
 If ProjName = '' Then ProjName := 'MonProjet';
 ProjType := NewProjectTypeToProjectType(NewProjDlg.SelType);
 ProjExt := NewProjectTypeExtension(NewProjDlg.SelType);
 { Initialiser la structure de la solution courante }
 CurrentSolution := CreateNewSolution(SolName,
  NewProjDlg.Location);
 AddProjectToSolution(CurrentSolution, ProjName,
  ProjName + ProjExt, ProjType);
 { Initialiser le projet courant }
 InitProject(CurrentProject);
 CurrentProject.Info.ProjectName := ProjName;
 CurrentProject.Info.AssemblyName := ProjName;
 CurrentProject.Info.RootNamespace := ProjName;
 CurrentProject.Info.ProjectType := ProjType;
 CurrentProject.Info.OutputType :=
  NewProjectTypeToOutputType(NewProjDlg.SelType);
 CurrentProject.Info.TargetFramework := 'v4.8';
 CurrentProject.Info.OutputPath := 'bin\Debug\';
 CurrentProject.CfgCount := 2;
 CurrentProject.Configs[0].ConfigName := 'Debug|AnyCPU';
 CurrentProject.Configs[0].OutputPath := 'bin\Debug\';
 CurrentProject.Configs[0].Optimize := False;
 CurrentProject.Configs[0].DebugSymbols := True;
 CurrentProject.Configs[1].ConfigName := 'Release|AnyCPU';
 CurrentProject.Configs[1].OutputPath := 'bin\Release\';
 CurrentProject.Configs[1].Optimize := True;
 CurrentProject.Configs[1].DebugSymbols := False;
 SolutionLoaded := True;
 SolutionModified := True;
 { Peupler l explorateur avec la nouvelle solution }
 ClearExplorer(SolExplorer);
 SolIdx := AddExplorerNode(SolExplorer, SolName,
  ENK_SOLUTION, -1);
 If SolIdx >= 0 Then Begin
  SolExplorer.Nodes[SolIdx].Expanded := True;
  ProjIdx := AddExplorerNode(SolExplorer, ProjName,
   ENK_PROJECT, SolIdx);
  If ProjIdx >= 0 Then Begin
   SolExplorer.Nodes[ProjIdx].Expanded := True;
   AddExplorerNode(SolExplorer, 'Properties',
    ENK_PROPERTIES, ProjIdx);
   AddExplorerNode(SolExplorer, 'References',
    ENK_REFERENCES, ProjIdx);
  End;
 End;
 If SolExplorer.NodeCount > 0 Then Begin
  SolExplorer.SelectedIdx := 0;
  SolExplorer.Nodes[0].Selected := True;
 End;
 SolExplorer.NeedRepaint := True;
 { Masquer la page de demarrage si visible }
 StartPage.Visible := False;
 FullRepaintNeeded := True;
 { Afficher un message dans le panneau de sortie }
 ClearOutput(OutputPanel, Ord(OTK_BUILD));
 AppendOutput(OutputPanel,
  'Solution ''' + SolName + ''' creee avec le projet ''' +
  ProjName + '''.',
  Ord(OTK_BUILD));
End;

{ --- Traitement de la confirmation nouveau fichier --- }

Procedure HandleNewFileConfirmed;
Var
 FN: String;
 FullPath: String;
 SolDir: String;
 ProjDir: String;
 I: Integer;
 ProjIdx: Integer;
 WIdx: Integer;
 TmpF: Text;
Begin
 FN := GetNewFileFullName(NewFileDlg);
 If FN = '' Then Exit;
 { Sauvegarder l editeur actuel }
 If EditorReady And (WinMgr.ActiveIdx >= 0) And
    (WinMgr.ActiveIdx < WinMgr.WinCount) And
    (Editors[WinMgr.ActiveIdx] <> Nil) Then
  Editors[WinMgr.ActiveIdx]^ := ActiveEditor;
 { Masquer la page de demarrage }
 If StartPage.Visible Then Begin
  StartPage.Visible := False;
  FullRepaintNeeded := True;
 End;
 { Construire le chemin complet du fichier }
 If SolutionLoaded And (CurrentSolution.ProjectCount > 0) Then
 Begin
  SolDir := CurrentSolution.Info.SolutionPath;
  If Length(SolDir) > 0 Then Begin
   If (SolDir[Length(SolDir)] <> '\') And
      (SolDir[Length(SolDir)] <> '/') Then
    SolDir := SolDir + '\';
  End;
  ProjDir := ExtractFilePath(
   CurrentSolution.Projects[0].ProjectPath);
  FullPath := SolDir + ProjDir + FN;
 End
 Else
  FullPath := FN;
 { Normaliser les separateurs }
 For I := 1 To Length(FullPath) Do
  If FullPath[I] = '/' Then FullPath[I] := '\';
 { Creer le fichier vide s il n existe pas }
 If Not FileExists(FullPath) Then Begin
  Assign(TmpF, FullPath);
  {$I-}
  Rewrite(TmpF);
  Close(TmpF);
  {$I+}
  If IOResult <> 0 Then ;
 End;
 { Verifier si le fichier est deja ouvert }
 WIdx := FindEditorByFileName(FullPath);
 If WIdx >= 0 Then Begin
  ActivateWindow(WIdx);
  FullRepaintNeeded := True;
  Exit;
 End;
 { Ouvrir dans un nouvel editeur }
 CreateEditorWindow(FullPath);
 WIdx := WinMgr.ActiveIdx;
 LoadFile(Editors[WIdx]^.Buffer, FullPath);
 ActiveEditor := Editors[WIdx]^;
 Opts.SourceFile := FullPath;
 EditorReady := True;
 { Ajouter le fichier a l explorateur }
 If (SolExplorer.NodeCount = 0) Or
    (SolExplorer.Nodes[0].Kind <> ENK_SOLUTION) Then Begin
  ClearExplorer(SolExplorer);
  AddExplorerNode(SolExplorer, 'Solution sans nom',
   ENK_SOLUTION, -1);
  SolExplorer.Nodes[0].Expanded := True;
  SolExplorer.Nodes[0].HasChildren := True;
 End;
 ProjIdx := -1;
 For I := 0 To SolExplorer.NodeCount - 1 Do
  If SolExplorer.Nodes[I].Kind = ENK_PROJECT Then Begin
   ProjIdx := I;
   Break;
  End;
 If ProjIdx < 0 Then
  ProjIdx := 0;
 AddExplorerNode(SolExplorer,
  FN, NodeKindFromExtension(FN), ProjIdx);
 SolExplorer.SelectedIdx := SolExplorer.NodeCount - 1;
 SolExplorer.Nodes[SolExplorer.NodeCount - 1].Selected := True;
 SolExplorer.NeedRepaint := True;
 { Ajouter au projet et sauvegarder }
 If SolutionLoaded Then Begin
  AddFileToProject(CurrentProject, FN);
  SolutionModified := True;
  SaveCurrentSolution;
 End;
 FullRepaintNeeded := True;
 AppendOutput(OutputPanel,
  'Nouveau fichier cree : ' + FullPath, Ord(OTK_BUILD));
End;

