{ --- Initialisation du mode graphique --- }

Procedure InitializeGraphics;
Var
 Driver, Mode: Integer;
 ErrCode: Integer;
Begin
 {$IFDEF FPC}
  Driver := VGA;
  Mode := VGAHi;
 {$ELSE}
  Driver := Detect;
  Mode := 0;
 {$ENDIF}
 InitGraph(Driver, Mode, '');
 ErrCode := GraphResult;
 If ErrCode <> grOk Then Begin
  WriteLn('DEVENV: Erreur graphique: ', GraphErrorMsg(ErrCode));
  Halt(EXIT_ERROR);
 End;
 SetColor(CLR_EDITOR_TEXT);
 SetBkColor(CLR_BACKGROUND);
 SetLineStyle(SolidLn, 0, NormWidth);
End;

{ --- Fermeture du mode graphique --- }

Procedure ShutdownGraphics;
Begin
 CloseGraph;
End;

{ --- Changement de resolution --- }

Procedure SetResolution(W, H: Integer);
Var
 Driver, Mode: Integer;
 ErrCode: Integer;
Begin
 CloseGraph;
 {$IFDEF FPC}
  Driver := VGA;
  If (W >= 1024) And (H >= 768) Then
   Mode := VGAHi    { 640x480, plus haute resolution VGA standard }
  Else If (W >= 640) And (H >= 350) Then
   Mode := VGAMed   { 640x350 }
  Else
   Mode := VGALo;   { 640x200 }
 {$ELSE}
  Driver := Detect;
  Mode := 0;
 {$ENDIF}
 InitGraph(Driver, Mode, '');
 ErrCode := GraphResult;
 If ErrCode <> grOk Then Begin
  WriteLn('DEVENV: Erreur graphique: ', GraphErrorMsg(ErrCode));
  Halt(EXIT_ERROR);
 End;
 SetColor(CLR_EDITOR_TEXT);
 SetBkColor(CLR_BACKGROUND);
 SetLineStyle(SolidLn, 0, NormWidth);
End;

