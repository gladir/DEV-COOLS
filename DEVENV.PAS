  CharH      : Integer;          { hauteur d un caractere (px)     }
  Cols       : Integer;          { colonnes effectives (40 ou 80)  }
  Rows       : Integer;          { lignes effectives (typ. 25)     }
  NeedRepaint: Boolean;          { redessin complet requis         }
