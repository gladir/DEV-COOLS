{ --- Dessiner l editeur complet --- }

Procedure DrawEditor(Var Ed: TEditor);
Var
 I, J: Integer;
 LineNo: LongInt;
 S: String;
 XPos, YPos: Integer;
 Len: Integer;
 FullLine: String;
 Colors: Array[0..255] Of Byte;
 Ch: String[1];
 IsPascal: Boolean;
 IsC: Boolean;
 IsCSharp: Boolean;
 IsAda: Boolean;
 IsAbap: Boolean;
 IsAWK: Boolean;
 IsPSP: Boolean;
 IsJava: Boolean;
 IsPython: Boolean;
 IsXML: Boolean;
 IsJSON: Boolean;
 IsYAML: Boolean;
 IsSQL: Boolean;
 Ext: String;
Begin
 { Detecter si le fichier est du Pascal }
 Ext := UpCaseStr(ExtractFileExt(Ed.Buffer.FileName));
 IsPascal := (Ext = '.PAS') Or (Ext = '.PP') Or (Ext = '.INC') Or
             (Ext = '.DPR') Or (Ext = '.LPR');
 IsC := (Ext = '.C') Or (Ext = '.H');
 IsCSharp := (Ext = '.CS');
 IsAda := (Ext = '.ADB') Or (Ext = '.ADS') Or (Ext = '.ADA');
 IsAbap := (Ext = '.ABAP') Or (Ext = '.ABP');
 IsAWK := (Ext = '.AWK');
 IsXML := (Ext = '.XML')     Or (Ext = '.XAML')   Or
          (Ext = '.HTM')     Or (Ext = '.HTML')   Or
          (Ext = '.CSPROJ')  Or (Ext = '.VBPROJ') Or
          (Ext = '.DPPROJ')  Or (Ext = '.ADAPROJ')Or
          (Ext = '.FSPROJ')  Or (Ext = '.PROJ')   Or
          (Ext = '.CONFIG')  Or (Ext = '.RESX')   Or
          (Ext = '.SVG')     Or (Ext = '.PLIST');
 IsJSON := (Ext = '.JSON') Or (Ext = '.JSONC') Or
           (Ext = '.JSON5');
 IsYAML := (Ext = '.YML') Or (Ext = '.YAML');
 IsSQL := (Ext = '.SQL') Or (Ext = '.DDL') Or (Ext = '.DML');
 IsPSP := (Ext = '.PSP');
 IsJava := (Ext = '.JAVA');
 IsPython := (Ext = '.PY');
 { Mettre a jour la gouttiere }
 Ed.GutterWidth := CalcGutterWidth(Ed.Buffer.LineCount, Ed.CharWidth);
 Ed.VisibleCols := (Ed.Width - Ed.GutterWidth) Div Ed.CharWidth;
 { Effacer la zone de l editeur }
 SetColor(CLR_EDITOR_BG);
 SetFillStyle(SolidFill, CLR_EDITOR_BG);
 Bar(Ed.X + Ed.GutterWidth, Ed.Y,
     Ed.X + Ed.Width - 1, Ed.Y + Ed.Height - 1);
 { Dessiner la surbrillance de la ligne courante }
 DrawLineHighlight(Ed);
 { Dessiner la selection }
 DrawSelection(Ed, EditorSel);
 { Dessiner le texte }
 For I := 0 To Ed.VisibleLines - 1 Do Begin
  LineNo := Ed.ScrollLine + I;
  If LineNo < Ed.Buffer.LineCount Then Begin
   FullLine := Ed.Buffer.Lines[LineNo];
   YPos := Ed.Y + I * Ed.CharHeight;
   XPos := Ed.X + Ed.GutterWidth;
   { Coloration syntaxique }
   FillChar(Colors, SizeOf(Colors), 0); { noir par defaut }
   If IsPascal And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightPascalLine(PascalHL, FullLine, Colors)
   Else If IsC And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightCLine(CHL, FullLine, Colors)
   Else If IsCSharp And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightCSharpLine(CSharpHL, FullLine, Colors)
   Else If IsAda And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightAdaLine(AdaHL, FullLine, Colors)
   Else If IsAbap And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightAbapLine(AbapHL, FullLine, Colors)
   Else If IsAWK And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightAWKLine(AWKHL, FullLine, Colors)
   Else If IsPSP And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightPSPLine(PSPHL, FullLine, Colors)
   Else If IsJava And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightJavaLine(JavaHL, FullLine, Colors)
   Else If IsPython And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightPythonLine(PythonHL, FullLine, Colors)
   Else If IsXML And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightXMLLine(XMLHL, FullLine, Colors)
   Else If IsJSON And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightJSONLine(FullLine, Colors)
   Else If IsYAML And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightYAMLLine(FullLine, Colors)
   Else If IsSQL And (Length(FullLine) > 0) And
      (Length(FullLine) <= 255) Then
    HighlightSQLLine(FullLine, Colors);
   { Extraire la partie visible }
   If Ed.ScrollCol <= Length(FullLine) Then Begin
    Len := Length(FullLine) - Ed.ScrollCol + 1;
    If Len > Ed.VisibleCols Then Len := Ed.VisibleCols;
    { Dessiner caractere par caractere avec la bonne couleur }
    For J := 0 To Len - 1 Do Begin
     SetColor(Colors[Ed.ScrollCol - 1 + J]);
     Ch := FullLine[Ed.ScrollCol + J];
     OutTextXY(XPos + J * Ed.CharWidth, YPos + 1, Ch);
    End;
   End;
  End;
 End;
 { Dessiner la gouttiere }
 DrawGutter(Ed);
 { Dessiner le curseur }
 DrawCursor(Ed);
End;

{ --- Assurer que le curseur est visible (defilement automatique) --- }

Procedure EnsureCursorVisible(Var Ed: TEditor);
Begin
 { Defilement vertical }
 If Ed.CursorLine < Ed.ScrollLine Then
  Ed.ScrollLine := Ed.CursorLine;
 If Ed.CursorLine >= Ed.ScrollLine + Ed.VisibleLines Then
  Ed.ScrollLine := Ed.CursorLine - Ed.VisibleLines + 1;
 If Ed.ScrollLine < 0 Then
  Ed.ScrollLine := 0;
 { Defilement horizontal }
 If Ed.CursorCol < Ed.ScrollCol Then
  Ed.ScrollCol := Ed.CursorCol;
 If Ed.CursorCol >= Ed.ScrollCol + Ed.VisibleCols Then
  Ed.ScrollCol := Ed.CursorCol - Ed.VisibleCols + 1;
 If Ed.ScrollCol < 1 Then
  Ed.ScrollCol := 1;
End;

{ --- Aller a une ligne donnee --- }

Procedure GotoLine(Var Ed: TEditor; ALine: LongInt);
Begin
 If ALine < 0 Then ALine := 0;
 If ALine >= Ed.Buffer.LineCount Then
  ALine := Ed.Buffer.LineCount - 1;
 Ed.CursorLine := ALine;
 EnsureCursorVisible(Ed);
End;

{ --- Aller a une colonne donnee --- }

Procedure GotoColumn(Var Ed: TEditor; ACol: LongInt);
Begin
 If ACol < 1 Then ACol := 1;
 Ed.CursorCol := ACol;
 EnsureCursorVisible(Ed);
End;

{ --- Obtenir l indentation de la ligne courante --- }

Function GetIndentation(S: String): String;
Var
 I: Integer;
Begin
 I := 1;
 While (I <= Length(S)) And (S[I] In [' ', #9]) Do
  Inc(I);
 GetIndentation := Copy(S, 1, I - 1);
End;

{ --- Gerer les clics souris dans l editeur --- }

Procedure HandleEditorMouse(Var Ed: TEditor; Ev: TEvent);
Var
 NewLine : LongInt;
 NewCol  : LongInt;
 LineLen : Integer;
Begin
 { Verifier que le clic est dans la zone texte de l editeur }
 If (Ev.MouseX < Ed.X + Ed.GutterWidth) Or
    (Ev.MouseX >= Ed.X + Ed.Width) Or
    (Ev.MouseY < Ed.Y) Or
    (Ev.MouseY >= Ed.Y + Ed.Height) Then Exit;
 { Convertir les coordonnees pixel en ligne/colonne }
 NewLine := Ed.ScrollLine +
            (Ev.MouseY - Ed.Y) Div Ed.CharHeight;
 NewCol := Ed.ScrollCol +
           (Ev.MouseX - Ed.X - Ed.GutterWidth) Div Ed.CharWidth;
 { Borner la ligne }
 If NewLine < 0 Then NewLine := 0;
 If NewLine >= Ed.Buffer.LineCount Then
  NewLine := Ed.Buffer.LineCount - 1;
 If NewLine < 0 Then NewLine := 0;
 { Borner la colonne }
 If NewCol < 1 Then NewCol := 1;
 LineLen := Length(Ed.Buffer.Lines[NewLine]);
 If NewCol > LineLen + 1 Then
  NewCol := LineLen + 1;

 If Ev.Kind = EV_MOUSE_DOWN Then Begin
  { Clic : deplacer le curseur et demarrer une possible selection }
  ClearSelection(EditorSel);
  Ed.CursorLine := NewLine;
  Ed.CursorCol := NewCol;
  StartSelection(EditorSel, NewLine, NewCol);
  EnsureCursorVisible(Ed);
  DrawEditor(Ed);
  DrawCursor(Ed);
 End
 Else If Ev.Kind = EV_MOUSE_MOVE Then Begin
  { Glissement : etendre la selection si un bouton est enfonce }
  If Ev.MouseBtn <> MB_NONE Then Begin
   Ed.CursorLine := NewLine;
   Ed.CursorCol := NewCol;
   ExtendSelection(EditorSel, NewLine, NewCol);
   EnsureCursorVisible(Ed);
   DrawEditor(Ed);
   DrawCursor(Ed);
  End;
 End
 Else If Ev.Kind = EV_MOUSE_UP Then Begin
  { Relachement : finaliser la selection }
  Ed.CursorLine := NewLine;
  Ed.CursorCol := NewCol;
  ExtendSelection(EditorSel, NewLine, NewCol);
  { Si debut = fin, pas de selection reelle }
  If (EditorSel.StartLine = EditorSel.EndLine) And
     (EditorSel.StartCol = EditorSel.EndCol) Then
   ClearSelection(EditorSel);
  EnsureCursorVisible(Ed);
  DrawEditor(Ed);
  DrawCursor(Ed);
 End;
End;

{ --- Gerer les touches de l editeur --- }

Procedure HandleEditorKey(Var Ed: TEditor; Ev: TEvent);
Var
 S, Indent: String;
 LineLen: Integer;
 TabStr: String;
 I: Integer;
 OldCh: Char;
Begin
 { Traiter les caracteres (EV_KEY_CHAR) }
 If Ev.Kind = EV_KEY_CHAR Then Begin
  Case Ev.KeyChar Of
   { Backspace }
   #8: Begin
    If Ed.CursorCol > 1 Then Begin
     Dec(Ed.CursorCol);
     S := Ed.Buffer.Lines[Ed.CursorLine];
     If Ed.CursorCol <= Length(S) Then
      PushUndo(EditorUndo, UA_DELETE, Ed.CursorLine,
       Ed.CursorCol, '', S[Ed.CursorCol], 0);
     DeleteChar(Ed.Buffer, Ed.CursorLine, Ed.CursorCol);
    End Else If Ed.CursorLine > 0 Then Begin
     LineLen := Length(Ed.Buffer.Lines[Ed.CursorLine - 1]);
     PushUndo(EditorUndo, UA_JOIN_LINE, Ed.CursorLine - 1,
      LineLen + 1, '', '', 0);
     Ed.Buffer.Lines[Ed.CursorLine - 1] :=
      Ed.Buffer.Lines[Ed.CursorLine - 1] +
      Ed.Buffer.Lines[Ed.CursorLine];
     DeleteLine(Ed.Buffer, Ed.CursorLine);
     Dec(Ed.CursorLine);
     Ed.CursorCol := LineLen + 1;
     Ed.Buffer.Modified := True;
    End;
    EnsureCursorVisible(Ed);
   End;
   { Tab }
   #9: Begin
    TabStr := '';
    For I := 1 To Ed.TabSize Do
     TabStr := TabStr + ' ';
    PushUndo(EditorUndo, UA_INSERT, Ed.CursorLine,
     Ed.CursorCol, TabStr, '', 0);
    InsertText(Ed.Buffer, Ed.CursorLine, Ed.CursorCol, TabStr);
    Inc(Ed.CursorCol, Ed.TabSize);
    EnsureCursorVisible(Ed);
   End;
   { Enter }
   #13: Begin
    PushUndo(EditorUndo, UA_SPLIT_LINE, Ed.CursorLine,
     Ed.CursorCol, '', '', 0);
    S := Ed.Buffer.Lines[Ed.CursorLine];
    InsertLine(Ed.Buffer, Ed.CursorLine + 1,
               Copy(S, Ed.CursorCol, Length(S) - Ed.CursorCol + 1));
    Ed.Buffer.Lines[Ed.CursorLine] :=
     Copy(S, 1, Ed.CursorCol - 1);
    Ed.Buffer.Modified := True;
    Inc(Ed.CursorLine);
    If Ed.AutoIndent Then Begin
     Indent := GetIndentation(
      Ed.Buffer.Lines[Ed.CursorLine - 1]);
     If Length(Indent) > 0 Then Begin
      Ed.Buffer.Lines[Ed.CursorLine] :=
       Indent + Ed.Buffer.Lines[Ed.CursorLine];
      Ed.CursorCol := Length(Indent) + 1;
     End Else
      Ed.CursorCol := 1;
    End Else
     Ed.CursorCol := 1;
    EnsureCursorVisible(Ed);
   End;
  Else
   { Caracteres imprimables }
   If (Ord(Ev.KeyChar) >= 32) And (Ord(Ev.KeyChar) <= 126) Then Begin
    If Ed.InsertMode Then Begin
     PushUndo(EditorUndo, UA_INSERT, Ed.CursorLine,
      Ed.CursorCol, Ev.KeyChar, '', 0);
     InsertChar(Ed.Buffer, Ed.CursorLine, Ed.CursorCol,
                Ev.KeyChar);
    End Else Begin
     S := Ed.Buffer.Lines[Ed.CursorLine];
     If Ed.CursorCol <= Length(S) Then Begin
      OldCh := S[Ed.CursorCol];
      PushUndo(EditorUndo, UA_REPLACE, Ed.CursorLine,
       Ed.CursorCol, Ev.KeyChar, OldCh, 0);
      S[Ed.CursorCol] := Ev.KeyChar;
     End Else Begin
      PushUndo(EditorUndo, UA_INSERT, Ed.CursorLine,
       Ed.CursorCol, Ev.KeyChar, '', 0);
      S := S + Ev.KeyChar;
     End;
     Ed.Buffer.Lines[Ed.CursorLine] := S;
     Ed.Buffer.Modified := True;
    End;
    Inc(Ed.CursorCol);
    EnsureCursorVisible(Ed);
   End;
  End;
  Exit;
 End;

 { Traiter les touches speciales (EV_KEY_DOWN) }
 If Ev.Kind <> EV_KEY_DOWN Then Exit;

 Case Ev.KeyCode Of
  { Fleche haut }
  72: Begin
   If Ed.CursorLine > 0 Then Begin
    Dec(Ed.CursorLine);
    LineLen := Length(Ed.Buffer.Lines[Ed.CursorLine]);
    If Ed.CursorCol > LineLen + 1 Then
     Ed.CursorCol := LineLen + 1;
   End;
   EnsureCursorVisible(Ed);
  End;
  { Fleche bas }
  80: Begin
   If Ed.CursorLine < Ed.Buffer.LineCount - 1 Then Begin
    Inc(Ed.CursorLine);
    LineLen := Length(Ed.Buffer.Lines[Ed.CursorLine]);
    If Ed.CursorCol > LineLen + 1 Then
     Ed.CursorCol := LineLen + 1;
   End;
   EnsureCursorVisible(Ed);
  End;
  { Fleche gauche }
  75: Begin
   If Ed.CursorCol > 1 Then
    Dec(Ed.CursorCol)
   Else If Ed.CursorLine > 0 Then Begin
    Dec(Ed.CursorLine);
    Ed.CursorCol := Length(Ed.Buffer.Lines[Ed.CursorLine]) + 1;
   End;
   EnsureCursorVisible(Ed);
  End;
  { Fleche droite }
  77: Begin
   LineLen := Length(Ed.Buffer.Lines[Ed.CursorLine]);
   If Ed.CursorCol <= LineLen Then
    Inc(Ed.CursorCol)
   Else If Ed.CursorLine < Ed.Buffer.LineCount - 1 Then Begin
    Inc(Ed.CursorLine);
    Ed.CursorCol := 1;
   End;
   EnsureCursorVisible(Ed);
  End;
  { Home }
  71: Begin
   Ed.CursorCol := 1;
   EnsureCursorVisible(Ed);
  End;
  { End }
  79: Begin
   Ed.CursorCol := Length(Ed.Buffer.Lines[Ed.CursorLine]) + 1;
   EnsureCursorVisible(Ed);
  End;
  { PgUp }
  73: Begin
   Dec(Ed.CursorLine, Ed.VisibleLines);
   If Ed.CursorLine < 0 Then Ed.CursorLine := 0;
   Dec(Ed.ScrollLine, Ed.VisibleLines);
   If Ed.ScrollLine < 0 Then Ed.ScrollLine := 0;
   LineLen := Length(Ed.Buffer.Lines[Ed.CursorLine]);
   If Ed.CursorCol > LineLen + 1 Then
    Ed.CursorCol := LineLen + 1;
   EnsureCursorVisible(Ed);
  End;
  { PgDn }
  81: Begin
   Inc(Ed.CursorLine, Ed.VisibleLines);
   If Ed.CursorLine >= Ed.Buffer.LineCount Then
    Ed.CursorLine := Ed.Buffer.LineCount - 1;
   Inc(Ed.ScrollLine, Ed.VisibleLines);
   If Ed.ScrollLine > Ed.Buffer.LineCount - Ed.VisibleLines Then Begin
    Ed.ScrollLine := Ed.Buffer.LineCount - Ed.VisibleLines;
    If Ed.ScrollLine < 0 Then Ed.ScrollLine := 0;
   End;
   LineLen := Length(Ed.Buffer.Lines[Ed.CursorLine]);
   If Ed.CursorCol > LineLen + 1 Then
    Ed.CursorCol := LineLen + 1;
   EnsureCursorVisible(Ed);
  End;
  { Insert }
  82: Begin
   Ed.InsertMode := Not Ed.InsertMode;
  End;
  { Delete }
  83: Begin
   S := Ed.Buffer.Lines[Ed.CursorLine];
   If (Ed.CursorCol >= 1) And (Ed.CursorCol <= Length(S)) Then
    PushUndo(EditorUndo, UA_DELETE, Ed.CursorLine,
     Ed.CursorCol, '', S[Ed.CursorCol], 0)
   Else If (Ed.CursorCol > Length(S)) And
           (Ed.CursorLine < Ed.Buffer.LineCount - 1) Then
    PushUndo(EditorUndo, UA_JOIN_LINE, Ed.CursorLine,
     Length(S) + 1, '', '', 0);
   DeleteChar(Ed.Buffer, Ed.CursorLine, Ed.CursorCol);
  End;
 End;
End;

{ --- Ctrl+Home : debut du fichier --- }

Procedure EditorCtrlHome(Var Ed: TEditor);
Begin
 Ed.CursorLine := 0;
 Ed.CursorCol := 1;
 Ed.ScrollLine := 0;
 Ed.ScrollCol := 1;
End;

{ --- Ctrl+End : fin du fichier --- }

Procedure EditorCtrlEnd(Var Ed: TEditor);
Begin
 If Ed.Buffer.LineCount > 0 Then Begin
  Ed.CursorLine := Ed.Buffer.LineCount - 1;
  Ed.CursorCol := Length(Ed.Buffer.Lines[Ed.CursorLine]) + 1;
 End Else Begin
  Ed.CursorLine := 0;
  Ed.CursorCol := 1;
 End;
 EnsureCursorVisible(Ed);
End;

{ --- Verifier si le curseur est a une position valide --- }

Function IsCursorValid(Var Ed: TEditor): Boolean;
Begin
 IsCursorValid := (Ed.CursorLine >= 0) And
                  (Ed.CursorLine < Ed.Buffer.LineCount) And
                  (Ed.CursorCol >= 1);
End;

{ --- Obtenir le numero de la ligne courante (1-based) --- }

Function GetCursorLineNumber(Var Ed: TEditor): LongInt;
Begin
 GetCursorLineNumber := Ed.CursorLine + 1;
End;

{ --- Obtenir le numero de la colonne courante --- }

Function GetCursorColumnNumber(Var Ed: TEditor): LongInt;
Begin
 GetCursorColumnNumber := Ed.CursorCol;
End;

{ --- Obtenir le contenu de la ligne courante --- }

Function GetCurrentLine(Var Ed: TEditor): String;
Begin
 If (Ed.CursorLine >= 0) And
    (Ed.CursorLine < Ed.Buffer.LineCount) Then
  GetCurrentLine := Ed.Buffer.Lines[Ed.CursorLine]
 Else
  GetCurrentLine := '';
End;

{ --- Obtenir le caractere sous le curseur --- }

Function GetCharAtCursor(Var Ed: TEditor): Char;
Var
 S: String;
Begin
 S := GetCurrentLine(Ed);
 If (Ed.CursorCol >= 1) And (Ed.CursorCol <= Length(S)) Then
  GetCharAtCursor := S[Ed.CursorCol]
 Else
  GetCharAtCursor := ' ';
End;

{ --- Compter les lignes visibles non vides --- }

Function CountVisibleNonEmpty(Var Ed: TEditor): Integer;
Var
 I: Integer;
 Count: Integer;
 LineNo: LongInt;
Begin
 Count := 0;
 For I := 0 To Ed.VisibleLines - 1 Do Begin
  LineNo := Ed.ScrollLine + I;
  If (LineNo >= 0) And (LineNo < Ed.Buffer.LineCount) Then
   If Length(Ed.Buffer.Lines[LineNo]) > 0 Then
    Inc(Count);
 End;
 CountVisibleNonEmpty := Count;
End;

{ --- Verifier si l editeur est en mode insertion --- }

Function IsInsertMode(Var Ed: TEditor): Boolean;
Begin
 IsInsertMode := Ed.InsertMode;
End;

