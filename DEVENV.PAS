 { ---- Emulateur 8086 integre ---- }
 { Cellule de l ecran virtuel 80x25 }
 TEmuCell = Record
  Ch  : Char;             { caractere ASCII                       }
  Fg  : Byte;             { couleur de premier plan (0..15)       }
  Bg  : Byte;             { couleur de fond (0..15)               }
 End;

 { Structure d entete d un fichier .EXE (MZ) }
 TEmuHeaderEXE = Record
  Sign        : Array[0..1] Of Char;
  LenN511     : Word;
  LenShr9     : Word;
  NmSeg       : Word;
  SizeOfHeader: Word;
  MinParagraph: Word;
  MaxParagraph: Word;
  OfsLoadStack: Word;
  SizeOfStack : Word;
  CheckSum    : Word;
  IP          : Word;
  OfsLoad     : Word;
  AdrExeTable : Word;
  NmOvr       : Word;
 End;

 { Structure du PSP (Program Segment Prefix) DOS }
 TEmuPSPRecord = Packed Record Case Byte Of
  0:(Buffer:Array[0..255] Of Byte);
  1:(Int20h        : Word;
     EndSegPrg     : Word;
     ReservedA     : Byte;
     CallDOS       : Array[0..4] Of Byte;
     Int22h        : Pointer;
     Int23h        : Pointer;
     Int24h        : Pointer;
     ParentSeg     : Word;
     Handle        : Array[0..19] Of Byte;
     EnvSeg        : Word;
     ReservedB     : LongInt;
     LenHandle     : Word;
     HandlePtrOfs  : Word;
     HandlePtrSeg  : Word;
     ReservedC     : Array[0..22] Of Byte;
     Int21h        : Word;
     RetF          : Byte);
 End;

 TEmuLongRec = Record
  Lo, Hi : Word;
 End;

 { Drapeaux du 8086 (registre FLAGS) }
 TEmuFlag = (
  EFG_CF, EFG_BIT1, EFG_PF, EFG_BIT3, EFG_AF, EFG_BIT5, EFG_ZF,
  EFG_SF, EFG_TF, EFG_IF, EFG_DF, EFG_OF
 );
 TEmuFlagSet = Set Of TEmuFlag;

 TEmuFlags = Record Case Byte Of
  0:(s    : TEmuFlagSet);
  2:(Base : Word);
  3:(Abs  : LongInt);
  4:(Data : Byte);
 End;

 { Registres generaux 8086 }
 TEmuRegs = Record Case Byte Of
  0:(EAX,ECX,EDX,EBX,ESP,EBP,ESI,EDI : LongInt);
  1:(AX,EAH,CX,ECH,DX,EDH,BX,EBH,
     SP,SPH,BP,BPH,SI,SIH,DI,DIH    : Word);
  2:(AL,AH,HAL,HAH,CL,CH,HCL,HCH,
     DL,DH,HDL,HDH,BL,BH,HBL,HBH    : Byte);
 End;

 { Registres de segments 8086 }
 TEmuSegs = Record Case Byte Of
  0:(ES,CS,SS,DS : Word);
  1:(Abs        : Array[0..3] Of Word);
 End;

 { Etat complet du CPU emule }
 TEmuMemBuf = Array[0..$FFFFF] Of Byte;
 PEmuMemBuf = ^TEmuMemBuf;
 TEmuCPU = Record
  Memory       : PEmuMemBuf;          { 1 Mo de memoire RAM emulee  }
  MemReady     : Boolean;             { buffer alloue ?             }
  Regs         : TEmuRegs;
  Segs         : TEmuSegs;
  Flags        : TEmuFlags;
  OldFlags     : TEmuFlags;
  IP, FS, GS   : Word;
  CPU          : Word;                { type de CPU (cpu8086...)    }
  Fault        : Word;                { code de fin (sf*)           }
  NextRawKey   : Byte;
  CmosPos      : Byte;
  CurrSeg      : Byte;
  OldCSeg      : Word;
  CodeBrk      : Integer;
  PSP          : Word;
  ParityTable  : Array[0..255] Of Boolean;
  ModelComputer: Word;
  CPUVendor    : Byte;
  ReadOnly     : Boolean;
  Verbose      : Boolean;
  DebugMode    : Boolean;
  LastBadOp    : Byte;
  LastBadCS    : Word;
  LastBadIP    : Word;
  HasSegOvr    : Boolean;
  SegOvr       : Word;
 End;

 { Operande decode a partir d un octet ModR/M }
 TEmuOperand = Record
  IsReg : Boolean;
  RegNum: Byte;
  Seg   : Word;
  Ofs   : Word;
  Len   : Integer;       { octets consommes (ModRM + deplacement)  }
 End;

 { ========================================================
   PHASE 0 : Etat unifie de la carte video CGA / EGA / VGA.
   --------------------------------------------------------
   La memoire video est 256 Ko ($00000-$3FFFF) car les modes
   EGA/VGA planar ont 4 plans de 64 Ko chacun a $A000.
   En mode texte, on duplique aussi le contenu vers la VRAM
   80x25 du panneau pour le rendu rapide.
   ======================================================== }
 TEmuVideoMem = Array[0..262143] Of Byte;  { 4 plans x 64K }
 PEmuVideoMem = ^TEmuVideoMem;

 TEmuVideoState = Record
  Mode       : Byte;    { 0..13h, 7Fh inconnu               }
  Width      : Word;    { largeur en pixels                  }
  Height     : Word;    { hauteur en pixels                  }
  TextCols   : Byte;    { 40 ou 80                          }
  TextRows   : Byte;    { 25 typique                         }
  BitsPerPix : Byte;    { 0=texte, 1, 2, 4, 8                }
  IsGraphic  : Boolean; { mode graphique vs texte            }
  IsPlanar   : Boolean; { EGA/VGA planar vs lineaire         }
  ChainFour  : Boolean; { mode 13h = chain-4 lineaire        }
  PageBase   : LongInt; { offset dans VideoMem               }
  Mem        : PEmuVideoMem;{ buffer 256 Ko alloue            }
  MemReady   : Boolean;
  { --- DAC (registres VGA $3C7-$3C9) --- }
  DAC        : Array[0..767] Of Byte; { 256 RGB, 6 bits     }
  DACWriteIdx: Word;    { index octet courant ecriture       }
  DACReadIdx : Word;    { index octet courant lecture        }
  DACMask    : Byte;    { masque pixel ($3C6)                }
  DACState   : Byte;    { etat $3C7 : 0=write, 3=read        }
  { --- Sequencer ($3C4 / $3C5) --- }
  SeqIdx     : Byte;
  SeqReg     : Array[0..7] Of Byte;
  { --- Graphics Controller ($3CE / $3CF) --- }
  GCIdx      : Byte;
  GCReg      : Array[0..15] Of Byte;
  { --- Attribute Controller ($3C0 / $3C1) --- }
  ACFlipFlop : Boolean; { 0=index, 1=data                    }
  ACIdx      : Byte;
  ACReg      : Array[0..31] Of Byte;
  { --- CRT Controller ($3D4 / $3D5) --- }
  CRTCIdx    : Byte;
  CRTCReg    : Array[0..31] Of Byte;
  { --- 4 latches plan (lus par MOV reg,[mem] en mode planar) --- }
  Latch      : Array[0..3] Of Byte;
  { --- CGA registers ($3D8 / $3D9) --- }
  CGAMode    : Byte;    { Mode Control Register $3D8         }
  CGAColor   : Byte;    { Color Select Register $3D9         }
  { --- Status (lecture de $3DA) --- }
  StatusRetrace : Byte; { bit 0 = HRetrace, bit 3 = VRetrace }
  { --- Dirty flag pour le rendu graphique --- }
  GfxDirty   : Boolean;
 End;

 { Etat de l emulateur 8086 + ecran virtuel + clavier }
 TEmulatorPanel = Record
  Base       : TDialog;          { dialogue de base                }
  Visible    : Boolean;          { panneau visible                 }
  Running    : Boolean;          { execution en cours              }
  Fault      : Integer;          { code de fin (sf*)               }
