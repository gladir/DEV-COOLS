{ --- CD / CHDIR / SET-LOCATION --- }

Procedure TermCmd_CD(Var TP: TTerminalPanel; ParamStr: String);
Var
 Err: Word;
 FirstParam, Dir, AbsP: String;
 IsRoot: Boolean;
 StartCl: LongInt;
 Idx: Byte;
Begin
 FirstParam := TermExtractParam(ParamStr, 1);
 { Mode disque virtuel : naviguer dans le FAT image }
 If TP.VirtDrive >= 0 Then Begin
  Idx := TP.VirtDrive;
  If Length(FirstParam) = 0 Then Begin
   TermAddLine(TP, Term_VirtFullPath(TP));
   Exit;
  End;
  { Si le parametre contient un lecteur (X:), on bascule. }
  If (Length(FirstParam) >= 2) And (FirstParam[2] = ':') Then Begin
   { Bascule de lecteur dans CD : seulement informer si X: != A: ou B: }
   TermAddLine(TP,
    'CD inter-lecteur non supporte ; utiliser X: directement.');
   Exit;
  End;
  AbsP := Fat_AbsPath(TP.VirtCwd, FirstParam);
  If Not Fat_ResolveDir(Idx, AbsP, IsRoot, StartCl) Then Begin
   TermAddLine(TP,
    'Le systeme ne trouve pas le chemin specifie.');
   Exit;
  End;
  TP.VirtCwd := AbsP;
  Exit;
 End;
 If Length(FirstParam) > 0 Then Begin
  {$I-} ChDir(FirstParam); {$I+}
  Err := IOResult;
  If Err <> 0 Then
   TermAddLine(TP, TermGetErrorMessage(Err))
  Else Begin
   GetDir(0, Dir);
   TermAddLine(TP, Dir);
  End;
 End Else Begin
  GetDir(0, Dir);
  TermAddLine(TP, Dir);
 End;
End;

{ --- CLS / CLEAR-HOST --- }

Procedure TermCmd_CLS(Var TP: TTerminalPanel);
Var
 I: Integer;
 N, NN: PTermLine;
Begin
 For I := 0 To MAX_TERM_LINES - 1 Do
  TP.Lines[I] := '';
 TP.LineCount := 0;
 TP.ScrollTop := 0;
 { Liberer la liste chainee }
 N := TP.HistHead;
 While N <> Nil Do Begin
  NN := N^.Next;
  Dispose(N);
  N := NN;
 End;
 TP.HistHead := Nil;
 TP.HistTail := Nil;
 TP.HistCount := 0;
 TP.ScrollOffset := 0;
 TP.NeedRepaint := True;
End;

{ --- DIR / LS / GET-CHILDITEM --- }

{ --- DIR style CMD (Windows command prompt) --- }

Procedure TermCmd_DIR_CMD(Var TP: TTerminalPanel; ParamStr: String);
Var
 Info: SearchRec;
 T: DateTime;
 ShowDir, S, Line: String;
 TotalFiles, TotalDirs: LongInt;
 TotalSize: LongInt;
 FirstParam: String;
 Idx: Byte;
 AbsP: String;
 IsRoot: Boolean;
 StartCl: LongInt;
 Free: LongInt;
 LblTxt: String;
Begin
 FirstParam := TermExtractParam(ParamStr, 1);
 { Mode disque virtuel : utiliser le FAT image (cwd ou cible explicite
   prefixee A:/B:). }
 If Term_ResolveVirtTarget(TP, FirstParam, Idx, AbsP) Then Begin
  If Not Fat_ResolveDir(Idx, AbsP, IsRoot, StartCl) Then Begin
   TermAddLine(TP,
    'Le systeme ne trouve pas le chemin specifie.');
   Exit;
  End;
  If FatVol[Idx].VolLabel <> '' Then
   LblTxt := FatVol[Idx].VolLabel
  Else
   LblTxt := 'no label';
  TermAddLine(TP, ' Volume in drive ' +
   Chr(Ord('A') + Idx) + ' is ' + LblTxt);
  TermAddLine(TP, '');
  If (AbsP = '') Or (AbsP = '\') Then
   TermAddLine(TP, ' Directory of ' + Chr(Ord('A') + Idx) + ':\')
  Else
   TermAddLine(TP, ' Directory of ' + Chr(Ord('A') + Idx) + ':' + AbsP);
  TermAddLine(TP, '');
  Fat_ListDir(Idx, IsRoot, StartCl, TP, 0);
  Free := Fat_FreeBytes(Idx);
  Str(Free, S);
  While Length(S) < 14 Do S := ' ' + S;
  TermAddLine(TP, '              ' + S + ' bytes free');
  Exit;
 End;
 If FirstParam = '' Then
  ShowDir := '*.*'
 Else
  ShowDir := FirstParam;
 TermAddLine(TP, ' Volume in drive C has no label.');
 TermAddLine(TP, ' Volume Serial Number is 1234-5678');
 TermAddLine(TP, '');
 TermAddLine(TP, ' Directory of ' + TermGetCurrentDir);
 TermAddLine(TP, '');
 TotalFiles := 0;
 TotalDirs := 0;
 TotalSize := 0;
 FindFirst(ShowDir, AnyFile, Info);
 While DosError = 0 Do Begin
  UnpackTime(Info.Time, T);
  Line := TermPadZeroLeft(T.Month, 2) + '/' +
   TermPadZeroLeft(T.Day, 2) + '/' +
   TermPadZeroLeft(T.Year, 4) + '  ';
  Str(T.Hour:2, S);
  Line := Line + S + ':' + TermPadZeroLeft(T.Min, 2) + '    ';
  If Info.Attr And Directory = Directory Then Begin
   Line := Line + '<DIR>          ' + Info.Name;
   Inc(TotalDirs);
  End Else Begin
   Str(Info.Size, S);
   While Length(S) < 14 Do S := ' ' + S;
   Line := Line + S + ' ' + Info.Name;
   Inc(TotalFiles);
   Inc(TotalSize, Info.Size);
  End;
  TermAddLine(TP, Line);
  FindNext(Info);
 End;
 Str(TotalFiles, S);
 While Length(S) < 16 Do S := ' ' + S;
 Str(TotalSize, Line);
 While Length(Line) < 14 Do Line := ' ' + Line;
 TermAddLine(TP, S + ' File(s)' + Line + ' bytes');
 Str(TotalDirs, S);
 While Length(S) < 16 Do S := ' ' + S;
 TermAddLine(TP, S + ' Dir(s)   bytes free');
End;

{ --- DIR style PowerShell (Get-ChildItem) --- }

Procedure TermCmd_DIR_PS(Var TP: TTerminalPanel; ParamStr: String);
Var
 Info: SearchRec;
 T: DateTime;
 ShowDir, S, Line: String;
 FirstParam: String;
 Idx: Byte;
 AbsP: String;
 IsRoot: Boolean;
 StartCl: LongInt;
Begin
 FirstParam := TermExtractParam(ParamStr, 1);
 If Term_ResolveVirtTarget(TP, FirstParam, Idx, AbsP) Then Begin
  If Not Fat_ResolveDir(Idx, AbsP, IsRoot, StartCl) Then Begin
   TermAddLine(TP,
    'Get-ChildItem : Impossible de trouver le chemin ' + AbsP);
   Exit;
  End;
  TermAddLine(TP, '');
  If (AbsP = '') Or (AbsP = '\') Then
   TermAddLine(TP,
    '    Directory: ' + Chr(Ord('A') + Idx) + ':\')
  Else
   TermAddLine(TP,
    '    Directory: ' + Chr(Ord('A') + Idx) + ':' + AbsP);
  TermAddLine(TP, '');
  TermAddLine(TP,
   'Mode                 LastWriteTime         Length Name');
  TermAddLine(TP,
   '----                 -------------         ------ ----');
  Fat_ListDir(Idx, IsRoot, StartCl, TP, 1);
  TermAddLine(TP, '');
  Exit;
 End;
 If FirstParam = '' Then
  ShowDir := '*.*'
 Else
  ShowDir := FirstParam;
 TermAddLine(TP, '');
 TermAddLine(TP,
  '    Directory: ' + TermGetCurrentDir);
 TermAddLine(TP, '');
 TermAddLine(TP,
  'Mode                 LastWriteTime         Length Name');
 TermAddLine(TP,
  '----                 -------------         ------ ----');
 FindFirst(ShowDir, AnyFile, Info);
 While DosError = 0 Do Begin
  Line := '';
  If Info.Attr And Directory = Directory Then
   Line := Line + 'd' Else Line := Line + '-';
  If Info.Attr And Archive = Archive Then
   Line := Line + 'a' Else Line := Line + '-';
  If Info.Attr And ReadOnly = ReadOnly Then
   Line := Line + 'r' Else Line := Line + '-';
  If Info.Attr And Hidden = Hidden Then
   Line := Line + 'h' Else Line := Line + '-';
  If Info.Attr And SysFile = SysFile Then
   Line := Line + 's' Else Line := Line + '-';
  Line := Line + '-  ';
  UnpackTime(Info.Time, T);
  Str(T.Month, S);
  Line := Line + S + '/' +
   TermPadZeroLeft(T.Day, 2) + '/' +
   TermPadZeroLeft(T.Year, 4) + '  ';
  Str(T.Hour, S);
  Line := Line + S + ':' +
   TermPadZeroLeft(T.Min, 2) + ' ';
  If T.Hour >= 12 Then Line := Line + 'PM'
  Else Line := Line + 'AM';
  Line := Line + '  ';
  If Info.Attr And Directory = Directory Then
   Line := Line + TermPadRight('', 14)
  Else Begin
   Str(Info.Size, S);
   While Length(S) < 14 Do S := ' ' + S;
   Line := Line + S;
  End;
  Line := Line + ' ' + Info.Name;
  TermAddLine(TP, Line);
  FindNext(Info);
 End;
 TermAddLine(TP, '');
End;

{ --- LS style Bash (colonnes simples) --- }

Procedure TermCmd_DIR_BASH(Var TP: TTerminalPanel;
 ParamStr: String);
Var
 Info: SearchRec;
 T: DateTime;
 ShowDir, S, Line: String;
 FirstParam: String;
 TotalSize: LongInt;
Begin
 FirstParam := TermExtractParam(ParamStr, 1);
 If FirstParam = '' Then
  ShowDir := '*.*'
 Else
  ShowDir := FirstParam;
 TotalSize := 0;
 FindFirst(ShowDir, AnyFile, Info);
 While DosError = 0 Do Begin
  Inc(TotalSize, Info.Size);
  FindNext(Info);
 End;
 Str(TotalSize Div 1024, S);
 TermAddLine(TP, 'total ' + S);
 FindFirst(ShowDir, AnyFile, Info);
 While DosError = 0 Do Begin
  { drwxr-xr-x style permissions }
  Line := '';
  If Info.Attr And Directory = Directory Then
   Line := 'd' Else Line := '-';
  If Info.Attr And ReadOnly = ReadOnly Then
   Line := Line + 'r--r--r--'
  Else
   Line := Line + 'rw-rw-rw-';
  Line := Line + ' 1 user user ';
  Str(Info.Size, S);
  While Length(S) < 8 Do S := ' ' + S;
  Line := Line + S + ' ';
  UnpackTime(Info.Time, T);
  Case T.Month Of
   1: S := 'Jan'; 2: S := 'Feb'; 3: S := 'Mar';
   4: S := 'Apr'; 5: S := 'May'; 6: S := 'Jun';
   7: S := 'Jul'; 8: S := 'Aug'; 9: S := 'Sep';
   10: S := 'Oct'; 11: S := 'Nov'; 12: S := 'Dec';
  Else S := '???';
  End;
  Line := Line + S + ' ';
  Str(T.Day:2, S);
  Line := Line + S + ' ';
  Str(T.Hour:2, S);
  Line := Line + S + ':' + TermPadZeroLeft(T.Min, 2) + ' ';
  Line := Line + Info.Name;
  TermAddLine(TP, Line);
  FindNext(Info);
 End;
End;

{ --- DIR style AmigaDOS --- }

Procedure TermCmd_DIR_AMIGA(Var TP: TTerminalPanel;
 ParamStr: String);
Var
 Info: SearchRec;
 ShowDir, S: String;
 FirstParam: String;
 TotalFiles, TotalDirs: LongInt;
Begin
 FirstParam := TermExtractParam(ParamStr, 1);
 If FirstParam = '' Then
  ShowDir := '*.*'
 Else
  ShowDir := FirstParam;
 TotalFiles := 0;
 TotalDirs := 0;
 FindFirst(ShowDir, AnyFile, Info);
 While DosError = 0 Do Begin
  If Info.Attr And Directory = Directory Then Begin
   TermAddLine(TP, '  ' + Info.Name + '           (dir)');
   Inc(TotalDirs);
  End Else Begin
   Str(Info.Size, S);
   While Length(S) < 8 Do S := ' ' + S;
   TermAddLine(TP, '  ' + Info.Name);
   Inc(TotalFiles);
  End;
  FindNext(Info);
 End;
 Str(TotalFiles, S);
 TermAddLine(TP, S + ' files - ' +
  TermPadZeroLeft(TotalDirs, 1) + ' directories');
End;

