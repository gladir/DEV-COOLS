   Loaded := M6809_LoadDECB(BinaryPath, EntryAddr16);
  End
  Else If TargetCPU = '-CTO7' Then Begin
   M6809_Variant := 3;
   Loaded := M6809_LoadThomsonBin(BinaryPath, EntryAddr16);
  End
  Else If TargetCPU = '-CTO8' Then Begin
   M6809_Variant := 4;
   Loaded := M6809_LoadThomsonBin(BinaryPath, EntryAddr16);
  End
  Else If TargetCPU = '-CMO5' Then Begin
   M6809_Variant := 5;
