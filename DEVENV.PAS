               CPU6502_Mem[EA] := M; CPU6502_DoSBC(M); End;
    $FF: Begin EA := CPU6502_AmABX; M := (CPU6502_Mem[EA] + 1) And $FF;
               CPU6502_Mem[EA] := M; CPU6502_DoSBC(M); End;
    { SLO : ASL + ORA }
    $03: Begin EA := CPU6502_AmIZX; M := CPU6502_DoASL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Or M;
               CPU6502_SetNZ(CPU6502_A); End;
    $07: Begin EA := CPU6502_AmZP;  M := CPU6502_DoASL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Or M;
               CPU6502_SetNZ(CPU6502_A); End;
    $0F: Begin EA := CPU6502_AmABS; M := CPU6502_DoASL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Or M;
               CPU6502_SetNZ(CPU6502_A); End;
    $13: Begin EA := CPU6502_AmIZY; M := CPU6502_DoASL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Or M;
               CPU6502_SetNZ(CPU6502_A); End;
    $17: Begin EA := CPU6502_AmZPX; M := CPU6502_DoASL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Or M;
               CPU6502_SetNZ(CPU6502_A); End;
    $1B: Begin EA := CPU6502_AmABY; M := CPU6502_DoASL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Or M;
               CPU6502_SetNZ(CPU6502_A); End;
    $1F: Begin EA := CPU6502_AmABX; M := CPU6502_DoASL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Or M;
               CPU6502_SetNZ(CPU6502_A); End;
    { RLA : ROL + AND }
    $23: Begin EA := CPU6502_AmIZX; M := CPU6502_DoROL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A And M;
               CPU6502_SetNZ(CPU6502_A); End;
    $27: Begin EA := CPU6502_AmZP;  M := CPU6502_DoROL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A And M;
               CPU6502_SetNZ(CPU6502_A); End;
    $2F: Begin EA := CPU6502_AmABS; M := CPU6502_DoROL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A And M;
               CPU6502_SetNZ(CPU6502_A); End;
    $33: Begin EA := CPU6502_AmIZY; M := CPU6502_DoROL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A And M;
               CPU6502_SetNZ(CPU6502_A); End;
    $37: Begin EA := CPU6502_AmZPX; M := CPU6502_DoROL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A And M;
               CPU6502_SetNZ(CPU6502_A); End;
    $3B: Begin EA := CPU6502_AmABY; M := CPU6502_DoROL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A And M;
               CPU6502_SetNZ(CPU6502_A); End;
    $3F: Begin EA := CPU6502_AmABX; M := CPU6502_DoROL(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A And M;
               CPU6502_SetNZ(CPU6502_A); End;
    { SRE : LSR + EOR }
    $43: Begin EA := CPU6502_AmIZX; M := CPU6502_DoLSR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Xor M;
               CPU6502_SetNZ(CPU6502_A); End;
    $47: Begin EA := CPU6502_AmZP;  M := CPU6502_DoLSR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Xor M;
               CPU6502_SetNZ(CPU6502_A); End;
    $4F: Begin EA := CPU6502_AmABS; M := CPU6502_DoLSR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Xor M;
               CPU6502_SetNZ(CPU6502_A); End;
    $53: Begin EA := CPU6502_AmIZY; M := CPU6502_DoLSR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Xor M;
               CPU6502_SetNZ(CPU6502_A); End;
    $57: Begin EA := CPU6502_AmZPX; M := CPU6502_DoLSR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Xor M;
               CPU6502_SetNZ(CPU6502_A); End;
    $5B: Begin EA := CPU6502_AmABY; M := CPU6502_DoLSR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Xor M;
               CPU6502_SetNZ(CPU6502_A); End;
    $5F: Begin EA := CPU6502_AmABX; M := CPU6502_DoLSR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_A := CPU6502_A Xor M;
               CPU6502_SetNZ(CPU6502_A); End;
    { RRA : ROR + ADC }
    $63: Begin EA := CPU6502_AmIZX; M := CPU6502_DoROR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_DoADC(M); End;
    $67: Begin EA := CPU6502_AmZP;  M := CPU6502_DoROR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_DoADC(M); End;
    $6F: Begin EA := CPU6502_AmABS; M := CPU6502_DoROR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_DoADC(M); End;
    $73: Begin EA := CPU6502_AmIZY; M := CPU6502_DoROR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_DoADC(M); End;
    $77: Begin EA := CPU6502_AmZPX; M := CPU6502_DoROR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_DoADC(M); End;
    $7B: Begin EA := CPU6502_AmABY; M := CPU6502_DoROR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_DoADC(M); End;
    $7F: Begin EA := CPU6502_AmABX; M := CPU6502_DoROR(CPU6502_Mem[EA]);
               CPU6502_Mem[EA] := M; CPU6502_DoADC(M); End;
    { ANC : AND + carry copie de bit 7 }
    $0B, $2B: Begin EA := CPU6502_AmIMM;
                    CPU6502_A := CPU6502_A And CPU6502_Mem[EA];
                    CPU6502_SetNZ(CPU6502_A);
                    CPU6502_SetC((CPU6502_A And $80) <> 0); End;
    { ALR : AND + LSR }
    $4B: Begin EA := CPU6502_AmIMM;
               CPU6502_A := CPU6502_A And CPU6502_Mem[EA];
               CPU6502_A := CPU6502_DoLSR(CPU6502_A); End;
    { ARR : AND + ROR (simplifie, drapeaux V/C non exacts) }
    $6B: Begin EA := CPU6502_AmIMM;
               CPU6502_A := CPU6502_A And CPU6502_Mem[EA];
               CPU6502_A := CPU6502_DoROR(CPU6502_A); End;
    { AXS : (A AND X) - imm -> X }
    $CB: Begin EA := CPU6502_AmIMM;
               TmpW := (Word(CPU6502_A And CPU6502_X) -
                        Word(CPU6502_Mem[EA])) And $1FF;
               CPU6502_X := TmpW And $FF;
               CPU6502_SetC(TmpW < $100);
               CPU6502_SetNZ(CPU6502_X); End;
    { SBC alias }
    $EB: Begin EA := CPU6502_AmIMM; CPU6502_DoSBC(CPU6502_Mem[EA]); End;
    { JAM / KIL : halt and catch fire sur 6502 NMOS reel. Pour la       }
    { robustesse de l emulateur (cas ou un kernel deborde une table de  }
    { donnees), on les traite en NOP 1-octet silencieux.                }
    $02, $12, $22, $32, $42, $52, $62, $72, $92, $B2, $D2, $F2: ;
    { Famille instable - opcodes "magic value" dependants de la temp    }
    { du die sur silicium reel. Traites en NOP avec consommation des   }
    { octets d operande pour avancer PC correctement.                   }
    { SHY abs,X / SHX abs,Y / SHA abs,Y / SHA (zp),Y / TAS abs,Y / LAS  }
    $9C: Inc(CPU6502_PC, 2);                              { SHY abs,X }
    $9E: Inc(CPU6502_PC, 2);                              { SHX abs,Y }
    $9F: Inc(CPU6502_PC, 2);                              { SHA abs,Y }
    $93: Inc(CPU6502_PC, 1);                              { SHA (zp),Y }
    $9B: Inc(CPU6502_PC, 2);                              { TAS abs,Y }
    $BB: Begin EA := CPU6502_AmABY;                       { LAS abs,Y }
               M := CPU6502_Mem[EA] And CPU6502_S;
               CPU6502_A := M; CPU6502_X := M; CPU6502_S := M;
               CPU6502_SetNZ(M); End;
    { XAA imm : magic value. Traite en AND imm sur A (approximation).   }
    $8B: Begin EA := CPU6502_AmIMM;
               CPU6502_A := CPU6502_A And CPU6502_Mem[EA];
               CPU6502_SetNZ(CPU6502_A); End;
  Else
    EmuVScr_WriteStr(CPU6502_Panel^,
     '[opcode 6502 inconnu $' + M68K_HexN(Op, 2) +
     ' au PC $' + M68K_HexN(CPU6502_PC - 1, 4) + ']');
    CPU6502_Halted := True;
    CPU6502_ExitCode := 1;
  End;
  { Penalite page-cross : +1 cycle pour les opcodes LECTURE en abs,X /  }
  { abs,Y / (zp),Y quand l indexation traverse une frontiere de page.  }
  If CPU6502_PageCrossed And (CPU6502_PageCrossTab[Op] <> 0) Then
    Inc(CPU6502_LastCyc);
End;

{ Charger un binaire AppleII (.bin) : 4 octets header (load_lo load_hi    }
{ len_lo len_hi) + payload                                                 }
Function CPU6502_LoadAppleBin(Const FileName: String;
                              Var EntryAddr: Word): Boolean;
Var
  F: File;
  Hdr: Array[0..3] Of Byte;
  Load: Word;
  Len, I: LongInt;
  B: Byte;
Begin
  CPU6502_LoadAppleBin := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  BlockRead(F, Hdr, 4);
  Load := Hdr[0] Or (Word(Hdr[1]) Shl 8);
  Len  := Hdr[2] Or (LongInt(Hdr[3]) Shl 8);
  EntryAddr := Load;
  For I := 0 To Len - 1 Do
  Begin
    BlockRead(F, B, 1);
    If (Load + I) <= $FFFF Then CPU6502_Mem[Load + I] := B;
  End;
  Close(F);
  CPU6502_LoadAppleBin := True;
End;

{ Charger un PRG C64 : 2 octets load addr LE + payload }
Function CPU6502_LoadC64Prg(Const FileName: String;
                            Var EntryAddr: Word): Boolean;
Var
  F: File;
  Hdr: Array[0..1] Of Byte;
  Load: Word;
  I: LongInt;
  B: Byte;
Begin
  CPU6502_LoadC64Prg := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  BlockRead(F, Hdr, 2);
  Load := Hdr[0] Or (Word(Hdr[1]) Shl 8);
  EntryAddr := Load;
  I := 0;
  While Not Eof(F) Do
  Begin
    BlockRead(F, B, 1);
    If (Load + I) <= $FFFF Then CPU6502_Mem[Load + I] := B;
    Inc(I);
  End;
  Close(F);
  { Si l image charge a $0801 et que les premiers octets ressemblent a un  }
  { stub BASIC SYS (link non nul, ligne 10, token $9E), sauter le stub et  }
  { entrer directement au JMP suivant ($080D = 2061). Sinon entree = Load. }
  If (Load = $0801) And (CPU6502_Mem[$0805] = $9E) Then
    EntryAddr := $080D;
  CPU6502_LoadC64Prg := True;
End;

{ Charger Atari .xex : suite de segments [FF FF] start_lo start_hi          }
{ end_lo end_hi data...                                                     }
Function CPU6502_LoadAtariXex(Const FileName: String;
                              Var EntryAddr: Word): Boolean;
Var
  F: File;
  B: Byte;
  Hdr: Array[0..3] Of Byte;
  Magic: Word;
  StartA, EndA: Word;
  I: LongInt;
  First: Boolean;
Begin
  CPU6502_LoadAtariXex := False;
  EntryAddr := 0;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  First := True;
  While Not Eof(F) Do
  Begin
    { Lire un en-tete de segment FF FF puis 4 octets }
    BlockRead(F, B, 1); If Eof(F) Then Break;
    Magic := B;
    BlockRead(F, B, 1); Magic := Magic Or (Word(B) Shl 8);
    If Magic <> $FFFF Then
    Begin
      { Pas un segment FF FF : essayer de continuer apres alignement }
      Continue;
    End;
    BlockRead(F, Hdr, 4);
    StartA := Hdr[0] Or (Word(Hdr[1]) Shl 8);
    EndA   := Hdr[2] Or (Word(Hdr[3]) Shl 8);
    If First Then Begin EntryAddr := StartA; First := False; End;
    For I := 0 To EndA - StartA Do
    Begin
      BlockRead(F, B, 1);
      If (StartA + I) <= $FFFF Then CPU6502_Mem[StartA + I] := B;
    End;
  End;
  Close(F);
  CPU6502_LoadAtariXex := True;
End;
{$POP}

{ Charger un fichier brut (NES, A2600) }
Function CPU6502_LoadRaw(Const FileName: String;
                         LoadAddr: Word; SkipHeader: Integer): Boolean;
Var
  F: File;
  B: Byte;
  I: LongInt;
Begin
  CPU6502_LoadRaw := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  For I := 1 To SkipHeader Do BlockRead(F, B, 1);
  I := 0;
  While Not Eof(F) Do
  Begin
    BlockRead(F, B, 1);
    If (LoadAddr + I) <= $FFFF Then CPU6502_Mem[LoadAddr + I] := B;
    Inc(I);
  End;
  Close(F);
  CPU6502_LoadRaw := True;
End;

Procedure CPU6502_Reset(EntryAddr: Word);
Var I: LongInt;
Begin
  CPU6502_A := 0;
  CPU6502_X := 0;
  CPU6502_Y := 0;
  CPU6502_P := $24;        { I=1, U=1 }
  CPU6502_S := $FD;
  CPU6502_PC := EntryAddr;
  CPU6502_Halted := False;
  CPU6502_ExitCode := 0;
  CPU6502_Cycles := 0;
  { Sentinelle de fin : push d une adresse de halt sur la pile.       }
  { En mode NES (3) et Atari 2600 (4), $FFFE/$FFFF est le vecteur     }
  { IRQ/BRK reel en ROM : ne pas ecraser.                              }
  If (CPU6502_Variant <> 3) And (CPU6502_Variant <> 4) Then Begin
    CPU6502_Mem[$FFFE] := $00;
    CPU6502_Mem[$FFFF] := $00;
  End;
End;

{ ========================================================================== }
{ EMULATEUR Z80 INTEGRE                                                      }
{ Couvre TRS-80 (-CTRS80), MSX (-CMSX) et Coleco Adam (-CADAM).               }
{ Sous-ensemble couvrant : page principale (NOP/LD/INC/DEC/ADD/SUB/AND/OR/    }
{ XOR/CP/JP/JR/CALL/RET/PUSH/POP/EX/HALT/RST), prefixe CB (BIT/RES/SET/RLC/   }
{ RRC/RL/RR/SLA/SRA/SRL), prefixe ED (LDIR/LDDR/IN/OUT/IM).                   }
{ Traps de sortie :                                                           }
{   CALL $0005 (BDOS CP/M)  : C=2 -> imprime E ; C=9 -> imprime $-string DE   }
{   CALL $00A2 (MSX BIOS CHPUT) : imprime A                                   }
{   CALL $0033 (TRS-80 PUTCH)   : imprime A                                   }
{ Drapeaux F : SZ-H-PNC (S=$80 Z=$40 H=$10 P/V=$04 N=$02 C=$01).             }
{ ========================================================================== }

{ Acces 16-bit registres-paires }
Function Z80_GetBC: Word;
Begin Z80_GetBC := (Word(Z80_B) Shl 8) Or Z80_C; End;
Function Z80_GetDE: Word;
Begin Z80_GetDE := (Word(Z80_D) Shl 8) Or Z80_E; End;
Function Z80_GetHL: Word;
Begin Z80_GetHL := (Word(Z80_H) Shl 8) Or Z80_L; End;
Function Z80_GetAF: Word;
Begin Z80_GetAF := (Word(Z80_A) Shl 8) Or Z80_F; End;

Procedure Z80_SetBC(V: Word);
Begin Z80_B := (V Shr 8) And $FF; Z80_C := V And $FF; End;
Procedure Z80_SetDE(V: Word);
Begin Z80_D := (V Shr 8) And $FF; Z80_E := V And $FF; End;
Procedure Z80_SetHL(V: Word);
Begin Z80_H := (V Shr 8) And $FF; Z80_L := V And $FF; End;
Procedure Z80_SetAF(V: Word);
Begin Z80_A := (V Shr 8) And $FF; Z80_F := V And $FF; End;

Function Z80_Rd(A: Word): Byte;
Begin Z80_Rd := Z80_Mem[A]; End;
Procedure Z80_Wr(A: Word; V: Byte);
Begin Z80_Mem[A] := V; End;

Function Z80_Rd16(A: Word): Word;
Begin Z80_Rd16 := Z80_Mem[A] Or (Word(Z80_Mem[Word(A + 1)]) Shl 8); End;
Procedure Z80_Wr16(A: Word; V: Word);
Begin
  Z80_Mem[A] := V And $FF;
  Z80_Mem[Word(A + 1)] := (V Shr 8) And $FF;
End;

Procedure Z80_Push(V: Word);
Begin
  Z80_SP := Z80_SP - 2;
  Z80_Wr16(Z80_SP, V);
End;

Function Z80_Pop: Word;
Begin
  Z80_Pop := Z80_Rd16(Z80_SP);
  Z80_SP := Z80_SP + 2;
End;

Function Z80_FetchByte: Byte;
Begin
  Z80_FetchByte := Z80_Mem[Z80_PC];
  Z80_PC := (Z80_PC + 1) And $FFFF;
End;

Function Z80_FetchWord: Word;
Var Lo, Hi: Byte;
Begin
  Lo := Z80_FetchByte;
  Hi := Z80_FetchByte;
  Z80_FetchWord := Lo Or (Word(Hi) Shl 8);
End;

{ Drapeau parite paire }
Function Z80_Parity(V: Byte): Boolean;
Var C, I: Integer;
Begin
  C := 0;
  For I := 0 To 7 Do
    If (V And (1 Shl I)) <> 0 Then Inc(C);
  Z80_Parity := (C And 1) = 0;
End;

{ Met S et Z d apres V }
Procedure Z80_SetSZ(V: Byte);
Begin
  Z80_F := Z80_F And Not $C0;
  If V = 0 Then Z80_F := Z80_F Or $40;
  If (V And $80) <> 0 Then Z80_F := Z80_F Or $80;
End;

Procedure Z80_DoAdd(V: Byte);
Var
  R: Word;
  H: Byte;
Begin
  R := Z80_A + V;
  H := ((Z80_A And $0F) + (V And $0F)) And $10;
  Z80_F := 0;
  If (R And $FF) = 0 Then Z80_F := Z80_F Or $40;
  If (R And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If H <> 0 Then Z80_F := Z80_F Or $10;
  If R > $FF Then Z80_F := Z80_F Or $01;
  If (((Z80_A Xor V) And $80) = 0) And
     (((Z80_A Xor (R And $FF)) And $80) <> 0) Then
    Z80_F := Z80_F Or $04;
  Z80_A := R And $FF;
End;

Procedure Z80_DoAdc(V: Byte);
Var
  Cy: Byte;
  R: Word;
  H: Byte;
Begin
  If (Z80_F And $01) <> 0 Then Cy := 1 Else Cy := 0;
  R := Z80_A + V + Cy;
  H := ((Z80_A And $0F) + (V And $0F) + Cy) And $10;
  Z80_F := 0;
  If (R And $FF) = 0 Then Z80_F := Z80_F Or $40;
  If (R And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If H <> 0 Then Z80_F := Z80_F Or $10;
  If R > $FF Then Z80_F := Z80_F Or $01;
  If (((Z80_A Xor V) And $80) = 0) And
     (((Z80_A Xor (R And $FF)) And $80) <> 0) Then
    Z80_F := Z80_F Or $04;
  Z80_A := R And $FF;
End;

Procedure Z80_DoSub(V: Byte);
Var
  R: Integer;
  H: Byte;
Begin
  R := Z80_A - V;
  H := ((Z80_A And $0F) - (V And $0F)) And $10;
  Z80_F := $02; { N=1 }
  If (R And $FF) = 0 Then Z80_F := Z80_F Or $40;
  If (R And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If H <> 0 Then Z80_F := Z80_F Or $10;
  If R < 0 Then Z80_F := Z80_F Or $01;
  If (((Z80_A Xor V) And $80) <> 0) And
     (((Z80_A Xor (R And $FF)) And $80) <> 0) Then
    Z80_F := Z80_F Or $04;
  Z80_A := R And $FF;
End;

Procedure Z80_DoSbc(V: Byte);
Var
  Cy: Byte;
  R: Integer;
  H: Byte;
Begin
  If (Z80_F And $01) <> 0 Then Cy := 1 Else Cy := 0;
  R := Z80_A - V - Cy;
  H := ((Z80_A And $0F) - (V And $0F) - Cy) And $10;
  Z80_F := $02;
  If (R And $FF) = 0 Then Z80_F := Z80_F Or $40;
  If (R And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If H <> 0 Then Z80_F := Z80_F Or $10;
  If R < 0 Then Z80_F := Z80_F Or $01;
  Z80_A := R And $FF;
End;

Procedure Z80_DoCp(V: Byte);
Var
  Sav: Byte;
Begin
  Sav := Z80_A;
  Z80_DoSub(V);
  Z80_A := Sav;
End;

Procedure Z80_DoAnd(V: Byte);
Begin
  Z80_A := Z80_A And V;
  Z80_F := $10;
  If Z80_A = 0 Then Z80_F := Z80_F Or $40;
  If (Z80_A And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If Z80_Parity(Z80_A) Then Z80_F := Z80_F Or $04;
End;

Procedure Z80_DoOr(V: Byte);
Begin
  Z80_A := Z80_A Or V;
  Z80_F := 0;
  If Z80_A = 0 Then Z80_F := Z80_F Or $40;
  If (Z80_A And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If Z80_Parity(Z80_A) Then Z80_F := Z80_F Or $04;
End;

Procedure Z80_DoXor(V: Byte);
Begin
  Z80_A := Z80_A Xor V;
  Z80_F := 0;
  If Z80_A = 0 Then Z80_F := Z80_F Or $40;
  If (Z80_A And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If Z80_Parity(Z80_A) Then Z80_F := Z80_F Or $04;
End;

Function Z80_DoInc8(V: Byte): Byte;
Begin
  V := (V + 1) And $FF;
  Z80_F := Z80_F And $01; { conserve C }
  If V = 0 Then Z80_F := Z80_F Or $40;
  If (V And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If (V And $0F) = 0 Then Z80_F := Z80_F Or $10;
  If V = $80 Then Z80_F := Z80_F Or $04;
  Z80_DoInc8 := V;
End;

Function Z80_DoDec8(V: Byte): Byte;
Begin
  V := (V - 1) And $FF;
  Z80_F := (Z80_F And $01) Or $02; { conserve C, N=1 }
  If V = 0 Then Z80_F := Z80_F Or $40;
  If (V And $80) <> 0 Then Z80_F := Z80_F Or $80;
  If (V And $0F) = $0F Then Z80_F := Z80_F Or $10;
  If V = $7F Then Z80_F := Z80_F Or $04;
  Z80_DoDec8 := V;
End;

{ Lit/ecrit registre 8-bit selon code 0..7 (B C D E H L (HL) A) }
Function Z80_GetR8(N: Integer): Byte;
Begin
  Case N Of
    0: Z80_GetR8 := Z80_B;
    1: Z80_GetR8 := Z80_C;
    2: Z80_GetR8 := Z80_D;
    3: Z80_GetR8 := Z80_E;
    4: Z80_GetR8 := Z80_H;
    5: Z80_GetR8 := Z80_L;
    6: Z80_GetR8 := Z80_Rd(Z80_GetHL);
    7: Z80_GetR8 := Z80_A;
  Else Z80_GetR8 := 0;
  End;
End;

Procedure Z80_SetR8(N: Integer; V: Byte);
Begin
  Case N Of
    0: Z80_B := V;
    1: Z80_C := V;
    2: Z80_D := V;
    3: Z80_E := V;
    4: Z80_H := V;
    5: Z80_L := V;
    6: Z80_Wr(Z80_GetHL, V);
    7: Z80_A := V;
  End;
End;

{ Trap : si CALL vers une adresse magique connue, executer service et      }
{ retourner. Retourne True si le CALL a ete intercepte.                    }
Function Z80_TryTrap(Target: Word): Boolean;
Var
  Ch: Byte;
  Addr: Word;
Begin
  Z80_TryTrap := False;
  { BDOS CP/M : $0005 - utilise par MSX-DOS et Adam EOS/CP/M }
  If Target = $0005 Then
  Begin
    Case Z80_C Of
      2: Begin { Conout : print E }
           Ch := Z80_E;
           If Ch = $0D Then Begin
             EmuVScr_PutChar(Z80_Panel^, #13);
             EmuVScr_PutChar(Z80_Panel^, #10);
           End Else If Ch = $0A Then
             { ignore : LF souvent suit CR }
           Else If Ch >= 32 Then
             EmuVScr_PutChar(Z80_Panel^, Chr(Ch));
         End;
      9: Begin { Print $-string at DE }
           Addr := Z80_GetDE;
           While (Addr <= $FFFF) And (Z80_Mem[Addr] <> Ord('$')) Do
           Begin
             Ch := Z80_Mem[Addr];
             If Ch = $0D Then Begin
               EmuVScr_PutChar(Z80_Panel^, #13);
               EmuVScr_PutChar(Z80_Panel^, #10);
             End Else If Ch >= 32 Then
               EmuVScr_PutChar(Z80_Panel^, Chr(Ch));
             Inc(Addr);
           End;
         End;
      0: Begin { System reset / exit }
           Z80_Halted := True;
           Z80_ExitCode := 0;
         End;
    End;
    Z80_TryTrap := True;
    Exit;
  End;
  { MSX BIOS CHPUT : $00A2 - imprime A }
  If Target = $00A2 Then
  Begin
    Ch := Z80_A;
    If Ch = $0D Then Begin
      EmuVScr_PutChar(Z80_Panel^, #13);
      EmuVScr_PutChar(Z80_Panel^, #10);
    End Else If (Ch >= 32) And (Ch < 128) Then
      EmuVScr_PutChar(Z80_Panel^, Chr(Ch));
    Z80_TryTrap := True;
    Exit;
  End;
  { TRS-80 ROM PUTCH : $0033 - imprime A }
  If Target = $0033 Then
  Begin
    Ch := Z80_A;
    If Ch = $0D Then Begin
      EmuVScr_PutChar(Z80_Panel^, #13);
      EmuVScr_PutChar(Z80_Panel^, #10);
    End Else If (Ch >= 32) And (Ch < 128) Then
      EmuVScr_PutChar(Z80_Panel^, Chr(Ch));
    Z80_TryTrap := True;
    Exit;
  End;
End;

{ Prefixe CB - rotations, decalages, BIT/SET/RES }
Procedure Z80_StepCB;
Var
  Op, V, R: Byte;
  Bit: Integer;
  RegN: Integer;
  C0: Byte;
Begin
  Op := Z80_FetchByte;
  RegN := Op And $07;
  V := Z80_GetR8(RegN);
  Case Op And $C0 Of
    $00: { rotations/decalages }
      Begin
        Case (Op Shr 3) And $07 Of
          0: Begin { RLC }
               C0 := (V Shr 7) And 1;
               R := ((V Shl 1) Or C0) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
          1: Begin { RRC }
               C0 := V And 1;
               R := ((V Shr 1) Or (C0 Shl 7)) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
          2: Begin { RL }
               C0 := (V Shr 7) And 1;
               R := ((V Shl 1) Or (Z80_F And $01)) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
          3: Begin { RR }
               C0 := V And 1;
               R := ((V Shr 1) Or ((Z80_F And $01) Shl 7)) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
          4: Begin { SLA }
               C0 := (V Shr 7) And 1;
               R := (V Shl 1) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
          5: Begin { SRA }
               C0 := V And 1;
               R := ((V Shr 1) Or (V And $80)) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
          6: Begin { SLL (non documente) }
               C0 := (V Shr 7) And 1;
               R := ((V Shl 1) Or 1) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
          7: Begin { SRL }
               C0 := V And 1;
               R := (V Shr 1) And $FF;
               Z80_F := 0;
               If C0 <> 0 Then Z80_F := Z80_F Or $01;
             End;
        Else R := V;
        End;
        If R = 0 Then Z80_F := Z80_F Or $40;
        If (R And $80) <> 0 Then Z80_F := Z80_F Or $80;
        If Z80_Parity(R) Then Z80_F := Z80_F Or $04;
        Z80_SetR8(RegN, R);
      End;
    $40: { BIT n,r }
      Begin
        Bit := (Op Shr 3) And $07;
        Z80_F := (Z80_F And $01) Or $10;
        If (V And (1 Shl Bit)) = 0 Then Z80_F := Z80_F Or $44;
      End;
    $80: { RES n,r }
      Begin
        Bit := (Op Shr 3) And $07;
        Z80_SetR8(RegN, V And Not (1 Shl Bit));
      End;
    $C0: { SET n,r }
      Begin
        Bit := (Op Shr 3) And $07;
        Z80_SetR8(RegN, V Or (1 Shl Bit));
      End;
  End;
End;

{ Prefixe ED - LDIR/LDDR/IN/OUT/extensions }
Procedure Z80_StepED;
Var
  Op: Byte;
  Addr: Word;
Begin
  Op := Z80_FetchByte;
  Case Op Of
    $46, $66: Z80_IM := 0;
    $56, $76: Z80_IM := 1;
    $5E, $7E: Z80_IM := 2;
    $47: Z80_I := Z80_A;
    $4F: Z80_R := Z80_A;
    $57: Begin Z80_A := Z80_I; Z80_SetSZ(Z80_A); End;
    $5F: Begin Z80_A := Z80_R; Z80_SetSZ(Z80_A); End;
    $43: Begin Addr := Z80_FetchWord; Z80_Wr16(Addr, Z80_GetBC); End;
    $4B: Begin Addr := Z80_FetchWord; Z80_SetBC(Z80_Rd16(Addr)); End;
    $53: Begin Addr := Z80_FetchWord; Z80_Wr16(Addr, Z80_GetDE); End;
    $5B: Begin Addr := Z80_FetchWord; Z80_SetDE(Z80_Rd16(Addr)); End;
    $63: Begin Addr := Z80_FetchWord; Z80_Wr16(Addr, Z80_GetHL); End;
    $6B: Begin Addr := Z80_FetchWord; Z80_SetHL(Z80_Rd16(Addr)); End;
    $73: Begin Addr := Z80_FetchWord; Z80_Wr16(Addr, Z80_SP); End;
    $7B: Begin Addr := Z80_FetchWord; Z80_SP := Z80_Rd16(Addr); End;
    $A0: Begin { LDI }
           Z80_Wr(Z80_GetDE, Z80_Rd(Z80_GetHL));
           Z80_SetHL(Z80_GetHL + 1); Z80_SetDE(Z80_GetDE + 1);
           Z80_SetBC(Z80_GetBC - 1);
           Z80_F := Z80_F And $C1;
           If Z80_GetBC <> 0 Then Z80_F := Z80_F Or $04;
         End;
    $A8: Begin { LDD }
           Z80_Wr(Z80_GetDE, Z80_Rd(Z80_GetHL));
           Z80_SetHL(Z80_GetHL - 1); Z80_SetDE(Z80_GetDE - 1);
           Z80_SetBC(Z80_GetBC - 1);
           Z80_F := Z80_F And $C1;
           If Z80_GetBC <> 0 Then Z80_F := Z80_F Or $04;
         End;
    $B0: Begin { LDIR }
           While Z80_GetBC <> 0 Do
           Begin
             Z80_Wr(Z80_GetDE, Z80_Rd(Z80_GetHL));
             Z80_SetHL(Z80_GetHL + 1); Z80_SetDE(Z80_GetDE + 1);
             Z80_SetBC(Z80_GetBC - 1);
           End;
           Z80_F := Z80_F And $C1;
         End;
    $B8: Begin { LDDR }
           While Z80_GetBC <> 0 Do
           Begin
             Z80_Wr(Z80_GetDE, Z80_Rd(Z80_GetHL));
             Z80_SetHL(Z80_GetHL - 1); Z80_SetDE(Z80_GetDE - 1);
             Z80_SetBC(Z80_GetBC - 1);
           End;
           Z80_F := Z80_F And $C1;
         End;
  End; { autres opcodes ED ignores }
End;

Procedure Z80_Step;
Var
  Op, V, R: Byte;
  W, Addr: Word;
  Cond: Boolean;
  Off: ShortInt;
  Tmp: Byte;
  Tmp16: Word;
  Sum: LongInt;
Begin
  Op := Z80_FetchByte;
  Case Op Of
    $00: ; { NOP }
    $76: Begin Z80_Halted := True; Z80_ExitCode := 0; End; { HALT }
    { LD r,r' (groupe $40-$7F sauf $76 = HALT)                         }
    { Inclut LD r,(HL) ($46,$4E,$56,$5E,$66,$6E,$7E) et LD (HL),r       }
    { ($70-$75,$77) via Z80_GetR8(6)/Z80_SetR8(6) qui accedent (HL).    }
    $40..$45, $46, $47, $48..$4D, $4E, $4F,
    $50..$55, $56, $57, $58..$5D, $5E, $5F,
    $60..$65, $66, $67, $68..$6D, $6E, $6F,
    $70..$75, $77, $78..$7D, $7E, $7F:
      Z80_SetR8((Op Shr 3) And $07, Z80_GetR8(Op And $07));
    { LD r,n }
    $06, $0E, $16, $1E, $26, $2E, $36, $3E:
      Z80_SetR8((Op Shr 3) And $07, Z80_FetchByte);
    { LD BC,nn / DE,nn / HL,nn / SP,nn }
    $01: Z80_SetBC(Z80_FetchWord);
    $11: Z80_SetDE(Z80_FetchWord);
    $21: Z80_SetHL(Z80_FetchWord);
    $31: Z80_SP := Z80_FetchWord;
    { LD (BC),A / LD (DE),A / LD A,(BC) / LD A,(DE) }
    $02: Z80_Wr(Z80_GetBC, Z80_A);
    $12: Z80_Wr(Z80_GetDE, Z80_A);
    $0A: Z80_A := Z80_Rd(Z80_GetBC);
    $1A: Z80_A := Z80_Rd(Z80_GetDE);
    { LD (nn),HL / LD HL,(nn) / LD (nn),A / LD A,(nn) }
    $22: Begin Addr := Z80_FetchWord; Z80_Wr16(Addr, Z80_GetHL); End;
    $2A: Begin Addr := Z80_FetchWord; Z80_SetHL(Z80_Rd16(Addr)); End;
    $32: Begin Addr := Z80_FetchWord; Z80_Wr(Addr, Z80_A); End;
    $3A: Begin Addr := Z80_FetchWord; Z80_A := Z80_Rd(Addr); End;
    { INC/DEC rr }
    $03: Z80_SetBC(Z80_GetBC + 1);
    $0B: Z80_SetBC(Z80_GetBC - 1);
    $13: Z80_SetDE(Z80_GetDE + 1);
    $1B: Z80_SetDE(Z80_GetDE - 1);
    $23: Z80_SetHL(Z80_GetHL + 1);
    $2B: Z80_SetHL(Z80_GetHL - 1);
    $33: Z80_SP := Z80_SP + 1;
    $3B: Z80_SP := Z80_SP - 1;
    { INC r / DEC r }
    $04: Z80_B := Z80_DoInc8(Z80_B);
    $05: Z80_B := Z80_DoDec8(Z80_B);
    $0C: Z80_C := Z80_DoInc8(Z80_C);
    $0D: Z80_C := Z80_DoDec8(Z80_C);
    $14: Z80_D := Z80_DoInc8(Z80_D);
    $15: Z80_D := Z80_DoDec8(Z80_D);
    $1C: Z80_E := Z80_DoInc8(Z80_E);
    $1D: Z80_E := Z80_DoDec8(Z80_E);
    $24: Z80_H := Z80_DoInc8(Z80_H);
    $25: Z80_H := Z80_DoDec8(Z80_H);
    $2C: Z80_L := Z80_DoInc8(Z80_L);
    $2D: Z80_L := Z80_DoDec8(Z80_L);
    $34: Begin V := Z80_DoInc8(Z80_Rd(Z80_GetHL));
              Z80_Wr(Z80_GetHL, V); End;
    $35: Begin V := Z80_DoDec8(Z80_Rd(Z80_GetHL));
              Z80_Wr(Z80_GetHL, V); End;
    $3C: Z80_A := Z80_DoInc8(Z80_A);
    $3D: Z80_A := Z80_DoDec8(Z80_A);
    { ADD HL,rr }
    $09: Begin Sum := Z80_GetHL + Z80_GetBC;
              Z80_F := Z80_F And $C4;
              If Sum > $FFFF Then Z80_F := Z80_F Or $01;
              Z80_SetHL(Sum And $FFFF); End;
    $19: Begin Sum := Z80_GetHL + Z80_GetDE;
              Z80_F := Z80_F And $C4;
              If Sum > $FFFF Then Z80_F := Z80_F Or $01;
              Z80_SetHL(Sum And $FFFF); End;
    $29: Begin Sum := Z80_GetHL + Z80_GetHL;
              Z80_F := Z80_F And $C4;
              If Sum > $FFFF Then Z80_F := Z80_F Or $01;
              Z80_SetHL(Sum And $FFFF); End;
    $39: Begin Sum := LongInt(Z80_GetHL) + Z80_SP;
              Z80_F := Z80_F And $C4;
              If Sum > $FFFF Then Z80_F := Z80_F Or $01;
              Z80_SetHL(Sum And $FFFF); End;
    { ADD/ADC/SUB/SBC/AND/XOR/OR/CP A,r }
    $80..$87: Z80_DoAdd(Z80_GetR8(Op And 7));
    $88..$8F: Z80_DoAdc(Z80_GetR8(Op And 7));
    $90..$97: Z80_DoSub(Z80_GetR8(Op And 7));
    $98..$9F: Z80_DoSbc(Z80_GetR8(Op And 7));
    $A0..$A7: Z80_DoAnd(Z80_GetR8(Op And 7));
    $A8..$AF: Z80_DoXor(Z80_GetR8(Op And 7));
    $B0..$B7: Z80_DoOr(Z80_GetR8(Op And 7));
    $B8..$BF: Z80_DoCp(Z80_GetR8(Op And 7));
    { ADD/ADC/SUB/SBC/AND/XOR/OR/CP A,n }
    $C6: Z80_DoAdd(Z80_FetchByte);
    $CE: Z80_DoAdc(Z80_FetchByte);
    $D6: Z80_DoSub(Z80_FetchByte);
    $DE: Z80_DoSbc(Z80_FetchByte);
    $E6: Z80_DoAnd(Z80_FetchByte);
    $EE: Z80_DoXor(Z80_FetchByte);
    $F6: Z80_DoOr(Z80_FetchByte);
    $FE: Z80_DoCp(Z80_FetchByte);
    { Rotations sur A }
    $07: Begin { RLCA } Tmp := (Z80_A Shr 7) And 1;
              Z80_A := ((Z80_A Shl 1) Or Tmp) And $FF;
              Z80_F := (Z80_F And $C4) Or Tmp; End;
    $0F: Begin { RRCA } Tmp := Z80_A And 1;
              Z80_A := ((Z80_A Shr 1) Or (Tmp Shl 7)) And $FF;
              Z80_F := (Z80_F And $C4) Or Tmp; End;
    $17: Begin { RLA } Tmp := (Z80_A Shr 7) And 1;
              Z80_A := ((Z80_A Shl 1) Or (Z80_F And 1)) And $FF;
              Z80_F := (Z80_F And $C4) Or Tmp; End;
    $1F: Begin { RRA } Tmp := Z80_A And 1;
              Z80_A := ((Z80_A Shr 1) Or ((Z80_F And 1) Shl 7)) And $FF;
              Z80_F := (Z80_F And $C4) Or Tmp; End;
    { CPL / SCF / CCF }
    $2F: Begin Z80_A := Z80_A Xor $FF;
              Z80_F := Z80_F Or $12; End;
    $37: Z80_F := (Z80_F And $C4) Or $01;
    $3F: Z80_F := (Z80_F And $C4) Xor $01;
    { JP nn / JP cc,nn }
    $C3: Z80_PC := Z80_FetchWord;
    $C2: Begin W := Z80_FetchWord;
              If (Z80_F And $40) = 0 Then Z80_PC := W; End; { NZ }
    $CA: Begin W := Z80_FetchWord;
              If (Z80_F And $40) <> 0 Then Z80_PC := W; End; { Z }
    $D2: Begin W := Z80_FetchWord;
              If (Z80_F And $01) = 0 Then Z80_PC := W; End; { NC }
    $DA: Begin W := Z80_FetchWord;
              If (Z80_F And $01) <> 0 Then Z80_PC := W; End; { C }
    $E2: Begin W := Z80_FetchWord;
              If (Z80_F And $04) = 0 Then Z80_PC := W; End; { PO }
    $EA: Begin W := Z80_FetchWord;
              If (Z80_F And $04) <> 0 Then Z80_PC := W; End; { PE }
    $F2: Begin W := Z80_FetchWord;
              If (Z80_F And $80) = 0 Then Z80_PC := W; End; { P }
    $FA: Begin W := Z80_FetchWord;
              If (Z80_F And $80) <> 0 Then Z80_PC := W; End; { M }
    { JR e / JR cc,e }
    $18: Begin Off := ShortInt(Z80_FetchByte);
              Z80_PC := Z80_PC + Off; End;
    $20: Begin Off := ShortInt(Z80_FetchByte);
              If (Z80_F And $40) = 0 Then Z80_PC := Z80_PC + Off; End;
    $28: Begin Off := ShortInt(Z80_FetchByte);
              If (Z80_F And $40) <> 0 Then Z80_PC := Z80_PC + Off; End;
    $30: Begin Off := ShortInt(Z80_FetchByte);
              If (Z80_F And $01) = 0 Then Z80_PC := Z80_PC + Off; End;
    $38: Begin Off := ShortInt(Z80_FetchByte);
              If (Z80_F And $01) <> 0 Then Z80_PC := Z80_PC + Off; End;
    { DJNZ }
    $10: Begin Off := ShortInt(Z80_FetchByte);
              Z80_B := (Z80_B - 1) And $FF;
              If Z80_B <> 0 Then Z80_PC := Z80_PC + Off; End;
    { JP (HL) }
    $E9: Z80_PC := Z80_GetHL;
    { CALL nn / CALL cc,nn }
    $CD: Begin W := Z80_FetchWord;
              If Z80_TryTrap(W) Then
                { trap : ne pas faire le call reel }
              Else Begin
                Z80_Push(Z80_PC);
                Z80_PC := W;
              End;
            End;
    $C4, $CC, $D4, $DC, $E4, $EC, $F4, $FC:
      Begin
        W := Z80_FetchWord;
        Case (Op Shr 3) And $07 Of
          0: Cond := (Z80_F And $40) = 0;
          1: Cond := (Z80_F And $40) <> 0;
          2: Cond := (Z80_F And $01) = 0;
          3: Cond := (Z80_F And $01) <> 0;
          4: Cond := (Z80_F And $04) = 0;
          5: Cond := (Z80_F And $04) <> 0;
          6: Cond := (Z80_F And $80) = 0;
        Else Cond := (Z80_F And $80) <> 0;
        End;
        If Cond Then
        Begin
          If Z80_TryTrap(W) Then
          Else Begin Z80_Push(Z80_PC); Z80_PC := W; End;
        End;
      End;
    { RET / RET cc }
    $C9: Begin
           If Z80_SP >= $FFFE Then Begin
             Z80_Halted := True; Z80_ExitCode := 0;
           End Else Z80_PC := Z80_Pop;
         End;
    $C0, $C8, $D0, $D8, $E0, $E8, $F0, $F8:
      Begin
        Case (Op Shr 3) And $07 Of
          0: Cond := (Z80_F And $40) = 0;
          1: Cond := (Z80_F And $40) <> 0;
          2: Cond := (Z80_F And $01) = 0;
          3: Cond := (Z80_F And $01) <> 0;
          4: Cond := (Z80_F And $04) = 0;
          5: Cond := (Z80_F And $04) <> 0;
          6: Cond := (Z80_F And $80) = 0;
        Else Cond := (Z80_F And $80) <> 0;
        End;
        If Cond Then Z80_PC := Z80_Pop;
      End;
    { RST n }
    $C7, $CF, $D7, $DF, $E7, $EF, $F7, $FF:
      Begin
        W := Op And $38;
        If Z80_TryTrap(W) Then
        Else Begin Z80_Push(Z80_PC); Z80_PC := W; End;
      End;
    { PUSH/POP }
    $C5: Z80_Push(Z80_GetBC);
    $D5: Z80_Push(Z80_GetDE);
    $E5: Z80_Push(Z80_GetHL);
    $F5: Z80_Push(Z80_GetAF);
    $C1: Z80_SetBC(Z80_Pop);
    $D1: Z80_SetDE(Z80_Pop);
    $E1: Z80_SetHL(Z80_Pop);
    $F1: Z80_SetAF(Z80_Pop);
    { EX }
    $EB: Begin Tmp16 := Z80_GetDE;
              Z80_SetDE(Z80_GetHL); Z80_SetHL(Tmp16); End;
    $E3: Begin Tmp16 := Z80_Rd16(Z80_SP);
              Z80_Wr16(Z80_SP, Z80_GetHL); Z80_SetHL(Tmp16); End;
    $08: Begin Tmp16 := Z80_GetAF;
              Z80_SetAF((Word(Z80_AA) Shl 8) Or Z80_FF);
              Z80_AA := (Tmp16 Shr 8) And $FF;
              Z80_FF := Tmp16 And $FF; End;
    $D9: Begin { EXX }
              Tmp := Z80_B; Z80_B := Z80_BB; Z80_BB := Tmp;
              Tmp := Z80_C; Z80_C := Z80_CC; Z80_CC := Tmp;
              Tmp := Z80_D; Z80_D := Z80_DD; Z80_DD := Tmp;
              Tmp := Z80_E; Z80_E := Z80_EE; Z80_EE := Tmp;
              Tmp := Z80_H; Z80_H := Z80_HH; Z80_HH := Tmp;
              Tmp := Z80_L; Z80_L := Z80_LL; Z80_LL := Tmp;
            End;
    { Interruptions }
    $F3: Begin Z80_IFF1 := False; Z80_IFF2 := False; End;
    $FB: Begin Z80_IFF1 := True;  Z80_IFF2 := True;  End;
    { Prefixes }
    $CB: Z80_StepCB;
    $ED: Z80_StepED;
    { I/O - traite comme NOP avec lecture/ecriture port factice }
    $D3: V := Z80_FetchByte; { OUT (n),A }
    $DB: Begin V := Z80_FetchByte; Z80_A := 0; End; { IN A,(n) }
    { DD/FD : prefixes IX/IY non implementes - les sauter }
    $DD, $FD:
      Begin
        { Avancer d un opcode supplementaire pour la majorite des cas. }
        V := Z80_FetchByte;
      End;
  Else
    EmuVScr_WriteStr(Z80_Panel^,
     '[opcode Z80 inconnu $' + M68K_HexN(Op, 2) +
     ' au PC $' + M68K_HexN(Word(Z80_PC - 1), 4) + ']');
    Z80_Halted := True;
    Z80_ExitCode := 1;
  End;
End;

{ Charger un binaire CP/M COM (MSX-DOS, Adam EOS) : raw a $0100 }
Function Z80_LoadCom(Const FileName: String;
                     Var EntryAddr: Word): Boolean;
Var
  F: File;
  B: Byte;
  I: LongInt;
Begin
  Z80_LoadCom := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  EntryAddr := $0100;
  I := 0;
  While Not Eof(F) Do
  Begin
    BlockRead(F, B, 1);
    If ($0100 + I) <= $FFFF Then Z80_Mem[$0100 + I] := B;
    Inc(I);
  End;
  Close(F);
  Z80_LoadCom := True;
End;

{ Charger un binaire TRS-80 .cmd : segments avec headers                   }
{ Format : type(1) len(1) [addr(2)] data(len-2) ; type=01 data, 02 entry,  }
{ autres : ignore. Si echec, fallback : raw a $5200.                       }
Function Z80_LoadCmd(Const FileName: String;
                     Var EntryAddr: Word): Boolean;
Var
  F: File;
  B, T, L: Byte;
  Addr: Word;
  I: LongInt;
  HasEntry: Boolean;
  GotData: Boolean;
Begin
  Z80_LoadCmd := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  HasEntry := False;
  GotData := False;
  EntryAddr := $5200;
  While Not Eof(F) Do
  Begin
    BlockRead(F, T, 1);
    If Eof(F) Then Break;
    BlockRead(F, L, 1);
    Case T Of
      $01: Begin { Load block }
             BlockRead(F, B, 1); Addr := B;
             BlockRead(F, B, 1); Addr := Addr Or (Word(B) Shl 8);
             { Longueur reelle = L-2 (mais 0 signifie 256) }
             If L = 0 Then I := 254
             Else If L = 1 Then I := 255
             Else I := L - 2;
             While I > 0 Do
             Begin
               If Eof(F) Then Break;
               BlockRead(F, B, 1);
               Z80_Mem[Addr] := B;
               Addr := (Addr + 1) And $FFFF;
               Dec(I);
             End;
             GotData := True;
           End;
      $02: Begin { Entry }
             BlockRead(F, B, 1); Addr := B;
             BlockRead(F, B, 1); Addr := Addr Or (Word(B) Shl 8);
             EntryAddr := Addr;
             HasEntry := True;
           End;
    Else
      { Sauter L octets }
      For I := 1 To L Do
        If Not Eof(F) Then BlockRead(F, B, 1);
    End;
  End;
  Close(F);
  If Not GotData Then
  Begin
    { Fallback : recharger en raw a $5200 }
    Assign(F, FileName);
    {$I-} Reset(F, 1); {$I+}
    If IOResult <> 0 Then Exit;
    I := 0;
    While Not Eof(F) Do
    Begin
      BlockRead(F, B, 1);
      If ($5200 + I) <= $FFFF Then Z80_Mem[$5200 + I] := B;
      Inc(I);
    End;
    Close(F);
    EntryAddr := $5200;
  End;
  If Not HasEntry Then EntryAddr := $5200;
  Z80_LoadCmd := True;
End;

Procedure Z80_Reset(EntryAddr: Word);
Begin
  Z80_A := 0; Z80_F := 0;
  Z80_B := 0; Z80_C := 0;
  Z80_D := 0; Z80_E := 0;
  Z80_H := 0; Z80_L := 0;
  Z80_AA := 0; Z80_FF := 0;
  Z80_BB := 0; Z80_CC := 0;
  Z80_DD := 0; Z80_EE := 0;
  Z80_HH := 0; Z80_LL := 0;
  Z80_IX := 0; Z80_IY := 0;
  Z80_I := 0; Z80_R := 0;
  Z80_IFF1 := False; Z80_IFF2 := False;
  Z80_IM := 0;
  Z80_SP := $FFFE;
  Z80_PC := EntryAddr;
  Z80_Halted := False;
  Z80_ExitCode := 0;
  Z80_Cycles := 0;
  { Sentinelle : si le programme fait RET au sommet, atterrit ici. }
  Z80_Mem[$FFFE] := $00;
  Z80_Mem[$FFFF] := $00;
End;

{ ========================================================================== }
{ EMULATEUR Motorola 6809 INTEGRE                                            }
{ Couvre Tandy CoCo 3 (-CCOCO3), Dragon 32/64 (-CDRAGON32/-CDRAGON64),       }
{ Thomson TO7 (-CTO7), TO8 (-CTO8) et MO5 (-CMO5).                            }
{ Sous-ensemble couvrant la majorite des opcodes : page 1 complete (LD/ST/   }
{ ADD/SUB/CMP/AND/OR/EOR/BIT/INC/DEC/NEG/COM/CLR/TST/ASL/ASR/LSR/ROL/ROR/    }
{ JMP/JSR/RTS/RTI/BRA/Bcc/LBRA/LBcc/PSH/PUL/TFR/EXG/SWI/NOP/ABX/SEX/MUL),    }
{ pages 2 et 3 (LDY/STY/CMPY/CMPS/CMPU/CMPD/LBcc).                          }
{ Modes d adressage : immediat (8/16), direct (DP+offset 8b), etendu (16b), }
{ indexe simple (sans offset, offset 5/8/16, A/B/D offset, +/-/++/--, PC).   }
{ Drapeaux CC : EFHINZVC ($80,$40,$20,$10,$08,$04,$02,$01).                  }
{ Traps de sortie :                                                          }
{   JSR $A002 (CoCo3 BASIC CHROUT)  : imprime A                              }
{   JSR $BB5A (Dragon CHROUT)       : imprime A                              }
{   JSR $E803 (Thomson PUTC)        : imprime A                              }
{ ========================================================================== }

{ Forward : trappes I/O CoCo 3 (definition plus loin avec les autres
  routines Coco3_*) }
Function  Coco3_IoWrite(Addr: Word; V: Byte): Boolean; Forward;
Function  Coco3_IoRead(Addr: Word): Byte;             Forward;

Function M6809_Rd(A: Word): Byte;
Begin
  If Coco3_Active And (A >= $FF00) Then
    M6809_Rd := Coco3_IoRead(A)
  Else
    M6809_Rd := M6809_Mem[A];
End;
Procedure M6809_Wr(A: Word; V: Byte);
Begin
  If Coco3_Active And (A >= $FF00) Then
    If Coco3_IoWrite(A, V) Then Exit;
  M6809_Mem[A] := V;
End;
Function M6809_Rd16(A: Word): Word;
Begin M6809_Rd16 := (Word(M6809_Rd(A)) Shl 8) Or
                    M6809_Rd(Word(A + 1)); End;
Procedure M6809_Wr16(A: Word; V: Word);
Begin
  M6809_Wr(A, (V Shr 8) And $FF);
  M6809_Wr(Word(A + 1), V And $FF);
End;

Function M6809_GetD: Word;
Begin M6809_GetD := (Word(M6809_A) Shl 8) Or M6809_B; End;
Procedure M6809_SetD(V: Word);
Begin M6809_A := (V Shr 8) And $FF; M6809_B := V And $FF; End;

Function M6809_FetchByte: Byte;
Begin
  M6809_FetchByte := M6809_Mem[M6809_PC];
  M6809_PC := (M6809_PC + 1) And $FFFF;
End;

Function M6809_FetchWord: Word;
Var Hi, Lo: Byte;
Begin
  Hi := M6809_FetchByte;
  Lo := M6809_FetchByte;
  M6809_FetchWord := (Word(Hi) Shl 8) Or Lo;
End;

{ Drapeaux CC : E=$80 F=$40 H=$20 I=$10 N=$08 Z=$04 V=$02 C=$01 }
Procedure M6809_SetNZ8(V: Byte);
Begin
  M6809_CC := M6809_CC And Not $0C;
  If V = 0 Then M6809_CC := M6809_CC Or $04;
  If (V And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
End;

Procedure M6809_SetNZ16(V: Word);
Begin
  M6809_CC := M6809_CC And Not $0C;
  If V = 0 Then M6809_CC := M6809_CC Or $04;
  If (V And $8000) <> 0 Then M6809_CC := M6809_CC Or $08;
End;

Procedure M6809_Push8S(V: Byte);
Begin M6809_S := (M6809_S - 1) And $FFFF; M6809_Wr(M6809_S, V); End;
Function M6809_Pop8S: Byte;
Begin M6809_Pop8S := M6809_Rd(M6809_S); M6809_S := (M6809_S + 1) And $FFFF; End;
Procedure M6809_Push16S(V: Word);
Begin M6809_Push8S(V And $FF); M6809_Push8S((V Shr 8) And $FF); End;
Function M6809_Pop16S: Word;
Var Hi: Byte;
Begin Hi := M6809_Pop8S;
  M6809_Pop16S := (Word(Hi) Shl 8) Or M6809_Pop8S; End;
Procedure M6809_Push8U(V: Byte);
Begin M6809_U := (M6809_U - 1) And $FFFF; M6809_Wr(M6809_U, V); End;
Function M6809_Pop8U: Byte;
Begin M6809_Pop8U := M6809_Rd(M6809_U); M6809_U := (M6809_U + 1) And $FFFF; End;

{ Resoudre une adresse en mode indexe (post-byte) }
Function M6809_GetIdxReg(N: Integer): Word;
Begin
  Case N Of
    0: M6809_GetIdxReg := M6809_X;
    1: M6809_GetIdxReg := M6809_Y;
    2: M6809_GetIdxReg := M6809_U;
    3: M6809_GetIdxReg := M6809_S;
  Else M6809_GetIdxReg := 0;
  End;
End;

Procedure M6809_SetIdxReg(N: Integer; V: Word);
Begin
  Case N Of
    0: M6809_X := V;
    1: M6809_Y := V;
    2: M6809_U := V;
    3: M6809_S := V;
  End;
End;

Function M6809_AmIndexed: Word;
Var
  PB: Byte;
  RR: Integer;
  Off: Integer;
  Off16: Word;
  Base: Word;
  Indirect: Boolean;
  Lo: Byte;
Begin
  PB := M6809_FetchByte;
  RR := (PB Shr 5) And $03;
  Indirect := False;
  M6809_AmIndexed := 0;
  If (PB And $80) = 0 Then
  Begin
    { 5-bit signed offset, R }
    Off := PB And $1F;
    If (Off And $10) <> 0 Then Off := Off Or Not $1F;
    M6809_AmIndexed := (M6809_GetIdxReg(RR) + Off) And $FFFF;
    Exit;
  End;
  Indirect := (PB And $10) <> 0;
  Case PB And $0F Of
    $0: { ,R+ }
       Begin
         Base := M6809_GetIdxReg(RR);
         M6809_SetIdxReg(RR, (Base + 1) And $FFFF);
       End;
    $1: { ,R++ }
       Begin
         Base := M6809_GetIdxReg(RR);
         M6809_SetIdxReg(RR, (Base + 2) And $FFFF);
       End;
    $2: { ,-R }
       Begin
         M6809_SetIdxReg(RR, (M6809_GetIdxReg(RR) - 1) And $FFFF);
         Base := M6809_GetIdxReg(RR);
       End;
    $3: { ,--R }
       Begin
         M6809_SetIdxReg(RR, (M6809_GetIdxReg(RR) - 2) And $FFFF);
         Base := M6809_GetIdxReg(RR);
       End;
    $4: Base := M6809_GetIdxReg(RR);                  { ,R }
    $5: Begin                                          { B,R }
          Off := ShortInt(M6809_B);
          Base := (M6809_GetIdxReg(RR) + Off) And $FFFF;
        End;
    $6: Begin                                          { A,R }
          Off := ShortInt(M6809_A);
          Base := (M6809_GetIdxReg(RR) + Off) And $FFFF;
        End;
    $8: Begin                                          { n8,R }
          Off := ShortInt(M6809_FetchByte);
          Base := (M6809_GetIdxReg(RR) + Off) And $FFFF;
        End;
    $9: Begin                                          { n16,R }
          Off16 := M6809_FetchWord;
          Base := (M6809_GetIdxReg(RR) + Off16) And $FFFF;
        End;
    $B: Begin                                          { D,R }
          Base := (M6809_GetIdxReg(RR) + M6809_GetD) And $FFFF;
        End;
    $C: Begin                                          { n8,PC }
          Off := ShortInt(M6809_FetchByte);
          Base := (M6809_PC + Off) And $FFFF;
        End;
    $D: Begin                                          { n16,PC }
          Off16 := M6809_FetchWord;
          Base := (M6809_PC + Off16) And $FFFF;
        End;
    $F: Begin                                          { [n16] }
          Base := M6809_FetchWord;
        End;
  Else
    Base := M6809_GetIdxReg(RR);
  End;
  If Indirect Then
  Begin
    Lo := M6809_Mem[Word(Base + 1)];
    M6809_AmIndexed := (Word(M6809_Mem[Base]) Shl 8) Or Lo;
  End
  Else
    M6809_AmIndexed := Base;
End;

Function M6809_AmDirect: Word;
Begin
  M6809_AmDirect := (Word(M6809_DP) Shl 8) Or M6809_FetchByte;
End;

Function M6809_AmExtended: Word;
Begin M6809_AmExtended := M6809_FetchWord; End;

{ Resolution d adresse selon nibble haut $1x..$Bx d un opcode 8-bit memoire }
{ NN = 0 direct, 1 indexed, 2 extended }
Function M6809_GetEA(NN: Integer): Word;
Begin
  Case NN Of
    0: M6809_GetEA := M6809_AmDirect;
    1: M6809_GetEA := M6809_AmIndexed;
    2: M6809_GetEA := M6809_AmExtended;
  Else M6809_GetEA := 0;
  End;
End;

{ Operations memoire : INC/DEC/NEG/COM/CLR/TST/ASL/ASR/LSR/ROL/ROR }
Function M6809_DoMemOp(SubOp: Byte; V: Byte): Byte;
Var R: Byte; Cy: Byte;
Begin
  R := V;
  Case SubOp Of
    $0: Begin { NEG } R := (-V) And $FF;
              M6809_CC := M6809_CC And Not $0F;
              If V = $80 Then M6809_CC := M6809_CC Or $02;
              If V <> 0  Then M6809_CC := M6809_CC Or $01;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $3: Begin { COM } R := V Xor $FF;
              M6809_CC := (M6809_CC And Not $0E) Or $01;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $4: Begin { LSR } Cy := V And 1; R := V Shr 1;
              M6809_CC := M6809_CC And Not $0F;
              If Cy <> 0 Then M6809_CC := M6809_CC Or $01;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $6: Begin { ROR } Cy := V And 1;
              R := (V Shr 1) Or ((M6809_CC And 1) Shl 7);
              M6809_CC := M6809_CC And Not $0F;
              If Cy <> 0 Then M6809_CC := M6809_CC Or $01;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $7: Begin { ASR } Cy := V And 1;
              R := (V Shr 1) Or (V And $80);
              M6809_CC := M6809_CC And Not $0D;
              If Cy <> 0 Then M6809_CC := M6809_CC Or $01;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $8: Begin { ASL/LSL } Cy := (V Shr 7) And 1;
              R := (V Shl 1) And $FF;
              M6809_CC := M6809_CC And Not $0F;
              If Cy <> 0 Then M6809_CC := M6809_CC Or $01;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $9: Begin { ROL } Cy := (V Shr 7) And 1;
              R := ((V Shl 1) Or (M6809_CC And 1)) And $FF;
              M6809_CC := M6809_CC And Not $0F;
              If Cy <> 0 Then M6809_CC := M6809_CC Or $01;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $A: Begin { DEC } R := (V - 1) And $FF;
              M6809_CC := M6809_CC And Not $0E;
              If V = $80 Then M6809_CC := M6809_CC Or $02;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $C: Begin { INC } R := (V + 1) And $FF;
              M6809_CC := M6809_CC And Not $0E;
              If V = $7F Then M6809_CC := M6809_CC Or $02;
              If (R And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If R = 0 Then M6809_CC := M6809_CC Or $04; End;
    $D: Begin { TST } R := V;
              M6809_CC := M6809_CC And Not $0E;
              If (V And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
              If V = 0 Then M6809_CC := M6809_CC Or $04; End;
    $F: Begin { CLR } R := 0;
              M6809_CC := (M6809_CC And Not $0B) Or $04; End;
  End;
  M6809_DoMemOp := R;
End;

{ Operations ALU 8 bits sur A/B }
Procedure M6809_DoAdd8(Var Reg: Byte; V: Byte);
Var R: Word; H: Byte;
Begin
  R := Reg + V;
  H := ((Reg And $0F) + (V And $0F)) And $10;
  M6809_CC := M6809_CC And Not $2F;
  If H <> 0 Then M6809_CC := M6809_CC Or $20;
  If R > $FF Then M6809_CC := M6809_CC Or $01;
  If (((Reg Xor V) And $80) = 0) And
     (((Reg Xor (R And $FF)) And $80) <> 0) Then
    M6809_CC := M6809_CC Or $02;
  Reg := R And $FF;
  If (Reg And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04;
End;

Procedure M6809_DoAdc8(Var Reg: Byte; V: Byte);
Var Cy: Byte; R: Word;
Begin
  If (M6809_CC And 1) <> 0 Then Cy := 1 Else Cy := 0;
  R := Reg + V + Cy;
  M6809_CC := M6809_CC And Not $2F;
  If R > $FF Then M6809_CC := M6809_CC Or $01;
  Reg := R And $FF;
  If (Reg And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04;
End;

Procedure M6809_DoSub8(Var Reg: Byte; V: Byte);
Var R: Integer;
Begin
  R := Integer(Reg) - Integer(V);
  M6809_CC := M6809_CC And Not $0F;
  If R < 0 Then M6809_CC := M6809_CC Or $01;
  If (((Reg Xor V) And $80) <> 0) And
     (((Reg Xor (R And $FF)) And $80) <> 0) Then
    M6809_CC := M6809_CC Or $02;
  Reg := R And $FF;
  If (Reg And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04;
End;

Procedure M6809_DoSbc8(Var Reg: Byte; V: Byte);
Var Cy: Byte; R: Integer;
Begin
  If (M6809_CC And 1) <> 0 Then Cy := 1 Else Cy := 0;
  R := Integer(Reg) - Integer(V) - Cy;
  M6809_CC := M6809_CC And Not $0F;
  If R < 0 Then M6809_CC := M6809_CC Or $01;
  Reg := R And $FF;
  If (Reg And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04;
End;

Procedure M6809_DoCmp8(Reg, V: Byte);
Var T: Byte;
Begin T := Reg; M6809_DoSub8(T, V); End;

Procedure M6809_DoAnd8(Var Reg: Byte; V: Byte);
Begin Reg := Reg And V; M6809_CC := M6809_CC And Not $0E;
  If (Reg And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04; End;

Procedure M6809_DoOr8(Var Reg: Byte; V: Byte);
Begin Reg := Reg Or V; M6809_CC := M6809_CC And Not $0E;
  If (Reg And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04; End;

Procedure M6809_DoEor8(Var Reg: Byte; V: Byte);
Begin Reg := Reg Xor V; M6809_CC := M6809_CC And Not $0E;
  If (Reg And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04; End;

Procedure M6809_DoBit8(Reg, V: Byte);
Var T: Byte;
Begin T := Reg And V; M6809_CC := M6809_CC And Not $0E;
  If (T And $80) <> 0 Then M6809_CC := M6809_CC Or $08;
  If T = 0 Then M6809_CC := M6809_CC Or $04; End;

Procedure M6809_DoAdd16(Var Reg: Word; V: Word);
Var R: LongInt;
Begin R := LongInt(Reg) + V;
  M6809_CC := M6809_CC And Not $0F;
  If R > $FFFF Then M6809_CC := M6809_CC Or $01;
  Reg := R And $FFFF;
  If (Reg And $8000) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04; End;

Procedure M6809_DoSub16(Var Reg: Word; V: Word);
Var R: LongInt;
Begin R := LongInt(Reg) - V;
  M6809_CC := M6809_CC And Not $0F;
  If R < 0 Then M6809_CC := M6809_CC Or $01;
  Reg := R And $FFFF;
  If (Reg And $8000) <> 0 Then M6809_CC := M6809_CC Or $08;
  If Reg = 0 Then M6809_CC := M6809_CC Or $04; End;

Procedure M6809_DoCmp16(Reg, V: Word);
Var T: Word;
Begin T := Reg; M6809_DoSub16(T, V); End;

{ Branchements : evaluation condition selon nibble bas }
Function M6809_BranchCond(N: Integer): Boolean;
Var
  N_, Z_, V_, C_: Boolean;
Begin
  N_ := (M6809_CC And $08) <> 0;
  Z_ := (M6809_CC And $04) <> 0;
  V_ := (M6809_CC And $02) <> 0;
  C_ := (M6809_CC And $01) <> 0;
  Case N Of
    $0: M6809_BranchCond := True;       { BRA }
    $1: M6809_BranchCond := False;      { BRN }
    $2: M6809_BranchCond := (Not C_) And (Not Z_);  { BHI }
    $3: M6809_BranchCond := C_ Or Z_;   { BLS }
    $4: M6809_BranchCond := Not C_;     { BCC/BHS }
    $5: M6809_BranchCond := C_;         { BCS/BLO }
    $6: M6809_BranchCond := Not Z_;     { BNE }
    $7: M6809_BranchCond := Z_;         { BEQ }
    $8: M6809_BranchCond := Not V_;     { BVC }
    $9: M6809_BranchCond := V_;         { BVS }
    $A: M6809_BranchCond := Not N_;     { BPL }
    $B: M6809_BranchCond := N_;         { BMI }
    $C: M6809_BranchCond := (N_ = V_);                          { BGE }
    $D: M6809_BranchCond := (N_ <> V_);                         { BLT }
    $E: M6809_BranchCond := (Not Z_) And (N_ = V_);             { BGT }
    $F: M6809_BranchCond := Z_ Or (N_ <> V_);                   { BLE }
  Else M6809_BranchCond := False;
  End;
End;

{ Trap OS : si JSR vers une adresse magique connue, executer le service }
Function M6809_TryTrap(Target: Word): Boolean;
Var Ch: Byte;
Begin
  M6809_TryTrap := False;
  If (Target = $A002) Or { CoCo3 BASIC CHROUT }
     (Target = $BB5A) Or { Dragon CHROUT }
     (Target = $BB26) Or { Dragon variante }
     (Target = $E803) Then { Thomson PUTC }
  Begin
    Ch := M6809_A;
    If (Ch = $0D) Or (Ch = $0A) Then Begin
      EmuVScr_PutChar(M6809_Panel^, #13);
      EmuVScr_PutChar(M6809_Panel^, #10);
    End Else If (Ch >= 32) And (Ch < 128) Then
      EmuVScr_PutChar(M6809_Panel^, Chr(Ch));
    M6809_TryTrap := True;
  End;
End;

{ Push/Pop selon registre destinataire pour PSHS/PULS/PSHU/PULU }
Procedure M6809_DoPshS(Mask: Byte);
Begin
  If (Mask And $80) <> 0 Then M6809_Push16S(M6809_PC);
  If (Mask And $40) <> 0 Then M6809_Push16S(M6809_U);
  If (Mask And $20) <> 0 Then M6809_Push16S(M6809_Y);
  If (Mask And $10) <> 0 Then M6809_Push16S(M6809_X);
  If (Mask And $08) <> 0 Then M6809_Push8S(M6809_DP);
  If (Mask And $04) <> 0 Then M6809_Push8S(M6809_B);
  If (Mask And $02) <> 0 Then M6809_Push8S(M6809_A);
  If (Mask And $01) <> 0 Then M6809_Push8S(M6809_CC);
End;

Procedure M6809_DoPulS(Mask: Byte);
Begin
  If (Mask And $01) <> 0 Then M6809_CC := M6809_Pop8S;
  If (Mask And $02) <> 0 Then M6809_A := M6809_Pop8S;
  If (Mask And $04) <> 0 Then M6809_B := M6809_Pop8S;
  If (Mask And $08) <> 0 Then M6809_DP := M6809_Pop8S;
  If (Mask And $10) <> 0 Then M6809_X := M6809_Pop16S;
  If (Mask And $20) <> 0 Then M6809_Y := M6809_Pop16S;
  If (Mask And $40) <> 0 Then M6809_U := M6809_Pop16S;
  If (Mask And $80) <> 0 Then M6809_PC := M6809_Pop16S;
End;

{ TFR/EXG : encodage registres post-byte                                    }
{ 0=D 1=X 2=Y 3=U 4=S 5=PC 8=A 9=B 10=CC 11=DP                              }
Function M6809_GetReg(N: Integer): Word;
Begin
  Case N Of
    0: M6809_GetReg := M6809_GetD;
    1: M6809_GetReg := M6809_X;
    2: M6809_GetReg := M6809_Y;
    3: M6809_GetReg := M6809_U;
    4: M6809_GetReg := M6809_S;
    5: M6809_GetReg := M6809_PC;
    8: M6809_GetReg := M6809_A;
    9: M6809_GetReg := M6809_B;
   10: M6809_GetReg := M6809_CC;
   11: M6809_GetReg := M6809_DP;
  Else M6809_GetReg := 0;
  End;
End;

Procedure M6809_PutReg(N: Integer; V: Word);
Begin
  Case N Of
    0: M6809_SetD(V);
    1: M6809_X := V;
    2: M6809_Y := V;
    3: M6809_U := V;
    4: M6809_S := V;
    5: M6809_PC := V;
    8: M6809_A := V And $FF;
    9: M6809_B := V And $FF;
   10: M6809_CC := V And $FF;
   11: M6809_DP := V And $FF;
  End;
End;

{ Page 2 ($10) : LBcc, CMPD/CMPY, LDY/STY, LDS/STS, SWI2 }
Procedure M6809_StepPage2;
Var
  Op, PB: Byte;
  W: Word;
  Off16: Word;
  EA: Word;
Begin
  Op := M6809_FetchByte;
  Case Op Of
    $21..$2F: { LBcc }
       Begin
         Off16 := M6809_FetchWord;
         If M6809_BranchCond(Op And $0F) Then
           M6809_PC := (M6809_PC + Off16) And $FFFF;
       End;
    $83: Begin W := M6809_FetchWord; M6809_DoCmp16(M6809_GetD, W); End;
    $93: Begin EA := M6809_AmDirect; M6809_DoCmp16(M6809_GetD, M6809_Rd16(EA)); End;
    $A3: Begin EA := M6809_AmIndexed; M6809_DoCmp16(M6809_GetD, M6809_Rd16(EA)); End;
    $B3: Begin EA := M6809_AmExtended; M6809_DoCmp16(M6809_GetD, M6809_Rd16(EA)); End;
    $8C: Begin W := M6809_FetchWord; M6809_DoCmp16(M6809_Y, W); End;
    $9C: Begin EA := M6809_AmDirect; M6809_DoCmp16(M6809_Y, M6809_Rd16(EA)); End;
    $AC: Begin EA := M6809_AmIndexed; M6809_DoCmp16(M6809_Y, M6809_Rd16(EA)); End;
    $BC: Begin EA := M6809_AmExtended; M6809_DoCmp16(M6809_Y, M6809_Rd16(EA)); End;
    $8E: Begin M6809_Y := M6809_FetchWord; M6809_SetNZ16(M6809_Y); End;
    $9E: Begin EA := M6809_AmDirect; M6809_Y := M6809_Rd16(EA); M6809_SetNZ16(M6809_Y); End;
    $AE: Begin EA := M6809_AmIndexed; M6809_Y := M6809_Rd16(EA); M6809_SetNZ16(M6809_Y); End;
    $BE: Begin EA := M6809_AmExtended; M6809_Y := M6809_Rd16(EA); M6809_SetNZ16(M6809_Y); End;
    $9F: Begin EA := M6809_AmDirect; M6809_Wr16(EA, M6809_Y); M6809_SetNZ16(M6809_Y); End;
    $AF: Begin EA := M6809_AmIndexed; M6809_Wr16(EA, M6809_Y); M6809_SetNZ16(M6809_Y); End;
    $BF: Begin EA := M6809_AmExtended; M6809_Wr16(EA, M6809_Y); M6809_SetNZ16(M6809_Y); End;
    $CE: Begin M6809_S := M6809_FetchWord; M6809_SetNZ16(M6809_S); End;
    $DE: Begin EA := M6809_AmDirect; M6809_S := M6809_Rd16(EA); M6809_SetNZ16(M6809_S); End;
    $EE: Begin EA := M6809_AmIndexed; M6809_S := M6809_Rd16(EA); M6809_SetNZ16(M6809_S); End;
    $FE: Begin EA := M6809_AmExtended; M6809_S := M6809_Rd16(EA); M6809_SetNZ16(M6809_S); End;
    $DF: Begin EA := M6809_AmDirect; M6809_Wr16(EA, M6809_S); M6809_SetNZ16(M6809_S); End;
    $EF: Begin EA := M6809_AmIndexed; M6809_Wr16(EA, M6809_S); M6809_SetNZ16(M6809_S); End;
    $FF: Begin EA := M6809_AmExtended; M6809_Wr16(EA, M6809_S); M6809_SetNZ16(M6809_S); End;
    $3F: Begin { SWI2 } M6809_Halted := True; M6809_ExitCode := 0; End;
  End;
End;

{ Page 3 ($11) : CMPU, CMPS, SWI3 }
Procedure M6809_StepPage3;
Var
  Op: Byte;
  W: Word;
  EA: Word;
Begin
  Op := M6809_FetchByte;
  Case Op Of
    $83: Begin W := M6809_FetchWord; M6809_DoCmp16(M6809_U, W); End;
    $93: Begin EA := M6809_AmDirect; M6809_DoCmp16(M6809_U, M6809_Rd16(EA)); End;
    $A3: Begin EA := M6809_AmIndexed; M6809_DoCmp16(M6809_U, M6809_Rd16(EA)); End;
    $B3: Begin EA := M6809_AmExtended; M6809_DoCmp16(M6809_U, M6809_Rd16(EA)); End;
    $8C: Begin W := M6809_FetchWord; M6809_DoCmp16(M6809_S, W); End;
    $9C: Begin EA := M6809_AmDirect; M6809_DoCmp16(M6809_S, M6809_Rd16(EA)); End;
    $AC: Begin EA := M6809_AmIndexed; M6809_DoCmp16(M6809_S, M6809_Rd16(EA)); End;
    $BC: Begin EA := M6809_AmExtended; M6809_DoCmp16(M6809_S, M6809_Rd16(EA)); End;
    $3F: Begin { SWI3 } M6809_Halted := True; M6809_ExitCode := 0; End;
  End;
End;

Procedure M6809_Step;
Var
  Op, PB, V: Byte;
  W, EA, Tgt: Word;
  Off: ShortInt;
  Off16: Word;
  Hi, Lo: Integer;
  R32: LongInt;
  Tmp: Word;
Begin
  Op := M6809_FetchByte;
  Case Op Of
    $00, $03, $04, $06, $07, $08, $09, $0A, $0C, $0D, $0F: { direct mem-op }
      Begin
        EA := M6809_AmDirect;
        V := M6809_DoMemOp(Op And $0F, M6809_Rd(EA));
        If (Op And $0F) <> $D Then M6809_Wr(EA, V);
      End;
    $40, $43, $44, $46, $47, $48, $49, $4A, $4C, $4D, $4F: { A reg }
      M6809_A := M6809_DoMemOp(Op And $0F, M6809_A);
    $50, $53, $54, $56, $57, $58, $59, $5A, $5C, $5D, $5F: { B reg }
      M6809_B := M6809_DoMemOp(Op And $0F, M6809_B);
    $60, $63, $64, $66, $67, $68, $69, $6A, $6C, $6D, $6F: { indexed mem-op }
      Begin
        EA := M6809_AmIndexed;
        V := M6809_DoMemOp(Op And $0F, M6809_Rd(EA));
        If (Op And $0F) <> $D Then M6809_Wr(EA, V);
      End;
    $70, $73, $74, $76, $77, $78, $79, $7A, $7C, $7D, $7F: { extended mem-op }
      Begin
        EA := M6809_AmExtended;
        V := M6809_DoMemOp(Op And $0F, M6809_Rd(EA));
        If (Op And $0F) <> $D Then M6809_Wr(EA, V);
      End;
    { NOP/SYNC/etc }
    $12: ; { NOP }
    $13: ; { SYNC -> NOP }
    $19: { DAA }
       Begin
         Tmp := M6809_A;
         { Approximation : non utilise par codeur Pascal }
         M6809_A := Tmp And $FF;
         M6809_SetNZ8(M6809_A);
       End;
    $1A: M6809_CC := M6809_CC Or M6809_FetchByte;        { ORCC #i }
    $1C: M6809_CC := M6809_CC And M6809_FetchByte;       { ANDCC #i }
    $1D: { SEX : sign-extend B vers A }
         Begin
           If (M6809_B And $80) <> 0 Then M6809_A := $FF
           Else M6809_A := $00;
           M6809_SetNZ16(M6809_GetD);
         End;
    $1E: { EXG }
       Begin
         PB := M6809_FetchByte;
         Hi := (PB Shr 4) And $0F; Lo := PB And $0F;
         Tmp := M6809_GetReg(Hi);
         M6809_PutReg(Hi, M6809_GetReg(Lo));
         M6809_PutReg(Lo, Tmp);
       End;
    $1F: { TFR }
       Begin
         PB := M6809_FetchByte;
         Hi := (PB Shr 4) And $0F; Lo := PB And $0F;
         M6809_PutReg(Lo, M6809_GetReg(Hi));
       End;
    { Branchements courts }
    $20..$2F:
       Begin
         Off := ShortInt(M6809_FetchByte);
         If M6809_BranchCond(Op And $0F) Then
           M6809_PC := (M6809_PC + Off) And $FFFF;
       End;
    { Long branches Page 1 (BRA long et BSR long) }
    $16: Begin Off16 := M6809_FetchWord;
              M6809_PC := (M6809_PC + Off16) And $FFFF; End; { LBRA }
    $17: Begin Off16 := M6809_FetchWord;
              Tgt := (M6809_PC + Off16) And $FFFF;
              If Not M6809_TryTrap(Tgt) Then Begin
                M6809_Push16S(M6809_PC); M6809_PC := Tgt;
              End; End;                                       { LBSR }
    $39: Begin { RTS }
           If ((M6809_S = $FFFE) Or (M6809_S >= $FFFE))
              And (Not Coco3_Active) Then Begin
             M6809_Halted := True; M6809_ExitCode := 0;
           End Else M6809_PC := M6809_Pop16S;
         End;
    $3B: { RTI }
       Begin
         M6809_CC := M6809_Pop8S;
         If (M6809_CC And $80) <> 0 Then Begin
           M6809_A := M6809_Pop8S; M6809_B := M6809_Pop8S;
           M6809_DP := M6809_Pop8S;
           M6809_X := M6809_Pop16S; M6809_Y := M6809_Pop16S;
           M6809_U := M6809_Pop16S;
         End;
         M6809_PC := M6809_Pop16S;
       End;
    $3D: { MUL : D = A * B }
       Begin
         Tmp := M6809_A * M6809_B;
         M6809_SetD(Tmp);
         M6809_CC := M6809_CC And Not $05;
         If Tmp = 0 Then M6809_CC := M6809_CC Or $04;
         If (M6809_B And $80) <> 0 Then M6809_CC := M6809_CC Or $01;
       End;
    $3F: Begin { SWI } M6809_Halted := True; M6809_ExitCode := 0; End;
    $32: M6809_S := M6809_AmIndexed;                     { LEAS }
    $33: M6809_U := M6809_AmIndexed;                     { LEAU }
    $30: Begin M6809_X := M6809_AmIndexed;
              M6809_CC := M6809_CC And Not $04;
              If M6809_X = 0 Then M6809_CC := M6809_CC Or $04; End; { LEAX }
    $31: Begin M6809_Y := M6809_AmIndexed;
              M6809_CC := M6809_CC And Not $04;
              If M6809_Y = 0 Then M6809_CC := M6809_CC Or $04; End; { LEAY }
    $34: M6809_DoPshS(M6809_FetchByte);                  { PSHS }
    $35: M6809_DoPulS(M6809_FetchByte);                  { PULS }
    $36: { PSHU } Begin PB := M6809_FetchByte;
              If (PB And $80) <> 0 Then Begin
                M6809_Push8U(M6809_PC And $FF); M6809_Push8U((M6809_PC Shr 8) And $FF); End;
              If (PB And $40) <> 0 Then Begin
                M6809_Push8U(M6809_S And $FF); M6809_Push8U((M6809_S Shr 8) And $FF); End;
              If (PB And $20) <> 0 Then Begin
                M6809_Push8U(M6809_Y And $FF); M6809_Push8U((M6809_Y Shr 8) And $FF); End;
              If (PB And $10) <> 0 Then Begin
                M6809_Push8U(M6809_X And $FF); M6809_Push8U((M6809_X Shr 8) And $FF); End;
              If (PB And $08) <> 0 Then M6809_Push8U(M6809_DP);
              If (PB And $04) <> 0 Then M6809_Push8U(M6809_B);
              If (PB And $02) <> 0 Then M6809_Push8U(M6809_A);
              If (PB And $01) <> 0 Then M6809_Push8U(M6809_CC);
            End;
    $37: { PULU } Begin PB := M6809_FetchByte;
              If (PB And $01) <> 0 Then M6809_CC := M6809_Pop8U;
              If (PB And $02) <> 0 Then M6809_A := M6809_Pop8U;
              If (PB And $04) <> 0 Then M6809_B := M6809_Pop8U;
              If (PB And $08) <> 0 Then M6809_DP := M6809_Pop8U;
              If (PB And $10) <> 0 Then Begin
                Hi := M6809_Pop8U; Lo := M6809_Pop8U;
                M6809_X := (Word(Hi) Shl 8) Or Lo; End;
              If (PB And $20) <> 0 Then Begin
                Hi := M6809_Pop8U; Lo := M6809_Pop8U;
                M6809_Y := (Word(Hi) Shl 8) Or Lo; End;
              If (PB And $40) <> 0 Then Begin
                Hi := M6809_Pop8U; Lo := M6809_Pop8U;
                M6809_S := (Word(Hi) Shl 8) Or Lo; End;
              If (PB And $80) <> 0 Then Begin
                Hi := M6809_Pop8U; Lo := M6809_Pop8U;
                M6809_PC := (Word(Hi) Shl 8) Or Lo; End;
            End;
    $3A: M6809_X := (M6809_X + M6809_B) And $FFFF;       { ABX }
    { ALU 8 bits sur A : ADDA, ADCA, SUBA, SBCA, CMPA, ANDA, ORA, EORA, BITA, LDA, STA }
    $80: Begin V := M6809_FetchByte; M6809_DoSub8(M6809_A, V); End; { SUBA imm }
    $81: Begin V := M6809_FetchByte; M6809_DoCmp8(M6809_A, V); End; { CMPA imm }
    $82: Begin V := M6809_FetchByte; M6809_DoSbc8(M6809_A, V); End; { SBCA imm }
    $84: Begin V := M6809_FetchByte; M6809_DoAnd8(M6809_A, V); End;
    $85: Begin V := M6809_FetchByte; M6809_DoBit8(M6809_A, V); End;
    $86: Begin M6809_A := M6809_FetchByte; M6809_SetNZ8(M6809_A); End;
    $88: Begin V := M6809_FetchByte; M6809_DoEor8(M6809_A, V); End;
    $89: Begin V := M6809_FetchByte; M6809_DoAdc8(M6809_A, V); End;
    $8A: Begin V := M6809_FetchByte; M6809_DoOr8(M6809_A, V); End;
    $8B: Begin V := M6809_FetchByte; M6809_DoAdd8(M6809_A, V); End;
    { ADDD/SUBD/CMPX/LDX/JSR/LDD/STD imm/dir/idx/ext }
    $83: Begin W := M6809_FetchWord; Tmp := M6809_GetD; M6809_DoSub16(Tmp, W);
              M6809_SetD(Tmp); End;                       { SUBD imm }
    $8C: Begin W := M6809_FetchWord; M6809_DoCmp16(M6809_X, W); End; { CMPX imm }
    $8D: Begin Off := ShortInt(M6809_FetchByte);
              Tgt := (M6809_PC + Off) And $FFFF;
              If Not M6809_TryTrap(Tgt) Then Begin
                M6809_Push16S(M6809_PC); M6809_PC := Tgt;
              End; End;                                   { BSR }
    $8E: Begin M6809_X := M6809_FetchWord; M6809_SetNZ16(M6809_X); End;
    $8F: ; { reserved }
    { Direct page (90-9F) }
    $90: Begin EA := M6809_AmDirect; M6809_DoSub8(M6809_A, M6809_Rd(EA)); End;
    $91: Begin EA := M6809_AmDirect; M6809_DoCmp8(M6809_A, M6809_Rd(EA)); End;
    $92: Begin EA := M6809_AmDirect; M6809_DoSbc8(M6809_A, M6809_Rd(EA)); End;
    $93: Begin EA := M6809_AmDirect; Tmp := M6809_GetD;
              M6809_DoSub16(Tmp, M6809_Rd16(EA)); M6809_SetD(Tmp); End;
    $94: Begin EA := M6809_AmDirect; M6809_DoAnd8(M6809_A, M6809_Rd(EA)); End;
    $95: Begin EA := M6809_AmDirect; M6809_DoBit8(M6809_A, M6809_Rd(EA)); End;
    $96: Begin EA := M6809_AmDirect; M6809_A := M6809_Rd(EA); M6809_SetNZ8(M6809_A); End;
    $97: Begin EA := M6809_AmDirect; M6809_Wr(EA, M6809_A); M6809_SetNZ8(M6809_A); End;
    $98: Begin EA := M6809_AmDirect; M6809_DoEor8(M6809_A, M6809_Rd(EA)); End;
    $99: Begin EA := M6809_AmDirect; M6809_DoAdc8(M6809_A, M6809_Rd(EA)); End;
    $9A: Begin EA := M6809_AmDirect; M6809_DoOr8(M6809_A, M6809_Rd(EA)); End;
    $9B: Begin EA := M6809_AmDirect; M6809_DoAdd8(M6809_A, M6809_Rd(EA)); End;
    $9C: Begin EA := M6809_AmDirect; M6809_DoCmp16(M6809_X, M6809_Rd16(EA)); End;
    $9D: Begin EA := M6809_AmDirect;
              If Not M6809_TryTrap(EA) Then Begin
                M6809_Push16S(M6809_PC); M6809_PC := EA;
              End; End;                                   { JSR direct }
    $9E: Begin EA := M6809_AmDirect; M6809_X := M6809_Rd16(EA); M6809_SetNZ16(M6809_X); End;
    $9F: Begin EA := M6809_AmDirect; M6809_Wr16(EA, M6809_X); M6809_SetNZ16(M6809_X); End;
    { Indexed (A0-AF) }
    $A0: Begin EA := M6809_AmIndexed; M6809_DoSub8(M6809_A, M6809_Rd(EA)); End;
    $A1: Begin EA := M6809_AmIndexed; M6809_DoCmp8(M6809_A, M6809_Rd(EA)); End;
    $A2: Begin EA := M6809_AmIndexed; M6809_DoSbc8(M6809_A, M6809_Rd(EA)); End;
    $A3: Begin EA := M6809_AmIndexed; Tmp := M6809_GetD;
              M6809_DoSub16(Tmp, M6809_Rd16(EA)); M6809_SetD(Tmp); End;
    $A4: Begin EA := M6809_AmIndexed; M6809_DoAnd8(M6809_A, M6809_Rd(EA)); End;
    $A5: Begin EA := M6809_AmIndexed; M6809_DoBit8(M6809_A, M6809_Rd(EA)); End;
    $A6: Begin EA := M6809_AmIndexed; M6809_A := M6809_Rd(EA); M6809_SetNZ8(M6809_A); End;
    $A7: Begin EA := M6809_AmIndexed; M6809_Wr(EA, M6809_A); M6809_SetNZ8(M6809_A); End;
    $A8: Begin EA := M6809_AmIndexed; M6809_DoEor8(M6809_A, M6809_Rd(EA)); End;
    $A9: Begin EA := M6809_AmIndexed; M6809_DoAdc8(M6809_A, M6809_Rd(EA)); End;
    $AA: Begin EA := M6809_AmIndexed; M6809_DoOr8(M6809_A, M6809_Rd(EA)); End;
    $AB: Begin EA := M6809_AmIndexed; M6809_DoAdd8(M6809_A, M6809_Rd(EA)); End;
    $AC: Begin EA := M6809_AmIndexed; M6809_DoCmp16(M6809_X, M6809_Rd16(EA)); End;
    $AD: Begin EA := M6809_AmIndexed;
              If Not M6809_TryTrap(EA) Then Begin
                M6809_Push16S(M6809_PC); M6809_PC := EA;
              End; End;                                   { JSR indexed }
    $AE: Begin EA := M6809_AmIndexed; M6809_X := M6809_Rd16(EA); M6809_SetNZ16(M6809_X); End;
    $AF: Begin EA := M6809_AmIndexed; M6809_Wr16(EA, M6809_X); M6809_SetNZ16(M6809_X); End;
    { Extended (B0-BF) }
    $B0: Begin EA := M6809_AmExtended; M6809_DoSub8(M6809_A, M6809_Rd(EA)); End;
    $B1: Begin EA := M6809_AmExtended; M6809_DoCmp8(M6809_A, M6809_Rd(EA)); End;
    $B2: Begin EA := M6809_AmExtended; M6809_DoSbc8(M6809_A, M6809_Rd(EA)); End;
    $B3: Begin EA := M6809_AmExtended; Tmp := M6809_GetD;
              M6809_DoSub16(Tmp, M6809_Rd16(EA)); M6809_SetD(Tmp); End;
    $B4: Begin EA := M6809_AmExtended; M6809_DoAnd8(M6809_A, M6809_Rd(EA)); End;
    $B5: Begin EA := M6809_AmExtended; M6809_DoBit8(M6809_A, M6809_Rd(EA)); End;
    $B6: Begin EA := M6809_AmExtended; M6809_A := M6809_Rd(EA); M6809_SetNZ8(M6809_A); End;
    $B7: Begin EA := M6809_AmExtended; M6809_Wr(EA, M6809_A); M6809_SetNZ8(M6809_A); End;
    $B8: Begin EA := M6809_AmExtended; M6809_DoEor8(M6809_A, M6809_Rd(EA)); End;
    $B9: Begin EA := M6809_AmExtended; M6809_DoAdc8(M6809_A, M6809_Rd(EA)); End;
    $BA: Begin EA := M6809_AmExtended; M6809_DoOr8(M6809_A, M6809_Rd(EA)); End;
    $BB: Begin EA := M6809_AmExtended; M6809_DoAdd8(M6809_A, M6809_Rd(EA)); End;
    $BC: Begin EA := M6809_AmExtended; M6809_DoCmp16(M6809_X, M6809_Rd16(EA)); End;
    $BD: Begin EA := M6809_AmExtended;
              If Not M6809_TryTrap(EA) Then Begin
                M6809_Push16S(M6809_PC); M6809_PC := EA;
              End; End;                                   { JSR extended }
    $BE: Begin EA := M6809_AmExtended; M6809_X := M6809_Rd16(EA); M6809_SetNZ16(M6809_X); End;
    $BF: Begin EA := M6809_AmExtended; M6809_Wr16(EA, M6809_X); M6809_SetNZ16(M6809_X); End;
    { ALU 8 bits sur B : SUBB, CMPB, SBCB, ADDD, ANDB, BITB, LDB, STB, EORB, ADCB, ORB, ADDB }
    $C0: Begin V := M6809_FetchByte; M6809_DoSub8(M6809_B, V); End;
    $C1: Begin V := M6809_FetchByte; M6809_DoCmp8(M6809_B, V); End;
    $C2: Begin V := M6809_FetchByte; M6809_DoSbc8(M6809_B, V); End;
    $C3: Begin W := M6809_FetchWord; Tmp := M6809_GetD; M6809_DoAdd16(Tmp, W); M6809_SetD(Tmp); End;
    $C4: Begin V := M6809_FetchByte; M6809_DoAnd8(M6809_B, V); End;
    $C5: Begin V := M6809_FetchByte; M6809_DoBit8(M6809_B, V); End;
    $C6: Begin M6809_B := M6809_FetchByte; M6809_SetNZ8(M6809_B); End;
    $C8: Begin V := M6809_FetchByte; M6809_DoEor8(M6809_B, V); End;
    $C9: Begin V := M6809_FetchByte; M6809_DoAdc8(M6809_B, V); End;
    $CA: Begin V := M6809_FetchByte; M6809_DoOr8(M6809_B, V); End;
    $CB: Begin V := M6809_FetchByte; M6809_DoAdd8(M6809_B, V); End;
    $CC: Begin Tmp := M6809_FetchWord; M6809_SetD(Tmp); M6809_SetNZ16(Tmp); End; { LDD imm }
    $CE: Begin M6809_U := M6809_FetchWord; M6809_SetNZ16(M6809_U); End; { LDU imm }
    $D0: Begin EA := M6809_AmDirect; M6809_DoSub8(M6809_B, M6809_Rd(EA)); End;
    $D1: Begin EA := M6809_AmDirect; M6809_DoCmp8(M6809_B, M6809_Rd(EA)); End;
    $D2: Begin EA := M6809_AmDirect; M6809_DoSbc8(M6809_B, M6809_Rd(EA)); End;
    $D3: Begin EA := M6809_AmDirect; Tmp := M6809_GetD;
              M6809_DoAdd16(Tmp, M6809_Rd16(EA)); M6809_SetD(Tmp); End;
    $D4: Begin EA := M6809_AmDirect; M6809_DoAnd8(M6809_B, M6809_Rd(EA)); End;
    $D5: Begin EA := M6809_AmDirect; M6809_DoBit8(M6809_B, M6809_Rd(EA)); End;
    $D6: Begin EA := M6809_AmDirect; M6809_B := M6809_Rd(EA); M6809_SetNZ8(M6809_B); End;
    $D7: Begin EA := M6809_AmDirect; M6809_Wr(EA, M6809_B); M6809_SetNZ8(M6809_B); End;
    $D8: Begin EA := M6809_AmDirect; M6809_DoEor8(M6809_B, M6809_Rd(EA)); End;
    $D9: Begin EA := M6809_AmDirect; M6809_DoAdc8(M6809_B, M6809_Rd(EA)); End;
    $DA: Begin EA := M6809_AmDirect; M6809_DoOr8(M6809_B, M6809_Rd(EA)); End;
    $DB: Begin EA := M6809_AmDirect; M6809_DoAdd8(M6809_B, M6809_Rd(EA)); End;
    $DC: Begin EA := M6809_AmDirect; Tmp := M6809_Rd16(EA); M6809_SetD(Tmp); M6809_SetNZ16(Tmp); End;
    $DD: Begin EA := M6809_AmDirect; M6809_Wr16(EA, M6809_GetD); M6809_SetNZ16(M6809_GetD); End;
    $DE: Begin EA := M6809_AmDirect; M6809_U := M6809_Rd16(EA); M6809_SetNZ16(M6809_U); End;
    $DF: Begin EA := M6809_AmDirect; M6809_Wr16(EA, M6809_U); M6809_SetNZ16(M6809_U); End;
    $E0: Begin EA := M6809_AmIndexed; M6809_DoSub8(M6809_B, M6809_Rd(EA)); End;
    $E1: Begin EA := M6809_AmIndexed; M6809_DoCmp8(M6809_B, M6809_Rd(EA)); End;
    $E2: Begin EA := M6809_AmIndexed; M6809_DoSbc8(M6809_B, M6809_Rd(EA)); End;
    $E3: Begin EA := M6809_AmIndexed; Tmp := M6809_GetD;
              M6809_DoAdd16(Tmp, M6809_Rd16(EA)); M6809_SetD(Tmp); End;
    $E4: Begin EA := M6809_AmIndexed; M6809_DoAnd8(M6809_B, M6809_Rd(EA)); End;
    $E5: Begin EA := M6809_AmIndexed; M6809_DoBit8(M6809_B, M6809_Rd(EA)); End;
    $E6: Begin EA := M6809_AmIndexed; M6809_B := M6809_Rd(EA); M6809_SetNZ8(M6809_B); End;
    $E7: Begin EA := M6809_AmIndexed; M6809_Wr(EA, M6809_B); M6809_SetNZ8(M6809_B); End;
    $E8: Begin EA := M6809_AmIndexed; M6809_DoEor8(M6809_B, M6809_Rd(EA)); End;
    $E9: Begin EA := M6809_AmIndexed; M6809_DoAdc8(M6809_B, M6809_Rd(EA)); End;
    $EA: Begin EA := M6809_AmIndexed; M6809_DoOr8(M6809_B, M6809_Rd(EA)); End;
    $EB: Begin EA := M6809_AmIndexed; M6809_DoAdd8(M6809_B, M6809_Rd(EA)); End;
    $EC: Begin EA := M6809_AmIndexed; Tmp := M6809_Rd16(EA); M6809_SetD(Tmp); M6809_SetNZ16(Tmp); End;
    $ED: Begin EA := M6809_AmIndexed; M6809_Wr16(EA, M6809_GetD); M6809_SetNZ16(M6809_GetD); End;
    $EE: Begin EA := M6809_AmIndexed; M6809_U := M6809_Rd16(EA); M6809_SetNZ16(M6809_U); End;
    $EF: Begin EA := M6809_AmIndexed; M6809_Wr16(EA, M6809_U); M6809_SetNZ16(M6809_U); End;
    $F0: Begin EA := M6809_AmExtended; M6809_DoSub8(M6809_B, M6809_Rd(EA)); End;
    $F1: Begin EA := M6809_AmExtended; M6809_DoCmp8(M6809_B, M6809_Rd(EA)); End;
    $F2: Begin EA := M6809_AmExtended; M6809_DoSbc8(M6809_B, M6809_Rd(EA)); End;
    $F3: Begin EA := M6809_AmExtended; Tmp := M6809_GetD;
              M6809_DoAdd16(Tmp, M6809_Rd16(EA)); M6809_SetD(Tmp); End;
    $F4: Begin EA := M6809_AmExtended; M6809_DoAnd8(M6809_B, M6809_Rd(EA)); End;
    $F5: Begin EA := M6809_AmExtended; M6809_DoBit8(M6809_B, M6809_Rd(EA)); End;
    $F6: Begin EA := M6809_AmExtended; M6809_B := M6809_Rd(EA); M6809_SetNZ8(M6809_B); End;
    $F7: Begin EA := M6809_AmExtended; M6809_Wr(EA, M6809_B); M6809_SetNZ8(M6809_B); End;
    $F8: Begin EA := M6809_AmExtended; M6809_DoEor8(M6809_B, M6809_Rd(EA)); End;
    $F9: Begin EA := M6809_AmExtended; M6809_DoAdc8(M6809_B, M6809_Rd(EA)); End;
    $FA: Begin EA := M6809_AmExtended; M6809_DoOr8(M6809_B, M6809_Rd(EA)); End;
    $FB: Begin EA := M6809_AmExtended; M6809_DoAdd8(M6809_B, M6809_Rd(EA)); End;
    $FC: Begin EA := M6809_AmExtended; Tmp := M6809_Rd16(EA); M6809_SetD(Tmp); M6809_SetNZ16(Tmp); End;
    $FD: Begin EA := M6809_AmExtended; M6809_Wr16(EA, M6809_GetD); M6809_SetNZ16(M6809_GetD); End;
    $FE: Begin EA := M6809_AmExtended; M6809_U := M6809_Rd16(EA); M6809_SetNZ16(M6809_U); End;
    $FF: Begin EA := M6809_AmExtended; M6809_Wr16(EA, M6809_U); M6809_SetNZ16(M6809_U); End;
    { JMP }
    $0E: M6809_PC := M6809_AmDirect;
    $6E: M6809_PC := M6809_AmIndexed;
    $7E: M6809_PC := M6809_AmExtended;
    { Prefixes pages 2 et 3 }
    $10: M6809_StepPage2;
    $11: M6809_StepPage3;
  Else
    If Coco3_Active Then Begin
      { Pour CoCo 3 : tolerer les opcodes non implementes (NOP silencieux) }
      Inc(Coco3_DbgUnknown);
      Coco3_DbgLastBad := Word(M6809_PC - 1);
    End Else Begin
      EmuVScr_WriteStr(M6809_Panel^,
       '[opcode 6809 inconnu $' + M68K_HexN(Op, 2) +
       ' au PC $' + M68K_HexN(Word(M6809_PC - 1), 4) + ']');
      M6809_Halted := True;
      M6809_ExitCode := 1;
    End;
  End;
End;

{ Charger un binaire DECB (CoCo, Dragon) : preambule(1=$00 data, $FF EOF)   }
{ + len(2BE) + addr(2BE) + data. Sur EOF : data = exec addr.                }
Function M6809_LoadDECB(Const FileName: String;
                        Var EntryAddr: Word): Boolean;
Var
  F: File;
  Hdr: Array[0..4] Of Byte;
  Tag: Byte;
  Len, Addr: Word;
  I: LongInt;
  B: Byte;
  GotData: Boolean;
Begin
  M6809_LoadDECB := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  GotData := False;
  EntryAddr := $4000;
  While Not Eof(F) Do
  Begin
    BlockRead(F, Tag, 1);
    If Eof(F) Then Break;
    BlockRead(F, Hdr, 4);
    Len := (Word(Hdr[0]) Shl 8) Or Hdr[1];
    Addr := (Word(Hdr[2]) Shl 8) Or Hdr[3];
    If Tag = $00 Then
    Begin
      For I := 0 To Len - 1 Do
      Begin
        If Eof(F) Then Break;
        BlockRead(F, B, 1);
        If (Addr + I) <= $FFFF Then M6809_Mem[Addr + I] := B;
      End;
      GotData := True;
    End
    Else If Tag = $FF Then
    Begin
      EntryAddr := Addr;
      Break;
    End
    Else
      Break;
  End;
  Close(F);
  If Not GotData Then
  Begin
    { Fallback : raw a $4000 }
    Assign(F, FileName);
    {$I-} Reset(F, 1); {$I+}
    If IOResult <> 0 Then Exit;
    I := 0;
    While Not Eof(F) Do
    Begin
      BlockRead(F, B, 1);
      If ($4000 + I) <= $FFFF Then M6809_Mem[$4000 + I] := B;
      Inc(I);
    End;
    Close(F);
    EntryAddr := $4000;
  End;
  M6809_LoadDECB := True;
End;

{ ============================================================
  Emulateur Tandy CoCo 3 - Jalon 1 :
  - Chargement cartouche .PAK (raw, charge a $C000, 16K max)
  - Reset CoCo 3 (PC = $C000, S = $7FFE)
  - Rendu VDG alpha mode (32 colonnes x 16 lignes a $0400-$05FF)
  - Carte memoire simplifiee : flat 64K via M6809_Mem
  ============================================================ }

{ Charger une cartouche / ROM CoCo brute. Pour les fichiers <= 16K on
  charge a $C000 (cartouche standard). Pour les fichiers > 16K (ROM
  BASIC 32K), on charge a $8000 et le point d entree est lu dans le
  vecteur RESET en $FFFE/$FFFF. }
Function Coco3_LoadPAK(Const FileName: String;
                       Var EntryAddr: Word): Boolean;
Var
  F: File;
  B: Byte;
  I: LongInt;
  LoadAddr: Word;
  FileSize: LongInt;
  Buf: Array[0..$7FFF] Of Byte;
  IsSystemROM: Boolean;
  HdrSkip: LongInt;
  EffSize: LongInt;
Begin
  Coco3_LoadPAK := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  FileSize := System.FileSize(F);
  If FileSize > $8000 Then FileSize := $8000;
  I := 0;
  FillChar(Coco3_PakRom, SizeOf(Coco3_PakRom), $FF);
  FillChar(Buf, SizeOf(Buf), $FF);
  While (Not Eof(F)) And (I < FileSize) Do Begin
    BlockRead(F, B, 1);
    Buf[I] := B;
    Inc(I);
  End;
  Close(F);
  { Jalon 10 : detection en-tete .PAK desactivee (les .PAK CoCo standard
    sont du code brut a $C000, le $FF initial peut etre une instruction
    STU extended valide). On garde HdrSkip = 0 pour les .PAK ; les vrais
    PAK Multi-Pak avec header sont rares. }
  HdrSkip := 0;
  EffSize := FileSize - HdrSkip;
  If EffSize < 0 Then EffSize := 0;
  { Jalon 10 : .PAK = toujours cartouche (16K max a $C000). Les fichiers
    >16K sont des carts a bank-switching (gere via $FF40 plus tard) ;
    on ne charge que le premier banc. Les ROM systeme CoCo 3 viennent
    via .ROM uniquement. }
  IsSystemROM := (Pos('.ROM', UpCaseStr(FileName)) > 0) And
                 (FileSize > $4000);
  If IsSystemROM Then LoadAddr := $8000
                 Else LoadAddr := $C000;
  Coco3_PakSize := EffSize;
  If IsSystemROM Then Begin
    { Jalon 7 : ROM systeme 16K-32K -> Coco3_RomImg, retenue meme apres
      ecritures MMU. }
    FillChar(Coco3_RomImg, SizeOf(Coco3_RomImg), $FF);
    For I := 0 To EffSize - 1 Do
      Coco3_RomImg[I] := Buf[I];
    Coco3_RomLoaded := True;
    Coco3_RomMode := 2;  { 32K ROM interne par defaut }
    For I := 0 To EffSize - 1 Do
      If (LongInt(LoadAddr) + I) <= $FFFF Then
        M6809_Mem[LoadAddr + I] := Buf[I];
    EntryAddr := (Word(M6809_Mem[$FFFE]) Shl 8) Or M6809_Mem[$FFFF];
  End Else Begin
    { Cartouche standard <=16K (apres saut d en-tete) : copie dans
      PakRom + miroir a $C000. }
    If EffSize > $4000 Then EffSize := $4000;
    For I := 0 To EffSize - 1 Do
      If I < SizeOf(Coco3_PakRom) Then
        Coco3_PakRom[I] := Buf[HdrSkip + I];
    For I := 0 To EffSize - 1 Do
      If (LongInt(LoadAddr) + I) <= $FFFF Then
        M6809_Mem[LoadAddr + I] := Buf[HdrSkip + I];
    EntryAddr := $C000;
  End;
  If EntryAddr = 0 Then EntryAddr := LoadAddr;
  Coco3_LoadPAK := True;
End;

{ --- Jalon 2 : MMU CoCo 3 ---------------------------------------- }
{ Numerotation banks :
   $00..$3F  : 64 banks de 8K dans Coco3_PhysMem (512K total)
   $80..$87  : 8 banks de 8K de la ROM cartouche (16K seulement = 2 banks
              utilises, les autres sont copies miroir / $FF)            }

{ Renvoie l offset physique pour un bank donne dans PhysMem (lecture seule
  pour la ROM cart). }
Function Coco3_BankBaseAddr(Bank: Byte): LongInt;
Begin
  If Bank < $40 Then
    Coco3_BankBaseAddr := LongInt(Bank) Shl 13   { bank * 8192 }
  Else
    Coco3_BankBaseAddr := -1;  { ROM : pas dans PhysMem }
End;

{ Vide les donnees ecrites par le CPU (M6809_Mem) vers PhysMem pour le bank
  RAM en cours sur le segment specifie. Sans effet pour la ROM cart ou
  un segment shadow ROM. }
Procedure Coco3_FlushSegment(Seg: Byte);
Var
  Bank: Byte;
  Base: LongInt;
  I: Integer;
Begin
  If Coco3_SegIsRom[Seg And 7] Then Exit;
  Bank := Coco3_LiveBank[Seg And 7];
  Base := Coco3_BankBaseAddr(Bank);
  If Base < 0 Then Exit;
  For I := 0 To $1FFF Do
    Coco3_PhysMem[Base + I] := M6809_Mem[(LongInt(Seg And 7) Shl 13) + I];
End;

{ --- Jalon 7 : test si la ROM interne couvre ce segment ---
  La ROM interne est visible aux segments 4..7 ($8000-$FFFF) sauf en
  mode "all RAM" (RomMode=3) ou si aucune ROM n est chargee.            }
Function Coco3_RomVisibleAt(Seg: Byte): Boolean;
Begin
  Coco3_RomVisibleAt := False;
  If Not Coco3_RomLoaded Then Exit;
  If (Seg And 7) < 4 Then Exit;
  If Coco3_RomMode = 3 Then Exit;
  Coco3_RomVisibleAt := True;
End;

{ Remplit la fenetre 8K du segment depuis l image ROM interne ou cart. }
Procedure Coco3_LoadSegmentROM(Seg: Byte);
Var
  Dst: LongInt;
  I: Integer;
  PakOfs: LongInt;
  RomOfs: LongInt;
Begin
  Dst := LongInt(Seg And 7) Shl 13;
  Case Coco3_RomMode Of
    0, 1: Begin
      { 16K interne $8000-$BFFF (segs 4-5) + 16K cart $C000-$FFFF (6-7) }
      If (Seg And 7) <= 5 Then Begin
        RomOfs := LongInt((Seg And 7) - 4) Shl 13;
        For I := 0 To $1FFF Do
          M6809_Mem[Dst + I] := Coco3_RomImg[RomOfs + I];
      End Else Begin
        PakOfs := LongInt((Seg And 7) - 6) Shl 13;
        For I := 0 To $1FFF Do
          If (PakOfs + I) < Coco3_PakSize Then
            M6809_Mem[Dst + I] := Coco3_PakRom[PakOfs + I]
          Else
            M6809_Mem[Dst + I] := $FF;
      End;
    End;
  Else
    { Mode 2 ou autre : 32K ROM interne $8000-$FFFF }
    RomOfs := LongInt((Seg And 7) - 4) Shl 13;
    For I := 0 To $1FFF Do
      M6809_Mem[Dst + I] := Coco3_RomImg[RomOfs + I];
  End;
  Coco3_SegIsRom[Seg And 7] := True;
End;

{ Charge le contenu d un bank vers la fenetre 8K du segment specifie. }
Procedure Coco3_LoadSegment(Seg: Byte; Bank: Byte);
Var
  Base: LongInt;
  I: Integer;
  PakOfs: LongInt;
Begin
  { Jalon 7 : si la ROM doit etre visible a ce segment, l overlay
    s applique quel que soit le bank programme dans la MMU. }
  If Coco3_RomVisibleAt(Seg) Then Begin
    Coco3_LoadSegmentROM(Seg);
    Coco3_LiveBank[Seg And 7] := Bank;
    Exit;
  End;
  Coco3_SegIsRom[Seg And 7] := False;
  Base := Coco3_BankBaseAddr(Bank);
  If Base >= 0 Then Begin
    For I := 0 To $1FFF Do
      M6809_Mem[(LongInt(Seg And 7) Shl 13) + I] :=
        Coco3_PhysMem[Base + I];
  End Else Begin
    { ROM cart : Bank $80..$87 = pages 0..7 de PakRom (16K = 2 pages) }
    PakOfs := LongInt(Bank And $07) Shl 13;
    For I := 0 To $1FFF Do
      If (PakOfs + I) < Coco3_PakSize Then
        M6809_Mem[(LongInt(Seg And 7) Shl 13) + I] :=
          Coco3_PakRom[PakOfs + I]
      Else
        M6809_Mem[(LongInt(Seg And 7) Shl 13) + I] := $FF;
  End;
  Coco3_LiveBank[Seg And 7] := Bank;
End;

{ Rafraichit les segments 4..7 apres un changement de mode ROM. }
Procedure Coco3_RefreshRomSegments;
Var
  Seg: Byte;
Begin
  For Seg := 4 To 7 Do Begin
    If Coco3_RomVisibleAt(Seg) Then
      Coco3_LoadSegmentROM(Seg)
    Else If Coco3_SegIsRom[Seg] Then Begin
      { ROM etait visible, plus maintenant : recharger depuis MMU/RAM }
      Coco3_SegIsRom[Seg] := False;
      If Coco3_MMUEnable Then
        Coco3_LoadSegment(Seg, Coco3_MMU[Coco3_MMUTask, Seg])
      Else
        Coco3_LoadSegment(Seg, $38 + Seg);
    End;
  End;
End;

{ Reprogramme un segment de la MMU (FFA0..FFA7 ou FFA8..FFAF). }
Procedure Coco3_SetMMU(RegOfs: Byte; NewBank: Byte);
Var
  Task, Seg: Byte;
Begin
  If RegOfs < $A8 Then Begin
    Task := 0; Seg := RegOfs - $A0;
  End Else Begin
    Task := 1; Seg := RegOfs - $A8;
  End;
  Coco3_MMU[Task, Seg] := NewBank And $7F;
  { N appliquer que si la tache courante = celle qu on modifie ET MMU
    activee }
  If Coco3_MMUEnable And (Task = Coco3_MMUTask) Then Begin
    If Coco3_LiveBank[Seg] <> (NewBank And $7F) Then Begin
      Coco3_FlushSegment(Seg);
      Coco3_LoadSegment(Seg, NewBank And $7F);
    End;
  End;
End;

{ Bascule la tache active (bit 0 de $FF91). Resynchronise les 8 segments. }
Procedure Coco3_SetTask(NewTask: Byte);
Var
  Seg: Byte;
Begin
  NewTask := NewTask And 1;
  If NewTask = Coco3_MMUTask Then Exit;
  { Sauvegarder les 8 segments actuels }
  For Seg := 0 To 7 Do Coco3_FlushSegment(Seg);
  Coco3_MMUTask := NewTask;
  { Charger les 8 segments de la nouvelle tache }
  For Seg := 0 To 7 Do
    Coco3_LoadSegment(Seg, Coco3_MMU[Coco3_MMUTask, Seg]);
End;

{ Active ou desactive la MMU (bit 6 de $FF90). Quand desactivee, la map
  par defaut $38..$3F (banks 56..63 = haut 64K de PhysMem) est utilisee. }
Procedure Coco3_SetMMUEnable(Enable: Boolean);
Var
  Seg: Byte;
Begin
  If Enable = Coco3_MMUEnable Then Exit;
  { Sauvegarder l etat actuel }
  For Seg := 0 To 7 Do Coco3_FlushSegment(Seg);
  Coco3_MMUEnable := Enable;
  If Enable Then
    For Seg := 0 To 7 Do
      Coco3_LoadSegment(Seg, Coco3_MMU[Coco3_MMUTask, Seg])
  Else
    For Seg := 0 To 7 Do
      Coco3_LoadSegment(Seg, $38 + Seg);
End;

{ Trappe d ecriture I/O ($FF00-$FFFF) pour le CoCo 3.
  Renvoie True si l ecriture est consommee (ne pas stocker dans M6809_Mem). }
Function Coco3_IoWrite(Addr: Word; V: Byte): Boolean;
Var
  Bit, Pair: Byte;
Begin
  Coco3_IoWrite := False;
  { PIA0 $FF00..$FF03 : clavier/joystick }
  Case Addr Of
    $FF00: Begin Coco3_PIA0_PortB := V; Coco3_IoWrite := True; Exit; End;
    $FF01: Begin Coco3_PIA0_CRA := V;   Coco3_IoWrite := True; Exit; End;
    $FF02: Begin Coco3_PIA0_DDRB := V;  Coco3_IoWrite := True; Exit; End;
    $FF03: Begin Coco3_PIA0_CRB := V;   Coco3_IoWrite := True; Exit; End;
    $FF22: Begin
             Coco3_PIA1_PB := V;
             Inc(Coco3_DbgFF22Wr);
             Coco3_IoWrite := True; Exit;
           End;
  End;
  { Registres SAM $FFC0..$FFDF : 16 paires set/clear pour 16 bits.
    Adresses paires (FFC0, FFC2, ..., FFDE) = clear bit ;
    adresses impaires = set bit. }
  If (Addr >= $FFC0) And (Addr <= $FFDF) Then Begin
    Bit := (Addr - $FFC0) Shr 1;  { 0..15 }
    Pair := (Addr - $FFC0) And 1;
    Inc(Coco3_DbgSamWr);
    If Pair = 1 Then
      Coco3_SAM := Coco3_SAM Or (Word(1) Shl Bit)
    Else
      Coco3_SAM := Coco3_SAM And (Not (Word(1) Shl Bit));
    { Bits F0..F6 = bits 3..9 du SAM (offset video / 512). }
    Coco3_SamVidBase := ((Coco3_SAM Shr 3) And $7F) Shl 9;
    Coco3_IoWrite := True;
    Exit;
  End;
  If (Addr >= $FF90) And (Addr <= $FFDF) Then Begin
    Coco3_GimeReg[Addr And $FF] := V;
    Case Addr Of
      $FF90: Begin
               Coco3_RomMode := V And 3;
               Coco3_SetMMUEnable((V And $40) <> 0);
               Coco3_RefreshRomSegments;
             End;
      $FF91: Coco3_SetTask(V And 1);
      $FF94: Begin
               Coco3_TimerInit :=
                 (Coco3_TimerInit And $00FF) Or (Word(V And $0F) Shl 8);
               Coco3_TimerCount := Coco3_TimerInit;
             End;
      $FF95: Begin
               Coco3_TimerInit :=
                 (Coco3_TimerInit And $0F00) Or V;
               Coco3_TimerCount := Coco3_TimerInit;
             End;
    End;
    Coco3_IoWrite := True;
    Exit;
  End;
  If (Addr >= $FFA0) And (Addr <= $FFAF) Then Begin
    Coco3_SetMMU(Addr And $FF, V);
    Coco3_IoWrite := True;
    Exit;
  End;
End;

{ Trappe de lecture I/O ($FF00-$FFFF). Renvoie la valeur si interceptee,
  sinon renvoie M6809_Mem[Addr]. }
Function Coco3_IoRead(Addr: Word): Byte;
Var
  Sense, ColMask, Row: Byte;
  KbdRet: Byte;
Begin
  { PIA0 clavier : pas de touche -> $7F (toutes lignes hautes), accuse
    sur les bits de PB. Pour le jalon 5 on reporte simplement $FF. }
  Case Addr Of
    $FF00: Begin
             { Jalon 8 : scan PIA0. PB (output) selectionne les colonnes
               (bit=0 = active). On retourne PA = AND des lignes pour
               les colonnes actives (bit=0 si une touche de cette
               ligne est pressee dans une colonne active). }
             ColMask := Coco3_PIA0_PortB;  { bit=0 -> colonne active }
             Sense := $7F;
             For Row := 0 To 6 Do Begin
               KbdRet := Coco3_KbdMatrix[Row] Or ColMask;
               If KbdRet <> $FF Then
                 Sense := Sense And (Not (Byte(1) Shl Row));
             End;
             { Lecture de PA acquitte CA1 (HSYNC flag) }
             Coco3_PIA0_CRA := Coco3_PIA0_CRA And $7F;
             Coco3_IoRead := Sense;
             Exit;
           End;
    $FF01: Begin Coco3_IoRead := Coco3_PIA0_CRA;  Exit; End;
    $FF02: Begin
             { Lecture de PB acquitte CB1 (VSYNC flag) }
             Coco3_PIA0_CRB := Coco3_PIA0_CRB And $7F;
             Coco3_IoRead := Coco3_PIA0_PortB; Exit;
           End;
    $FF03: Begin Coco3_IoRead := Coco3_PIA0_CRB;  Exit; End;
    $FF22: Begin Coco3_IoRead := Coco3_PIA1_PB; Exit; End;
    { Vecteurs CPU $FFF0-$FFFF : sur CoCo 3 ils sont fournis par le
      segment 7 (mappe par MMU). Comme M6809_Mem refletera deja le bon
      contenu via LoadSegment, on tombe sur le path par defaut. }
  End;
  If (Addr >= $FFC0) And (Addr <= $FFDF) Then Begin
    Coco3_IoRead := $FF;  { lecture sans effet, retourne floating }
    Exit;
  End;
  If (Addr >= $FF90) And (Addr <= $FFDF) Then
    Coco3_IoRead := Coco3_GimeReg[Addr And $FF]
  Else If (Addr >= $FFA0) And (Addr <= $FFA7) Then
    Coco3_IoRead := Coco3_MMU[0, (Addr - $FFA0) And 7]
  Else If (Addr >= $FFA8) And (Addr <= $FFAF) Then
    Coco3_IoRead := Coco3_MMU[1, (Addr - $FFA8) And 7]
  Else
    Coco3_IoRead := M6809_Mem[Addr];
End;

{ --- Jalon 5 : injection d interruption IRQ/FIRQ -------------- }
{ Pousse l etat complet (E=1 dans CC) et saute via le vecteur 16 bits
  loge a VecAddr ($FFF8 pour IRQ, $FFF6 pour FIRQ).
  Verifie le masque CC.I/F. Aucun effet si masquee. }
Procedure Coco3_FireIrq(VecAddr: Word; FastIrq: Boolean);
Var
  Vec: Word;
Begin
  If FastIrq Then Begin
    If (M6809_CC And $40) <> 0 Then Exit;  { F=1 : masquee }
    { FIRQ : push PC + CC seulement, E=0 }
    M6809_CC := M6809_CC And $7F;
    M6809_Push16S(M6809_PC);
    M6809_Push8S(M6809_CC);
    M6809_CC := M6809_CC Or $50;  { I=1, F=1 }
  End Else Begin
    If (M6809_CC And $10) <> 0 Then Exit;  { I=1 : masquee }
    { IRQ : push tout, E=1 }
    M6809_CC := M6809_CC Or $80;
    M6809_Push16S(M6809_PC);
    M6809_Push16S(M6809_U);
    M6809_Push16S(M6809_Y);
    M6809_Push16S(M6809_X);
    M6809_Push8S(M6809_DP);
    M6809_Push8S(M6809_B);
    M6809_Push8S(M6809_A);
    M6809_Push8S(M6809_CC);
    M6809_CC := M6809_CC Or $10;  { I=1 (F inchangee) }
  End;
  Vec := (Word(M6809_Rd(VecAddr)) Shl 8) Or M6809_Rd(VecAddr + 1);
  M6809_PC := Vec;
End;

{ --- Jalon 8 : clavier matriciel CoCo --------------------------- }
{ Mapper un caractere ASCII vers (ligne, colonne) dans la matrice 7x8.
  Renvoie False si pas de correspondance. }
Function Coco3_KeyToMatrix(Ch: Char; Var Row, Col: Integer): Boolean;
Var
  C: Byte;
Begin
  Coco3_KeyToMatrix := True;
  C := Ord(UpCase(Ch));
  If (C >= Ord('@')) And (C <= Ord('G')) Then Begin
    Row := 0; Col := C - Ord('@'); Exit;
  End;
  If (C >= Ord('H')) And (C <= Ord('O')) Then Begin
    Row := 1; Col := C - Ord('H'); Exit;
  End;
  If (C >= Ord('P')) And (C <= Ord('W')) Then Begin
    Row := 2; Col := C - Ord('P'); Exit;
  End;
  If (C >= Ord('X')) And (C <= Ord('Z')) Then Begin
    Row := 3; Col := C - Ord('X'); Exit;
  End;
  If (C >= Ord('0')) And (C <= Ord('7')) Then Begin
    Row := 4; Col := C - Ord('0'); Exit;
  End;
  If (C >= Ord('8')) And (C <= Ord('9')) Then Begin
    Row := 5; Col := C - Ord('8'); Exit;
  End;
  Case C Of
    Ord(' '): Begin Row := 3; Col := 7; End;
    Ord(':'): Begin Row := 5; Col := 2; End;
    Ord(';'): Begin Row := 5; Col := 3; End;
    Ord(','): Begin Row := 5; Col := 4; End;
    Ord('-'): Begin Row := 5; Col := 5; End;
    Ord('.'): Begin Row := 5; Col := 6; End;
    Ord('/'): Begin Row := 5; Col := 7; End;
    13:       Begin Row := 6; Col := 0; End;  { ENTER }
    8:        Begin Row := 3; Col := 5; End;  { BACKSPACE -> LEFT  }
  Else
    Coco3_KeyToMatrix := False;
  End;
End;

{ Pousser une touche dans la matrice clavier pour quelques trames. }
Procedure Coco3_PressKey(Ch: Char);
Var
  Row, Col: Integer;
Begin
  If Coco3_KeyToMatrix(Ch, Row, Col) Then Begin
    Coco3_KbdMatrix[Row] := Coco3_KbdMatrix[Row] And
                            (Not (Byte(1) Shl Col));
    Coco3_KbdHold := 4;
  End;
End;

{ Liberer toutes les touches apres l intervalle de hold. }
Procedure Coco3_KbdTick;
Var
  I: Integer;
Begin
  If Coco3_KbdHold > 0 Then Begin
    Dec(Coco3_KbdHold);
    If Coco3_KbdHold = 0 Then
      For I := 0 To 6 Do Coco3_KbdMatrix[I] := $FF;
  End;
End;

{ Jalon 9 : HSYNC IRQ (CA1 PIA0). Appelee 262 fois par trame.
  Met a jour le flag CRA bit 7 et tire IRQ si CRA bit 0 enable. }
Procedure Coco3_HsyncIrq;
Begin
  Coco3_PIA0_CRA := Coco3_PIA0_CRA Or $80;
  If (Coco3_PIA0_CRA And $01) <> 0 Then
    Coco3_FireIrq($FFF8, False);
End;

{ Tirer une VSYNC IRQ a la fin de chaque trame, si autorisee.
  GIME $FF92 bit 3 = enable VSYNC IRQ.
  GIME $FF93 bit 3 = enable VSYNC FIRQ.
  GIME $FF92 (lecture)/ FF92 ack : on positionne le flag dans GimeReg. }
Procedure Coco3_VsyncIrq;
Begin
  Inc(Coco3_VsyncCount);
  Coco3_KbdTick;
  { Jalon 9 : flag CB1 PIA0 + IRQ legacy }
  Coco3_PIA0_CRB := Coco3_PIA0_CRB Or $80;
  If (Coco3_PIA0_CRB And $01) <> 0 Then
    Coco3_FireIrq($FFF8, False);
  { Avancer le timer GIME : decremente d une unite par trame en mode
    "60 Hz" simplifie (vrai timer = 14 us / 63.7 us selon mode). }
  If Coco3_TimerCount > 0 Then Begin
    Dec(Coco3_TimerCount);
    If Coco3_TimerCount = 0 Then Begin
      { Timer expire : recharge + IRQ TIMR }
      Coco3_TimerCount := Coco3_TimerInit;
      If (Coco3_GimeReg[$92] And $20) <> 0 Then
        Coco3_FireIrq($FFF8, False);
      If (Coco3_GimeReg[$93] And $20) <> 0 Then
        Coco3_FireIrq($FFF6, True);
    End;
  End;
  { VSYNC IRQ }
  If (Coco3_GimeReg[$92] And $08) <> 0 Then
    Coco3_FireIrq($FFF8, False);
  If (Coco3_GimeReg[$93] And $08) <> 0 Then
    Coco3_FireIrq($FFF6, True);
End;

{ Initialiser l'etat CoCo 3 et la zone ecran VDG alpha par defaut }
Procedure Coco3_InitState;
Var
  I: Integer;
  Seg: Byte;
Begin
  Coco3_Active := True;
  Coco3_FBFirst := True;
  Coco3_FrameNo := 0;
  FillChar(Coco3_FB, SizeOf(Coco3_FB), 0);
  FillChar(Coco3_FBPrev, SizeOf(Coco3_FBPrev), $FF);
  { --- Jalon 2 : init MMU + GIME --- }
  { --- Jalon 2 : init MMU + GIME --- }
  FillChar(Coco3_GimeReg, SizeOf(Coco3_GimeReg), 0);
  { --- Jalon 5 : init IRQ/timer/PIA --- }
  Coco3_TimerInit  := 0;
  Coco3_TimerCount := 0;
  Coco3_PIA0_DDRA  := 0; Coco3_PIA0_CRA := 0;
  Coco3_PIA0_DDRB  := 0; Coco3_PIA0_CRB := 0;
  Coco3_PIA0_PortB := $FF;
  Coco3_VsyncCount := 0;
  { --- Jalon 6 : init VDG/SAM legacy --- }
  Coco3_PIA1_PB    := 0;       { mode alpha au boot }
  Coco3_SAM        := 0;
  Coco3_SamVidBase := $0400;   { ecran texte standard CoCo }
  { --- Jalon 7 : marquer les segments 4..7 comme ROM si chargee --- }
  For Seg := 0 To 3 Do Coco3_SegIsRom[Seg] := False;
  If Coco3_RomLoaded Then Begin
    For Seg := 4 To 7 Do Coco3_SegIsRom[Seg] := True;
  End Else
    For Seg := 4 To 7 Do Coco3_SegIsRom[Seg] := False;
  { --- Jalon 8 : matrice clavier (toutes touches relachees) --- }
  For Seg := 0 To 6 Do Coco3_KbdMatrix[Seg] := $FF;
  Coco3_KbdHold := 0;
  { --- Jalon 11 : reset diagnostics --- }
  Coco3_DbgUnknown := 0;
  Coco3_DbgLastBad := 0;
  Coco3_DbgFF22Wr  := 0;
  Coco3_DbgSamWr   := 0;
  { Etat par defaut : MMU desactivee, tache 0, mapping fixe banks $38..$3F.
    Coco3_MMUEnable demarre a True pour forcer SetMMUEnable(False) a
    appliquer le mapping par defaut sans flush. }
  Coco3_MMUEnable := True;
  Coco3_MMUTask  := 0;
  For Seg := 0 To 7 Do Begin
    Coco3_MMU[0, Seg] := $38 + Seg;
    Coco3_MMU[1, Seg] := $38 + Seg;
    Coco3_LiveBank[Seg] := $38 + Seg;
  End;
  { Le passage a False applique simplement le mapping fixe, donc on saute
    le flush en pre-positionnant LiveBank. }
  Coco3_MMUEnable := False;
  { Remplir la zone ecran VDG alpha avec espaces (0x60 = espace inverse, 0x20 = espace) }
  For I := $0400 To $05FF Do
    M6809_Mem[I] := $60;  { espace, vert sur noir par defaut }
End;

{ Palette CoCo VDG alpha - 8 couleurs (semi-graphiques utilisent ces teintes) }
{ Indices EGA : 0=noir, 2=vert, 6=jaune, 1=bleu, 4=rouge, 11=cyan, 5=magenta, 9=orange (approx) }
Function Coco3_VdgColorToEga(Idx: Byte): Byte;
Begin
  Case Idx And 7 Of
    0: Coco3_VdgColorToEga := 2;   { vert }
    1: Coco3_VdgColorToEga := 14;  { jaune }
    2: Coco3_VdgColorToEga := 1;   { bleu }
    3: Coco3_VdgColorToEga := 4;   { rouge }
    4: Coco3_VdgColorToEga := 15;  { buff/blanc }
    5: Coco3_VdgColorToEga := 3;   { cyan }
    6: Coco3_VdgColorToEga := 5;   { magenta }
    7: Coco3_VdgColorToEga := 12;  { orange }
  Else
    Coco3_VdgColorToEga := 7;
  End;
End;

{ Rendu d'un caractere ASCII 5x7 dans le framebuffer Coco3_FB. }
{ Fonte simple : on reutilise le rendu textuel en remplissant des blocs 8x8 }
{ Pour le jalon 1, on dessine chaque case 8x8 en couleur unie selon le byte VRAM }
Procedure Coco3_DrawCell(Col, Row: Integer; B: Byte);
Var
  PxX, PxY: Integer;
  Fg, Bg: Byte;
  Ch: Byte;
  IsAlpha: Boolean;
  IsSemi4: Boolean;
  Bx, By: Integer;
  PatternByte: Byte;
  I, J: Integer;
  { Mini-fonte 5x7 integree (caracteres ASCII basiques) }
  { Pour le jalon 1, on simplifie : chaque cellule 8x8 est dessinee }
  { en mode "carre uni colore" si semi-graphique, ou comme un point lumineux }
  { + un marqueur de caractere ASCII en mode alpha. }
Begin
  IsAlpha := (B And $80) = 0;       { bit 7 = 0 : alphanumerique }
  IsSemi4 := (B And $80) <> 0;      { bit 7 = 1 : semi-graphique 4 }
  PxX := Col * 8;
  PxY := Row * 12;  { 200 lignes / 16 = 12.5 => on prend 12 pour avoir 192 lignes utiles }
  If (PxX < 0) Or (PxY < 0) Or (PxX + 7 >= 256) Or (PxY + 11 >= 200) Then Exit;
  If IsAlpha Then Begin
    Ch := B And $3F;          { 6 bits ASCII }
    { Couleurs : alpha standard = vert sur noir, ou inverse si bit 6 set }
    If (B And $40) <> 0 Then Begin
      Fg := 0; Bg := Coco3_VdgColorToEga(0);  { inverse }
    End Else Begin
      Fg := Coco3_VdgColorToEga(0); Bg := 0;
    End;
    { Convertir code VDG (0-63) en ASCII : 0..31 = @A..Z[\]^_, 32..63 = espace, !, "...? }
    If Ch < 32 Then Ch := Ch + 64
    Else Ch := Ch;
    { Dessiner le rectangle de fond }
    For By := 0 To 11 Do
      For Bx := 0 To 7 Do
        Coco3_FB[PxY + By, PxX + Bx] := Bg;
    { Tracer une representation simplifiee du caractere :
      pour le jalon 1, on dessine un point en couleur Fg pour chaque caractere
      non-espace, en utilisant un pattern derive du code }
    If Ch <> 32 Then Begin
      { Pattern pseudo-aleatoire base sur Ch pour distinguer les caracteres }
      For I := 1 To 10 Do Begin
        PatternByte := Byte(Ch Xor I);
        For J := 1 To 6 Do
          If (PatternByte And (1 Shl (J And 7))) <> 0 Then
            Coco3_FB[PxY + I, PxX + J] := Fg;
      End;
    End;
  End Else If IsSemi4 Then Begin
    { Semi-graphique 4 : 2x2 blocs colores
      bits 7..4 = couleur (bit 7 = 1 indique mode SG4)
      bits 3..0 = 4 demi-cases on/off }
    Fg := Coco3_VdgColorToEga((B Shr 4) And 7);
    { Quadrant TL = bit 3, TR = bit 2, BL = bit 1, BR = bit 0 }
    For By := 0 To 5 Do
      For Bx := 0 To 3 Do
        If (B And $08) <> 0 Then
          Coco3_FB[PxY + By, PxX + Bx] := Fg
        Else
          Coco3_FB[PxY + By, PxX + Bx] := 0;
    For By := 0 To 5 Do
      For Bx := 4 To 7 Do
        If (B And $04) <> 0 Then
          Coco3_FB[PxY + By, PxX + Bx] := Fg
        Else
          Coco3_FB[PxY + By, PxX + Bx] := 0;
    For By := 6 To 11 Do
      For Bx := 0 To 3 Do
        If (B And $02) <> 0 Then
          Coco3_FB[PxY + By, PxX + Bx] := Fg
        Else
          Coco3_FB[PxY + By, PxX + Bx] := 0;
    For By := 6 To 11 Do
      For Bx := 4 To 7 Do
        If (B And $01) <> 0 Then
          Coco3_FB[PxY + By, PxX + Bx] := Fg
        Else
          Coco3_FB[PxY + By, PxX + Bx] := 0;
  End;
End;

{ Render full frame : VDG alpha 32x16 a partir de M6809_Mem[base..base+512] }
Procedure Coco3_RenderAlpha;
Var
  Col, Row: Integer;
  B: Byte;
  Base: Word;
Begin
  Base := Coco3_SamVidBase;
  If Base = 0 Then Base := $0400;
  For Row := 0 To 15 Do
    For Col := 0 To 31 Do Begin
      B := M6809_Mem[(Base + Row * 32 + Col) And $FFFF];
      Coco3_DrawCell(Col, Row, B);
    End;
End;

{ --- Jalon 6 : rendu VDG graphique (PMODE 0..4) ------------------- }
{ Couleurs VDG (CG modes, 4 couleurs) :
  CSS=0 : 0=vert, 1=jaune, 2=bleu, 3=rouge
  CSS=1 : 0=buff, 1=cyan, 2=magenta, 3=orange
  Mode RG (2 couleurs) : CSS=0 -> noir/vert ; CSS=1 -> noir/buff. }
Function Coco3_VdgCgColor(C, CSS: Byte): Byte;
Begin
  If CSS = 0 Then
    Case C And 3 Of
      0: Coco3_VdgCgColor := 2;   { vert  -> EGA 2 }
      1: Coco3_VdgCgColor := 14;  { jaune -> EGA 14 }
      2: Coco3_VdgCgColor := 1;   { bleu  -> EGA 1 }
      3: Coco3_VdgCgColor := 4;   { rouge -> EGA 4 }
    Else Coco3_VdgCgColor := 0;
    End
  Else
    Case C And 3 Of
      0: Coco3_VdgCgColor := 15;  { buff  -> EGA blanc }
      1: Coco3_VdgCgColor := 3;   { cyan  -> EGA 3 }
      2: Coco3_VdgCgColor := 5;   { magenta -> EGA 5 }
      3: Coco3_VdgCgColor := 12;  { orange -> EGA 12 }
    Else Coco3_VdgCgColor := 0;
    End;
End;

Function Coco3_VdgRgColor(Bit, CSS: Byte): Byte;
Begin
  If Bit = 0 Then
    Coco3_VdgRgColor := 0  { noir }
  Else If CSS = 0 Then
    Coco3_VdgRgColor := 2  { vert }
  Else
    Coco3_VdgRgColor := 15; { buff/blanc }
End;

{ Decoder le mode VDG depuis PIA $FF22 et restituer dans Coco3_FB.
  Renvoie False si on est en mode alpha (caller appelle RenderAlpha).
  Si pas en mode CoCo 3 GIME ($FF98 bit 7 = 0). }
Function Coco3_RenderVdg: Boolean;
Var
  V, GM, CSS: Byte;
  W, H, BPL: Integer;
  Base: Word;
  X, Y, FbX, FbY: Integer;
  Bx: Integer;
  ByteOfs: Integer;
  ByteVal: Byte;
  Pix, ColorVal: Byte;
  IsCG: Boolean;
Begin
  Coco3_RenderVdg := False;
  V := Coco3_PIA1_PB;
  If (V And $80) = 0 Then Exit;  { mode alpha }
  GM := (V Shr 4) And 7;
  CSS := (V Shr 3) And 1;
  Base := Coco3_SamVidBase;
  If Base = 0 Then Base := $0E00;  { defaut PMODE classique }
  { Table : (W, H, BPL, IsCG) selon GM }
  Case GM Of
    0: Begin W :=  64; H := 64;  BPL := 16; IsCG := True;  End; { CG1 64x64x4 }
    1: Begin W := 128; H := 64;  BPL := 16; IsCG := False; End; { RG1 128x64x2 }
    2: Begin W := 128; H := 64;  BPL := 32; IsCG := True;  End; { CG2 128x64x4 }
    3: Begin W := 128; H := 96;  BPL := 16; IsCG := False; End; { RG2 128x96x2 }
    4: Begin W := 128; H := 96;  BPL := 32; IsCG := True;  End; { CG3 128x96x4 }
    5: Begin W := 128; H := 192; BPL := 16; IsCG := False; End; { RG3 128x192x2 }
    6: Begin W := 128; H := 192; BPL := 32; IsCG := True;  End; { CG6 128x192x4 }
    7: Begin W := 256; H := 192; BPL := 32; IsCG := False; End; { RG6 256x192x2 }
  Else
    Exit;
  End;
  For FbY := 0 To 199 Do Begin
    Y := (FbY * H) Div 200;
    If Y >= H Then Y := H - 1;
    For FbX := 0 To 255 Do Begin
      X := (FbX * W) Div 256;
      If X >= W Then X := W - 1;
      If IsCG Then Begin
        { 4 couleurs : 2 bits/pixel, 4 pixels/octet }
        ByteOfs := Y * BPL + (X Shr 2);
        ByteVal := M6809_Mem[(Base + ByteOfs) And $FFFF];
        Bx := (3 - (X And 3)) Shl 1;
        Pix := (ByteVal Shr Bx) And 3;
        ColorVal := Coco3_VdgCgColor(Pix, CSS);
      End Else Begin
        { 2 couleurs : 1 bit/pixel, 8 pixels/octet }
        ByteOfs := Y * BPL + (X Shr 3);
        ByteVal := M6809_Mem[(Base + ByteOfs) And $FFFF];
        Bx := 7 - (X And 7);
        Pix := (ByteVal Shr Bx) And 1;
        ColorVal := Coco3_VdgRgColor(Pix, CSS);
      End;
      Coco3_FB[FbY, FbX] := ColorVal;
    End;
  End;
  Coco3_RenderVdg := True;
End;

{ --- Jalon 3 : modes graphiques GIME ----------------------------- }
{ Adresse physique de base de la video (19 bits).
  $FF9D = bits 18..11, $FF9E = bits 10..3 (les 3 bits LSB sont 0).         }
Function Coco3_VideoBase: LongInt;
Begin
  Coco3_VideoBase :=
    (LongInt(Coco3_GimeReg[$9D]) Shl 11) Or
    (LongInt(Coco3_GimeReg[$9E]) Shl 3);
End;

{ Decoder les parametres video GIME en mode graphique.
  Renvoie largeur (px), hauteur (px), bits/pixel, octets/ligne. }
Procedure Coco3_GetGfxParams(Var W, H: Integer;
                             Var BPP, BytesPerLine: Integer);
Var
  HRES, CRES, LPF: Byte;
Begin
  HRES := (Coco3_GimeReg[$99] Shr 2) And 7;
  CRES :=  Coco3_GimeReg[$99]        And 3;
  LPF  := (Coco3_GimeReg[$99] Shr 5) And 3;
  Case CRES Of
    0: BPP := 1;
    1: BPP := 2;
    2: BPP := 4;
  Else
    BPP := 4;
  End;
  Case HRES Of
    0: BytesPerLine := 16;
    1: BytesPerLine := 20;
    2: BytesPerLine := 32;
    3: BytesPerLine := 40;
    4: BytesPerLine := 64;
    5: BytesPerLine := 80;
    6: BytesPerLine := 64;
    7: BytesPerLine := 80;
  End;
  W := (BytesPerLine * 8) Div BPP;
  Case LPF Of
    0: H := 192;
    1: H := 200;
    3: H := 225;
  Else
    H := 192;
  End;
End;

{ Mapper une entree de palette GIME (6 bits RGB) vers couleur EGA.
  Format CoCo 3 RGB : bits = r'g'b' r g b (haut..bas).
  Chaque composant fait 2 bits : MSB depuis bits 5/4/3, LSB depuis 2/1/0.
  On reduit chaque composant 0..3 a 1 bit RGB + un bit "intensite" pour
  produire un index EGA 0..15. Le mode CMP (composite) est traite comme
  RGB faute d emulation NTSC ; les jeux fonctionnent generalement bien. }
Function Coco3_PaletteToEga(PalIdx: Byte): Byte;
Var
  V: Byte;
  R, G, B: Byte;
  Bit, Intensity, Sum: Byte;
Begin
  V := Coco3_GimeReg[$B0 + (PalIdx And $0F)] And $3F;
  R := (((V Shr 5) And 1) Shl 1) Or ((V Shr 2) And 1);
  G := (((V Shr 4) And 1) Shl 1) Or ((V Shr 1) And 1);
  B := (((V Shr 3) And 1) Shl 1) Or  (V        And 1);
  { Construire RGBI : R/G/B : 1 si composant >= 2, intensite si somme >=4 }
  Bit := 0;
  If R >= 2 Then Bit := Bit Or 4;
  If G >= 2 Then Bit := Bit Or 2;
  If B >= 2 Then Bit := Bit Or 1;
  Sum := R + G + B;
  If Sum >= 4 Then Intensity := 8 Else Intensity := 0;
  { Cas special : EGA index 6 (marron) au lieu de jaune fonce.
    On corrige en promotant vers index 14 (jaune) quand R=G eleves et B=0. }
  If (Bit = 6) And (Intensity = 0) And (R + G >= 3) Then
    Coco3_PaletteToEga := 14
  Else
    Coco3_PaletteToEga := Intensity Or Bit;
End;

{ Lire un pixel BPP-bits depuis PhysMem. }
Function Coco3_ReadPixel(BaseAddr: LongInt; Y, X, BPP,
                         BytesPerLine: Integer): Byte;
Var
  Ofs: LongInt;
  B: Byte;
  Sub: Integer;
Begin
  Ofs := BaseAddr + LongInt(Y) * BytesPerLine;
  Coco3_ReadPixel := 0;
  Case BPP Of
    1: Begin
         Ofs := Ofs + (X Shr 3);
         B := Coco3_PhysMem[Ofs And $7FFFF];
         Sub := 7 - (X And 7);
         Coco3_ReadPixel := (B Shr Sub) And 1;
       End;
    2: Begin
         Ofs := Ofs + (X Shr 2);
         B := Coco3_PhysMem[Ofs And $7FFFF];
         Sub := (3 - (X And 3)) Shl 1;
         Coco3_ReadPixel := (B Shr Sub) And 3;
       End;
    4: Begin
         Ofs := Ofs + (X Shr 1);
         B := Coco3_PhysMem[Ofs And $7FFFF];
         If (X And 1) = 0 Then
           Coco3_ReadPixel := (B Shr 4) And $0F
         Else
           Coco3_ReadPixel := B And $0F;
       End;
  End;
End;

{ Rendu graphique GIME : ecrit dans Coco3_FB[200, 256] avec downsample. }
Procedure Coco3_RenderGfx;
Var
  W, H, BPP, BPL: Integer;
  Base: LongInt;
  Y, X, FbX, FbY: Integer;
  Pix: Byte;
  Seg: Byte;
Begin
  { Sync : recopie l etat CPU (M6809_Mem) vers PhysMem pour les 8
    segments mappes. Le controleur video GIME lit toujours en RAM
    physique, independamment de l etat MMU. }
  For Seg := 0 To 7 Do Coco3_FlushSegment(Seg);
  Coco3_GetGfxParams(W, H, BPP, BPL);
  Base := Coco3_VideoBase;
  If (W <= 0) Or (H <= 0) Then Exit;
  For FbY := 0 To 199 Do Begin
    Y := (FbY * H) Div 200;
    If Y >= H Then Y := H - 1;
    For FbX := 0 To 255 Do Begin
      X := (FbX * W) Div 256;
      If X >= W Then X := W - 1;
      Pix := Coco3_ReadPixel(Base, Y, X, BPP, BPL);
      Coco3_FB[FbY, FbX] := Coco3_PaletteToEga(Pix);
    End;
  End;
End;

{ Dispatch : GIME (jalons 3-4) si $FF98 actif, sinon VDG legacy
  graphique (jalon 6) si PIA $FF22 bit 7=1, sinon VDG alpha. }
Procedure Coco3_RenderFrame;
Begin
  If (Coco3_GimeReg[$98] And $80) <> 0 Then
    Coco3_RenderGfx
  Else If (Coco3_PIA1_PB And $80) <> 0 Then Begin
    If Not Coco3_RenderVdg Then
      Coco3_RenderAlpha;
  End Else
    Coco3_RenderAlpha;
  Inc(Coco3_FrameNo);
End;


{   $00 len(2BE) addr(2BE) data...   (chunk de donnees)                    }
{   $FF $00 $00 entry(2BE)           (terminateur avec point d entree)     }
{ Variante historique acceptee : $5B/$5A.                                  }
{ Sur echec : raw a $6100 (zone utilisateur).                              }
Function M6809_LoadThomsonBin(Const FileName: String;
                              Var EntryAddr: Word): Boolean;
Var
  F: File;
  Tag: Byte;
  Hdr: Array[0..3] Of Byte;
  Len, Addr: Word;
  I: LongInt;
  B: Byte;
  GotData: Boolean;
Begin
  M6809_LoadThomsonBin := False;
  Assign(F, FileName);
  {$I-} Reset(F, 1); {$I+}
  If IOResult <> 0 Then Exit;
  GotData := False;
  EntryAddr := $6100;
  While Not Eof(F) Do
  Begin
    BlockRead(F, Tag, 1);
    If Eof(F) Then Break;
    If (Tag = $5B) Or (Tag = $00) Then
    Begin
      BlockRead(F, Hdr, 4);
      Len := (Word(Hdr[0]) Shl 8) Or Hdr[1];
      Addr := (Word(Hdr[2]) Shl 8) Or Hdr[3];
      For I := 0 To Len - 1 Do
      Begin
        If Eof(F) Then Break;
        BlockRead(F, B, 1);
        If (Addr + I) <= $FFFF Then M6809_Mem[Addr + I] := B;
      End;
      GotData := True;
    End
    Else If (Tag = $5A) Or (Tag = $FF) Then
    Begin
      BlockRead(F, Hdr, 4);
      Addr := (Word(Hdr[2]) Shl 8) Or Hdr[3];
      EntryAddr := Addr;
      Break;
    End
    Else Break;
  End;
  Close(F);
  If Not GotData Then
  Begin
    { Fallback : raw a $6100 }
    Assign(F, FileName);
    {$I-} Reset(F, 1); {$I+}
    If IOResult <> 0 Then Exit;
    I := 0;
    While Not Eof(F) Do
    Begin
      BlockRead(F, B, 1);
      If ($6100 + I) <= $FFFF Then M6809_Mem[$6100 + I] := B;
      Inc(I);
    End;
    Close(F);
    EntryAddr := $6100;
  End;
  M6809_LoadThomsonBin := True;
End;

Procedure M6809_Reset(EntryAddr: Word);
Begin
  M6809_A := 0; M6809_B := 0;
  M6809_DP := 0; M6809_CC := $50; { I=1, F=1 }
  M6809_X := 0; M6809_Y := 0;
  M6809_U := $FFFE; M6809_S := $FFFE;
  M6809_PC := EntryAddr;
  M6809_Halted := False;
  M6809_ExitCode := 0;
  M6809_Cycles := 0;
  { Sentinelle de fin (sauf en mode CoCo 3 ou les vecteurs sont reels) }
  If Not Coco3_Active Then Begin
    M6809_Mem[$FFFE] := $00;
    M6809_Mem[$FFFF] := $00;
  End;
End;

Function Emu_FaultText(F: Integer): String;
Begin
 Case F Of
  sfNone        : Emu_FaultText := 'aucune erreur';
  sfInvalidCode : Emu_FaultText := 'opcode non supporte';
  { la chaine completed est composee plus loin avec l opcode et l adresse }
  sfHLT         : Emu_FaultText := 'instruction HLT';
  sfHotBoot     : Emu_FaultText := 'redemarrage a chaud';
  sfColdBoot    : Emu_FaultText := 'redemarrage a froid';
  sfInvalidIntr : Emu_FaultText := 'interruption invalide';
  sfEndProgram  : Emu_FaultText := 'fin de programme';
  sfBreakPoint  : Emu_FaultText := 'point d arret';
  sfDivision0   : Emu_FaultText := 'division par zero';
  Else            Emu_FaultText := 'code ' + IntToStr(F);
 End;
End;

{ --- Vidage du trace circulaire CS:IP/opcode dans EMUTRACE.LOG --- }

Procedure Emu_DumpTrace;
Var
 F: Text;
 I, K: Integer;
Begin
 {$I-}
 Assign(F, 'EMUTRACE.LOG');
 Rewrite(F);
 {$I+}
 If IOResult <> 0 Then Exit;
 WriteLn(F, '8192 dernieres instructions executees (boucle suspectee) :');
 WriteLn(F, 'Premier passage en zone 0x20 (espaces) : ',
  HexWord(EmuRunawayCS), ':', HexWord(EmuRunawayIP),
  '  step=', EmuRunawayStep);
 WriteLn(F, '');
 For I := 0 To 8191 Do Begin
  K := (EmuTraceIdx + I) And $1FFF;
  WriteLn(F, HexWord(EmuTraceBuf[K].CS), ':', HexWord(EmuTraceBuf[K].IP),
   '  opcode=', HexByte(EmuTraceBuf[K].Op),
   '  ES=', HexWord(EmuTraceBuf[K].ES),
   '  DI=', HexWord(EmuTraceBuf[K].DI),
   '  CX=', HexWord(EmuTraceBuf[K].CX),
   '  AX=', HexWord(EmuTraceBuf[K].AX));
 End;
 Close(F);
End;

{ --- Charger un binaire DOS et lancer l execution --- }

Procedure ShowEmulatorPanel(Var P: TEmulatorPanel;
 BinaryPath, TargetCPU: String);
Var
 OldFg, OldBg: Byte;
 Loaded: Boolean;
 Steps: LongInt;
 IsX86: Boolean;
 IsM68K: Boolean;
 IsCray: Boolean;
 Is6502: Boolean;
 IsZ80: Boolean;
 Is6809: Boolean;
 CPUName: String;
 EntryAddr: LongInt;
 EntryAddr16: Word;
 NesFH: File;
 NesHdr: Array[0..15] Of Byte;
 NesBR: Word;
 NesPrgBlocks: Byte;
 NesChrBlocks: Byte;
 NesPrgSize: LongInt;
 NesChrSize: LongInt;
 NesFrameLimit: LongInt;
 NesInstrPerFrame: LongInt;
 NesKeyEsc: Boolean;
 Coco3InstrIdx: LongInt;
 Coco3FrameElapsed: LongInt;
 EmuPumpEv: TEvent;
 EmuPumpCnt: LongInt;
 EmuPumpDrainI: Integer;
 EmuPumpNow: LongInt;
 EmuLastDraw: LongInt;
 EmuKeyLogF: Text;
 LogF_R: Text;
 Idx_R, KK_R: Integer;
 AllZero: Boolean;
Begin NesActive := False;
 InitEmulatorPanel(P);
 P.BinaryPath := BinaryPath;
 P.TargetCPU := TargetCPU; P.Base.Visible := True;
 P.Visible := True;
 P.Running := True;
 P.Fault := 0;
 { Geometrie et couleurs specifiques C64 : 40 colonnes, fond bleu, texte cyan }
 If TargetCPU = '-CC64' Then
 Begin
  P.Cols := 40;
  P.Rows := 25;
  P.CurFg := 11;  { cyan clair }
  P.CurBg := 1;   { bleu       }
  EmuVScr_Clear(P);
 End
 Else If TargetCPU = '-CMSX' Then
 Begin
  P.Cols := 40;
  P.Rows := 25;
  P.CurFg := 15;  { blanc      }
  P.CurBg := 9;   { bleu clair }
  EmuVScr_Clear(P);
 End
 Else If TargetCPU = '-CCOCO3' Then
 Begin
  P.Cols := 32;   { CoCo 3 ecran texte 32 colonnes }
  P.Rows := 16;
  P.CurFg := 0;   { noir       }
  P.CurBg := 10;  { vert clair }
  EmuVScr_Clear(P);
 End
 Else If (TargetCPU = '-CD') Or (TargetCPU = '-CP') Then
 Begin
  { Emulateur DOS : 80x25, fond noir, texte gris (attribut DOS standard 07h) }
  P.Cols := 80;
  P.Rows := 25;
  P.CurFg := 7;   { gris clair }
  P.CurBg := 0;   { noir       }
  EmuVScr_Clear(P);
 End;
 IsX86 := (TargetCPU = '-CD') Or (TargetCPU = '-CP');
 IsM68K := (TargetCPU = '-C68000') Or (TargetCPU = '-CATARIST') Or
           (TargetCPU = '-CAMIGA');
 IsCray := (TargetCPU = '-CCRAY1');
 Is6502 := (TargetCPU = '-CAPPLEII') Or (TargetCPU = '-CC64') Or
           (TargetCPU = '-CATARI400') Or (TargetCPU = '-CATARI800') Or
           (TargetCPU = '-CNES') Or (TargetCPU = '-CATARI2600');
 IsZ80 := (TargetCPU = '-CTRS80') Or (TargetCPU = '-CMSX') Or
          (TargetCPU = '-CADAM');
 Is6809 := (TargetCPU = '-CCOCO3') Or (TargetCPU = '-CDRAGON32') Or
           (TargetCPU = '-CDRAGON64') Or (TargetCPU = '-CTO7') Or
           (TargetCPU = '-CTO8') Or (TargetCPU = '-CMO5');
 If TargetCPU = '-CZ80'    Then CPUName := 'Zilog Z80'
 Else If TargetCPU = '-C6502'   Then CPUName := 'MOS 6502'
 Else If TargetCPU = '-C6809'   Then CPUName := 'Motorola 6809'
 Else If TargetCPU = '-C68000'  Then CPUName := 'Motorola 68000'
 Else If TargetCPU = '-CATARIST'Then CPUName := 'Atari ST 68000'
 Else If TargetCPU = '-CAMIGA'  Then CPUName := 'Amiga 68000'
 Else If TargetCPU = '-CD'      Then CPUName := 'Intel 8086 mode reel'
 Else If TargetCPU = '-CP'      Then CPUName := 'Intel 8086 mode protege'
 Else If TargetCPU = '-CCRAY1'  Then CPUName := 'Cray-1 (COS)'
 Else If TargetCPU = '-CAPPLEII'Then CPUName := 'Apple II (6502)'
 Else If TargetCPU = '-CC64'    Then CPUName := 'Commodore 64 (6510)'
 Else If TargetCPU = '-CATARI400'Then CPUName := 'Atari 400 (6502)'
 Else If TargetCPU = '-CATARI800'Then CPUName := 'Atari 800 (6502)'
 Else If TargetCPU = '-CNES'    Then CPUName := 'NES (Ricoh 2A03)'
 Else If TargetCPU = '-CATARI2600' Then CPUName := 'Atari 2600 (6507)'
 Else If TargetCPU = '-CTRS80'  Then CPUName := 'TRS-80 (Z80)'
 Else If TargetCPU = '-CMSX'    Then CPUName := 'MSX (Z80)'
 Else If TargetCPU = '-CADAM'   Then CPUName := 'Coleco Adam (Z80)'
 Else If TargetCPU = '-CCOCO3'   Then CPUName := 'Tandy CoCo 3 (6809)'
 Else If TargetCPU = '-CDRAGON32'Then CPUName := 'Dragon 32 (6809)'
 Else If TargetCPU = '-CDRAGON64'Then CPUName := 'Dragon 64 (6809)'
 Else If TargetCPU = '-CTO7'     Then CPUName := 'Thomson TO7 (6809)'
 Else If TargetCPU = '-CTO8'     Then CPUName := 'Thomson TO8 (6809)'
 Else If TargetCPU = '-CMO5'     Then CPUName := 'Thomson MO5 (6809)'
 Else CPUName := TargetCPU;
 OldFg := P.CurFg; OldBg := P.CurBg;
 P.CurFg := 14; P.CurBg := OldBg;
 EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
 P.CurFg := OldFg; P.CurBg := OldBg;
 EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
 EmuVScr_WriteStr(P, 'Cible    : ' + TargetCPU + ' (' + CPUName + ')');
 EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
 EmuVScr_WriteStr(P, 'Binaire  : ' + BinaryPath);
 EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
 If IsM68K Then Begin
  { ----- Emulateur Motorola 68000 ----- }
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 14;
  If TargetCPU = '-CATARIST' Then
   EmuVScr_WriteStr(P, 'Chargement du binaire 68000 (Atari ST PRG)...')
  Else
   EmuVScr_WriteStr(P, 'Chargement du binaire 68000 (Amiga Hunk)...');
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 7;
  { Initialisation des registres et de la memoire }
  FillChar(M68K_Mem, SizeOf(M68K_Mem), 0);
  For Steps := 0 To 7 Do Begin
   M68K_D[Steps] := 0;
   M68K_A[Steps] := 0;
  End;
  M68K_PC := 0;
  M68K_SR := $2000;
  M68K_Halted := False;
  M68K_ExitCode := 0;
  M68K_Verbose := False;
  M68K_Cycles := 0;
  M68K_Panel := @P;
  Loaded := False;
  EntryAddr := -1;
  { Pour Atari ST, essayer le format PRG GEMDOS en premier }
  If TargetCPU = '-CATARIST' Then
   Loaded := M68K_LoadPRG(BinaryPath, EntryAddr);
  { Sinon (ou si echec), essayer le format Amiga Hunk }
  If Not Loaded Then
   Loaded := M68K_LoadAmigaHunk(BinaryPath, EntryAddr);
  { Si Amiga Hunk a echoue aussi, essayer PRG (au cas ou) }
  If (Not Loaded) And (TargetCPU <> '-CATARIST') Then
   Loaded := M68K_LoadPRG(BinaryPath, EntryAddr);
  { En dernier recours, essayer S-Record }
  If Not Loaded Then
   Loaded := M68K_LoadSRecord(BinaryPath, EntryAddr);
  If Not Loaded Then Begin
   P.CurFg := 12;
   EmuVScr_WriteStr(P,
    'Erreur : impossible de charger ' + BinaryPath);
   EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
   EmuVScr_WriteStr(P,
    '(formats supportes : Atari PRG .prg, Amiga Hunk .exe, S-Record .s19)');
   P.CurFg := OldFg;
   P.Running := False;
   P.Fault := sfEndProgram;
   P.StatusMsg := 'Echec chargement binaire 68000';
   Exit;
  End;
  If EntryAddr >= 0 Then
   M68K_PC := EntryAddr;
  M68K_A[7] := MEM_SIZE - 4;
  { Empiler une adresse de retour sentinelle : quand le programme    }
  { Amiga/AtariST executera son RTS final, PC sautera a $00FFFFFE,   }
  { ce qui sera detecte par M68K_Step pour arreter proprement.       }
  M68K_A[7] := M68K_A[7] - 4;
  M68K_Write32(M68K_A[7], $00FFFFFE);
  P.CurFg := 10;
  EmuVScr_WriteStr(P, 'Programme charge (PC=$' +
   M68K_HexN(M68K_PC, 6) + ')');
  P.CurFg := 7;
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  { Boucle d execution }
  Steps := 0;
  While (Not M68K_Halted) And (Steps < MAX_CYCLES) Do Begin
   M68K_Step;
   Inc(Steps);
  End;
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 11;
  If M68K_Halted Then
   EmuVScr_WriteStr(P, '[Fin d execution : TRAP #15 termine apres ' +
    IntToStr(Steps) + ' instructions, code=' +
    IntToStr(M68K_ExitCode) + ']')
  Else
   EmuVScr_WriteStr(P, '[Limite de ' + IntToStr(MAX_CYCLES) +
    ' cycles atteinte (boucle infinie ?)]');
  P.CurFg := OldFg;
  P.CurBg := OldBg;
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  EmuVScr_WriteStr(P, 'Appuyez sur Echap pour fermer.');
  P.Running := False;
  P.Fault := sfEndProgram;
  P.StatusMsg := 'Emulateur 68000 : ' + IntToStr(Steps) + ' instr.';
  Exit;
 End;
 If IsCray Then Begin
  { ----- Emulateur Cray-1 ----- }
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 14;
  EmuVScr_WriteStr(P, 'Chargement du binaire Cray-1 (COS Absolute)...');
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 7;
  For Steps := 0 To 7 Do CRAY1_Reg[Steps] := 0;
  CRAY1_PC := 0;
  CRAY1_Halted := False;
  CRAY1_ExitCode := 0;
  CRAY1_Cycles := 0;
  CRAY1_Panel := @P;
  EntryAddr := 0;
  Loaded := CRAY1_LoadAbs(BinaryPath, EntryAddr);
  If Not Loaded Then Begin
   P.CurFg := 12;
   EmuVScr_WriteStr(P,
    'Erreur : impossible de charger ' + BinaryPath);
   EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
   EmuVScr_WriteStr(P,
    '(format attendu : COS Absolute Binary, signature CRAY-1)');
   P.CurFg := OldFg;
   P.Running := False;
   P.Fault := sfEndProgram;
   P.StatusMsg := 'Echec chargement binaire Cray-1';
   Exit;
  End;
  { Le backend TPCW32 place le code utilisateur a parcel 0,         }
  { l entree COS pointe ailleurs ($0200 typiquement). On execute    }
  { directement le code utilisateur.                                }
  CRAY1_PC := 0;
  P.CurFg := 10;
  EmuVScr_WriteStr(P, 'Programme charge (entree COS=$' +
   M68K_HexN(EntryAddr, 4) + ', execution depuis $0000)');
  P.CurFg := 7;
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  Steps := 0;
  While (Not CRAY1_Halted) And (Steps < 1000000) Do Begin
   CRAY1_Step;
   Inc(Steps);
  End;
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 11;
  If CRAY1_Halted Then
   EmuVScr_WriteStr(P, '[Fin Cray-1 : ' +
    IntToStr(Steps) + ' instructions, code=' +
    IntToStr(CRAY1_ExitCode) + ']')
  Else
   EmuVScr_WriteStr(P, '[Limite 1000000 instructions atteinte]');
  P.CurFg := OldFg;
  P.CurBg := OldBg;
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  EmuVScr_WriteStr(P, 'Appuyez sur Echap pour fermer.');
  P.Running := False;
  P.Fault := sfEndProgram;
  P.StatusMsg := 'Emulateur Cray-1 : ' + IntToStr(Steps) + ' instr.';
  Exit;
 End;
 If Is6502 Then Begin
  { ----- Emulateur 6502 (Apple II / C64 / Atari 8b / NES / A2600) ----- }
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 14;
  EmuVScr_WriteStr(P, 'Chargement du binaire ' + CPUName + '...');
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  P.CurFg := 7;
  FillChar(CPU6502_Mem, SizeOf(CPU6502_Mem), 0);
  CPU6502_Panel := @P;
  EntryAddr16 := 0;
  Loaded := False;
  If TargetCPU = '-CAPPLEII' Then Begin
   CPU6502_Variant := 0;
   Loaded := CPU6502_LoadAppleBin(BinaryPath, EntryAddr16);
  End
  Else If TargetCPU = '-CC64' Then Begin
   CPU6502_Variant := 1;
   Loaded := CPU6502_LoadC64Prg(BinaryPath, EntryAddr16);
  End
  Else If (TargetCPU = '-CATARI400') Or (TargetCPU = '-CATARI800') Then Begin
   CPU6502_Variant := 2;
   Loaded := CPU6502_LoadAtariXex(BinaryPath, EntryAddr16);
  End
  Else If TargetCPU = '-CNES' Then Begin
   CPU6502_Variant := 3;
   { Compat ancien moteur texte }
   NesPpu_Addr := 0;
   NesPpu_Latch := False;
   NesPpu_Rendered := False;
   FillChar(NesPpu_NameTable, SizeOf(NesPpu_NameTable), $20);
   { Reset etat PPU complet }
   NesPpu_Reset;
   FillChar(NesChr, SizeOf(NesChr), 0);
   FillChar(NesPrgRom, SizeOf(NesPrgRom), 0);
   FillChar(NesChrRom, SizeOf(NesChrRom), 0);
   NesMapper := 0;
   NesUseChrRam := False;
   NesPrgBlocksTotal := 0;
   NesChrBlocksTotal := 0;
   { Lecture entete iNES + extraction PRG/CHR/mirroring/mapper }
   NesPrgBlocks := 1;
   NesChrBlocks := 0;
   NesMirror := 0;
   Loaded := False;
   Assign(NesFH, BinaryPath);
   {$I-} Reset(NesFH, 1); {$I+}
   If IOResult = 0 Then Begin
    BlockRead(NesFH, NesHdr, 16, NesBR);
    If (NesBR = 16) And (NesHdr[0] = $4E) And (NesHdr[1] = $45) And
       (NesHdr[2] = $53) And (NesHdr[3] = $1A) Then Begin
     NesPrgBlocks := NesHdr[4];
     NesChrBlocks := NesHdr[5];
     NesPrgBlocksTotal := NesPrgBlocks;
     NesChrBlocksTotal := NesChrBlocks;
     If NesChrBlocks = 0 Then NesUseChrRam := True;
     If (NesHdr[6] And $01) <> 0 Then NesMirror := 1
                                  Else NesMirror := 0;
     If (NesHdr[6] And $08) <> 0 Then NesMirror := 2;
     NesMapper := ((NesHdr[6] Shr 4) And $0F) Or (NesHdr[7] And $F0);
     { Heuristique "DiskDude!" : si bytes 12-15 non nuls, le byte 7   }
     { contient des donnees garbage (vieux iNES) ; ignorer byte 7.    }
     If (NesHdr[12] <> 0) Or (NesHdr[13] <> 0) Or
        (NesHdr[14] <> 0) Or (NesHdr[15] <> 0) Then
      NesMapper := (NesHdr[6] Shr 4) And $0F;
     { Skip trainer si bit 2 du flag6 }
     If (NesHdr[6] And $04) <> 0 Then
      Seek(NesFH, 16 + 512)
     Else
      Seek(NesFH, 16);
     { Charger PRG-ROM complete dans NesPrgRom }
     NesPrgSize := LongInt(NesPrgBlocks) * 16384;
     If NesPrgSize > SizeOf(NesPrgRom) Then NesPrgSize := SizeOf(NesPrgRom);
     If NesPrgSize > 0 Then
      BlockRead(NesFH, NesPrgRom, NesPrgSize, NesBR);
     { Charger CHR-ROM complete dans NesChrRom }
     NesChrSize := LongInt(NesChrBlocks) * 8192;
     If NesChrSize > SizeOf(NesChrRom) Then NesChrSize := SizeOf(NesChrRom);
     If NesChrSize > 0 Then
      BlockRead(NesFH, NesChrRom, NesChrSize, NesBR);
     Loaded := True;
    End;
    Close(NesFH);
   End;
   If Loaded Then Begin
    { Mapping initial mapper 0 (NROM) : copie directe ; sinon delegue }
    If NesMapper = 0 Then Begin
     { NROM : copier PRG en $8000, mirroir si NROM-128 }
     For Steps := 0 To 16383 Do
      CPU6502_Mem[$8000 + Steps] := NesPrgRom[Steps];
     If NesPrgBlocksTotal >= 2 Then
      For Steps := 0 To 16383 Do
       CPU6502_Mem[$C000 + Steps] := NesPrgRom[16384 + Steps]
     Else
      For Steps := 0 To 16383 Do
       CPU6502_Mem[$C000 + Steps] := NesPrgRom[Steps];
     { CHR -> NesChr }
     If NesChrBlocksTotal >= 1 Then
      For Steps := 0 To 8191 Do
       NesChr[Steps] := NesChrRom[Steps];
    End Else
     Nes_MapperInit;
    EntryAddr16 := CPU6502_Mem[$FFFC] Or (Word(CPU6502_Mem[$FFFD]) Shl 8);
   End;
   NesActive := Loaded;
  End
  Else If TargetCPU = '-CATARI2600' Then Begin
   CPU6502_Variant := 4;
   { Atari 2600 : ROM mappee a $F000-$FFFF sur 6507 (bus 13 bits).      }
   { Tailles supportees :                                                }
   {   2K  -> 1 banque, miroir $F000-$F7FF dans $F800-$FFFF              }
   {   4K  -> 1 banque                                                   }
   {   8K  -> F8 (2 banques, hotspots $FFF8/$FFF9)                       }
   {   16K -> F6 (4 banques, hotspots $FFF6..$FFF9)                      }
   {   32K -> F4 (8 banques, hotspots $FFF4..$FFFB)                      }
   FillChar(A2600_ROM, SizeOf(A2600_ROM), 0);
   A2600_BankCnt := 1; A2600_CurBank := 0; A2600_ROMSize := 0;
   Assign(NesFH, BinaryPath);
   {$I-} Reset(NesFH, 1); {$I+}
   If IOResult = 0 Then Begin
    A2600_ROMSize := FileSize(NesFH);
    If A2600_ROMSize > SizeOf(A2600_ROM) Then
     A2600_ROMSize := SizeOf(A2600_ROM);
    BlockRead(NesFH, A2600_ROM, A2600_ROMSize, NesBR);
    Close(NesFH);
    Loaded := NesBR > 0;
   End Else Loaded := False;
   If Loaded Then Begin
    Case A2600_ROMSize Of
      8192:  A2600_BankCnt := 2;   { F8 }
      16384: A2600_BankCnt := 4;   { F6 }
      32768: A2600_BankCnt := 8;   { F4 }
      12288: A2600_BankCnt := 3;   { FA (12K) }
    Else
      A2600_BankCnt := 1;
    End;
    { Detection scheme : heuristique simple sur taille puis contenu.   }
    { F8SC/F6SC/F4SC : empreinte typique sur octets de RAM init.       }
    { On scanne les hotspots dans la ROM pour distinguer F8 vs E0/FE.  }
    A2600_Scheme := 0;
    { Detection 3E+ prioritaire : signature "TJ" dans les 8 derniers   }
    { octets de la ROM (convention Stella/TJentzsch).                  }
    If A2600_ROMSize >= 8192 Then Begin
      For Steps := A2600_ROMSize - 8 To A2600_ROMSize - 2 Do
        If (Steps >= 0) And (Steps + 1 < A2600_ROMSize)
           And (A2600_ROM[Steps] = $54)            { 'T' }
           And (A2600_ROM[Steps + 1] = $4A) Then Begin   { 'J' }
          A2600_Scheme := 13;
          Break;
        End;
    End;
    If A2600_Scheme <> 13 Then
    Case A2600_ROMSize Of
      8192: Begin
        A2600_Scheme := 1;                          { F8 par defaut }
        { Detection FE : recherche du pattern LDA ($xx,X) + bit 5 }
        { Detection E0 : presence d'acces $1FE0 dans la ROM       }
        For Steps := 0 To 8190 Do
          If (A2600_ROM[Steps] = $8D) And
             (A2600_ROM[Steps + 1] = $E0) And
             (A2600_ROM[Steps + 2] = $1F) Then Begin
            A2600_Scheme := 9;                      { E0 Parker }
            Break;
          End;
        { Detection 3E : pattern STA $3E (85 3E) au moins 2 fois. }
        If A2600_Scheme = 1 Then Begin
          NesPrgSize := 0;
          For Steps := 0 To 8190 Do
            If (A2600_ROM[Steps] = $85) And (A2600_ROM[Steps + 1] = $3E) Then
              Inc(NesPrgSize);
          If NesPrgSize >= 2 Then A2600_Scheme := 12;   { 3E }
        End;
      End;
      16384: Begin
        A2600_Scheme := 2;                          { F6 par defaut }
        { Detection E7 : presence d'acces $1FE7 (hotspot RAM 1K) }
        For Steps := 0 To 16382 Do
          If (A2600_ROM[Steps] = $E7) And
             (A2600_ROM[Steps + 1] = $1F) Then Begin
            A2600_Scheme := 11;                     { E7 M-Network }
            Break;
          End;
        { Detection 3E : pattern STA $3E. }
        If A2600_Scheme = 2 Then Begin
          NesPrgSize := 0;
          For Steps := 0 To 16382 Do
            If (A2600_ROM[Steps] = $85) And (A2600_ROM[Steps + 1] = $3E) Then
              Inc(NesPrgSize);
          If NesPrgSize >= 2 Then A2600_Scheme := 12;
        End;
      End;
      32768: Begin
        A2600_Scheme := 3;                          { F4 par defaut }
        { Detection 3E : pattern STA $3E. }
        NesPrgSize := 0;
        For Steps := 0 To 32766 Do
          If (A2600_ROM[Steps] = $85) And (A2600_ROM[Steps + 1] = $3E) Then
            Inc(NesPrgSize);
        If NesPrgSize >= 2 Then A2600_Scheme := 12;
      End;
      12288: A2600_Scheme := 7;                     { FA }
    End;
    { Mapper la derniere banque a $F000-$FFFF (les ROMs bankswitchees     }
    { placent typiquement leur vecteur reset dans la derniere banque).   }
    A2600_CurBank := A2600_BankCnt - 1;
    If A2600_ROMSize <= 2048 Then Begin
     { 2K : copier deux fois dans la banque pour faire 4K }
     For Steps := 0 To 2047 Do
      A2600_ROM[2048 + Steps] := A2600_ROM[Steps];
    End;
    { E0 : initialiser les 3 slots commutables sur la derniere banque, }
    { slot 3 fixe a la banque 7 (1K * 7..8K).                           }
    If A2600_Scheme = 9 Then Begin
     A2600_E0Slot[0] := 4;
     A2600_E0Slot[1] := 5;
     A2600_E0Slot[2] := 6;
     A2600_E0RebuildSlot(0, 4);
     A2600_E0RebuildSlot(1, 5);
     A2600_E0RebuildSlot(2, 6);
     { Slot 3 (= $1C00-$1FFF) fixe a banque 7 }
     For NesPrgSize := 0 To 1023 Do
      For NesPrgBlocks := 0 To 7 Do
       CPU6502_Mem[(NesPrgBlocks * $2000) + $1C00 + NesPrgSize] :=
        A2600_ROM[7 * 1024 + NesPrgSize];
    End Else If A2600_Scheme = 11 Then Begin
     { E7 : lower 2K = banque 0, upper 2K = banque 7 fixe }
     A2600_E7_LowerRAM := False;
     A2600_E7_LowerROM := 0;
     A2600_E7_R256Bank := 0;
     A2600_E7_RebuildLower;
     A2600_E7_RebuildUpper;
    End Else If A2600_Scheme = 12 Then Begin
     { 3E : recalcul nb banques 2K (ROM) au lieu de 4K.                }
     { Slot bas = banque 0 ROM par defaut, slot haut = derniere banque.}
     A2600_BankCnt := A2600_ROMSize Div 2048;
     If A2600_BankCnt < 1 Then A2600_BankCnt := 1;
     A2600_3E_RAMMode := False;
     A2600_3E_LowerROM := 0;
     A2600_3E_LowerRAM := 0;
     FillChar(A2600_3E_RAM, SizeOf(A2600_3E_RAM), 0);
     A2600_3E_RebuildLower;
     A2600_3E_RebuildUpper;
    End Else If A2600_Scheme = 13 Then Begin
     { 3E+ : banques ROM 1K. Init slots 0..3 = banques 0..3, ou les   }
     { 4 dernieres banques si la ROM en a moins, pour que le vecteur   }
     { reset (banque finale) tombe dans le slot 3.                     }
     A2600_BankCnt := A2600_ROMSize Div 1024;
     If A2600_BankCnt < 1 Then A2600_BankCnt := 1;
     FillChar(A2600_3E_RAM, SizeOf(A2600_3E_RAM), 0);
     For Steps := 0 To 3 Do Begin
       A2600_3EP_SlotIsRAM[Steps] := False;
       If A2600_BankCnt >= 4 Then
         A2600_3EP_SlotBank[Steps] := A2600_BankCnt - 4 + Steps
       Else
         A2600_3EP_SlotBank[Steps] := Steps Mod A2600_BankCnt;
       A2600_3EP_RebuildSlot(Steps);
     End;
    End Else Begin
    For NesPrgSize := 0 To 4095 Do Begin
     CPU6502_Mem[$1000 + NesPrgSize] := A2600_ROM[(A2600_CurBank * 4096) + NesPrgSize];
     CPU6502_Mem[$3000 + NesPrgSize] := CPU6502_Mem[$1000 + NesPrgSize];
     CPU6502_Mem[$5000 + NesPrgSize] := CPU6502_Mem[$1000 + NesPrgSize];
     CPU6502_Mem[$7000 + NesPrgSize] := CPU6502_Mem[$1000 + NesPrgSize];
     CPU6502_Mem[$9000 + NesPrgSize] := CPU6502_Mem[$1000 + NesPrgSize];
     CPU6502_Mem[$B000 + NesPrgSize] := CPU6502_Mem[$1000 + NesPrgSize];
     CPU6502_Mem[$D000 + NesPrgSize] := CPU6502_Mem[$1000 + NesPrgSize];
     CPU6502_Mem[$F000 + NesPrgSize] := CPU6502_Mem[$1000 + NesPrgSize];
    End;
    End;
   End;
   EntryAddr16 := CPU6502_Mem[$FFFC] Or (Word(CPU6502_Mem[$FFFD]) Shl 8);
  End;
  If Not Loaded Then Begin
   P.CurFg := 12;
   EmuVScr_WriteStr(P,
    'Erreur : impossible de charger ' + BinaryPath);
   EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
   P.CurFg := OldFg;
   P.Running := False;
   P.Fault := sfEndProgram;
   P.StatusMsg := 'Echec chargement binaire 6502';
   Exit;
  End;
  CPU6502_Reset(EntryAddr16);
  P.CurFg := 10;
  EmuVScr_WriteStr(P, 'Programme charge (PC=$' +
   M68K_HexN(CPU6502_PC, 4) + ')');
  P.CurFg := 7;
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  EmuVScr_PutChar(P, #13); EmuVScr_PutChar(P, #10);
  Steps := 0;
  If NesActive And (TargetCPU = '-CNES') Then Begin
   { ----- Boucle NES par trame (60 Hz approx.) ----- }
   NesFrameLimit    := 36000;  { 10 minutes a 60 Hz }
   NesInstrPerFrame := 7460;   { ~29780 cycles / 4 cy/instr moyenne }
   NesFrameNo := 0;
   NesKeyEsc := False;
   NesFBFirst := True;
   FillChar(NesFBPrev, SizeOf(NesFBPrev), $FF);
   { Premier rendu pour afficher le panneau }
   DrawEmulatorPanel(P);
   EntryAddr := GetTimestamp;
   While (Not CPU6502_Halted) And (NesFrameNo < NesFrameLimit) And
         (Not NesKeyEsc) Do Begin
    { Drainer tampon clavier (gestion ESC + activation focus) }
    While KeyPressed Do Begin
     NesChrSize := Ord(ReadKey);
     If NesChrSize = 27 Then NesKeyEsc := True;
     If NesChrSize = 0 Then If KeyPressed Then ReadKey;
    End;
    If NesKeyEsc Then Break;
    { Lire etat manette pour cette trame }
    NesPollInput;
    { Effacer vblank/sprite0 hit au debut du prerender (scanline 261) }
    NesPpuStatus := NesPpuStatus And $7F;
    NesPpuStatus := NesPpuStatus And $BF;
    { Phase visible : ~80% des instructions (scanlines 0..239) }
    For NesPrgSize := 0 To (NesInstrPerFrame * 4 Div 5) - 1 Do Begin
     If CPU6502_Halted Then Break;
     CPU6502_Step;
     Inc(Steps);
    End;
    { Rendre la trame avant le declenchement de vblank pour que    }
    { le NMI handler voit l ecran deja construit                    }
    NesPpu_RenderFrame;
    { Declencher vblank + NMI si active (scanline 241) }
    NesPpuStatus := NesPpuStatus Or $80;
    If (NesPpuCtrl And $80) <> 0 Then NesNmiPending := True;
    { Phase vblank : ~20% des instructions restantes }
    For NesPrgSize := 0 To (NesInstrPerFrame Div 5) - 1 Do Begin
     If CPU6502_Halted Then Break;
     CPU6502_Step;
     Inc(Steps);
    End;
    { Afficher }
    DrawEmulatorPanel(P);
    Inc(NesFrameNo);
    { Pacing 60 Hz : attendre la fin du quantum 16 ms }
    {$IFDEF WINDOWS}
    NesChrSize := GetTimestamp - EntryAddr;
    If NesChrSize < 16 Then WinSleep(16 - NesChrSize);
    EntryAddr := GetTimestamp;
    {$ENDIF}
   End;
   NesActive := False;
  End Else If TargetCPU = '-CATARI2600' Then Begin
   { ----- Boucle Atari 2600 par trame (60 Hz approx.) ----- }
   A2600_Active := True;
   A2600_Reset;
   { Premier rendu pour afficher le panneau }
   DrawEmulatorPanel(P);
   {$IFDEF WINDOWS}
   EntryAddr := GetTimestamp;
   {$ENDIF}
   While (Not CPU6502_Halted) And (A2600_FrameNo < 36000) And
         (Not A2600_KeyEsc) Do Begin
    { Drainer tampon clavier (Esc) }
    While KeyPressed Do Begin
     NesChrSize := Ord(ReadKey);
     If NesChrSize = 27 Then A2600_KeyEsc := True;
     If NesChrSize = 0 Then If KeyPressed Then NesChrSize := Ord(ReadKey);
    End;
    If A2600_KeyEsc Then Break;
    { Lecture directe du clavier (joystick + tir) via Win32 :       }
    { Fleches / WASD / Enter+Espace=tir.                            }
    A2600_KeyJoy := 0;
    A2600_KeyFire := False;
    {$IFDEF WINDOWS}
    If (GetAsyncKeyState($26) < 0) Or (GetAsyncKeyState($57) < 0) Then
     A2600_KeyJoy := A2600_KeyJoy Or 1;  { Up    / W }
    If (GetAsyncKeyState($28) < 0) Or (GetAsyncKeyState($53) < 0) Then
     A2600_KeyJoy := A2600_KeyJoy Or 2;  { Down  / S }
    If (GetAsyncKeyState($25) < 0) Or (GetAsyncKeyState($41) < 0) Then
     A2600_KeyJoy := A2600_KeyJoy Or 4;  { Left  / A }
    If (GetAsyncKeyState($27) < 0) Or (GetAsyncKeyState($44) < 0) Then
     A2600_KeyJoy := A2600_KeyJoy Or 8;  { Right / D }
    If (GetAsyncKeyState($20) < 0) Or (GetAsyncKeyState($0D) < 0) Or
       (GetAsyncKeyState($11) < 0) Or (GetAsyncKeyState($5A) < 0) Or
       (GetAsyncKeyState($58) < 0) Then
     A2600_KeyFire := True;             { Espace/Enter/Ctrl/Z/X = tir }
    If GetAsyncKeyState($1B) < 0 Then A2600_KeyEsc := True;
    { F4 = toggle controleur Driving (Indy 500) sur port P0,         }
    { encodage Gray sur SWCHA bits D4-D5. Detection front montant.   }
    If GetAsyncKeyState($73) < 0 Then Begin
     If Not A2600_DriveF4_Prev Then Begin
      A2600_DrivingP0 := Not A2600_DrivingP0;
      A2600_DriveP0_Pos := 0;
     End;
     A2600_DriveF4_Prev := True;
    End Else
     A2600_DriveF4_Prev := False;
    { F5 = toggle Booster Grip (Omega Race, Thrust). Touche B = bouton }
    { booster (INPT1). Le fire principal reste sur INPT4.              }
    If GetAsyncKeyState($74) < 0 Then Begin
     If Not A2600_BoostF5_Prev Then
      A2600_BoosterP0 := Not A2600_BoosterP0;
     A2600_BoostF5_Prev := True;
    End Else
     A2600_BoostF5_Prev := False;
    A2600_KeyBooster := A2600_BoosterP0 And (GetAsyncKeyState($42) < 0);
    {$ENDIF}
    { Mode Driving : Left/Right font tourner la roue (1 cran Gray par }
    { frame). Sens : Left = antihoraire, Right = horaire.             }
    If A2600_DrivingP0 Then Begin
     If (A2600_KeyJoy And 4) <> 0 Then
      A2600_DriveP0_Pos := (A2600_DriveP0_Pos + 3) And 3;
     If (A2600_KeyJoy And 8) <> 0 Then
      A2600_DriveP0_Pos := (A2600_DriveP0_Pos + 1) And 3;
    End;
    { Pour les jeux paddle : Left/Right deplacent le paddle 0.   }
    { 1 frame = 1 pas de 4 unites (0..255).                       }
    If Not A2600_DrivingP0 Then Begin
     If (A2600_KeyJoy And 4) <> 0 Then Begin
       Dec(A2600_Paddle[0], 4);
       If A2600_Paddle[0] < 0 Then A2600_Paddle[0] := 0;
     End;
     If (A2600_KeyJoy And 8) <> 0 Then Begin
       Inc(A2600_Paddle[0], 4);
       If A2600_Paddle[0] > 255 Then A2600_Paddle[0] := 255;
     End;
    End;
    { Mettre a jour CPU6502_Mem pour les LDA directs sur les ports.   }
    { RIOT I/O est mirrore aux 4 adresses ou bit12=0, bit7=1, bit9=1 :}
    { $0280, $0680, $0A80, $0E80 (+offset 0..$1F).                     }
    NesChrSize := $FF;
    If A2600_DrivingP0 Then Begin
      NesChrSize := NesChrSize And Not $30;
      Case A2600_DriveP0_Pos And 3 Of
        1: NesChrSize := NesChrSize Or $10;
        2: NesChrSize := NesChrSize Or $30;
        3: NesChrSize := NesChrSize Or $20;
      End;
    End Else Begin
      If (A2600_KeyJoy And 1) <> 0 Then NesChrSize := NesChrSize And Not $10;
      If (A2600_KeyJoy And 2) <> 0 Then NesChrSize := NesChrSize And Not $20;
      If (A2600_KeyJoy And 4) <> 0 Then NesChrSize := NesChrSize And Not $40;
      If (A2600_KeyJoy And 8) <> 0 Then NesChrSize := NesChrSize And Not $80;
    End;
    For NesPrgBlocks := 0 To 3 Do Begin
     CPU6502_Mem[$0280 + NesPrgBlocks * $0400] := NesChrSize;    { SWCHA }
     CPU6502_Mem[$0282 + NesPrgBlocks * $0400] := $3F;           { SWCHB }
     CPU6502_Mem[$0284 + NesPrgBlocks * $0400] := 0;             { INTIM }
     If A2600_KeyFire Then
      CPU6502_Mem[$028C + NesPrgBlocks * $0400] := 0
     Else
      CPU6502_Mem[$028C + NesPrgBlocks * $0400] := $80;          { INPT4 }
     CPU6502_Mem[$028D + NesPrgBlocks * $0400] := $80;           { INPT5 }
    End;
    { Executer une trame : 262 (NTSC) ou 312 (PAL) scanlines. }
    { La trame est consideree finie sur front montant VSYNC (FrameReady).}
    { Si le jeu ne strobe pas VSYNC (jeu bug), repli sur LinesPerFrame.  }
    A2600_FrameReady := False;
    A2600_HMOVEComb := False;
    A2600_PhantomCombX := -1;
    For NesPrgSize := 0 To 8500 Do Begin
     If CPU6502_Halted Then Break;
     If A2600_FrameReady Then Break;
     If A2600_ScanLine >= A2600_LinesPerFrame Then Begin
       { Repli sans VSYNC : on simule un wrap manuel pour eviter le gel. }
       A2600_ScanLine := 0;
       A2600_VisLine := 0;
       A2600_CurY := 0;
       A2600_LastX := -1;
       Break;
     End;
     CPU6502_Step;
     Inc(Steps);
     A2600_AfterInstr;
    End;
    DrawEmulatorPanel(P);
    Inc(A2600_FrameNo);
    {$IFDEF WINDOWS}
    NesChrSize := GetTimestamp - EntryAddr;
    If A2600_PAL Then Begin
      If NesChrSize < 20 Then WinSleep(20 - NesChrSize);   { 50 Hz }
    End Else Begin
      If NesChrSize < 16 Then WinSleep(16 - NesChrSize);   { 60 Hz }
    End;
    EntryAddr := GetTimestamp;
    {$ENDIF}
   End;
   A2600_Active := False;
  End Else Begin
   While (Not CPU6502_Halted) And (Steps < 1000000) Do Begin
    CPU6502_Step;
    Inc(Steps);
   End;
