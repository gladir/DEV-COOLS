{ --- VOL --- }

Procedure TermCmd_VOL(Var TP: TTerminalPanel; ParamStr: String);
Var
 Idx: Byte;
 DL: Char;
 Lbl: String;
 P: String;
Begin
 P := TermExtractParam(ParamStr, 1);
 { Determiner le lecteur cible : argument explicite, ou lecteur courant }
 If (Length(P) >= 2) And (P[2] = ':') Then
  DL := UpCase(P[1])
 Else If TP.VirtDrive = 0 Then DL := 'A'
 Else If TP.VirtDrive = 1 Then DL := 'B'
 Else DL := 'C';
 If (DL = 'A') Or (DL = 'B') Then Begin
  If DL = 'A' Then Idx := 0 Else Idx := 1;
  Term_VirtEnsureMounted(Idx);
  If Not EmuFloppyOpen[Idx] Then Begin
   TermAddLine(TP,
    'Le systeme ne peut pas trouver le lecteur specifie.');
   Exit;
  End;
  If Not FatVol[Idx].Mounted Then Begin
   TermAddLine(TP, ' Volume in drive ' + DL +
    ' has no recognized file system.');
   Exit;
  End;
  Lbl := FatVol[Idx].VolLabel;
  If Lbl = '' Then
   TermAddLine(TP, ' Volume in drive ' + DL + ' has no label.')
  Else
   TermAddLine(TP, ' Volume in drive ' + DL + ' is ' + Lbl);
  TermAddLine(TP, ' Volume Serial Number is 0000-0000');
  Exit;
 End;
 TermAddLine(TP, ' Volume in drive ' + DL + ' has no label.');
 TermAddLine(TP, ' Volume Serial Number is 1234-5678');
End;

{ --- DF (Bash) : afficher les disquettes montees via /DISK0 et /DISK1 --- }

Procedure TermCmd_DF(Var TP: TTerminalPanel);
Var
 Idx: Byte;
 Total, Used, Free: LongInt;
 TotalK, UsedK, FreeK: LongInt;
 UsePct: Integer;
 MountP, Fs, Src: String;
 SizeS, UsedS, FreeS, PctS: String;

 Function PadLeft(S: String; W: Integer): String;
 Begin
  While Length(S) < W Do S := ' ' + S;
  PadLeft := S;
 End;

 Function PadRight(S: String; W: Integer): String;
 Begin
  While Length(S) < W Do S := S + ' ';
  PadRight := S;
 End;

 Function FmtFs(Idx: Byte): String;
 Begin
  If Not FatVol[Idx].Mounted Then FmtFs := 'raw'
  Else If FatVol[Idx].FATType = 12 Then FmtFs := 'vfat12'
  Else If FatVol[Idx].FATType = 16 Then FmtFs := 'vfat16'
  Else FmtFs := 'vfat';
 End;

Begin
 TermAddLine(TP,
  'Filesystem     1K-blocks      Used Available Use% Mounted on');
 If (Not EmuFloppyOpen[0]) And (Not EmuFloppyOpen[1]) Then Begin
  TermAddLine(TP,
   '(aucune image montee ; utilisez /DISK0:img ou /DISK1:img)');
  Exit;
 End;
 For Idx := 0 To 1 Do Begin
  If Not EmuFloppyOpen[Idx] Then Continue;
  Term_VirtEnsureMounted(Idx);
  Total := EmuFloppySize[Idx];
  If FatVol[Idx].Mounted Then Begin
   Free := Fat_FreeBytes(Idx);
   { L espace "utile" exclut zones reservees/FAT/root, mais pour rester
     simple on rapporte Total et Free tels que vus par DF. }
   If Free > Total Then Free := Total;
   Used := Total - Free;
  End Else Begin
   Free := 0;
   Used := Total;
  End;
  TotalK := Total Div 1024;
  UsedK  := Used  Div 1024;
  FreeK  := Free  Div 1024;
  If Total > 0 Then
   UsePct := Integer((LongInt(Used) * 100 + Total Div 2) Div Total)
  Else
   UsePct := 0;
  If UsePct < 0 Then UsePct := 0;
  If UsePct > 100 Then UsePct := 100;
  Fs := FmtFs(Idx);
  Src := EmuFloppyName[Idx];
  If Src = '' Then Src := '(image)';
  MountP := '/mnt/' + Chr(Ord('a') + Idx);
  Str(TotalK, SizeS); SizeS := PadLeft(SizeS, 9);
  Str(UsedK, UsedS);  UsedS := PadLeft(UsedS, 9);
  Str(FreeK, FreeS);  FreeS := PadLeft(FreeS, 9);
  Str(UsePct, PctS);  PctS := PadLeft(PctS + '%', 4);
  TermAddLine(TP, PadRight(Fs, 14) + ' ' + SizeS + ' ' +
   UsedS + ' ' + FreeS + ' ' + PctS + ' ' + MountP);
  TermAddLine(TP, '  source: ' + Src);
 End;
End;

{ --- Sauvegarder l historique d affichage dans un fichier --- }

Procedure TermSaveHistory(Var TP: TTerminalPanel);
Var
 F: Text;
 N: PTermLine;
 FName: String;
 IOErr: Word;
Begin
 Case TP.Shell Of
  SK_CMD:        FName := 'terminal-cmd.log';
  SK_POWERSHELL: FName := 'terminal-ps.log';
  SK_BASH:       FName := 'terminal-bash.log';
  SK_AMIGADOS:   FName := 'terminal-amiga.log';
 Else
  FName := 'terminal.log';
 End;
 Assign(F, FName);
 {$I-} Rewrite(F); {$I+}
 IOErr := IOResult;
 If IOErr <> 0 Then Begin
  TermAddLine(TP, 'Erreur : impossible d''ouvrir ' + FName);
  Exit;
 End;
 N := TP.HistHead;
 While N <> Nil Do Begin
  WriteLn(F, N^.S);
  N := N^.Next;
 End;
 Close(F);
 TermAddLine(TP, 'Historique sauve dans ' + FName +
  ' (' + IntToStr(TP.HistCount) + ' lignes)');
End;

{ --- Zoom : agrandir/reduire la hauteur du panneau terminal --- }

Procedure TermZoomCycle;
Var
 ScrH, BottomY, NewH: Integer;
Begin
 ScrH := GetScreenHeight;
 Inc(TermZoomLvl);
 If TermZoomLvl > 2 Then TermZoomLvl := 0;
 Case TermZoomLvl Of
  0: NewH := OUTPUT_HEIGHT;
  1: NewH := OUTPUT_HEIGHT + 80;
  2: NewH := OUTPUT_HEIGHT + 160;
 End;
 BottomY := ScrH - NewH - STATUSBAR_HEIGHT;
 TermY := BottomY;
 TermHeight := NewH;
 FullRepaintNeeded := True;
End;

{ --- Restaurer la hauteur normale du terminal (niveau de zoom 0) --- }

Procedure TermZoomReset;
Var
 ScrH, BottomY: Integer;
Begin
 If TermZoomLvl = 0 Then Exit;
 ScrH := GetScreenHeight;
 TermZoomLvl := 0;
 BottomY := ScrH - OUTPUT_HEIGHT - STATUSBAR_HEIGHT;
 TermY := BottomY;
 TermHeight := OUTPUT_HEIGHT;
 FullRepaintNeeded := True;
End;

{ --- PWD --- }

Procedure TermCmd_PWD(Var TP: TTerminalPanel);
Var
 Dir: String;
Begin
 GetDir(0, Dir);
 TermAddLine(TP, Dir);
End;

{ --- PUSHD / PUSH-LOCATION --- }

Procedure TermCmd_PUSHD(Var TP: TTerminalPanel;
 ParamStr: String);
Var
 Err: Word;
 FirstParam, Dir: String;
Begin
 FirstParam := TermExtractParam(ParamStr, 1);
 If Length(FirstParam) > 0 Then Begin
  GetDir(0, Dir);
  If TP.NumberDirStack >= MAX_TERM_DIRSTACK Then Begin
   TermAddLine(TP, 'Pile de repertoires pleine');
   Exit;
  End;
  Inc(TP.NumberDirStack);
  TP.DirStack[TP.NumberDirStack] := Dir;
  {$I-} ChDir(FirstParam); {$I+}
  Err := IOResult;
  If Err <> 0 Then Begin
   Dec(TP.NumberDirStack);
   TermAddLine(TP, TermGetErrorMessage(Err));
  End;
 End Else Begin
  GetDir(0, Dir);
  If TP.NumberDirStack >= MAX_TERM_DIRSTACK Then Begin
   TermAddLine(TP, 'Pile de repertoires pleine');
   Exit;
  End;
  Inc(TP.NumberDirStack);
  TP.DirStack[TP.NumberDirStack] := Dir;
 End;
End;

{ --- POPD / POP-LOCATION --- }

Procedure TermCmd_POPD(Var TP: TTerminalPanel);
Var
 Err: Word;
 Dir: String;
Begin
 If TP.NumberDirStack <= 0 Then Begin
  TermAddLine(TP, 'Pile de repertoires vide');
  Exit;
 End;
 Dir := TP.DirStack[TP.NumberDirStack];
 Dec(TP.NumberDirStack);
 {$I-} ChDir(Dir); {$I+}
 Err := IOResult;
 If Err <> 0 Then
  TermAddLine(TP, TermGetErrorMessage(Err));
End;

{ --- SET --- }

Procedure TermCmd_SET(Var TP: TTerminalPanel;
 ParamStr: String);
Var
 I: Integer;
Begin
 If ParamStr = '' Then Begin
  For I := 0 To EnvCount Do
   TermAddLine(TP, EnvStr(I));
 End Else
  TermAddLine(TP,
   'SET variable=valeur n''est pas supporte dans le terminal integre. ' +
   'Utilisez l''environnement systeme.');
End;

