{ ============================================================
  EXECUTEUR DE COMMANDES DU TERMINAL
  ============================================================ }

Procedure TermExecuteCommand(Var TP: TTerminalPanel;
 CmdStr: String);
Var
 CurrCmd, ParamStr, PipeS: String;
 Err: Word;
Begin
 CmdStr := TermTrim(CmdStr);
 If CmdStr = '' Then Exit;
 TermAddHistory(TP, CmdStr);
 { Changement de lecteur : A:, B:, C:, D:, ... }
 If (Length(CmdStr) = 2) And (CmdStr[2] = ':') And
  (CmdStr[1] In ['A'..'Z', 'a'..'z']) Then Begin
  { Lecteurs virtuels A: et B: : sur image montee, on bascule le
    terminal en mode disque virtuel. }
  If UpCase(CmdStr[1]) = 'A' Then Begin
   Term_VirtEnsureMounted(0);
   If EmuFloppyOpen[0] And FatVol[0].Mounted Then Begin
    TP.VirtDrive := 0;
    If TP.VirtCwd = '' Then TP.VirtCwd := '\';
    Exit;
   End Else If EmuFloppyOpen[0] Then Begin
    TermAddLine(TP, 'Volume A: monte mais format FAT non reconnu.');
    Exit;
   End Else Begin
    TermAddLine(TP,
     'Le systeme ne peut pas trouver le lecteur specifie.');
    TermAddLine(TP,
     '(Monter une image avec /DISK0:fichier.img au demarrage.)');
    Exit;
   End;
  End;
  If UpCase(CmdStr[1]) = 'B' Then Begin
   Term_VirtEnsureMounted(1);
   If EmuFloppyOpen[1] And FatVol[1].Mounted Then Begin
    TP.VirtDrive := 1;
    If TP.VirtCwd = '' Then TP.VirtCwd := '\';
    Exit;
   End Else If EmuFloppyOpen[1] Then Begin
    TermAddLine(TP, 'Volume B: monte mais format FAT non reconnu.');
    Exit;
   End Else Begin
    TermAddLine(TP,
     'Le systeme ne peut pas trouver le lecteur specifie.');
    TermAddLine(TP,
     '(Monter une image avec /DISK1:fichier.img au demarrage.)');
    Exit;
   End;
  End;
  { Autres lecteurs : on revient au mode hote standard }
  TP.VirtDrive := -1;
  {$I-}
  GetDir(Ord(UpCase(CmdStr[1])) - 64, PipeS);
  If PipeS <> '' Then ChDir(PipeS)
   Else ChDir(CmdStr + '\');
  {$I+}
  Err := IOResult;
  If Err <> 0 Then
   TermAddLine(TP, TermGetErrorMessage(Err));
  Exit;
 End;
 { Extraire la commande et les parametres }
 TermExtractCommand(CmdStr, CurrCmd, ParamStr);
 { Dispatcher selon le type de shell }
 Case TP.Shell Of
  SK_CMD: Begin
   If CurrCmd = 'EXIT' Then
    TermVisible := False
   Else If (CurrCmd = 'CD') Or (CurrCmd = 'CHDIR') Then
    TermCmd_CD(TP, ParamStr)
   Else If CurrCmd = 'CLS' Then
    TermCmd_CLS(TP)
   Else If (CurrCmd = 'DIR') Then
    TermCmd_DIR_CMD(TP, ParamStr)
   Else If CurrCmd = 'COPY' Then
    TermCmd_COPY(TP, ParamStr)
   Else If (CurrCmd = 'DEL') Or (CurrCmd = 'DELETE') Or
    (CurrCmd = 'ERASE') Or (CurrCmd = 'ERA') Then
    TermCmd_DEL(TP, ParamStr)
   Else If CurrCmd = 'ECHO' Then
    TermCmd_ECHO(TP, ParamStr)
   Else If (CurrCmd = 'MKDIR') Or (CurrCmd = 'MD') Then
    TermCmd_MKDIR(TP, ParamStr)
   Else If (CurrCmd = 'RMDIR') Or (CurrCmd = 'RD') Then
    TermCmd_RMDIR(TP, ParamStr)
   Else If (CurrCmd = 'REN') Or (CurrCmd = 'RENAME') Then
    TermCmd_REN(TP, ParamStr)
   Else If CurrCmd = 'MOVE' Then
    TermCmd_MOVE(TP, ParamStr)
   Else If CurrCmd = 'TYPE' Then
    TermCmd_TYPE(TP, ParamStr)
   Else If CurrCmd = 'DATE' Then
    TermCmd_DATE(TP)
   Else If CurrCmd = 'TIME' Then
    TermCmd_TIME(TP)
   Else If CurrCmd = 'VER' Then
    TermCmd_VER(TP)
   Else If CurrCmd = 'PWD' Then
    TermCmd_PWD(TP)
   Else If CurrCmd = 'PUSHD' Then
    TermCmd_PUSHD(TP, ParamStr)
   Else If CurrCmd = 'POPD' Then
    TermCmd_POPD(TP)
   Else If CurrCmd = 'SET' Then
    TermCmd_SET(TP, ParamStr)
   Else If CurrCmd = 'VOL' Then
    TermCmd_VOL(TP, ParamStr)
   Else If (CurrCmd = 'HELP') Or (CurrCmd = '?') Then
    TermCmd_HELP(TP)
   Else
    TermAddLine(TP,
     '''' + CurrCmd +
     ''' n''est pas reconnu comme commande interne.');
  End;
  SK_POWERSHELL: Begin
   If CurrCmd = 'EXIT' Then
    TermVisible := False
   Else If (CurrCmd = 'CD') Or (CurrCmd = 'CHDIR') Or
    (CurrCmd = 'SET-LOCATION') Then
    TermCmd_CD(TP, ParamStr)
   Else If (CurrCmd = 'CLS') Or
    (CurrCmd = 'CLEAR-HOST') Or
    (CurrCmd = 'CLEAR') Then
    TermCmd_CLS(TP)
   Else If (CurrCmd = 'DIR') Or (CurrCmd = 'LS') Or
    (CurrCmd = 'GET-CHILDITEM') Then
    TermCmd_DIR_PS(TP, ParamStr)
   Else If (CurrCmd = 'COPY') Or
    (CurrCmd = 'COPY-ITEM') Then
    TermCmd_COPY(TP, ParamStr)
   Else If (CurrCmd = 'DEL') Or
    (CurrCmd = 'REMOVE-ITEM') Then
    TermCmd_DEL(TP, ParamStr)
   Else If (CurrCmd = 'ECHO') Or
    (CurrCmd = 'WRITE-OUTPUT') Then
    TermCmd_ECHO(TP, ParamStr)
   Else If (CurrCmd = 'MKDIR') Or
    (CurrCmd = 'NEW-ITEM') Then
    TermCmd_MKDIR(TP, ParamStr)
   Else If (CurrCmd = 'RMDIR') Or (CurrCmd = 'RD') Then
    TermCmd_RMDIR(TP, ParamStr)
   Else If (CurrCmd = 'REN') Or
    (CurrCmd = 'RENAME-ITEM') Then
    TermCmd_REN(TP, ParamStr)
   Else If (CurrCmd = 'MOVE') Or
    (CurrCmd = 'MOVE-ITEM') Then
    TermCmd_MOVE(TP, ParamStr)
   Else If (CurrCmd = 'TYPE') Or (CurrCmd = 'CAT') Or
    (CurrCmd = 'GET-CONTENT') Then
    TermCmd_TYPE(TP, ParamStr)
   Else If CurrCmd = 'DATE' Then
    TermCmd_DATE(TP)
   Else If CurrCmd = 'TIME' Then
    TermCmd_TIME(TP)
   Else If CurrCmd = 'VER' Then
    TermCmd_VER(TP)
   Else If CurrCmd = 'PWD' Then
    TermCmd_PWD(TP)
   Else If (CurrCmd = 'PUSHD') Or
    (CurrCmd = 'PUSH-LOCATION') Then
    TermCmd_PUSHD(TP, ParamStr)
   Else If (CurrCmd = 'POPD') Or
    (CurrCmd = 'POP-LOCATION') Then
    TermCmd_POPD(TP)
   Else If CurrCmd = 'SET' Then
    TermCmd_SET(TP, ParamStr)
   Else If CurrCmd = 'VOL' Then
    TermCmd_VOL(TP, ParamStr)
   Else If (CurrCmd = 'HELP') Or
    (CurrCmd = 'GET-HELP') Or (CurrCmd = '?') Then
    TermCmd_HELP(TP)
   Else
    TermAddLine(TP, CurrCmd +
     ' : le terme n''est pas reconnu comme nom de cmdlet.');
  End;
  SK_BASH: Begin
   If CurrCmd = 'EXIT' Then
    TermVisible := False
   Else If CurrCmd = 'CD' Then
    TermCmd_CD(TP, ParamStr)
   Else If CurrCmd = 'CLEAR' Then
    TermCmd_CLS(TP)
   Else If (CurrCmd = 'LS') Or (CurrCmd = 'DIR') Then
    TermCmd_DIR_BASH(TP, ParamStr)
   Else If CurrCmd = 'CP' Then
    TermCmd_COPY(TP, ParamStr)
   Else If CurrCmd = 'RM' Then
    TermCmd_DEL(TP, ParamStr)
   Else If CurrCmd = 'ECHO' Then
    TermCmd_ECHO(TP, ParamStr)
   Else If CurrCmd = 'MKDIR' Then
    TermCmd_MKDIR(TP, ParamStr)
   Else If CurrCmd = 'RMDIR' Then
    TermCmd_RMDIR(TP, ParamStr)
   Else If CurrCmd = 'MV' Then
    TermCmd_MOVE(TP, ParamStr)
   Else If CurrCmd = 'CAT' Then
    TermCmd_TYPE(TP, ParamStr)
   Else If CurrCmd = 'DATE' Then
    TermCmd_DATE(TP)
   Else If CurrCmd = 'PWD' Then
    TermCmd_PWD(TP)
   Else If CurrCmd = 'PUSHD' Then
    TermCmd_PUSHD(TP, ParamStr)
   Else If CurrCmd = 'POPD' Then
    TermCmd_POPD(TP)
   Else If CurrCmd = 'EXPORT' Then
    TermCmd_SET(TP, ParamStr)
   Else If CurrCmd = 'DF' Then
    TermCmd_DF(TP)
   Else If CurrCmd = 'HISTORY' Then
    TermCmd_HELP(TP)
   Else If CurrCmd = 'HELP' Then
    TermCmd_HELP(TP)
   Else
    TermAddLine(TP, 'bash: ' + CurrCmd +
     ': command not found');
  End;
  SK_AMIGADOS: Begin
   If (CurrCmd = 'QUIT') Or (CurrCmd = 'ENDCLI') Then
    TermVisible := False
   Else If CurrCmd = 'CD' Then
    TermCmd_CD(TP, ParamStr)
   Else If CurrCmd = 'DIR' Then
    TermCmd_DIR_AMIGA(TP, ParamStr)
   Else If CurrCmd = 'LIST' Then
    TermCmd_DIR_AMIGA(TP, ParamStr)
   Else If CurrCmd = 'COPY' Then
    TermCmd_COPY(TP, ParamStr)
   Else If CurrCmd = 'DELETE' Then
    TermCmd_DEL(TP, ParamStr)
   Else If CurrCmd = 'ECHO' Then
    TermCmd_ECHO(TP, ParamStr)
   Else If CurrCmd = 'MAKEDIR' Then
    TermCmd_MKDIR(TP, ParamStr)
   Else If CurrCmd = 'RENAME' Then
    TermCmd_REN(TP, ParamStr)
   Else If CurrCmd = 'TYPE' Then
    TermCmd_TYPE(TP, ParamStr)
   Else If CurrCmd = 'DATE' Then
    TermCmd_DATE(TP)
   Else If CurrCmd = 'INFO' Then
    TermCmd_PWD(TP)
   Else If CurrCmd = 'STACK' Then
    TermAddLine(TP, 'Stack size: 4096')
   Else If CurrCmd = 'STATUS' Then
    TermAddLine(TP, 'Process 1: AmigaDOS console')
   Else If CurrCmd = 'FAULT' Then
    TermAddLine(TP, 'No error')
   Else If CurrCmd = 'WHY' Then
    TermAddLine(TP, 'No error to report')
   Else If CurrCmd = 'PROTECT' Then
    TermAddLine(TP, 'Usage: PROTECT file flags')
   Else If CurrCmd = 'SEARCH' Then
    TermAddLine(TP, 'Usage: SEARCH FROM path SEARCH string')
   Else If CurrCmd = 'SORT' Then
    TermAddLine(TP, 'Usage: SORT FROM file TO file')
   Else If CurrCmd = 'JOIN' Then
    TermAddLine(TP, 'Usage: JOIN file1 file2 AS destfile')
   Else If CurrCmd = 'PATH' Then
    TermCmd_PWD(TP)
   Else If CurrCmd = 'NEWCLI' Then
    TermAddLine(TP, 'New CLI process started.')
   Else If CurrCmd = 'ASSIGN' Then
    TermAddLine(TP, 'Usage: ASSIGN name: device')
   Else If (CurrCmd = '?') Or (CurrCmd = 'HELP') Then Begin
    TermAddLine(TP, 'AmigaDOS built-in commands:');
    TermAddLine(TP, ' ASSIGN  CD     COPY    DATE   DELETE');
    TermAddLine(TP, ' DIR     ECHO   ENDCLI  FAULT  INFO');
    TermAddLine(TP, ' JOIN    LIST   MAKEDIR NEWCLI PATH');
    TermAddLine(TP, ' PROTECT QUIT   RENAME  SEARCH SORT');
    TermAddLine(TP, ' STACK   STATUS TYPE    WHY');
   End
   Else
    TermAddLine(TP, CurrCmd +
     ': Unknown command');
  End;
 End;
End;

{ --- Nom du fichier d historique des commandes par shell --- }

Function TermCmdHistFile(Kind: TShellKind): String;
Begin
 Case Kind Of
  SK_CMD:        TermCmdHistFile := 'devenv-cmd.hist';
  SK_POWERSHELL: TermCmdHistFile := 'devenv-ps.hist';
  SK_BASH:       TermCmdHistFile := 'devenv-bash.hist';
  SK_AMIGADOS:   TermCmdHistFile := 'devenv-amiga.hist';
 Else
  TermCmdHistFile := 'devenv-term.hist';
 End;
End;

{ --- Charger l historique des commandes depuis le fichier --- }

Procedure TermLoadCmdHistory(Var TP: TTerminalPanel);
Var
 F: Text;
 FName, L: String;
Begin
 FName := TermCmdHistFile(TP.Shell);
 Assign(F, FName);
 {$I-} Reset(F); {$I+}
 If IOResult <> 0 Then Exit;
 While Not Eof(F) Do Begin
  ReadLn(F, L);
  If L = '' Then Continue;
  If TP.NumberHistory >= MAX_TERM_HISTORY Then Begin
   Move(TP.TermHistory[2], TP.TermHistory[1],
    (MAX_TERM_HISTORY - 1) * SizeOf(TP.TermHistory[1]));
   TP.TermHistory[MAX_TERM_HISTORY] := L;
  End Else Begin
   Inc(TP.NumberHistory);
   TP.TermHistory[TP.NumberHistory] := L;
  End;
 End;
 Close(F);
 TP.HistoryPos := TP.NumberHistory + 1;
End;

{ --- Sauvegarder l historique des commandes dans le fichier --- }

Procedure TermSaveCmdHistory(Var TP: TTerminalPanel);
Var
 F: Text;
 FName: String;
 I: Integer;
Begin
 FName := TermCmdHistFile(TP.Shell);
 Assign(F, FName);
 {$I-} Rewrite(F); {$I+}
 If IOResult <> 0 Then Exit;
 For I := 1 To TP.NumberHistory Do
  WriteLn(F, TP.TermHistory[I]);
 Close(F);
End;

{ --- Initialiser un terminal (buffer seulement, pas le layout) --- }

Procedure InitTerminalPanel(Var TP: TTerminalPanel;
 Kind: TShellKind);
Var
 I: Integer;
Begin
 For I := 0 To MAX_TERM_LINES - 1 Do
  TP.Lines[I] := '';
 TP.LineCount := 0;
 TP.ScrollTop := 0;
 TP.HistHead := Nil;
 TP.HistTail := Nil;
 TP.HistCount := 0;
 TP.ScrollOffset := 0;
 TP.InputLine := '';
 TP.InputCol := 1;
 TP.PartialLine := '';
 TP.X := 0;
 TP.Y := 0;
 TP.Width := 0;
 TP.Height := 0;
 TP.Visible := False;
 TP.NeedRepaint := True;
 TP.Shell := Kind;
 TP.Echo := True;
 TP.NumberHistory := 0;
 TP.HistoryPos := 0;
 TP.NumberDirStack := 0;
 TP.VirtDrive := -1;
 TP.VirtCwd   := '\';
 TermLoadCmdHistory(TP);
End;

{ --- Initialiser le conteneur des deux terminaux --- }

Procedure InitTerminals;
Var
 ScrW, ScrH, BottomY: Integer;
Begin
 ScrW := GetScreenWidth;
 ScrH := GetScreenHeight;
 BottomY := ScrH - OUTPUT_HEIGHT - STATUSBAR_HEIGHT;
 TermX := 0;
 TermY := BottomY;
 TermWidth := ScrW - EXPLORER_WIDTH;
 TermHeight := OUTPUT_HEIGHT;
 TermZoomLvl := 0;
 TermVisible := False;
 TermSelectOpen := False;
 TermSelectIdx := 1;
 TerminalOnTop := True;
 TerminalHasFocus := False;
 ExplorerHasFocus := False;
 ActiveShell := SK_POWERSHELL;
 InitTerminalPanel(TermPanels[SK_CMD], SK_CMD);
 InitTerminalPanel(TermPanels[SK_POWERSHELL], SK_POWERSHELL);
 InitTerminalPanel(TermPanels[SK_BASH], SK_BASH);
 InitTerminalPanel(TermPanels[SK_AMIGADOS], SK_AMIGADOS);
End;

{ --- Dessiner le panneau terminal avec selecteur deroulant --- }

Procedure DrawTerminalPanel(Var TP: TTerminalPanel);
Var
 I, YPos, VisLines: Integer;
 S, PromptStr, SelLabel: String;
 MaxCols: Integer;
 PX, PY, PW, PH: Integer;
 SBX, SBY: Integer;
 SBarX, TextRight: Integer;
 TrackTop, TrackBottom, TrackH: Integer;
 ThumbY, ThumbH: Integer;
 Node: PTermLine;
 SkipBack: LongInt;
 TextLines: LongInt;
Begin
 If Not TermVisible Then Exit;
 PX := TermX;
 PY := TermY;
 PW := TermWidth;
 PH := TermHeight;
 { Fond sombre (8=gris fonce, pas 0 car SetBkColor remappe 0) }
 SetFillStyle(SolidFill, 8);
 Bar(PX, PY, PX + PW - 1, PY + PH - 1);
 { Barre du haut avec titre TERMINAL et SelectBox }
 SetFillStyle(SolidFill, CLR_TITLEBAR_ACTIVE);
 Bar(PX, PY, PX + PW - 1, PY + TERM_TAB_HEIGHT - 1);
 SetColor(15);
 OutTextXY(PX + 4, PY + 4, 'TERMINAL');
 { SelectBox deroulant a droite du titre }
 SBX := PX + 80;
 SBY := PY + 2;
 { Fond du selectbox : gris fonce }
 SetFillStyle(SolidFill, 8);
 Bar(SBX, SBY, SBX + TERM_SELECT_WIDTH - 1,
  SBY + TERM_SELECT_HEIGHT - 1);
 { Bordure du selectbox }
 SetColor(CLR_BORDER);
 Rectangle(SBX, SBY, SBX + TERM_SELECT_WIDTH - 1,
  SBY + TERM_SELECT_HEIGHT - 1);
 { Texte du SelectBox : nom du shell actif }
 Case ActiveShell Of
  SK_CMD:        SelLabel := 'Invite de commandes';
  SK_POWERSHELL: SelLabel := 'PowerShell dev';
  SK_BASH:       SelLabel := 'Bash';
  SK_AMIGADOS:   SelLabel := 'AmigaDOS';
 End;
 SetColor(15);
 OutTextXY(SBX + 4, SBY + 3, SelLabel);
 { Fleche vers le bas }
 OutTextXY(SBX + TERM_SELECT_WIDTH - 14, SBY + 3, #31);
 { Bordure du panneau }
 SetColor(CLR_BORDER);
 Rectangle(PX, PY, PX + PW - 1, PY + PH - 1);
 { Zone de texte (reserver TERM_SCROLLBAR_WIDTH a droite) }
 SBarX := PX + PW - TERM_SCROLLBAR_WIDTH - 1;
 TextRight := SBarX - 1;
 VisLines := (PH - TERM_TAB_HEIGHT - TERM_LINE_HEIGHT - 4)
  Div TERM_LINE_HEIGHT;
 If VisLines < 1 Then VisLines := 1;
 MaxCols := (TextRight - (PX + 4)) Div TERM_CHAR_WIDTH;
 If MaxCols < 10 Then MaxCols := 10;
 { Borner le decalage de defilement }
 If TP.HistCount = 0 Then TP.ScrollOffset := 0
 Else Begin
  If TP.ScrollOffset < 0 Then TP.ScrollOffset := 0;
  If TP.ScrollOffset > TP.HistCount - 1 Then
   TP.ScrollOffset := TP.HistCount - 1;
 End;
 { Trouver le noeud le plus en haut de la fenetre visible.
   Depuis le tail, reculer de (ScrollOffset + VisLines - 1) noeuds. }
 Node := TP.HistTail;
 SkipBack := TP.ScrollOffset + VisLines - 1;
 While (SkipBack > 0) And (Node <> Nil) And (Node^.Prev <> Nil) Do Begin
  Node := Node^.Prev;
  Dec(SkipBack);
 End;
 { Afficher VisLines lignes en avant }
 SetColor(15);
 YPos := PY + TERM_TAB_HEIGHT + 2;
 TextLines := 0;
 For I := 0 To VisLines - 1 Do Begin
  If Node <> Nil Then Begin
   S := Node^.S;
   If Length(S) > MaxCols Then
    S := Copy(S, 1, MaxCols);
   OutTextXY(PX + 4, YPos, S);
   Node := Node^.Next;
   Inc(TextLines);
  End;
  YPos := YPos + TERM_LINE_HEIGHT;
 End;
 { Ligne de saisie : visible uniquement si on n est pas remonte
   dans l historique (ScrollOffset = 0). Sinon on conserve la
   ligne pour le prochain affichage. }
 SetColor(10);
 If TextLines < VisLines Then
  YPos := PY + TERM_TAB_HEIGHT + 2
   + TextLines * TERM_LINE_HEIGHT
 Else
  YPos := PY + TERM_TAB_HEIGHT + 2
   + VisLines * TERM_LINE_HEIGHT;
 GetDir(0, PromptStr);
 If TP.VirtDrive >= 0 Then
  PromptStr := Term_VirtFullPath(TP);
 Case TP.Shell Of
  SK_POWERSHELL:
   PromptStr := 'PS ' + PromptStr + '> ' + TP.InputLine + '_';
  SK_BASH:
   PromptStr := 'user$ ' + TP.InputLine + '_';
  SK_AMIGADOS:
   PromptStr := '1.SYS:> ' + TP.InputLine + '_';
 Else
  PromptStr := PromptStr + '> ' + TP.InputLine + '_';
 End;
 If TP.ScrollOffset > 0 Then
  PromptStr := '-- defilement (PgUp/PgDn pour naviguer) --';
 If Length(PromptStr) > MaxCols Then
  PromptStr := Copy(PromptStr, 1, MaxCols);
 OutTextXY(PX + 4, YPos, PromptStr);
 { ===== Barre de defilement a droite ===== }
 { Fond de la barre }
 SetFillStyle(SolidFill, 7);
 Bar(SBarX, PY + TERM_TAB_HEIGHT,
  SBarX + TERM_SCROLLBAR_WIDTH - 1, PY + PH - 2);
 { Bordure }
 SetColor(CLR_BORDER);
 Rectangle(SBarX, PY + TERM_TAB_HEIGHT,
  SBarX + TERM_SCROLLBAR_WIDTH - 1, PY + PH - 2);
 { Bouton fleche haut }
 SetFillStyle(SolidFill, 8);
 Bar(SBarX + 1, PY + TERM_TAB_HEIGHT + 1,
  SBarX + TERM_SCROLLBAR_WIDTH - 2,
  PY + TERM_TAB_HEIGHT + TERM_SCROLL_BTN_H - 1);
 SetColor(CLR_BORDER);
 Rectangle(SBarX + 1, PY + TERM_TAB_HEIGHT + 1,
  SBarX + TERM_SCROLLBAR_WIDTH - 2,
  PY + TERM_TAB_HEIGHT + TERM_SCROLL_BTN_H - 1);
 SetColor(15);
 OutTextXY(SBarX + 3, PY + TERM_TAB_HEIGHT + 3, #30);
 { Bouton fleche bas }
 SetFillStyle(SolidFill, 8);
 Bar(SBarX + 1, PY + PH - 2 - TERM_SCROLL_BTN_H,
  SBarX + TERM_SCROLLBAR_WIDTH - 2, PY + PH - 3);
 SetColor(CLR_BORDER);
 Rectangle(SBarX + 1, PY + PH - 2 - TERM_SCROLL_BTN_H,
  SBarX + TERM_SCROLLBAR_WIDTH - 2, PY + PH - 3);
 SetColor(15);
 OutTextXY(SBarX + 3, PY + PH - 1 - TERM_SCROLL_BTN_H + 2, #31);
 { Zone du curseur (entre les deux fleches) }
 TrackTop := PY + TERM_TAB_HEIGHT + TERM_SCROLL_BTN_H + 1;
 TrackBottom := PY + PH - 3 - TERM_SCROLL_BTN_H;
 TrackH := TrackBottom - TrackTop + 1;
 If TrackH < 4 Then TrackH := 4;
 { Curseur proportionnel : taille = VisLines / HistCount }
 If TP.HistCount > VisLines Then Begin
  ThumbH := (LongInt(VisLines) * TrackH) Div TP.HistCount;
  If ThumbH < 8 Then ThumbH := 8;
  If ThumbH > TrackH Then ThumbH := TrackH;
  { Position : 0 (bas) -> bas du track, max -> haut du track }
  { Position depuis le bas : ScrollOffset / (HistCount - VisLines) }
  If TP.HistCount > VisLines Then
   ThumbY := TrackBottom - ThumbH + 1
    - (LongInt(TP.ScrollOffset) * (TrackH - ThumbH))
      Div (TP.HistCount - VisLines)
  Else
   ThumbY := TrackTop;
 End Else Begin
  ThumbH := TrackH;
  ThumbY := TrackTop;
 End;
 SetFillStyle(SolidFill, CLR_TITLEBAR_ACTIVE);
 Bar(SBarX + 2, ThumbY,
  SBarX + TERM_SCROLLBAR_WIDTH - 3, ThumbY + ThumbH - 1);
 SetColor(CLR_BORDER);
 Rectangle(SBarX + 2, ThumbY,
  SBarX + TERM_SCROLLBAR_WIDTH - 3, ThumbY + ThumbH - 1);
 { Dessiner la liste deroulante PAR-DESSUS le texte }
 If TermSelectOpen Then Begin
  { Item 1 : Invite de commandes }
  If TermSelectIdx = 0 Then
   SetFillStyle(SolidFill, CLR_TITLEBAR_ACTIVE)
  Else
   SetFillStyle(SolidFill, 8);
  Bar(SBX, SBY + TERM_SELECT_HEIGHT,
   SBX + TERM_SELECT_WIDTH - 1,
   SBY + TERM_SELECT_HEIGHT + TERM_SELECT_ITEM_H - 1);
  SetColor(15);
  OutTextXY(SBX + 4, SBY + TERM_SELECT_HEIGHT + 3,
   'Invite de commandes');
  { Item 2 : PowerShell dev }
  If TermSelectIdx = 1 Then
   SetFillStyle(SolidFill, CLR_TITLEBAR_ACTIVE)
  Else
   SetFillStyle(SolidFill, 8);
  Bar(SBX, SBY + TERM_SELECT_HEIGHT + TERM_SELECT_ITEM_H,
   SBX + TERM_SELECT_WIDTH - 1,
   SBY + TERM_SELECT_HEIGHT + 2 * TERM_SELECT_ITEM_H - 1);
  SetColor(15);
  OutTextXY(SBX + 4,
   SBY + TERM_SELECT_HEIGHT + TERM_SELECT_ITEM_H + 3,
   'PowerShell dev');
  { Item 3 : Bash }
  If TermSelectIdx = 2 Then
   SetFillStyle(SolidFill, CLR_TITLEBAR_ACTIVE)
  Else
   SetFillStyle(SolidFill, 8);
  Bar(SBX, SBY + TERM_SELECT_HEIGHT + 2 * TERM_SELECT_ITEM_H,
   SBX + TERM_SELECT_WIDTH - 1,
   SBY + TERM_SELECT_HEIGHT + 3 * TERM_SELECT_ITEM_H - 1);
  SetColor(15);
  OutTextXY(SBX + 4,
   SBY + TERM_SELECT_HEIGHT + 2 * TERM_SELECT_ITEM_H + 3,
   'Bash');
  { Item 4 : AmigaDOS }
  If TermSelectIdx = 3 Then
   SetFillStyle(SolidFill, CLR_TITLEBAR_ACTIVE)
  Else
   SetFillStyle(SolidFill, 8);
  Bar(SBX, SBY + TERM_SELECT_HEIGHT + 3 * TERM_SELECT_ITEM_H,
   SBX + TERM_SELECT_WIDTH - 1,
   SBY + TERM_SELECT_HEIGHT + 4 * TERM_SELECT_ITEM_H - 1);
  SetColor(15);
  OutTextXY(SBX + 4,
   SBY + TERM_SELECT_HEIGHT + 3 * TERM_SELECT_ITEM_H + 3,
   'AmigaDOS');
  { Bordure de la liste }
  SetColor(CLR_BORDER);
  Rectangle(SBX, SBY + TERM_SELECT_HEIGHT,
   SBX + TERM_SELECT_WIDTH - 1,
   SBY + TERM_SELECT_HEIGHT + 4 * TERM_SELECT_ITEM_H - 1);
 End;
 TP.NeedRepaint := False;
End;

Procedure HandleTerminalEvent(Var TP: TTerminalPanel;
 Var Ev: TEvent);
Var
 Ch: Char;
 Dir: String;
 SBX, SBY: Integer;
 NewShell: TShellKind;
Begin
 If Not TermVisible Then Exit;
 { Position du SelectBox }
 SBX := TermX + 80;
 SBY := TermY + 2;
 { Clic souris }
 If (Ev.Kind = EV_MOUSE_DOWN) Then Begin
  { Clic droit dans la zone du terminal : menu contextuel }
  If (Ev.MouseBtn = MB_RIGHT) And
     (Ev.MouseX >= TermX) And
     (Ev.MouseX < TermX + TermWidth) And
     (Ev.MouseY >= TermY + TERM_TAB_HEIGHT) And
     (Ev.MouseY < TermY + TermHeight) Then Begin
   InitContextMenu(CtxMenu);
   CtxMenu.X := Ev.MouseX;
   CtxMenu.Y := Ev.MouseY;
   CtxMenu.Width := 200;
   AddContextItem(CtxMenu, 'Aide', 900);
   AddContextItem(CtxMenu, 'Sauvegarder historiques', 901);
   AddContextItem(CtxMenu, 'Zoom', 902);
   CtxMenu.Visible := True;
   DrawContextMenu(CtxMenu);
   Exit;
  End;
  { Si la liste deroulante est ouverte, verifier clic sur un item }
  If TermSelectOpen Then Begin
   { Item 1 : Invite de commandes }
   If (Ev.MouseX >= SBX) And
      (Ev.MouseX < SBX + TERM_SELECT_WIDTH) And
      (Ev.MouseY >= SBY + TERM_SELECT_HEIGHT) And
      (Ev.MouseY < SBY + TERM_SELECT_HEIGHT
       + TERM_SELECT_ITEM_H) Then Begin
    NewShell := SK_CMD;
    TermSelectOpen := False;
    If ActiveShell <> NewShell Then Begin
     ActiveShell := NewShell;
     If TermPanels[SK_CMD].LineCount = 0 Then
      TermAddLine(TermPanels[SK_CMD],
       'Invite de commandes developpeur. Tapez HELP.');
    End;
    TermPanels[ActiveShell].NeedRepaint := True;
    FullRepaintNeeded := True;
    Exit;
   End;
   { Item 2 : PowerShell dev }
   If (Ev.MouseX >= SBX) And
      (Ev.MouseX < SBX + TERM_SELECT_WIDTH) And
      (Ev.MouseY >= SBY + TERM_SELECT_HEIGHT
       + TERM_SELECT_ITEM_H) And
      (Ev.MouseY < SBY + TERM_SELECT_HEIGHT
       + 2 * TERM_SELECT_ITEM_H) Then Begin
    NewShell := SK_POWERSHELL;
    TermSelectOpen := False;
    If ActiveShell <> NewShell Then Begin
     ActiveShell := NewShell;
     If TermPanels[SK_POWERSHELL].LineCount = 0 Then
      TermAddLine(TermPanels[SK_POWERSHELL],
       'PowerShell developpeur. Tapez HELP.');
    End;
    TermPanels[ActiveShell].NeedRepaint := True;
    FullRepaintNeeded := True;
    Exit;
   End;
   { Item 3 : Bash }
   If (Ev.MouseX >= SBX) And
      (Ev.MouseX < SBX + TERM_SELECT_WIDTH) And
      (Ev.MouseY >= SBY + TERM_SELECT_HEIGHT
       + 2 * TERM_SELECT_ITEM_H) And
      (Ev.MouseY < SBY + TERM_SELECT_HEIGHT
       + 3 * TERM_SELECT_ITEM_H) Then Begin
    NewShell := SK_BASH;
    TermSelectOpen := False;
    If ActiveShell <> NewShell Then Begin
     ActiveShell := NewShell;
     If TermPanels[SK_BASH].LineCount = 0 Then
      TermAddLine(TermPanels[SK_BASH],
       'Bash terminal. Tapez help.');
    End;
    TermPanels[ActiveShell].NeedRepaint := True;
    FullRepaintNeeded := True;
    Exit;
   End;
   { Item 4 : AmigaDOS }
   If (Ev.MouseX >= SBX) And
      (Ev.MouseX < SBX + TERM_SELECT_WIDTH) And
      (Ev.MouseY >= SBY + TERM_SELECT_HEIGHT
       + 3 * TERM_SELECT_ITEM_H) And
      (Ev.MouseY < SBY + TERM_SELECT_HEIGHT
       + 4 * TERM_SELECT_ITEM_H) Then Begin
    NewShell := SK_AMIGADOS;
    TermSelectOpen := False;
    If ActiveShell <> NewShell Then Begin
     ActiveShell := NewShell;
     If TermPanels[SK_AMIGADOS].LineCount = 0 Then
      TermAddLine(TermPanels[SK_AMIGADOS],
       'AmigaDOS 3.1. Tapez ? pour la liste des commandes.');
    End;
    TermPanels[ActiveShell].NeedRepaint := True;
    FullRepaintNeeded := True;
    Exit;
   End;
   { Clic ailleurs : fermer la liste }
   TermSelectOpen := False;
   FullRepaintNeeded := True;
  End;
  { Clic sur le SelectBox ferme : ouvrir/fermer la liste }
  If (Ev.MouseX >= SBX) And
     (Ev.MouseX < SBX + TERM_SELECT_WIDTH) And
     (Ev.MouseY >= SBY) And
     (Ev.MouseY < SBY + TERM_SELECT_HEIGHT) Then Begin
   TermSelectOpen := Not TermSelectOpen;
   If TermSelectOpen Then
    Case ActiveShell Of
     SK_CMD:        TermSelectIdx := 0;
     SK_POWERSHELL: TermSelectIdx := 1;
     SK_BASH:       TermSelectIdx := 2;
     SK_AMIGADOS:   TermSelectIdx := 3;
    End;
   FullRepaintNeeded := True;
   Exit;
  End;
  { Clic dans la zone du terminal }
  If (Ev.MouseX >= TermX) And
     (Ev.MouseX < TermX + TermWidth) And
     (Ev.MouseY >= TermY) And
     (Ev.MouseY < TermY + TermHeight) Then Begin
   If TermSelectOpen Then Begin
    TermSelectOpen := False;
    FullRepaintNeeded := True;
   End;
   { Defilement via la barre a droite }
   If (Ev.MouseX >= TermX + TermWidth - TERM_SCROLLBAR_WIDTH - 1)
    And (Ev.MouseX < TermX + TermWidth - 1)
    And (Ev.MouseY >= TermY + TERM_TAB_HEIGHT) Then Begin
    { Bouton fleche haut : remonter d une ligne }
    If Ev.MouseY < TermY + TERM_TAB_HEIGHT
     + TERM_SCROLL_BTN_H Then Begin
     If TP.ScrollOffset < TP.HistCount - 1 Then Begin
      Inc(TP.ScrollOffset);
      TP.NeedRepaint := True;
      FullRepaintNeeded := True;
     End;
     Exit;
    End;
    { Bouton fleche bas : descendre d une ligne }
    If Ev.MouseY >= TermY + TermHeight - 2
     - TERM_SCROLL_BTN_H Then Begin
     If TP.ScrollOffset > 0 Then Begin
      Dec(TP.ScrollOffset);
      TP.NeedRepaint := True;
      FullRepaintNeeded := True;
     End;
     Exit;
    End;
    { Clic dans le track : page up/down selon position relative
      au curseur (heuristique simple : moitie haute = remonter,
      moitie basse = descendre, page = hauteur visible). }
    If Ev.MouseY < (TermY + TERM_TAB_HEIGHT
     + (TermHeight - TERM_TAB_HEIGHT) Div 2) Then Begin
     TP.ScrollOffset := TP.ScrollOffset +
      ((TermHeight - TERM_TAB_HEIGHT - TERM_LINE_HEIGHT - 4)
       Div TERM_LINE_HEIGHT);
     If TP.ScrollOffset > TP.HistCount - 1 Then
      TP.ScrollOffset := TP.HistCount - 1;
    End Else Begin
     TP.ScrollOffset := TP.ScrollOffset -
      ((TermHeight - TERM_TAB_HEIGHT - TERM_LINE_HEIGHT - 4)
       Div TERM_LINE_HEIGHT);
     If TP.ScrollOffset < 0 Then TP.ScrollOffset := 0;
    End;
    TP.NeedRepaint := True;
    FullRepaintNeeded := True;
    Exit;
   End;
   Exit;
  End;
 End;
 { Navigation clavier dans la liste deroulante }
 If TermSelectOpen Then Begin
  If Ev.Kind = EV_KEY_DOWN Then Begin
   If Ev.KeyCode = $48 Then Begin { Fleche haut }
    If TermSelectIdx > 0 Then
     Dec(TermSelectIdx);
    FullRepaintNeeded := True;
    Exit;
   End;
   If Ev.KeyCode = $50 Then Begin { Fleche bas }
    If TermSelectIdx < 3 Then
     Inc(TermSelectIdx);
    FullRepaintNeeded := True;
    Exit;
   End;
  End;
  If Ev.Kind = EV_KEY_CHAR Then Begin
   If Ev.KeyChar = #13 Then Begin { Enter : confirmer }
    Case TermSelectIdx Of
     0: NewShell := SK_CMD;
     1: NewShell := SK_POWERSHELL;
     2: NewShell := SK_BASH;
     3: NewShell := SK_AMIGADOS;
    End;
    TermSelectOpen := False;
    If ActiveShell <> NewShell Then Begin
     ActiveShell := NewShell;
     If TermPanels[ActiveShell].LineCount = 0 Then
      Case ActiveShell Of
       SK_CMD:
        TermAddLine(TermPanels[SK_CMD],
         'Invite de commandes developpeur. Tapez HELP.');
       SK_POWERSHELL:
        TermAddLine(TermPanels[SK_POWERSHELL],
         'PowerShell developpeur. Tapez HELP.');
       SK_BASH:
        TermAddLine(TermPanels[SK_BASH],
         'Bash terminal. Tapez help.');
       SK_AMIGADOS:
        TermAddLine(TermPanels[SK_AMIGADOS],
         'AmigaDOS 3.1. Tapez ? pour la liste des commandes.');
      End;
    End;
    TermPanels[ActiveShell].NeedRepaint := True;
    FullRepaintNeeded := True;
    Exit;
   End;
   If Ev.KeyChar = #27 Then Begin { Echap : fermer }
    TermSelectOpen := False;
    FullRepaintNeeded := True;
    Exit;
   End;
  End;
  Exit;
 End;
 { Clavier }
 If Ev.Kind = EV_KEY_CHAR Then Begin
  Ch := Ev.KeyChar;
  Case Ch Of
   #8: Begin { Backspace }
    If Length(TP.InputLine) > 0 Then Begin
     TP.InputLine := Copy(TP.InputLine, 1,
      Length(TP.InputLine) - 1);
     TP.NeedRepaint := True;
    End;
   End;
   #13: Begin { Enter }
    GetDir(0, Dir);
    { Toute saisie ramene la fenetre au bas de l historique }
    TP.ScrollOffset := 0;
    Case TP.Shell Of
     SK_POWERSHELL:
      TermAddLine(TP, 'PS ' + Dir + '> ' + TP.InputLine);
     SK_BASH:
      TermAddLine(TP, 'user$ ' + TP.InputLine);
     SK_AMIGADOS:
      TermAddLine(TP, '1.SYS:> ' + TP.InputLine);
    Else
     TermAddLine(TP, Dir + '> ' + TP.InputLine);
    End;
    TermExecuteCommand(TP, TP.InputLine);
    TP.InputLine := '';
    TP.InputCol := 1;
    TP.ScrollOffset := 0;
    TP.NeedRepaint := True;
   End;
   #27: ; { Echap : ne rien faire }
  Else
   If (Ord(Ch) >= 32) And
    (Length(TP.InputLine) < 240) Then Begin
    TP.InputLine := TP.InputLine + Ch;
    Inc(TP.InputCol);
    TP.NeedRepaint := True;
   End;
  End;
 End;
 { Fleche haut/bas pour naviguer dans l historique }
 If Ev.Kind = EV_KEY_DOWN Then Begin
  If (Ev.KeyCode = $48) And { Fleche haut }
   (TP.NumberHistory > 0) Then Begin
   If TP.HistoryPos > 1 Then
    Dec(TP.HistoryPos);
   TP.InputLine := TP.TermHistory[TP.HistoryPos];
   TP.InputCol := Length(TP.InputLine) + 1;
   TP.NeedRepaint := True;
  End
  Else If (Ev.KeyCode = $50) And { Fleche bas }
   (TP.NumberHistory > 0) Then Begin
   If TP.HistoryPos < TP.NumberHistory Then Begin
    Inc(TP.HistoryPos);
    TP.InputLine := TP.TermHistory[TP.HistoryPos];
   End Else Begin
    TP.HistoryPos := TP.NumberHistory + 1;
    TP.InputLine := '';
   End;
   TP.InputCol := Length(TP.InputLine) + 1;
   TP.NeedRepaint := True;
  End;
  { PageUp / PageDown : defilement de la fenetre d historique }
  If Ev.KeyCode = $49 Then Begin { PgUp }
   TP.ScrollOffset := TP.ScrollOffset +
    ((TermHeight - TERM_TAB_HEIGHT - TERM_LINE_HEIGHT - 4)
     Div TERM_LINE_HEIGHT);
   If TP.ScrollOffset > TP.HistCount - 1 Then
    TP.ScrollOffset := TP.HistCount - 1;
   If TP.ScrollOffset < 0 Then TP.ScrollOffset := 0;
   TP.NeedRepaint := True;
   FullRepaintNeeded := True;
  End
  Else If Ev.KeyCode = $51 Then Begin { PgDn }
   TP.ScrollOffset := TP.ScrollOffset -
    ((TermHeight - TERM_TAB_HEIGHT - TERM_LINE_HEIGHT - 4)
     Div TERM_LINE_HEIGHT);
   If TP.ScrollOffset < 0 Then TP.ScrollOffset := 0;
   TP.NeedRepaint := True;
   FullRepaintNeeded := True;
  End;
 End;
End;

