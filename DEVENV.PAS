{ --- Traiter un evenement global --- }

Procedure DispatchEvent(Var Ev: TEvent);
Var
 CtxTag: LongInt;
 I: Integer;
Begin
 If Ev.Kind = EV_NONE Then Exit;
 { Menu contextuel en priorite si visible }
 If CtxMenu.Visible Then Begin
  CtxTag := HandleContextMenuEvent(CtxMenu, Ev);
  If Not CtxMenu.Visible Then Begin
   FullRepaintNeeded := True;
   { Traiter la commande selectionnee }
   If CtxTag > 0 Then Begin
    { Plage MRU : 5000-5099 = fichier recent, 5100-5199 = projet recent }
    If (CtxTag >= 5000) And
       (CtxTag < 5200) Then Begin
     I := CtxTag Mod 100;
     If (I >= 0) And (I < MRUPopupCount) Then Begin
      FileDlg.SelectedFile := MRUPopupPaths[I];
      HandleOpenFileConfirmed;
      FullRepaintNeeded := True;
     End;
     Exit;
    End;
    Case CtxTag Of
     900: Begin { Aide du terminal }
      TermCmd_HELP(TermPanels[ActiveShell]);
      TermPanels[ActiveShell].NeedRepaint := True;
      FullRepaintNeeded := True;
     End;
     901: Begin { Sauvegarder l historique du terminal }
      TermSaveHistory(TermPanels[ActiveShell]);
      TermPanels[ActiveShell].NeedRepaint := True;
      FullRepaintNeeded := True;
     End;
     902: Begin { Cycler le zoom du terminal }
      TermZoomCycle;
     End;
     311, 411: Begin { Ajouter un fichier }
      InitFileDialog(FileDlg, False);
      LoadDirectoryFiles(FileDlg);
      FileDlg.Base.Visible := True;
      DrawFileDialog(FileDlg);
     End;
     320, 420, 520: Begin { Renommer }
      StartExplorerRename(SolExplorer, CtxMenu.NodeIdx);
      DrawExplorer(SolExplorer);
     End;
     500: Begin { Ouvrir }
      If (CtxMenu.NodeIdx >= 0) And
         (CtxMenu.NodeIdx < SolExplorer.NodeCount) Then
       OpenExplorerFileNode(SolExplorer, CtxMenu.NodeIdx);
     End;
     399: Begin { Proprietes du projet }
      InitProjectPropertiesDialog(ProjPropDlg);
      LoadProjectProperties(ProjPropDlg, CurrentProject);
      ShowProjectPropertiesDialog(ProjPropDlg);
     End;
     521: Begin { Supprimer fichier/reference }
      If (CtxMenu.NodeIdx >= 0) And
         (CtxMenu.NodeIdx < SolExplorer.NodeCount) Then
      Begin
       If SolExplorer.Nodes[CtxMenu.NodeIdx].Kind In
        [ENK_FILE_CS, ENK_FILE_VB, ENK_FILE_PAS,
         ENK_FILE_OTHER] Then
       Begin
        { Retirer du projet }
        If SolutionLoaded Then Begin
         I := FindFileInProject(CurrentProject,
          SolExplorer.Nodes[CtxMenu.NodeIdx].Caption);
         If I >= 0 Then
          RemoveFileFromProject(CurrentProject, I);
         SolutionModified := True;
         SaveCurrentSolution;
        End;
        { Retirer de l explorateur }
        RemoveExplorerNode(SolExplorer, CtxMenu.NodeIdx);
        RefreshExplorer(SolExplorer);
        SolExplorer.NeedRepaint := True;
       End
       Else If SolExplorer.Nodes[CtxMenu.NodeIdx].Kind
        = ENK_REFERENCE Then
       Begin
        If SolutionLoaded Then Begin
         I := FindReferenceInProject(CurrentProject,
          SolExplorer.Nodes[CtxMenu.NodeIdx].Caption);
         If I >= 0 Then
          RemoveReferenceFromProject(CurrentProject, I);
         SolutionModified := True;
         SaveCurrentSolution;
        End;
        RemoveExplorerNode(SolExplorer, CtxMenu.NodeIdx);
        RefreshExplorer(SolExplorer);
        SolExplorer.NeedRepaint := True;
       End;
      End;
     End;
    End;
   End;
  End;
  Exit;
 End;
 { Page de demarrage en priorite si visible }
 If StartPage.Visible Then Begin
  HandleStartPageEvent(StartPage, MRUList, Ev);
  Exit;
 End;
 { Raccourcis clavier globaux (touches speciales uniquement) }
 If (Ev.Kind = EV_KEY_DOWN) Then Begin
  Case Ev.KeyCode Of
   $6B: Begin { Alt+F4 : quitter }
    TryQuit;
    Exit;
   End;
   $2D: Begin { Alt+X : quitter }
    TryQuit;
    Exit;
   End;
   $3B: Begin { F1 : aide (stub) }
    { A implementer }
    Exit;
   End;
   $3F: Begin { F5 : demarrer le debogage }
    HandleStartDebugging;
    Exit;
   End;
   $40: Begin { F6 : generer la solution }
    HandleStartDebugging;
    Exit;
   End;
  End;
 End;
 If (Ev.Kind = EV_KEY_CHAR) Then Begin
  { Raccourcis Ctrl+lettre via KeyChar }
  If Ev.KeyChar = #19 Then Begin { Ctrl+S : enregistrer }
   HandleSaveCurrentFile;
   Exit;
  End;
  If Ev.KeyChar = #14 Then Begin { Ctrl+N : nouveau fichier }
   ShowNewFileDialog(NewFileDlg);
   Exit;
  End;
  If Ev.KeyChar = #15 Then Begin { Ctrl+O : ouvrir fichier }
   InitFileDialog(FileDlg, False);
   LoadDirectoryFiles(FileDlg);
   FileDlg.Base.Visible := True;
   DrawFileDialog(FileDlg);
   Exit;
  End;
  If Ev.KeyChar = #6 Then Begin { Ctrl+F : rechercher }
   ShowFindDialog(FindReplaceDlg);
   Exit;
  End;
  If (Ev.KeyChar = #8) And ((Ev.ShiftState And 2) <> 0) Then Begin
   { Ctrl+H : remplacer (distinguer de Backspace via ShiftState) }
   ShowReplaceDialog(FindReplaceDlg);
   Exit;
  End;
  If Ev.KeyChar = #7 Then Begin { Ctrl+G : aller a la ligne }
   If EditorReady Then
    ShowGoToLineDialog(ActiveEditor);
   Exit;
  End;
 End;
 { Distribuer aux panneaux dans l ordre de priorite }
 If MenuActive Then Begin
  HandleMenuEvent(Ev);
  Exit;
 End;
 If FindReplaceDlg.Base.Visible Then Begin
  HandleFindDialogEvent(FindReplaceDlg,
   Ord(Ev.Kind), Ev.KeyChar, Ev.MouseX, Ev.MouseY);
  If Not FindReplaceDlg.Base.Visible Then Begin
   If (FindReplaceDlg.Base.Result = DR_OK) And EditorReady Then Begin
    If FindReplaceDlg.IsReplaceMode Then Begin
     I := ReplaceAll(ActiveEditor, FindReplaceDlg.SearchText,
      FindReplaceDlg.ReplaceText, FindReplaceDlg.Options);
     AppendOutput(OutputPanel,
      'Remplacement : ' + IntToStr(I) +
      ' occurrence(s) remplacee(s).', 0);
    End Else
     FindNext(ActiveEditor, FindReplaceDlg.SearchText,
      FindReplaceDlg.Options);
    EnsureCursorVisible(ActiveEditor);
   End;
   FullRepaintNeeded := True;
  End;
  Exit;
 End;
 If FileDlg.Base.Visible Then Begin
  HandleFileDialogEvent(FileDlg, Ev);
  If Not FileDlg.Base.Visible Then Begin
   If FileDlg.Base.Result = DR_OK Then Begin
    If FileDlg.FolderMode Then
     HandleOpenFolderConfirmed
    Else
     HandleOpenFileConfirmed;
   End;
   FileDlg.FolderMode := False;
   FullRepaintNeeded := True;
  End;
  DrawFileDialog(FileDlg);
  Exit;
 End;
 If NewFileDlg.Base.Visible Then Begin
  HandleNewFileDialogEvent(NewFileDlg, Ev);
  If Not NewFileDlg.Base.Visible Then Begin
   If NewFileDlg.Confirmed Then
    HandleNewFileConfirmed;
   FullRepaintNeeded := True;
  End;
  DrawNewFileDialog(NewFileDlg);
  Exit;
 End;
 If NewProjDlg.Base.Visible Then Begin
  HandleNewProjectDialogEvent(NewProjDlg, Ev);
  If Not NewProjDlg.Base.Visible Then Begin
   If NewProjDlg.Confirmed Then
    HandleNewSolutionConfirmed;
   FullRepaintNeeded := True;
  End;
  DrawNewProjectDialog(NewProjDlg);
  Exit;
 End;
 If ProjPropDlg.Base.Visible Then Begin
  HandleProjectPropertiesDialogEvent(ProjPropDlg, Ev);
  If Not ProjPropDlg.Base.Visible Then Begin
   If ProjPropDlg.Confirmed Then Begin
    SaveProjectProperties(ProjPropDlg, CurrentProject);
    SolutionModified := True;
   End;
   FullRepaintNeeded := True;
  End Else
   DrawProjectPropertiesDialog(ProjPropDlg);
  Exit;
 End;
 If EmuPanel.Base.Visible Then Begin
  HandleEmulatorPanelEvent(EmuPanel, Ev);
  If Not EmuPanel.Base.Visible Then
   FullRepaintNeeded := True
  Else
   DrawEmulatorPanel(EmuPanel);
  Exit;
 End;
 If GoToLineDlg.Base.Visible Then Begin
  HandleGoToLineEvent(GoToLineDlg,
   Ord(Ev.Kind), Ev.KeyChar, Ev.MouseX, Ev.MouseY);
  If Not GoToLineDlg.Base.Visible Then Begin
   If GoToLineDlg.Confirmed And EditorReady Then Begin
    ActiveEditor.CursorLine := GoToLineDlg.LineNumber - 1;
    ActiveEditor.CursorCol := 1;
    EnsureCursorVisible(ActiveEditor);
   End;
   FullRepaintNeeded := True;
  End;
  Exit;
 End;
 If OptionsDlg.Base.Visible Then Begin
  HandleOptionsEvent(OptionsDlg, Ev);
  If Not OptionsDlg.Base.Visible Then Begin
   If OptionsDlg.Confirmed And EditorReady Then Begin
    ActiveEditor.TabSize         := OptionsDlg.Data.TabSize;
    ActiveEditor.AutoIndent      := OptionsDlg.Data.AutoIndent;
    ActiveEditor.ShowLineNumbers := OptionsDlg.Data.ShowLineNumbers;
    ActiveEditor.ShowWhitespace  := OptionsDlg.Data.ShowWhitespace;
    AppendOutput(OutputPanel,
     'Options appliquees a l editeur courant.', 0);
   End;
   FullRepaintNeeded := True;
  End;
  Exit;
 End;
 If DbgPanel.Visible Then Begin
  HandleDebugPanelEvent(DbgPanel, BPMgr);
  Exit;
 End;
 { Evenements pour la barre de menus }
 HandleMenuEvent(Ev);
 { Si un menu vient d etre ouvert, ne pas redessiner la toolbar par dessus }
 If MenuActive Then Exit;
 { Evenements pour la barre d outils }
 HandleToolBarEvent(Ev);
 { Evenements pour les onglets d editeurs }
 HandleTabEvent(Ev);
 { Evenements pour l editeur de texte actif }
 { Gestion du focus : clic souris determine qui recoit le clavier }
 If (Ev.Kind = EV_MOUSE_DOWN) Then Begin
  { Verifier d abord le panneau au-dessus selon le z-order }
  If TermVisible And TerminalOnTop And
     (Ev.MouseX >= TermX) And
     (Ev.MouseX < TermX + TermWidth) And
     (Ev.MouseY >= TermY) And
     (Ev.MouseY < TermY + TermHeight) Then Begin
   { Le clic est dans la zone du terminal (au-dessus) }
   { Verifier si c est aussi dans l OutputPanel (zone de chevauchement) }
   If OutputPanel.Visible And
      (Ev.MouseX >= OutputPanel.X) And
      (Ev.MouseX < OutputPanel.X + OutputPanel.Width) And
      (Ev.MouseY >= OutputPanel.Y) And
      (Ev.MouseY < OutputPanel.Y + OutputPanel.Height) Then Begin
    { Zone de chevauchement : le terminal est au-dessus, le prend }
   End;
   TerminalHasFocus := True;
   HandleTerminalEvent(TermPanels[ActiveShell], Ev);
   Exit;
  End
  Else If TermVisible And (Not TerminalOnTop) And
     OutputPanel.Visible And
     (Ev.MouseX >= OutputPanel.X) And
     (Ev.MouseX < OutputPanel.X + OutputPanel.Width) And
     (Ev.MouseY >= OutputPanel.Y) And
     (Ev.MouseY < OutputPanel.Y + OutputPanel.Height) Then Begin
   { Output est au-dessus et on clique dessus : passer a HandleOutputEvent }
   TerminalHasFocus := False;
   If TermSelectOpen Then Begin
    TermSelectOpen := False;
    FullRepaintNeeded := True;
   End;
   HandleOutputEvent(OutputPanel, Ev);
   Exit;
  End
  Else If TermVisible And
     (Ev.MouseX >= TermX) And
     (Ev.MouseX < TermX + TermWidth) And
     (Ev.MouseY >= TermY) And
     (Ev.MouseY < TermY + TermHeight) Then Begin
   { Terminal est en dessous mais on clique dessus (hors OutputPanel) }
   TerminalOnTop := True;
   TerminalHasFocus := True;
   FullRepaintNeeded := True;
   HandleTerminalEvent(TermPanels[ActiveShell], Ev);
   Exit;
  End
  Else If TermVisible And OutputPanel.Visible And
     (Ev.MouseX >= OutputPanel.X) And
     (Ev.MouseX < OutputPanel.X + OutputPanel.Width) And
     (Ev.MouseY >= OutputPanel.Y) And
     (Ev.MouseY < OutputPanel.Y + OutputPanel.Height) Then Begin
   { Output est en dessous mais on clique dessus (hors terminal) }
   TerminalOnTop := False;
   TerminalHasFocus := False;
   FullRepaintNeeded := True;
   If TermSelectOpen Then Begin
    TermSelectOpen := False;
   End;
   HandleOutputEvent(OutputPanel, Ev);
   Exit;
  End
  Else Begin
   TerminalHasFocus := False;
   If TermSelectOpen Then Begin
    TermSelectOpen := False;
    FullRepaintNeeded := True;
   End;
   { Clic hors du terminal (typiquement sur l editeur) : si le
     terminal etait agrandi par zoom, le ramener a la hauteur
     normale pour reveler l editeur. }
   If TermVisible And (TermZoomLvl > 0) Then TermZoomReset;
  End;
 End;
 { Suivi du focus de l explorateur de solutions : un clic dans son
   panneau lui donne le focus clavier (fleches, PgUp/PgDn, Entree).
   Tout autre clic le retire. }
 If Ev.Kind = EV_MOUSE_DOWN Then Begin
  If (Ev.MouseX >= SolExplorer.X) And
     (Ev.MouseX < SolExplorer.X + SolExplorer.Width) And
     (Ev.MouseY >= SolExplorer.Y) And
     (Ev.MouseY < SolExplorer.Y + SolExplorer.Height) Then
   ExplorerHasFocus := True
  Else
   ExplorerHasFocus := False;
 End;
 { Si l explorateur a le focus, lui envoyer les touches de navigation. }
 If ExplorerHasFocus And
    ((Ev.Kind = EV_KEY_DOWN) Or (Ev.Kind = EV_KEY_CHAR)) Then Begin
  HandleExplorerEvent(SolExplorer, Ev);
  If SolExplorer.NeedRepaint Then
   DrawExplorer(SolExplorer);
  Exit;
 End;
 { Si le terminal a le focus, lui envoyer les evenements clavier }
 If TermVisible And TerminalHasFocus Then Begin
  If (Ev.Kind = EV_KEY_CHAR) Or (Ev.Kind = EV_KEY_DOWN) Then Begin
   HandleTerminalEvent(TermPanels[ActiveShell], Ev);
   Exit;
  End;
 End;
 If EditorReady And (WinMgr.ActiveIdx >= 0) Then Begin
  { Si renommage en cours dans l explorateur, lui envoyer les touches }
  If SolExplorer.Renaming And
     ((Ev.Kind = EV_KEY_CHAR) Or (Ev.Kind = EV_KEY_DOWN)) Then Begin
   HandleExplorerEvent(SolExplorer, Ev);
   Exit;
  End;
  If (Ev.Kind = EV_KEY_CHAR) Or (Ev.Kind = EV_KEY_DOWN) Then Begin
   HandleSelectionKey(ActiveEditor, EditorSel, EditorClip,
    EditorUndo, EditorRedo, Ev);
   { Sauvegarder l etat de l editeur dans le tableau }
   If Editors[WinMgr.ActiveIdx] <> Nil Then
    Editors[WinMgr.ActiveIdx]^ := ActiveEditor;
   { Synchroniser curseur vers TEditorWindow pour la barre d etat }
   WinMgr.Windows[WinMgr.ActiveIdx].CursorY := ActiveEditor.CursorLine;
   WinMgr.Windows[WinMgr.ActiveIdx].CursorX := ActiveEditor.CursorCol - 1;
   Exit;
  End;
  If (Ev.Kind = EV_MOUSE_DOWN) Or (Ev.Kind = EV_MOUSE_MOVE) Or
     (Ev.Kind = EV_MOUSE_UP) Then Begin
   { Ne pas intercepter les clics dans l explorateur }
   If (Ev.Kind = EV_MOUSE_DOWN) And
      (Ev.MouseX >= SolExplorer.X) And
      (Ev.MouseX < SolExplorer.X + SolExplorer.Width) And
      (Ev.MouseY >= SolExplorer.Y) And
      (Ev.MouseY < SolExplorer.Y + SolExplorer.Height) Then Begin
    { Laisser passer vers HandleExplorerEvent }
   End Else Begin
    HandleEditorMouse(ActiveEditor, Ev);
    If Editors[WinMgr.ActiveIdx] <> Nil Then
     Editors[WinMgr.ActiveIdx]^ := ActiveEditor;
    WinMgr.Windows[WinMgr.ActiveIdx].CursorY := ActiveEditor.CursorLine;
    WinMgr.Windows[WinMgr.ActiveIdx].CursorX := ActiveEditor.CursorCol - 1;
    Exit;
   End;
  End;
 End;
 { Evenements pour l explorateur }
 HandleExplorerEvent(SolExplorer, Ev);
 { Evenements pour le panneau de proprietes }
 HandlePropertiesEvent(PropsPanel, Ev);
 { Evenements pour le panneau de sortie }
 HandleOutputEvent(OutputPanel, Ev);
 { Evenements pour le terminal integre }
 If TermVisible Then
  HandleTerminalEvent(TermPanels[ActiveShell], Ev);
 { Evenements pour la liste d erreurs }
 HandleErrorListEvent(ErrorList, Ev);
End;

{ --- Boucle principale de l IDE --- }

Procedure MainLoop;
Var
 Ev: TEvent;
 LastBlinkState: Boolean;
 CurBlinkState: Boolean;
Begin
 QuitRequested := False;
 LastBlinkState := ProjPropCursorVisible;
 While Not QuitRequested Do Begin
  PollEvents(Ev);
  If Ev.Kind <> EV_NONE Then Begin
   DispatchEvent(Ev);
   UpdateStatusBar(StatusBar, WinMgr);
   { Ne pas redessiner tous les widgets si un menu est ouvert :
     DrawAllWidgets appelle DrawToolBar qui ecrase le menu deroulant }
   If Not MenuActive And Not CtxMenu.Visible Then
    DrawAllWidgets
   Else If CtxMenu.Visible Then Begin
    DrawAllWidgets;
    DrawContextMenu(CtxMenu);
   End;
   LastBlinkState := ProjPropCursorVisible;
  End Else Begin
   { Meme sans evenement utilisateur, redessiner si le terminal a change }
   If TermVisible And TermPanels[ActiveShell].NeedRepaint Then
    DrawTerminalPanel(TermPanels[ActiveShell]);
   { Faire clignoter le curseur du dialogue Proprietes du projet :
     ne redessiner que lorsque l etat de clignotement change }
   If ProjPropDlg.Base.Visible Then Begin
    CurBlinkState := ProjPropCursorVisible;
    If CurBlinkState <> LastBlinkState Then Begin
     UpdateProjPropCursor(ProjPropDlg);
     LastBlinkState := CurBlinkState;
    End;
   End;
  End;
 End;
End;

{ --- Demarrage de l IDE (procedure Run) --- }

Procedure Run;
Begin
 InitStatusBar(StatusBar);
 InitMRUList(MRUList);
 LoadMRUList(MRUList);
 InitStartPage(StartPage);
 InitTerminals;
 TerminalHasFocus := False;
 QuitRequested := False;
 FullRepaintNeeded := False;
 EditorReady := False;
 { Si un fichier solution .sln a ete passe en argument }
 If Opts.SolutionFile <> '' Then Begin
  StartPage.Visible := False;
  FullRepaintNeeded := True;
  OpenSolutionFile(Opts.SolutionFile);
 End
 { Mode -emu:XXX,fichier : lancer immediatement l emulateur }
 Else If Opts.EmuMode Then Begin
  StartPage.Visible := False;
  FullRepaintNeeded := True;
  EmuStartCmdLine := Opts.EmuArgs;
  ShowEmulatorPanel(EmuPanel, Opts.EmuFile, Opts.EmuTarget);
 End
 { Si un fichier source a ete passe en argument, ouvrir directement l editeur }
 Else If Opts.SourceFile <> '' Then Begin
  StartPage.Visible := False;
  CreateEditorWindow(Opts.SourceFile);
  { Charger le fichier dans l editeur alloue }
  LoadFile(Editors[WinMgr.ActiveIdx]^.Buffer, Opts.SourceFile);
  ActiveEditor := Editors[WinMgr.ActiveIdx]^;
  EditorReady := True;
  { Peupler l explorateur de solutions avec le fichier ouvert }
  ClearExplorer(SolExplorer);
  AddExplorerNode(SolExplorer, 'Solution sans nom',
   ENK_SOLUTION, -1);
  SolExplorer.Nodes[0].Expanded := True;
  SolExplorer.Nodes[0].HasChildren := True;
  AddExplorerNode(SolExplorer,
   ExtractFileName(Opts.SourceFile),
   NodeKindFromExtension(Opts.SourceFile), 0);
  SolExplorer.SelectedIdx := 1;
  SolExplorer.Nodes[1].Selected := True;
  SolExplorer.NeedRepaint := True;
 End;
 DrawAllWidgets;
 MainLoop;
 SaveMRUList(MRUList);
End;

