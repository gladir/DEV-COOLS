Function IsVBNetType(Word: String): Boolean;
Var
 LW: String;
Begin
 LW := LowerCaseStr(Word);
 IsVBNetType :=
  (LW = 'boolean') Or (LW = 'byte') Or (LW = 'char') Or
  (LW = 'date') Or (LW = 'decimal') Or (LW = 'double') Or
  (LW = 'integer') Or (LW = 'long') Or (LW = 'object') Or
