{ --- Test de clic sur les onglets de proprietes projet --- }

Function ProjPropTabHitTest(Var Dlg: TProjectPropertiesDialog;
 MX, MY: Integer): Integer;
Var
 TX, TY, TW, I: Integer;
Begin
 ProjPropTabHitTest := -1;
 TX := Dlg.Base.X + DLG_PADDING;
 TY := Dlg.Base.Y + DLG_TITLE_HEIGHT + DLG_PADDING;
 TW := (Dlg.Base.Width - DLG_PADDING * 2) Div PROJPROP_TAB_COUNT;
 If (MY >= TY) And (MY < TY + TAB_HEIGHT) Then
 Begin
  For I := 0 To PROJPROP_TAB_COUNT - 1 Do
  Begin
   If (MX >= TX + I * TW) And (MX < TX + (I + 1) * TW) Then
   Begin
    ProjPropTabHitTest := I;
    Exit;
   End;
  End;
 End;
End;

{ --- Test de clic sur le checkbox TreatWarningsAsErrors --- }

Function ProjPropWarningCheckHitTest(
 Var Dlg: TProjectPropertiesDialog;
 MX, MY: Integer): Boolean;
Var
 FX, BaseY: Integer;
Begin
 ProjPropWarningCheckHitTest := False;
 If Dlg.ActiveTab <> PPT_BUILD Then Exit;
 FX := Dlg.Base.X + DLG_PADDING;
 BaseY := Dlg.Base.Y + DLG_TITLE_HEIGHT + DLG_PADDING +
  TAB_HEIGHT + DLG_PADDING + PROJPROP_ROW_SPACING * 4;
 ProjPropWarningCheckHitTest :=
  (MX >= FX) And (MX <= FX + 12) And
  (MY >= BaseY) And (MY <= BaseY + 12);
End;

{ --- Test de clic sur les champs de saisie --- }

Function ProjPropFieldHitTest(
 Var Dlg: TProjectPropertiesDialog;
 MX, MY: Integer): Integer;
Var
 FX, FW, BaseY, NbFields, I, RowY: Integer;
Begin
 ProjPropFieldHitTest := -1;
 FX := Dlg.Base.X + DLG_PADDING;
 FW := Dlg.Base.Width - DLG_PADDING * 2;
 BaseY := Dlg.Base.Y + DLG_TITLE_HEIGHT + DLG_PADDING +
  TAB_HEIGHT + DLG_PADDING;
 Case Dlg.ActiveTab Of
  PPT_APPLICATION:  NbFields := 3;
  PPT_BUILD:        NbFields := 4;
  PPT_BUILD_EVENTS: NbFields := 2;
  PPT_DEBUG:        NbFields := 2;
 Else
  NbFields := 0;
 End;
 If (MX < FX + PROJPROP_LABEL_WIDTH) Or (MX > FX + FW) Then Exit;
 For I := 0 To NbFields - 1 Do
 Begin
  RowY := BaseY + I * PROJPROP_ROW_SPACING;
  If (MY >= RowY - 2) And (MY <= RowY + PROJPROP_FIELD_HEIGHT) Then
  Begin
   ProjPropFieldHitTest := I;
   Exit;
  End;
 End;
End;

{ --- Gestion des touches du dialogue Proprietes du projet --- }

Procedure HandleProjectPropertiesDialogKey(
 Var Dlg: TProjectPropertiesDialog; Key: Word; Ch: Char);
Begin
 If Key = $1B Then
 Begin
  Dlg.Confirmed := False;
  CloseDialog(Dlg.Base);
  Exit;
 End;
 If Key = $0D Then
 Begin
  Dlg.Confirmed := True;
  Dlg.Base.Result := DR_OK;
  CloseDialog(Dlg.Base);
  Exit;
 End;
 If Key = $09 Then
 Begin
  Inc(Dlg.FocusField);
  Case Dlg.ActiveTab Of
   PPT_APPLICATION:
    If Dlg.FocusField > 2 Then Dlg.FocusField := 0;
   PPT_BUILD:
    If Dlg.FocusField > 3 Then Dlg.FocusField := 0;
   PPT_BUILD_EVENTS:
    If Dlg.FocusField > 1 Then Dlg.FocusField := 0;
   PPT_DEBUG:
    If Dlg.FocusField > 1 Then Dlg.FocusField := 0;
  End;
  Exit;
 End;
 { Saisie dans le champ actif selon l onglet }
 Case Dlg.ActiveTab Of
  PPT_APPLICATION:
   Case Dlg.FocusField Of
    0: { AssemblyName }
     If (Ch >= ' ') And (Length(Dlg.AssemblyName) < 63) Then
     Begin
      Dlg.AssemblyName := Dlg.AssemblyName + Ch;
      Inc(Dlg.AsmNameCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.AssemblyName) > 0 Then
      Begin
       Delete(Dlg.AssemblyName, Length(Dlg.AssemblyName), 1);
       Dec(Dlg.AsmNameCursor);
      End;
     End;
    1: { RootNamespace }
     If (Ch >= ' ') And (Length(Dlg.RootNamespace) < 63) Then
     Begin
      Dlg.RootNamespace := Dlg.RootNamespace + Ch;
      Inc(Dlg.NsCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.RootNamespace) > 0 Then
      Begin
       Delete(Dlg.RootNamespace, Length(Dlg.RootNamespace), 1);
       Dec(Dlg.NsCursor);
      End;
     End;
    2: { OutputType toggle }
     If (Ch = ' ') Or (Key = $0D) Then
      Dlg.OutputTypeIdx := (Dlg.OutputTypeIdx + 1) Mod 3;
   End;
  PPT_BUILD:
   Case Dlg.FocusField Of
    0: { DefineConstants }
     If (Ch >= ' ') And (Length(Dlg.DefineConstants) < 255) Then
     Begin
      Dlg.DefineConstants := Dlg.DefineConstants + Ch;
      Inc(Dlg.DefCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.DefineConstants) > 0 Then
      Begin
       Delete(Dlg.DefineConstants,
        Length(Dlg.DefineConstants), 1);
       Dec(Dlg.DefCursor);
      End;
     End;
    1: { OutputPath }
     If (Ch >= ' ') And (Length(Dlg.OutputPath) < 255) Then
     Begin
      Dlg.OutputPath := Dlg.OutputPath + Ch;
      Inc(Dlg.OutPathCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.OutputPath) > 0 Then
      Begin
       Delete(Dlg.OutputPath, Length(Dlg.OutputPath), 1);
       Dec(Dlg.OutPathCursor);
      End;
     End;
    2: { WarningLevel }
     If (Ch >= '0') And (Ch <= '4') Then
      Dlg.WarningLevel := Ord(Ch) - Ord('0');
   End;
  PPT_BUILD_EVENTS:
   Case Dlg.FocusField Of
    0: { PreBuildEvent }
     If (Ch >= ' ') And (Length(Dlg.PreBuildEvent) < 255) Then
     Begin
      Dlg.PreBuildEvent := Dlg.PreBuildEvent + Ch;
      Inc(Dlg.PreBuildCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.PreBuildEvent) > 0 Then
      Begin
       Delete(Dlg.PreBuildEvent,
        Length(Dlg.PreBuildEvent), 1);
       Dec(Dlg.PreBuildCursor);
      End;
     End;
    1: { PostBuildEvent }
     If (Ch >= ' ') And (Length(Dlg.PostBuildEvent) < 255) Then
     Begin
      Dlg.PostBuildEvent := Dlg.PostBuildEvent + Ch;
      Inc(Dlg.PostBuildCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.PostBuildEvent) > 0 Then
      Begin
       Delete(Dlg.PostBuildEvent,
        Length(Dlg.PostBuildEvent), 1);
       Dec(Dlg.PostBuildCursor);
      End;
     End;
   End;
  PPT_DEBUG:
   Case Dlg.FocusField Of
    0: { DebugArgs }
     If (Ch >= ' ') And (Length(Dlg.DebugArgs) < 255) Then
     Begin
      Dlg.DebugArgs := Dlg.DebugArgs + Ch;
      Inc(Dlg.DebugArgsCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.DebugArgs) > 0 Then
      Begin
       Delete(Dlg.DebugArgs, Length(Dlg.DebugArgs), 1);
       Dec(Dlg.DebugArgsCursor);
      End;
     End;
    1: { WorkingDir }
     If (Ch >= ' ') And (Length(Dlg.WorkingDir) < 255) Then
     Begin
      Dlg.WorkingDir := Dlg.WorkingDir + Ch;
      Inc(Dlg.WorkDirCursor);
     End
     Else If Key = $08 Then
     Begin
      If Length(Dlg.WorkingDir) > 0 Then
      Begin
       Delete(Dlg.WorkingDir, Length(Dlg.WorkingDir), 1);
       Dec(Dlg.WorkDirCursor);
      End;
     End;
   End;
 End;
End;

{ --- Gestion des evenements du dialogue Proprietes du projet --- }

Procedure HandleProjectPropertiesDialogEvent(
 Var Dlg: TProjectPropertiesDialog; Var Ev: TEvent);
Var
 TabIdx, BtnR, FldIdx: Integer;
 FX, FW, BaseY, DY, ItemIdx: Integer;
 SbL, SbR, SbTop2, SbBot2, SbUpYM, SbDnYM, MaxTopM, VisM: Integer;
Begin
 If Not Dlg.Base.Visible Then Exit;
 Case Ev.Kind Of
  EV_KEY_DOWN, EV_KEY_CHAR:
  Begin
   If Dlg.OutputTypeOpen Then
   Begin
    { Echap ferme la liste sans changer la valeur }
    If (Ev.Kind = EV_KEY_CHAR) And (Ev.KeyChar = #27) Then Begin
     Dlg.OutputTypeOpen := False;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    { Entree valide la selection }
    If (Ev.Kind = EV_KEY_CHAR) And (Ev.KeyChar = #13) Then Begin
     Dlg.OutputTypeOpen := False;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    { Fleches haut/bas pour naviguer }
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $48) Then Begin
     If Dlg.OutputTypeIdx > 0 Then Dec(Dlg.OutputTypeIdx);
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $50) Then Begin
     If Dlg.OutputTypeIdx < 2 Then Inc(Dlg.OutputTypeIdx);
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    { Toute autre touche est avalee }
    Exit;
   End;
   If Dlg.TargetCPUOpen Then
   Begin
    If (Ev.Kind = EV_KEY_CHAR) And (Ev.KeyChar = #27) Then Begin
     Dlg.TargetCPUOpen := False;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    If (Ev.Kind = EV_KEY_CHAR) And (Ev.KeyChar = #13) Then Begin
     Dlg.TargetCPUOpen := False;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $48) Then Begin
     If Dlg.TargetCPUIdx > 0 Then Dec(Dlg.TargetCPUIdx);
     If Dlg.TargetCPUIdx < Dlg.TargetCPUTop Then
      Dlg.TargetCPUTop := Dlg.TargetCPUIdx;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $50) Then Begin
     If Dlg.TargetCPUIdx < TargetCPUCount - 1 Then
      Inc(Dlg.TargetCPUIdx);
     If Dlg.TargetCPUIdx >=
        Dlg.TargetCPUTop + PROJPROP_TGT_VISIBLE Then
      Dlg.TargetCPUTop :=
       Dlg.TargetCPUIdx - PROJPROP_TGT_VISIBLE + 1;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    { PgUp = $49 }
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $49) Then Begin
     Dlg.TargetCPUIdx := Dlg.TargetCPUIdx - PROJPROP_TGT_VISIBLE;
     If Dlg.TargetCPUIdx < 0 Then Dlg.TargetCPUIdx := 0;
     Dlg.TargetCPUTop := Dlg.TargetCPUTop - PROJPROP_TGT_VISIBLE;
     If Dlg.TargetCPUTop < 0 Then Dlg.TargetCPUTop := 0;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    { PgDn = $51 }
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $51) Then Begin
     Dlg.TargetCPUIdx := Dlg.TargetCPUIdx + PROJPROP_TGT_VISIBLE;
     If Dlg.TargetCPUIdx > TargetCPUCount - 1 Then
      Dlg.TargetCPUIdx := TargetCPUCount - 1;
     If Dlg.TargetCPUIdx >=
        Dlg.TargetCPUTop + PROJPROP_TGT_VISIBLE Then
      Dlg.TargetCPUTop :=
       Dlg.TargetCPUIdx - PROJPROP_TGT_VISIBLE + 1;
     If Dlg.TargetCPUTop < 0 Then Dlg.TargetCPUTop := 0;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    { Home = $47 }
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $47) Then Begin
     Dlg.TargetCPUIdx := 0;
     Dlg.TargetCPUTop := 0;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    { End = $4F }
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $4F) Then Begin
     Dlg.TargetCPUIdx := TargetCPUCount - 1;
     Dlg.TargetCPUTop := TargetCPUCount - PROJPROP_TGT_VISIBLE;
     If Dlg.TargetCPUTop < 0 Then Dlg.TargetCPUTop := 0;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    Exit;
   End;
   { Sur le champ Type de sortie ferme : Espace ou fleche bas
     ouvrent le dropdown }
   If (Dlg.ActiveTab = PPT_APPLICATION) And
      (Dlg.FocusField = 2) Then
   Begin
    If (Ev.Kind = EV_KEY_CHAR) And (Ev.KeyChar = ' ') Then Begin
     Dlg.OutputTypeOpen := True;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $50) Then Begin
     Dlg.OutputTypeOpen := True;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
   End;
   { Sur le champ Plateforme cible ferme : Espace ou fleche bas
     ouvrent le dropdown }
   If (Dlg.ActiveTab = PPT_BUILD) And
      (Dlg.FocusField = 3) Then
   Begin
    If (Ev.Kind = EV_KEY_CHAR) And (Ev.KeyChar = ' ') Then Begin
     Dlg.TargetCPUOpen := True;
     If Dlg.TargetCPUIdx >= PROJPROP_TGT_VISIBLE Then
      Dlg.TargetCPUTop :=
       Dlg.TargetCPUIdx - PROJPROP_TGT_VISIBLE + 1
     Else
      Dlg.TargetCPUTop := 0;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
    If (Ev.Kind = EV_KEY_DOWN) And (Ev.KeyCode = $50) Then Begin
     Dlg.TargetCPUOpen := True;
     If Dlg.TargetCPUIdx >= PROJPROP_TGT_VISIBLE Then
      Dlg.TargetCPUTop :=
       Dlg.TargetCPUIdx - PROJPROP_TGT_VISIBLE + 1
     Else
      Dlg.TargetCPUTop := 0;
     DrawProjectPropertiesDialog(Dlg);
     Exit;
    End;
   End;
   HandleProjectPropertiesDialogKey(Dlg, Ev.KeyCode, Ev.KeyChar);
   DrawProjectPropertiesDialog(Dlg);
  End;
  EV_MOUSE_DOWN:
  Begin
   { Si le dropdown est ouvert, gerer en priorite }
   If Dlg.OutputTypeOpen Then
   Begin
    FX := Dlg.Base.X + DLG_PADDING;
    FW := Dlg.Base.Width - DLG_PADDING * 2;
    BaseY := Dlg.Base.Y + DLG_TITLE_HEIGHT + DLG_PADDING +
     TAB_HEIGHT + DLG_PADDING + PROJPROP_ROW_SPACING * 2;
    DY := BaseY + PROJPROP_FIELD_HEIGHT;
    If (Ev.MouseX >= FX + PROJPROP_LABEL_WIDTH) And
       (Ev.MouseX <= FX + FW) And
       (Ev.MouseY >= DY) And
       (Ev.MouseY <= DY + 3 * PROJPROP_FIELD_HEIGHT) Then
    Begin
     ItemIdx := (Ev.MouseY - DY) Div PROJPROP_FIELD_HEIGHT;
     If (ItemIdx >= 0) And (ItemIdx <= 2) Then
      Dlg.OutputTypeIdx := ItemIdx;
    End;
    Dlg.OutputTypeOpen := False;
    DrawProjectPropertiesDialog(Dlg);
    Exit;
   End;
   If Dlg.TargetCPUOpen Then
   Begin
    FX := Dlg.Base.X + DLG_PADDING;
    FW := Dlg.Base.Width - DLG_PADDING * 2;
    BaseY := Dlg.Base.Y + DLG_TITLE_HEIGHT + DLG_PADDING +
     TAB_HEIGHT + DLG_PADDING + PROJPROP_ROW_SPACING * 3;
    DY := BaseY + PROJPROP_FIELD_HEIGHT;
    { Geometrie scrollbar }
    Begin
     VisM := PROJPROP_TGT_VISIBLE;
     If VisM > TargetCPUCount Then VisM := TargetCPUCount;
     MaxTopM := TargetCPUCount - VisM;
     If MaxTopM < 0 Then MaxTopM := 0;
     SbR := FX + FW;
     SbL := SbR - PROJPROP_SBAR_WIDTH;
     SbTop2 := DY;
     SbBot2 := DY + VisM * PROJPROP_FIELD_HEIGHT;
     SbUpYM := SbTop2;
     SbDnYM := SbBot2 - PROJPROP_SBAR_WIDTH;
     { Clic dans la zone scrollbar : ne ferme pas le dropdown }
     If (Ev.MouseX >= SbL) And (Ev.MouseX <= SbR) And
        (Ev.MouseY >= SbTop2) And (Ev.MouseY <= SbBot2) Then
     Begin
      { Bouton haut }
      If Ev.MouseY < SbUpYM + PROJPROP_SBAR_WIDTH Then
      Begin
       If Dlg.TargetCPUTop > 0 Then Dec(Dlg.TargetCPUTop);
      End
      Else If Ev.MouseY >= SbDnYM Then
      Begin
       If Dlg.TargetCPUTop < MaxTopM Then Inc(Dlg.TargetCPUTop);
      End
      Else
      Begin
       { Track : page up/down }
       If Ev.MouseY < (SbTop2 + SbBot2) Div 2 Then
       Begin
        Dlg.TargetCPUTop := Dlg.TargetCPUTop - VisM;
        If Dlg.TargetCPUTop < 0 Then Dlg.TargetCPUTop := 0;
       End
       Else
       Begin
        Dlg.TargetCPUTop := Dlg.TargetCPUTop + VisM;
        If Dlg.TargetCPUTop > MaxTopM Then
         Dlg.TargetCPUTop := MaxTopM;
       End;
      End;
      DrawProjectPropertiesDialog(Dlg);
      Exit;
     End;
     { Clic dans la zone des items (hors scrollbar) }
     If (Ev.MouseX >= FX + PROJPROP_LABEL_WIDTH) And
        (Ev.MouseX < SbL) And
        (Ev.MouseY >= DY) And
        (Ev.MouseY <= SbBot2) Then
     Begin
      ItemIdx := (Ev.MouseY - DY) Div PROJPROP_FIELD_HEIGHT
       + Dlg.TargetCPUTop;
      If (ItemIdx >= 0) And (ItemIdx < TargetCPUCount) Then
       Dlg.TargetCPUIdx := ItemIdx;
      Dlg.TargetCPUOpen := False;
      DrawProjectPropertiesDialog(Dlg);
      Exit;
     End;
    End;
    { Clic en dehors : fermer dropdown }
    Dlg.TargetCPUOpen := False;
    DrawProjectPropertiesDialog(Dlg);
    Exit;
   End;
   TabIdx := ProjPropTabHitTest(Dlg, Ev.MouseX, Ev.MouseY);
   If TabIdx >= 0 Then
   Begin
    Case TabIdx Of
     0: Dlg.ActiveTab := PPT_APPLICATION;
     1: Dlg.ActiveTab := PPT_BUILD;
     2: Dlg.ActiveTab := PPT_BUILD_EVENTS;
     3: Dlg.ActiveTab := PPT_DEBUG;
    End;
    Dlg.FocusField := 0;
    DrawProjectPropertiesDialog(Dlg);
    Exit;
   End;
   If ProjPropWarningCheckHitTest(Dlg, Ev.MouseX, Ev.MouseY) Then
   Begin
    Dlg.TreatWarningsAsErrors :=
     Not Dlg.TreatWarningsAsErrors;
    DrawProjectPropertiesDialog(Dlg);
    Exit;
   End;
   FldIdx := ProjPropFieldHitTest(Dlg, Ev.MouseX, Ev.MouseY);
   If FldIdx >= 0 Then
   Begin
    Dlg.FocusField := FldIdx;
    { Sur le champ Type de sortie, ouvrir le dropdown }
    If (Dlg.ActiveTab = PPT_APPLICATION) And (FldIdx = 2) Then
     Dlg.OutputTypeOpen := True;
    { Sur le champ Plateforme cible, ouvrir le dropdown }
    If (Dlg.ActiveTab = PPT_BUILD) And (FldIdx = 3) Then
    Begin
     Dlg.TargetCPUOpen := True;
     If Dlg.TargetCPUIdx >= PROJPROP_TGT_VISIBLE Then
      Dlg.TargetCPUTop :=
       Dlg.TargetCPUIdx - PROJPROP_TGT_VISIBLE + 1
     Else
      Dlg.TargetCPUTop := 0;
    End;
    DrawProjectPropertiesDialog(Dlg);
    Exit;
   End;
   BtnR := DialogButtonHitTest(Dlg.Base, Ev.MouseX, Ev.MouseY);
   If BtnR >= 0 Then
   Begin
    If BtnR = 0 Then Begin
     Dlg.Confirmed := True;
     Dlg.Base.Result := DR_OK;
    End Else Begin
     Dlg.Confirmed := False;
     Dlg.Base.Result := DR_CANCEL;
    End;
    CloseDialog(Dlg.Base);
   End;
  End;
 End;
End;

