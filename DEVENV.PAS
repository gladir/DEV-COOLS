{ --- Initialiser la barre d etat --- }

Procedure InitStatusBar(Var SB: TStatusBar);
Begin
 SB.CursorLine := 1;
 SB.CursorCol := 1;
 SB.InsertMode := IM_INSERT;
 SB.Encoding := FE_ASCII;
 SB.LineEnding := LE_CRLF;
 SB.Language := '';
 SB.FileName := '';
 SB.BuildStatus := 'Ready';
 SB.NeedRepaint := True;
End;

{ --- Nom du mode d insertion --- }

Function InsertModeName(Mode: TInsertMode): String;
Begin
 Case Mode Of
  IM_INSERT:    InsertModeName := 'INS';
  IM_OVERWRITE: InsertModeName := 'OVR';
 Else
  InsertModeName := '???';
 End;
End;

{ --- Nom de l encodage --- }

Function FileEncodingName(Enc: TFileEncoding): String;
Begin
 Case Enc Of
  FE_ASCII: FileEncodingName := 'ASCII';
  FE_UTF8:  FileEncodingName := 'UTF-8';
 Else
  FileEncodingName := '???';
 End;
End;

{ --- Nom du type de fin de ligne --- }

Function LineEndingName(LE: TLineEnding): String;
Begin
 Case LE Of
  LE_CRLF: LineEndingName := 'CRLF';
  LE_LF:   LineEndingName := 'LF';
  LE_CR:   LineEndingName := 'CR';
 Else
  LineEndingName := '???';
 End;
End;

{ --- Mettre a jour la barre d etat depuis l editeur actif --- }

Procedure UpdateStatusBar(Var SB: TStatusBar;
 Var WM: TWindowManager);
Var
 Idx: Integer;
Begin
 Idx := WM.ActiveIdx;
 If (Idx >= 0) And (Idx < WM.WinCount) Then Begin
  SB.CursorLine := WM.Windows[Idx].CursorY + 1;
  SB.CursorCol := WM.Windows[Idx].CursorX + 1;
  SB.FileName := WM.Windows[Idx].FileName;
  SB.Language := 'Text';
 End Else Begin
  SB.CursorLine := 1;
  SB.CursorCol := 1;
  SB.FileName := '';
  SB.Language := '';
 End;
 SB.NeedRepaint := True;
End;

{ --- Dessiner la barre d etat --- }

Procedure DrawStatusBar(Var SB: TStatusBar);
Var
 Y, ScreenW, X: Integer;
 PosStr: String;
Begin
 ScreenW := GetScreenWidth;
 Y := GetScreenHeight - STATUSBAR_HEIGHT;
 DrawFilledRect(0, Y, ScreenW, Y + STATUSBAR_HEIGHT, CLR_STATUSBAR);
 X := STATUS_BAR_PADDING;
 { Position du curseur }
 PosStr := 'Ln ' + IntToStr(SB.CursorLine) + ', Col ' +
  IntToStr(SB.CursorCol);
 DrawText(X, Y + 3, PosStr, 15);
 X := X + Length(PosStr) * 8 + STATUS_BAR_FIELD_GAP;
 { Mode d insertion }
 DrawText(X, Y + 3, InsertModeName(SB.InsertMode), 15);
 X := X + 24 + STATUS_BAR_FIELD_GAP;
 { Encodage }
 DrawText(X, Y + 3, FileEncodingName(SB.Encoding), 15);
 X := X + 40 + STATUS_BAR_FIELD_GAP;
 { Fin de ligne }
 DrawText(X, Y + 3, LineEndingName(SB.LineEnding), 15);
 X := X + 32 + STATUS_BAR_FIELD_GAP;
 { Langage }
 If SB.Language <> '' Then Begin
  DrawText(X, Y + 3, SB.Language, 15);
  X := X + Length(SB.Language) * 8 + STATUS_BAR_FIELD_GAP;
 End;
 { Nom du fichier }
 If SB.FileName <> '' Then
  DrawText(X, Y + 3, SB.FileName, 15);
 { Etat du build a droite }
 If SB.BuildStatus <> '' Then
  DrawText(ScreenW - Length(SB.BuildStatus) * 8 -
   STATUS_BAR_PADDING, Y + 3, SB.BuildStatus, 15);
 SB.NeedRepaint := False;
End;

{ --- Initialiser la liste MRU --- }

Procedure InitMRUList(Var MRU: TMRUList);
Var
 I: Integer;
Begin
 For I := 0 To MRU_MAX_ENTRIES - 1 Do
  MRU.Entries[I].FilePath := '';
 MRU.Count := 0;
End;

{ --- Ajouter un fichier a la liste MRU --- }

Procedure AddMRUEntry(Var MRU: TMRUList; FilePath: String);
Var
 I, J: Integer;
Begin
 { Verifier si deja present et le retirer }
 For I := 0 To MRU.Count - 1 Do Begin
  If MRU.Entries[I].FilePath = FilePath Then Begin
   For J := I To MRU.Count - 2 Do
    MRU.Entries[J] := MRU.Entries[J + 1];
   Dec(MRU.Count);
  End;
 End;
 { Decaler les entrees vers le bas }
 If MRU.Count >= MRU_MAX_ENTRIES Then
  MRU.Count := MRU_MAX_ENTRIES - 1;
 For I := MRU.Count DownTo 1 Do
  MRU.Entries[I] := MRU.Entries[I - 1];
 { Inserer en premiere position }
 MRU.Entries[0].FilePath := FilePath;
 Inc(MRU.Count);
End;

{ --- Sauvegarder la liste MRU --- }

Procedure SaveMRUList(Var MRU: TMRUList);
Var
 F: Text;
 I: Integer;
Begin
 Assign(F, MRU_FILENAME);
 {$I-}
 Rewrite(F);
 {$I+}
 If IOResult <> 0 Then Exit;
 For I := 0 To MRU.Count - 1 Do
  WriteLn(F, MRU.Entries[I].FilePath);
 Close(F);
End;

{ --- Charger la liste MRU --- }

Procedure LoadMRUList(Var MRU: TMRUList);
Var
 F: Text;
 Line: String;
Begin
 InitMRUList(MRU);
 Assign(F, MRU_FILENAME);
 {$I-}
 Reset(F);
 {$I+}
 If IOResult <> 0 Then Exit;
 While (Not Eof(F)) And (MRU.Count < MRU_MAX_ENTRIES) Do Begin
  ReadLn(F, Line);
  If Line <> '' Then Begin
   MRU.Entries[MRU.Count].FilePath := Line;
   Inc(MRU.Count);
  End;
 End;
 Close(F);
End;

{ --- Obtenir le nombre d entrees MRU --- }

Function GetMRUCount(Var MRU: TMRUList): Integer;
Begin
 GetMRUCount := MRU.Count;
End;

{ --- Obtenir une entree MRU par index --- }

Function GetMRUEntry(Var MRU: TMRUList; Idx: Integer): String;
Begin
 If (Idx >= 0) And (Idx < MRU.Count) Then
  GetMRUEntry := MRU.Entries[Idx].FilePath
 Else
  GetMRUEntry := '';
End;

{ --- Effacer la liste MRU --- }

Procedure ClearMRUList(Var MRU: TMRUList);
Begin
 InitMRUList(MRU);
End;

{ --- Verifier si la liste MRU est vide --- }

Function IsMRUListEmpty(Var MRU: TMRUList): Boolean;
Begin
 IsMRUListEmpty := MRU.Count = 0;
End;

{ --- Initialiser la page de demarrage --- }

Procedure InitStartPage(Var SP: TStartPage);
Begin
 SP.Visible := True;
 SP.SelectedItem := -1;
 SP.ScrollTop := 0;
 SP.NeedRepaint := True;
 SP.FocusedBtn := 0;  { Nouveau projet par defaut }
End;

{ --- Dessiner la page de demarrage --- }

Procedure DrawStartPage(Var SP: TStartPage;
 Var MRU: TMRUList);
Var
 ScreenW, CenterX, I, Y: Integer;
 Title: String;
Begin
 If Not SP.Visible Then Exit;
 ScreenW := GetScreenWidth;
 CenterX := ScreenW Div 2;
 { Titre }
 Title := 'DEVENV - IDE Visual Studio';
 DrawText(CenterX - (Length(Title) * 8 Div 2),
  START_PAGE_TITLE_Y, Title, 15);
 { Sous-titre }
 Title := 'DEV-COOLS v' + IDE_VERSION;
 DrawText(CenterX - (Length(Title) * 8 Div 2),
  START_PAGE_TITLE_Y + 20, Title, 8);
 { Bouton Nouveau projet (0) }
 If SP.FocusedBtn = 0 Then
  DrawFilledRect(CenterX - START_PAGE_BTN_WIDTH - 10,
   START_PAGE_BTN_Y + 50, CenterX - 10,
   START_PAGE_BTN_Y + 50 + START_PAGE_BTN_HEIGHT, CLR_MENU_HIGHLIGHT)
 Else
  DrawFilledRect(CenterX - START_PAGE_BTN_WIDTH - 10,
   START_PAGE_BTN_Y + 50, CenterX - 10,
   START_PAGE_BTN_Y + 50 + START_PAGE_BTN_HEIGHT, CLR_STATUSBAR);
 DrawText(CenterX - START_PAGE_BTN_WIDTH - 10 + 12,
  START_PAGE_BTN_Y + 50 + 6, 'Nouveau projet', 15);
 If SP.FocusedBtn = 0 Then
  DrawRect(CenterX - START_PAGE_BTN_WIDTH - 10, START_PAGE_BTN_Y + 50,
   CenterX - 10, START_PAGE_BTN_Y + 50 + START_PAGE_BTN_HEIGHT, 15);
 { Bouton Ouvrir projet (1) }
 If SP.FocusedBtn = 1 Then
  DrawFilledRect(CenterX + 10, START_PAGE_BTN_Y + 50,
   CenterX + 10 + START_PAGE_BTN_WIDTH,
   START_PAGE_BTN_Y + 50 + START_PAGE_BTN_HEIGHT, CLR_MENU_HIGHLIGHT)
 Else
  DrawFilledRect(CenterX + 10, START_PAGE_BTN_Y + 50,
   CenterX + 10 + START_PAGE_BTN_WIDTH,
   START_PAGE_BTN_Y + 50 + START_PAGE_BTN_HEIGHT, CLR_STATUSBAR);
 DrawText(CenterX + 10 + 16,
  START_PAGE_BTN_Y + 50 + 6, 'Ouvrir projet', 15);
 If SP.FocusedBtn = 1 Then
  DrawRect(CenterX + 10, START_PAGE_BTN_Y + 50,
   CenterX + 10 + START_PAGE_BTN_WIDTH,
   START_PAGE_BTN_Y + 50 + START_PAGE_BTN_HEIGHT, 15);
 { Liste des fichiers recents }
 If MRU.Count > 0 Then Begin
  DrawText(CenterX - 100, START_PAGE_LIST_Y + 20,
   'Fichiers recents :', 15);
  Y := START_PAGE_LIST_Y + 44;
  For I := 0 To MRU.Count - 1 Do Begin
   If I >= 10 Then Break;
   If I = SP.SelectedItem Then
    DrawFilledRect(CenterX - 200, Y, CenterX + 200,
     Y + START_PAGE_ITEM_HEIGHT, CLR_SELECTION);
   If I = SP.SelectedItem Then
    DrawText(CenterX - 196, Y + 2,
     MRU.Entries[I].FilePath, 15)
   Else
    DrawText(CenterX - 196, Y + 2,
     MRU.Entries[I].FilePath, 8);
   Y := Y + START_PAGE_ITEM_HEIGHT;
  End;
 End Else Begin
  DrawText(CenterX - 80, START_PAGE_LIST_Y + 20,
   'Aucun fichier recent', 8);
 End;
 SP.NeedRepaint := False;
End;

{ --- Gerer les evenements de la page de demarrage --- }

Procedure HandleStartPageEvent(Var SP: TStartPage;
 Var MRU: TMRUList; Var Ev: TEvent);
Var
 ScreenW, CenterX, BtnY, ItemIdx: Integer;
Begin
 If Not SP.Visible Then Exit;
 ScreenW := GetScreenWidth;
 CenterX := ScreenW Div 2;
 If Ev.Kind = EV_MOUSE_DOWN Then Begin
   { Verifier clic sur bouton Nouveau }
   BtnY := START_PAGE_BTN_Y + 50;
   If (Ev.MouseX >= CenterX - START_PAGE_BTN_WIDTH - 10) And
      (Ev.MouseX < CenterX - 10) And
      (Ev.MouseY >= BtnY) And
      (Ev.MouseY < BtnY + START_PAGE_BTN_HEIGHT) Then Begin
    SP.Visible := False;
    SP.NeedRepaint := True;
    FullRepaintNeeded := True;
    DrawAllWidgets;
    ShowNewProjectDialog(NewProjDlg);
    Exit;
   End;
   { Verifier clic sur bouton Ouvrir }
   If (Ev.MouseX >= CenterX + 10) And
      (Ev.MouseX < CenterX + 10 + START_PAGE_BTN_WIDTH) And
      (Ev.MouseY >= BtnY) And
      (Ev.MouseY < BtnY + START_PAGE_BTN_HEIGHT) Then Begin
    SP.Visible := False;
    SP.NeedRepaint := True;
    FullRepaintNeeded := True;
    DrawAllWidgets;
    InitFileDialog(FileDlg, False);
    LoadDirectoryFiles(FileDlg);
    FileDlg.Base.Visible := True;
    DrawFileDialog(FileDlg);
    Exit;
   End;
   { Verifier clic sur un element de la liste MRU }
   If MRU.Count > 0 Then Begin
    ItemIdx := (Ev.MouseY - (START_PAGE_LIST_Y + 44)) Div
     START_PAGE_ITEM_HEIGHT;
    If (ItemIdx >= 0) And (ItemIdx < MRU.Count) And
       (ItemIdx < 10) And
       (Ev.MouseX >= CenterX - 200) And
       (Ev.MouseX < CenterX + 200) Then Begin
     SP.SelectedItem := ItemIdx;
     SP.Visible := False;
     SP.NeedRepaint := True;
     FullRepaintNeeded := True;
     DrawAllWidgets;
     { Ouvrir le fichier selectionne }
     FileDlg.SelectedFile := MRU.Entries[ItemIdx].FilePath;
     HandleOpenFileConfirmed;
     Exit;
    End;
   End;
 End;
 If Ev.Kind = EV_KEY_CHAR Then Begin
  Case Ev.KeyChar Of
   #9:  Begin { Tab : basculer le bouton actif }
         SP.FocusedBtn := 1 - SP.FocusedBtn;
         SP.NeedRepaint := True;
        End;
   #13: Begin { Entree : activer le bouton courant }
         SP.Visible := False;
         SP.NeedRepaint := True;
         FullRepaintNeeded := True;
         DrawAllWidgets;
         If SP.FocusedBtn = 0 Then Begin
          ShowNewProjectDialog(NewProjDlg);
         End Else Begin
          InitFileDialog(FileDlg, False);
          LoadDirectoryFiles(FileDlg);
          FileDlg.Base.Visible := True;
          DrawFileDialog(FileDlg);
         End;
        End;
   #27: Begin { Echap : fermer la page de demarrage }
         SP.Visible := False;
         SP.NeedRepaint := True;
         FullRepaintNeeded := True;
        End;
  End;
 End Else If Ev.Kind = EV_KEY_DOWN Then Begin
  Case Ev.KeyCode Of
   75: Begin { Fleche gauche : bouton Nouveau }
        SP.FocusedBtn := 0;
        SP.NeedRepaint := True;
       End;
   77: Begin { Fleche droite : bouton Ouvrir }
        SP.FocusedBtn := 1;
        SP.NeedRepaint := True;
       End;
  End;
 End;
End;

{ --- Masquer la page de demarrage --- }

Procedure HideStartPage(Var SP: TStartPage);
Begin
 SP.Visible := False;
 SP.NeedRepaint := True;
End;

{ --- Verifier si la page de demarrage est visible --- }

Function IsStartPageVisible(Var SP: TStartPage): Boolean;
Begin
 IsStartPageVisible := SP.Visible;
End;

{ --- Obtenir l element selectionne de la page de demarrage --- }

Function GetStartPageSelectedItem(
 Var SP: TStartPage): Integer;
Begin
 GetStartPageSelectedItem := SP.SelectedItem;
End;

{ --- Demarrer la compilation et l execution --- }

Procedure HandleStartDebugging;
Var
 SourceFile: String;
 Ext: String;
 CmdLine: String;
 TempFile: String;
 ExitCode: Integer;
 ExeName: String;
 BaseName: String;
 SrcDir: String;
 I: Integer;
Begin
 { Determiner le fichier source a compiler }
 SourceFile := '';
 If Opts.SourceFile <> '' Then
  SourceFile := Opts.SourceFile
 Else If EditorReady And (WinMgr.ActiveIdx >= 0) Then
  SourceFile := WinMgr.Windows[WinMgr.ActiveIdx].FileName;
 If SourceFile = '' Then Begin
  AppendOutput(OutputPanel,
   'Erreur : aucun fichier source ouvert.',
   Ord(OTK_BUILD));
  Exit;
 End;
 { Determiner l extension }
 Ext := LowerCaseStr(ExtractFileExt(SourceFile));
 { Extraire le repertoire du fichier source }
 SrcDir := ExtractFilePath(SourceFile);
 { Preparer le panneau de sortie }
 ClearOutput(OutputPanel, Ord(OTK_BUILD));
 ClearErrors(ErrorList);
 TempFile := '_buildout.tmp';
 { Calculer le nom de base sans extension }
 BaseName := ExtractFileName(SourceFile);
 For I := Length(BaseName) DownTo 1 Do
  If BaseName[I] = '.' Then Begin
   BaseName := Copy(BaseName, 1, I - 1);
   Break;
  End;
 {$IFDEF WINDOWS}
 ExeName := SrcDir + BaseName + '.exe';
 {$ELSE}
 ExeName := SrcDir + BaseName;
 {$ENDIF}
 If (Ext = '.pas') Or (Ext = '.pp') Or (Ext = '.lpr')
    Or (Ext = '.dpr') Then Begin
  { Compilation Pascal avec Free Pascal }
  DetectTPCCompiler(TPCContext);
  If TPCContext.CompilerFound Then Begin
   CmdLine := TPCContext.CompilerPath + ' ' + SourceFile;
   { Si un projet est charge, utiliser sa plateforme cible }
   If SolutionLoaded And (CurrentProject.Info.TargetCPU <> '') Then
    CmdLine := CmdLine + ' ' + CurrentProject.Info.TargetCPU;

   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   { Aucun compilateur interne trouve, essayer fpc }
   CmdLine := 'fpc -Mtp ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End;
  { Pour toute cible non-Windows, lancer le panneau emulateur :
    pour 8086 (-CD/-CP) il execute reellement le binaire,
    pour les autres il affiche un panneau d information. }
  If SolutionLoaded And
     (CurrentProject.Info.TargetCPU <> '') And
     (CurrentProject.Info.TargetCPU <> '-CW32') And
     (CurrentProject.Info.TargetCPU <> '-CW') Then Begin
   { Pour les cibles 68000, TPCW32 produit directement un binaire :
     -CAMIGA   -> .exe (Amiga Hunk)
     -CATARIST -> .prg (Atari ST)
     -C68000   -> .prg }
   If (CurrentProject.Info.TargetCPU = '-CATARIST') Or
      (CurrentProject.Info.TargetCPU = '-C68000') Then
    ExeName := SrcDir + BaseName + '.prg';
   { Pour AMIGA, l extension par defaut est deja .exe -> conserver ExeName. }
   { Cible Cray-1 : TPCW32 produit un binaire COS Absolute .abs. }
   If CurrentProject.Info.TargetCPU = '-CCRAY1' Then
    ExeName := SrcDir + BaseName + '.abs';
   { Cibles 6502 retro : extension specifique au format }
   If CurrentProject.Info.TargetCPU = '-CAPPLEII' Then
    ExeName := SrcDir + BaseName + '.bin';
   If CurrentProject.Info.TargetCPU = '-CC64' Then
    ExeName := SrcDir + BaseName + '.prg';
   If (CurrentProject.Info.TargetCPU = '-CATARI400') Or
      (CurrentProject.Info.TargetCPU = '-CATARI800') Then
    ExeName := SrcDir + BaseName + '.xex';
   If CurrentProject.Info.TargetCPU = '-CNES' Then
    ExeName := SrcDir + BaseName + '.nes';
   If CurrentProject.Info.TargetCPU = '-CATARI2600' Then
    ExeName := SrcDir + BaseName + '.a26';
   If CurrentProject.Info.TargetCPU = '-CCOCO3' Then
    ExeName := SrcDir + BaseName + '.bin';
   If (CurrentProject.Info.TargetCPU = '-CDRAGON32') Or
      (CurrentProject.Info.TargetCPU = '-CDRAGON64') Then
    ExeName := SrcDir + BaseName + '.bin';
   If (CurrentProject.Info.TargetCPU = '-CTO7') Or
      (CurrentProject.Info.TargetCPU = '-CTO8') Or
      (CurrentProject.Info.TargetCPU = '-CMO5') Then
    ExeName := SrcDir + BaseName + '.bin';
   If CurrentProject.Info.TargetCPU = '-CTRS80' Then
    ExeName := SrcDir + BaseName + '.cmd';
   If CurrentProject.Info.TargetCPU = '-CMSX' Then
    ExeName := SrcDir + BaseName + '.com';
   If CurrentProject.Info.TargetCPU = '-CADAM' Then
    ExeName := SrcDir + BaseName + '.com';
   ShowEmulatorPanel(EmuPanel, ExeName,
    CurrentProject.Info.TargetCPU);
  End;
 End
 Else If (Ext = '.cs') Then Begin
  { Compilation C# }
  DetectCSCCompiler(CSCContext);
  If CSCContext.CompilerFound Then Begin
   CmdLine := CSCContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur C# non trouve.',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.vb') Then Begin
  { Compilation VB.NET }
  DetectVBCCompiler(VBCContext);
  If VBCContext.CompilerFound Then Begin
   CmdLine := VBCContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur VB.NET non trouve.',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.adb') Or (Ext = '.ads') Or (Ext = '.ada') Then Begin
  { Compilation Ada }
  DetectADACCompiler(ADACContext);
  If ADACContext.CompilerFound Then Begin
   CmdLine := ADACContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur Ada non trouve (ADACW32/ADA86).',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.abap') Or (Ext = '.abp') Then Begin
  { Compilation ABAP/4 }
  DetectABAPCompiler(ABAPContext);
  If ABAPContext.CompilerFound Then Begin
   CmdLine := ABAPContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur ABAP non trouve (ABAPCW32/ABAP86).',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.c') Or (Ext = '.h') Then Begin
  { Compilation C }
  DetectCCCompiler(CCContext);
  If CCContext.CompilerFound Then Begin
   CmdLine := CCContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur C non trouve (CCW32/CC8086).',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.psp') Then Begin
  { Compilation PSP (Pascal Server Pages) }
  DetectPSPCompiler(PSPContext);
  If PSPContext.CompilerFound Then Begin
   CmdLine := PSPContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur PSP non trouve (PSPCW32/PSP86).',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.awk') Then Begin
  { Compilation AWK }
  DetectAWKCompiler(AWKContext);
  If AWKContext.CompilerFound Then Begin
   CmdLine := AWKContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur AWK non trouve (AWKCW32/AWK86).',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.java') Then Begin
  { Compilation Java }
  DetectJavaCompiler(JavaContext);
  If JavaContext.CompilerFound Then Begin
   CmdLine := JavaContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur Java non trouve (JAVACW32/JAVAC86).',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else If (Ext = '.py') Then Begin
  { Compilation Python }
  DetectPythonCompiler(PythonContext);
  If PythonContext.CompilerFound Then Begin
   CmdLine := PythonContext.CompilerPath + ' ' + SourceFile;
   AppendOutput(OutputPanel,
    '------ Build started: ' + SourceFile + ' ------',
    Ord(OTK_BUILD));
   AppendOutput(OutputPanel, '> ' + CmdLine,
    Ord(OTK_BUILD));
   ExitCode := ExecuteCompiler(CmdLine, TempFile);
   ReadOutputFile(TempFile, OutputPanel, Ord(OTK_BUILD));
   CleanupTempFile(TempFile);
  End Else Begin
   AppendOutput(OutputPanel,
    'Erreur : compilateur Python non trouve (PYTHCW32/PYTHON86).',
    Ord(OTK_BUILD));
   Exit;
  End;
 End
 Else Begin
  AppendOutput(OutputPanel,
   'Erreur : type de fichier non supporte (' + Ext + ').',
   Ord(OTK_BUILD));
  Exit;
 End;
 { Afficher le resultat }
 If ExitCode = 0 Then Begin
  AppendOutput(OutputPanel,
   '========== Build: 1 succeeded, 0 failed ==========',
   Ord(OTK_BUILD));
  { Pour les cibles non-Windows, l emulateur integre s en charge :
    on n essaie PAS d executer le binaire DOS/68k/6502/... avec
    Exec() sous Windows, ce qui afficherait un popup d erreur. }
  If SolutionLoaded And (CurrentProject.Info.TargetCPU <> '')
     And (CurrentProject.Info.TargetCPU <> '-CW32')
     And (CurrentProject.Info.TargetCPU <> '-CW') Then Begin
   AppendOutput(OutputPanel,
    'Cible ' + CurrentProject.Info.TargetCPU +
    ' : execution via emulateur integre (pas d exec systeme).',
    Ord(OTK_BUILD));
  End Else Begin
   { Lancer l executable }
   AppendOutput(OutputPanel, 'Execution de ' + ExeName + '...',
    Ord(OTK_BUILD));
   {$IFDEF WINDOWS}
   Exec(GetEnv('COMSPEC'), '/C ' + ExeName);
   {$ELSE}
   Exec('/bin/sh', '-c ./' + ExeName);
   {$ENDIF}
  End;
 End Else Begin
  AppendOutput(OutputPanel,
   '========== Build: 0 succeeded, 1 failed ==========',
   Ord(OTK_BUILD));
 End;
End;

