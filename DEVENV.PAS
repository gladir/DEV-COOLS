{ --- Calcul du rectangle occupe par un menu deroulant --- }

Procedure GetMenuRect(Idx: Integer; Var X1,Y1,X2,Y2: Integer);
Var
 M: TMenu;
 MW, MH, I: Integer;
Begin
 M := MainMenuBar.Menus[Idx];
 X1 := M.X;
 Y1 := MainMenuBar.Height;
 MW := M.Width;
 If MW < 160 Then MW := 160;
 MH := 4;
 For I := 0 To M.ItemCount - 1 Do Begin
  If M.Items[I].Separator Then MH := MH + 8
  Else MH := MH + 16;
 End;
 { +2 pour l ombre }
 X2 := X1 + MW + 2;
 Y2 := Y1 + MH + 2;
End;

{ --- Sauvegarder le fond avant d afficher un menu deroulant --- }

Procedure SaveMenuBackground(Idx: Integer);
Var
 BufSize: LongInt;
Begin
 GetMenuRect(Idx, MenuBgX1, MenuBgY1, MenuBgX2, MenuBgY2);
 BufSize := ImageSize(MenuBgX1, MenuBgY1, MenuBgX2, MenuBgY2);
 GetMem(MenuBgBuf, BufSize);
 GetImage(MenuBgX1, MenuBgY1, MenuBgX2, MenuBgY2, MenuBgBuf^);
 MenuBgSaved := True;
End;

{ --- Restaurer le fond sauvegarde (efface le menu deroulant) --- }

Procedure RestoreMenuBackground;
Var
 BufSize: LongInt;
Begin
 If Not MenuBgSaved Then Exit;
 PutImage(MenuBgX1, MenuBgY1, MenuBgBuf^, NormalPut);
 BufSize := ImageSize(MenuBgX1, MenuBgY1, MenuBgX2, MenuBgY2);
 FreeMem(MenuBgBuf, BufSize);
 MenuBgBuf := nil;
 MenuBgSaved := False;
End;

Procedure DrawMenuBar;
Var
 I, TX: Integer;
Begin
 { Fond de la barre }
 SetColor(CLR_MENUBAR);
 Bar(0, MainMenuBar.Y, GetScreenWidth - 1,
     MainMenuBar.Y + MainMenuBar.Height - 1);
 { Ligne de separation }
 SetColor(CLR_BORDER);
 Line(0, MainMenuBar.Y + MainMenuBar.Height - 1,
      GetScreenWidth - 1, MainMenuBar.Y + MainMenuBar.Height - 1);
 { Titres des menus }
 TX := 4;
 For I := 0 To MainMenuBar.MenuCount - 1 Do Begin
  If I = OpenMenuIdx Then Begin
   SetColor(CLR_MENU_HIGHLIGHT);
   Bar(TX - 4, MainMenuBar.Y,
       TX + Length(MainMenuBar.Menus[I].Title) * 8 + 12,
       MainMenuBar.Y + MainMenuBar.Height - 2);
   SetColor(CLR_EDITOR_BG);
  End Else
   SetColor(CLR_MENU_TEXT);
  OutTextXY(TX, MainMenuBar.Y + 4, MainMenuBar.Menus[I].Title);
  TX := TX + Length(MainMenuBar.Menus[I].Title) * 8 + 16;
 End;
End;

{ --- Ouverture d un menu deroulant --- }

Procedure DrawOpenMenu;
Var
 I, YPos, MX, MW, MH: Integer;
 M: TMenu;
Begin
 If OpenMenuIdx < 0 Then Exit;
 M := MainMenuBar.Menus[OpenMenuIdx];
 MX := M.X;
 MW := M.Width;
 If MW < 160 Then MW := 160;
 MH := 4;
 For I := 0 To M.ItemCount - 1 Do Begin
  If M.Items[I].Separator Then
   MH := MH + 8
  Else
   MH := MH + 16;
 End;
 { Ombre }
 SetColor(CLR_TITLEBAR);
 Bar(MX + 2, MainMenuBar.Height + 2, MX + MW + 2,
     MainMenuBar.Height + MH + 2);
 { Fond du menu }
 SetColor(CLR_EDITOR_BG);
 Bar(MX, MainMenuBar.Height, MX + MW, MainMenuBar.Height + MH);
 { Bordure }
 SetColor(CLR_BORDER);
 Rectangle(MX, MainMenuBar.Height, MX + MW, MainMenuBar.Height + MH);
 { Items }
 YPos := MainMenuBar.Height + 2;
 For I := 0 To M.ItemCount - 1 Do Begin
  If M.Items[I].Separator Then Begin
   SetColor(CLR_BORDER);
   Line(MX + 2, YPos + 3, MX + MW - 2, YPos + 3);
   YPos := YPos + 8;
  End Else Begin
   If I = SelItemIdx Then Begin
    SetColor(CLR_MENU_HIGHLIGHT);
    Bar(MX + 1, YPos, MX + MW - 1, YPos + 15);
    SetColor(CLR_EDITOR_BG);
   End Else Begin
    If Not M.Items[I].Enabled Then
     SetColor(CLR_BORDER)
    Else
     SetColor(CLR_MENU_TEXT);
   End;
   { Coche }
   If M.Items[I].Checked Then
    OutTextXY(MX + 4, YPos + 2, #251);
   { Caption }
   OutTextXY(MX + 16, YPos + 2, M.Items[I].Caption);
   { Raccourci }
   If Length(M.Items[I].ShortCut) > 0 Then Begin
    If I = SelItemIdx Then
     SetColor(CLR_EDITOR_BG)
    Else
     SetColor(CLR_BORDER);
    OutTextXY(MX + MW - Length(M.Items[I].ShortCut) * 8 - 8,
              YPos + 2, M.Items[I].ShortCut);
   End;
   YPos := YPos + 16;
  End;
 End;
End;

Procedure OpenMenu(Index: Integer);
Begin
 If (Index >= 0) And (Index < MainMenuBar.MenuCount) Then Begin
  { Si un menu est deja ouvert, restaurer le fond avant d afficher le nouveau }
  If MenuActive Then
   RestoreMenuBackground;
  OpenMenuIdx := Index;
  SelItemIdx := -1;
  MenuActive := True;
  DrawMenuBar;
  SaveMenuBackground(Index);  { sauvegarder le fond AVANT de dessiner }
  DrawOpenMenu;
 End;
End;

Procedure CloseMenu;
Begin
 { Restaurer le fond sauvegarde pour effacer le menu deroulant }
 RestoreMenuBackground;
 OpenMenuIdx := -1;
 SelItemIdx := -1;
 MenuActive := False;
 DrawMenuBar; { redessiner la barre sans surbrillance }
End;

{ --- Execution d un element de menu --- }

Procedure ExecuteMenuItem(Var Item: TMenuItem);
Var
 I: Integer;
Begin
 CloseMenu;
 Case Item.Tag Of
  100: Begin { Nouveau projet }
        ShowNewProjectDialog(NewProjDlg);
       End;
  101: Begin { Nouveau fichier (Ctrl+N) }
        ShowNewFileDialog(NewFileDlg);
       End;
  102: Begin { Nouvelle solution }
        InitNewProjectDialog(NewProjDlg);
        NewProjDlg.Base.Title := 'Nouvelle solution';
        NewProjDlg.Base.Visible := True;
        DrawNewProjectDialog(NewProjDlg);
       End;
  110: Begin { Ouvrir projet/solution (Ctrl+Maj+O) }
        InitFileDialog(FileDlg, False);
        LoadDirectoryFiles(FileDlg);
        FileDlg.Base.Title := 'Ouvrir projet/solution';
        FileDlg.Base.Visible := True;
        DrawFileDialog(FileDlg);
       End;
  111: Begin { Ouvrir fichier (Ctrl+O) }
        InitFileDialog(FileDlg, False);
        LoadDirectoryFiles(FileDlg);
        FileDlg.Base.Visible := True;
        DrawFileDialog(FileDlg);
       End;
  112: Begin { Ouvrir dossier... }
