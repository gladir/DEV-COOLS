{ --- Initialiser un noeud de l explorateur --- }

Procedure InitExplorerNode(Var Node: TExplorerNode);
Begin
 Node.Caption := '';
 Node.Kind := ENK_FILE_OTHER;
 Node.ParentIdx := -1;
 Node.Level := 0;
 Node.Expanded := False;
 Node.Visible := True;
 Node.Selected := False;
 Node.HasChildren := False;
 Node.Tag := 0;
End;

{ --- Initialiser l explorateur de solution --- }

Procedure InitExplorer(Var Exp: TSolutionExplorer);
Var
 I: Integer;
Begin
 Exp.NodeCount := 0;
 Exp.SelectedIdx := -1;
 Exp.ScrollTop := 0;
 Exp.X := GetScreenWidth - EXPLORER_WIDTH;
 Exp.Y := TOOLBTN_HEIGHT + TAB_HEIGHT + 2;
 Exp.Width := EXPLORER_WIDTH;
 Exp.Height := GetScreenHeight - Exp.Y - 20
  - PROPS_PANEL_HEIGHT - PROPS_SPLITTER_HEIGHT;
 Exp.SplitterX := Exp.X - SPLITTER_WIDTH;
 Exp.Dragging := False;
 Exp.NeedRepaint := True;
 Exp.Renaming := False;
 Exp.RenameIdx := -1;
 Exp.RenameBuf := '';
 Exp.RenameCPos := 0;
 For I := 0 To MAX_EXPLORER_NODES - 1 Do
  InitExplorerNode(Exp.Nodes[I]);
End;

{ --- Vider l explorateur --- }

Procedure ClearExplorer(Var Exp: TSolutionExplorer);
Var
 I: Integer;
Begin
 For I := 0 To Exp.NodeCount - 1 Do
  InitExplorerNode(Exp.Nodes[I]);
 Exp.NodeCount := 0;
 Exp.SelectedIdx := -1;
 Exp.ScrollTop := 0;
 Exp.NeedRepaint := True;
End;

{ --- Ajouter un noeud a l explorateur --- }

Function AddExplorerNode(Var Exp: TSolutionExplorer;
 ACaption: String; Kind: TExplorerNodeKind;
 ParentIdx: Integer): Integer;
Begin
 If Exp.NodeCount >= MAX_EXPLORER_NODES Then Begin
  AddExplorerNode := -1;
  Exit;
 End;
 InitExplorerNode(Exp.Nodes[Exp.NodeCount]);
 Exp.Nodes[Exp.NodeCount].Caption := ACaption;
 Exp.Nodes[Exp.NodeCount].Kind := Kind;
 Exp.Nodes[Exp.NodeCount].ParentIdx := ParentIdx;
 If ParentIdx >= 0 Then
  Exp.Nodes[Exp.NodeCount].Level :=
   Exp.Nodes[ParentIdx].Level + 1
 Else
  Exp.Nodes[Exp.NodeCount].Level := 0;
 Exp.Nodes[Exp.NodeCount].Visible := True;
 If ParentIdx >= 0 Then
  Exp.Nodes[ParentIdx].HasChildren := True;
 AddExplorerNode := Exp.NodeCount;
 Inc(Exp.NodeCount);
 Exp.NeedRepaint := True;
End;

{ --- Supprimer un noeud de l explorateur --- }

Procedure RemoveExplorerNode(Var Exp: TSolutionExplorer;
 Index: Integer);
Var
 I: Integer;
Begin
 If (Index < 0) Or (Index >= Exp.NodeCount) Then Exit;
 For I := Index To Exp.NodeCount - 2 Do
  Exp.Nodes[I] := Exp.Nodes[I + 1];
 Dec(Exp.NodeCount);
 For I := 0 To Exp.NodeCount - 1 Do Begin
  If Exp.Nodes[I].ParentIdx = Index Then
   Exp.Nodes[I].ParentIdx := -1
  Else If Exp.Nodes[I].ParentIdx > Index Then
   Dec(Exp.Nodes[I].ParentIdx);
 End;
 If Exp.SelectedIdx = Index Then
  Exp.SelectedIdx := -1
 Else If Exp.SelectedIdx > Index Then
  Dec(Exp.SelectedIdx);
 Exp.NeedRepaint := True;
End;

{ --- Determiner le type de noeud selon l extension --- }

Function NodeKindFromExtension(FileName: String): TExplorerNodeKind;
Var
 Ext: String;
 I: Integer;
Begin
 Ext := '';
 For I := Length(FileName) DownTo 1 Do Begin
  If FileName[I] = '.' Then Begin
   Ext := LowerCaseStr(Copy(FileName, I, Length(FileName) - I + 1));
   Break;
  End;
 End;
 If Ext = '.cs' Then
  NodeKindFromExtension := ENK_FILE_CS
 Else If Ext = '.vb' Then
  NodeKindFromExtension := ENK_FILE_VB
 Else If (Ext = '.pas') Or (Ext = '.pp') Then
  NodeKindFromExtension := ENK_FILE_PAS
 Else
  NodeKindFromExtension := ENK_FILE_OTHER;
End;

{ --- Rafraichir la visibilite des noeuds --- }

Procedure RefreshExplorer(Var Exp: TSolutionExplorer);
Var
 I, Parent: Integer;
Begin
 For I := 0 To Exp.NodeCount - 1 Do Begin
  Exp.Nodes[I].Visible := True;
  Parent := Exp.Nodes[I].ParentIdx;
  While Parent >= 0 Do Begin
   If Not Exp.Nodes[Parent].Expanded Then Begin
    Exp.Nodes[I].Visible := False;
    Break;
   End;
   Parent := Exp.Nodes[Parent].ParentIdx;
  End;
 End;
 Exp.NeedRepaint := True;
End;

{ --- Construire l arbre depuis la solution --- }

Procedure BuildSolutionTree(Var Exp: TSolutionExplorer;
 Var Sol: TSolution);
Var
 SolIdx, ProjIdx, RefIdx: Integer;
 I: Integer;
 ProjEntry: TProjectEntry;
Begin
 ClearExplorer(Exp);
 SolIdx := AddExplorerNode(Exp, Sol.Info.SolutionName,
  ENK_SOLUTION, -1);
 If SolIdx < 0 Then Exit;
 Exp.Nodes[SolIdx].Expanded := True;
 For I := 0 To Sol.ProjectCount - 1 Do Begin
  ProjEntry := Sol.Projects[I];
  ProjIdx := AddExplorerNode(Exp, ProjEntry.ProjectName,
   ENK_PROJECT, SolIdx);
  If ProjIdx < 0 Then Exit;
  Exp.Nodes[ProjIdx].Expanded := True;
  AddExplorerNode(Exp, 'Properties', ENK_PROPERTIES, ProjIdx);
  RefIdx := AddExplorerNode(Exp, 'References', ENK_REFERENCES,
   ProjIdx);
  If RefIdx >= 0 Then Begin
   Exp.Nodes[RefIdx].HasChildren := True;
   AddExplorerNode(Exp, 'System', ENK_REFERENCE, RefIdx);
   AddExplorerNode(Exp, 'System.Core', ENK_REFERENCE, RefIdx);
   AddExplorerNode(Exp, 'System.Data', ENK_REFERENCE, RefIdx);
  End;
 End;
 If Exp.NodeCount > 0 Then Begin
  Exp.SelectedIdx := 0;
  Exp.Nodes[0].Selected := True;
 End;
 Exp.NeedRepaint := True;
End;

{ --- Deplier un noeud --- }

Procedure ExpandNode(Var Exp: TSolutionExplorer; NodeIdx: Integer);
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then Exit;
 If Not Exp.Nodes[NodeIdx].HasChildren Then Exit;
 Exp.Nodes[NodeIdx].Expanded := True;
 RefreshExplorer(Exp);
End;

{ --- Replier un noeud --- }

Procedure CollapseNode(Var Exp: TSolutionExplorer;
 NodeIdx: Integer);
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then Exit;
 Exp.Nodes[NodeIdx].Expanded := False;
 RefreshExplorer(Exp);
End;

{ --- Basculer l etat deplie/replie --- }

Procedure ToggleNode(Var Exp: TSolutionExplorer;
 NodeIdx: Integer);
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then Exit;
 If Not Exp.Nodes[NodeIdx].HasChildren Then Exit;
 If Exp.Nodes[NodeIdx].Expanded Then
  CollapseNode(Exp, NodeIdx)
 Else
  ExpandNode(Exp, NodeIdx);
End;

{ --- Nombre total de noeuds --- }

Function GetExplorerNodeCount(Var Exp: TSolutionExplorer): Integer;
Begin
 GetExplorerNodeCount := Exp.NodeCount;
End;

{ --- Nombre de noeuds visibles --- }

Function GetVisibleNodeCount(Var Exp: TSolutionExplorer): Integer;
Var
 I, Cnt: Integer;
Begin
 Cnt := 0;
 For I := 0 To Exp.NodeCount - 1 Do
  If Exp.Nodes[I].Visible Then Inc(Cnt);
 GetVisibleNodeCount := Cnt;
End;

{ --- Couleur du noeud selon son type --- }

Function NodeKindColor(Kind: TExplorerNodeKind): Integer;
Begin
 Case Kind Of
  ENK_SOLUTION:    NodeKindColor := CLR_TITLEBAR_ACTIVE;
  ENK_PROJECT:     NodeKindColor := CLR_TITLEBAR_ACTIVE;
  ENK_PROPERTIES:  NodeKindColor := 8;
  ENK_REFERENCES:  NodeKindColor := 8;
  ENK_REFERENCE:   NodeKindColor := CLR_LINE_HIGHLIGHT;
  ENK_FOLDER:      NodeKindColor := CLR_LINE_HIGHLIGHT;
  ENK_FILE_CS:     NodeKindColor := CLR_TITLEBAR_ACTIVE;
  ENK_FILE_VB:     NodeKindColor := CLR_TITLEBAR_ACTIVE;
  ENK_FILE_PAS:    NodeKindColor := CLR_LINE_HIGHLIGHT;
  ENK_FILE_OTHER:  NodeKindColor := CLR_MENU_TEXT;
 Else
  NodeKindColor := CLR_MENU_TEXT;
 End;
End;

{ --- Dessiner un noeud de l explorateur --- }

Procedure DrawExplorerNode(Var Exp: TSolutionExplorer;
 NodeIdx: Integer; DrawY: Integer);
Var
 DrawX: Integer;
 TriX, TriY: Integer;
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then Exit;
 DrawX := Exp.X + 4 + Exp.Nodes[NodeIdx].Level * EXPLORER_INDENT;
 { Fond de selection }
 If Exp.Nodes[NodeIdx].Selected Then Begin
  SetFillStyle(SolidFill, CLR_SELECTION);
  Bar(Exp.X, DrawY, Exp.X + Exp.Width - 1,
   DrawY + EXPLORER_NODE_HEIGHT - 1);
 End;
 { Triangle de depliage si le noeud a des enfants }
 If Exp.Nodes[NodeIdx].HasChildren Then Begin
  TriX := DrawX;
  TriY := DrawY + EXPLORER_NODE_HEIGHT Div 2;
  If Exp.Nodes[NodeIdx].Expanded Then Begin
   SetColor(CLR_MENU_TEXT);
   Line(TriX, TriY - 3, TriX + 6, TriY - 3);
   Line(TriX, TriY - 3, TriX + 3, TriY + 3);
   Line(TriX + 6, TriY - 3, TriX + 3, TriY + 3);
  End Else Begin
   SetColor(CLR_MENU_TEXT);
   Line(TriX, TriY - 4, TriX, TriY + 4);
   Line(TriX, TriY - 4, TriX + 6, TriY);
   Line(TriX, TriY + 4, TriX + 6, TriY);
  End;
  DrawX := DrawX + 10;
 End Else
  DrawX := DrawX + 10;
 { Petit carre d icone }
 SetFillStyle(SolidFill,
  NodeKindColor(Exp.Nodes[NodeIdx].Kind));
 Bar(DrawX, DrawY + 2, DrawX + EXPLORER_ICON_SIZE - 4,
  DrawY + EXPLORER_NODE_HEIGHT - 4);
 DrawX := DrawX + EXPLORER_ICON_SIZE;
 { Texte du noeud ou champ de renommage }
 If Exp.Renaming And (NodeIdx = Exp.RenameIdx) Then Begin
  { Fond blanc pour le champ de saisie }
  SetFillStyle(SolidFill, CLR_EDITOR_BG);
  Bar(DrawX - 2, DrawY + 1,
   Exp.X + Exp.Width - 14, DrawY + EXPLORER_NODE_HEIGHT - 2);
  SetColor(CLR_TITLEBAR_ACTIVE);
  Rectangle(DrawX - 2, DrawY + 1,
   Exp.X + Exp.Width - 14, DrawY + EXPLORER_NODE_HEIGHT - 2);
  SetColor(CLR_MENU_TEXT);
  OutTextXY(DrawX, DrawY + 3, Exp.RenameBuf);
  { Curseur clignotant }
  SetColor(CLR_MENU_TEXT);
  Line(DrawX + TextWidth(Copy(Exp.RenameBuf, 1, Exp.RenameCPos)),
   DrawY + 3,
   DrawX + TextWidth(Copy(Exp.RenameBuf, 1, Exp.RenameCPos)),
   DrawY + EXPLORER_NODE_HEIGHT - 4);
 End Else Begin
  If Exp.Nodes[NodeIdx].Selected Then
   SetColor(CLR_EDITOR_BG)
  Else
   SetColor(CLR_MENU_TEXT);
  OutTextXY(DrawX, DrawY + 3, Exp.Nodes[NodeIdx].Caption);
 End;
End;

{ --- Dessiner l explorateur de solution --- }

Procedure DrawExplorer(Var Exp: TSolutionExplorer);
Var
 I, DrawY, VisCount, VisTot, MaxVis: Integer;
Begin
 { Fond du panneau }
 SetFillStyle(SolidFill, CLR_EXPLORER_BG);
 Bar(Exp.X, Exp.Y, Exp.X + Exp.Width - 1,
  Exp.Y + Exp.Height - 1);
 { Titre }
 If ExplorerHasFocus Then
  SetFillStyle(SolidFill, CLR_TITLEBAR_ACTIVE)
 Else
  SetFillStyle(SolidFill, CLR_TITLEBAR);
 Bar(Exp.X, Exp.Y, Exp.X + Exp.Width - 1,
  Exp.Y + EXPLORER_NODE_HEIGHT - 1);
 SetColor(CLR_EDITOR_BG);
 OutTextXY(Exp.X + 4, Exp.Y + 3, 'Explorateur de solutions');
 { Splitter }
 SetFillStyle(SolidFill, CLR_BORDER);
 Bar(Exp.SplitterX, Exp.Y,
  Exp.SplitterX + SPLITTER_WIDTH - 1,
  Exp.Y + Exp.Height - 1);
 { Dessiner les noeuds visibles }
 DrawY := Exp.Y + EXPLORER_NODE_HEIGHT + 2;
 VisCount := 0;
 For I := 0 To Exp.NodeCount - 1 Do Begin
  If Not Exp.Nodes[I].Visible Then Continue;
  If VisCount < Exp.ScrollTop Then Begin
   Inc(VisCount);
   Continue;
  End;
  If DrawY + EXPLORER_NODE_HEIGHT > Exp.Y + Exp.Height Then
   Break;
  DrawExplorerNode(Exp, I, DrawY);
  DrawY := DrawY + EXPLORER_NODE_HEIGHT;
  Inc(VisCount);
 End;
 { Barre de defilement (toujours visible). Inclut deux boutons fleches
   en haut et en bas, et un curseur (thumb) proportionnel au centre.
   Si l'arbre tient en entier dans la zone visible, le thumb prend
   toute la hauteur du couloir. }
 VisTot := GetVisibleNodeCount(Exp);
 MaxVis := (Exp.Height - EXPLORER_NODE_HEIGHT) Div
  EXPLORER_NODE_HEIGHT;
 If MaxVis < 1 Then MaxVis := 1;
 Begin
   { Couloir de la scrollbar (14 px de large). }
   SetFillStyle(SolidFill, CLR_SCROLLBAR);
   Bar(Exp.X + Exp.Width - 14, Exp.Y + EXPLORER_NODE_HEIGHT,
    Exp.X + Exp.Width - 1, Exp.Y + Exp.Height - 1);
   { Bouton fleche haut (14x14 sous le titre). }
   SetFillStyle(SolidFill, CLR_BORDER);
   Bar(Exp.X + Exp.Width - 14, Exp.Y + EXPLORER_NODE_HEIGHT,
    Exp.X + Exp.Width - 1,
    Exp.Y + EXPLORER_NODE_HEIGHT + 13);
   SetColor(CLR_EDITOR_BG);
   Rectangle(Exp.X + Exp.Width - 14, Exp.Y + EXPLORER_NODE_HEIGHT,
    Exp.X + Exp.Width - 1,
    Exp.Y + EXPLORER_NODE_HEIGHT + 13);
   { Triangle haut. }
   SetFillStyle(SolidFill, CLR_EDITOR_BG);
   Bar(Exp.X + Exp.Width - 8, Exp.Y + EXPLORER_NODE_HEIGHT + 4,
    Exp.X + Exp.Width - 7, Exp.Y + EXPLORER_NODE_HEIGHT + 4);
   Bar(Exp.X + Exp.Width - 9, Exp.Y + EXPLORER_NODE_HEIGHT + 5,
    Exp.X + Exp.Width - 6, Exp.Y + EXPLORER_NODE_HEIGHT + 5);
   Bar(Exp.X + Exp.Width - 10, Exp.Y + EXPLORER_NODE_HEIGHT + 6,
    Exp.X + Exp.Width - 5, Exp.Y + EXPLORER_NODE_HEIGHT + 6);
   Bar(Exp.X + Exp.Width - 11, Exp.Y + EXPLORER_NODE_HEIGHT + 7,
    Exp.X + Exp.Width - 4, Exp.Y + EXPLORER_NODE_HEIGHT + 7);
   { Bouton fleche bas (14x14 en bas). }
   SetFillStyle(SolidFill, CLR_BORDER);
   Bar(Exp.X + Exp.Width - 14, Exp.Y + Exp.Height - 14,
    Exp.X + Exp.Width - 1, Exp.Y + Exp.Height - 1);
   SetColor(CLR_EDITOR_BG);
   Rectangle(Exp.X + Exp.Width - 14, Exp.Y + Exp.Height - 14,
    Exp.X + Exp.Width - 1, Exp.Y + Exp.Height - 1);
   { Triangle bas. }
   SetFillStyle(SolidFill, CLR_EDITOR_BG);
   Bar(Exp.X + Exp.Width - 11, Exp.Y + Exp.Height - 11,
    Exp.X + Exp.Width - 4, Exp.Y + Exp.Height - 11);
   Bar(Exp.X + Exp.Width - 10, Exp.Y + Exp.Height - 10,
    Exp.X + Exp.Width - 5, Exp.Y + Exp.Height - 10);
   Bar(Exp.X + Exp.Width - 9, Exp.Y + Exp.Height - 9,
    Exp.X + Exp.Width - 6, Exp.Y + Exp.Height - 9);
   Bar(Exp.X + Exp.Width - 8, Exp.Y + Exp.Height - 8,
    Exp.X + Exp.Width - 7, Exp.Y + Exp.Height - 8);
   { Curseur (thumb) proportionnel a la taille visible. }
   Begin
    VisCount := Exp.Y + EXPLORER_NODE_HEIGHT + 14;  { y debut couloir }
    DrawY := Exp.Y + Exp.Height - 14;               { y fin couloir   }
    I := DrawY - VisCount;                          { hauteur couloir }
    If I < 12 Then I := 12;
    { Hauteur du thumb proportionnelle. }
    If VisTot <= MaxVis Then
     MaxVis := I            { l'arbre tient en entier : thumb plein }
    Else
     MaxVis := (I * MaxVis) Div VisTot;
    If MaxVis < 12 Then MaxVis := 12;
    If MaxVis > I Then MaxVis := I;
    { Position du thumb. }
    If VisTot - ((Exp.Height - EXPLORER_NODE_HEIGHT) Div
                  EXPLORER_NODE_HEIGHT) > 0 Then
     DrawY := VisCount +
      (Exp.ScrollTop * (I - MaxVis)) Div
      (VisTot - ((Exp.Height - EXPLORER_NODE_HEIGHT) Div
                 EXPLORER_NODE_HEIGHT))
    Else
     DrawY := VisCount;
    SetFillStyle(SolidFill, CLR_BORDER);
    Bar(Exp.X + Exp.Width - 13, DrawY,
     Exp.X + Exp.Width - 2, DrawY + MaxVis);
    SetColor(CLR_EDITOR_BG);
    Rectangle(Exp.X + Exp.Width - 13, DrawY,
     Exp.X + Exp.Width - 2, DrawY + MaxVis);
   End;
  End;
 { Bordure }
 SetColor(CLR_BORDER);
 Rectangle(Exp.X, Exp.Y, Exp.X + Exp.Width - 1,
  Exp.Y + Exp.Height - 1);
 Exp.NeedRepaint := False;
End;

{ --- Trouver le noeud sous la souris --- }

Function ExplorerNodeHitTest(Var Exp: TSolutionExplorer;
 MX, MY: Integer): Integer;
Var
 I, DrawY, VisCount: Integer;
Begin
 ExplorerNodeHitTest := -1;
 If (MX < Exp.X) Or (MX >= Exp.X + Exp.Width) Then Exit;
 { Exclure la zone de la barre de defilement (14 px a droite). }
 If MX >= Exp.X + Exp.Width - 14 Then Exit;
 If (MY < Exp.Y + EXPLORER_NODE_HEIGHT) Or
    (MY >= Exp.Y + Exp.Height) Then Exit;
 DrawY := Exp.Y + EXPLORER_NODE_HEIGHT + 2;
 VisCount := 0;
 For I := 0 To Exp.NodeCount - 1 Do Begin
  If Not Exp.Nodes[I].Visible Then Continue;
  If VisCount < Exp.ScrollTop Then Begin
   Inc(VisCount);
   Continue;
  End;
  If DrawY + EXPLORER_NODE_HEIGHT > Exp.Y + Exp.Height Then
   Break;
  If (MY >= DrawY) And (MY < DrawY + EXPLORER_NODE_HEIGHT) Then Begin
   ExplorerNodeHitTest := I;
   Exit;
  End;
  DrawY := DrawY + EXPLORER_NODE_HEIGHT;
  Inc(VisCount);
 End;
End;

{ --- Gerer les evenements de l explorateur --- }

Procedure StartExplorerRename(Var Exp: TSolutionExplorer;
 NodeIdx: Integer);
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then Exit;
 Exp.Renaming := True;
 Exp.RenameIdx := NodeIdx;
 Exp.RenameBuf := Exp.Nodes[NodeIdx].Caption;
 Exp.RenameCPos := Length(Exp.RenameBuf);
 Exp.NeedRepaint := True;
End;

Procedure ConfirmExplorerRename(Var Exp: TSolutionExplorer);
Begin
 If Not Exp.Renaming Then Exit;
 If Length(Exp.RenameBuf) > 0 Then
  Exp.Nodes[Exp.RenameIdx].Caption := Exp.RenameBuf;
 Exp.Renaming := False;
 Exp.RenameIdx := -1;
 Exp.NeedRepaint := True;
End;

Procedure CancelExplorerRename(Var Exp: TSolutionExplorer);
Begin
 Exp.Renaming := False;
 Exp.RenameIdx := -1;
 Exp.NeedRepaint := True;
End;

{ --- Ouvrir un fichier source depuis l explorateur --- }

Procedure OpenExplorerFileNode(Var Exp: TSolutionExplorer;
 NodeIdx: Integer);
Var
 FN: String;
 SolDir: String;
 ProjDir: String;
 FullPath: String;
 WIdx: Integer;
 I: Integer;
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then Exit;
 FN := Exp.Nodes[NodeIdx].Caption;
 If FN = '' Then Exit;
 { Construire le chemin complet du fichier }
 If SolutionLoaded And (CurrentSolution.ProjectCount > 0) Then
 Begin
  SolDir := CurrentSolution.Info.SolutionPath;
  If Length(SolDir) > 0 Then Begin
   If (SolDir[Length(SolDir)] <> '\') And
      (SolDir[Length(SolDir)] <> '/') Then
    SolDir := SolDir + '\';
  End;
  ProjDir := ExtractFilePath(
   CurrentSolution.Projects[0].ProjectPath);
  FullPath := SolDir + ProjDir + FN;
  { Normaliser les separateurs }
  For I := 1 To Length(FullPath) Do
   If FullPath[I] = '/' Then FullPath[I] := '\';
 End
 Else
  FullPath := FN;
 { Sauvegarder l editeur actuel }
 If EditorReady And (WinMgr.ActiveIdx >= 0) And
    (WinMgr.ActiveIdx < WinMgr.WinCount) And
    (Editors[WinMgr.ActiveIdx] <> Nil) Then
  Editors[WinMgr.ActiveIdx]^ := ActiveEditor;
 { Masquer la page de demarrage }
 If StartPage.Visible Then Begin
  StartPage.Visible := False;
  FullRepaintNeeded := True;
 End;
 { Verifier si le fichier est deja ouvert }
 WIdx := FindEditorByFileName(FullPath);
 If WIdx >= 0 Then Begin
  { Activer l editeur existant }
  ActivateWindow(WIdx);
  FullRepaintNeeded := True;
  Exit;
 End;
 { Ouvrir dans un nouvel editeur }
 CreateEditorWindow(FullPath);
 WIdx := WinMgr.ActiveIdx;
 LoadFile(Editors[WIdx]^.Buffer, FullPath);
 ActiveEditor := Editors[WIdx]^;
 Opts.SourceFile := FullPath;
 EditorReady := True;
 FullRepaintNeeded := True;
End;

Procedure HandleExplorerEvent(Var Exp: TSolutionExplorer;
 Ev: TEvent);
Var
 HitIdx: Integer;
 MaxScroll: Integer;
Begin
 { Mode renommage : intercepter les evenements clavier }
 If Exp.Renaming Then Begin
  If Ev.Kind = EV_KEY_CHAR Then Begin
   If Ev.KeyChar = #27 Then { Escape : annuler }
    CancelExplorerRename(Exp)
   Else If Ev.KeyChar = #13 Then { Entree : confirmer }
    ConfirmExplorerRename(Exp)
   Else If Ev.KeyChar = #8 Then Begin { Backspace }
    If Exp.RenameCPos > 0 Then Begin
     Delete(Exp.RenameBuf, Exp.RenameCPos, 1);
     Dec(Exp.RenameCPos);
     Exp.NeedRepaint := True;
    End;
   End
   Else If (Ev.KeyChar >= #32) And (Ev.KeyChar <= #126) Then Begin
    { Caractere imprimable }
    If Length(Exp.RenameBuf) < 127 Then Begin
     Insert(Ev.KeyChar, Exp.RenameBuf, Exp.RenameCPos + 1);
     Inc(Exp.RenameCPos);
     Exp.NeedRepaint := True;
    End;
   End;
   If Exp.NeedRepaint Then
    DrawExplorer(Exp);
   Exit;
  End
  Else If Ev.Kind = EV_KEY_DOWN Then Begin
   If Ev.KeyCode = $4B Then Begin { Fleche gauche }
    If Exp.RenameCPos > 0 Then Begin
     Dec(Exp.RenameCPos);
     Exp.NeedRepaint := True;
     DrawExplorer(Exp);
    End;
   End
   Else If Ev.KeyCode = $4D Then Begin { Fleche droite }
    If Exp.RenameCPos < Length(Exp.RenameBuf) Then Begin
     Inc(Exp.RenameCPos);
     Exp.NeedRepaint := True;
     DrawExplorer(Exp);
    End;
   End
   Else If Ev.KeyCode = $47 Then Begin { Home }
    Exp.RenameCPos := 0;
    Exp.NeedRepaint := True;
    DrawExplorer(Exp);
   End
   Else If Ev.KeyCode = $4F Then Begin { End }
    Exp.RenameCPos := Length(Exp.RenameBuf);
    Exp.NeedRepaint := True;
    DrawExplorer(Exp);
   End
   Else If Ev.KeyCode = $53 Then Begin { Delete }
    If Exp.RenameCPos < Length(Exp.RenameBuf) Then Begin
     Delete(Exp.RenameBuf, Exp.RenameCPos + 1, 1);
     Exp.NeedRepaint := True;
     DrawExplorer(Exp);
    End;
   End;
   Exit;
  End
  Else If Ev.Kind = EV_MOUSE_DOWN Then Begin
   { Clic hors du champ : confirmer le renommage }
   ConfirmExplorerRename(Exp);
   DrawExplorer(Exp);
   { Ne pas sortir, laisser le clic etre traite normalement }
  End;
 End;
 If Ev.Kind = EV_MOUSE_DOWN Then Begin
  { Clic droit : menu contextuel }
  If Ev.MouseBtn = MB_RIGHT Then Begin
   HitIdx := ExplorerNodeHitTest(Exp, Ev.MouseX, Ev.MouseY);
   If HitIdx >= 0 Then Begin
    If (Exp.SelectedIdx >= 0) And
       (Exp.SelectedIdx < Exp.NodeCount) Then
     Exp.Nodes[Exp.SelectedIdx].Selected := False;
    Exp.SelectedIdx := HitIdx;
    Exp.Nodes[HitIdx].Selected := True;
    Exp.NeedRepaint := True;
    DrawExplorer(Exp);
    ShowExplorerContextMenu(Exp, CtxMenu, HitIdx,
     Ev.MouseX, Ev.MouseY);
   End;
   Exit;
  End;
  { Verifier le clic sur le splitter }
  If (Ev.MouseX >= Exp.SplitterX) And
     (Ev.MouseX < Exp.SplitterX + SPLITTER_WIDTH) Then Begin
   Exp.Dragging := True;
   Exit;
  End;
  { Verifier le clic dans la barre de defilement (14 px de large
    sur le bord droit du panneau, sous la barre de titre).
    Bouton fleche haut : 14 px hauts ; bouton fleche bas : 14 px bas ;
    couloir entre les deux : page-scroll. }
  If (Ev.MouseX >= Exp.X + Exp.Width - 14) And
     (Ev.MouseX < Exp.X + Exp.Width) And
     (Ev.MouseY >= Exp.Y + EXPLORER_NODE_HEIGHT) And
     (Ev.MouseY < Exp.Y + Exp.Height) Then Begin
   MaxScroll := (Exp.Height - EXPLORER_NODE_HEIGHT) Div
    EXPLORER_NODE_HEIGHT;
   If MaxScroll < 1 Then MaxScroll := 1;
   { Bouton haut. }
   If Ev.MouseY < Exp.Y + EXPLORER_NODE_HEIGHT + 14 Then
    Dec(Exp.ScrollTop)
   { Bouton bas. }
   Else If Ev.MouseY >= Exp.Y + Exp.Height - 14 Then
    Inc(Exp.ScrollTop)
   { Page haut/bas selon position dans le couloir. }
   Else If Ev.MouseY < Exp.Y + EXPLORER_NODE_HEIGHT + 14 +
                       ((Exp.Height - EXPLORER_NODE_HEIGHT - 28) Div 2) Then
    Dec(Exp.ScrollTop, MaxScroll)
   Else
    Inc(Exp.ScrollTop, MaxScroll);
   If Exp.ScrollTop < 0 Then Exp.ScrollTop := 0;
   HitIdx := GetVisibleNodeCount(Exp) - MaxScroll;
   If HitIdx < 0 Then HitIdx := 0;
   If Exp.ScrollTop > HitIdx Then Exp.ScrollTop := HitIdx;
   Exp.NeedRepaint := True;
   Exit;
  End;
  { Trouver le noeud clique }
  HitIdx := ExplorerNodeHitTest(Exp, Ev.MouseX, Ev.MouseY);
  If HitIdx >= 0 Then Begin
   If (Exp.SelectedIdx >= 0) And
      (Exp.SelectedIdx < Exp.NodeCount) Then
    Exp.Nodes[Exp.SelectedIdx].Selected := False;
   Exp.SelectedIdx := HitIdx;
   Exp.Nodes[HitIdx].Selected := True;
   If Exp.Nodes[HitIdx].HasChildren Then
    ToggleNode(Exp, HitIdx)
   Else If Exp.Nodes[HitIdx].Kind In
    [ENK_FILE_CS, ENK_FILE_VB, ENK_FILE_PAS,
     ENK_FILE_OTHER] Then
    OpenExplorerFileNode(Exp, HitIdx);
   Exp.NeedRepaint := True;
  End;
 End
 Else If Ev.Kind = EV_MOUSE_UP Then Begin
  If Exp.Dragging Then
   Exp.Dragging := False;
 End
 Else If Ev.Kind = EV_MOUSE_MOVE Then Begin
  If Exp.Dragging Then Begin
   If (Ev.MouseX >= GetScreenWidth - EXPLORER_MAX_WIDTH) And
      (Ev.MouseX <= GetScreenWidth - EXPLORER_MIN_WIDTH) Then Begin
    Exp.Width := GetScreenWidth - Ev.MouseX;
    Exp.X := Ev.MouseX;
    Exp.SplitterX := Exp.X - SPLITTER_WIDTH;
    Exp.NeedRepaint := True;
   End;
  End;
 End
 Else If Ev.Kind = EV_KEY_DOWN Then Begin
  Case Ev.KeyCode Of
   72: Begin { Fleche haut }
    If Exp.SelectedIdx > 0 Then Begin
     HitIdx := Exp.SelectedIdx - 1;
     While (HitIdx > 0) And
      (Not Exp.Nodes[HitIdx].Visible) Do
      Dec(HitIdx);
     If (HitIdx >= 0) And Exp.Nodes[HitIdx].Visible Then Begin
      Exp.Nodes[Exp.SelectedIdx].Selected := False;
      Exp.SelectedIdx := HitIdx;
      Exp.Nodes[Exp.SelectedIdx].Selected := True;
      Exp.NeedRepaint := True;
     End;
    End;
   End;
   80: Begin { Fleche bas }
    If Exp.SelectedIdx < Exp.NodeCount - 1 Then Begin
     HitIdx := Exp.SelectedIdx + 1;
     While (HitIdx < Exp.NodeCount - 1) And
      (Not Exp.Nodes[HitIdx].Visible) Do
      Inc(HitIdx);
     If (HitIdx < Exp.NodeCount) And Exp.Nodes[HitIdx].Visible Then Begin
      Exp.Nodes[Exp.SelectedIdx].Selected := False;
      Exp.SelectedIdx := HitIdx;
      Exp.Nodes[Exp.SelectedIdx].Selected := True;
      Exp.NeedRepaint := True;
     End;
    End;
   End;
   75: Begin { Fleche gauche : replier }
    If (Exp.SelectedIdx >= 0) And
       (Exp.SelectedIdx < Exp.NodeCount) Then Begin
     If Exp.Nodes[Exp.SelectedIdx].Expanded Then
      CollapseNode(Exp, Exp.SelectedIdx)
     Else If Exp.Nodes[Exp.SelectedIdx].ParentIdx >= 0 Then Begin
      Exp.Nodes[Exp.SelectedIdx].Selected := False;
      Exp.SelectedIdx := Exp.Nodes[Exp.SelectedIdx].ParentIdx;
      Exp.Nodes[Exp.SelectedIdx].Selected := True;
      Exp.NeedRepaint := True;
     End;
    End;
   End;
   77: Begin { Fleche droite : deplier }
    If (Exp.SelectedIdx >= 0) And
       (Exp.SelectedIdx < Exp.NodeCount) Then Begin
     If Exp.Nodes[Exp.SelectedIdx].HasChildren And
        (Not Exp.Nodes[Exp.SelectedIdx].Expanded) Then
      ExpandNode(Exp, Exp.SelectedIdx);
    End;
   End;
   13: Begin { Entree : basculer ou ouvrir }
    If (Exp.SelectedIdx >= 0) And
       (Exp.SelectedIdx < Exp.NodeCount) Then Begin
     If Exp.Nodes[Exp.SelectedIdx].Kind In
      [ENK_FILE_CS, ENK_FILE_VB, ENK_FILE_PAS,
       ENK_FILE_OTHER] Then
      OpenExplorerFileNode(Exp, Exp.SelectedIdx)
     Else
      ToggleNode(Exp, Exp.SelectedIdx);
    End;
   End;
   73, 81: Begin { PgUp (73), PgDn (81) }
    Begin
     If Exp.SelectedIdx >= 0 Then
      Exp.Nodes[Exp.SelectedIdx].Selected := False;
     MaxScroll := (Exp.Height - EXPLORER_NODE_HEIGHT) Div
      EXPLORER_NODE_HEIGHT;
     If MaxScroll < 1 Then MaxScroll := 1;
     If Ev.KeyCode = 73 Then Begin
      Dec(Exp.SelectedIdx, MaxScroll);
      If Exp.SelectedIdx < 0 Then Exp.SelectedIdx := 0;
     End Else Begin
      Inc(Exp.SelectedIdx, MaxScroll);
      If Exp.SelectedIdx >= Exp.NodeCount Then
       Exp.SelectedIdx := Exp.NodeCount - 1;
     End;
     While (Exp.SelectedIdx >= 0) And
           (Exp.SelectedIdx < Exp.NodeCount) And
           (Not Exp.Nodes[Exp.SelectedIdx].Visible) Do
      If Ev.KeyCode = 73 Then Dec(Exp.SelectedIdx)
      Else Inc(Exp.SelectedIdx);
     If (Exp.SelectedIdx >= 0) And
        (Exp.SelectedIdx < Exp.NodeCount) Then
      Exp.Nodes[Exp.SelectedIdx].Selected := True;
     Exp.NeedRepaint := True;
    End;
   End;
   71: Begin { Home : premier noeud visible }
    If Exp.SelectedIdx >= 0 Then
     Exp.Nodes[Exp.SelectedIdx].Selected := False;
    Exp.SelectedIdx := 0;
    While (Exp.SelectedIdx < Exp.NodeCount) And
          (Not Exp.Nodes[Exp.SelectedIdx].Visible) Do
     Inc(Exp.SelectedIdx);
    If Exp.SelectedIdx < Exp.NodeCount Then
     Exp.Nodes[Exp.SelectedIdx].Selected := True;
    Exp.ScrollTop := 0;
    Exp.NeedRepaint := True;
   End;
   79: Begin { End : dernier noeud visible }
    If Exp.SelectedIdx >= 0 Then
     Exp.Nodes[Exp.SelectedIdx].Selected := False;
    Exp.SelectedIdx := Exp.NodeCount - 1;
    While (Exp.SelectedIdx > 0) And
          (Not Exp.Nodes[Exp.SelectedIdx].Visible) Do
     Dec(Exp.SelectedIdx);
    If (Exp.SelectedIdx >= 0) And
       (Exp.SelectedIdx < Exp.NodeCount) Then
     Exp.Nodes[Exp.SelectedIdx].Selected := True;
    Exp.NeedRepaint := True;
   End;
  End;
 End;
 { Ajuster le defilement pour garder le noeud selectionne visible. }
 If (Exp.SelectedIdx >= 0) And (Exp.SelectedIdx < Exp.NodeCount) And
    Exp.Nodes[Exp.SelectedIdx].Visible Then Begin
  HitIdx := 0;  { reutilise comme compteur d'index visible }
  For MaxScroll := 0 To Exp.SelectedIdx - 1 Do
   If Exp.Nodes[MaxScroll].Visible Then Inc(HitIdx);
  MaxScroll := (Exp.Height - EXPLORER_NODE_HEIGHT) Div
   EXPLORER_NODE_HEIGHT;
  If MaxScroll < 1 Then MaxScroll := 1;
  If HitIdx < Exp.ScrollTop Then Begin
   Exp.ScrollTop := HitIdx;
   Exp.NeedRepaint := True;
  End
  Else If HitIdx >= Exp.ScrollTop + MaxScroll Then Begin
   Exp.ScrollTop := HitIdx - MaxScroll + 1;
   Exp.NeedRepaint := True;
  End;
 End;
 { Ajuster le defilement }
 MaxScroll := GetVisibleNodeCount(Exp) -
  ((Exp.Height - EXPLORER_NODE_HEIGHT) Div EXPLORER_NODE_HEIGHT);
 If MaxScroll < 0 Then MaxScroll := 0;
 If Exp.ScrollTop > MaxScroll Then Begin
  Exp.ScrollTop := MaxScroll;
  Exp.NeedRepaint := True;
 End;
End;

{ --- Initialiser le menu contextuel --- }

Procedure InitContextMenu(Var CM: TContextMenu);
Begin
 CM.ItemCount := 0;
 CM.X := 0;
 CM.Y := 0;
 CM.Width := 160;
 CM.Visible := False;
 CM.SelIdx := -1;
 CM.NodeIdx := -1;
End;

{ --- Ajouter un item au menu contextuel --- }

Procedure AddContextItem(Var CM: TContextMenu; ACaption: String;
 ATag: LongInt);
Begin
 If CM.ItemCount >= MAX_CTX_ITEMS Then Exit;
 CM.Items[CM.ItemCount].Caption := ACaption;
 CM.Items[CM.ItemCount].ShortCut := '';
 CM.Items[CM.ItemCount].Tag := ATag;
 CM.Items[CM.ItemCount].Enabled := True;
 CM.Items[CM.ItemCount].Separator := False;
 CM.Items[CM.ItemCount].Checked := False;
 Inc(CM.ItemCount);
End;

{ --- Ajouter un separateur au menu contextuel --- }

Procedure AddContextSeparator(Var CM: TContextMenu);
Begin
 If CM.ItemCount >= MAX_CTX_ITEMS Then Exit;
 CM.Items[CM.ItemCount].Separator := True;
 CM.Items[CM.ItemCount].Caption := '';
 CM.Items[CM.ItemCount].Tag := 0;
 Inc(CM.ItemCount);
End;

{ --- Dessiner le menu contextuel --- }

Procedure DrawContextMenu(Var CM: TContextMenu);
Var
 I, YPos, MH: Integer;
Begin
 If Not CM.Visible Then Exit;
 MH := 4;
 For I := 0 To CM.ItemCount - 1 Do
  If CM.Items[I].Separator Then MH := MH + 8
  Else MH := MH + 16;
 { Ombre }
 SetColor(CLR_TITLEBAR);
 Bar(CM.X + 2, CM.Y + 2, CM.X + CM.Width + 2, CM.Y + MH + 2);
 { Fond }
 SetColor(CLR_EDITOR_BG);
 Bar(CM.X, CM.Y, CM.X + CM.Width, CM.Y + MH);
 { Bordure }
 SetColor(CLR_BORDER);
 Rectangle(CM.X, CM.Y, CM.X + CM.Width, CM.Y + MH);
 { Items }
 YPos := CM.Y + 2;
 For I := 0 To CM.ItemCount - 1 Do Begin
  If CM.Items[I].Separator Then Begin
   SetColor(CLR_BORDER);
   Line(CM.X + 2, YPos + 3, CM.X + CM.Width - 2, YPos + 3);
   YPos := YPos + 8;
  End Else Begin
   If I = CM.SelIdx Then Begin
    SetColor(CLR_MENU_HIGHLIGHT);
    Bar(CM.X + 1, YPos, CM.X + CM.Width - 1, YPos + 15);
    SetColor(CLR_EDITOR_BG);
   End Else
    SetColor(CLR_MENU_TEXT);
   OutTextXY(CM.X + 8, YPos + 2, CM.Items[I].Caption);
   YPos := YPos + 16;
  End;
 End;
End;

{ --- Ouvrir le menu contextuel de l explorateur --- }

Procedure ShowExplorerContextMenu(Var Exp: TSolutionExplorer;
 Var CM: TContextMenu; NodeIdx, MX, MY: Integer);
Var
 Kind: TExplorerNodeKind;
Begin
 InitContextMenu(CM);
 CM.X := MX;
 CM.Y := MY;
 CM.NodeIdx := NodeIdx;
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then Exit;
 Kind := Exp.Nodes[NodeIdx].Kind;
 Case Kind Of
  ENK_SOLUTION: Begin
   AddContextItem(CM, 'Generer la solution', 300);
   AddContextItem(CM, 'Regener. la solution', 301);
   AddContextSeparator(CM);
   AddContextItem(CM, 'Ajouter un projet...', 310);
   AddContextItem(CM, 'Ajouter un fichier...', 311);
   AddContextSeparator(CM);
   AddContextItem(CM, 'Renommer', 320);
   AddContextItem(CM, 'Proprietes', 399);
  End;
  ENK_PROJECT: Begin
   AddContextItem(CM, 'Generer', 400);
   AddContextItem(CM, 'Regenerer', 401);
   AddContextSeparator(CM);
   AddContextItem(CM, 'Ajouter un fichier...', 411);
   AddContextItem(CM, 'Ajouter une reference...', 412);
   AddContextSeparator(CM);
   AddContextItem(CM, 'Renommer', 420);
   AddContextItem(CM, 'Supprimer', 421);
   AddContextItem(CM, 'Proprietes', 499);
  End;
  ENK_FILE_CS, ENK_FILE_VB, ENK_FILE_PAS, ENK_FILE_OTHER: Begin
   AddContextItem(CM, 'Ouvrir', 500);
   AddContextSeparator(CM);
   AddContextItem(CM, 'Renommer', 520);
   AddContextItem(CM, 'Supprimer', 521);
  End;
  ENK_REFERENCES: Begin
   AddContextItem(CM, 'Ajouter une reference...', 412);
  End;
  ENK_REFERENCE: Begin
   AddContextItem(CM, 'Supprimer', 521);
  End;
  ENK_FOLDER: Begin
   AddContextItem(CM, 'Ajouter un fichier...', 411);
   AddContextSeparator(CM);
   AddContextItem(CM, 'Renommer', 520);
   AddContextItem(CM, 'Supprimer', 521);
  End;
  ENK_PROPERTIES: Begin
   AddContextItem(CM, 'Ouvrir', 500);
  End;
 End;
 If CM.ItemCount > 0 Then
  CM.Visible := True;
 DrawContextMenu(CM);
End;

{ --- Gerer un evenement du menu contextuel --- }

Function HandleContextMenuEvent(Var CM: TContextMenu;
 Var Ev: TEvent): LongInt;
Var
 I, YPos, MH: Integer;
Begin
 HandleContextMenuEvent := 0;
 If Not CM.Visible Then Exit;
 If Ev.Kind = EV_MOUSE_MOVE Then Begin
  { Survol : calculer l item sous la souris }
  CM.SelIdx := -1;
  MH := 4;
  For I := 0 To CM.ItemCount - 1 Do
   If CM.Items[I].Separator Then MH := MH + 8
   Else MH := MH + 16;
  If (Ev.MouseX >= CM.X) And (Ev.MouseX <= CM.X + CM.Width) And
     (Ev.MouseY >= CM.Y) And (Ev.MouseY <= CM.Y + MH) Then Begin
   YPos := CM.Y + 2;
   For I := 0 To CM.ItemCount - 1 Do Begin
    If CM.Items[I].Separator Then
     YPos := YPos + 8
    Else Begin
     If (Ev.MouseY >= YPos) And (Ev.MouseY < YPos + 16) Then Begin
      CM.SelIdx := I;
      Break;
     End;
     YPos := YPos + 16;
    End;
   End;
  End;
  DrawContextMenu(CM);
 End
 Else If Ev.Kind = EV_MOUSE_DOWN Then Begin
  { Clic : verifier si c est sur un item }
  YPos := CM.Y + 2;
  For I := 0 To CM.ItemCount - 1 Do Begin
   If CM.Items[I].Separator Then
    YPos := YPos + 8
   Else Begin
    If (Ev.MouseX >= CM.X) And (Ev.MouseX <= CM.X + CM.Width) And
       (Ev.MouseY >= YPos) And (Ev.MouseY < YPos + 16) Then Begin
     HandleContextMenuEvent := CM.Items[I].Tag;
     CM.Visible := False;
     Exit;
    End;
    YPos := YPos + 16;
   End;
  End;
  { Clic hors du menu : fermer }
  CM.Visible := False;
 End
 Else If Ev.Kind = EV_KEY_CHAR Then Begin
  If Ev.KeyChar = #27 Then { Escape }
   CM.Visible := False;
  If Ev.KeyChar = #13 Then Begin { Entree }
   If (CM.SelIdx >= 0) And (CM.SelIdx < CM.ItemCount) And
      (Not CM.Items[CM.SelIdx].Separator) Then Begin
    HandleContextMenuEvent := CM.Items[CM.SelIdx].Tag;
    CM.Visible := False;
   End;
  End;
 End
 Else If Ev.Kind = EV_KEY_DOWN Then Begin
  If Ev.KeyCode = $48 Then Begin { Fleche haut }
   If CM.SelIdx > 0 Then Begin
    Dec(CM.SelIdx);
    If CM.Items[CM.SelIdx].Separator And (CM.SelIdx > 0) Then
     Dec(CM.SelIdx);
   End;
   DrawContextMenu(CM);
  End
  Else If Ev.KeyCode = $50 Then Begin { Fleche bas }
   If CM.SelIdx < CM.ItemCount - 1 Then Begin
    Inc(CM.SelIdx);
    If CM.Items[CM.SelIdx].Separator And
       (CM.SelIdx < CM.ItemCount - 1) Then
     Inc(CM.SelIdx);
   End;
   DrawContextMenu(CM);
  End;
 End;
End;

{ --- Trouver un noeud par son nom --- }

Function FindExplorerNode(Var Exp: TSolutionExplorer;
 ACaption: String): Integer;
Var
 I: Integer;
Begin
 FindExplorerNode := -1;
 For I := 0 To Exp.NodeCount - 1 Do
  If Exp.Nodes[I].Caption = ACaption Then Begin
   FindExplorerNode := I;
   Exit;
  End;
End;

{ --- Verifier si un noeud est deplie --- }

Function IsExplorerNodeExpanded(Var Exp: TSolutionExplorer;
 NodeIdx: Integer): Boolean;
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then
  IsExplorerNodeExpanded := False
 Else
  IsExplorerNodeExpanded := Exp.Nodes[NodeIdx].Expanded;
End;

{ --- Verifier si un noeud est visible --- }

Function IsExplorerNodeVisible(Var Exp: TSolutionExplorer;
 NodeIdx: Integer): Boolean;
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then
  IsExplorerNodeVisible := False
 Else
  IsExplorerNodeVisible := Exp.Nodes[NodeIdx].Visible;
End;

{ --- Obtenir le niveau d un noeud --- }

Function GetExplorerNodeLevel(Var Exp: TSolutionExplorer;
 NodeIdx: Integer): Integer;
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then
  GetExplorerNodeLevel := -1
 Else
  GetExplorerNodeLevel := Exp.Nodes[NodeIdx].Level;
End;

{ --- Obtenir le texte d un noeud --- }

Function GetExplorerNodeCaption(Var Exp: TSolutionExplorer;
 NodeIdx: Integer): String;
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then
  GetExplorerNodeCaption := ''
 Else
  GetExplorerNodeCaption := Exp.Nodes[NodeIdx].Caption;
End;

{ --- Obtenir le type d un noeud --- }

Function GetExplorerNodeKind(Var Exp: TSolutionExplorer;
 NodeIdx: Integer): TExplorerNodeKind;
Begin
 If (NodeIdx < 0) Or (NodeIdx >= Exp.NodeCount) Then
  GetExplorerNodeKind := ENK_FILE_OTHER
 Else
  GetExplorerNodeKind := Exp.Nodes[NodeIdx].Kind;
End;

{ --- Obtenir l index du noeud selectionne --- }

Function GetExplorerSelectedNode(
 Var Exp: TSolutionExplorer): Integer;
Begin
 GetExplorerSelectedNode := Exp.SelectedIdx;
End;

{ --- Definir le noeud selectionne --- }

Procedure SetExplorerSelectedNode(Var Exp: TSolutionExplorer;
 NodeIdx: Integer);
Begin
 If (Exp.SelectedIdx >= 0) And
    (Exp.SelectedIdx < Exp.NodeCount) Then
  Exp.Nodes[Exp.SelectedIdx].Selected := False;
 If (NodeIdx >= 0) And (NodeIdx < Exp.NodeCount) Then Begin
  Exp.SelectedIdx := NodeIdx;
  Exp.Nodes[NodeIdx].Selected := True;
 End Else
  Exp.SelectedIdx := -1;
 Exp.NeedRepaint := True;
End;

{ --- Verifier si l explorateur est vide --- }

Function IsExplorerEmpty(Var Exp: TSolutionExplorer): Boolean;
Begin
 IsExplorerEmpty := Exp.NodeCount = 0;
End;


