MODULE REALTEST;

  DEFINE MAX = 100;
  DEFINE HALF = 50;

  ITEM A F;
  ITEM B F;
  ITEM COUNTER I 16;

  PROCEDURE REALTEST;
    COUNTER = MAX;
    OUTPUT ('MAX = $D', COUNTER);
    COUNTER = HALF;
    OUTPUT ('HALF = $D', COUNTER);
    COUNTER = MAX + HALF;
    OUTPUT ('MAX+HALF = $D', COUNTER);
    COUNTER = MAX * 2;
    OUTPUT ('MAX*2 = $D', COUNTER);
    OUTPUT ('ITEMS REELS DECLARES : A B');
    STOP;
  END;

END MODULE REALTEST;
