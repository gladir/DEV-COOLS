MODULE BITOPS;

  ITEM FLAGS B 16;
  ITEM MASK  B 16;
  ITEM RESULT B 16;

  PROCEDURE BITOPS;
    FLAGS  = 255;
    MASK   = 15;
    RESULT = FLAGS AND MASK;
    OUTPUT ('FLAGS AND MASK = $D', RESULT);
    RESULT = FLAGS OR MASK;
    OUTPUT ('FLAGS OR  MASK = $D', RESULT);
    RESULT = FLAGS XOR MASK;
    OUTPUT ('FLAGS XOR MASK = $D', RESULT);
    RESULT = NOT MASK;
    OUTPUT ('NOT MASK       = $D', RESULT);
    STOP;
  END;

END MODULE BITOPS;
