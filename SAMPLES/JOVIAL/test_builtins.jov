MODULE BUILTINS;

  ITEM X I 16;
  ITEM Y I 16;
  ITEM FLAGS B 16;
  TABLE T(8) I 16;
  ITEM COLOR S 8 (ROUGE, VERT, BLEU);

  PROCEDURE BUILTINS;
    X = -5;
    Y = ABS(X);
    OUTPUT ('ABS(-5) = $D', Y);
    X = -3;
    Y = SGN(X);
    OUTPUT ('SGN(-3) = $D', Y);
    X = 7;
    Y = SGN(X);
    OUTPUT ('SGN(7) = $D', Y);
    X = 0;
    Y = SGN(X);
    OUTPUT ('SGN(0) = $D', Y);
    X = 1;
    Y = SHIFTL(X, 4);
    OUTPUT ('SHIFTL(1,4) = $D', Y);
    X = 256;
    Y = SHIFTR(X, 3);
    OUTPUT ('SHIFTR(256,3) = $D', Y);
    X = 0;
    Y = BIT(255, 4, 3);
    OUTPUT ('BIT(255,4,3) = $D', Y);
    Y = BITSIZE(FLAGS);
    OUTPUT ('BITSIZE(FLAGS) = $D', Y);
    Y = BYTESIZE(X);
    OUTPUT ('BYTESIZE(X) = $D', Y);
    Y = WORDSIZE(X);
    OUTPUT ('WORDSIZE(X) = $D', Y);
    Y = UBOUND(T, 1);
    OUTPUT ('UBOUND(T,1) = $D', Y);
    Y = LBOUND(T, 1);
    OUTPUT ('LBOUND(T,1) = $D', Y);
    Y = NWSDEN(T);
    OUTPUT ('NWSDEN(T) = $D', Y);
    Y = FIRST(COLOR);
    OUTPUT ('FIRST(COLOR) = $D', Y);
    Y = LAST(COLOR);
    OUTPUT ('LAST(COLOR) = $D', Y);
    STOP;
  END;

END MODULE BUILTINS;
