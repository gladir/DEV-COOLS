import java.awt.BorderLayout;
import java.awt.Button;
import java.awt.Frame;
import java.awt.Label;
import java.awt.event.ActionEvent;
import java.awt.event.ActionListener;
import java.awt.event.WindowAdapter;
import java.awt.event.WindowEvent;

/*
 * Fenetre AWT 1.1 portable et modele d'evenements par listener.
 */
public class Test13Awt extends Frame
    implements ActionListener {
    private Label message;

    public Test13Awt() {
        super("Exemple J++ / AWT");
        message = new Label("Appuyez sur le bouton.");
        Button bouton = new Button("Bonjour");

        setLayout(new BorderLayout());
        add(message, BorderLayout.CENTER);
        add(bouton, BorderLayout.SOUTH);
        bouton.addActionListener(this);

        addWindowListener(new WindowAdapter() {
            public void windowClosing(WindowEvent evenement) {
                dispose();
                System.exit(0);
            }
        });

        setSize(320, 120);
    }

    public void actionPerformed(ActionEvent evenement) {
        message.setText("Bonjour depuis AWT !");
    }

    public static void main(String[] args) {
        new Test13Awt().setVisible(true);
    }
}

