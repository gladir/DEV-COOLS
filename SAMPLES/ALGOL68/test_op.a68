BEGIN
  CO Test des definitions d operateurs (TODO 20) CO

  CO OP dyadique : addition personnalisee CO
  OP ADDX = (INT a, INT b) INT : a + b + 1;
  INT r1 := 10 ADDX 20;

  CO OP monadique : double CO
  OP DBL = (INT x) INT : x + x;
  INT r2 := DBL 7;

  CO OP surcharge d operateur existant avec PRIO CO
  PRIO MYMUL = 5;
  OP MYMUL = (INT a, INT b) INT : a * b;
  INT r3 := 3 MYMUL 4;

  CO OP monadique : negation personnalisee CO
  OP NEG2 = (INT x) INT : 0 - x;
  INT r4 := NEG2 42;

  CO OP dyadique avec priorite declaree CO
  PRIO MODX = 5;
  OP MODX = (INT a, INT b) INT : a - (a OVER b) * b;
  INT r5 := 17 MODX 5;

  CO Utilisation d operateurs dans des expressions complexes CO
  INT r6 := (10 ADDX 5) MYMUL 2;

  CO OP dyadique : soustraction CO
  OP SUBX = (INT a, INT b) INT : a - b;
  INT r7 := 100 SUBX 58;

  SKIP
END
