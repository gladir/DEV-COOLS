<%@ language="pascal" %>
<html>
<body>
<%
  var i : Integer;
  var sum : Integer;

  { Test for..to..do }
  sum := 0;
  for i := 1 to 10 do
  begin
    sum := sum + i;
  end;
  writeln('Somme 1..10 = ');
  writeln(sum);

  { Test for..downto..do }
  for i := 5 downto 1 do
    writeln(i);

  { Test while..do }
  i := 0;
  while i < 5 do
  begin
    writeln(i);
    i := i + 1;
  end;

  { Test repeat..until }
  i := 10;
  repeat
    writeln(i);
    i := i - 1;
  until i = 0;

  { Test break dans for }
  for i := 1 to 100 do
  begin
    if i > 3 then
      break;
    writeln(i);
  end;

  { Test continue dans for }
  for i := 1 to 5 do
  begin
    if i = 3 then
      continue;
    writeln(i);
  end;

  { Test while avec break }
  i := 0;
  while i < 100 do
  begin
    if i = 3 then
      break;
    writeln(i);
    i := i + 1;
  end;
%>
</body>
</html>
