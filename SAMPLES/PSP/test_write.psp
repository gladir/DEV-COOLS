<html>
<body>
<h1>Test TODO 12</h1>
<%
const
  TITLE = 'PSP86 Test';
  MAX   = 42;

var
  x: Integer;
  name: String;
  flag: Boolean;
  ch: Char;

x := 123;
name := 'monde';
flag := true;

{ Test Write avec differents types }
Write('Bonjour ');
WriteLn(name);
WriteLn('x = ', x);
WriteLn('flag = ', flag);
WriteLn;
Write(MAX);
