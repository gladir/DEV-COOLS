comment Test des expressions arithmetiques et booleennes (TODO 11) ;
BEGIN
  INTEGER a, b, c;
  BOOLEAN p, q, r;

  comment Arithmetique de base ;
  a := 10 + 5;
  b := 20 - 3;
  c := 4 * 7;

  comment Division entiere ;
  a := 100 / 5;
  b := 17 DIV 3;

  comment Puissance (^ appelle _A60RT_POWER) ;
  c := 2 ^ 3;
  a := 5 ^ 0;
  b := 3 ^ 4;

  comment Comparaisons ;
  p := 10 < 20;
  q := 5 <= 5;
  r := 3 = 3;
  p := 7 > 2;
  q := 8 >= 8;
  r := 4 != 5;

  comment Logique AND avec court-circuit ;
  p := TRUE AND FALSE;
  q := TRUE AND TRUE;
  r := FALSE AND TRUE;

  comment Logique OR avec court-circuit ;
  p := TRUE OR FALSE;
  q := FALSE OR FALSE;
  r := FALSE OR TRUE;

  comment NOT logique ;
  p := NOT TRUE;
  q := NOT FALSE;

  comment IMPL (implication) ;
  p := FALSE IMPL TRUE;
  q := TRUE IMPL FALSE;
  r := TRUE IMPL TRUE;

  comment EQUIV (equivalence) ;
  p := TRUE EQUIV TRUE;
  q := FALSE EQUIV FALSE;
  r := TRUE EQUIV FALSE;

  comment Precedence combinee ;
  a := 2 + 3 * 4;
  b := 2 * 3 ^ 2;
  c := (2 + 3) * (4 - 1);

  comment Unaires et combos ;
  a := -5 + 10;
  b := -(3 * 2);
  c := NOT TRUE AND FALSE;
END.
