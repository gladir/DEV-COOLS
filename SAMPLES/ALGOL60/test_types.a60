comment Test du systeme de types Algol 60 (TODO 06) ;
comment Ce fichier teste les types primitifs et les conversions ;
BEGIN
  comment Declarations de types primitifs ;
  INTEGER n, m;
  REAL x, y;
  BOOLEAN flag, done;
  
  comment Affectations entieres ;
  n := 42;
  m := n + 1;
  
  comment Affectations reelles (stub: entier tronque) ;
  x := 3.14;
  y := x + 1.0;
  
  comment Affectations booleennes ;
  flag := TRUE;
  done := FALSE;
  
  comment Conversions implicites INTEGER -> REAL ;
  x := n;
  y := m + 2;
  
  comment Expressions arithmetiques mixtes ;
  n := 10;
  x := n * 2;
  
  comment Expressions de comparaison -> BOOLEAN ;
  flag := n < 100;
  done := x = y;
  
  comment Expressions logiques -> BOOLEAN ;
  flag := flag AND done;
  done := flag OR NOT done;
  flag := TRUE IMPL FALSE;
  done := TRUE EQUIV TRUE;
  
  comment Division entiere (div -> INTEGER) ;
  n := 10 div 3;
  
  comment Puissance ;
  m := n ^ 2;
  
  comment Expressions imbriquees avec types ;
  IF n > 0 THEN x := n + 1
            ELSE x := 0
END.
