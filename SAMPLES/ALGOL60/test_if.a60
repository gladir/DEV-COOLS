comment Test des instructions conditionnelles IF/THEN/ELSE (TODO 13) ;
comment Ce fichier teste les differentes formes d instructions IF
  en Algol 60 : IF simple, IF/ELSE, IF imbriques, blocs BEGIN/END ;
BEGIN
  INTEGER x;
  INTEGER y;

  comment Test 1 : IF simple (vrai) ;
  x := 10;
  IF x = 10 THEN
    outstring(1, `Test 1: x is 10`);
  newline;

  comment Test 2 : IF simple (faux) ;
  IF x = 99 THEN
    outstring(1, `ERREUR: ne devrait pas s afficher`);
  outstring(1, `Test 2: IF faux passe`);
  newline;

  comment Test 3 : IF / ELSE (branche THEN) ;
  y := 5;
  IF y = 5 THEN
    outstring(1, `Test 3: y is 5`)
  ELSE
    outstring(1, `ERREUR`);
  newline;

  comment Test 4 : IF / ELSE (branche ELSE) ;
  IF y = 99 THEN
    outstring(1, `ERREUR`)
  ELSE
    outstring(1, `Test 4: y n est pas 99`);
  newline;

  comment Test 5 : IF avec bloc BEGIN/END en THEN ;
  IF x = 10 THEN
  BEGIN
    outstring(1, `Test 5a: bloc THEN`);
    newline;
    outstring(1, `Test 5b: suite bloc`)
  END;
  newline;

  comment Test 6 : IF/ELSE avec blocs BEGIN/END ;
  IF x = 99 THEN
  BEGIN
    outstring(1, `ERREUR bloc THEN`)
  END
  ELSE
  BEGIN
    outstring(1, `Test 6: bloc ELSE`);
    newline;
    outstring(1, `Test 6b: suite bloc ELSE`)
  END;
  newline;

  comment Test 7 : IF imbriques ;
  IF x = 10 THEN
    IF y = 5 THEN
      outstring(1, `Test 7: x=10 et y=5`);
  newline;

  comment Test 8 : expression conditionnelle dans affectation ;
  y := IF x = 10 THEN 100 ELSE 200;
  outstring(1, `Test 8: y=`);
  outinteger(1, y);
  newline;

  comment Test 9 : expression conditionnelle (branche fausse) ;
  y := IF x = 99 THEN 100 ELSE 200;
  outstring(1, `Test 9: y=`);
  outinteger(1, y);
  newline;

  outstring(1, `Fin test IF`)
END.
