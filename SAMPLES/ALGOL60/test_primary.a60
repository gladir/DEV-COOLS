comment Test des expressions primaires (TODO 10) ;
comment Ce fichier teste les appels de fonctions,
  l acces aux elements de tableau, les expressions
  conditionnelles comme valeur, et les acces switch ;
BEGIN
  comment Declarations de variables ;
  INTEGER a, b, c;
  INTEGER result;

  comment Affectation simple et expression comme valeur ;
  a := 10;
  b := 20;
  c := a + b;

  comment Expression conditionnelle inline (IF/THEN/ELSE) ;
  result := IF a > b THEN a ELSE b;

  comment Expression conditionnelle avec egalite ;
  result := IF a = 10 THEN 1 ELSE 0;

  comment Parentheses imbriquees ;
  result := (a + b) * (a - b);
  result := ((a + 1) * 2);

  comment Expressions avec litteraux mixtes ;
  result := 42;
  result := TRUE;
  result := FALSE;

  comment Expression avec plusieurs operateurs ;
  result := a * b + c;
  result := a + b * c;

  comment Bloc imbrique avec expressions primaires ;
  BEGIN
    INTEGER local;
    local := a + 1;
    result := local * 2;
    result := IF local > 5 THEN local ELSE 0
  END
END.
