comment Test des tableaux ARRAY a bornes dynamiques (TODO 17) ;
BEGIN
  comment Declaration de tableau global INTEGER ARRAY 1D ;
  INTEGER ARRAY a[1:5];

  comment Affectation aux elements du tableau ;
  a[1] := 10;
  a[2] := 20;
  a[3] := 30;
  a[4] := 40;
  a[5] := 50;

  comment Lecture et affichage des elements ;
  OUTINTEGER(1, a[1]);
  OUTINTEGER(1, a[3]);
  OUTINTEGER(1, a[5]);

  comment Expression avec acces tableau ;
  INTEGER x;
  x := a[2] + a[4];
  OUTINTEGER(1, x);

  comment Boucle FOR avec acces tableau ;
  INTEGER i;
  FOR i := 1 STEP 1 UNTIL 5 DO
    OUTINTEGER(1, a[i]);

  comment Tableau local dans un bloc imbrique ;
  BEGIN
    INTEGER ARRAY b[0:3];
    b[0] := 100;
    b[1] := 200;
    b[2] := 300;
    b[3] := 400;
    OUTINTEGER(1, b[0]);
    OUTINTEGER(1, b[2])
  END;

  comment Tableau avec bornes non standard ;
  INTEGER ARRAY c[5:8];
  c[5] := 55;
  c[6] := 66;
  c[7] := 77;
  c[8] := 88;
  OUTINTEGER(1, c[5]);
  OUTINTEGER(1, c[8]);

  comment REAL ARRAY ;
  REAL ARRAY r[1:3];
  r[1] := 111;
  r[2] := 222;
  r[3] := 333;
  OUTINTEGER(1, r[1]);
  OUTINTEGER(1, r[3]);

  comment BOOLEAN ARRAY ;
  BOOLEAN ARRAY flags[1:2];
  flags[1] := TRUE;
  flags[2] := FALSE;
  OUTBOOLEAN(1, flags[1]);
  OUTBOOLEAN(1, flags[2]);

  newline(1);
  outstring(1, `Fin test tableaux`)
END.
