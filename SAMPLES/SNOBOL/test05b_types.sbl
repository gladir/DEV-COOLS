* test05b_types.sbl - IDENT, pattern, branches S/F complexes
* Sortie attendue :
*   CHAINES DIFFERENTES
*   PATTERN TROUVE
*   TAILLE OK
        X = 'ALPHA'
        Y = 'BETA'
        IDENT(X,Y) :S(PAREIL) :F(DIFF)
PAREIL  &OUTPUT = 'CHAINES IDENTIQUES' :(SUITE1)
DIFF    &OUTPUT = 'CHAINES DIFFERENTES'
SUITE1  TEXTE = 'COMPILATION SNOBOL4'
        TEXTE 'SNOBOL' :S(PATOK) :F(PATNOK)
PATOK   &OUTPUT = 'PATTERN TROUVE' :(SUITE2)
PATNOK  &OUTPUT = 'PATTERN ABSENT'
SUITE2  MOT = 'BONJOUR'
        LT(SIZE(MOT),'10') :S(TAILLEOK) :F(TROPLONG)
TAILLEOK &OUTPUT = 'TAILLE OK' :(FIN)
TROPLONG &OUTPUT = 'MOT TROP LONG'
FIN
-END-
