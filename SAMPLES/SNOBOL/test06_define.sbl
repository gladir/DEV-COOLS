* test06_define.sbl - DEFINE + appel + RETURN + valeur retournee
* Sortie attendue :
*   BONJOUR ALICE
*   BONJOUR BOB
*   LONGUEUR: 5
        DEFINE('SALUER(NOM)')
        DEFINE('LONGUEUR(S)')
        &OUTPUT = SALUER('ALICE')
        &OUTPUT = SALUER('BOB')
        &OUTPUT = 'LONGUEUR: ' LONGUEUR('HELLO')
        :(FIN)
SALUER  SALUER = 'BONJOUR ' NOM
        RETURN
LONGUEUR LONGUEUR = SIZE(S)
        RETURN
FIN
-END-
