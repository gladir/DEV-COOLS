* test05_types.sbl - LT, IDENT, SIZE, branches S/F enchainées
* Sortie attendue :
*   A EST INFERIEUR A B
*   CHAINE VIDE
*   TAILLE = 5
        A = '3'
        B = '7'
        LT(A,B) :S(AINF) :F(BSUP)
AINF    &OUTPUT = 'A EST INFERIEUR A B' :(SUITE1)
BSUP    &OUTPUT = 'B EST INFERIEUR A A'
SUITE1  VIDE = ''
        IDENT(VIDE,'') :S(ESTVIDE) :F(PASVIDE)
ESTVIDE &OUTPUT = 'CHAINE VIDE' :(SUITE2)
PASVIDE &OUTPUT = 'CHAINE NON VIDE'
SUITE2  MOT = 'HELLO'
        TAILLE = SIZE(MOT)
        &OUTPUT = 'TAILLE = ' TAILLE
-END-
