// variables.pfx - Variables Number, Text et Boolean avec Set()
// Une variable est creee au premier Set() et peut etre reaffectee ensuite.

Set(Largeur, 12);
Set(Hauteur, 5);
Set(Aire, Largeur * Hauteur);

Set(Nom, "Sylvain");
Set(Salutation, "Bonjour, " & Nom & " !");

Set(EstMajeur, true);
Set(EstDisponible, false);

Print(Aire);
Print(Salutation);
Print(EstMajeur);
Print(EstDisponible);

// Reaffectation : Aire est mise a jour avec une nouvelle formule
Set(Aire, Aire + 100);
Print(Aire);
