
; ============================================================
; F77C86 Runtime Library (_FRT_xxx) - 8086 NEAR mode
; ============================================================
        .CODE

        .DATA
_FRT_SCAT_BUF  DB  256 DUP(20h)  ; buffer interne SCAT (espaces)
_FRT_MSG_TRUE  DB  '.TRUE.'
_FRT_MSG_FALSE DB  '.FALSE.'
_FRT_MSG_PAUSE DB  'PAUSE', 0Dh, 0Ah, '$'
        .CODE

; --- Symboles exportes (PUBLIC) ---
        PUBLIC _FP_HELLO


; --- _FRT_IPOW : AX=base, CX=exp -> AX=resultat ---
_FRT_IPOW  PROC NEAR
        PUSH BX
        TEST CX, CX
        JG   _IPOW_pos
        MOV  AX, 1          ; exp<=0 -> return 1
        POP  BX
        RET
_IPOW_pos:
        MOV  BX, AX         ; BX = base
        MOV  AX, 1          ; AX = accumulator
_IPOW_loop:
        IMUL BX              ; DX:AX = AX * BX
        LOOP _IPOW_loop
        POP  BX
        RET
_FRT_IPOW  ENDP

; --- _FRT_PRINT_NL : CR+LF ---
_FRT_PRINT_NL  PROC NEAR
        PUSH DX
        MOV  AH, 02h
        MOV  DL, 0Dh
        INT  21h
        MOV  DL, 0Ah
        INT  21h
        POP  DX
        RET
_FRT_PRINT_NL  ENDP

; --- _FRT_PRINT_I : AX=entier -> decimal ---
_FRT_PRINT_I  PROC NEAR
        PUSH BX
        PUSH CX
        PUSH DX
        TEST AX, AX
        JGE  _PRI_pos
        PUSH AX
        MOV  AH, 02h
        MOV  DL, 2Dh         ; '-'
        INT  21h
        POP  AX
        NEG  AX
_PRI_pos:
        MOV  BX, 10
        MOV  CX, 0           ; compteur de chiffres
_PRI_divl:
        XOR  DX, DX
        DIV  BX              ; AX=quot, DX=reste
        PUSH DX              ; empiler le chiffre
        INC  CX
        TEST AX, AX
        JNZ  _PRI_divl
_PRI_prtl:
        POP  DX
        ADD  DL, 30h         ; '0'+chiffre
        MOV  AH, 02h
        INT  21h
        LOOP _PRI_prtl
        POP  DX
        POP  CX
        POP  BX
        RET
_FRT_PRINT_I  ENDP

; --- _FRT_PRINT_S : AX=ptr, CX=len -> afficher la chaine ---
_FRT_PRINT_S  PROC NEAR
        PUSH BX
        PUSH CX
        PUSH DX
        PUSH SI
        MOV  SI, AX
        TEST CX, CX
        JZ   _PRS_done
_PRS_loop:
        MOV  DL, [SI]
        INC  SI
        MOV  AH, 02h
        INT  21h
        LOOP _PRS_loop
_PRS_done:
        POP  SI
        POP  DX
        POP  CX
        POP  BX
        RET
_FRT_PRINT_S  ENDP

; --- _FRT_PRINT_L : AX=0->.FALSE. sinon .TRUE. ---
_FRT_PRINT_L  PROC NEAR
        PUSH DX
        TEST AX, AX
        JZ   _PRL_false
        ; Afficher .TRUE.
        MOV  AH, 02h
        MOV  DL, 2Eh  ; '.'
        INT  21h
        MOV  DL, 54h  ; T
        INT  21h
        MOV  DL, 52h  ; R
        INT  21h
        MOV  DL, 55h  ; U
        INT  21h
        MOV  DL, 45h  ; E
        INT  21h
        MOV  DL, 2Eh  ; '.'
        INT  21h
        JMP  _PRL_done
_PRL_false:
        MOV  AH, 02h
        MOV  DL, 2Eh  ; '.'
        INT  21h
        MOV  DL, 46h  ; F
        INT  21h
        MOV  DL, 41h  ; A
        INT  21h
        MOV  DL, 4Ch  ; L
        INT  21h
        MOV  DL, 53h  ; S
        INT  21h
        MOV  DL, 45h  ; E
        INT  21h
        MOV  DL, 2Eh  ; '.'
        INT  21h
_PRL_done:
        POP  DX
        RET
_FRT_PRINT_L  ENDP

; --- _FRT_READ_I : lire un entier -> AX ---
_FRT_READ_I  PROC NEAR
        PUSH BX
        PUSH CX
        PUSH DX
        XOR  AX, AX          ; accumulateur
        MOV  BX, 1           ; signe +
; Ignorer espaces initiaux
_RDI_sp:
        MOV  AH, 08h         ; lire sans echo
        INT  21h
        MOV  DL, AL          ; echo manuel
        MOV  AH, 02h
        INT  21h
        CMP  AL, 20h
        JE   _RDI_sp
        CMP  AL, 09h         ; TAB
        JE   _RDI_sp
; Signe ?
        CMP  AL, 2Dh         ; '-'
        JNE  _RDI_nsg
        MOV  BX, -1
        MOV  AH, 08h
        INT  21h
        MOV  DL, AL
        MOV  AH, 02h
        INT  21h
_RDI_nsg:
; Lire les chiffres
        XOR  AX, AX
        MOV  CX, 10
_RDI_dg:
        CMP  AL, 30h
        JB   _RDI_dn
        CMP  AL, 39h
        JA   _RDI_dn
        SUB  AL, 30h
        XCHG AX, DX          ; DX = AX (ancien), AX = chiffre
        PUSH AX
        MOV  AX, DX
        IMUL CX              ; DX:AX = ancien*10
        POP  DX              ; DX = chiffre
        ADD  AX, DX
        MOV  AH, 08h
        INT  21h
        MOV  DL, AL
        PUSH AX
        MOV  AH, 02h
        INT  21h
        POP  AX
        JMP  _RDI_dg
_RDI_dn:
        IMUL BX              ; appliquer le signe
        POP  DX
        POP  CX
        POP  BX
        RET
_FRT_READ_I  ENDP

; --- _FRT_READ_NL : vider tampon -> CR ---
_FRT_READ_NL  PROC NEAR
        PUSH AX
        PUSH DX
_RNLI_loop:
        MOV  AH, 08h
        INT  21h
        CMP  AL, 0Dh
        JNE  _RNLI_loop
        POP  DX
        POP  AX
        RET
_FRT_READ_NL  ENDP

; --- _FRT_SCOPY(dst_addr,dst_len,src_addr,src_len) ---
_FRT_SCOPY  PROC NEAR
        PUSH BP
        MOV  BP, SP
        PUSH BX
        PUSH CX
        PUSH DX
        PUSH SI
        PUSH DI
        MOV  DI, WORD PTR [BP+4]  ; dst_addr
        MOV  CX, WORD PTR [BP+6]  ; dst_len
        MOV  SI, WORD PTR [BP+8]  ; src_addr
        MOV  BX, WORD PTR [BP+10] ; src_len
        TEST CX, CX
        JZ   _SCPY_done
_SCPY_loop:
        TEST BX, BX
        JZ   _SCPY_pad
        MOV  AL, [SI]
        INC  SI
        DEC  BX
        JMP  _SCPY_wr
_SCPY_pad:
        MOV  AL, 20h           ; espace
_SCPY_wr:
        MOV  [DI], AL
        INC  DI
        LOOP _SCPY_loop
_SCPY_done:
        POP  DI
        POP  SI
        POP  DX
        POP  CX
        POP  BX
        POP  BP
        RET
_FRT_SCOPY  ENDP

; --- _FRT_SCMP(ptr1,len1,ptr2,len2) -> AX ---
_FRT_SCMP  PROC NEAR
        PUSH BP
        MOV  BP, SP
        PUSH BX
        PUSH CX
        PUSH DX
        PUSH SI
        PUSH DI
        MOV  SI, WORD PTR [BP+4]   ; ptr1
        MOV  CX, WORD PTR [BP+6]   ; len1
        MOV  DI, WORD PTR [BP+8]   ; ptr2
        MOV  DX, WORD PTR [BP+10]  ; len2
; Comparer min(len1,len2) caracteres
        MOV  BX, CX
        CMP  BX, DX
        JBE  _SCM_mc
        MOV  BX, DX
_SCM_mc:
        TEST BX, BX
        JZ   _SCM_rest
_SCM_loop:
        MOV  AL, [SI]
        MOV  AH, [DI]
        INC  SI
        INC  DI
        CMP  AL, AH
        JB   _SCM_lt
        JA   _SCM_gt
        DEC  BX
        JNZ  _SCM_loop
_SCM_rest:
; Chaines egales sur min(len) : comparer les longueurs
        CMP  CX, DX
        JB   _SCM_lt
        JA   _SCM_gt
        XOR  AX, AX
        JMP  _SCM_done
_SCM_lt:
        MOV  AX, -1
        JMP  _SCM_done
_SCM_gt:
        MOV  AX, 1
_SCM_done:
        POP  DI
        POP  SI
        POP  DX
        POP  CX
        POP  BX
        POP  BP
        RET
_FRT_SCMP  ENDP

; --- _FRT_SCAT(addr_g,len_g,addr_d,len_d) -> AX=buf,CX=len ---
_FRT_SCAT  PROC NEAR
        PUSH BP
        MOV  BP, SP
        PUSH BX
        PUSH DX
        PUSH SI
        PUSH DI
        MOV  DI, OFFSET _FRT_SCAT_BUF
        MOV  SI, WORD PTR [BP+4]   ; addr_g
        MOV  CX, WORD PTR [BP+6]   ; len_g
        MOV  BX, WORD PTR [BP+8]   ; addr_d
        MOV  DX, WORD PTR [BP+10]  ; len_d
; Copier gauche
        PUSH CX
        TEST CX, CX
        JZ   _SCAT_d
_SCAT_gl:
        MOV  AL, [SI]
        MOV  [DI], AL
        INC  SI
        INC  DI
        LOOP _SCAT_gl
_SCAT_d:
; Copier droite
        MOV  SI, BX
        MOV  CX, DX
        TEST CX, CX
        JZ   _SCAT_fin
_SCAT_dr:
        MOV  AL, [SI]
        MOV  [DI], AL
        INC  SI
        INC  DI
        LOOP _SCAT_dr
_SCAT_fin:
        POP  CX              ; CX = len_g
        ADD  CX, DX          ; CX = len_g + len_d
        MOV  AX, OFFSET _FRT_SCAT_BUF
        POP  DI
        POP  SI
        POP  DX
        POP  BX
        POP  BP
        RET
_FRT_SCAT  ENDP

; --- _FRT_STOP_0 : exit code 0 ---
_FRT_STOP_0  PROC NEAR
        MOV  AX, 4C00h
        INT  21h
_FRT_STOP_0  ENDP

; --- _FRT_STOP_N : AX=n, afficher puis exit ---
_FRT_STOP_N  PROC NEAR
        PUSH AX
        CALL _FRT_PRINT_I
        CALL _FRT_PRINT_NL
        POP  AX
        MOV  AH, 4Ch
        INT  21h
_FRT_STOP_N  ENDP

; --- _FRT_PAUSE : AX=code, afficher et attendre ---
_FRT_PAUSE  PROC NEAR
        PUSH DX
        TEST AX, AX
        JZ   _PAUSE_nn
        PUSH AX
        CALL _FRT_PRINT_I
        CALL _FRT_PRINT_NL
        POP  AX
_PAUSE_nn:
        MOV  AH, 09h
        MOV  DX, OFFSET _FRT_MSG_PAUSE
        INT  21h            ; afficher PAUSE
        MOV  AH, 08h
        INT  21h            ; attendre touche
        POP  DX
        RET
_FRT_PAUSE  ENDP

; --- _FRT_ITOF : [SP+4]=int16 -> DX:AX=float32 ---
_FRT_ITOF  PROC NEAR
        PUSH BP
        MOV  BP, SP
        PUSH BX
        PUSH CX
        PUSH SI
        MOV  AX, WORD PTR [BP+4]   ; AX = entier
        XOR  SI, SI
        TEST AX, AX
        JNZ  _ITOF_nz
        XOR  DX, DX           ; return 0.0
        JMP  _ITOF_done
_ITOF_nz:
        JGE  _ITOF_pos
        MOV  SI, 8000h        ; bit signe negatif
        NEG  AX
_ITOF_pos:
; Normaliser : decaler gauche jusqu'a bit 15 = 1
        MOV  CX, 0
_ITOF_norm:
        TEST AX, 8000h
        JNZ  _ITOF_normed
        SHL  AX, 1
        INC  CX
        JMP  _ITOF_norm
_ITOF_normed:
; AX=norme, CX=nb decalages, exp=142-CX
        PUSH AX              ; sauver valeur normalisee
        MOV  DX, 142
        SUB  DX, CX          ; DX = exposant
        MOV  BX, 7
        MOV  CL, BL          ; CL = 7
        SHL  DX, CL          ; DX = exp << 7 (bits [14:7])
        POP  AX              ; AX = valeur normalisee
        PUSH AX
        MOV  BX, AX
        MOV  CL, 8
        SHR  BX, CL          ; BX = AX >> 8 = N[15:8]
        AND  BX, 007Fh       ; BX = N[14:8] (7 bits mantisse haute)
        OR   DX, BX          ; DX |= mantisse haute
        OR   DX, SI          ; DX |= bit signe
; AX = (N[7:0]) << 8
        POP  AX
        AND  AX, 00FFh       ; AX = N[7:0]
        MOV  AH, AL          ; AH = N[7:0]
        XOR  AL, AL          ; AL = 0
_ITOF_done:
        POP  SI
        POP  CX
        POP  BX
        POP  BP
        RET
_FRT_ITOF  ENDP

; --- _FRT_FTOI : [SP+4]=lo,[SP+6]=hi -> AX=int16 ---
_FRT_FTOI  PROC NEAR
        PUSH BP
        MOV  BP, SP
        PUSH BX
        PUSH CX
        PUSH DX
        PUSH SI
        MOV  DX, WORD PTR [BP+6]   ; DX = mot haut du float
        MOV  AX, WORD PTR [BP+4]   ; AX = mot bas
        MOV  SI, DX
        AND  SI, 8000h             ; SI = bit signe
; Extraire exposant : DX[14:7]
        MOV  BX, DX
        AND  BX, 7F80h
        MOV  CL, 7
        SHR  BX, CL                ; BX = exposant biais
        CMP  BX, 127
        JB   _FTOI_zero            ; |val| < 1 -> 0
        CMP  BX, 142
        JA   _FTOI_ovfl            ; > 32767 -> saturer
; Reconstituer la mantisse avec bit implicite
        AND  DX, 007Fh
        OR   DX, 0080h             ; DX[7:0] = mantisse[23:16] avec bit implicite
        SUB  BX, 127               ; BX = exposant reel (0..15)
; Construire {DX[7:0],AX[15:8]} dans CX
        PUSH BX
        MOV  CL, 8
        SHL  DX, CL                ; DX = DX[7:0] << 8
        SHR  AX, CL                ; AX = AX[15:8]
        OR   DX, AX                ; DX = {mantisse[23:16],mantisse[15:8]}
; Decaler droite de (15-exp) positions
        POP  BX
        MOV  CX, 15
        SUB  CX, BX                ; CX = 15-exp
        JZ   _FTOI_ns
        MOV  CL, CL
_FTOI_shr:
        SHR  DX, 1
        LOOP _FTOI_shr
_FTOI_ns:
        MOV  AX, DX
        TEST SI, SI
        JZ   _FTOI_done
        NEG  AX
        JMP  _FTOI_done
_FTOI_zero:
        XOR  AX, AX
        JMP  _FTOI_done
_FTOI_ovfl:
        TEST SI, SI
        JZ   _FTOI_op
        MOV  AX, 8000h
        JMP  _FTOI_done
_FTOI_op:
        MOV  AX, 7FFFh
_FTOI_done:
        POP  SI
        POP  DX
        POP  CX
        POP  BX
        POP  BP
        RET
_FRT_FTOI  ENDP

; --- _FRT_FADD / FSUB / FMUL / FDIV / FCMP : stubs ---
_FRT_FADD  PROC NEAR
        MOV  AX, WORD PTR [SP+4]
        MOV  DX, WORD PTR [SP+6]
        RET
_FRT_FADD  ENDP

_FRT_FSUB  PROC NEAR
        MOV  AX, WORD PTR [SP+4]
        MOV  DX, WORD PTR [SP+6]
        RET
_FRT_FSUB  ENDP

_FRT_FMUL  PROC NEAR
        XOR  AX, AX
        XOR  DX, DX
        RET
_FRT_FMUL  ENDP

_FRT_FDIV  PROC NEAR
        XOR  AX, AX
        XOR  DX, DX
        RET
_FRT_FDIV  ENDP

_FRT_FCMP  PROC NEAR
        XOR  AX, AX
        RET
_FRT_FCMP  ENDP

_FRT_FMOD  PROC NEAR
        XOR  AX, AX
        XOR  DX, DX
        RET
_FRT_FMOD  ENDP

_FRT_FDIM  PROC NEAR
        XOR  AX, AX
        XOR  DX, DX
        RET
_FRT_FDIM  ENDP

_FRT_FSIGN PROC NEAR
        MOV  AX, WORD PTR [SP+4]
        MOV  DX, WORD PTR [SP+6]
        RET
_FRT_FSIGN ENDP

_FRT_FMIN  PROC NEAR
        MOV  AX, WORD PTR [SP+4]
        MOV  DX, WORD PTR [SP+6]
        RET
_FRT_FMIN  ENDP

_FRT_FMAX  PROC NEAR
        MOV  AX, WORD PTR [SP+4]
        MOV  DX, WORD PTR [SP+6]
        RET
_FRT_FMAX  ENDP

_FRT_SQRT  PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_SQRT  ENDP

_FRT_EXP   PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_EXP   ENDP

_FRT_LOG   PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_LOG   ENDP

_FRT_LOG10 PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_LOG10 ENDP

_FRT_SIN   PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_SIN   ENDP

_FRT_COS   PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_COS   ENDP

_FRT_TAN   PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_TAN   ENDP

_FRT_ASIN  PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_ASIN  ENDP

_FRT_ACOS  PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_ACOS  ENDP

_FRT_ATAN  PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_ATAN  ENDP

_FRT_ATAN2 PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_ATAN2 ENDP

_FRT_SINH  PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_SINH  ENDP

_FRT_COSH  PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_COSH  ENDP

_FRT_TANH  PROC NEAR
        XOR AX,AX
        XOR DX,DX
        RET
_FRT_TANH  ENDP

; --- _FRT_LNBLNK : AX=ptr, CX=len -> AX=longueur effective ---
_FRT_LNBLNK  PROC NEAR
        PUSH BX
        PUSH SI
        MOV  SI, AX
        ADD  SI, CX          ; SI = ptr + len (apres la fin)
        DEC  SI              ; SI = ptr + len - 1 (dernier char)
        MOV  BX, CX          ; BX = longueur courante
_LNB_loop:
        TEST BX, BX
        JZ   _LNB_done
        CMP  BYTE PTR [SI], 20h
        JNE  _LNB_done
        DEC  SI
        DEC  BX
        JMP  _LNB_loop
_LNB_done:
        MOV  AX, BX
        POP  SI
        POP  BX
        RET
_FRT_LNBLNK  ENDP

; --- _FRT_INDEX(s,ls,p,lp) -> AX=position (1-base) ou 0 ---
_FRT_INDEX  PROC NEAR
        PUSH BP
        MOV  BP, SP
        PUSH BX
        PUSH CX
        PUSH DX
        PUSH SI
        PUSH DI
        MOV  SI, WORD PTR [BP+4]   ; ptr_s
        MOV  CX, WORD PTR [BP+6]   ; len_s
        MOV  DI, WORD PTR [BP+8]   ; ptr_p
        MOV  DX, WORD PTR [BP+10]  ; len_p
        XOR  AX, AX               ; resultat = 0 (non trouve)
        TEST DX, DX
        JZ   _IDX_done             ; pattern vide -> 0
        MOV  BX, 0                 ; position courante (0-base)
_IDX_outer:
        MOV  AX, CX
        SUB  AX, BX
        CMP  AX, DX
        JB   _IDX_nf              ; plus assez de chars
        PUSH SI
        PUSH DI
        PUSH BX
        PUSH CX
        MOV  SI, WORD PTR [BP+4]
        ADD  SI, BX               ; SI = ptr_s + pos
        MOV  DI, WORD PTR [BP+8]
        MOV  CX, DX
_IDX_inner:
        MOV  AL, [SI]
        CMP  AL, [DI]
        JNE  _IDX_mism
        INC  SI
        INC  DI
        LOOP _IDX_inner
        POP  CX
        POP  BX
        POP  DI
        POP  SI
        MOV  AX, BX
        INC  AX                   ; convertir en 1-base
        JMP  _IDX_done
_IDX_mism:
        POP  CX
        POP  BX
        POP  DI
        POP  SI
        INC  BX
        JMP  _IDX_outer
_IDX_nf:
        XOR  AX, AX
_IDX_done:
        POP  DI
        POP  SI
        POP  DX
        POP  CX
        POP  BX
        POP  BP
        RET
_FRT_INDEX  ENDP

; ============================================================
; Fin du runtime F77C86
; ============================================================
