comment Test TODO 14 - BOUCLES FOR;
comment Teste les boucles for avec step/until, while, et clauses simples;
begin
  integer i;
  integer s;

  comment Test 1 : boucle for step 1 until (somme 1..5 = 15);
  s := 0;
  for i := 1 step 1 until 5 do
    s := s + i;
  writeln(s);

  comment Test 2 : boucle for step 2 until (1, 3, 5 -> somme = 9);
  s := 0;
  for i := 1 step 2 until 5 do
    s := s + i;
  writeln(s);

  comment Test 3 : boucle for step -1 until (5, 4, 3, 2, 1 -> somme = 15);
  s := 0;
  for i := 5 step -1 until 1 do
    s := s + i;
  writeln(s);

  comment Test 4 : boucle vide (init > limit avec step positif);
  s := 99;
  for i := 10 step 1 until 5 do
    s := 0;
  writeln(s);

  comment Test 5 : boucle for avec bloc begin/end;
  s := 0;
  for i := 1 step 1 until 3 do
  begin
    s := s + i;
    s := s + 1
  end;
  writeln(s);

  comment Test 6 : boucle for avec un seul tour (1 step 1 until 1);
  s := 0;
  for i := 1 step 1 until 1 do
    s := s + i;
  writeln(s);

  comment Test 7 : clause simple (for v := expr do stmt);
  s := 0;
  for i := 42 do
    s := i;
  writeln(s);

  comment Test 8 : boucle for while;
  s := 0;
  i := 1;
  for i := i while i <= 5 do
  begin
    s := s + i;
    i := i + 1
  end;
  writeln(s);

  comment Test 9 : boucle for step 3 until (1, 4, 7, 10 -> somme = 22);
  s := 0;
  for i := 1 step 3 until 10 do
    s := s + i;
  writeln(s);

  comment Test 10 : boucle imbriquee;
  s := 0;
  for i := 1 step 1 until 3 do
    s := s + i * 10;
  writeln(s)
end
