# test_symbols.raku - Test de la table des symboles (TODO 05)

# Variables scalaires my
my $x = 42;
my $y = 10;
my $name = "hello";

# Variable our (package scope)
our $count = 0;

# Constante
my $pi = 3;

# Differents sigils
my $scalar = 1;
my @array;
my %hash;

# Expression avec variable
my $z = $x + $y;

# Affectation composee
$x += 5;
