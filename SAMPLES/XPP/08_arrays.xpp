// Exemple 08 - Tableaux fixes (arrays), indexés à partir de 1
class ArraysDemo
{
    public static void main(Args _args)
    {
        int         tab[5];
        int         i;
        int         total = 0;

        for (i = 1; i <= 5; i++)
        {
            tab[i] = i * i;
        }

        for (i = 1; i <= 5; i++)
        {
            total += tab[i];
            info(strFmt("tab[%1] = %2", i, tab[i]));
        }

        info(strFmt("Somme des carrés = %1", total));
    }
}
